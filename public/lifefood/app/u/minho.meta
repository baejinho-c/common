{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/u/layout,_N_T_/u/[handle]/layout,_N_T_/u/[handle]/page,_N_T_/u/minho"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/u/$d$handle/__PAGE__",
    "/u/$d$handle",
    "/u",
    "/_index",
    "/_head"
  ]
}