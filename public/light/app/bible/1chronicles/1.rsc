2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":1,"verses":[{"id":"10254","book":"역대상","book_name":"역대상","chapter":1,"verse":1,"text":"아담, 셋, 에노스","reference":"역대상 1:1","category":"$undefined"},{"id":"10255","book":"역대상","book_name":"역대상","chapter":1,"verse":2,"text":"게난, 마할랄렐, 야렛","reference":"역대상 1:2","category":"$undefined"},{"id":"10256","book":"역대상","book_name":"역대상","chapter":1,"verse":3,"text":"에녹, 므두셀라","reference":"역대상 1:3","category":"$undefined"},{"id":"10257","book":"역대상","book_name":"역대상","chapter":1,"verse":4,"text":"라멕, 노아, 셈, 함과, 야벳","reference":"역대상 1:4","category":"$undefined"},{"id":"10258","book":"역대상","book_name":"역대상","chapter":1,"verse":5,"text":"야벳의 아들은 고멜과, 마곡과, 마대와, 야완과, 두발과, 메섹과, 디라스요","reference":"역대상 1:5","category":"$undefined"},{"id":"10259","book":"역대상","book_name":"역대상","chapter":1,"verse":6,"text":"고멜의 아들은 아스그나스와, 디밧과, 도갈마요","reference":"역대상 1:6","category":"$undefined"},{"id":"10260","book":"역대상","book_name":"역대상","chapter":1,"verse":7,"text":"야완의 아들은 엘리사와, 다시스와, 깃딤과, 도다님이더라","reference":"역대상 1:7","category":"$undefined"},{"id":"10261","book":"역대상","book_name":"역대상","chapter":1,"verse":8,"text":"함의 아들은 구스와, 미스라임과, 붓과, 가나안이요","reference":"역대상 1:8","category":"$undefined"},{"id":"10262","book":"역대상","book_name":"역대상","chapter":1,"verse":9,"text":"구스의 아들은 스바와, 하윌라와, 삽다와, 라아마와, 삽드가요, 라아마의 아들은 스바와, 드단이요","reference":"역대상 1:9","category":"$undefined"},{"id":"10263","book":"역대상","book_name":"역대상","chapter":1,"verse":10,"text":"구스가 또 니므롯을 낳았으니 세상에 처음 영걸한 자며","reference":"역대상 1:10","category":"$undefined"},{"id":"10264","book":"역대상","book_name":"역대상","chapter":1,"verse":11,"text":"미스라임은 루딤과, 아나밈과, 르하빔과, 납두힘과","reference":"역대상 1:11","category":"$undefined"},{"id":"10265","book":"역대상","book_name":"역대상","chapter":1,"verse":12,"text":"바드루심과, 가슬루힘과, 갑도림을 낳았으니 블레셋 족속은 가슬루힘에게서 나왔으며","reference":"역대상 1:12","category":"$undefined"},{"id":"10266","book":"역대상","book_name":"역대상","chapter":1,"verse":13,"text":"가나안은 맏아들 시돈과, 헷을 낳고","reference":"역대상 1:13","category":"$undefined"},{"id":"10267","book":"역대상","book_name":"역대상","chapter":1,"verse":14,"text":"또 여부스 족속과, 아모리 족속과, 기르가스 족속과","reference":"역대상 1:14","category":"$undefined"},{"id":"10268","book":"역대상","book_name":"역대상","chapter":1,"verse":15,"text":"히위 족속과, 알가 족속과, 신 족속과","reference":"역대상 1:15","category":"$undefined"},{"id":"10269","book":"역대상","book_name":"역대상","chapter":1,"verse":16,"text":"아르왓 족속과, 스말 족속과, 하맛 족속을 낳았더라","reference":"역대상 1:16","category":"$undefined"},{"id":"10270","book":"역대상","book_name":"역대상","chapter":1,"verse":17,"text":"셈의 아들은 엘람과, 앗수르와, 아르박삿과, 룻과, 아람과, 우스와, 훌과, 게델과, 메섹이라","reference":"역대상 1:17","category":"$undefined"},{"id":"10271","book":"역대상","book_name":"역대상","chapter":1,"verse":18,"text":"아르박삿은 셀라를 낳고, 셀라는 에벨을 낳고","reference":"역대상 1:18","category":"$undefined"},{"id":"10272","book":"역대상","book_name":"역대상","chapter":1,"verse":19,"text":"에벨은 두 아들을 낳아 하나의 이름을 벨렉이라 하였으니 이는 그 때에 땅이 나뉘었음이요 그 아우의 이름은 욕단이며","reference":"역대상 1:19","category":"$undefined"},{"id":"10273","book":"역대상","book_name":"역대상","chapter":1,"verse":20,"text":"욕단이 알모닷과, 셀렙과, 하살마웹과, 예라와","reference":"역대상 1:20","category":"$undefined"},{"id":"10274","book":"역대상","book_name":"역대상","chapter":1,"verse":21,"text":"하도람과, 우살과, 디글라와","reference":"역대상 1:21","category":"$undefined"},{"id":"10275","book":"역대상","book_name":"역대상","chapter":1,"verse":22,"text":"에발과, 아비마엘과, 스바와","reference":"역대상 1:22","category":"$undefined"},{"id":"10276","book":"역대상","book_name":"역대상","chapter":1,"verse":23,"text":"오빌과, 하윌라와, 요밥을 낳았으니 욕단의 아들들은 이러하니라","reference":"역대상 1:23","category":"$undefined"},{"id":"10277","book":"역대상","book_name":"역대상","chapter":1,"verse":24,"text":"셈, 아르박삿, 셀라","reference":"역대상 1:24","category":"$undefined"},{"id":"10278","book":"역대상","book_name":"역대상","chapter":1,"verse":25,"text":"에벨, 벨렉, 르우","reference":"역대상 1:25","category":"$undefined"},{"id":"10279","book":"역대상","book_name":"역대상","chapter":1,"verse":26,"text":"스룩, 나홀, 데라","reference":"역대상 1:26","category":"$undefined"},{"id":"10280","book":"역대상","book_name":"역대상","chapter":1,"verse":27,"text":"아브람 곧 아브라함","reference":"역대상 1:27","category":"$undefined"},{"id":"10281","book":"역대상","book_name":"역대상","chapter":1,"verse":28,"text":"아브라함의 아들은 이삭과, 이스마엘이라","reference":"역대상 1:28","category":"$undefined"},{"id":"10282","book":"역대상","book_name":"역대상","chapter":1,"verse":29,"text":"이스마엘의 세계는 이러하니 그 맏아들은 느바욧이요, 다음은 게달과, 앗브엘과, 밉삼과","reference":"역대상 1:29","category":"$undefined"},{"id":"10283","book":"역대상","book_name":"역대상","chapter":1,"verse":30,"text":"미스마와, 두마와, 맛사와, 하닷과, 데마와","reference":"역대상 1:30","category":"$undefined"},{"id":"10284","book":"역대상","book_name":"역대상","chapter":1,"verse":31,"text":"여둘과, 나비스와, 게드마라 이스마엘의 아들들은 이러하니라","reference":"역대상 1:31","category":"$undefined"},{"id":"10285","book":"역대상","book_name":"역대상","chapter":1,"verse":32,"text":"아브라함의 첩 그두라의 낳은 아들은 시므란과, 욕산과, 므단과, 미디안과, 이스박과, 수아요 욕산의 아들은 스바와, 드단이요","reference":"역대상 1:32","category":"$undefined"},{"id":"10286","book":"역대상","book_name":"역대상","chapter":1,"verse":33,"text":"미디안의 아들은 에바와, 에벨과, 하녹과, 아비다와, 엘다아니 그두라의 아들들은 이러하니라","reference":"역대상 1:33","category":"$undefined"},{"id":"10287","book":"역대상","book_name":"역대상","chapter":1,"verse":34,"text":"아브라함이 이삭을 낳았으니 이삭의 아들은 에서와, 이스라엘이더라","reference":"역대상 1:34","category":"$undefined"},{"id":"10288","book":"역대상","book_name":"역대상","chapter":1,"verse":35,"text":"에서의 아들은 엘리바스와, 르우엘과, 여우스와, 얄람과, 고라요,","reference":"역대상 1:35","category":"$undefined"},{"id":"10289","book":"역대상","book_name":"역대상","chapter":1,"verse":36,"text":"엘리바스의 아들은 데만과, 오말과, 스비와, 가담과, 그나스와, 딤나와, 아말렉이요,","reference":"역대상 1:36","category":"$undefined"},{"id":"10290","book":"역대상","book_name":"역대상","chapter":1,"verse":37,"text":"르우엘의 아들은 나핫과, 세라와, 삼마와, 밋사요,","reference":"역대상 1:37","category":"$undefined"},{"id":"10291","book":"역대상","book_name":"역대상","chapter":1,"verse":38,"text":"세일의 아들은 로단과, 소발과, 시브온과, 아나와, 디손과, 에셀과, 디산이요,","reference":"역대상 1:38","category":"$undefined"},{"id":"10292","book":"역대상","book_name":"역대상","chapter":1,"verse":39,"text":"로단의 아들은 호리와, 호맘이요, 로단의 누이는 딤나요,","reference":"역대상 1:39","category":"$undefined"},{"id":"10293","book":"역대상","book_name":"역대상","chapter":1,"verse":40,"text":"소발의 아들은 알랸과, 마나핫과, 에발과, 스비와, 오남이요 시브온의 아들은 아야와, 아나요,","reference":"역대상 1:40","category":"$undefined"},{"id":"10294","book":"역대상","book_name":"역대상","chapter":1,"verse":41,"text":"아나의 아들은 디손이요 디손의 아들은 하므란과, 에스반과, 이드란과, 그란이요,","reference":"역대상 1:41","category":"$undefined"},{"id":"10295","book":"역대상","book_name":"역대상","chapter":1,"verse":42,"text":"에셀의 아들은 빌한과, 사아완과, 야아간이요 디산의 아들은 우스와, 아란이더라","reference":"역대상 1:42","category":"$undefined"},{"id":"10296","book":"역대상","book_name":"역대상","chapter":1,"verse":43,"text":"이스라엘 자손을 치리하는 왕이 있기 전에 에돔 땅을 다스린 왕이 이러하니라 브올의 아들 벨라니 그 도성 이름은 딘하바며","reference":"역대상 1:43","category":"$undefined"},{"id":"10297","book":"역대상","book_name":"역대상","chapter":1,"verse":44,"text":"벨라가 죽으매 보스라 세라의 아들 요밥이 대신하여 왕이 되었고","reference":"역대상 1:44","category":"$undefined"},{"id":"10298","book":"역대상","book_name":"역대상","chapter":1,"verse":45,"text":"요밥이 죽으매 데만 족속의 땅 사람 후삼이 대신하여 왕이 되었고","reference":"역대상 1:45","category":"$undefined"},{"id":"10299","book":"역대상","book_name":"역대상","chapter":1,"verse":46,"text":"후삼이 죽으매 브닷의 아들 하닷이 대신하여 왕이 되었으니 하닷은 모압 들에서 미디안을 친 자요 그 도성 이름은 아윗이며","reference":"역대상 1:46","category":"$undefined"},{"id":"10300","book":"역대상","book_name":"역대상","chapter":1,"verse":47,"text":"하닷이 죽으매 마스레가 사믈라가 대신하여 왕이 되었고","reference":"역대상 1:47","category":"$undefined"},{"id":"10301","book":"역대상","book_name":"역대상","chapter":1,"verse":48,"text":"사믈라가 죽으매 하숫가의 르호봇 사울이 대신하여 왕이 되었고","reference":"역대상 1:48","category":"$undefined"},{"id":"10302","book":"역대상","book_name":"역대상","chapter":1,"verse":49,"text":"사울이 죽으매 악볼의 아들 바알하난이 대신하여 왕이 되었고","reference":"역대상 1:49","category":"$undefined"},{"id":"10303","book":"역대상","book_name":"역대상","chapter":1,"verse":50,"text":"바알하난이 죽으매 하닷이 대신하여 왕이 되었으니 그 도성 이름은 바이요 그 아내의 이름은 므헤다벨이라 메사합의 손녀요 마드렛의 딸이었더라","reference":"역대상 1:50","category":"$undefined"},{"id":"10304","book":"역대상","book_name":"역대상","chapter":1,"verse":51,"text":"하닷이 죽은 후에 에돔의 족장이 이러하니 딤나 족장과, 알랴 족장과, 여뎃 족장과","reference":"역대상 1:51","category":"$undefined"},{"id":"10305","book":"역대상","book_name":"역대상","chapter":1,"verse":52,"text":"오홀리바마 족장과, 엘라 족장과, 비논 족장과","reference":"역대상 1:52","category":"$undefined"},{"id":"10306","book":"역대상","book_name":"역대상","chapter":1,"verse":53,"text":"그나스 족장과, 데만 족장과, 밉살 족장과","reference":"역대상 1:53","category":"$undefined"},{"id":"10307","book":"역대상","book_name":"역대상","chapter":1,"verse":54,"text":"막디엘 족장과, 이람 족장이라 에돔 족장이 이러하였더라","reference":"역대상 1:54","category":"$undefined"}],"bookSlug":"1chronicles"}]
