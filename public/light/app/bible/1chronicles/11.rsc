2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":11,"verses":[{"id":"10675","book":"역대상","book_name":"역대상","chapter":11,"verse":1,"text":"온 이스라엘이 헤브론에 모여 다윗을 보고 가로되 우리는 왕의 골육이니이다","reference":"역대상 11:1","category":"$undefined"},{"id":"10676","book":"역대상","book_name":"역대상","chapter":11,"verse":2,"text":"전일 곧 사울이 왕이 되었을 때에도 이스라엘을 거느려 출입하게 한 자가 왕이시었고 왕의 하나님 여호와께서도 왕에게 말씀하시기를 네가 내 백성 이스라엘의 목자가 되며 내 백성 이스라엘의 주권자가 되리라 하셨나이다 하니라","reference":"역대상 11:2","category":"$undefined"},{"id":"10677","book":"역대상","book_name":"역대상","chapter":11,"verse":3,"text":"이에 이스라엘 모든 장로가 헤브론에 이르러 왕에게 나아오니 다윗이 헤브론에서 여호와 앞에서 저희와 언약을 세우매 저희가 다윗에게 기름을 부어 이스라엘 왕을 삼으니 여호와께서 사무엘로 전하신 말씀대로 되었더라","reference":"역대상 11:3","category":"$undefined"},{"id":"10678","book":"역대상","book_name":"역대상","chapter":11,"verse":4,"text":"다윗이 온 이스라엘로 더불어 예루살렘 곧 여부스에 이르니 여부스 토인이 거기 거하였더라","reference":"역대상 11:4","category":"$undefined"},{"id":"10679","book":"역대상","book_name":"역대상","chapter":11,"verse":5,"text":"여부스 토인이 다윗에게 이르기를 네가 이리로 들어오지 못하리라 하나 다윗이 시온산 성을 빼앗았으니 이는 다윗 성이더라","reference":"역대상 11:5","category":"$undefined"},{"id":"10680","book":"역대상","book_name":"역대상","chapter":11,"verse":6,"text":"다윗이 가로되 먼저 여부스 사람을 치는 자는 두목과 장관을 삼으리라 하였더니 스루야의 아들 요압이 먼저 올라갔으므로 두목이 되었고","reference":"역대상 11:6","category":"$undefined"},{"id":"10681","book":"역대상","book_name":"역대상","chapter":11,"verse":7,"text":"다윗이 그 산성에 거한고로 무리가 다윗성이라 일컬었으며","reference":"역대상 11:7","category":"$undefined"},{"id":"10682","book":"역대상","book_name":"역대상","chapter":11,"verse":8,"text":"다윗이 밀로에서부터 두루 성을 쌓았고 그 남은 성은 요압이 중수하였더라","reference":"역대상 11:8","category":"$undefined"},{"id":"10683","book":"역대상","book_name":"역대상","chapter":11,"verse":9,"text":"만군의 여호와께서 함께 계시니 다윗이 점점 강성하여 가니라","reference":"역대상 11:9","category":"$undefined"},{"id":"10684","book":"역대상","book_name":"역대상","chapter":11,"verse":10,"text":"다윗에게 있는 용사의 두목은 이러하니라 이 사람들이 온 이스라엘로 더불어 다윗의 힘을 도와 나라를 얻게 하고 세워 왕을 삼았으니 이는 여호와께서 이스라엘에 대하여 이르신 말씀대로 함이었더라","reference":"역대상 11:10","category":"$undefined"},{"id":"10685","book":"역대상","book_name":"역대상","chapter":11,"verse":11,"text":"다윗에게 있는 용사의 수효가 이러하니라 학몬 사람의 아들 야소브암은 삼십인의 두목이라 저가 창을 들어 한 때에 삼백인을 죽였고","reference":"역대상 11:11","category":"$undefined"},{"id":"10686","book":"역대상","book_name":"역대상","chapter":11,"verse":12,"text":"그 다음은 아호아 사람 도도의 아들 엘르아살이니 세 용사 중 하나이라","reference":"역대상 11:12","category":"$undefined"},{"id":"10687","book":"역대상","book_name":"역대상","chapter":11,"verse":13,"text":"저가 바스담밈에서 다윗과 함께하였더니 블레셋 사람이 그곳에 모여와서 치니 거기 보리가 많이 난 밭이 있더라 백성들이 블레셋 사람 앞에서 도망하되","reference":"역대상 11:13","category":"$undefined"},{"id":"10688","book":"역대상","book_name":"역대상","chapter":11,"verse":14,"text":"저희가 그 밭 가운데 서서 그 밭을 보호하여 블레셋 사람을 죽였으니 여호와께서 큰 구원으로 구원하심이었더라","reference":"역대상 11:14","category":"$undefined"},{"id":"10689","book":"역대상","book_name":"역대상","chapter":11,"verse":15,"text":"삼십 두목 중 세 사람이 바위로 내려가서 아둘람 굴 다윗에게 이를 때에 블레셋 군대가 르바임 골짜기에 진쳤더라","reference":"역대상 11:15","category":"$undefined"},{"id":"10690","book":"역대상","book_name":"역대상","chapter":11,"verse":16,"text":"그 때에 다윗은 산성에 있고 블레셋 사람의 영채는 베들레헴에 있는지라","reference":"역대상 11:16","category":"$undefined"},{"id":"10691","book":"역대상","book_name":"역대상","chapter":11,"verse":17,"text":"다윗이 사모하여 가로되 베들레헴 성문 곁 우물물을 누가 나로 마시게 할꼬 하매","reference":"역대상 11:17","category":"$undefined"},{"id":"10692","book":"역대상","book_name":"역대상","chapter":11,"verse":18,"text":"이 세 사람이 블레셋 사람의 군대를 충돌하고 지나가서 베들레헴성문 곁 우물물을 길어 가지고 다윗에게로 왔으나 다윗이 마시기를 기뻐아니하고 그 물을 여호와께 부어드리고","reference":"역대상 11:18","category":"$undefined"},{"id":"10693","book":"역대상","book_name":"역대상","chapter":11,"verse":19,"text":"가로되 내 하나님이여 내가 결단코 이런 일을 하지 아니하리이다 생명을 돌아보지 아니하고 갔던 사람들의 피를 어찌 마시리이까 하고 마시기를 즐겨 아니하니라 세 용사가 이런 일을 행하였더라","reference":"역대상 11:19","category":"$undefined"},{"id":"10694","book":"역대상","book_name":"역대상","chapter":11,"verse":20,"text":"요압의 아우 아비새는 그 삼인의 두목이라 저가 창을 들어 삼백인을 죽이고 그 삼인 중에 이름을 얻었으니","reference":"역대상 11:20","category":"$undefined"},{"id":"10695","book":"역대상","book_name":"역대상","chapter":11,"verse":21,"text":"저는 둘째 삼인 중에 가장 존귀하여 저희의 두목이 되었으나 그러나 첫째 삼인에게는 미치지 못하니라","reference":"역대상 11:21","category":"$undefined"},{"id":"10696","book":"역대상","book_name":"역대상","chapter":11,"verse":22,"text":"갑스엘 용사의 손자 여호야다의 아들 브나야는 효용한 일을 행한자라 저가 모압 아리엘의 아들 둘을 죽였고 또 눈 올 때에 함정에 내려가서 한 사자를 죽였으며","reference":"역대상 11:22","category":"$undefined"},{"id":"10697","book":"역대상","book_name":"역대상","chapter":11,"verse":23,"text":"또 장대한 애굽 사람을 죽였는데 그 사람의 키가 다섯 규빗이요 그 손에 든 창이 베틀채 같으나 저가 막대기를 가지고 내려가서 그 애굽 사람의 손에서 창을 빼앗아 그 창으로 죽였더라","reference":"역대상 11:23","category":"$undefined"},{"id":"10698","book":"역대상","book_name":"역대상","chapter":11,"verse":24,"text":"여호야다의 아들 브나야가 이런 일을 행하였으므로 세 용사 중에 이름을 얻고","reference":"역대상 11:24","category":"$undefined"},{"id":"10699","book":"역대상","book_name":"역대상","chapter":11,"verse":25,"text":"삼십인보다 존귀하나 그러나 첫 삼인에게는 미치지 못하니라 다윗이 저를 세워 시위대 장관을 삼았더라","reference":"역대상 11:25","category":"$undefined"},{"id":"10700","book":"역대상","book_name":"역대상","chapter":11,"verse":26,"text":"또 군중의 큰 용사는 요압의 아우 아사헬과 베들레헴 사람 도도의 아들 엘하난과","reference":"역대상 11:26","category":"$undefined"},{"id":"10701","book":"역대상","book_name":"역대상","chapter":11,"verse":27,"text":"하롤 사람 삼훗과 블론 사람 헬레스와","reference":"역대상 11:27","category":"$undefined"},{"id":"10702","book":"역대상","book_name":"역대상","chapter":11,"verse":28,"text":"드고아 사람 익게스의 아들 이라와 아나돗 사람 아비에셀과","reference":"역대상 11:28","category":"$undefined"},{"id":"10703","book":"역대상","book_name":"역대상","chapter":11,"verse":29,"text":"후사 사람 십브개와 아호아 사람 일래와","reference":"역대상 11:29","category":"$undefined"},{"id":"10704","book":"역대상","book_name":"역대상","chapter":11,"verse":30,"text":"느도바 사람 마하래와 느도바 사람 바아나의 아들 헬렛과","reference":"역대상 11:30","category":"$undefined"},{"id":"10705","book":"역대상","book_name":"역대상","chapter":11,"verse":31,"text":"베냐민 자손에 속한 기브아 사람 리배의 아들 이대와 비라돈 사람 브나야와","reference":"역대상 11:31","category":"$undefined"},{"id":"10706","book":"역대상","book_name":"역대상","chapter":11,"verse":32,"text":"가아스 시냇가에 사는 후래와 아르바 사람 아비엘과","reference":"역대상 11:32","category":"$undefined"},{"id":"10707","book":"역대상","book_name":"역대상","chapter":11,"verse":33,"text":"바하룸 사람 아스마웹과 사알본 사람 엘리아바와","reference":"역대상 11:33","category":"$undefined"},{"id":"10708","book":"역대상","book_name":"역대상","chapter":11,"verse":34,"text":"기손 사람 하셈의 아들들과 하랄 사람 사게의 아들 요나단과","reference":"역대상 11:34","category":"$undefined"},{"id":"10709","book":"역대상","book_name":"역대상","chapter":11,"verse":35,"text":"하랄 사람 사갈의 아들 아히암과 울의 아들 엘리발과","reference":"역대상 11:35","category":"$undefined"},{"id":"10710","book":"역대상","book_name":"역대상","chapter":11,"verse":36,"text":"므게랏 사람 헤벨과 블론 사람 아히야와","reference":"역대상 11:36","category":"$undefined"},{"id":"10711","book":"역대상","book_name":"역대상","chapter":11,"verse":37,"text":"갈멜 사람 헤스로와 에스배의 아들 나아래와","reference":"역대상 11:37","category":"$undefined"},{"id":"10712","book":"역대상","book_name":"역대상","chapter":11,"verse":38,"text":"나단의 아우 요엘과 하그리의 아들 밉할과","reference":"역대상 11:38","category":"$undefined"},{"id":"10713","book":"역대상","book_name":"역대상","chapter":11,"verse":39,"text":"암몬 사람 셀렉과 스루야의 아들 요압의 병기 잡은 자 베롯 사람 나하래와","reference":"역대상 11:39","category":"$undefined"},{"id":"10714","book":"역대상","book_name":"역대상","chapter":11,"verse":40,"text":"이델 사람 이라와 이델 사람 가렙과","reference":"역대상 11:40","category":"$undefined"},{"id":"10715","book":"역대상","book_name":"역대상","chapter":11,"verse":41,"text":"헷 사람 우리아와 알래의 아들 사밧과","reference":"역대상 11:41","category":"$undefined"},{"id":"10716","book":"역대상","book_name":"역대상","chapter":11,"verse":42,"text":"르우벤 자손 시사의 아들 곧 르우벤 자손의 두목 아디나와 그 종자 삼십인과","reference":"역대상 11:42","category":"$undefined"},{"id":"10717","book":"역대상","book_name":"역대상","chapter":11,"verse":43,"text":"마아가의 아들 하난과 미덴 사람 요사밧과","reference":"역대상 11:43","category":"$undefined"},{"id":"10718","book":"역대상","book_name":"역대상","chapter":11,"verse":44,"text":"아스드랏 사람 웃시야와 아로엘 사람 호담의 아들 사마와 여이엘과","reference":"역대상 11:44","category":"$undefined"},{"id":"10719","book":"역대상","book_name":"역대상","chapter":11,"verse":45,"text":"시므리의 아들 여디아엘과 그 아우 디스 사람 요하와","reference":"역대상 11:45","category":"$undefined"},{"id":"10720","book":"역대상","book_name":"역대상","chapter":11,"verse":46,"text":"마하위 사람 엘리엘과 엘라암의 아들 여리배와 요사위야와 모압사람 이드마와","reference":"역대상 11:46","category":"$undefined"},{"id":"10721","book":"역대상","book_name":"역대상","chapter":11,"verse":47,"text":"엘리엘과 오벳과 므소바 사람 야아시엘이더라","reference":"역대상 11:47","category":"$undefined"}],"bookSlug":"1chronicles"}]
