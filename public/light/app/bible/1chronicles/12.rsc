2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":12,"verses":[{"id":"10722","book":"역대상","book_name":"역대상","chapter":12,"verse":1,"text":"다윗이 기스의 아들 사울을 인하여 시글락에 숨어 있을 때에 그에게 와서 싸움을 돕는 용사 중에 든 자가 있었으니","reference":"역대상 12:1","category":"$undefined"},{"id":"10723","book":"역대상","book_name":"역대상","chapter":12,"verse":2,"text":"저희는 활을 가지며 좌우 손을 놀려 물매도 던지며 살도 발하는 자요 베냐민 지파 사울의 동족인데 그 이름은 이러하니라","reference":"역대상 12:2","category":"$undefined"},{"id":"10724","book":"역대상","book_name":"역대상","chapter":12,"verse":3,"text":"그 두목은 아히에셀이요 다음은 요아스니 기브아 사람 스마아의 두 아들이요 또 아스마웹의 아들 여시엘과 벨렛과 또 브라가와 아나돗 사람 예후와","reference":"역대상 12:3","category":"$undefined"},{"id":"10725","book":"역대상","book_name":"역대상","chapter":12,"verse":4,"text":"기브온 사람 곧 삼십인 중에 용사요 삼십인의 두목된 이스마야며 또 예레미야와 야하시엘과 요하난과 그데라 사람 요사밧과","reference":"역대상 12:4","category":"$undefined"},{"id":"10726","book":"역대상","book_name":"역대상","chapter":12,"verse":5,"text":"엘루새와 여리못과 브아랴와 스마랴와 하룹 사람 스바댜와","reference":"역대상 12:5","category":"$undefined"},{"id":"10727","book":"역대상","book_name":"역대상","chapter":12,"verse":6,"text":"고라 사람들 엘가나와 잇시야와 아사렐과 요에셀과 야소브암이며","reference":"역대상 12:6","category":"$undefined"},{"id":"10728","book":"역대상","book_name":"역대상","chapter":12,"verse":7,"text":"그돌 사람 여로함의 아들 요엘라와 스바댜더라","reference":"역대상 12:7","category":"$undefined"},{"id":"10729","book":"역대상","book_name":"역대상","chapter":12,"verse":8,"text":"갓 사람 중에서 거친 땅 견고한 곳에 이르러 다윗에게 돌아온 자가 있었으니 다 용사요 싸움에 익숙하여 방패와 창을 능히 쓰는 자라 그 얼굴은 사자 같고 빠르기는 산의 사슴 같으니","reference":"역대상 12:8","category":"$undefined"},{"id":"10730","book":"역대상","book_name":"역대상","chapter":12,"verse":9,"text":"그 두목은 에셀이요 둘째는 오바댜요 세째는 엘리압이요","reference":"역대상 12:9","category":"$undefined"},{"id":"10731","book":"역대상","book_name":"역대상","chapter":12,"verse":10,"text":"네째는 미스만나요 다섯째는 예레미야요","reference":"역대상 12:10","category":"$undefined"},{"id":"10732","book":"역대상","book_name":"역대상","chapter":12,"verse":11,"text":"여섯째는 앗대요 일곱째는 엘리엘이요","reference":"역대상 12:11","category":"$undefined"},{"id":"10733","book":"역대상","book_name":"역대상","chapter":12,"verse":12,"text":"여덟째는 요하난이요 아홉째는 엘사밧이요","reference":"역대상 12:12","category":"$undefined"},{"id":"10734","book":"역대상","book_name":"역대상","chapter":12,"verse":13,"text":"열째는 예레미야요 열 한째는 막반내라","reference":"역대상 12:13","category":"$undefined"},{"id":"10735","book":"역대상","book_name":"역대상","chapter":12,"verse":14,"text":"이 갓 자손이 군대 장관이 되어 그 작은 자는 일백인을 관할하고 그 큰 자는 일천인을 관할하더니","reference":"역대상 12:14","category":"$undefined"},{"id":"10736","book":"역대상","book_name":"역대상","chapter":12,"verse":15,"text":"정월에 요단강 물이 모든 언덕에 넘칠 때에 이 무리가 강물을 건너서 골짜기에 있는 모든 자로 동서로 도망하게 하였더라","reference":"역대상 12:15","category":"$undefined"},{"id":"10737","book":"역대상","book_name":"역대상","chapter":12,"verse":16,"text":"베냐민과 유다 자손 중에서 견고한 곳에 이르러 다윗에게 나오매","reference":"역대상 12:16","category":"$undefined"},{"id":"10738","book":"역대상","book_name":"역대상","chapter":12,"verse":17,"text":"다윗이 나가서 맞아 저희에게 일러 가로되 만일 너희가 평화로이 와서 나를 돕고자 하면 내 마음이 너희와 연합하려니와 만일 너희가 나를 속여 내 대적에게 붙이고자 하면 내 손에 불의함이 없으니 우리 열조의 하나님이 감찰하시고 책망하시기를 원하노라 하매","reference":"역대상 12:17","category":"$undefined"},{"id":"10739","book":"역대상","book_name":"역대상","chapter":12,"verse":18,"text":"때에 성신이 삼십인의 두목 아마새에게 감동하시니 가로되 다윗이여 우리가 당신에게 속하겠고 이새의 아들이여 우리가 당신과 함께하리니 원컨대 평강하소서 당신도 평강하고 당신을 돕는자에게도 평강이 있을지니 이는 당신의 하나님이 당신을 도우심이니이다 한지라 다윗이 드디어 접대하여 세워 군대장관을 삼았더라","reference":"역대상 12:18","category":"$undefined"},{"id":"10740","book":"역대상","book_name":"역대상","chapter":12,"verse":19,"text":"다윗이 전에 블레셋 사람과 함께가서 사울을 치려할때에 므낫세 지파에서 두어 사람이 다윗에게 돌아왔으나 다윗 등이 블레셋 사람을 돕지 못하였음은 블레셋 사람의 방백이 서로 의논하고 보내며 이르기를 저가 그 주 사울에게로 돌아가리니 우리 머리가 위태할까하라 함이라","reference":"역대상 12:19","category":"$undefined"},{"id":"10741","book":"역대상","book_name":"역대상","chapter":12,"verse":20,"text":"다윗이 시글락으로 갈 때에 므낫세 지파에서 그에게로 돌아온 자는 아드나와 요사밧과 여디아엘과 미가엘과 요사밧과 엘리후와 실르대니 다 므낫세의 천부장이라","reference":"역대상 12:20","category":"$undefined"},{"id":"10742","book":"역대상","book_name":"역대상","chapter":12,"verse":21,"text":"이 무리가 다윗을 도와 적당을 쳤으니 저희는 다 큰 용사요 군대 장관이 됨이었더라","reference":"역대상 12:21","category":"$undefined"},{"id":"10743","book":"역대상","book_name":"역대상","chapter":12,"verse":22,"text":"그 때에 사람이 날마다 다윗에게로 돌아와서 돕고자 하매 큰 군대를 이루어 하나님의 군대와 같았더라","reference":"역대상 12:22","category":"$undefined"},{"id":"10744","book":"역대상","book_name":"역대상","chapter":12,"verse":23,"text":"싸움을 예비한 군대 장관들이 헤브론에 이르러 다윗에게로 나아와서 여호와의 말씀대로 사울의 나라를 저에게 돌리고자 하였으니 그 수효가 이러하였더라","reference":"역대상 12:23","category":"$undefined"},{"id":"10745","book":"역대상","book_name":"역대상","chapter":12,"verse":24,"text":"유다 자손 중에서 방패와 창을 들고 싸움을 예비한 자가 육천 팔백명이요","reference":"역대상 12:24","category":"$undefined"},{"id":"10746","book":"역대상","book_name":"역대상","chapter":12,"verse":25,"text":"시므온 자손 중에서 싸움하는 큰 용사가 칠천 일백명이요","reference":"역대상 12:25","category":"$undefined"},{"id":"10747","book":"역대상","book_name":"역대상","chapter":12,"verse":26,"text":"레위 자손 중에서 사천 육백명이요","reference":"역대상 12:26","category":"$undefined"},{"id":"10748","book":"역대상","book_name":"역대상","chapter":12,"verse":27,"text":"아론의 집 족장 여호야다와 그와 함께한 자가 삼천 칠백명이요","reference":"역대상 12:27","category":"$undefined"},{"id":"10749","book":"역대상","book_name":"역대상","chapter":12,"verse":28,"text":"또 젊은 용사 사독과 그 족속의 장관이 이십 이명이요","reference":"역대상 12:28","category":"$undefined"},{"id":"10750","book":"역대상","book_name":"역대상","chapter":12,"verse":29,"text":"베냐민 자손 곧 사울의 동족은 아직도 태반이나 사울의 집을 좇으나 그 중에서 나아온 자가 삼천명이요","reference":"역대상 12:29","category":"$undefined"},{"id":"10751","book":"역대상","book_name":"역대상","chapter":12,"verse":30,"text":"에브라임 자손 중에서 본 족속의 유명한 큰 용사가 이만 팔백명이요","reference":"역대상 12:30","category":"$undefined"},{"id":"10752","book":"역대상","book_name":"역대상","chapter":12,"verse":31,"text":"므낫세 반 지파 중에 녹명된 자로서 와서 다윗을 세워 왕을 삼으려 하는 자가 일만 팔천명이요","reference":"역대상 12:31","category":"$undefined"},{"id":"10753","book":"역대상","book_name":"역대상","chapter":12,"verse":32,"text":"잇사갈 자손 중에서 시세를 알고 이스라엘이 마땅히 행할 것을 아는 두목이 이백명이니 저희는 그 모든 형제를 관할하는 자며","reference":"역대상 12:32","category":"$undefined"},{"id":"10754","book":"역대상","book_name":"역대상","chapter":12,"verse":33,"text":"스불론 중에서 모든 군기를 가지고 항오를 정제히 하고 두마음을 품지 아니하고 능히 진에 나아가서 싸움을 잘하는 자가 오만명이요","reference":"역대상 12:33","category":"$undefined"},{"id":"10755","book":"역대상","book_name":"역대상","chapter":12,"verse":34,"text":"납달리 중에서 장관 일천명과 방패와 창을 가지고 함께한 자가 삼만 칠천명이요","reference":"역대상 12:34","category":"$undefined"},{"id":"10756","book":"역대상","book_name":"역대상","chapter":12,"verse":35,"text":"단 자손 중에서 싸움을 잘하는 자가 이만 팔천 륙백명이요","reference":"역대상 12:35","category":"$undefined"},{"id":"10757","book":"역대상","book_name":"역대상","chapter":12,"verse":36,"text":"아셀 중에서 능히 진에 나가서 싸움을 잘하는 자가 사만명이요","reference":"역대상 12:36","category":"$undefined"},{"id":"10758","book":"역대상","book_name":"역대상","chapter":12,"verse":37,"text":"요단 저편 르우벤 자손과 갓 자손과 므낫세 반 지파 중에서 모든 군기를 가지고 능히 싸우는 자가 십이만 명이었더라","reference":"역대상 12:37","category":"$undefined"},{"id":"10759","book":"역대상","book_name":"역대상","chapter":12,"verse":38,"text":"이 모든 군사가 항오를 정제히 하고 다 성심으로 헤브론에 이르러 다윗으로 온 이스라엘 왕을 삼고자 하고 또 이스라엘의 남은 자도 다 일심으로 다윗으로 왕을 삼고자 하여","reference":"역대상 12:38","category":"$undefined"},{"id":"10760","book":"역대상","book_name":"역대상","chapter":12,"verse":39,"text":"무리가 거기서 다윗과 함께 사흘을 지내며 먹고 마셨으니 이는 그 형제가 이미 식물을 예비하였음이며","reference":"역대상 12:39","category":"$undefined"},{"id":"10761","book":"역대상","book_name":"역대상","chapter":12,"verse":40,"text":"또 근처에 있는 자로부터 잇사갈과 스불론과 납달리까지도 식물을 나귀와 약대와 노새와 소에 무수히 실어 왔으니 곧 과자와 무화과병과 건포도와 포도주와 기름이요 소와 양도 많이 가져왔으니 이스라엘 가운데 희락이 있음이었더라","reference":"역대상 12:40","category":"$undefined"}],"bookSlug":"1chronicles"}]
