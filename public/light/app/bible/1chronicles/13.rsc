2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":13,"verses":[{"id":"10762","book":"역대상","book_name":"역대상","chapter":13,"verse":1,"text":"다윗이 천부장과 백부장 곧 모든 장수로 더불어 의논하고","reference":"역대상 13:1","category":"$undefined"},{"id":"10763","book":"역대상","book_name":"역대상","chapter":13,"verse":2,"text":"이스라엘의 온 회중에게 이르되 만일 너희가 선히 여기고 또 우리의 하나님 여호와께로 말미암았으면 우리가 이스라엘 온 땅에 남아있는 우리 형제와 또 저희와 함께 들어있는 성읍에 거하는 제사장과 레위 사람에게 보내어 저희를 우리에게로 모이게하고","reference":"역대상 13:2","category":"$undefined"},{"id":"10764","book":"역대상","book_name":"역대상","chapter":13,"verse":3,"text":"우리가 우리 하나님의 궤를 옮겨 오자 사울 때에는 우리가 궤 앞에서 묻지 아니하였느니라 하매","reference":"역대상 13:3","category":"$undefined"},{"id":"10765","book":"역대상","book_name":"역대상","chapter":13,"verse":4,"text":"뭇 백성이 이 일을 선히 여기므로 온 회중이 그대로 행하겠다 한지라","reference":"역대상 13:4","category":"$undefined"},{"id":"10766","book":"역대상","book_name":"역대상","chapter":13,"verse":5,"text":"이에 다윗이 애굽의 시홀 시내에서부터 하맛 어귀까지 온 이스라엘을 불러 모으고 기럇여아림에서부터 하나님의 궤를 메어 오고자 할새","reference":"역대상 13:5","category":"$undefined"},{"id":"10767","book":"역대상","book_name":"역대상","chapter":13,"verse":6,"text":"다윗이 온 이스라엘을 거느리고 바알라 곧 유다에 속한 기럇여아림에 올라가서 여호와 하나님의 궤를 메어오려 하니 이는 여호와께서 두 그룹 사이에 계시므로 그 이름으로 일컫는 궤라","reference":"역대상 13:6","category":"$undefined"},{"id":"10768","book":"역대상","book_name":"역대상","chapter":13,"verse":7,"text":"하나님의 궤를 새 수레에 싣고 아비나답의 집에서 나오는데 웃사와 아히오는 수레를 몰며","reference":"역대상 13:7","category":"$undefined"},{"id":"10769","book":"역대상","book_name":"역대상","chapter":13,"verse":8,"text":"다윗과 이스라엘 온 무리는 하나님 앞에서 힘을 다하여 뛰놀며 노래하며 수금과 비파와 소고와 제금과 나팔로 주악하니라","reference":"역대상 13:8","category":"$undefined"},{"id":"10770","book":"역대상","book_name":"역대상","chapter":13,"verse":9,"text":"기돈의 타작 마당에 이르러서는 소들이 뛰므로 웃사가 손을 펴서 궤를 붙들었더니","reference":"역대상 13:9","category":"$undefined"},{"id":"10771","book":"역대상","book_name":"역대상","chapter":13,"verse":10,"text":"웃사가 손을 펴서 궤를 붙듦을 인하여 여호와께서 진노하사 치시매 웃사가 거기 하나님 앞에서 죽으니라","reference":"역대상 13:10","category":"$undefined"},{"id":"10772","book":"역대상","book_name":"역대상","chapter":13,"verse":11,"text":"여호와께서 웃사를 충돌하시므로 다윗이 분하여 그곳을 베레스 웃사라 칭하니 그 이름이 오늘날까지 이르니라","reference":"역대상 13:11","category":"$undefined"},{"id":"10773","book":"역대상","book_name":"역대상","chapter":13,"verse":12,"text":"그 날에 다윗이 하나님을 두려워하여 가로되 내가 어찌 하나님의 궤를 내 곳으로 오게 하리요 하고","reference":"역대상 13:12","category":"$undefined"},{"id":"10774","book":"역대상","book_name":"역대상","chapter":13,"verse":13,"text":"궤를 옮겨 다윗성 자기에게 메어들이지 못하고 치우쳐 가드 사람 오벧에돔의 집으로 메어가니라","reference":"역대상 13:13","category":"$undefined"},{"id":"10775","book":"역대상","book_name":"역대상","chapter":13,"verse":14,"text":"하나님의 궤가 오벧에돔의 집에서 그 권속과 함께 석달을 있으니라 여호와께서 오벧에돔의 집과 그 모든 소유에 복을 내리셨더라","reference":"역대상 13:14","category":"$undefined"}],"bookSlug":"1chronicles"}]
