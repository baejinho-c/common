2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":14,"verses":[{"id":"10776","book":"역대상","book_name":"역대상","chapter":14,"verse":1,"text":"두로 왕 히람이 다윗에게 사자들과 백향목과 석수와 목수를 보내어 그 궁궐을 건축하게 하였더라","reference":"역대상 14:1","category":"$undefined"},{"id":"10777","book":"역대상","book_name":"역대상","chapter":14,"verse":2,"text":"다윗이 여호와께서 자기로 이스라엘 왕을 삼으신 줄을 깨달았으니 이는 그 백성 이스라엘을 위하여 나라를 진흥하게 하셨음이더라","reference":"역대상 14:2","category":"$undefined"},{"id":"10778","book":"역대상","book_name":"역대상","chapter":14,"verse":3,"text":"다윗이 예루살렘에서 또 아내들을 취하여 또 자녀를 낳았으니","reference":"역대상 14:3","category":"$undefined"},{"id":"10779","book":"역대상","book_name":"역대상","chapter":14,"verse":4,"text":"예루살렘에서 낳은 아들들의 이름은 삼무아와 소밥과 나단과 솔로몬과","reference":"역대상 14:4","category":"$undefined"},{"id":"10780","book":"역대상","book_name":"역대상","chapter":14,"verse":5,"text":"입할과 엘리수아와 엘벨렛과","reference":"역대상 14:5","category":"$undefined"},{"id":"10781","book":"역대상","book_name":"역대상","chapter":14,"verse":6,"text":"노가와 네벡과 야비아와","reference":"역대상 14:6","category":"$undefined"},{"id":"10782","book":"역대상","book_name":"역대상","chapter":14,"verse":7,"text":"엘리사마와 브엘랴다와 엘리벨렛이었더라","reference":"역대상 14:7","category":"$undefined"},{"id":"10783","book":"역대상","book_name":"역대상","chapter":14,"verse":8,"text":"다윗이 기름 부음을 받아 온 이스라엘의 왕이 되었다 함을 블레셋 사람이 듣고 다윗을 찾으러 다 올라오매 다윗이 듣고 방비하러 나갔으나","reference":"역대상 14:8","category":"$undefined"},{"id":"10784","book":"역대상","book_name":"역대상","chapter":14,"verse":9,"text":"블레셋 사람이 이미 이르러 르바임 골짜기를 침범하였는지라","reference":"역대상 14:9","category":"$undefined"},{"id":"10785","book":"역대상","book_name":"역대상","chapter":14,"verse":10,"text":"다윗이 하나님께 물어 가로되 내가 블레셋 사람을 치러 올라가리이까 주께서 저희를 내 손에 붙이시겠나이까 여호와께서 이르시되 올라가라 내가 저희를 네 손에 붙이리라 하신지라","reference":"역대상 14:10","category":"$undefined"},{"id":"10786","book":"역대상","book_name":"역대상","chapter":14,"verse":11,"text":"이에 무리가 바알부라심으로 올라갔더니 다윗이 거기서 저희를 치고 가로되 하나님이 물을 흩음 같이 내 손으로 내 대적을 흩으셨다 함으로 그 곳 이름을 바알브라심이라 칭하니라","reference":"역대상 14:11","category":"$undefined"},{"id":"10787","book":"역대상","book_name":"역대상","chapter":14,"verse":12,"text":"블레셋 사람이 그 우상을 그곳에 버렸으므로 다윗이 명하여 불에 사르니라","reference":"역대상 14:12","category":"$undefined"},{"id":"10788","book":"역대상","book_name":"역대상","chapter":14,"verse":13,"text":"블레셋 사람이 다시 골짜기를 침범한지라","reference":"역대상 14:13","category":"$undefined"},{"id":"10789","book":"역대상","book_name":"역대상","chapter":14,"verse":14,"text":"다윗이 또 하나님께 묻자온대 하나님이 이르시되 마주 올라가지 말고 저희 뒤로 돌아 뽕나무 수풀 맞은편에서 저희를 엄습하되","reference":"역대상 14:14","category":"$undefined"},{"id":"10790","book":"역대상","book_name":"역대상","chapter":14,"verse":15,"text":"뽕나무 꼭대기에서 걸음 걷는 소리가 들리거든 곧 나가서 싸우라 하나님이 네 앞서 나아가서 블레셋 사람의 군대를 치리라 하신지라","reference":"역대상 14:15","category":"$undefined"},{"id":"10791","book":"역대상","book_name":"역대상","chapter":14,"verse":16,"text":"이에 다윗이 하나님의 명대로 행하여 블레셋 사람의 군대를 쳐서 기브온에서부터 게셀까지 이르렀더니","reference":"역대상 14:16","category":"$undefined"},{"id":"10792","book":"역대상","book_name":"역대상","chapter":14,"verse":17,"text":"다윗의 명성이 열국에 퍼졌고 여호와께서 열국으로 저를 두려워하게 하셨더라","reference":"역대상 14:17","category":"$undefined"}],"bookSlug":"1chronicles"}]
