2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":15,"verses":[{"id":"10793","book":"역대상","book_name":"역대상","chapter":15,"verse":1,"text":"다윗이 다윗성에서 자기를 위하여 궁궐을 세우고 또 하나님의 궤를 위하여 처소를 예비하고 위하여 장막을 치고","reference":"역대상 15:1","category":"$undefined"},{"id":"10794","book":"역대상","book_name":"역대상","chapter":15,"verse":2,"text":"가로되 레위 사람 외에는 하나님의 궤를 멜 수 없나니 이는 여호와께서 저희를 택하사 하나님의 궤를 메고 영원히 저를 섬기게 하셨음이니라 하고","reference":"역대상 15:2","category":"$undefined"},{"id":"10795","book":"역대상","book_name":"역대상","chapter":15,"verse":3,"text":"이스라엘 온 무리를 예루살렘으로 모으고 여호와의 궤를 그 예비한 곳으로 메어 올리고자 하여","reference":"역대상 15:3","category":"$undefined"},{"id":"10796","book":"역대상","book_name":"역대상","chapter":15,"verse":4,"text":"아론 자손과 레위 사람을 모으니","reference":"역대상 15:4","category":"$undefined"},{"id":"10797","book":"역대상","book_name":"역대상","chapter":15,"verse":5,"text":"그핫 자손 중에 족장 우리엘과 그 형제 일백 이십인이요","reference":"역대상 15:5","category":"$undefined"},{"id":"10798","book":"역대상","book_name":"역대상","chapter":15,"verse":6,"text":"므라리 자손 중에 족장 아사야와 그 형제 이백 이십인이요","reference":"역대상 15:6","category":"$undefined"},{"id":"10799","book":"역대상","book_name":"역대상","chapter":15,"verse":7,"text":"게르솜 자손 중에 족장 요엘과 그 형제 일백 삼십인이요","reference":"역대상 15:7","category":"$undefined"},{"id":"10800","book":"역대상","book_name":"역대상","chapter":15,"verse":8,"text":"엘리사반 자손 중에 족장 스마야와 그 형제 이백인이요","reference":"역대상 15:8","category":"$undefined"},{"id":"10801","book":"역대상","book_name":"역대상","chapter":15,"verse":9,"text":"헤브론 자손 중에 족장 엘리엘과 그 형제 팔십인이요","reference":"역대상 15:9","category":"$undefined"},{"id":"10802","book":"역대상","book_name":"역대상","chapter":15,"verse":10,"text":"웃시엘 자손 중에 족장 암미나답과 그 형제 일백 십 이인이라","reference":"역대상 15:10","category":"$undefined"},{"id":"10803","book":"역대상","book_name":"역대상","chapter":15,"verse":11,"text":"다윗이 제사장 사독과 아비아달을 부르고 또 레위 사람 우리엘과 아사야와 요엘과 스마야와 엘리엘과 암미나답을 불러","reference":"역대상 15:11","category":"$undefined"},{"id":"10804","book":"역대상","book_name":"역대상","chapter":15,"verse":12,"text":"저희에게 이르되 너희는 레위 사람의 족장이니 너희와 너희 형제는 몸을 성결케 하고 내가 예비한 곳으로 이스라엘 하나님 여호와의 궤를 메어 올리라","reference":"역대상 15:12","category":"$undefined"},{"id":"10805","book":"역대상","book_name":"역대상","chapter":15,"verse":13,"text":"전에는 너희가 메지 아니하였으므로 우리 하나님 여호와께서 우리를 충돌하셨나니 이는 우리가 규례대로 저에게 구하지 아니하였음이니라","reference":"역대상 15:13","category":"$undefined"},{"id":"10806","book":"역대상","book_name":"역대상","chapter":15,"verse":14,"text":"이에 제사장들과 레위 사람들이 이스라엘 하나님 여호와의 궤를 메고 올라가려 하여 몸을 성결케 하고","reference":"역대상 15:14","category":"$undefined"},{"id":"10807","book":"역대상","book_name":"역대상","chapter":15,"verse":15,"text":"모세가 여호와의 말씀을 따라 명한대로 레위 자손이 채로 하나님의 궤를 꿰어 어깨에 메니라","reference":"역대상 15:15","category":"$undefined"},{"id":"10808","book":"역대상","book_name":"역대상","chapter":15,"verse":16,"text":"다윗이 레위 사람의 어른들에게 명하여 그 형제 노래하는 자를 세우고 비파와 수금과 제금등의 악기를 울려서 즐거운 소리를 크게 내라 하매","reference":"역대상 15:16","category":"$undefined"},{"id":"10809","book":"역대상","book_name":"역대상","chapter":15,"verse":17,"text":"레위 사람이 요엘의 아들 헤만과 그 형제 중 베레야의 아들 아삽과 그 동종 므라리 자손 중에 구사야의 아들 에단을 세우고","reference":"역대상 15:17","category":"$undefined"},{"id":"10810","book":"역대상","book_name":"역대상","chapter":15,"verse":18,"text":"그 다음으로 형제 스가랴와 벤과 야아시엘과 스미라못과 여히엘과 운니와 엘리압과 브나야와 마아세야와 맛디디야와 엘리블레후와 믹네야와 문지기 오벧에돔과 여이엘을 세우니","reference":"역대상 15:18","category":"$undefined"},{"id":"10811","book":"역대상","book_name":"역대상","chapter":15,"verse":19,"text":"노래하는 자 헤만과 아삽과 에단은 놋제금을 크게 치는 자요","reference":"역대상 15:19","category":"$undefined"},{"id":"10812","book":"역대상","book_name":"역대상","chapter":15,"verse":20,"text":"스가랴와 아시엘과 스미라못과 여히엘과 운니와 엘리압과 마아세야와 브나야는 비파를 타서 여창에 맞추는 자요","reference":"역대상 15:20","category":"$undefined"},{"id":"10813","book":"역대상","book_name":"역대상","chapter":15,"verse":21,"text":"맛디디야와 엘리블레후와 믹네야와 오벧에돔과 여이엘과 아사시야는 수금을 타서 여덟째 음에 맞추어 인도하는 자요","reference":"역대상 15:21","category":"$undefined"},{"id":"10814","book":"역대상","book_name":"역대상","chapter":15,"verse":22,"text":"레위 사람의 족장 그나냐는 노래에 익숙하므로 노래를 주장하여 사람에게 가르치는 자요","reference":"역대상 15:22","category":"$undefined"},{"id":"10815","book":"역대상","book_name":"역대상","chapter":15,"verse":23,"text":"베레갸와 엘가나는 궤 앞에서 문을 지키는 자요","reference":"역대상 15:23","category":"$undefined"},{"id":"10816","book":"역대상","book_name":"역대상","chapter":15,"verse":24,"text":"제사장 스바냐와 요사밧과 느다넬과 아미새와 스가랴와 브나야와 엘리에셀은 하나님의 궤 앞에서 나팔을 부는 자요 오벧에돔과 여히야는 궤 앞에서 문을 지키는 자더라","reference":"역대상 15:24","category":"$undefined"},{"id":"10817","book":"역대상","book_name":"역대상","chapter":15,"verse":25,"text":"이에 다윗과 이스라엘 장로들과 천부장들이 가서 여호와의 언약궤를 즐거이 메고 오벧에돔의 집에서 올라왔는데","reference":"역대상 15:25","category":"$undefined"},{"id":"10818","book":"역대상","book_name":"역대상","chapter":15,"verse":26,"text":"하나님이 여호와의 언약궤를 멘 레위 사람을 도우셨으므로 무리가 수송아지 일곱과 수양 일곱으로 제사를 드렸더라","reference":"역대상 15:26","category":"$undefined"},{"id":"10819","book":"역대상","book_name":"역대상","chapter":15,"verse":27,"text":"다윗과 궤를 멘 레위 사람과 노래하는 자와 그 두목 그나냐와 모든 노래하는 자도 다 세마포 겉옷을 입었으며 다윗은 또 베 에봇을 입었고","reference":"역대상 15:27","category":"$undefined"},{"id":"10820","book":"역대상","book_name":"역대상","chapter":15,"verse":28,"text":"이스라엘 무리는 크게 부르며 각과 나팔을 불며 제금을 치며 비파와 수금을 힘있게 타며 여호와의 언약궤를 메어 올렸더라","reference":"역대상 15:28","category":"$undefined"},{"id":"10821","book":"역대상","book_name":"역대상","chapter":15,"verse":29,"text":"여호와의 언약궤가 다윗성으로 들어올 때에 사울의 딸 미갈이 창으로 내어다보다가 다윗 왕의 춤추며 뛰노는 것을 보고 심중에 업신여겼더라","reference":"역대상 15:29","category":"$undefined"}],"bookSlug":"1chronicles"}]
