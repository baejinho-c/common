2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":16,"verses":[{"id":"10822","book":"역대상","book_name":"역대상","chapter":16,"verse":1,"text":"하나님의 궤를 메고 들어가서 다윗이 위하여 친 장막 가운데 두고 번제와 화목제를 하나님 앞에 드리니라","reference":"역대상 16:1","category":"$undefined"},{"id":"10823","book":"역대상","book_name":"역대상","chapter":16,"verse":2,"text":"다윗이 번제와 화목제 드리기를 마치고 여호와의 이름으로 백성에게 축복하고","reference":"역대상 16:2","category":"$undefined"},{"id":"10824","book":"역대상","book_name":"역대상","chapter":16,"verse":3,"text":"또 이스라엘 무리의 무론 남녀하고 매 명에 떡 한 덩이와 고기 한 조각과 건포도병 하나씩 나누어 주었더라","reference":"역대상 16:3","category":"$undefined"},{"id":"10825","book":"역대상","book_name":"역대상","chapter":16,"verse":4,"text":"또 레위 사람을 세워 여호와의 궤 앞에서 섬기며 이스라엘 하나님 여호와를 칭송하며 감사하며 찬양하게 하였으니","reference":"역대상 16:4","category":"$undefined"},{"id":"10826","book":"역대상","book_name":"역대상","chapter":16,"verse":5,"text":"그 두목은 아삽이요 다음은 스가랴와 여이엘과 스미라못과 여히엘과 맛디디아와 엘리압과 브나야와 오벧에돔과 여이엘이라 비파와 수금을 타고 아삽은 제금을 힘있게 치고","reference":"역대상 16:5","category":"$undefined"},{"id":"10827","book":"역대상","book_name":"역대상","chapter":16,"verse":6,"text":"제사장 브나야와 야하시엘은 항상 하나님의 언약궤 앞에서 나팔을 부니라","reference":"역대상 16:6","category":"$undefined"},{"id":"10828","book":"역대상","book_name":"역대상","chapter":16,"verse":7,"text":"그 날에 다윗이 아삽과 그 형제를 세워 위선 여호와께 감사하게 하여 이르기를","reference":"역대상 16:7","category":"$undefined"},{"id":"10829","book":"역대상","book_name":"역대상","chapter":16,"verse":8,"text":"너희는 여호와께 감사하며 그 이름을 불러 아뢰며 그 행사를 만민 중에 알게 할지어다","reference":"역대상 16:8","category":"$undefined"},{"id":"10830","book":"역대상","book_name":"역대상","chapter":16,"verse":9,"text":"그에게 노래하며 그를 찬양하며 그 모든 기사를 말할지어다","reference":"역대상 16:9","category":"$undefined"},{"id":"10831","book":"역대상","book_name":"역대상","chapter":16,"verse":10,"text":"그 성호를 자랑하라 무릇 여호와를 구하는 자는 마음이 즐거울지로다","reference":"역대상 16:10","category":"$undefined"},{"id":"10832","book":"역대상","book_name":"역대상","chapter":16,"verse":11,"text":"여호와와 그 능력을 구할지어다 그 얼굴을 항상 구할지어다","reference":"역대상 16:11","category":"$undefined"},{"id":"10833","book":"역대상","book_name":"역대상","chapter":16,"verse":12,"text":"그 종 이스라엘의 후손 곧 택하신 야곱의 자손 너희는 그 행하신 기사와 그 이적과 그 입의 판단을 기억할지어다","reference":"역대상 16:12","category":"$undefined"},{"id":"10834","book":"역대상","book_name":"역대상","chapter":16,"verse":13,"text":"(12절과 같음)","reference":"역대상 16:13","category":"$undefined"},{"id":"10835","book":"역대상","book_name":"역대상","chapter":16,"verse":14,"text":"그는 여호와 우리 하나님이시라 그의 판단이 온 땅에 있도다","reference":"역대상 16:14","category":"$undefined"},{"id":"10836","book":"역대상","book_name":"역대상","chapter":16,"verse":15,"text":"너희는 그 언약 곧 천대에 명하신 말씀을 영원히 기억할지어다","reference":"역대상 16:15","category":"$undefined"},{"id":"10837","book":"역대상","book_name":"역대상","chapter":16,"verse":16,"text":"이것은 아브라함에게 하신 언약이며 이삭에게 하신 맹세며","reference":"역대상 16:16","category":"$undefined"},{"id":"10838","book":"역대상","book_name":"역대상","chapter":16,"verse":17,"text":"이는 야곱에게 세우신 율례 곧 이스라엘에게 하신 영원한 언약이라","reference":"역대상 16:17","category":"$undefined"},{"id":"10839","book":"역대상","book_name":"역대상","chapter":16,"verse":18,"text":"이르시기를 내가 가나안 땅을 네게 주어 너희 기업의 지경이 되게 하리라 하셨도다","reference":"역대상 16:18","category":"$undefined"},{"id":"10840","book":"역대상","book_name":"역대상","chapter":16,"verse":19,"text":"때에 너희 인수가 적어서 매우 영성하며 그 땅에 객이 되어","reference":"역대상 16:19","category":"$undefined"},{"id":"10841","book":"역대상","book_name":"역대상","chapter":16,"verse":20,"text":"이 족속에게서 저 족속에게로, 이 나라에서 다른 민족에게로 유리하였도다","reference":"역대상 16:20","category":"$undefined"},{"id":"10842","book":"역대상","book_name":"역대상","chapter":16,"verse":21,"text":"사람이 그들을 해하기를 용납지 아니하시고 그들의 연고로 열왕을 꾸짖어","reference":"역대상 16:21","category":"$undefined"},{"id":"10843","book":"역대상","book_name":"역대상","chapter":16,"verse":22,"text":"이르기를 나의 기름 부은 자를 만지지 말며 나의 선지자를 상하지 말라 하셨도다","reference":"역대상 16:22","category":"$undefined"},{"id":"10844","book":"역대상","book_name":"역대상","chapter":16,"verse":23,"text":"온 땅이여 여호와께 노래하며 구원을 날마다 선포할지어다","reference":"역대상 16:23","category":"$undefined"},{"id":"10845","book":"역대상","book_name":"역대상","chapter":16,"verse":24,"text":"그 영광을 열방 중에, 그 기이한 행적을 만민 중에 선포할지어다","reference":"역대상 16:24","category":"$undefined"},{"id":"10846","book":"역대상","book_name":"역대상","chapter":16,"verse":25,"text":"여호와는 광대하시니 극진히 찬양할 것이요 모든 신보다 경외할 것임이여","reference":"역대상 16:25","category":"$undefined"},{"id":"10847","book":"역대상","book_name":"역대상","chapter":16,"verse":26,"text":"만방의 모든 신은 헛것이요 여호와께서는 하늘을 지으셨음이로다","reference":"역대상 16:26","category":"$undefined"},{"id":"10848","book":"역대상","book_name":"역대상","chapter":16,"verse":27,"text":"존귀와 위엄이 그 앞에 있으며 능력과 즐거움이 그 처소에 있도다","reference":"역대상 16:27","category":"$undefined"},{"id":"10849","book":"역대상","book_name":"역대상","chapter":16,"verse":28,"text":"만방의 족속들아 영광과 권능을 여호와께 돌릴지어다 여호와께 돌릴지어다","reference":"역대상 16:28","category":"$undefined"},{"id":"10850","book":"역대상","book_name":"역대상","chapter":16,"verse":29,"text":"여호와의 이름에 합당한 영광을 그에게 돌릴지어다 예물을 가지고 그 앞에 들어갈지어다 아름답고 거룩한 것으로 여호와께 경배할지어다","reference":"역대상 16:29","category":"$undefined"},{"id":"10851","book":"역대상","book_name":"역대상","chapter":16,"verse":30,"text":"온 땅이여 그 앞에서 떨지어다 세계가 굳게 서고 흔들리지 못하는도다","reference":"역대상 16:30","category":"$undefined"},{"id":"10852","book":"역대상","book_name":"역대상","chapter":16,"verse":31,"text":"하늘은 기뻐하고 땅은 즐거워하며 열방 중에서는 이르기를 여호와께서 통치하신다 할지로다","reference":"역대상 16:31","category":"$undefined"},{"id":"10853","book":"역대상","book_name":"역대상","chapter":16,"verse":32,"text":"바다와 거기 충만한 것이 외치며 밭과 그 가운데 모든 것은 즐거워할지로다","reference":"역대상 16:32","category":"$undefined"},{"id":"10854","book":"역대상","book_name":"역대상","chapter":16,"verse":33,"text":"그리 할 때에 삼림의 나무들이 여호와 앞에서 즐거이 노래하리니 주께서 땅을 심판하러 오실 것임이로다","reference":"역대상 16:33","category":"$undefined"},{"id":"10855","book":"역대상","book_name":"역대상","chapter":16,"verse":34,"text":"여호와께 감사하라 그는 선하시며 그 인자하심이 영원함이로다","reference":"역대상 16:34","category":"$undefined"},{"id":"10856","book":"역대상","book_name":"역대상","chapter":16,"verse":35,"text":"너희는 이르기를 우리의 구원의 하나님이여 우리를 구원하여 만국 가운데서 건져 내시고 모으시사 우리로 주의 성호를 감사하며 주의 영예를 찬양하게 하소서 할지어다","reference":"역대상 16:35","category":"$undefined"},{"id":"10857","book":"역대상","book_name":"역대상","chapter":16,"verse":36,"text":"여호와 이스라엘의 하나님을 영원부터 영원까지 송축할지로다 하매 모든 백성이 아멘하고 여호와를 찬양하였더라","reference":"역대상 16:36","category":"$undefined"},{"id":"10858","book":"역대상","book_name":"역대상","chapter":16,"verse":37,"text":"다윗이 아삽과 그 형제를 여호와의 언약궤 앞에 머물러 항상 그 궤 앞에서 섬기게 하되 날마다 그 일대로 하게 하였고","reference":"역대상 16:37","category":"$undefined"},{"id":"10859","book":"역대상","book_name":"역대상","chapter":16,"verse":38,"text":"오벧에돔과 그 형제 육십 팔인과 여두둔의 아들 오벧에돔과 호사로 문지기를 삼았고","reference":"역대상 16:38","category":"$undefined"},{"id":"10860","book":"역대상","book_name":"역대상","chapter":16,"verse":39,"text":"제사장 사독과 그 형제 제사장들로 기브온 산당에서 여호와의 성막 앞에 모시게 하여","reference":"역대상 16:39","category":"$undefined"},{"id":"10861","book":"역대상","book_name":"역대상","chapter":16,"verse":40,"text":"항상 조석으로 번제단 위에 여호와께 번제를 드리되 여호와의 율법에 기록하여 이스라엘에게 명하신대로 다 준행하게 하였고","reference":"역대상 16:40","category":"$undefined"},{"id":"10862","book":"역대상","book_name":"역대상","chapter":16,"verse":41,"text":"또 저희와 함께 헤만과 여두둔과 그 남아 택함을 받고 녹명된자를 세워 여호와의 자비하심이 영원함을 인하여 감사하게 하였고","reference":"역대상 16:41","category":"$undefined"},{"id":"10863","book":"역대상","book_name":"역대상","chapter":16,"verse":42,"text":"또 저희와 함께 헤만과 여두둔을 세워 나팔과 제금들과 하나님을 찬송하는 악기로 소리를 크게 내게 하였고 또 여두둔의 아들로 문을 지키게 하였더라","reference":"역대상 16:42","category":"$undefined"},{"id":"10864","book":"역대상","book_name":"역대상","chapter":16,"verse":43,"text":"이에 뭇 백성은 각각 그 집으로 돌아가고 다윗도 자기 집을 위하여 축복하려고 돌아갔더라","reference":"역대상 16:43","category":"$undefined"}],"bookSlug":"1chronicles"}]
