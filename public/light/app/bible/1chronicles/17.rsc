2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":17,"verses":[{"id":"10865","book":"역대상","book_name":"역대상","chapter":17,"verse":1,"text":"다윗이 그 궁실에 거할 때에 선지자 나단에게 이르되 나는 백향목 궁에 거하거늘 여호와의 언약궤는 휘장 밑에 있도다","reference":"역대상 17:1","category":"$undefined"},{"id":"10866","book":"역대상","book_name":"역대상","chapter":17,"verse":2,"text":"나단이 다윗에게 고하되 하나님이 왕과 함께 계시니 무릇 마음에 있는 바를 행하소서","reference":"역대상 17:2","category":"$undefined"},{"id":"10867","book":"역대상","book_name":"역대상","chapter":17,"verse":3,"text":"그 밤에 하나님의 말씀이 나단에게 임하여 가라사대","reference":"역대상 17:3","category":"$undefined"},{"id":"10868","book":"역대상","book_name":"역대상","chapter":17,"verse":4,"text":"가서 내 종 다윗에게 말하기를 여호와의 말씀이 너는 나의 거할 집을 건축하지 말라","reference":"역대상 17:4","category":"$undefined"},{"id":"10869","book":"역대상","book_name":"역대상","chapter":17,"verse":5,"text":"내가 이스라엘을 올라오게 한날부터 오늘날까지 집에 거하지 아니하고 오직 이 장막과 저 장막에 있으며 이 성막과 저 성막에 있었나니","reference":"역대상 17:5","category":"$undefined"},{"id":"10870","book":"역대상","book_name":"역대상","chapter":17,"verse":6,"text":"무릇 이스라엘 무리로 더불어 행하는 곳에서 내가 내 백성을 먹이라고 명한 이스라엘 어느 사사에게 내가 말하기를 너희가 어찌하여 나를 위하여 백향목 집을 건축하지 아니하였느냐고 말하였느냐 하고","reference":"역대상 17:6","category":"$undefined"},{"id":"10871","book":"역대상","book_name":"역대상","chapter":17,"verse":7,"text":"연하여 내 종 다윗에게 이처럼 말하라 만군의 여호와께서 이처럼 말씀하시기를 내가 너를 목장 곧 양을 따르는 데서 취하여 내 백성 이스라엘의 주권자를 삼고","reference":"역대상 17:7","category":"$undefined"},{"id":"10872","book":"역대상","book_name":"역대상","chapter":17,"verse":8,"text":"네가 어디를 가든지 내가 너와 함께 있어 네 모든 대적을 네 앞에서 멸하였은즉 세상에서 존귀한 자의 이름 같은 이름을 네게 만들어 주리라","reference":"역대상 17:8","category":"$undefined"},{"id":"10873","book":"역대상","book_name":"역대상","chapter":17,"verse":9,"text":"내가 또 내 백성 이스라엘을 위하여 한 곳을 정하여 저희를 심고 저희로 자기 곳에 거하여 다시는 옮기지 않게 하며 악한 유로 전과 같이 저희를 해하지 못하게 하여","reference":"역대상 17:9","category":"$undefined"},{"id":"10874","book":"역대상","book_name":"역대상","chapter":17,"verse":10,"text":"전에 내가 사사를 명하여 내 백성 이스라엘을 다스리던 때와 같지 않게 하고 또 모든 대적으로 네게 복종하게 하리라 또 네게 이르노니 여호와가 너를 위하여 집을 세울지라","reference":"역대상 17:10","category":"$undefined"},{"id":"10875","book":"역대상","book_name":"역대상","chapter":17,"verse":11,"text":"네 수한이 차서 네가 열조에게로 돌아가면 내가 네 뒤에 네씨 곧 네 아들 중 하나를 세우고 그 나라를 견고하게 하리니","reference":"역대상 17:11","category":"$undefined"},{"id":"10876","book":"역대상","book_name":"역대상","chapter":17,"verse":12,"text":"저는 나를 위하여 집을 건축할것이요 나는 그 위를 영원히 견고하게 하리라","reference":"역대상 17:12","category":"$undefined"},{"id":"10877","book":"역대상","book_name":"역대상","chapter":17,"verse":13,"text":"나는 그 아비가 되고 그는 나의 아들이 되리니 나의 자비를 그 에게서 빼앗지 아니하기를 내가 네 전에 있던 자에게서 빼앗음과 같이 하지 않을 것이며","reference":"역대상 17:13","category":"$undefined"},{"id":"10878","book":"역대상","book_name":"역대상","chapter":17,"verse":14,"text":"내가 영영히 그를 내 집과 내 나라에 세우리니 그 위가 영원히 견고하리라 하셨다 하라","reference":"역대상 17:14","category":"$undefined"},{"id":"10879","book":"역대상","book_name":"역대상","chapter":17,"verse":15,"text":"나단이 이 모든 말씀과 이 모든 묵시대로 다윗에게 고하니라","reference":"역대상 17:15","category":"$undefined"},{"id":"10880","book":"역대상","book_name":"역대상","chapter":17,"verse":16,"text":"다윗 왕이 여호와 앞에 들어가 앉아서 가로되 여호와 하나님이여 나는 누구오며 내 집은 무엇이관대 나로 이에 이르게 하셨나이까","reference":"역대상 17:16","category":"$undefined"},{"id":"10881","book":"역대상","book_name":"역대상","chapter":17,"verse":17,"text":"하나님이여 주께서 이것을 오히려 작게 여기시고 또 종의 집에 대하여 먼 장래까지 말씀하셨사오니 여호와 하나님이여 나를 존귀한 자 같이 여기셨나이다","reference":"역대상 17:17","category":"$undefined"},{"id":"10882","book":"역대상","book_name":"역대상","chapter":17,"verse":18,"text":"주께서 주의 종에게 베푸신 존귀에 대하여 다윗이 다시 무슨 말씀을 하오리이까 주께서는 주의 종을 아시나이다","reference":"역대상 17:18","category":"$undefined"},{"id":"10883","book":"역대상","book_name":"역대상","chapter":17,"verse":19,"text":"여호와여 주께서 주의 종을 위하여 주의 뜻대로 이 모든 큰 일을 행하사 이 모든 큰 일을 알게 하셨나이다","reference":"역대상 17:19","category":"$undefined"},{"id":"10884","book":"역대상","book_name":"역대상","chapter":17,"verse":20,"text":"여호와여 우리 귀로 들은 대로는 주와 같은 이가 없고 주 외에는 참 신이 없나이다","reference":"역대상 17:20","category":"$undefined"},{"id":"10885","book":"역대상","book_name":"역대상","chapter":17,"verse":21,"text":"땅의 어느 한 나라가 주의 백성 이스라엘과 같으리이까 하나님이 가서 구속하사 자기 백성을 삼으시고 크고 두려운 일로 인하여 이름을 얻으시고 애굽에서 구속하신 자기 백성 앞에서 열국을 쫓아내셨사오며","reference":"역대상 17:21","category":"$undefined"},{"id":"10886","book":"역대상","book_name":"역대상","chapter":17,"verse":22,"text":"주께서 주의 백성 이스라엘로 영원히 주의 백성을 삼으셨사오니 여호와여 주께서 저희 하나님이 되셨나이다","reference":"역대상 17:22","category":"$undefined"},{"id":"10887","book":"역대상","book_name":"역대상","chapter":17,"verse":23,"text":"여호와여 이제 주의 종과 그 집에 대하여 말씀하신 것을 영원히 견고케 하시며 말씀하신 대로 행하사","reference":"역대상 17:23","category":"$undefined"},{"id":"10888","book":"역대상","book_name":"역대상","chapter":17,"verse":24,"text":"견고케 하시고 사람으로 영원히 주의 이름을 높여 이르기를 만군의 여호와는 이스라엘의 하나님 곧 이스라엘에게 하나님이시라 하게 하시며 주의 종 다윗의 집이 주 앞에서 견고히 서게 하옵소서","reference":"역대상 17:24","category":"$undefined"},{"id":"10889","book":"역대상","book_name":"역대상","chapter":17,"verse":25,"text":"나의 하나님이여 주께서 종을 위하여 집을 세우실 것을 이미 듣게 하셨으므로 주의 종이 주 앞에서 이 기도로 구할 마음이 생겼나이다","reference":"역대상 17:25","category":"$undefined"},{"id":"10890","book":"역대상","book_name":"역대상","chapter":17,"verse":26,"text":"여호와여 오직 주는 하나님이시라 주께서 이 좋은 것으로 주의 종에게 허락하시고","reference":"역대상 17:26","category":"$undefined"},{"id":"10891","book":"역대상","book_name":"역대상","chapter":17,"verse":27,"text":"이제 주께서 종의 집에 복을 주사 주 앞에 영원히 두시기를 기뻐하시나이다 여호와여 주께서 복을 주셨사오니 이 복을 영원히 누리리이다 하니라","reference":"역대상 17:27","category":"$undefined"}],"bookSlug":"1chronicles"}]
