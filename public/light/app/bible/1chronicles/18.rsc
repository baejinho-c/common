2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":18,"verses":[{"id":"10892","book":"역대상","book_name":"역대상","chapter":18,"verse":1,"text":"이 후에 다윗이 블레셋 사람을 쳐서 항복받고 블레셋 사람의 손에서 가드와 그 동네를 빼앗고","reference":"역대상 18:1","category":"$undefined"},{"id":"10893","book":"역대상","book_name":"역대상","chapter":18,"verse":2,"text":"또 모압을 치매 모압 사람이 다윗의 종이 되어 조공을 바치니라","reference":"역대상 18:2","category":"$undefined"},{"id":"10894","book":"역대상","book_name":"역대상","chapter":18,"verse":3,"text":"소바 왕 하닷에셀이 유브라데 강 가에서 자기 권세를 펴고자 하매 다윗이 저를 쳐서 하막까지 이르고","reference":"역대상 18:3","category":"$undefined"},{"id":"10895","book":"역대상","book_name":"역대상","chapter":18,"verse":4,"text":"그 병거 일천승과 기병 칠천과 보병 이만을 빼앗고 그 병거 일백승의 말만 남기고 그 외의 병거의 말은 다 발의 힘줄을 끊었더니","reference":"역대상 18:4","category":"$undefined"},{"id":"10896","book":"역대상","book_name":"역대상","chapter":18,"verse":5,"text":"다메섹 아람 사람이 소바 왕 하닷에셀을 도우러 온지라 다윗이 아람 사람 이만 이천을 죽이고","reference":"역대상 18:5","category":"$undefined"},{"id":"10897","book":"역대상","book_name":"역대상","chapter":18,"verse":6,"text":"다메섹 아람에 수비대를 두매 아람 사람이 다윗의 종이 되어 조공을 바치니라 다윗이 어디로 가든지 여호와께서 이기게 하시니라","reference":"역대상 18:6","category":"$undefined"},{"id":"10898","book":"역대상","book_name":"역대상","chapter":18,"verse":7,"text":"다윗이 하닷에셀의 신복들의 가진 금방패를 빼앗아 예루살렘으로 가져오고","reference":"역대상 18:7","category":"$undefined"},{"id":"10899","book":"역대상","book_name":"역대상","chapter":18,"verse":8,"text":"또 하닷에셀의 성읍 디브핫과 군에서 심히 많은 곳을 취하였더니 솔로몬이 그것으로 놋바다와 기둥과 놋그릇들을 만들었더라","reference":"역대상 18:8","category":"$undefined"},{"id":"10900","book":"역대상","book_name":"역대상","chapter":18,"verse":9,"text":"하맛 왕 도우가 다윗이 소바 왕 하닷에셀의 온 군대를 쳐서 파하였다 함을 듣고","reference":"역대상 18:9","category":"$undefined"},{"id":"10901","book":"역대상","book_name":"역대상","chapter":18,"verse":10,"text":"그 아들 하도람을 보내어 다윗 왕에게 문안하고 축복하게 하니 이는 하닷에셀이 이왕에 도우로 더불어 여러번 전쟁이 있던 터에 다윗이 하닷에셀을 쳐서 파하였음이라 하도람이 금과 은과 놋의 여러 가지 그릇을 가져온지라","reference":"역대상 18:10","category":"$undefined"},{"id":"10902","book":"역대상","book_name":"역대상","chapter":18,"verse":11,"text":"다윗 왕이 그것도 여호와께 드리되 에돔과 모압과 암몬 자손과 블레셋 사람과 아말렉 등 여러 족속에게서 취하여 온 은금과 함께 하여 드리니라","reference":"역대상 18:11","category":"$undefined"},{"id":"10903","book":"역대상","book_name":"역대상","chapter":18,"verse":12,"text":"스루야의 아들 아비새가 염곡에서 에돔 사람 일만 팔천을 쳐 죽인지라","reference":"역대상 18:12","category":"$undefined"},{"id":"10904","book":"역대상","book_name":"역대상","chapter":18,"verse":13,"text":"다윗이 에돔에 수비대를 두매 에돔 사람이 다 다윗의 종이 되니라 다윗이 어디로 가든지 여호와께서 이기게 하셨더라","reference":"역대상 18:13","category":"$undefined"},{"id":"10905","book":"역대상","book_name":"역대상","chapter":18,"verse":14,"text":"다윗이 온 이스라엘을 다스려 모든 백성에게 공과 의를 행할새","reference":"역대상 18:14","category":"$undefined"},{"id":"10906","book":"역대상","book_name":"역대상","chapter":18,"verse":15,"text":"스루야의 아들 요압은 군대 장관이 되고 아힐룻의 아들 여호사밧은 사관이 되고","reference":"역대상 18:15","category":"$undefined"},{"id":"10907","book":"역대상","book_name":"역대상","chapter":18,"verse":16,"text":"아히둡의 아들 사독과 아비아달의 아들 아비멜렉은 제사장이 되고 사워사는 서기관이 되고","reference":"역대상 18:16","category":"$undefined"},{"id":"10908","book":"역대상","book_name":"역대상","chapter":18,"verse":17,"text":"여호야다의 아들 브나야는 그렛 사람과 블렛 사람을 관할하고 다윗의 아들들은 왕을 모셔 대신이 되니라","reference":"역대상 18:17","category":"$undefined"}],"bookSlug":"1chronicles"}]
