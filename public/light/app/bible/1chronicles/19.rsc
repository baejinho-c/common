2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":19,"verses":[{"id":"10909","book":"역대상","book_name":"역대상","chapter":19,"verse":1,"text":"그 후에 암몬 자손의 왕 나하스가 죽고 그 아들이 대신하여 왕이되니","reference":"역대상 19:1","category":"$undefined"},{"id":"10910","book":"역대상","book_name":"역대상","chapter":19,"verse":2,"text":"다윗이 가로되 하눈의 아비 나하스가 전에 내게 은혜를 베풀었으니 이제 내가 그 아들 하눈에게 은혜를 베풀리라 하고 사자를 보내어 그 아비 죽은 것을 조상하게 하니라 다윗의 신복들이 암몬 자손의 땅에 이르러 하눈에게 나아가 조상하매","reference":"역대상 19:2","category":"$undefined"},{"id":"10911","book":"역대상","book_name":"역대상","chapter":19,"verse":3,"text":"암몬 자손의 방백들이 하눈에게 고하되 왕은 다윗이 조문사를 보낸 것이 왕의 부친을 공경함인 줄로 여기시나이까 그 신복이 왕에게 나아온 것이 이 땅을 엿보고 탐지하여 함락시키고자 함이 아니니이까","reference":"역대상 19:3","category":"$undefined"},{"id":"10912","book":"역대상","book_name":"역대상","chapter":19,"verse":4,"text":"하눈이 이에 다윗의 신복들을 잡아 그 수염을 깍고 그 의복의 중동 볼기까지 자르고 돌려 보내매","reference":"역대상 19:4","category":"$undefined"},{"id":"10913","book":"역대상","book_name":"역대상","chapter":19,"verse":5,"text":"혹이 다윗에게 가서 그 사람들의 당한 일을 고하니라 그 사람들이 심히 부끄러워하므로 다윗이 저희를 맞으러 보내어 이르기를 너희는 수염이 자라기까지 여리고에 머물다가 돌아오라 하니라","reference":"역대상 19:5","category":"$undefined"},{"id":"10914","book":"역대상","book_name":"역대상","chapter":19,"verse":6,"text":"암몬 자손이 자기가 다윗에게 밉게 한 줄 안지라 하눈이 암몬 자손으로 더불어 은 일천 달란트를 아람 나하라임과 아람마아가와 소바에 보내어 병거와 마병을 삯 내되","reference":"역대상 19:6","category":"$undefined"},{"id":"10915","book":"역대상","book_name":"역대상","chapter":19,"verse":7,"text":"곧 병거 삼만 이천승과 마아가 왕과 그 백성을 삯 내었더니 저희가와서 메드바 앞에 진 치매 암몬 자손이 그 모든 성읍으로 좇아 모여와서 싸우려 한지라","reference":"역대상 19:7","category":"$undefined"},{"id":"10916","book":"역대상","book_name":"역대상","chapter":19,"verse":8,"text":"다윗이 듣고 요압과 용사의 온 무리를 보내었더니","reference":"역대상 19:8","category":"$undefined"},{"id":"10917","book":"역대상","book_name":"역대상","chapter":19,"verse":9,"text":"암몬 자손은 나와서 성문 앞에 진 치고 도우러 온 여러 왕은 따로 들에 있더라","reference":"역대상 19:9","category":"$undefined"},{"id":"10918","book":"역대상","book_name":"역대상","chapter":19,"verse":10,"text":"요압이 앞 뒤에 친 적진을 보고 이스라엘 뺀 자 중에서 또 빼서 아람 사람을 대하여 진 치고","reference":"역대상 19:10","category":"$undefined"},{"id":"10919","book":"역대상","book_name":"역대상","chapter":19,"verse":11,"text":"그 남은 무리는 그 아우 아비새의 수하에 붙여 암몬 자손을 대하여 진 치게 하고","reference":"역대상 19:11","category":"$undefined"},{"id":"10920","book":"역대상","book_name":"역대상","chapter":19,"verse":12,"text":"가로되 만일 아람 사람이 나보다 강하면 네가 나를 돕고 만일 암몬 자손이 너보다 강하면 내가 너를 도우리라","reference":"역대상 19:12","category":"$undefined"},{"id":"10921","book":"역대상","book_name":"역대상","chapter":19,"verse":13,"text":"너는 담대하라 우리가 우리 백성과 우리 하나님의 성읍들을 위하여 담대히 하자 여호와께서 선히 여기시는 대로 행하시기를 원하노라 하고","reference":"역대상 19:13","category":"$undefined"},{"id":"10922","book":"역대상","book_name":"역대상","chapter":19,"verse":14,"text":"요압과 그 종자가 싸우려고 아람 사람 앞에 나아가니 저희가 그 앞에서 도망하고","reference":"역대상 19:14","category":"$undefined"},{"id":"10923","book":"역대상","book_name":"역대상","chapter":19,"verse":15,"text":"암몬 자손은 아람 사람의 도망함을 보고 저희도 요압의 아우 아비새 앞에서 도망하여 성으로 들어간지라 이에 요압이 예루살렘으로 돌아오니라","reference":"역대상 19:15","category":"$undefined"},{"id":"10924","book":"역대상","book_name":"역대상","chapter":19,"verse":16,"text":"아람 사람이 자기가 이스라엘 앞에서 패하였음을 보고 사자를 보내어 강 건너편에 있는 아람 사람을 불러내니 하닷에셀의 군대 장관 소박이 저희를 거느린지라","reference":"역대상 19:16","category":"$undefined"},{"id":"10925","book":"역대상","book_name":"역대상","chapter":19,"verse":17,"text":"혹이 다윗에게 고하매 다윗이 온 이스라엘을 모으고 요단을 건너 아람사람에게 이르러 저희를 향하여 진을 치니라 다윗이 아람 사람을 향하여 진을 치매 저희가 다윗으로 더불어 싸우더니","reference":"역대상 19:17","category":"$undefined"},{"id":"10926","book":"역대상","book_name":"역대상","chapter":19,"verse":18,"text":"아람 사람이 이스라엘 앞에서 도망한지라 다윗이 아람 병거 칠천승의 군사와 보병 사만을 죽이고 또 군대 장관 소박을 죽이매","reference":"역대상 19:18","category":"$undefined"},{"id":"10927","book":"역대상","book_name":"역대상","chapter":19,"verse":19,"text":"하닷에셀의 신복이 자기가 이스라엘 앞에서 패하였음을 보고 다윗으로 더불어 화친하여 섬기고 이후로는 아람 사람이 암몬 자손 돕기를 싫어하니라","reference":"역대상 19:19","category":"$undefined"}],"bookSlug":"1chronicles"}]
