2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":2,"verses":[{"id":"10308","book":"역대상","book_name":"역대상","chapter":2,"verse":1,"text":"이스라엘의 아들은 이러하니 르우벤과, 시므온과, 레위와, 유다와, 잇사갈과, 스불론과","reference":"역대상 2:1","category":"$undefined"},{"id":"10309","book":"역대상","book_name":"역대상","chapter":2,"verse":2,"text":"단과, 요셉과, 베냐민과, 납달리와, 갓과, 아셀이더라","reference":"역대상 2:2","category":"$undefined"},{"id":"10310","book":"역대상","book_name":"역대상","chapter":2,"verse":3,"text":"유다의 아들은 에르와, 오난과, 셀라니 이 세 사람은 가나안 사람 수아의 딸이 유다로 말미암아 낳은 자요 유다의 맏아들 에르는 여호와 보시기에 악하였으므로 여호와께서 죽이셨고","reference":"역대상 2:3","category":"$undefined"},{"id":"10311","book":"역대상","book_name":"역대상","chapter":2,"verse":4,"text":"유다의 며느리 다말이 유다로 말미암아 베레스와 세라를 낳았으니 유다의 아들이 모두 다섯이더라","reference":"역대상 2:4","category":"$undefined"},{"id":"10312","book":"역대상","book_name":"역대상","chapter":2,"verse":5,"text":"베레스의 아들은 헤스론과, 하물이요","reference":"역대상 2:5","category":"$undefined"},{"id":"10313","book":"역대상","book_name":"역대상","chapter":2,"verse":6,"text":"세라의 아들은 시므리와 에단과, 헤만과, 갈골과, 다라니 모두 다섯 사람이요","reference":"역대상 2:6","category":"$undefined"},{"id":"10314","book":"역대상","book_name":"역대상","chapter":2,"verse":7,"text":"가르미의 아들은 아갈이니 저는 마땅히 멸할 물건으로 인하여 이스라엘을 괴롭게 한 자며","reference":"역대상 2:7","category":"$undefined"},{"id":"10315","book":"역대상","book_name":"역대상","chapter":2,"verse":8,"text":"에단의 아들은 아사랴더라","reference":"역대상 2:8","category":"$undefined"},{"id":"10316","book":"역대상","book_name":"역대상","chapter":2,"verse":9,"text":"헤스론의 낳은 아들은 여라므엘과, 람과, 글루배라","reference":"역대상 2:9","category":"$undefined"},{"id":"10317","book":"역대상","book_name":"역대상","chapter":2,"verse":10,"text":"람은 암미나답을 낳았고, 암미나답은 나손을 낳았으니, 나손은 유다 자손의 방백이며","reference":"역대상 2:10","category":"$undefined"},{"id":"10318","book":"역대상","book_name":"역대상","chapter":2,"verse":11,"text":"나손은 살마를 낳았고, 살마는 보아스를 낳았고","reference":"역대상 2:11","category":"$undefined"},{"id":"10319","book":"역대상","book_name":"역대상","chapter":2,"verse":12,"text":"보아스는 오벳을 낳았고, 오벳은 이새를 낳았고","reference":"역대상 2:12","category":"$undefined"},{"id":"10320","book":"역대상","book_name":"역대상","chapter":2,"verse":13,"text":"이새는 맏아들 엘리압과, 둘째로 아비나답과, 세째로 시므아와","reference":"역대상 2:13","category":"$undefined"},{"id":"10321","book":"역대상","book_name":"역대상","chapter":2,"verse":14,"text":"네째로 느다넬과, 다섯째로 랏대와","reference":"역대상 2:14","category":"$undefined"},{"id":"10322","book":"역대상","book_name":"역대상","chapter":2,"verse":15,"text":"여섯째로 오셈과, 일곱째로 다윗을 낳았으며","reference":"역대상 2:15","category":"$undefined"},{"id":"10323","book":"역대상","book_name":"역대상","chapter":2,"verse":16,"text":"저희의 자매(姉妹)는 스루야와, 아비가일이라 스루야의 아들은 아비새와, 요압과 아사헬 삼형제요","reference":"역대상 2:16","category":"$undefined"},{"id":"10324","book":"역대상","book_name":"역대상","chapter":2,"verse":17,"text":"아비가일은 아마사를 낳았으니 아마사의 아비는 이스마엘 사람 예델이었더라","reference":"역대상 2:17","category":"$undefined"},{"id":"10325","book":"역대상","book_name":"역대상","chapter":2,"verse":18,"text":"헤스론의 아들 갈렙이 그 아내 아수바와 여리옷에게서 아들을 낳았으니 그 낳은 아들은 예셀과 소밥과 아르돈이며","reference":"역대상 2:18","category":"$undefined"},{"id":"10326","book":"역대상","book_name":"역대상","chapter":2,"verse":19,"text":"아수바가 죽은 후에 갈렙이 또 에브랏에게 장가 들었더니 에브랏이 그로 말미암아 훌을 낳았고,","reference":"역대상 2:19","category":"$undefined"},{"id":"10327","book":"역대상","book_name":"역대상","chapter":2,"verse":20,"text":"훌은 우리를 낳았고, 우리는 브사렐을 낳았더라","reference":"역대상 2:20","category":"$undefined"},{"id":"10328","book":"역대상","book_name":"역대상","chapter":2,"verse":21,"text":"그 후에 헤스론이 육십세에 길르앗의 아비 마길의 딸에게 장가들어 동침하였더니 저가 헤스론으로 말미암아 스굽을 낳았으며","reference":"역대상 2:21","category":"$undefined"},{"id":"10329","book":"역대상","book_name":"역대상","chapter":2,"verse":22,"text":"스굽은 야일을 낳았고 야일은 길르앗 땅에서 스물 세 성읍을 가졌더니","reference":"역대상 2:22","category":"$undefined"},{"id":"10330","book":"역대상","book_name":"역대상","chapter":2,"verse":23,"text":"그술과 아람이 야일의 성읍들과 그낫과 그 성들 모두 육십을 그들에게서 빼앗았으며 저희는 다 길르앗의 아비 마길의 자손이었더라","reference":"역대상 2:23","category":"$undefined"},{"id":"10331","book":"역대상","book_name":"역대상","chapter":2,"verse":24,"text":"헤스론의 맏아들 여라므엘의 아들은 맏아들 람과 그 다음 브나와 오렌과 오셈과 아히야며","reference":"역대상 2:24","category":"$undefined"},{"id":"10332","book":"역대상","book_name":"역대상","chapter":2,"verse":25,"text":"여라므엘이 다른 아내가 있었으니 이름은 아다라라 저는 오남의 어미더라","reference":"역대상 2:25","category":"$undefined"},{"id":"10333","book":"역대상","book_name":"역대상","chapter":2,"verse":26,"text":"여라므엘의 맏아들 람의 아들은 마아스와, 야민과, 에겔이요","reference":"역대상 2:26","category":"$undefined"},{"id":"10334","book":"역대상","book_name":"역대상","chapter":2,"verse":27,"text":"오남의 아들들은 삼매와, 야다요 삼매의 아들은 나답과, 아비술이며","reference":"역대상 2:27","category":"$undefined"},{"id":"10335","book":"역대상","book_name":"역대상","chapter":2,"verse":28,"text":"아비술의 아내의 이름은 아비하일이라 저가 그로 말미암아 아반과 몰릿을 낳았으며","reference":"역대상 2:28","category":"$undefined"},{"id":"10336","book":"역대상","book_name":"역대상","chapter":2,"verse":29,"text":"나답의 아들은 셀렛과, 압바임이라 셀렛은 아들이 없이 죽었고","reference":"역대상 2:29","category":"$undefined"},{"id":"10337","book":"역대상","book_name":"역대상","chapter":2,"verse":30,"text":"압바임의 아들은 이시요, 이시의 아들은 세산이요, 세산의 아들은 알래요","reference":"역대상 2:30","category":"$undefined"},{"id":"10338","book":"역대상","book_name":"역대상","chapter":2,"verse":31,"text":"삼매의 아우 야다의 아들은 예델과, 요나단이라 예델은 아들이 없이 죽었고","reference":"역대상 2:31","category":"$undefined"},{"id":"10339","book":"역대상","book_name":"역대상","chapter":2,"verse":32,"text":"요나단의 아들은 벨렛과, 사사라 여라므엘의 자손은 이러하며","reference":"역대상 2:32","category":"$undefined"},{"id":"10340","book":"역대상","book_name":"역대상","chapter":2,"verse":33,"text":"세산은 아들이 없고 딸 뿐이라 그에게 야르하라 하는 애굽 종이 있는고로","reference":"역대상 2:33","category":"$undefined"},{"id":"10341","book":"역대상","book_name":"역대상","chapter":2,"verse":34,"text":"딸을 그 종 야르하에게 주어 아내를 삼게 하였더니 저가 그로 말미암아 앗대를 낳았고,","reference":"역대상 2:34","category":"$undefined"},{"id":"10342","book":"역대상","book_name":"역대상","chapter":2,"verse":35,"text":"앗대는 나단을 낳았고, 나단은 사밧을 낳았고,","reference":"역대상 2:35","category":"$undefined"},{"id":"10343","book":"역대상","book_name":"역대상","chapter":2,"verse":36,"text":"사밧은 에블랄을 낳았고, 에블랄은 오벳을 낳았고,","reference":"역대상 2:36","category":"$undefined"},{"id":"10344","book":"역대상","book_name":"역대상","chapter":2,"verse":37,"text":"오벳은 예후를 낳았고, 예후는 아사랴를 낳았고,","reference":"역대상 2:37","category":"$undefined"},{"id":"10345","book":"역대상","book_name":"역대상","chapter":2,"verse":38,"text":"아사랴는 헬레스를 낳았고, 헬레스는 엘르아사를 낳았고,","reference":"역대상 2:38","category":"$undefined"},{"id":"10346","book":"역대상","book_name":"역대상","chapter":2,"verse":39,"text":"엘르아사는 시스매를 낳았고, 시스매는 살룸을 낳았고,","reference":"역대상 2:39","category":"$undefined"},{"id":"10347","book":"역대상","book_name":"역대상","chapter":2,"verse":40,"text":"살룸은 여가먀를 낳았고, 여가먀는 엘리사마를 낳았더라,","reference":"역대상 2:40","category":"$undefined"},{"id":"10348","book":"역대상","book_name":"역대상","chapter":2,"verse":41,"text":"여라므엘의 아우 갈렙의 아들 곧 맏아들은 메사니 십의 아비요 그 아들은 마레사니 헤브론의 아비며","reference":"역대상 2:41","category":"$undefined"},{"id":"10349","book":"역대상","book_name":"역대상","chapter":2,"verse":42,"text":"헤브론의 아들은 고라와, 답부아와, 레겜과, 세마라","reference":"역대상 2:42","category":"$undefined"},{"id":"10350","book":"역대상","book_name":"역대상","chapter":2,"verse":43,"text":"세마는 라함을 낳았으니 라함은 요르그암의 아비며 레겜은 삼매를 낳았고,","reference":"역대상 2:43","category":"$undefined"},{"id":"10351","book":"역대상","book_name":"역대상","chapter":2,"verse":44,"text":"삼매의 아들은 마온이라 마온은 벳술의 아비며","reference":"역대상 2:44","category":"$undefined"},{"id":"10352","book":"역대상","book_name":"역대상","chapter":2,"verse":45,"text":"갈렙의 첩 에바는 하란과, 모사와, 가세스를 낳았고, 하란은 가세스를 낳았으며","reference":"역대상 2:45","category":"$undefined"},{"id":"10353","book":"역대상","book_name":"역대상","chapter":2,"verse":46,"text":"야대의 아들은 레겜과, 요단과, 게산과, 벨렛과, 에바와, 사압이며","reference":"역대상 2:46","category":"$undefined"},{"id":"10354","book":"역대상","book_name":"역대상","chapter":2,"verse":47,"text":"갈렙의 첩 마아가는 세벨과, 디르하나를 낳았고,","reference":"역대상 2:47","category":"$undefined"},{"id":"10355","book":"역대상","book_name":"역대상","chapter":2,"verse":48,"text":"또 맛만나의 아비 사압을 낳았고 또 막베나와, 기브아의 아비 스와를 낳았으며 갈렙의 딸은 악사더라","reference":"역대상 2:48","category":"$undefined"},{"id":"10356","book":"역대상","book_name":"역대상","chapter":2,"verse":49,"text":"갈렙의 자손 곧 에브라다의 맏아들 훌의 아들은 이러하니 기럇여아림의 아비 소발과","reference":"역대상 2:49","category":"$undefined"},{"id":"10357","book":"역대상","book_name":"역대상","chapter":2,"verse":50,"text":"베들레헴의 아비 살마와, 벧가델의 아비 하렙이라","reference":"역대상 2:50","category":"$undefined"},{"id":"10358","book":"역대상","book_name":"역대상","chapter":2,"verse":51,"text":"기럇여아림의 아비 소발의 자손은 하로에와, 므누홋 사람의 절반이니","reference":"역대상 2:51","category":"$undefined"},{"id":"10359","book":"역대상","book_name":"역대상","chapter":2,"verse":52,"text":"기럇여아림 족속들은 이델 족속과, 붓 족속과, 수맛 족속과, 미스라 족속이라 이로 말미암아 소라와 에스다올 두 족속이 나왔으며","reference":"역대상 2:52","category":"$undefined"},{"id":"10360","book":"역대상","book_name":"역대상","chapter":2,"verse":53,"text":"살마의 자손들은 베들레헴과 느도바 족속과, 아다롯벳 요압과, 마하낫 족속의 절반과 소라 족속과","reference":"역대상 2:53","category":"$undefined"},{"id":"10361","book":"역대상","book_name":"역대상","chapter":2,"verse":54,"text":"야베스에 거한 서기관 족속 곧 디랏 족속과, 시므앗 족속과, 수갓 족속이니 이는 다 레갑의 집 조상 함맛에게서 나온 겐 족속이더라","reference":"역대상 2:54","category":"$undefined"},{"id":"10362","book":"역대상","book_name":"역대상","chapter":2,"verse":55,"text":"","reference":"역대상 2:55","category":"$undefined"}],"bookSlug":"1chronicles"}]
