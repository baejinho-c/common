2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":22,"verses":[{"id":"10966","book":"역대상","book_name":"역대상","chapter":22,"verse":1,"text":"다윗이 가로되 이는 여호와 하나님의 전이요 이는 이스라엘의 번제단이라 하였더라","reference":"역대상 22:1","category":"$undefined"},{"id":"10967","book":"역대상","book_name":"역대상","chapter":22,"verse":2,"text":"다윗이 명하여 이스라엘 땅에 우거하는 이방 사람을 모으고 석수를 시켜 하나님의 전을 건축할 돌을 다듬게 하고","reference":"역대상 22:2","category":"$undefined"},{"id":"10968","book":"역대상","book_name":"역대상","chapter":22,"verse":3,"text":"다윗이 또 문짝못과 거멀못에 쓸 철을 한 없이 준비하고 또 심히 많아서 중수를 셀 수 없는 놋을 준비하고","reference":"역대상 22:3","category":"$undefined"},{"id":"10969","book":"역대상","book_name":"역대상","chapter":22,"verse":4,"text":"또 백향목을 무수히 준비하였으니 이는 시돈 사람과 두로 사람이 백향목을 다윗에게로 많이 수운하여 왔음이라","reference":"역대상 22:4","category":"$undefined"},{"id":"10970","book":"역대상","book_name":"역대상","chapter":22,"verse":5,"text":"다윗이 가로되 내 아들 솔로몬이 어리고 연약하고 여호와를 위하여 건축할 전은 극히 장려하여 만국에 명성과 영광이 있게 하여야 할지라 그러므로 내가 이제 위하여 준비하리라 하고 죽기 전에 많이 준비하였더라","reference":"역대상 22:5","category":"$undefined"},{"id":"10971","book":"역대상","book_name":"역대상","chapter":22,"verse":6,"text":"다윗이 그 아들 솔로몬을 불러 이스라엘 하나님 여호와를 위하여 전을 건축하기를 부탁하여","reference":"역대상 22:6","category":"$undefined"},{"id":"10972","book":"역대상","book_name":"역대상","chapter":22,"verse":7,"text":"이르되 내 아들아 나는 내 하나님 여호와의 이름을 위하여 전을 건축할 마음이 있었으나","reference":"역대상 22:7","category":"$undefined"},{"id":"10973","book":"역대상","book_name":"역대상","chapter":22,"verse":8,"text":"여호와의 말씀이 내게 임하여 이르시되 너는 피를 심히 많이 흘렸고 크게 전쟁하였느니라 네가 내 앞에서 땅에 피를 많이 흘렸은즉 내 이름을 위하여 전을 건축하지 못하리라","reference":"역대상 22:8","category":"$undefined"},{"id":"10974","book":"역대상","book_name":"역대상","chapter":22,"verse":9,"text":"한 아들이 네게서 나리니 저는 평강의 사람이라 내가 저로 사면 모든 대적에게서 평강하게 하리라 그 이름을 솔로몬이라 하리니 이는 내가 저의 생전에 평안과 안정을 이스라엘에게 줄 것임이니라","reference":"역대상 22:9","category":"$undefined"},{"id":"10975","book":"역대상","book_name":"역대상","chapter":22,"verse":10,"text":"저가 내 이름을 위하여 전을 건축할지라 저는 내 아들이 되고 나는 저의 아비가 되어 그 나라 위를 이스라엘 위에 굳게 세워 영원까지 이르게 하리라 하셨나니","reference":"역대상 22:10","category":"$undefined"},{"id":"10976","book":"역대상","book_name":"역대상","chapter":22,"verse":11,"text":"내 아들아 여호와께서 너와 함께 하시기를 원하며 네가 형통하여 여호와께서 네게 대하여 말씀하신 대로 여호와의 전을 건축하며","reference":"역대상 22:11","category":"$undefined"},{"id":"10977","book":"역대상","book_name":"역대상","chapter":22,"verse":12,"text":"여호와께서 네게 지혜와 총명을 주사 너로 이스라엘을 다스리게 하시고 너의 하나님 여호와의 율법을 지키게 하시기를 더욱 원하노라","reference":"역대상 22:12","category":"$undefined"},{"id":"10978","book":"역대상","book_name":"역대상","chapter":22,"verse":13,"text":"네가 만일 여호와께서 모세로 이스라엘에게 명하신 모든 율례와 규례를 삼가 행하면 형통하리니 강하고 담대하여 두려워 말고 놀라지 말지어다","reference":"역대상 22:13","category":"$undefined"},{"id":"10979","book":"역대상","book_name":"역대상","chapter":22,"verse":14,"text":"내가 환난 중에 여호와의 전을 위하여 금 십만 달란트와 은 일백만 달란트와 놋과 철을 그 중수를 셀 수 없을만큼 심히 많이 예비하였고 또 재목과 돌을 예비하였으나 너는 더할 것이며","reference":"역대상 22:14","category":"$undefined"},{"id":"10980","book":"역대상","book_name":"역대상","chapter":22,"verse":15,"text":"또 공장이 네게 많이 있나니 곧 석수와 목수와 온갖 일에 익숙한 모든 사람이니라","reference":"역대상 22:15","category":"$undefined"},{"id":"10981","book":"역대상","book_name":"역대상","chapter":22,"verse":16,"text":"금과 은과 놋과 철이 무수하니 너는 일어나 일하라 여호와께서 너와 함께 계실지로다","reference":"역대상 22:16","category":"$undefined"},{"id":"10982","book":"역대상","book_name":"역대상","chapter":22,"verse":17,"text":"다윗이 또 이스라엘 모든 방백에게 명하여 그 아들 솔로몬을 도우라 하여 가로되","reference":"역대상 22:17","category":"$undefined"},{"id":"10983","book":"역대상","book_name":"역대상","chapter":22,"verse":18,"text":"너희 하나님 여호와께서 너희와 함께하지 아니하시느냐 사면으로 너희에게 평강을 주지 아니하셨느냐 이 땅 거민을 내 손에 붙이사 이 땅으로 여호와와 그 백성 앞에 복종하게 하셨나니","reference":"역대상 22:18","category":"$undefined"},{"id":"10984","book":"역대상","book_name":"역대상","chapter":22,"verse":19,"text":"이제 너희는 마음과 정신을 진정하여 너희 하나님 여호와를 구하고 일어나서 여호와 하나님의 성소를 건축하고 여호와의 언약궤와 하나님의 거룩한 기구를 가져다가 여호와의 이름을 위하여 건축한 전에 드리게 하라 하였더라","reference":"역대상 22:19","category":"$undefined"}],"bookSlug":"1chronicles"}]
