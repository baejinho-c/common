2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":23,"verses":[{"id":"10985","book":"역대상","book_name":"역대상","chapter":23,"verse":1,"text":"다윗이 나이 많아 늙으매 아들 솔로몬으로 이스라엘 왕을 삼고","reference":"역대상 23:1","category":"$undefined"},{"id":"10986","book":"역대상","book_name":"역대상","chapter":23,"verse":2,"text":"이스라엘 모든 방백과 제사장과 레위사람을 모았더라","reference":"역대상 23:2","category":"$undefined"},{"id":"10987","book":"역대상","book_name":"역대상","chapter":23,"verse":3,"text":"레위 사람은 삼십세 이상으로 계수하였으니 모든 남자의 명수가 삼만 팔천인데","reference":"역대상 23:3","category":"$undefined"},{"id":"10988","book":"역대상","book_name":"역대상","chapter":23,"verse":4,"text":"그 중에 이만 사천은 여호와의 전 사무를 보살피는 자요 육천은 유사와 재판관이요","reference":"역대상 23:4","category":"$undefined"},{"id":"10989","book":"역대상","book_name":"역대상","chapter":23,"verse":5,"text":"사천은 문지기요 사천은 다윗의 찬송하기 위하여 지은 악기로 여호와를 찬송하는 자라","reference":"역대상 23:5","category":"$undefined"},{"id":"10990","book":"역대상","book_name":"역대상","chapter":23,"verse":6,"text":"다윗이 레위의 아들 게르손과 그핫과 므라리의 각 족속을 따라 그 반열을 나누었더라","reference":"역대상 23:6","category":"$undefined"},{"id":"10991","book":"역대상","book_name":"역대상","chapter":23,"verse":7,"text":"게르손 자손은 라단과 시므이라","reference":"역대상 23:7","category":"$undefined"},{"id":"10992","book":"역대상","book_name":"역대상","chapter":23,"verse":8,"text":"라단의 아들들은 족장 여히엘과 또 세담과 요엘 세 사람이요","reference":"역대상 23:8","category":"$undefined"},{"id":"10993","book":"역대상","book_name":"역대상","chapter":23,"verse":9,"text":"시므이의 아들들은 슬로밋과 하시엘과 하란 세 사람이니 이는 라단의 족장들이며","reference":"역대상 23:9","category":"$undefined"},{"id":"10994","book":"역대상","book_name":"역대상","chapter":23,"verse":10,"text":"또 시므이의 아들들은 야핫과 시나와 여우스와 브리아니 이 네 사람도 시므이의 아들이라","reference":"역대상 23:10","category":"$undefined"},{"id":"10995","book":"역대상","book_name":"역대상","chapter":23,"verse":11,"text":"그 족장은 야핫이요 그 다음은 시사며 여우스와 브리아는 아들이 많지 아니하므로 저희와 한 족속으로 계수되었더라","reference":"역대상 23:11","category":"$undefined"},{"id":"10996","book":"역대상","book_name":"역대상","chapter":23,"verse":12,"text":"그핫의 아들들은 아므람과 이스할과 헤브론과 웃시엘 네 사람이라","reference":"역대상 23:12","category":"$undefined"},{"id":"10997","book":"역대상","book_name":"역대상","chapter":23,"verse":13,"text":"아므람의 아들들은 아론과 모세니 아론은 그 자손들과 함께 구별되어 몸을 성결케 하여 영원토록 지극히 거룩한 자가 되어 여호와 앞에 분향하며 섬기며 영원토록 그 이름을 받들어 축복하게 되었으며","reference":"역대상 23:13","category":"$undefined"},{"id":"10998","book":"역대상","book_name":"역대상","chapter":23,"verse":14,"text":"하나님의 사람 모세의 아들들은 레위 지파 중에 기록되었으니","reference":"역대상 23:14","category":"$undefined"},{"id":"10999","book":"역대상","book_name":"역대상","chapter":23,"verse":15,"text":"모세의 아들은 게르솜과 엘리에셀이라","reference":"역대상 23:15","category":"$undefined"},{"id":"11000","book":"역대상","book_name":"역대상","chapter":23,"verse":16,"text":"게르솜의 아들 중에 스브엘이 족장이 되었고","reference":"역대상 23:16","category":"$undefined"},{"id":"11001","book":"역대상","book_name":"역대상","chapter":23,"verse":17,"text":"엘리에셀의 아들은 족장 르하뱌라 엘리에셀이 이 외에는 다른 아들이 없고 르하뱌의 아들은 심히 많았으며","reference":"역대상 23:17","category":"$undefined"},{"id":"11002","book":"역대상","book_name":"역대상","chapter":23,"verse":18,"text":"이스할의 아들은 족장 슬로밋이요","reference":"역대상 23:18","category":"$undefined"},{"id":"11003","book":"역대상","book_name":"역대상","chapter":23,"verse":19,"text":"헤브론의 아들들은 족장 여리야와 둘째 아마랴와 세째 야하시엘과 네째 여가므암이며","reference":"역대상 23:19","category":"$undefined"},{"id":"11004","book":"역대상","book_name":"역대상","chapter":23,"verse":20,"text":"웃시엘의 아들은 족장 미가와 그 다음 잇시야더라","reference":"역대상 23:20","category":"$undefined"},{"id":"11005","book":"역대상","book_name":"역대상","chapter":23,"verse":21,"text":"므라리의 아들들은 마흘리와 무시요 마흘리의 아들들은 엘르아살과 기스라","reference":"역대상 23:21","category":"$undefined"},{"id":"11006","book":"역대상","book_name":"역대상","chapter":23,"verse":22,"text":"엘르아살이 아들이 없이 죽고 딸만 있더니 그 형제 기스의 아들이 저에게 장가 들었으며","reference":"역대상 23:22","category":"$undefined"},{"id":"11007","book":"역대상","book_name":"역대상","chapter":23,"verse":23,"text":"무시의 아들들은 마흘리와 에델과 여레못 세 사람이더라","reference":"역대상 23:23","category":"$undefined"},{"id":"11008","book":"역대상","book_name":"역대상","chapter":23,"verse":24,"text":"이는 다 레위 자손이니 그 종가를 따라 계수함을 입어 이름이 기록되고 여호와의 전에서 섬기는 일을 하는 이십세 이상 된 족장들이라","reference":"역대상 23:24","category":"$undefined"},{"id":"11009","book":"역대상","book_name":"역대상","chapter":23,"verse":25,"text":"다윗이 이르기를 이스라엘 하나님 여호와께서 평강을 그 백성에게 주시고 예루살렘에 영원히 거하시나니","reference":"역대상 23:25","category":"$undefined"},{"id":"11010","book":"역대상","book_name":"역대상","chapter":23,"verse":26,"text":"레위 사람이 다시는 성막과 그 가운데서 쓰는 모든 기구를 멜 것이 없다 한지라","reference":"역대상 23:26","category":"$undefined"},{"id":"11011","book":"역대상","book_name":"역대상","chapter":23,"verse":27,"text":"다윗의 유언대로 레위 자손이 이십세 이상으로 계수되었으니","reference":"역대상 23:27","category":"$undefined"},{"id":"11012","book":"역대상","book_name":"역대상","chapter":23,"verse":28,"text":"그 직분은 아론의 자손에게 수종들어 여호와의 전과 뜰과 골방에서 섬기고 또 모든 성물을 정결케 하는 일 곧 하나님의 전에서 섬기는 일과","reference":"역대상 23:28","category":"$undefined"},{"id":"11013","book":"역대상","book_name":"역대상","chapter":23,"verse":29,"text":"또 진설병과 고운 가루의 소제물 곧 무교전병이나 남비에 지지는 것이나 반죽하는 것이나 또 모든 저울과 자를 맡고","reference":"역대상 23:29","category":"$undefined"},{"id":"11014","book":"역대상","book_name":"역대상","chapter":23,"verse":30,"text":"새벽과 저녁마다 서서 여호와께 축사하며 찬송하며","reference":"역대상 23:30","category":"$undefined"},{"id":"11015","book":"역대상","book_name":"역대상","chapter":23,"verse":31,"text":"또 안식일과 초하루와 절기에 모든 번제를 여호와께 드리되 그 명하신 규례의 정한 수효대로 항상 여호와 앞에 드리며","reference":"역대상 23:31","category":"$undefined"},{"id":"11016","book":"역대상","book_name":"역대상","chapter":23,"verse":32,"text":"또 회막의 직무와 성소의 직무와 그 형제 아론 자손의 직무를 지켜 여호와의 전에서 수종드는 것이더라","reference":"역대상 23:32","category":"$undefined"}],"bookSlug":"1chronicles"}]
