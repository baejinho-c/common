2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":24,"verses":[{"id":"11017","book":"역대상","book_name":"역대상","chapter":24,"verse":1,"text":"아론 자손의 반차가 이러하니라 아론의 아들들은 나답과 아비후와 엘르아살과 이다말이라","reference":"역대상 24:1","category":"$undefined"},{"id":"11018","book":"역대상","book_name":"역대상","chapter":24,"verse":2,"text":"나답과 아비후가 그 아비보다 먼저 죽고 아들이 없으므로 엘르아살과 이다말이 제사장의 직분을 행하였더라","reference":"역대상 24:2","category":"$undefined"},{"id":"11019","book":"역대상","book_name":"역대상","chapter":24,"verse":3,"text":"다윗이 엘르아살의 자손 사독과 이다말의 자손 아히멜렉으로 더불어 저희를 나누어 각각 그 섬기는 직무를 맡겼는데","reference":"역대상 24:3","category":"$undefined"},{"id":"11020","book":"역대상","book_name":"역대상","chapter":24,"verse":4,"text":"엘르아살의 자손 중에 족장이 이다말의 자손보다 많으므로 나눈 것이 이러하니 엘르아살 자손의 족장이 십륙이요 이다말 자손은 그 열조의 집을 따라 여덟이라","reference":"역대상 24:4","category":"$undefined"},{"id":"11021","book":"역대상","book_name":"역대상","chapter":24,"verse":5,"text":"이에 제비 뽑아 피차에 차등이 없이 나누었으니 이는 성소의 일을 다스리는 자가 엘르아살의 자손 중에도 있고 이다말의 자손 중에도 있음이라","reference":"역대상 24:5","category":"$undefined"},{"id":"11022","book":"역대상","book_name":"역대상","chapter":24,"verse":6,"text":"레위 사람 느다넬의 아들 서기관 스마야가 왕과 방백과 제사장 사독과 아비아달의 아들 아히멜렉과 및 제사장과 레위 사람의 족장 앞에서 그 이름을 기록하여 엘르아살의 자손 중에서 한 집을 취하고 이다말의 자손 중에서 한 집을 취하였으니","reference":"역대상 24:6","category":"$undefined"},{"id":"11023","book":"역대상","book_name":"역대상","chapter":24,"verse":7,"text":"첫째로 제비뽑힌 자는 여호야립이요 둘째는 여다야요","reference":"역대상 24:7","category":"$undefined"},{"id":"11024","book":"역대상","book_name":"역대상","chapter":24,"verse":8,"text":"세째는 하림이요 네째는 스오림이요","reference":"역대상 24:8","category":"$undefined"},{"id":"11025","book":"역대상","book_name":"역대상","chapter":24,"verse":9,"text":"다섯째는 말기야요 여섯째는 미야민이요","reference":"역대상 24:9","category":"$undefined"},{"id":"11026","book":"역대상","book_name":"역대상","chapter":24,"verse":10,"text":"일곱째는 학고스요 여덟째는 아비야요","reference":"역대상 24:10","category":"$undefined"},{"id":"11027","book":"역대상","book_name":"역대상","chapter":24,"verse":11,"text":"아홉째는 예수아요 열째는 스가냐요","reference":"역대상 24:11","category":"$undefined"},{"id":"11028","book":"역대상","book_name":"역대상","chapter":24,"verse":12,"text":"열 한째는 엘리아십이요 열 둘째는 야김이요","reference":"역대상 24:12","category":"$undefined"},{"id":"11029","book":"역대상","book_name":"역대상","chapter":24,"verse":13,"text":"열 세째는 훔바요 열 네째는 예세브압이요","reference":"역대상 24:13","category":"$undefined"},{"id":"11030","book":"역대상","book_name":"역대상","chapter":24,"verse":14,"text":"열 다섯째는 빌가요 열 여섯째는 임멜이요","reference":"역대상 24:14","category":"$undefined"},{"id":"11031","book":"역대상","book_name":"역대상","chapter":24,"verse":15,"text":"열 일곱째는 헤실이요 열 여덟째는 합비세스요","reference":"역대상 24:15","category":"$undefined"},{"id":"11032","book":"역대상","book_name":"역대상","chapter":24,"verse":16,"text":"열 아홉째는 브다히야요 스무째는 여헤스겔이요","reference":"역대상 24:16","category":"$undefined"},{"id":"11033","book":"역대상","book_name":"역대상","chapter":24,"verse":17,"text":"스물 한째는 야긴이요 스물 둘째는 가물이요","reference":"역대상 24:17","category":"$undefined"},{"id":"11034","book":"역대상","book_name":"역대상","chapter":24,"verse":18,"text":"스물 세째는 들라야요 스물 네째는 마아시야라","reference":"역대상 24:18","category":"$undefined"},{"id":"11035","book":"역대상","book_name":"역대상","chapter":24,"verse":19,"text":"이와 같은 반차로 여호와의 전에 들어가서 이스라엘 하나님 여호와께서 저희 조상 아론에게 명하신 규례대로 수종들었더라","reference":"역대상 24:19","category":"$undefined"},{"id":"11036","book":"역대상","book_name":"역대상","chapter":24,"verse":20,"text":"레위 자손 중에 남은 자는 이러하니 아므람의 아들 중에는 수바엘이요 수바엘의 아들 중에는 예드야며","reference":"역대상 24:20","category":"$undefined"},{"id":"11037","book":"역대상","book_name":"역대상","chapter":24,"verse":21,"text":"르하뱌에게 이르러는 그 아들 중에 족장 잇시야요","reference":"역대상 24:21","category":"$undefined"},{"id":"11038","book":"역대상","book_name":"역대상","chapter":24,"verse":22,"text":"이스할의 아들 중에는 슬로못이요 슬로못의 아들중에는 야핫이요","reference":"역대상 24:22","category":"$undefined"},{"id":"11039","book":"역대상","book_name":"역대상","chapter":24,"verse":23,"text":"헤브론의 아들들은 장자 여리야와 둘째 아마랴와 세째 야하시엘과 네째 여가므암이요","reference":"역대상 24:23","category":"$undefined"},{"id":"11040","book":"역대상","book_name":"역대상","chapter":24,"verse":24,"text":"웃시엘의 아들은 미가요 미가의 아들중에는 사밀이요","reference":"역대상 24:24","category":"$undefined"},{"id":"11041","book":"역대상","book_name":"역대상","chapter":24,"verse":25,"text":"미가의 아우는 잇시야라 잇시야의 아들 중에는 스가랴며","reference":"역대상 24:25","category":"$undefined"},{"id":"11042","book":"역대상","book_name":"역대상","chapter":24,"verse":26,"text":"므라리의 아들은 마흘리와 무시요 야아시야의 아들은 브노니","reference":"역대상 24:26","category":"$undefined"},{"id":"11043","book":"역대상","book_name":"역대상","chapter":24,"verse":27,"text":"므라리의 자손 야아시야에게서 난 자는 브노와 소함과 삭굴과 이브리요","reference":"역대상 24:27","category":"$undefined"},{"id":"11044","book":"역대상","book_name":"역대상","chapter":24,"verse":28,"text":"마흘리의 아들 중에는 엘르아살이니 엘르아살은 무자하며","reference":"역대상 24:28","category":"$undefined"},{"id":"11045","book":"역대상","book_name":"역대상","chapter":24,"verse":29,"text":"기스에게 이르러는 그 아들 여라므엘이요","reference":"역대상 24:29","category":"$undefined"},{"id":"11046","book":"역대상","book_name":"역대상","chapter":24,"verse":30,"text":"무시의 아들은 마흘리와 에델과 여리못이니 이는 다 그 족속대로 기록한 레위 자손이라","reference":"역대상 24:30","category":"$undefined"},{"id":"11047","book":"역대상","book_name":"역대상","chapter":24,"verse":31,"text":"이 여러 사람도 다윗 왕과 사독과 아히멜렉과 및 제사장과 레위 족장 앞에서 그 형제 아론 자손처럼 제비 뽑혔으니 장자의 종가와 그 아우의 종가가 다름이 없더라","reference":"역대상 24:31","category":"$undefined"}],"bookSlug":"1chronicles"}]
