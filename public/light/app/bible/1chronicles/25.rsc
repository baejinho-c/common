2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":25,"verses":[{"id":"11048","book":"역대상","book_name":"역대상","chapter":25,"verse":1,"text":"다윗이 군대 장관들로 더불어 아삽과 헤만과 여두둔의 자손 중에서 구별하여 섬기게 하되 수금과 비파와 제금을 잡아 신령한 노래를 하게 하였으니 그 직무대로 일하는 자의 수효가 이러하니라","reference":"역대상 25:1","category":"$undefined"},{"id":"11049","book":"역대상","book_name":"역대상","chapter":25,"verse":2,"text":"아삽의 아들 중 삭굴과 요셉과 느다냐와 아사렐라니 이 아삽의 아들들이 아삽의 수하에 속하여 왕의 명령을 좇아 신령한 노래를 하며","reference":"역대상 25:2","category":"$undefined"},{"id":"11050","book":"역대상","book_name":"역대상","chapter":25,"verse":3,"text":"여두둔에게 이르러는 그 아들 그달리야와 스리와 여사야와 하사뱌와 맛디디야 여섯 사람이니 그 아비 여두둔의 수하에 속하여 수금을 잡아 신령한 노래를 하며 여호와께 감사하며 찬양하며","reference":"역대상 25:3","category":"$undefined"},{"id":"11051","book":"역대상","book_name":"역대상","chapter":25,"verse":4,"text":"헤만에게 이르러는 그 아들 북기야와 맛다냐와 웃시엘과 스브엘과 여리못과 하나냐와 하나니와 엘리아다와 깃달디와 로암디에셀과 요스브가사와 말로디와 호딜과 마하시옷이라","reference":"역대상 25:4","category":"$undefined"},{"id":"11052","book":"역대상","book_name":"역대상","chapter":25,"verse":5,"text":"이는 다 헤만의 아들들이니 나팔을 부는 자며 헤만은 하나님의 말씀을 받드는 왕의 선견자라 하나님이 헤만에게 열 네 아들과 세 딸을 주셨더라","reference":"역대상 25:5","category":"$undefined"},{"id":"11053","book":"역대상","book_name":"역대상","chapter":25,"verse":6,"text":"이들이 다 그 아비의 수하에 속하여 제금과 비파와 수금을 잡아 여호와 하나님의 전에서 노래하여 섬겼으며 아삽과 여두둔과 헤만은 왕의 수하에 속하였으니","reference":"역대상 25:6","category":"$undefined"},{"id":"11054","book":"역대상","book_name":"역대상","chapter":25,"verse":7,"text":"저희와 모든 형제 곧 여호와 찬송하기를 배워 익숙한 자의 수효가 이백 팔십 팔인이라","reference":"역대상 25:7","category":"$undefined"},{"id":"11055","book":"역대상","book_name":"역대상","chapter":25,"verse":8,"text":"이 무리의 큰 자나 작은 자나 스승이나 제자를 무론하고 일례로 제비뽑아 직임을 얻었으니","reference":"역대상 25:8","category":"$undefined"},{"id":"11056","book":"역대상","book_name":"역대상","chapter":25,"verse":9,"text":"첫째로 제비 뽑힌 자는 아삽의 아들 중 요셉이요 둘째는 그달리야니 저와 그 형제와 아들 십이인이요","reference":"역대상 25:9","category":"$undefined"},{"id":"11057","book":"역대상","book_name":"역대상","chapter":25,"verse":10,"text":"세째는 삭굴이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:10","category":"$undefined"},{"id":"11058","book":"역대상","book_name":"역대상","chapter":25,"verse":11,"text":"네째는 이스리니 그 아들과 형제와 십 이인이요","reference":"역대상 25:11","category":"$undefined"},{"id":"11059","book":"역대상","book_name":"역대상","chapter":25,"verse":12,"text":"다섯째는 느다냐니 그 아들과 형제와 십 이인이요","reference":"역대상 25:12","category":"$undefined"},{"id":"11060","book":"역대상","book_name":"역대상","chapter":25,"verse":13,"text":"여섯째는 북기야니 그 아들과 형제와 십 이인이요","reference":"역대상 25:13","category":"$undefined"},{"id":"11061","book":"역대상","book_name":"역대상","chapter":25,"verse":14,"text":"일곱째는 여사렐라니 그 아들과 형제와 십 이인이요","reference":"역대상 25:14","category":"$undefined"},{"id":"11062","book":"역대상","book_name":"역대상","chapter":25,"verse":15,"text":"여덟째는 여사야니 그 아들과 형제와 십이인이요","reference":"역대상 25:15","category":"$undefined"},{"id":"11063","book":"역대상","book_name":"역대상","chapter":25,"verse":16,"text":"아홉째는 맛다냐니 그 아들과 형제와 십 이인이요","reference":"역대상 25:16","category":"$undefined"},{"id":"11064","book":"역대상","book_name":"역대상","chapter":25,"verse":17,"text":"열째는 시므이니 그 아들과 형제와 십이인이요","reference":"역대상 25:17","category":"$undefined"},{"id":"11065","book":"역대상","book_name":"역대상","chapter":25,"verse":18,"text":"열 한째는 아사렐이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:18","category":"$undefined"},{"id":"11066","book":"역대상","book_name":"역대상","chapter":25,"verse":19,"text":"열 둘째는 하사뱌니 그 아들과 형제와 십 이인이요","reference":"역대상 25:19","category":"$undefined"},{"id":"11067","book":"역대상","book_name":"역대상","chapter":25,"verse":20,"text":"열 세째는 수바엘이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:20","category":"$undefined"},{"id":"11068","book":"역대상","book_name":"역대상","chapter":25,"verse":21,"text":"열 네째는 맛디디야니 그 아들과 형제와 십 이인이요","reference":"역대상 25:21","category":"$undefined"},{"id":"11069","book":"역대상","book_name":"역대상","chapter":25,"verse":22,"text":"열 다섯째는 여레못이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:22","category":"$undefined"},{"id":"11070","book":"역대상","book_name":"역대상","chapter":25,"verse":23,"text":"열 여섯째는 하나냐니 그 아들과 형제와 십 이인이요","reference":"역대상 25:23","category":"$undefined"},{"id":"11071","book":"역대상","book_name":"역대상","chapter":25,"verse":24,"text":"열 일곱째는 요스브가사니 그 아들과 형제와 십 이인이요","reference":"역대상 25:24","category":"$undefined"},{"id":"11072","book":"역대상","book_name":"역대상","chapter":25,"verse":25,"text":"열 여덟째는 하나니니 그 아들과 형제와 십 이인이요","reference":"역대상 25:25","category":"$undefined"},{"id":"11073","book":"역대상","book_name":"역대상","chapter":25,"verse":26,"text":"열 아홉째는 말로디니 그 아들과 형제와 십 이인이요","reference":"역대상 25:26","category":"$undefined"},{"id":"11074","book":"역대상","book_name":"역대상","chapter":25,"verse":27,"text":"스무째는 엘리아다니 그 아들과 형제와 십 이인이요","reference":"역대상 25:27","category":"$undefined"},{"id":"11075","book":"역대상","book_name":"역대상","chapter":25,"verse":28,"text":"스물 한째는 호딜이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:28","category":"$undefined"},{"id":"11076","book":"역대상","book_name":"역대상","chapter":25,"verse":29,"text":"스물 둘째는 깃달디니 그 아들과 형제와 십 이인이요","reference":"역대상 25:29","category":"$undefined"},{"id":"11077","book":"역대상","book_name":"역대상","chapter":25,"verse":30,"text":"스물 세째는 마하시옷이니 그 아들과 형제와 십 이인이요","reference":"역대상 25:30","category":"$undefined"},{"id":"11078","book":"역대상","book_name":"역대상","chapter":25,"verse":31,"text":"스물 네째는 로암디에셀이니 그 아들과 형제와 십 이인이었더라","reference":"역대상 25:31","category":"$undefined"}],"bookSlug":"1chronicles"}]
