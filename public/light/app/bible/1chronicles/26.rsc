2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":26,"verses":[{"id":"11079","book":"역대상","book_name":"역대상","chapter":26,"verse":1,"text":"문지기의 반차가 이러하니라 고라 족속 아삽의 자손중에 고레의 아들 므셀레먀와","reference":"역대상 26:1","category":"$undefined"},{"id":"11080","book":"역대상","book_name":"역대상","chapter":26,"verse":2,"text":"므셀레먀의 아들들 맏아들 스가랴와 둘째 여디야엘과 세째 스바댜와 네째 야드니엘과","reference":"역대상 26:2","category":"$undefined"},{"id":"11081","book":"역대상","book_name":"역대상","chapter":26,"verse":3,"text":"다섯째 엘람과 여섯째 여호하난과 일곱째 엘여호에내며","reference":"역대상 26:3","category":"$undefined"},{"id":"11082","book":"역대상","book_name":"역대상","chapter":26,"verse":4,"text":"오벧에돔의 아들들 맏아들 스마야와 둘째 여호사밧과 세째 요아와 네째 사갈과 다섯째 느다넬과","reference":"역대상 26:4","category":"$undefined"},{"id":"11083","book":"역대상","book_name":"역대상","chapter":26,"verse":5,"text":"여섯째 암미엘과 일곱째 잇사갈과 여덟째 브울래대니 이는 하나님이 오벧에돔에게 복을 주셨음이며","reference":"역대상 26:5","category":"$undefined"},{"id":"11084","book":"역대상","book_name":"역대상","chapter":26,"verse":6,"text":"그 아들 스마야도 두어 아들을 낳았으니 저희의 족속을 다스리는 자요 큰 용사라","reference":"역대상 26:6","category":"$undefined"},{"id":"11085","book":"역대상","book_name":"역대상","chapter":26,"verse":7,"text":"스마야의 아들들은 오드니와 르바엘과 오벳과 엘사밧이며 엘사밧의 형제 엘리후와 스마갸는 능력이 있는 자니","reference":"역대상 26:7","category":"$undefined"},{"id":"11086","book":"역대상","book_name":"역대상","chapter":26,"verse":8,"text":"이는 다 오벧에돔의 자손이라 저희와 그 아들들과 그 형제들은 다 능력이 있어 그 직무를 잘하는 자니 오벧에돔에게서 난 자가 육십 이명이며","reference":"역대상 26:8","category":"$undefined"},{"id":"11087","book":"역대상","book_name":"역대상","chapter":26,"verse":9,"text":"또 므셀레먀의 아들과 형제 십팔인은 능력이 있는 자며","reference":"역대상 26:9","category":"$undefined"},{"id":"11088","book":"역대상","book_name":"역대상","chapter":26,"verse":10,"text":"므라리 자손중 호사가 아들들이 있으니 그 장자는 시므리라 시므리는 본래 맏아들이 아니나 그 아비가 장자를 삼았고","reference":"역대상 26:10","category":"$undefined"},{"id":"11089","book":"역대상","book_name":"역대상","chapter":26,"verse":11,"text":"둘째는 힐기야요 세째는 드발리야요 네째는 스가랴니 호사의 아들과 형제가 십 삼인이더라","reference":"역대상 26:11","category":"$undefined"},{"id":"11090","book":"역대상","book_name":"역대상","chapter":26,"verse":12,"text":"이상은 다 문지기의 반장으로서 그 형제처럼 직임을 얻어 여호와의 전에서 섬기는 자라","reference":"역대상 26:12","category":"$undefined"},{"id":"11091","book":"역대상","book_name":"역대상","chapter":26,"verse":13,"text":"각 문을 지키기 위하여 그 종족을 따라 무론대소하고 다 제비 뽑혔으니","reference":"역대상 26:13","category":"$undefined"},{"id":"11092","book":"역대상","book_name":"역대상","chapter":26,"verse":14,"text":"셀레먀는 동방에 당첨되었고 그 아들 스가랴는 명철한 의사라 저를 위하여 제비 뽑으니 북방에 당첨되었고","reference":"역대상 26:14","category":"$undefined"},{"id":"11093","book":"역대상","book_name":"역대상","chapter":26,"verse":15,"text":"오벧에돔은 남방에 당첨되었고 그 아들들은 곳간에 당첨되었으며","reference":"역대상 26:15","category":"$undefined"},{"id":"11094","book":"역대상","book_name":"역대상","chapter":26,"verse":16,"text":"숩빔과 호사는 서방에 당첨되어 큰 길로 통한 살래겟 문 곁에 있어 서로 대하여 파수하였으니","reference":"역대상 26:16","category":"$undefined"},{"id":"11095","book":"역대상","book_name":"역대상","chapter":26,"verse":17,"text":"동방에 레위 사람이 여섯이요 북방에 매일 네 사람이요 남방에 매일 네 사람이요 곳간에는 둘씩이며","reference":"역대상 26:17","category":"$undefined"},{"id":"11096","book":"역대상","book_name":"역대상","chapter":26,"verse":18,"text":"낭실 서편 큰 길에 네 사람이요 낭실에 두 사람이니","reference":"역대상 26:18","category":"$undefined"},{"id":"11097","book":"역대상","book_name":"역대상","chapter":26,"verse":19,"text":"고라와 므라리 자손의 문지기의 반차가 이러하였더라","reference":"역대상 26:19","category":"$undefined"},{"id":"11098","book":"역대상","book_name":"역대상","chapter":26,"verse":20,"text":"레위 사람 중에 아히야는 하나님의 전 곳간과 성물 곳간을 맡았으며","reference":"역대상 26:20","category":"$undefined"},{"id":"11099","book":"역대상","book_name":"역대상","chapter":26,"verse":21,"text":"라단의 자손은 곧 라단에게 속한 게르손 사람의 자손이니 게르손 사람 라단에게 속한 족장은 여히엘리라","reference":"역대상 26:21","category":"$undefined"},{"id":"11100","book":"역대상","book_name":"역대상","chapter":26,"verse":22,"text":"여히엘리의 아들은 스담과 그 아우 요엘이니 여호와의 전 곳간을 맡았고","reference":"역대상 26:22","category":"$undefined"},{"id":"11101","book":"역대상","book_name":"역대상","chapter":26,"verse":23,"text":"아므람 자손과 이스할 자손과 헤브론 자손과 웃시엘 자손 중에","reference":"역대상 26:23","category":"$undefined"},{"id":"11102","book":"역대상","book_name":"역대상","chapter":26,"verse":24,"text":"모세의 아들 게르솜의 자손 스브엘은 곳간을 맡았고","reference":"역대상 26:24","category":"$undefined"},{"id":"11103","book":"역대상","book_name":"역대상","chapter":26,"verse":25,"text":"그 형제 곧 엘리에셀에게서 난 자는 그 아들 르하뱌와 그 아들 여사야와 그 아들 요람과 그 아들 시그리와 그 아들 슬로못이라","reference":"역대상 26:25","category":"$undefined"},{"id":"11104","book":"역대상","book_name":"역대상","chapter":26,"verse":26,"text":"이 슬로못과 그 형제는 성물의 모든 곳간을 맡았으니 곧 다윗왕과 족장과 천부장과 백부장과 군대의 모든 장관이 구별하여 드린 성물이라","reference":"역대상 26:26","category":"$undefined"},{"id":"11105","book":"역대상","book_name":"역대상","chapter":26,"verse":27,"text":"저희가 싸울 때에 노략하여 얻은 물건 중에서 구별하여 드려 여호와의 전을 중수하게 한 것이며","reference":"역대상 26:27","category":"$undefined"},{"id":"11106","book":"역대상","book_name":"역대상","chapter":26,"verse":28,"text":"선견자 사무엘과 기스의 아들 사울과 넬의 아들 아브넬과 스루야의 아들 요압이 무론 무엇이든지 구별하여 드린 성물은 다 슬로못과 그 형제의 수하에 있었더라","reference":"역대상 26:28","category":"$undefined"},{"id":"11107","book":"역대상","book_name":"역대상","chapter":26,"verse":29,"text":"이스할 자손중에 그나냐와 그 아들들은 이스라엘 바깥 일을 다스리는 유사와 재판관이 되었고","reference":"역대상 26:29","category":"$undefined"},{"id":"11108","book":"역대상","book_name":"역대상","chapter":26,"verse":30,"text":"헤브론 자손 중에 하사뱌와 그 동족 용사 일천 칠백인은 요단 서편에서 이스라엘을 주관하여 여호와의 모든 일과 왕을 섬기는 직임을 맡았으며","reference":"역대상 26:30","category":"$undefined"},{"id":"11109","book":"역대상","book_name":"역대상","chapter":26,"verse":31,"text":"헤브론 자손중에 여리야가 그 세계와 종족대로 헤브론 자손의 족장이 되었더라 다윗이 위에 있은지 사십년에 길르앗 야셀에서 그족속 중에 구하여 큰 용사를 얻었으니","reference":"역대상 26:31","category":"$undefined"},{"id":"11110","book":"역대상","book_name":"역대상","chapter":26,"verse":32,"text":"그 형제 중 이천 칠백명이 다 용사요 족장이라 다윗 왕이 저희로 르우벤과 갓과 므낫세 반 지파를 주관하여 하나님의 모든 일과 왕의 일을 다스리게 하였더라","reference":"역대상 26:32","category":"$undefined"}],"bookSlug":"1chronicles"}]
