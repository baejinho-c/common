2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":27,"verses":[{"id":"11111","book":"역대상","book_name":"역대상","chapter":27,"verse":1,"text":"이스라엘 자손의 모든 족장과 천부장과 백부장과 왕을 섬기는 유사들이 그 인수대로 반차가 나누이니 각 반열이 이만 사천명씩이라 일년동안 달마다 체번하여 들어가며 나왔으니","reference":"역대상 27:1","category":"$undefined"},{"id":"11112","book":"역대상","book_name":"역대상","chapter":27,"verse":2,"text":"정월 첫반의 반장은 삽디엘의 아들 야소브암이요 그 반열에 이만 사천명이라","reference":"역대상 27:2","category":"$undefined"},{"id":"11113","book":"역대상","book_name":"역대상","chapter":27,"verse":3,"text":"저는 베레스의 자손으로서 정월반의 모든 장관의 두목이 되었고","reference":"역대상 27:3","category":"$undefined"},{"id":"11114","book":"역대상","book_name":"역대상","chapter":27,"verse":4,"text":"이월반의 반장은 아호아 사람 도대요 또 미글롯이 그 반의 주장이 되었으니 그 반열에 이만 사천명이요","reference":"역대상 27:4","category":"$undefined"},{"id":"11115","book":"역대상","book_name":"역대상","chapter":27,"verse":5,"text":"삼월 군대의 세째 장관은 대제사장 여호야다의 아들 브나야요 그 반열에 이만 사천명이라","reference":"역대상 27:5","category":"$undefined"},{"id":"11116","book":"역대상","book_name":"역대상","chapter":27,"verse":6,"text":"이 브나야는 삼십인중에 용사요 삼십인 위에 있으며 그 반열 중에 그 아들 암미사밧이 있으며","reference":"역대상 27:6","category":"$undefined"},{"id":"11117","book":"역대상","book_name":"역대상","chapter":27,"verse":7,"text":"사월 네째 장관은 요압의 아우 아사헬이요 그 다음은 그 아들 스바댜니 그 반열에 이만 사천명이요","reference":"역대상 27:7","category":"$undefined"},{"id":"11118","book":"역대상","book_name":"역대상","chapter":27,"verse":8,"text":"오월 다섯째 장관은 이스라 사람 삼훗이니 그 반열에 이만 사천명이요","reference":"역대상 27:8","category":"$undefined"},{"id":"11119","book":"역대상","book_name":"역대상","chapter":27,"verse":9,"text":"유월 여섯째 장관은 드고아 사람 익게스의 아들 이라니 그 반열에 이만 사천명이요","reference":"역대상 27:9","category":"$undefined"},{"id":"11120","book":"역대상","book_name":"역대상","chapter":27,"verse":10,"text":"칠월 일곱째 장관은 에브라임자손에 속한 발론 사람 헬레스니 그 반열에 이만 사천명이요","reference":"역대상 27:10","category":"$undefined"},{"id":"11121","book":"역대상","book_name":"역대상","chapter":27,"verse":11,"text":"팔월 여덟째 장관은 세라 족속 후사 사람 십브개니 그 반열에 이만 사천명이요","reference":"역대상 27:11","category":"$undefined"},{"id":"11122","book":"역대상","book_name":"역대상","chapter":27,"verse":12,"text":"구월 아홉째 장관은 베냐민 자손 아나돗 사람 아비에셀이니 그 반열에 이만 사천명이요","reference":"역대상 27:12","category":"$undefined"},{"id":"11123","book":"역대상","book_name":"역대상","chapter":27,"verse":13,"text":"시월 열째 장관은 세라 족속 느도바 사람 마하래니 그 반열에 이만 사천명이요","reference":"역대상 27:13","category":"$undefined"},{"id":"11124","book":"역대상","book_name":"역대상","chapter":27,"verse":14,"text":"십일월 열 한째 장관은 에브라임 자손에 속한 비라돈 사람 브나 야니 그 반열에 이만 사천명이요","reference":"역대상 27:14","category":"$undefined"},{"id":"11125","book":"역대상","book_name":"역대상","chapter":27,"verse":15,"text":"십이월 열 둘째 장관은 옷니엘 자손에 속한 느도바 사람 헬대니 그 반열에 이만 사천명이었더라","reference":"역대상 27:15","category":"$undefined"},{"id":"11126","book":"역대상","book_name":"역대상","chapter":27,"verse":16,"text":"이스라엘 지파를 관할하는 자는 이러하니라 르우벤 사람의 관장은 시그리의 아들 엘리에셀이요 시므온 사람의 관장은 마아가의 아들 스바댜요","reference":"역대상 27:16","category":"$undefined"},{"id":"11127","book":"역대상","book_name":"역대상","chapter":27,"verse":17,"text":"레위 사람의 관장은 그무엘의 아들 하사뱌요 아론 자손의 관장은 사독이요","reference":"역대상 27:17","category":"$undefined"},{"id":"11128","book":"역대상","book_name":"역대상","chapter":27,"verse":18,"text":"유다의 관장은 다윗의 형 엘리후요 잇사갈의 관장은 미가엘의 아들 오므리요","reference":"역대상 27:18","category":"$undefined"},{"id":"11129","book":"역대상","book_name":"역대상","chapter":27,"verse":19,"text":"스불론의 관장은 오바댜의 아들 이스마야요 납달리의 관장은 아스리엘의 아들 여레못이요","reference":"역대상 27:19","category":"$undefined"},{"id":"11130","book":"역대상","book_name":"역대상","chapter":27,"verse":20,"text":"에브라임 자손의 관장은 아사시야의 아들 호세아요 므낫세 반 지파의 관장은 브다야의 아들 요엘이요","reference":"역대상 27:20","category":"$undefined"},{"id":"11131","book":"역대상","book_name":"역대상","chapter":27,"verse":21,"text":"길르앗에 있는 므낫세 반 지파의 관장은 스가랴의 아들 잇도요 베냐민의 관장은 아브넬의 아들 야아시엘이요","reference":"역대상 27:21","category":"$undefined"},{"id":"11132","book":"역대상","book_name":"역대상","chapter":27,"verse":22,"text":"단의 관장은 여로함의 아들 아사렐이니 이스라엘 지파의 관장이 이러하며","reference":"역대상 27:22","category":"$undefined"},{"id":"11133","book":"역대상","book_name":"역대상","chapter":27,"verse":23,"text":"이스라엘 사람의 이십세 이하의 수효는 다윗이 조사하지 아니하였으니 이는 여호와께서 전에 말씀하시기를 이스라엘 사람을 하늘의 별같이 많게 하리라 하셨음이라","reference":"역대상 27:23","category":"$undefined"},{"id":"11134","book":"역대상","book_name":"역대상","chapter":27,"verse":24,"text":"스루야의 아들 요압이 조사하기를 시작하고 끝내지 못하여서 그 일로 인하여 진노가 이스라엘에게 임한지라 그 수효를 다윗 왕의 역대지략에 기록하지 아니하였더라","reference":"역대상 27:24","category":"$undefined"},{"id":"11135","book":"역대상","book_name":"역대상","chapter":27,"verse":25,"text":"아디엘의 아들 아스마웹은 왕의 곳간을 맡았고 웃시야의 아들 요나단은 밭과 성읍과 촌과 산성의 곳간을 맡았고","reference":"역대상 27:25","category":"$undefined"},{"id":"11136","book":"역대상","book_name":"역대상","chapter":27,"verse":26,"text":"글룹의 아들 에스리는 밭 가는 농부를 거느렸고","reference":"역대상 27:26","category":"$undefined"},{"id":"11137","book":"역대상","book_name":"역대상","chapter":27,"verse":27,"text":"라마 사람 시므이는 포도원을 맡았고 스밤 사람 삽디는 포도원의 소산 포도주 곳간을 맡았고","reference":"역대상 27:27","category":"$undefined"},{"id":"11138","book":"역대상","book_name":"역대상","chapter":27,"verse":28,"text":"게델 사람 바알하난은 평야의 감람나무와 뽕나무를 맡았고 요아스는 기름 곳간을 맡았고","reference":"역대상 27:28","category":"$undefined"},{"id":"11139","book":"역대상","book_name":"역대상","chapter":27,"verse":29,"text":"사론 사람 시드래는 사론에서 먹이는 소떼를 맡았고 아들래의 아들 사밧은 골짜기에 있는 소떼를 맡았고","reference":"역대상 27:29","category":"$undefined"},{"id":"11140","book":"역대상","book_name":"역대상","chapter":27,"verse":30,"text":"이스마엘 사람 오빌은 약대를 맡았고 메로놋 사람 예드야는 나귀를 맡았고 하갈 사람 야시스는 양떼를 맡았으니","reference":"역대상 27:30","category":"$undefined"},{"id":"11141","book":"역대상","book_name":"역대상","chapter":27,"verse":31,"text":"다윗 왕의 재산을 맡은 자들이 이러하였더라","reference":"역대상 27:31","category":"$undefined"},{"id":"11142","book":"역대상","book_name":"역대상","chapter":27,"verse":32,"text":"다윗의 아자비 요나단은 지혜가 있어서 모사가 되며 서기관도 되었고 학모니의 아들 여히엘은 왕의 아들들의 배종이 되었고","reference":"역대상 27:32","category":"$undefined"},{"id":"11143","book":"역대상","book_name":"역대상","chapter":27,"verse":33,"text":"아히도벨은 왕의 모사가 되었고 아렉 사람 후새는 왕의 벗이 되었고","reference":"역대상 27:33","category":"$undefined"},{"id":"11144","book":"역대상","book_name":"역대상","chapter":27,"verse":34,"text":"브나야의 아들 여호야다와 아비아달은 아히도벨의 다음이 되었고 요압은 왕의 군대 장관이 되었더라","reference":"역대상 27:34","category":"$undefined"}],"bookSlug":"1chronicles"}]
