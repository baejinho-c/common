2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":28,"verses":[{"id":"11145","book":"역대상","book_name":"역대상","chapter":28,"verse":1,"text":"다윗이 이스라엘 모든 방백 곧 각 지파의 어른과 체번하어 왕을 섬기는 반장들과 천부장들과 백부장들과 및 왕과 왕자의 산업과 생축의 감독과 환관과 장사와 용사를 예루살렘으로 소집하고","reference":"역대상 28:1","category":"$undefined"},{"id":"11146","book":"역대상","book_name":"역대상","chapter":28,"verse":2,"text":"이에 다윗 왕이 일어서서 가로되 나의 형제들 나의 백성들아 내 말을 들으라 나는 여호와의 언약궤 곧 우리 하나님의 발등상을 봉안할 전 건축할 마음이 있어서 건축할 재료를 준비하였으나","reference":"역대상 28:2","category":"$undefined"},{"id":"11147","book":"역대상","book_name":"역대상","chapter":28,"verse":3,"text":"오직 하나님이 내게 이르시되 너는 군인이라 피를 흘렸으니 내 이름을 위하여 전을 건축하지 못하리라 하셨느니라","reference":"역대상 28:3","category":"$undefined"},{"id":"11148","book":"역대상","book_name":"역대상","chapter":28,"verse":4,"text":"그러나 이스라엘 하나님 여호와께서 전에 나를 내 부친의 온 집에서 택하여 영원히 이스라엘 왕이 되게 하셨나니 곧 하나님이 유다 지파를 택하사 머리를 삼으시고 유다의 족속에서 내 부친의 집을 택하시고 내 부친의 아들들 중에서 나를 기뻐하사 온 이스라엘의 왕을 삼으셨느니라","reference":"역대상 28:4","category":"$undefined"},{"id":"11149","book":"역대상","book_name":"역대상","chapter":28,"verse":5,"text":"여호와께서 내게 여러 아들을 주시고 그 모든 아들중에서 내 아들 솔로몬을 택하사 여호와의 나라 위에 앉혀 이스라엘을 다스리게 하려 하실새","reference":"역대상 28:5","category":"$undefined"},{"id":"11150","book":"역대상","book_name":"역대상","chapter":28,"verse":6,"text":"내게 이르시기를 네 아들 솔로몬 그가 내 전을 건축하고 내 여러 뜰을 만들리니 이는 내가 저를 택하여 내 아들을 삼고 나는 그 아비가 될 것임이라","reference":"역대상 28:6","category":"$undefined"},{"id":"11151","book":"역대상","book_name":"역대상","chapter":28,"verse":7,"text":"저가 만일 나의 계명과 규례를 힘써 준행하기를 오늘날과 같이 하면 내가 그 나라를 영원히 견고케 하리라 하셨느니라","reference":"역대상 28:7","category":"$undefined"},{"id":"11152","book":"역대상","book_name":"역대상","chapter":28,"verse":8,"text":"이제 너희는 온 이스라엘 곧 여호와의 회중의 보는데와 우리 하나님의 들으시는데서 너희 하나님 여호와의 모든 계명을 구하여 지키기로 하라 그리하면 너희가 이 아름다운 땅을 누리고 너희 후손에게 끼쳐 영원한 기업이 되게 하리라","reference":"역대상 28:8","category":"$undefined"},{"id":"11153","book":"역대상","book_name":"역대상","chapter":28,"verse":9,"text":"내 아들 솔로몬아 너는 네 아비의 하나님을 알고 온전한 마음과 기쁜 뜻으로 섬길지어다 여호와께서는 뭇 마음을 감찰하사 모든 사상을 아시나니 네가 저를 찾으면 만날 것이요 버리면 저가 너를 영원히 버리시리라","reference":"역대상 28:9","category":"$undefined"},{"id":"11154","book":"역대상","book_name":"역대상","chapter":28,"verse":10,"text":"그런즉 너는 삼갈지어다 여호와께서 너를 택하여 성소의 전을 건축하게 하셨으니 힘써 행할지니라","reference":"역대상 28:10","category":"$undefined"},{"id":"11155","book":"역대상","book_name":"역대상","chapter":28,"verse":11,"text":"다윗이 전의 낭실과 그 집들과 그 곳간과 다락과 골방과 속죄소의 식양을 그 아들 솔로몬에게 주고","reference":"역대상 28:11","category":"$undefined"},{"id":"11156","book":"역대상","book_name":"역대상","chapter":28,"verse":12,"text":"또 성신의 가르치신 모든 식양 곧 여호와의 전의 뜰과 사면의 모든 방과 하나님의 전 곳간과 성물 곳간의 식양을 주고","reference":"역대상 28:12","category":"$undefined"},{"id":"11157","book":"역대상","book_name":"역대상","chapter":28,"verse":13,"text":"또 제사장과 레위 사람의 반열과 여호와의 전에 섬기는 모든 일과 섬기는 데 쓰는 모든 그릇의 식양을 설명하고","reference":"역대상 28:13","category":"$undefined"},{"id":"11158","book":"역대상","book_name":"역대상","chapter":28,"verse":14,"text":"또 모든 섬기는 데 쓰는 금기명을 만들 금의 중량과 모든 섬기는 데 쓰는 은기명을 만들 은의 중량을 정하고","reference":"역대상 28:14","category":"$undefined"},{"id":"11159","book":"역대상","book_name":"역대상","chapter":28,"verse":15,"text":"또 금등대들과 그 등잔 곧 각등대와 그 등잔을 만들 금의 중량과 은등대와 그 등잔을 만들 은의 중량을 각기 적당하게 하고","reference":"역대상 28:15","category":"$undefined"},{"id":"11160","book":"역대상","book_name":"역대상","chapter":28,"verse":16,"text":"또 진설병의 각 상을 만들 금의 중량을 정하고 은상을 만들 은도 그렇게 하고","reference":"역대상 28:16","category":"$undefined"},{"id":"11161","book":"역대상","book_name":"역대상","chapter":28,"verse":17,"text":"고기 갈고리와 대접과 종자를 만들 정금과 금잔 곧 각 잔을 만들 금의 중량과 또 은잔 곧 각 잔을 만들 은의 중량을 정하고","reference":"역대상 28:17","category":"$undefined"},{"id":"11162","book":"역대상","book_name":"역대상","chapter":28,"verse":18,"text":"또 향단에 쓸 정금과 또 타시는 처소된 그룹들의 식양대로 만들 금의 중량을 정하여 주니 이 그룹들은 날개를 펴서 여호와의 언약궤를 덮는 것이더라","reference":"역대상 28:18","category":"$undefined"},{"id":"11163","book":"역대상","book_name":"역대상","chapter":28,"verse":19,"text":"다윗이 가로되 이 위의 모든 것의 식양을 여호와의 손이 내게 임하여 그려 나로 알게 하셨느니라","reference":"역대상 28:19","category":"$undefined"},{"id":"11164","book":"역대상","book_name":"역대상","chapter":28,"verse":20,"text":"또 그아들 솔로몬에게 이르되 너는 강하고 담대하게 이일을 행하고 두려워 말며 놀라지 말라 네가 여호와의 전 역사의 모든 일을 마칠 동안에 여호와 하나님 나의 하나님이 너와 함께하사 네게서 떠나지 아니하시고 너를 버리지 아니하시리라","reference":"역대상 28:20","category":"$undefined"},{"id":"11165","book":"역대상","book_name":"역대상","chapter":28,"verse":21,"text":"제사장과 레위 사람의 반열이 있으니 여호와의 전의 모든 역사를 도울 것이요 또 모든 공역에 공교한 공장이 기쁜 마음으로 너와 함께 할 것이요 또 모든 장관과 백성이 온전히 네 명령 아래 있으리라","reference":"역대상 28:21","category":"$undefined"}],"bookSlug":"1chronicles"}]
