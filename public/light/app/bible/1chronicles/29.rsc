2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":29,"verses":[{"id":"11166","book":"역대상","book_name":"역대상","chapter":29,"verse":1,"text":"다윗 왕이 온 회중에게 이르되 내 아들 솔로몬이 홀로 하나님의 택하신 바 되었으나 오히려 어리고 연약하고 이 역사는 크도다 이 전은 사람을 위한 것이 아니요 여호와 하나님을 위한 것이라","reference":"역대상 29:1","category":"$undefined"},{"id":"11167","book":"역대상","book_name":"역대상","chapter":29,"verse":2,"text":"내가 이미 내 하나님의 전을 위하여 힘을 다하여 예비하였나니 곧 기구를 만들 금과 은과 놋과 철과 나무며 또 마노와 박을 보석과 꾸밀 보석과 채석과 다른 보석들과 화반석이 매우 많으며","reference":"역대상 29:2","category":"$undefined"},{"id":"11168","book":"역대상","book_name":"역대상","chapter":29,"verse":3,"text":"성전을 위하여 예비한 이 모든 것 외에도 내 마음에 내 하나님의 전을 사모하므로 나의 사유의 금 은으로 내 하나님의 전을 위하여 드렸노니","reference":"역대상 29:3","category":"$undefined"},{"id":"11169","book":"역대상","book_name":"역대상","chapter":29,"verse":4,"text":"곧 오빌의 금 삼천 달란트와 천은 칠천 달란트라 모든 전 벽에 입히며","reference":"역대상 29:4","category":"$undefined"},{"id":"11170","book":"역대상","book_name":"역대상","chapter":29,"verse":5,"text":"금 은 그릇을 만들며 공장의 손으로 하는 모든 일에 쓰게 하였노니 오늘날 누가 즐거이 손에 채워 여호와께 드리겠느냐","reference":"역대상 29:5","category":"$undefined"},{"id":"11171","book":"역대상","book_name":"역대상","chapter":29,"verse":6,"text":"이에 모든 족장과 이스라엘 모든 지파 어른과 천부장과 백부장과 왕의 사무 감독이 다 즐거이 드리되","reference":"역대상 29:6","category":"$undefined"},{"id":"11172","book":"역대상","book_name":"역대상","chapter":29,"verse":7,"text":"하나님의 전 역사를 위하여 금 오천 달란트와 금 다릭 일만과 은 일만 달란트와 놋 일만 팔천 달란트와 철 십만 달란트를 드리고","reference":"역대상 29:7","category":"$undefined"},{"id":"11173","book":"역대상","book_name":"역대상","chapter":29,"verse":8,"text":"무릇 보석이 있는 자는 게르손 사람 여히엘의 손에 부쳐 여호와의 전 곳간에 드렸더라","reference":"역대상 29:8","category":"$undefined"},{"id":"11174","book":"역대상","book_name":"역대상","chapter":29,"verse":9,"text":"백성이 자기의 즐거이 드림으로 기뻐하였으니 곧 저희가 성심으로 여호와께 즐거이 드림이며 다윗 왕도 기쁨을 이기지 못하여 하니라","reference":"역대상 29:9","category":"$undefined"},{"id":"11175","book":"역대상","book_name":"역대상","chapter":29,"verse":10,"text":"다윗이 온 회중앞에서 여호와를 송축하여 가로되 우리 조상 이스라엘의 하나님 여호와여 주는 영원히 송축을 받으시옵소서","reference":"역대상 29:10","category":"$undefined"},{"id":"11176","book":"역대상","book_name":"역대상","chapter":29,"verse":11,"text":"여호와여 ! 광대하심과 권능과 영광과 이김과 위엄이 다 주께 속하였사오니 천지에 있는 것이 다 주의 것이로소이다 여호와여 주권도 주께 속하였사오니 주는 높으사 만유의 머리심이니이다","reference":"역대상 29:11","category":"$undefined"},{"id":"11177","book":"역대상","book_name":"역대상","chapter":29,"verse":12,"text":"부와 귀가 주께로 말미암고 또 주는 만유의 주재가 되사 손에 권세와 능력이 있사오니 모든 자를 크게 하심과 강하게 하심이 주의 손에 있나이다","reference":"역대상 29:12","category":"$undefined"},{"id":"11178","book":"역대상","book_name":"역대상","chapter":29,"verse":13,"text":"우리 하나님이여 ! 이제 우리가 주께 감사하오며 주의 영화로운 이름을 찬양하나이다","reference":"역대상 29:13","category":"$undefined"},{"id":"11179","book":"역대상","book_name":"역대상","chapter":29,"verse":14,"text":"나와 나의 백성이 무엇이관대 이처럼 즐거운 마음으로 드릴 힘이있었나이까 모든 것이 주께로 말미암았사오니 우리가 주의 손에서 받은 것으로 주께 드렸을 뿐이니이다","reference":"역대상 29:14","category":"$undefined"},{"id":"11180","book":"역대상","book_name":"역대상","chapter":29,"verse":15,"text":"주 앞에서는 우리가 우리 열조와 다름이 없이 나그네와 우거한 자라 세상에 있는 날이 그림자 같아서 머무름이 없나이다","reference":"역대상 29:15","category":"$undefined"},{"id":"11181","book":"역대상","book_name":"역대상","chapter":29,"verse":16,"text":"우리 하나님 여호와여 ! 우리가 주의 거룩한 이름을 위하여 전을 건축하려고 미리 저축한 이 모든 물건이 다 주의 손에서 왔사오니 다 주의 것이니이다","reference":"역대상 29:16","category":"$undefined"},{"id":"11182","book":"역대상","book_name":"역대상","chapter":29,"verse":17,"text":"나의 하나님이여 ! 주께서 마음을 감찰하시고 정직을 기뻐하시는줄 내가 아나이다 내가 정직한 마음으로 이 모든 것을 즐거이 드렸사오며 이제 내가 또 여기있는 주의 백성이 주께 즐거이 드리는 것을 보오니 심히 기쁘도소이다","reference":"역대상 29:17","category":"$undefined"},{"id":"11183","book":"역대상","book_name":"역대상","chapter":29,"verse":18,"text":"우리 열조 아브라함과 이삭과 이스라엘의 하나님 여호와여 주께서 이것을 주의 백성의 심중에 영원히 두어 생각하게 하시고 그 마음을 예비하여 주께로 돌아오게 하옵시며","reference":"역대상 29:18","category":"$undefined"},{"id":"11184","book":"역대상","book_name":"역대상","chapter":29,"verse":19,"text":"또 내 아들 솔로몬에게 정성된 마음을 주사 주의 계명과 법도와 율례를 지켜 이 모든 일을 행하게 하시고 내가 위하여 예비한 것으로 전을 건축하게 하옵소서","reference":"역대상 29:19","category":"$undefined"},{"id":"11185","book":"역대상","book_name":"역대상","chapter":29,"verse":20,"text":"다윗이 온 회중에게 이르되 너희는 너희 하나님 여호와를 송축하라 하매 회중이 그 열조의 하나님 여호와를 송축하고 머리를 숙여 여호와와 왕에게 절하고","reference":"역대상 29:20","category":"$undefined"},{"id":"11186","book":"역대상","book_name":"역대상","chapter":29,"verse":21,"text":"이튿날 여호와께 제사를 드리고 또 번제를 드리니 수송아지가 일천이요 수양이 일천이요 어린 양이 일천이요 또 그 전제라 온 이스라엘을 위하여 풍성한 제물을 드리고","reference":"역대상 29:21","category":"$undefined"},{"id":"11187","book":"역대상","book_name":"역대상","chapter":29,"verse":22,"text":"이 날에 무리가 크게 기뻐하여 여호와 앞에서 먹으며 마셨더라 무리가 다윗의 아들 솔로몬으로 다시 왕을 삼아 기름을 부어 여호와께 돌려 주권자가 되게 하고 사독에게도 기름을 부어 제사장이 되게 하니라","reference":"역대상 29:22","category":"$undefined"},{"id":"11188","book":"역대상","book_name":"역대상","chapter":29,"verse":23,"text":"솔로몬이 여호와께서 주신 위에 앉아 부친 다윗을 이어 왕이 되어 형통하니 온 이스라엘이 그 명령을 순종하며","reference":"역대상 29:23","category":"$undefined"},{"id":"11189","book":"역대상","book_name":"역대상","chapter":29,"verse":24,"text":"모든 방백과 용사와 다윗 왕의 여러 아들이 솔로몬 왕에게 복종하니","reference":"역대상 29:24","category":"$undefined"},{"id":"11190","book":"역대상","book_name":"역대상","chapter":29,"verse":25,"text":"여호와께서 솔로몬으로 이스라엘 무리의 목전에 심히 존대케 하시고 또 왕의 위엄을 주사 그 전 이스라엘 모든 왕보다 뛰어나게 하셨더라","reference":"역대상 29:25","category":"$undefined"},{"id":"11191","book":"역대상","book_name":"역대상","chapter":29,"verse":26,"text":"이새의 아들 다윗이 온 이스라엘의 왕이 되어","reference":"역대상 29:26","category":"$undefined"},{"id":"11192","book":"역대상","book_name":"역대상","chapter":29,"verse":27,"text":"이스라엘을 치리한 날짜는 사십년이라 헤브론에서 칠년을 치리하였고 예루살렘에서 삼십 삼년을 치리하였더라","reference":"역대상 29:27","category":"$undefined"},{"id":"11193","book":"역대상","book_name":"역대상","chapter":29,"verse":28,"text":"저가 나이 많아 늙도록 부하고 존귀하다가 죽으매 그 아들 솔로몬이 대신하여 왕이 되니라","reference":"역대상 29:28","category":"$undefined"},{"id":"11194","book":"역대상","book_name":"역대상","chapter":29,"verse":29,"text":"다윗 왕의 시종 행적이 선견자 사무엘의 글과 선지자 나단의 글과 선견자 갓의 글에 다 기록되고","reference":"역대상 29:29","category":"$undefined"},{"id":"11195","book":"역대상","book_name":"역대상","chapter":29,"verse":30,"text":"또 저의 왕 된 일과 그 권세와 저와 이스라엘과 온 세상 열국의 지난 시사가 다 기록되니라","reference":"역대상 29:30","category":"$undefined"}],"bookSlug":"1chronicles"}]
