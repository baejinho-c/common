11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":3,"verses":[{"id":"10363","book":"역대상","book_name":"역대상","chapter":3,"verse":1,"text":"다윗이 헤브론에서 낳은 아들들이 이러하니 맏아들은 압논이라 이스르엘 여인 아히노암의 소생이요 둘째는 다니엘이라 갈멜 여인 아비가일의 소생이요","reference":"역대상 3:1","category":"$undefined"},{"id":"10364","book":"역대상","book_name":"역대상","chapter":3,"verse":2,"text":"세째는 압살롬이라 그술 왕 달매의 딸 마아가의 아들이요 네째는 아도니야라 학깃의 아들이요","reference":"역대상 3:2","category":"$undefined"},{"id":"10365","book":"역대상","book_name":"역대상","chapter":3,"verse":3,"text":"다섯째는 스바댜라 아비달의 소생이요, 여섯째는 이드르암이라 다윗의 아내 에글라의 소생이니","reference":"역대상 3:3","category":"$undefined"},{"id":"10366","book":"역대상","book_name":"역대상","chapter":3,"verse":4,"text":"이 여섯은 다윗이 헤브론에서 낳은 자라 다윗이 거기서 칠년 육개월을 치리하였고 또 예루살렘에서 삼십 삼년을 치리하였으며","reference":"역대상 3:4","category":"$undefined"},{"id":"10367","book":"역대상","book_name":"역대상","chapter":3,"verse":5,"text":"예루살렘에서 낳은 아들들은 이러하니 시므아와, 소밥과, 나단과, 솔로몬 네 사람은 다 암미엘의 딸 밧수아의 소생이요","reference":"역대상 3:5","category":"$undefined"},{"id":"10368","book":"역대상","book_name":"역대상","chapter":3,"verse":6,"text":"또 입할과, 엘리사마와, 엘리벨렛과","reference":"역대상 3:6","category":"$undefined"},{"id":"10369","book":"역대상","book_name":"역대상","chapter":3,"verse":7,"text":"노가와, 네벡과, 야비야와","reference":"역대상 3:7","category":"$undefined"},{"id":"10370","book":"역대상","book_name":"역대상","chapter":3,"verse":8,"text":"엘리사마와, 엘랴다와, 엘리벨렛 아홉 사람은","reference":"역대상 3:8","category":"$undefined"},{"id":"10371","book":"역대상","book_name":"역대상","chapter":3,"verse":9,"text":"다 다윗의 아들이요 저희의 누이는 다말이며 이 외에 또 첩의 아들이 있었더라","reference":"역대상 3:9","category":"$undefined"},{"id":"10372","book":"역대상","book_name":"역대상","chapter":3,"verse":10,"text":"솔로몬의 아들은 르호보암이요, 그 아들은 아비야요, 그 아들은 아사요, 그 아들은 여호사밧이요","reference":"역대상 3:10","category":"$undefined"},{"id":"10373","book":"역대상","book_name":"역대상","chapter":3,"verse":11,"text":"그 아들은 요람이요, 그 아들은 아하시야요, 그 아들은 요아스요","reference":"역대상 3:11","category":"$undefined"},{"id":"10374","book":"역대상","book_name":"역대상","chapter":3,"verse":12,"text":"그 아들은 아마샤요, 그 아들은 아사랴요, 그 아들은 요담이요","reference":"역대상 3:12","category":"$undefined"},{"id":"10375","book":"역대상","book_name":"역대상","chapter":3,"verse":13,"text":"그 아들은 아하스요, 그 아들은 히스기야요, 그 아들은 므낫세요","reference":"역대상 3:13","category":"$undefined"},{"id":"10376","book":"역대상","book_name":"역대상","chapter":3,"verse":14,"text":"그 아들은 아몬이요, 그 아들은 요시야며","reference":"역대상 3:14","category":"$undefined"},{"id":"10377","book":"역대상","book_name":"역대상","chapter":3,"verse":15,"text":"요시야의 아들들은 맏아들 요하난과 둘째 여호야김과 세째 시드기야와 네째 살룸이요","reference":"역대상 3:15","category":"$undefined"},{"id":"10378","book":"역대상","book_name":"역대상","chapter":3,"verse":16,"text":"여호야김의 아들들은 그 아들 여고냐 그 아들 시드기야요","reference":"역대상 3:16","category":"$undefined"},{"id":"10379","book":"역대상","book_name":"역대상","chapter":3,"verse":17,"text":"사로잡혀 간 여고냐의 아들들은 그 아들 스알디엘과","reference":"역대상 3:17","category":"$undefined"},{"id":"10380","book":"역대상","book_name":"역대상","chapter":3,"verse":18,"text":"말기람과, 브다야와, 세낫살과, 여가먀와, 호사마와, 느다뱌요","reference":"역대상 3:18","category":"$undefined"},{"id":"10381","book":"역대상","book_name":"역대상","chapter":3,"verse":19,"text":"브다야의 아들들은 스룹바벨과, 시므이요 스룹바벨의 아들은 므술람과, 하나냐와, 그 매제 슬로밋과","reference":"역대상 3:19","category":"$undefined"},{"id":"10382","book":"역대상","book_name":"역대상","chapter":3,"verse":20,"text":"또 하수바와, 오헬과, 베레갸와, 하사댜와, 유삽헤셋 다섯 사람이요","reference":"역대상 3:20","category":"$undefined"},{"id":"10383","book":"역대상","book_name":"역대상","chapter":3,"verse":21,"text":"하나냐의 아들은 블라댜와, 여사야요, 또 르바야의 아들 아르난의 아들들,오바댜의 아들들, 스가냐의 아들들이니","reference":"역대상 3:21","category":"$undefined"},{"id":"10384","book":"역대상","book_name":"역대상","chapter":3,"verse":22,"text":"스가냐의 아들은 스마야요, 스마야의 아들들은 핫두스와, 이갈과, 바리야와, 느아랴와, 사밧 여섯 사람이요","reference":"역대상 3:22","category":"$undefined"},{"id":"10385","book":"역대상","book_name":"역대상","chapter":3,"verse":23,"text":"느아랴의 아들은 엘료에내와, 히스기야와, 아스리감 세 사람이요","reference":"역대상 3:23","category":"$undefined"},{"id":"10386","book":"역대상","book_name":"역대상","chapter":3,"verse":24,"text":"엘료에내의 아들들은 호다위야와, 엘리아십과, 블라야와, 악굽과, 요하난과, 들라야와, 아나니 일곱 사람이더라","reference":"역대상 3:24","category":"$undefined"}],"bookSlug":"1chronicles"}]
