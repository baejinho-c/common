2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":4,"verses":[{"id":"10387","book":"역대상","book_name":"역대상","chapter":4,"verse":1,"text":"유다의 아들들은 베레스와, 헤스론과, 갈미와, 훌과, 소발이라","reference":"역대상 4:1","category":"$undefined"},{"id":"10388","book":"역대상","book_name":"역대상","chapter":4,"verse":2,"text":"소발의 아들 르아야는 야핫을 낳았고, 야핫은 아후매와, 라핫을 낳았으니 이는 소라 사람의 족속이며","reference":"역대상 4:2","category":"$undefined"},{"id":"10389","book":"역대상","book_name":"역대상","chapter":4,"verse":3,"text":"에담 조상의 자손들은 이스르엘과, 이스마와, 잇바스와 저희의 매제 하술렐보니와","reference":"역대상 4:3","category":"$undefined"},{"id":"10390","book":"역대상","book_name":"역대상","chapter":4,"verse":4,"text":"그들의 아비 브누엘과, 후사의 아비 에셀이니 이는 다 베들레헴의 아비 에브라다의 맏아들 훌의 소생이며","reference":"역대상 4:4","category":"$undefined"},{"id":"10391","book":"역대상","book_name":"역대상","chapter":4,"verse":5,"text":"드고아의 아비 아스훌의 두 아내는 헬라와, 나아라라","reference":"역대상 4:5","category":"$undefined"},{"id":"10392","book":"역대상","book_name":"역대상","chapter":4,"verse":6,"text":"나아라는 그로 말미암아 아훗삼과, 헤벨과, 데므니와, 하아하스다리를 낳았으니 이는 나아라의 소생이요","reference":"역대상 4:6","category":"$undefined"},{"id":"10393","book":"역대상","book_name":"역대상","chapter":4,"verse":7,"text":"헬라의 아들들은 세렛과, 이소할과, 에드난이며","reference":"역대상 4:7","category":"$undefined"},{"id":"10394","book":"역대상","book_name":"역대상","chapter":4,"verse":8,"text":"고스는 아눕과 소베바와 하룸의 아들 아하헬 족속들을 낳았으며","reference":"역대상 4:8","category":"$undefined"},{"id":"10395","book":"역대상","book_name":"역대상","chapter":4,"verse":9,"text":"야베스는 그 형제보다 존귀한 자라 그 어미가 이름하여 야베스라 하였으니 이는 내가 수고로이 낳았다 함이었더라","reference":"역대상 4:9","category":"$undefined"},{"id":"10396","book":"역대상","book_name":"역대상","chapter":4,"verse":10,"text":"야베스가 이스라엘 하나님께 아뢰어 가로되 `원컨대 주께서 내게 복에 복을 더하사 나의 지경을 넓히시고 주의 손으로 나를 도우사 나로 환난을 벗어나 근심이 없게 하옵소서' 하였더니 하나님이 그 구하는 것을 허락하셨더라","reference":"역대상 4:10","category":"$undefined"},{"id":"10397","book":"역대상","book_name":"역대상","chapter":4,"verse":11,"text":"수하의 형 글룹이 므힐을 낳았으니 므힐은 에스돈의 아비요","reference":"역대상 4:11","category":"$undefined"},{"id":"10398","book":"역대상","book_name":"역대상","chapter":4,"verse":12,"text":"에스돈은 베드라바와, 바세아와, 이르나하스의 아비 드힌나를 낳았으니 이는 다 레가 사람이며","reference":"역대상 4:12","category":"$undefined"},{"id":"10399","book":"역대상","book_name":"역대상","chapter":4,"verse":13,"text":"그나스의 아들들은 옷니엘과 스라야요, 옷니엘의 아들은 하닷이며","reference":"역대상 4:13","category":"$undefined"},{"id":"10400","book":"역대상","book_name":"역대상","chapter":4,"verse":14,"text":"므오노대는 오브라를 낳았고, 스라야는 요압을 낳았으니 요압은 게하라심의 조상이라 저희들은 공장이었더라","reference":"역대상 4:14","category":"$undefined"},{"id":"10401","book":"역대상","book_name":"역대상","chapter":4,"verse":15,"text":"여분네의 아들 갈렙의 자손은 이루와, 엘라와, 나암과, 엘라의 자손과, 그나스요","reference":"역대상 4:15","category":"$undefined"},{"id":"10402","book":"역대상","book_name":"역대상","chapter":4,"verse":16,"text":"여할렐렐의 아들은 십과, 시바와, 디리아와, 아사렐이요","reference":"역대상 4:16","category":"$undefined"},{"id":"10403","book":"역대상","book_name":"역대상","chapter":4,"verse":17,"text":"에스라의 아들들은 예델과, 메렛과, 에벨과, 얄론이며 메렛은 미리암과, 삼매와, 에스도모아의 조상 이스바를 낳았으니","reference":"역대상 4:17","category":"$undefined"},{"id":"10404","book":"역대상","book_name":"역대상","chapter":4,"verse":18,"text":"이는 메렛의 취한 바로의 딸 비디아의 아들들이며 또 그 아내 여후디야는 그돌의 조상 예렛과 소고의 조상 헤벨과 사노아의 조상 여구디엘을 낳았으며","reference":"역대상 4:18","category":"$undefined"},{"id":"10405","book":"역대상","book_name":"역대상","chapter":4,"verse":19,"text":"나함의 누이인 호디야의 아내의 아들들은 가미 사람 그일라의 아비와 마아가 사람 에스드모아며","reference":"역대상 4:19","category":"$undefined"},{"id":"10406","book":"역대상","book_name":"역대상","chapter":4,"verse":20,"text":"시몬의 아들들은 암논과, 린나와, 벤하난과, 딜론이요 이시의 아들들은 소헷과 벤소헷이더라","reference":"역대상 4:20","category":"$undefined"},{"id":"10407","book":"역대상","book_name":"역대상","chapter":4,"verse":21,"text":"유다의 아들 셀라의 자손은 레가의 아비 에르와, 마레사의 아비 라아다와 세마포 짜는 자의 집 곧 아스베야의 집 족속과","reference":"역대상 4:21","category":"$undefined"},{"id":"10408","book":"역대상","book_name":"역대상","chapter":4,"verse":22,"text":"또 요김과 고세바 사람들과 요아스와 모압을 다스리던 사랍과 야수비네헴이니 이는 다 옛 기록에 의지한 것이라","reference":"역대상 4:22","category":"$undefined"},{"id":"10409","book":"역대상","book_name":"역대상","chapter":4,"verse":23,"text":"이 모든 사람은 옹기장이가 되어 수풀과 산울 가운데 거하는 자로서 거기서 왕과 함께 거하여 왕의 일을 하였더라","reference":"역대상 4:23","category":"$undefined"},{"id":"10410","book":"역대상","book_name":"역대상","chapter":4,"verse":24,"text":"시므온의 아들들은 느무엘과, 야민과, 야립과, 세라와, 사울이요","reference":"역대상 4:24","category":"$undefined"},{"id":"10411","book":"역대상","book_name":"역대상","chapter":4,"verse":25,"text":"사울의 아들은 살룸이요, 그 아들은 밉삼이요, 그 아들은 미스마요","reference":"역대상 4:25","category":"$undefined"},{"id":"10412","book":"역대상","book_name":"역대상","chapter":4,"verse":26,"text":"미스마의 아들은 함무엘이요, 그 아들은 삭굴이요, 그 아들은 시므이라","reference":"역대상 4:26","category":"$undefined"},{"id":"10413","book":"역대상","book_name":"역대상","chapter":4,"verse":27,"text":"시므이는 아들 열 여섯과 딸 여섯이 있으나 그 형제에게는 자녀가 몇이 못되니 그 온 족속이 유다 자손처럼 번성하지 못하였더라","reference":"역대상 4:27","category":"$undefined"},{"id":"10414","book":"역대상","book_name":"역대상","chapter":4,"verse":28,"text":"시므온 자손의 거한 곳은 브엘세바와, 몰라다와, 하살수알과","reference":"역대상 4:28","category":"$undefined"},{"id":"10415","book":"역대상","book_name":"역대상","chapter":4,"verse":29,"text":"빌하와, 에셈과, 돌랏과","reference":"역대상 4:29","category":"$undefined"},{"id":"10416","book":"역대상","book_name":"역대상","chapter":4,"verse":30,"text":"브두엘과, 호르마와, 시글락과","reference":"역대상 4:30","category":"$undefined"},{"id":"10417","book":"역대상","book_name":"역대상","chapter":4,"verse":31,"text":"벧말가봇과, 하살수심과, 벧비리와, 사아라임이니 다윗 왕 때까지 이모든 성읍이 저희에게 속하였으며","reference":"역대상 4:31","category":"$undefined"},{"id":"10418","book":"역대상","book_name":"역대상","chapter":4,"verse":32,"text":"그 향촌은 에담과, 아인과, 림몬과, 도겐과, 아산 다섯 성읍이요","reference":"역대상 4:32","category":"$undefined"},{"id":"10419","book":"역대상","book_name":"역대상","chapter":4,"verse":33,"text":"또 그 각 성읍 사면에 촌이 있어 바알까지 미쳤으니 시므온 자손의 주소가 이러하고 각기 보계가 있더라","reference":"역대상 4:33","category":"$undefined"},{"id":"10420","book":"역대상","book_name":"역대상","chapter":4,"verse":34,"text":"또 메소밥과, 야믈렉과, 아마시야의 아들 요사와","reference":"역대상 4:34","category":"$undefined"},{"id":"10421","book":"역대상","book_name":"역대상","chapter":4,"verse":35,"text":"요엘과 아시엘의 증손 스라야의 손자, 요시비야의 아들 예후와","reference":"역대상 4:35","category":"$undefined"},{"id":"10422","book":"역대상","book_name":"역대상","chapter":4,"verse":36,"text":"또 엘료에내와, 야아고바와, 여소하야와, 아사야와, 아디엘과, 여시미엘과, 브나야와","reference":"역대상 4:36","category":"$undefined"},{"id":"10423","book":"역대상","book_name":"역대상","chapter":4,"verse":37,"text":"또 스마야의 오대손 시므리의 현손 여다야의 증손 알론의 손자 시비의 아들 시사니","reference":"역대상 4:37","category":"$undefined"},{"id":"10424","book":"역대상","book_name":"역대상","chapter":4,"verse":38,"text":"이 위에 녹명된 자는 다 그 본족의 족장이라 그 종족이 더욱 번성한지라","reference":"역대상 4:38","category":"$undefined"},{"id":"10425","book":"역대상","book_name":"역대상","chapter":4,"verse":39,"text":"저희가 그 양떼를 위하여 목장을 구하고자 하여 골짜기 동편 그돌 지경에 이르러","reference":"역대상 4:39","category":"$undefined"},{"id":"10426","book":"역대상","book_name":"역대상","chapter":4,"verse":40,"text":"아름답고 기름진 목장을 발견하였는데 그 땅이 광활하고 안정하니 이는 옛적부터 거기 거한 사람은 함의 자손인 까닭이라","reference":"역대상 4:40","category":"$undefined"},{"id":"10427","book":"역대상","book_name":"역대상","chapter":4,"verse":41,"text":"이 위에 녹명된 자가 유다 왕 히스기야 때에 가서 저희의 장막을 쳐서 파하고 거기 있는 모우님 사람을 쳐서 진멸하고 대신하여 오늘까지 거기 거하였으니 이는 그 양떼를 먹일 목장이 거기 있음이며","reference":"역대상 4:41","category":"$undefined"},{"id":"10428","book":"역대상","book_name":"역대상","chapter":4,"verse":42,"text":"또 시므온 자손 중에 오백명이 이시의 아들 블라디야와, 느아랴와, 르바야와, 웃시엘로 두목을 삼고 세일 산으로 가서","reference":"역대상 4:42","category":"$undefined"},{"id":"10429","book":"역대상","book_name":"역대상","chapter":4,"verse":43,"text":"피하여 남아 있는 아말렉 사람을 치고 오늘까지 거기 거하였더라","reference":"역대상 4:43","category":"$undefined"}],"bookSlug":"1chronicles"}]
