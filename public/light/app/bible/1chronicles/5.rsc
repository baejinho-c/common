11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":5,"verses":[{"id":"10430","book":"역대상","book_name":"역대상","chapter":5,"verse":1,"text":"이스라엘의 장자 르우벤의 아들들은 이러하니라 (르우벤은 장자라도 그 아비의 침상을 더럽게 하였으므로 장자의 명분이 이스라엘의 아들 요셉의 자손에게로 돌아갔으나 족보에는 장자의 명분대로 기록할 것이 아니니라","reference":"역대상 5:1","category":"$undefined"},{"id":"10431","book":"역대상","book_name":"역대상","chapter":5,"verse":2,"text":"유다는 형제보다 뛰어나고 주권자가 유다로 말미암아 났을지라도 장자의 명분은 요셉에게 있으니라)","reference":"역대상 5:2","category":"$undefined"},{"id":"10432","book":"역대상","book_name":"역대상","chapter":5,"verse":3,"text":"이스라엘의 장자 르우벤의 아들들은 하녹과, 발루와, 헤스론과, 갈미요","reference":"역대상 5:3","category":"$undefined"},{"id":"10433","book":"역대상","book_name":"역대상","chapter":5,"verse":4,"text":"요엘의 아들은 스마야요, 그 아들은 곡이요, 그 아들은 시므이요","reference":"역대상 5:4","category":"$undefined"},{"id":"10434","book":"역대상","book_name":"역대상","chapter":5,"verse":5,"text":"그 아들은 미가요, 그 아들은 르아야요, 그 아들은 바알이요","reference":"역대상 5:5","category":"$undefined"},{"id":"10435","book":"역대상","book_name":"역대상","chapter":5,"verse":6,"text":"그 아들은 브에라니 저는 르우벤 자손의 두목으로서 앗수르 왕 디글랏빌레셀에게 사로잡힌자라","reference":"역대상 5:6","category":"$undefined"},{"id":"10436","book":"역대상","book_name":"역대상","chapter":5,"verse":7,"text":"저의 형제가 종족과 보계대로 족장 된자는 여이엘과, 스가랴와","reference":"역대상 5:7","category":"$undefined"},{"id":"10437","book":"역대상","book_name":"역대상","chapter":5,"verse":8,"text":"벨라니 벨라는 아사스의 아들이요, 세마의 손자요, 요엘의 증손이라 저가 아로엘에 거하여 느보와 바알므온까지 미쳤고","reference":"역대상 5:8","category":"$undefined"},{"id":"10438","book":"역대상","book_name":"역대상","chapter":5,"verse":9,"text":"또 동으로 가서 거하여 유브라데강에서부터 광야 지경까지 미쳤으니 이는 길르앗 땅에서 그 생축이 번식함이라","reference":"역대상 5:9","category":"$undefined"},{"id":"10439","book":"역대상","book_name":"역대상","chapter":5,"verse":10,"text":"사울왕 때에 저희가 하갈 사람으로 더불어 싸워 쳐 죽이고 길르앗 동편 온 땅에서 장막에 거하였더라","reference":"역대상 5:10","category":"$undefined"},{"id":"10440","book":"역대상","book_name":"역대상","chapter":5,"verse":11,"text":"갓 자손은 르우벤 사람을 마주 대하여 바산 땅에 거하여 살르가까지 미쳤으니","reference":"역대상 5:11","category":"$undefined"},{"id":"10441","book":"역대상","book_name":"역대상","chapter":5,"verse":12,"text":"족장은 요엘이요, 다음은 사밤이요, 또 야내와, 바산에 거한 사밧이요","reference":"역대상 5:12","category":"$undefined"},{"id":"10442","book":"역대상","book_name":"역대상","chapter":5,"verse":13,"text":"그 족속 형제에는 미가엘과, 므술람과, 세바와, 요래와, 야간과, 시아와, 에벨 일곱명이니","reference":"역대상 5:13","category":"$undefined"},{"id":"10443","book":"역대상","book_name":"역대상","chapter":5,"verse":14,"text":"이는 다 아비하일의 아들이라 아비하일은 후리의 아들이요, 야로의 손자요, 길르앗의 증손이요, 미가엘의 현손이요, 여시새의 오대 손이요, 야도의 육대 손이요, 부스의 칠대 손이며,","reference":"역대상 5:14","category":"$undefined"},{"id":"10444","book":"역대상","book_name":"역대상","chapter":5,"verse":15,"text":"또 구니의 손자 압디엘의 아들 아히가 족장이 되었고","reference":"역대상 5:15","category":"$undefined"},{"id":"10445","book":"역대상","book_name":"역대상","chapter":5,"verse":16,"text":"저희가 바산길르앗과 그 향촌과 사론의 모든 들에 거하여 그 사방 변경에 미쳤더라","reference":"역대상 5:16","category":"$undefined"},{"id":"10446","book":"역대상","book_name":"역대상","chapter":5,"verse":17,"text":"이상은 유다 왕 요담과 이스라엘 왕 여로보암 때에 족보에 기록 되었더라","reference":"역대상 5:17","category":"$undefined"},{"id":"10447","book":"역대상","book_name":"역대상","chapter":5,"verse":18,"text":"르우벤 자손과 갓 사람과 므낫세 반 지파의 나가 싸울 만한 용사 곧 능히 방패와 칼을 들며 활을 당기어 싸움에 익숙한 자가 사만 사천 칠백 육십인이라","reference":"역대상 5:18","category":"$undefined"},{"id":"10448","book":"역대상","book_name":"역대상","chapter":5,"verse":19,"text":"저희가 하갈 사람과, 여두르와, 나비스와, 노답과 싸우는 중에","reference":"역대상 5:19","category":"$undefined"},{"id":"10449","book":"역대상","book_name":"역대상","chapter":5,"verse":20,"text":"도우심을 입었으므로 하갈 사람과 그 함께한 자들이 다 저희 손에 패하였으니 이는 저희가 싸울 때에 하나님께 의뢰하고 부르짖음을 하나님이 들으셨음이라","reference":"역대상 5:20","category":"$undefined"},{"id":"10450","book":"역대상","book_name":"역대상","chapter":5,"verse":21,"text":"저희가 대적의 짐승 곧 약대 오만과 양 이십 오만과 나귀 이천을 빼앗으며 사람 십만을 사로잡았고","reference":"역대상 5:21","category":"$undefined"},{"id":"10451","book":"역대상","book_name":"역대상","chapter":5,"verse":22,"text":"죽임을 당한 자가 많았으니 이 싸움이 하나님께로 말미암았음이라 저희가 그 땅에 거하여 사로잡힐 때까지 이르렀더라","reference":"역대상 5:22","category":"$undefined"},{"id":"10452","book":"역대상","book_name":"역대상","chapter":5,"verse":23,"text":"므낫세 반 지파 자손들이 그 땅에 거하여 번성하여 바산에서부터 바알 헤르몬과 스닐과 헤르몬 산까지 미쳤으며","reference":"역대상 5:23","category":"$undefined"},{"id":"10453","book":"역대상","book_name":"역대상","chapter":5,"verse":24,"text":"그 족장은 에벨과, 이시와, 엘리엘과, 아스리엘과, 예레미야와, 호다위야와, 야디엘이라 다 용력이 유명한 족장이었더라","reference":"역대상 5:24","category":"$undefined"},{"id":"10454","book":"역대상","book_name":"역대상","chapter":5,"verse":25,"text":"저희가 그 열조의 하나님께 범죄하여 하나님이 저희 앞에서 멸하신 그 땅 백성의 신들을 간음하듯 섬긴지라","reference":"역대상 5:25","category":"$undefined"},{"id":"10455","book":"역대상","book_name":"역대상","chapter":5,"verse":26,"text":"그러므로 이스라엘 하나님이 앗수르 왕 불의 마음을 일으키시며 앗수르 왕 디글랏 빌레셀의 마음을 일으키시매 곧 르우벤과 갓과 므낫세 반 지파를 사로잡아 할라와 하볼과 하라와 고산 하숫가에 옮긴지라 저희가 오늘날까지 거기 있으니라","reference":"역대상 5:26","category":"$undefined"}],"bookSlug":"1chronicles"}]
