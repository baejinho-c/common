2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":6,"verses":[{"id":"10456","book":"역대상","book_name":"역대상","chapter":6,"verse":1,"text":"레위의 아들들은 게르손과, 그핫과, 므라리요,","reference":"역대상 6:1","category":"$undefined"},{"id":"10457","book":"역대상","book_name":"역대상","chapter":6,"verse":2,"text":"그핫의 아들들은 아므람과, 이스할과, 헤브론과, 웃시엘이요,","reference":"역대상 6:2","category":"$undefined"},{"id":"10458","book":"역대상","book_name":"역대상","chapter":6,"verse":3,"text":"아므람의 자녀는 아론과 모세와 미리암이요 아론의 아들들은 나답과, 아비후와, 엘르아살과, 이다말이며","reference":"역대상 6:3","category":"$undefined"},{"id":"10459","book":"역대상","book_name":"역대상","chapter":6,"verse":4,"text":"엘르아살은 비느하스를 낳았고, 비느하스는 아비수아를 낳았고,","reference":"역대상 6:4","category":"$undefined"},{"id":"10460","book":"역대상","book_name":"역대상","chapter":6,"verse":5,"text":"아비수아는 북기를 낳았고, 북기는 웃시를 낳았고,","reference":"역대상 6:5","category":"$undefined"},{"id":"10461","book":"역대상","book_name":"역대상","chapter":6,"verse":6,"text":"웃시는 스라히야를 낳았고, 스라히야는 므라욧을 낳았고,","reference":"역대상 6:6","category":"$undefined"},{"id":"10462","book":"역대상","book_name":"역대상","chapter":6,"verse":7,"text":"므라욧은 아마랴를 낳았고, 아마랴는 아히둡을 낳았고,","reference":"역대상 6:7","category":"$undefined"},{"id":"10463","book":"역대상","book_name":"역대상","chapter":6,"verse":8,"text":"아히둡은 사독을 낳았고, 사독은 아히마아스를 낳았고,","reference":"역대상 6:8","category":"$undefined"},{"id":"10464","book":"역대상","book_name":"역대상","chapter":6,"verse":9,"text":"아히마아스는 아사랴를 낳았고, 아사랴는 요하난을 낳았고,","reference":"역대상 6:9","category":"$undefined"},{"id":"10465","book":"역대상","book_name":"역대상","chapter":6,"verse":10,"text":"요하난은 아사랴를 낳았으니 이 아사랴는 솔로몬이 예루살렘에 세운 전에서 제사장의 직분을 행한 자며","reference":"역대상 6:10","category":"$undefined"},{"id":"10466","book":"역대상","book_name":"역대상","chapter":6,"verse":11,"text":"아사랴는 아마랴를 낳았고, 아마랴는 아히둡을 낳았고,","reference":"역대상 6:11","category":"$undefined"},{"id":"10467","book":"역대상","book_name":"역대상","chapter":6,"verse":12,"text":"아히둡은 사독을 낳았고, 사독은 살룸을 낳았고,","reference":"역대상 6:12","category":"$undefined"},{"id":"10468","book":"역대상","book_name":"역대상","chapter":6,"verse":13,"text":"살룸은 힐기야를 낳았고, 힐기야는 아사랴를 낳았고,","reference":"역대상 6:13","category":"$undefined"},{"id":"10469","book":"역대상","book_name":"역대상","chapter":6,"verse":14,"text":"아사랴는 스라야를 낳았고, 스라야는 여호사닥을 낳았으며,","reference":"역대상 6:14","category":"$undefined"},{"id":"10470","book":"역대상","book_name":"역대상","chapter":6,"verse":15,"text":"여호와께서 느부갓네살의 손으로 유다와 예루살렘 백성을 옮기실 때에 여호사닥도 갔었더라","reference":"역대상 6:15","category":"$undefined"},{"id":"10471","book":"역대상","book_name":"역대상","chapter":6,"verse":16,"text":"레위의 아들들은 게르손과, 그핫과, 므라리며","reference":"역대상 6:16","category":"$undefined"},{"id":"10472","book":"역대상","book_name":"역대상","chapter":6,"verse":17,"text":"게르손의 아들의 이름은 립니와, 시므이요,","reference":"역대상 6:17","category":"$undefined"},{"id":"10473","book":"역대상","book_name":"역대상","chapter":6,"verse":18,"text":"그핫의 아들들은 아므람과, 이스할과, 헤브론과, 웃시엘이요,","reference":"역대상 6:18","category":"$undefined"},{"id":"10474","book":"역대상","book_name":"역대상","chapter":6,"verse":19,"text":"므라리의 아들들은 말리와, 무시라 이 레위 사람의 집들이 그 종족을 따라 이러하니","reference":"역대상 6:19","category":"$undefined"},{"id":"10475","book":"역대상","book_name":"역대상","chapter":6,"verse":20,"text":"게르손에게서 난 자는 곧 그 아들 립니요, 그 아들은 야핫이요, 그 아들은 심마요,","reference":"역대상 6:20","category":"$undefined"},{"id":"10476","book":"역대상","book_name":"역대상","chapter":6,"verse":21,"text":"그 아들은 요아요, 그 아들은 잇도요, 그 아들은 세라요, 그 아들은 여아드래며,","reference":"역대상 6:21","category":"$undefined"},{"id":"10477","book":"역대상","book_name":"역대상","chapter":6,"verse":22,"text":"그핫에게서 난 자는 곧 그 아들 암미나답이요, 그 아들은 고라요, 그 아들은 앗실이요,","reference":"역대상 6:22","category":"$undefined"},{"id":"10478","book":"역대상","book_name":"역대상","chapter":6,"verse":23,"text":"그 아들은 엘가나요, 그 아들은 에비아삽이요, 그 아들은 앗실이요,","reference":"역대상 6:23","category":"$undefined"},{"id":"10479","book":"역대상","book_name":"역대상","chapter":6,"verse":24,"text":"그 아들은 다핫이요, 그 아들은 우리엘이요, 그 아들은 웃시야요, 그 아들은 사울이며,","reference":"역대상 6:24","category":"$undefined"},{"id":"10480","book":"역대상","book_name":"역대상","chapter":6,"verse":25,"text":"엘가나의 아들들은 아마새와, 아히못이라","reference":"역대상 6:25","category":"$undefined"},{"id":"10481","book":"역대상","book_name":"역대상","chapter":6,"verse":26,"text":"엘가나로 말하면 그 자손은 이러하니 그 아들은 소배요, 그 아들은 나핫이요,","reference":"역대상 6:26","category":"$undefined"},{"id":"10482","book":"역대상","book_name":"역대상","chapter":6,"verse":27,"text":"그 아들은 엘리압이요 그 아들은 여로함이요, 그 아들은 엘가나며,","reference":"역대상 6:27","category":"$undefined"},{"id":"10483","book":"역대상","book_name":"역대상","chapter":6,"verse":28,"text":"사무엘의 아들들은 맏아들 요엘이요, 다음은 아비야며,","reference":"역대상 6:28","category":"$undefined"},{"id":"10484","book":"역대상","book_name":"역대상","chapter":6,"verse":29,"text":"므라리에게서 난 자는 말리요, 그 아들은 립니요, 그 아들은 시므이요, 그 아들은 웃사요,","reference":"역대상 6:29","category":"$undefined"},{"id":"10485","book":"역대상","book_name":"역대상","chapter":6,"verse":30,"text":"그 아들은 시므아요, 그 아들은 학기야요, 그 아들은 아사야더라","reference":"역대상 6:30","category":"$undefined"},{"id":"10486","book":"역대상","book_name":"역대상","chapter":6,"verse":31,"text":"언약궤가 평안한 곳을 얻은 후에 다윗이 이 아래의 무리를 세워 여호와의 집에서 찬송하는 일을 맡게 하매","reference":"역대상 6:31","category":"$undefined"},{"id":"10487","book":"역대상","book_name":"역대상","chapter":6,"verse":32,"text":"솔로몬이 예루살렘에서 여호와의 전을 세울 때까지 저희가 회막 앞에서 찬송하는 일을 행하되 그 반열대로 직무를 행하였더라","reference":"역대상 6:32","category":"$undefined"},{"id":"10488","book":"역대상","book_name":"역대상","chapter":6,"verse":33,"text":"직무를 행하는 자와 그 아들들이 이러하니 그핫의 자손 중에 헤만은 찬송하는 자라 저는 요엘의 아들이요, 요엘은 사무엘의 아들이요,","reference":"역대상 6:33","category":"$undefined"},{"id":"10489","book":"역대상","book_name":"역대상","chapter":6,"verse":34,"text":"사무엘은 엘가나의 아들이요, 엘가나는 여로함의 아들이요, 여로함은 엘리엘의 아들이요, 엘리엘은 도아의 아들이요,","reference":"역대상 6:34","category":"$undefined"},{"id":"10490","book":"역대상","book_name":"역대상","chapter":6,"verse":35,"text":"도아는 숩의 아들이요, 숩은 엘가나의 아들이요, 엘가나는 마핫의 아들이요, 마핫은 아마새의 아들이요,","reference":"역대상 6:35","category":"$undefined"},{"id":"10491","book":"역대상","book_name":"역대상","chapter":6,"verse":36,"text":"아마새는 엘가나의 아들이요, 엘가나는 요엘의 아들이요, 요엘은 아사랴의 아들이요, 아사랴는 스바냐의 아들이요,","reference":"역대상 6:36","category":"$undefined"},{"id":"10492","book":"역대상","book_name":"역대상","chapter":6,"verse":37,"text":"스바냐는 다핫의 아들이요, 다핫은 앗실의 아들이요, 앗실은 에비아삽의 아들이요, 에비아삽은 고라의 아들이요,","reference":"역대상 6:37","category":"$undefined"},{"id":"10493","book":"역대상","book_name":"역대상","chapter":6,"verse":38,"text":"고라는 이스할의 아들이요, 이스할은 그핫의 아들이요, 그핫은 레위의 아들이요, 레위는 이스라엘의 아들이며,","reference":"역대상 6:38","category":"$undefined"},{"id":"10494","book":"역대상","book_name":"역대상","chapter":6,"verse":39,"text":"헤만의 형제 아삽은 헤만의 우편에서 직무를 행하였으니 저는 베레갸의 아들이요, 베레갸는 시므아의 아들이요,","reference":"역대상 6:39","category":"$undefined"},{"id":"10495","book":"역대상","book_name":"역대상","chapter":6,"verse":40,"text":"시므아는 미가엘의 아들이요, 미가엘은 바아세야의 아들이요, 바아세야는 말기야의 아들이요,","reference":"역대상 6:40","category":"$undefined"},{"id":"10496","book":"역대상","book_name":"역대상","chapter":6,"verse":41,"text":"말기야는 에드니의 아들이요, 에드니는 세라의 아들이요,","reference":"역대상 6:41","category":"$undefined"},{"id":"10497","book":"역대상","book_name":"역대상","chapter":6,"verse":42,"text":"아다야는 에단의 아들이요, 에단은 심마의 아들이요, 심마는 시므이의 아들이요,","reference":"역대상 6:42","category":"$undefined"},{"id":"10498","book":"역대상","book_name":"역대상","chapter":6,"verse":43,"text":"시므이는 야핫의 아들이요, 야핫은 게르손의 아들이요, 게르손은 레위의 아들이며,","reference":"역대상 6:43","category":"$undefined"},{"id":"10499","book":"역대상","book_name":"역대상","chapter":6,"verse":44,"text":"저희의 형제 므라리의 자손 중 그 좌편에서 직무를 행하는 자는 에단이라 에단은 기시의 아들이요, 기시는 압디의 아들이요 압디는 말룩의 아들이요,","reference":"역대상 6:44","category":"$undefined"},{"id":"10500","book":"역대상","book_name":"역대상","chapter":6,"verse":45,"text":"말룩은 하사뱌의 아들이요, 하사뱌는 아마시야의 아들이요, 아마시야는 힐기야의 아들이요,","reference":"역대상 6:45","category":"$undefined"},{"id":"10501","book":"역대상","book_name":"역대상","chapter":6,"verse":46,"text":"힐기야는 암시의 아들이요, 암시는 바니의 아들이요, 바니는 세멜의 아들이요,","reference":"역대상 6:46","category":"$undefined"},{"id":"10502","book":"역대상","book_name":"역대상","chapter":6,"verse":47,"text":"세멜은 말리의 아들이요, 말리는 무시의 아들이요, 무시는 므라리의 아들이요, 므라리는 레위의 아들이며,","reference":"역대상 6:47","category":"$undefined"},{"id":"10503","book":"역대상","book_name":"역대상","chapter":6,"verse":48,"text":"저희의 형제 레위 사람들은 하나님의 집 장막의 모든 일을 맡았더라","reference":"역대상 6:48","category":"$undefined"},{"id":"10504","book":"역대상","book_name":"역대상","chapter":6,"verse":49,"text":"아론과 그 자손들은 번제단과 향단 위에 분향하며 제사를 드리며 지성소의 모든 일을 하여 하나님의 종 모세의 모든 명대로 이스라엘을 위하여 속죄하니","reference":"역대상 6:49","category":"$undefined"},{"id":"10505","book":"역대상","book_name":"역대상","chapter":6,"verse":50,"text":"아론의 자손들은 이러하니라 그 아들은 엘르아살이요, 그 아들은 비느하스요, 그 아들은 아비수아요","reference":"역대상 6:50","category":"$undefined"},{"id":"10506","book":"역대상","book_name":"역대상","chapter":6,"verse":51,"text":"그 아들은 북기요, 그 아들은 웃시요, 그 아들은 스라히야요","reference":"역대상 6:51","category":"$undefined"},{"id":"10507","book":"역대상","book_name":"역대상","chapter":6,"verse":52,"text":"그 아들은 므라욧이요, 그 아들은 아마랴요, 그 아들은 아히둡이요","reference":"역대상 6:52","category":"$undefined"},{"id":"10508","book":"역대상","book_name":"역대상","chapter":6,"verse":53,"text":"그 아들은 사독이요, 그 아들은 아히마아스더라","reference":"역대상 6:53","category":"$undefined"},{"id":"10509","book":"역대상","book_name":"역대상","chapter":6,"verse":54,"text":"저희의 거한 곳은 사방 지경 안에 있으니 그 향리는 아래와 같으니라 아론 자손 곧 그핫 족속이 먼저 제비 뽑았으므로","reference":"역대상 6:54","category":"$undefined"},{"id":"10510","book":"역대상","book_name":"역대상","chapter":6,"verse":55,"text":"저희에게 유다 땅의 헤브론과 그 사방 들을 주었고","reference":"역대상 6:55","category":"$undefined"},{"id":"10511","book":"역대상","book_name":"역대상","chapter":6,"verse":56,"text":"그 성의 밭과 향리는 여분네의 아들 갈렙에게 주었으며","reference":"역대상 6:56","category":"$undefined"},{"id":"10512","book":"역대상","book_name":"역대상","chapter":6,"verse":57,"text":"아론 자손에게 도피성을 주었으니 헤브론과 립나와 그 들과 얏딜과 에스드모아와 그 들과","reference":"역대상 6:57","category":"$undefined"},{"id":"10513","book":"역대상","book_name":"역대상","chapter":6,"verse":58,"text":"힐렌과 그 들과 드빌과 그 들과","reference":"역대상 6:58","category":"$undefined"},{"id":"10514","book":"역대상","book_name":"역대상","chapter":6,"verse":59,"text":"아산과 그 들과 벧세메스와 그 들이며","reference":"역대상 6:59","category":"$undefined"},{"id":"10515","book":"역대상","book_name":"역대상","chapter":6,"verse":60,"text":"또 베냐민 지파 중에서는 게바와 그 들과 알레멧과 그 들과 아나돗과 그 들을 주었으니 그핫 족속의 얻은 성이 모두 열 셋이었더라","reference":"역대상 6:60","category":"$undefined"},{"id":"10516","book":"역대상","book_name":"역대상","chapter":6,"verse":61,"text":"그핫 자손의 남은 자에게는 므낫세 반 지파 족속 중에서 제비뽑아 열 성을 주었고","reference":"역대상 6:61","category":"$undefined"},{"id":"10517","book":"역대상","book_name":"역대상","chapter":6,"verse":62,"text":"게르손 자손에게는 그 족속대로 잇사갈 지파와 아셀 지파와 납달리 지파와 바산에 있는 므낫세 지파 중에서 열 세 성을 주었고","reference":"역대상 6:62","category":"$undefined"},{"id":"10518","book":"역대상","book_name":"역대상","chapter":6,"verse":63,"text":"므라리 자손에게는 그 족속대로 르우벤 지파와 갓 지파와 스불론 지파 중에서 제비 뽑아 열 두 성을 주었더라","reference":"역대상 6:63","category":"$undefined"},{"id":"10519","book":"역대상","book_name":"역대상","chapter":6,"verse":64,"text":"이스라엘 자손이 이 모든 성과 그 들을 레위 자손에게 주되","reference":"역대상 6:64","category":"$undefined"},{"id":"10520","book":"역대상","book_name":"역대상","chapter":6,"verse":65,"text":"유다 자손의 지파와 시므온 자손의 지파와 베냐민 자손의 지파 중에서 이 위에 기록한 여러 성을 제비 뽑아 주었더라","reference":"역대상 6:65","category":"$undefined"},{"id":"10521","book":"역대상","book_name":"역대상","chapter":6,"verse":66,"text":"그핫 자손의 몇 족속은 에브라임 지파 중에서 성을 얻어 영지를 삼았으며","reference":"역대상 6:66","category":"$undefined"},{"id":"10522","book":"역대상","book_name":"역대상","chapter":6,"verse":67,"text":"또 저희에게 도피성을 주었으니 에브라임 산중 세겜과 그 들과 게셀과 그 들과","reference":"역대상 6:67","category":"$undefined"},{"id":"10523","book":"역대상","book_name":"역대상","chapter":6,"verse":68,"text":"욕므암과 그 들과 벧호론과 그 들과","reference":"역대상 6:68","category":"$undefined"},{"id":"10524","book":"역대상","book_name":"역대상","chapter":6,"verse":69,"text":"아얄론과 그 들과 가드림몬과 그 들이며","reference":"역대상 6:69","category":"$undefined"},{"id":"10525","book":"역대상","book_name":"역대상","chapter":6,"verse":70,"text":"또 그핫 자손의 남은 족속에게는 므낫세 반 지파중에서 아넬과 그 들과 빌르암과 그 들을 주었더라","reference":"역대상 6:70","category":"$undefined"},{"id":"10526","book":"역대상","book_name":"역대상","chapter":6,"verse":71,"text":"게르손 자손에게는 므낫세 반 지파 족속 중에서 바산의 골란과 그 들과 아스다롯과 그 들을 주었고","reference":"역대상 6:71","category":"$undefined"},{"id":"10527","book":"역대상","book_name":"역대상","chapter":6,"verse":72,"text":"또 잇사갈 지파 중에서 게데스와 그 들과 다브랏과 그 들과","reference":"역대상 6:72","category":"$undefined"},{"id":"10528","book":"역대상","book_name":"역대상","chapter":6,"verse":73,"text":"라못과 그 들과 아넴과 그 들을 주었고","reference":"역대상 6:73","category":"$undefined"},{"id":"10529","book":"역대상","book_name":"역대상","chapter":6,"verse":74,"text":"아셀 지파 중에서 마살과 그 들과 압돈과 그 들과","reference":"역대상 6:74","category":"$undefined"},{"id":"10530","book":"역대상","book_name":"역대상","chapter":6,"verse":75,"text":"후곡과 그 들과 르홉과 그 들을 주었고","reference":"역대상 6:75","category":"$undefined"},{"id":"10531","book":"역대상","book_name":"역대상","chapter":6,"verse":76,"text":"납달리 지파 중에서 갈릴리의 게데스와 그 들과 함몬과 그 들과 기랴다임과 그 들을 주었더라","reference":"역대상 6:76","category":"$undefined"},{"id":"10532","book":"역대상","book_name":"역대상","chapter":6,"verse":77,"text":"므라리 자손의 남은 자에게는 스불론 지파 중에서 림모노와 그 들과 다볼과 그 들을 주었고","reference":"역대상 6:77","category":"$undefined"},{"id":"10533","book":"역대상","book_name":"역대상","chapter":6,"verse":78,"text":"또 요단 건너 동편 곧 여리고 맞은편 르우벤 지파 중에서 광야의 베셀과 그 들과 야사와 그 들과","reference":"역대상 6:78","category":"$undefined"},{"id":"10534","book":"역대상","book_name":"역대상","chapter":6,"verse":79,"text":"그데못과 그 들과 메바앗과 그 들을 주었고","reference":"역대상 6:79","category":"$undefined"},{"id":"10535","book":"역대상","book_name":"역대상","chapter":6,"verse":80,"text":"또 갓 지파 중에서 길르앗의 라못과 그 들과 마하나임과 그 들과","reference":"역대상 6:80","category":"$undefined"},{"id":"10536","book":"역대상","book_name":"역대상","chapter":6,"verse":81,"text":"헤스본과 그 들과 야셀과 그 들을 주었더라","reference":"역대상 6:81","category":"$undefined"}],"bookSlug":"1chronicles"}]
