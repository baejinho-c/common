11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":7,"verses":[{"id":"10537","book":"역대상","book_name":"역대상","chapter":7,"verse":1,"text":"잇사갈의 아들들은 돌라와, 부아와, 야숩과, 시므론 네 사람이며","reference":"역대상 7:1","category":"$undefined"},{"id":"10538","book":"역대상","book_name":"역대상","chapter":7,"verse":2,"text":"돌라의 아들들은 웃시와, 르바야와, 여리엘과, 야매와, 입삼과, 스므엘이니 다 그 아비 돌라의 집 족장이라 대대로 용사더니 다윗 때에 이르러는 그 수효가 이만 이천 육백명이었더라","reference":"역대상 7:2","category":"$undefined"},{"id":"10539","book":"역대상","book_name":"역대상","chapter":7,"verse":3,"text":"웃시의 아들은 이스라히야요 이스라히야의 아들들은 미가엘과, 오바댜와, 요엘과, 잇시야 다섯 사람이 모두 족장이며","reference":"역대상 7:3","category":"$undefined"},{"id":"10540","book":"역대상","book_name":"역대상","chapter":7,"verse":4,"text":"저희와 함께한 자는 그 보계와 종족대로 능히 출전할만한 군대가 삼만 육천인이니 이는 그 처자가 많은 연고며","reference":"역대상 7:4","category":"$undefined"},{"id":"10541","book":"역대상","book_name":"역대상","chapter":7,"verse":5,"text":"그 형제 잇사갈의 모든 종족은 다 큰 용사라 그 보계대로 계수하면 팔만 칠천인이었더라","reference":"역대상 7:5","category":"$undefined"},{"id":"10542","book":"역대상","book_name":"역대상","chapter":7,"verse":6,"text":"베냐민의 아들들은 벨라와, 베겔과, 여디아엘 세 사람이며","reference":"역대상 7:6","category":"$undefined"},{"id":"10543","book":"역대상","book_name":"역대상","chapter":7,"verse":7,"text":"벨라의 아들들은 에스본과, 우시와, 웃시엘과, 여리못과, 이리 다섯 사람이니 다 그 집의 족장이요 큰 용사라 그 보계대로 계수하면 이만 이천 삼십 사인이며","reference":"역대상 7:7","category":"$undefined"},{"id":"10544","book":"역대상","book_name":"역대상","chapter":7,"verse":8,"text":"베겔의 아들들은 스미라와, 요아스와, 엘리에셀과, 엘료에내와, 오므리와, 여레못과, 아비야와, 아나돗과, 알레멧이니 베겔의 아들들은 이러하며","reference":"역대상 7:8","category":"$undefined"},{"id":"10545","book":"역대상","book_name":"역대상","chapter":7,"verse":9,"text":"저희는 다 그 집의 족장이요 큰 용사라 그 자손을 보계대로 계수하면 이만 이백인이며","reference":"역대상 7:9","category":"$undefined"},{"id":"10546","book":"역대상","book_name":"역대상","chapter":7,"verse":10,"text":"여디아엘의 아들은 빌한이요 빌한의 아들들은 여우스와, 베냐민과, 에훗과, 그나아나와, 세단과, 다시스와, 아히사할이니","reference":"역대상 7:10","category":"$undefined"},{"id":"10547","book":"역대상","book_name":"역대상","chapter":7,"verse":11,"text":"이 여디아엘의 아들들은 그 집의 족장이요 큰 용사라 그 자손 중에 능히 출전할만한 자가 일만 칠천 이백인이며","reference":"역대상 7:11","category":"$undefined"},{"id":"10548","book":"역대상","book_name":"역대상","chapter":7,"verse":12,"text":"일의 아들은 숩빔과, 훔빔이요 아헬의 아들은 후심이더라","reference":"역대상 7:12","category":"$undefined"},{"id":"10549","book":"역대상","book_name":"역대상","chapter":7,"verse":13,"text":"납달리의 아들들은 야시엘과, 구니와, 예셀과, 살룸이니 이는 빌하의 손자더라","reference":"역대상 7:13","category":"$undefined"},{"id":"10550","book":"역대상","book_name":"역대상","chapter":7,"verse":14,"text":"므낫세의 아들들 그 처의 소생은 아스리엘이요 그 첩 아람 여인의 소생은 길르앗의 아비 마길이니","reference":"역대상 7:14","category":"$undefined"},{"id":"10551","book":"역대상","book_name":"역대상","chapter":7,"verse":15,"text":"마길은 훔빔과 숩빔의 누이 마아가라 하는 이에게 장가들었더라 므낫세의 둘째 아들의 이름은 슬로브핫이니 슬로브핫은 딸들만 낳았으며","reference":"역대상 7:15","category":"$undefined"},{"id":"10552","book":"역대상","book_name":"역대상","chapter":7,"verse":16,"text":"마길의 아내 마아가는 아들을 낳아 그 이름을 베레스라 하였으며 그 아우는 이름이 세레스며 세레스의 아들은 울람과 라겜이요","reference":"역대상 7:16","category":"$undefined"},{"id":"10553","book":"역대상","book_name":"역대상","chapter":7,"verse":17,"text":"울람의 아들은 브단이니 이는 다 길르앗의 자손이라 길르앗은 마길의 아들이요 므낫세의 손자며","reference":"역대상 7:17","category":"$undefined"},{"id":"10554","book":"역대상","book_name":"역대상","chapter":7,"verse":18,"text":"그 누이 함몰레겟은 이스홋과, 아비에셀과, 말라를 낳았고","reference":"역대상 7:18","category":"$undefined"},{"id":"10555","book":"역대상","book_name":"역대상","chapter":7,"verse":19,"text":"스미다의 아들은 아히안과, 세겜과, 릭히와, 아니암이더라","reference":"역대상 7:19","category":"$undefined"},{"id":"10556","book":"역대상","book_name":"역대상","chapter":7,"verse":20,"text":"에브라임의 아들은 수델라요 그 아들은 베렛이요 그 아들은 다핫이요 그 아들은 엘르아다요 그 아들은 다핫이요","reference":"역대상 7:20","category":"$undefined"},{"id":"10557","book":"역대상","book_name":"역대상","chapter":7,"verse":21,"text":"그 아들은 사밧이요 그 아들은 수델라며 저가 또 에셀과 엘르앗을 낳았더니 저희가 가드 토인에게 죽임을 당하였으니 이는 저희가 내려가서 가드 사람의 짐승을 빼앗고자 하였음이라","reference":"역대상 7:21","category":"$undefined"},{"id":"10558","book":"역대상","book_name":"역대상","chapter":7,"verse":22,"text":"그 아비 에브라임이 위하여 여러 날 슬퍼하므로 그 형제가 와서 위로하였더라","reference":"역대상 7:22","category":"$undefined"},{"id":"10559","book":"역대상","book_name":"역대상","chapter":7,"verse":23,"text":"그 후에 에브라임이 그 아내와 동침하였더니 아내가 잉태하여 아들을 낳으니 그 집이 재앙을 받았으므로 그 이름을 브리아라 하였더라","reference":"역대상 7:23","category":"$undefined"},{"id":"10560","book":"역대상","book_name":"역대상","chapter":7,"verse":24,"text":"에브라임의 딸은 세에라니 저가 아래 윗 벧호론과 우센세에라를 세웠더라","reference":"역대상 7:24","category":"$undefined"},{"id":"10561","book":"역대상","book_name":"역대상","chapter":7,"verse":25,"text":"브리아의 아들들은 레바와, 레셉이요 레셉의 아들은 델라요 그 아들은 다한이요","reference":"역대상 7:25","category":"$undefined"},{"id":"10562","book":"역대상","book_name":"역대상","chapter":7,"verse":26,"text":"그 아들은 라단이요 그 아들은 암미훗이요 그 아들은 엘리사마요","reference":"역대상 7:26","category":"$undefined"},{"id":"10563","book":"역대상","book_name":"역대상","chapter":7,"verse":27,"text":"그 아들은 눈이요 그 아들은 여호수아더라","reference":"역대상 7:27","category":"$undefined"},{"id":"10564","book":"역대상","book_name":"역대상","chapter":7,"verse":28,"text":"에브라임 자손의 산업과 거처는 벧엘과 그 향리요 동에는 나아란이요 서에는 게셀과 그 향리며 또 세겜과 그 향리니 아사와 그 향리까지며","reference":"역대상 7:28","category":"$undefined"},{"id":"10565","book":"역대상","book_name":"역대상","chapter":7,"verse":29,"text":"또 므낫세 자손의 지경에 가까운 벧스안과 그 향리와 다아낙과 그 향리와 므깃도와 그 향리와 돌과 그 향리라 이스라엘의 아들 요셉의 자손이 이 여러 곳에 거하였더라","reference":"역대상 7:29","category":"$undefined"},{"id":"10566","book":"역대상","book_name":"역대상","chapter":7,"verse":30,"text":"아셀의 아들들은 임나와, 이스와와, 이스위와, 브리아요 저희의 매제는 세라며","reference":"역대상 7:30","category":"$undefined"},{"id":"10567","book":"역대상","book_name":"역대상","chapter":7,"verse":31,"text":"브리아의 아들들은 헤벨과, 말기엘이니 말기엘은 비르사잇의 아비며","reference":"역대상 7:31","category":"$undefined"},{"id":"10568","book":"역대상","book_name":"역대상","chapter":7,"verse":32,"text":"헤벨은 야블렛과, 소멜과, 호담과 저희의 매제 수아를 낳았으며","reference":"역대상 7:32","category":"$undefined"},{"id":"10569","book":"역대상","book_name":"역대상","chapter":7,"verse":33,"text":"야블렛의 아들들은 바삭과, 빔할과, 아스왓이니 야블렛의 아들은 이러하며","reference":"역대상 7:33","category":"$undefined"},{"id":"10570","book":"역대상","book_name":"역대상","chapter":7,"verse":34,"text":"소멜의 아들들은 아히와, 로가와, 호바와, 아람이요","reference":"역대상 7:34","category":"$undefined"},{"id":"10571","book":"역대상","book_name":"역대상","chapter":7,"verse":35,"text":"그 아우 헬렘의 아들들은 소바와, 임나와, 셀레스와, 아말이요","reference":"역대상 7:35","category":"$undefined"},{"id":"10572","book":"역대상","book_name":"역대상","chapter":7,"verse":36,"text":"소바의 아들들은 수아와, 하르네벨과, 수알과, 베리와, 이므라와","reference":"역대상 7:36","category":"$undefined"},{"id":"10573","book":"역대상","book_name":"역대상","chapter":7,"verse":37,"text":"베셀과, 홋과, 사마와, 실사와, 이드란과, 브에라요","reference":"역대상 7:37","category":"$undefined"},{"id":"10574","book":"역대상","book_name":"역대상","chapter":7,"verse":38,"text":"예델의 아들들은 여분네와, 비스바와, 아라요","reference":"역대상 7:38","category":"$undefined"},{"id":"10575","book":"역대상","book_name":"역대상","chapter":7,"verse":39,"text":"울라의 아들들은 아라와, 한니엘과, 리시아니","reference":"역대상 7:39","category":"$undefined"},{"id":"10576","book":"역대상","book_name":"역대상","chapter":7,"verse":40,"text":"이는 다 아셀의 자손으로 족장이요 뽑힌 큰 용사요 방백의 두목이라 출전할만한 자를 그 보계대로 계수하면 이만 육천인이었더라","reference":"역대상 7:40","category":"$undefined"}],"bookSlug":"1chronicles"}]
