2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":8,"verses":[{"id":"10577","book":"역대상","book_name":"역대상","chapter":8,"verse":1,"text":"베냐민의 낳은 자는 맏아들 벨라와 둘째 아스벨과 세째 아하라와","reference":"역대상 8:1","category":"$undefined"},{"id":"10578","book":"역대상","book_name":"역대상","chapter":8,"verse":2,"text":"네째 노하와 다섯째 라바며","reference":"역대상 8:2","category":"$undefined"},{"id":"10579","book":"역대상","book_name":"역대상","chapter":8,"verse":3,"text":"벨라에게 아들들이 있으니 곧 앗달과, 게라와, 아비훗과","reference":"역대상 8:3","category":"$undefined"},{"id":"10580","book":"역대상","book_name":"역대상","chapter":8,"verse":4,"text":"아비수아와, 나아만과, 아호아와","reference":"역대상 8:4","category":"$undefined"},{"id":"10581","book":"역대상","book_name":"역대상","chapter":8,"verse":5,"text":"게라와, 스부반과, 후람이며","reference":"역대상 8:5","category":"$undefined"},{"id":"10582","book":"역대상","book_name":"역대상","chapter":8,"verse":6,"text":"에훗의 아들들은 이러하니라 저희는 게바 거민의 족장으로서 사로잡아 마나핫으로 가되","reference":"역대상 8:6","category":"$undefined"},{"id":"10583","book":"역대상","book_name":"역대상","chapter":8,"verse":7,"text":"곧 나아만과, 아히야와, 게라를 사로잡아 갔고 그가 또 웃사와, 아히훗을 낳았으며","reference":"역대상 8:7","category":"$undefined"},{"id":"10584","book":"역대상","book_name":"역대상","chapter":8,"verse":8,"text":"사하라임은 두 아내 후심과, 바아라를 내어보낸 후에 모압 땅에서 자녀를 낳았으니","reference":"역대상 8:8","category":"$undefined"},{"id":"10585","book":"역대상","book_name":"역대상","chapter":8,"verse":9,"text":"그 아내 호데스에게서 낳은 자는 요밥과, 시비야와, 메사와, 말감과","reference":"역대상 8:9","category":"$undefined"},{"id":"10586","book":"역대상","book_name":"역대상","chapter":8,"verse":10,"text":"여우스와, 사갸와, 미르마라 이 아들들은 족장이며","reference":"역대상 8:10","category":"$undefined"},{"id":"10587","book":"역대상","book_name":"역대상","chapter":8,"verse":11,"text":"또 그 아내 후심에게서 아비둡과 엘바알을 낳았으며","reference":"역대상 8:11","category":"$undefined"},{"id":"10588","book":"역대상","book_name":"역대상","chapter":8,"verse":12,"text":"엘바알의 아들들은 에벨과, 미삼과, 세멧이니 저는 오노와 롯과 그 향리를 세웠고","reference":"역대상 8:12","category":"$undefined"},{"id":"10589","book":"역대상","book_name":"역대상","chapter":8,"verse":13,"text":"또 브리아와, 세마니 저희는 아얄론 거민의 족장이 되어 가드 거민을 쫓아내었더라","reference":"역대상 8:13","category":"$undefined"},{"id":"10590","book":"역대상","book_name":"역대상","chapter":8,"verse":14,"text":"아히요와, 사삭과, 여레못과","reference":"역대상 8:14","category":"$undefined"},{"id":"10591","book":"역대상","book_name":"역대상","chapter":8,"verse":15,"text":"스바댜와, 아랏과, 에델과","reference":"역대상 8:15","category":"$undefined"},{"id":"10592","book":"역대상","book_name":"역대상","chapter":8,"verse":16,"text":"미가엘과, 이스바와, 요하는 다 브리아의 아들들이요","reference":"역대상 8:16","category":"$undefined"},{"id":"10593","book":"역대상","book_name":"역대상","chapter":8,"verse":17,"text":"스바댜와, 므술람과, 히스기와, 헤벨과","reference":"역대상 8:17","category":"$undefined"},{"id":"10594","book":"역대상","book_name":"역대상","chapter":8,"verse":18,"text":"이스므래와, 이슬리아와, 요밥은 다 엘바알의 아들들이요","reference":"역대상 8:18","category":"$undefined"},{"id":"10595","book":"역대상","book_name":"역대상","chapter":8,"verse":19,"text":"야김과, 시그리와, 삽디와","reference":"역대상 8:19","category":"$undefined"},{"id":"10596","book":"역대상","book_name":"역대상","chapter":8,"verse":20,"text":"엘리에내와, 실르대와, 엘리엘과","reference":"역대상 8:20","category":"$undefined"},{"id":"10597","book":"역대상","book_name":"역대상","chapter":8,"verse":21,"text":"아다야와, 브라야와, 시므랏은 다 시므이의 아들들이요","reference":"역대상 8:21","category":"$undefined"},{"id":"10598","book":"역대상","book_name":"역대상","chapter":8,"verse":22,"text":"이스반과, 에벨과, 엘리엘과","reference":"역대상 8:22","category":"$undefined"},{"id":"10599","book":"역대상","book_name":"역대상","chapter":8,"verse":23,"text":"압돈과, 시그리와, 하난과","reference":"역대상 8:23","category":"$undefined"},{"id":"10600","book":"역대상","book_name":"역대상","chapter":8,"verse":24,"text":"하나냐와, 엘람과, 안도디야와","reference":"역대상 8:24","category":"$undefined"},{"id":"10601","book":"역대상","book_name":"역대상","chapter":8,"verse":25,"text":"이브드야와, 브누엘은 다 사삭의 아들들이요","reference":"역대상 8:25","category":"$undefined"},{"id":"10602","book":"역대상","book_name":"역대상","chapter":8,"verse":26,"text":"삼스래와, 스하랴와, 아달랴와","reference":"역대상 8:26","category":"$undefined"},{"id":"10603","book":"역대상","book_name":"역대상","chapter":8,"verse":27,"text":"야아레시야와 엘리야와 시그리는 다 여로함의 아들들이니","reference":"역대상 8:27","category":"$undefined"},{"id":"10604","book":"역대상","book_name":"역대상","chapter":8,"verse":28,"text":"이는 다 족장이요 대대로 두목이라 예루살렘에 거하였더라","reference":"역대상 8:28","category":"$undefined"},{"id":"10605","book":"역대상","book_name":"역대상","chapter":8,"verse":29,"text":"기브온의 조상 여이엘은 기브온에 거하였으니 그 아내의 이름은 마아가며","reference":"역대상 8:29","category":"$undefined"},{"id":"10606","book":"역대상","book_name":"역대상","chapter":8,"verse":30,"text":"장자는 압돈이요 다음은 술과 기스와 바알과 나답과","reference":"역대상 8:30","category":"$undefined"},{"id":"10607","book":"역대상","book_name":"역대상","chapter":8,"verse":31,"text":"그돌과 아히오와 세겔이며","reference":"역대상 8:31","category":"$undefined"},{"id":"10608","book":"역대상","book_name":"역대상","chapter":8,"verse":32,"text":"미글롯은 시므아를 낳았으며 이 무리가 그 형제로 더불어 서로 대하여 예루살렘에 거하였더라","reference":"역대상 8:32","category":"$undefined"},{"id":"10609","book":"역대상","book_name":"역대상","chapter":8,"verse":33,"text":"넬은 기스를 낳았고 기스는 사울을 낳았고 사울은 요나단과, 말기수아와, 아비나답과, 에스바알을 낳았으며","reference":"역대상 8:33","category":"$undefined"},{"id":"10610","book":"역대상","book_name":"역대상","chapter":8,"verse":34,"text":"요나단의 아들은 므립바알이라 므립바알이 미가를 낳았고","reference":"역대상 8:34","category":"$undefined"},{"id":"10611","book":"역대상","book_name":"역대상","chapter":8,"verse":35,"text":"미가의 아들들은 비돈과, 멜렉과, 다레아와, 아하스며","reference":"역대상 8:35","category":"$undefined"},{"id":"10612","book":"역대상","book_name":"역대상","chapter":8,"verse":36,"text":"아하스는 여호앗다를 낳았고 여호앗다는 알레멧과, 아스마웹과, 시므리를 낳았고 시므리는 모사를 낳았고","reference":"역대상 8:36","category":"$undefined"},{"id":"10613","book":"역대상","book_name":"역대상","chapter":8,"verse":37,"text":"모사는 비느아를 낳았으며 비느아의 아들은 라바요, 그 아들은 엘르아사요, 그 아들은 아셀이며,","reference":"역대상 8:37","category":"$undefined"},{"id":"10614","book":"역대상","book_name":"역대상","chapter":8,"verse":38,"text":"아셀에게 여섯 아들이 있어 그 이름이 이러하니 아스리감과, 보그루와, 이스마엘과, 스아랴와, 오바댜와, 하난이라 아셀의 모든 아들이 이러하며","reference":"역대상 8:38","category":"$undefined"},{"id":"10615","book":"역대상","book_name":"역대상","chapter":8,"verse":39,"text":"그 아우 에섹의 아들은 이러하니 그 장자는 울람이요 둘째는 여우스요 세째는 엘리벨렛이며","reference":"역대상 8:39","category":"$undefined"},{"id":"10616","book":"역대상","book_name":"역대상","chapter":8,"verse":40,"text":"울람의 아들은 다 큰 용사요 활을 잘 쏘는 자라 아들과 손자가 많아 모두 일백 오십인이었더라 베냐민의 자손들은 이러하였더라","reference":"역대상 8:40","category":"$undefined"}],"bookSlug":"1chronicles"}]
