2:["$","$L11",null,{"book":{"id":"1chronicles","name":"역대상","chapters":29,"testament":"old"},"chapter":9,"verses":[{"id":"10617","book":"역대상","book_name":"역대상","chapter":9,"verse":1,"text":"온 이스라엘이 그 보계대로 계수되고 이스라엘 열왕기에 기록되니라 유다가 범죄함을 인하여 바벨론으로 사로잡혀 갔더니","reference":"역대상 9:1","category":"$undefined"},{"id":"10618","book":"역대상","book_name":"역대상","chapter":9,"verse":2,"text":"먼저 그 본성으로 돌아와서 그 기업에 거한 자는 이스라엘 제사장들과 레위 사람과 느디님 사람들이라","reference":"역대상 9:2","category":"$undefined"},{"id":"10619","book":"역대상","book_name":"역대상","chapter":9,"verse":3,"text":"유다 자손과 베냐민 자손과 에브라임과 므낫세 자손 중에서 예루살렘에 거한 자는","reference":"역대상 9:3","category":"$undefined"},{"id":"10620","book":"역대상","book_name":"역대상","chapter":9,"verse":4,"text":"유다의 아들 베레스 자손 중에 우대니 저는 암미훗의 아들이요, 오므리의 손자요, 이므리의 증손이요, 바니의 현손이며","reference":"역대상 9:4","category":"$undefined"},{"id":"10621","book":"역대상","book_name":"역대상","chapter":9,"verse":5,"text":"실로 사람 중에서는 장자 아사야와 그 아들들이요","reference":"역대상 9:5","category":"$undefined"},{"id":"10622","book":"역대상","book_name":"역대상","chapter":9,"verse":6,"text":"세라 자손 중에서는 여우엘과 그 형제 육백 구십인이요","reference":"역대상 9:6","category":"$undefined"},{"id":"10623","book":"역대상","book_name":"역대상","chapter":9,"verse":7,"text":"베냐민 자손중에서는 핫스누아의 증손 호다위아의 손자 므술람의 아들 살루요,","reference":"역대상 9:7","category":"$undefined"},{"id":"10624","book":"역대상","book_name":"역대상","chapter":9,"verse":8,"text":"여로함의 아들 이브느야와, 미그리의 손자 웃시의 아들 엘라요, 이브니야의 증손 르우엘의 손자 스바댜의 아들 무술람이요,","reference":"역대상 9:8","category":"$undefined"},{"id":"10625","book":"역대상","book_name":"역대상","chapter":9,"verse":9,"text":"또 저의 형제들이라 그 보계대로 계수하면 구백 오십 륙인이니라 그 집의 족장된 자들이더라","reference":"역대상 9:9","category":"$undefined"},{"id":"10626","book":"역대상","book_name":"역대상","chapter":9,"verse":10,"text":"제사장 중에서는 여다야와, 여호야립과, 야긴과,","reference":"역대상 9:10","category":"$undefined"},{"id":"10627","book":"역대상","book_name":"역대상","chapter":9,"verse":11,"text":"하나님의 전을 맡은 자 아사랴니 저는 힐기야의 아들이요, 므술람의 손자요, 사독의 증손이요, 므라욧의 현손이요, 아히둡의 오대손이며","reference":"역대상 9:11","category":"$undefined"},{"id":"10628","book":"역대상","book_name":"역대상","chapter":9,"verse":12,"text":"또 아다야니 저는 여로함의 아들이요, 바스훌의 손자요, 말기야의 증손이며, 또 마아새니 저는 아디엘의 아들이요, 야세라의 손자요, 므술람의 증손이요, 므실레밋의 현손이요, 임멜의 오대손이며","reference":"역대상 9:12","category":"$undefined"},{"id":"10629","book":"역대상","book_name":"역대상","chapter":9,"verse":13,"text":"또 그 형제들이니 그 집의 족장이라 하나님의 전의 일에 수종 들재능이 있는 자가 모두 일천 칠백륙십인이더라","reference":"역대상 9:13","category":"$undefined"},{"id":"10630","book":"역대상","book_name":"역대상","chapter":9,"verse":14,"text":"레위 사람 중에서는 므라리 자손 스마야니 저는 핫숩의 아들이요, 아스리감의 손자요, 하사뱌의 증손이며","reference":"역대상 9:14","category":"$undefined"},{"id":"10631","book":"역대상","book_name":"역대상","chapter":9,"verse":15,"text":"또 박박갈과 헤레스와 갈랄과 맛다냐니 저는 미가의 아들이요, 시그리의 손자요, 아삽의 증손이며","reference":"역대상 9:15","category":"$undefined"},{"id":"10632","book":"역대상","book_name":"역대상","chapter":9,"verse":16,"text":"또 오바댜니 저는 스마야의 아들이요, 갈랄의 손자요, 여두둔의 증손이며 또 베레갸니 저는 아사의 아들이요, 엘가나의 손자라 느도바 사람의 향리에 거하였더라","reference":"역대상 9:16","category":"$undefined"},{"id":"10633","book":"역대상","book_name":"역대상","chapter":9,"verse":17,"text":"문지기는 살룸과, 악굽과, 달몬과, 아히만과, 그 형제들이니 살룸은 그 두목이라","reference":"역대상 9:17","category":"$undefined"},{"id":"10634","book":"역대상","book_name":"역대상","chapter":9,"verse":18,"text":"이 사람들은 전에 왕의 문 동편 곧 레위 자손의 영의 문지기며","reference":"역대상 9:18","category":"$undefined"},{"id":"10635","book":"역대상","book_name":"역대상","chapter":9,"verse":19,"text":"고라의 증손 에비아삽의 손자 고레의 아들 살룸과 그 종족 형제 곧 고라의 자손이 수종드는 일을 맡아 성막 문들을 지켰으니 그 열조도 여호와의 영을 맡고 그 들어가는 곳을 지켰으며","reference":"역대상 9:19","category":"$undefined"},{"id":"10636","book":"역대상","book_name":"역대상","chapter":9,"verse":20,"text":"여호와께서 함께하신 엘르아살의 아들 비느하스가 옛적에 그 무리를 거느렸고","reference":"역대상 9:20","category":"$undefined"},{"id":"10637","book":"역대상","book_name":"역대상","chapter":9,"verse":21,"text":"므셀레먀의 아들 스가랴는 회막 문지기가 되었더라","reference":"역대상 9:21","category":"$undefined"},{"id":"10638","book":"역대상","book_name":"역대상","chapter":9,"verse":22,"text":"택함을 입어 문지기 된 자가 모두 이백 열 둘이니 이는 그 향리에서 그 보계대로 계수된 자요 다윗과 선견자 사무엘이 전에 세워서 이 직분을 맡긴 자라","reference":"역대상 9:22","category":"$undefined"},{"id":"10639","book":"역대상","book_name":"역대상","chapter":9,"verse":23,"text":"저희와 그 자손이 그 반열을 좇아 여호와의 전 곧 성막문을 지켰는데","reference":"역대상 9:23","category":"$undefined"},{"id":"10640","book":"역대상","book_name":"역대상","chapter":9,"verse":24,"text":"이 문지기가 동서 남북 사방에 섰고","reference":"역대상 9:24","category":"$undefined"},{"id":"10641","book":"역대상","book_name":"역대상","chapter":9,"verse":25,"text":"그 향리에 있는 형제들은 이레마다 와서 함께하니","reference":"역대상 9:25","category":"$undefined"},{"id":"10642","book":"역대상","book_name":"역대상","chapter":9,"verse":26,"text":"이는 문지기의 두목 된 레위 사람 넷이 긴요한 직분을 맡아 하나님의 전 모든 방과 곳간을 지켰음이라","reference":"역대상 9:26","category":"$undefined"},{"id":"10643","book":"역대상","book_name":"역대상","chapter":9,"verse":27,"text":"저희는 하나님의 전을 맡은 직분이 있으므로 전 사면에 유하며 아침마다 문을 여는 책임이 있었더라","reference":"역대상 9:27","category":"$undefined"},{"id":"10644","book":"역대상","book_name":"역대상","chapter":9,"verse":28,"text":"그 중에 어떤 자는 섬기는데 쓰는 기명을 맡아서 그 수효대로 들여가고 수효대로 내어오며","reference":"역대상 9:28","category":"$undefined"},{"id":"10645","book":"역대상","book_name":"역대상","chapter":9,"verse":29,"text":"또 어떤 자는 성소의 기구와 모든 기명과 고운 가루와 포도주와 기름과 유향과 향품을 맡았으며","reference":"역대상 9:29","category":"$undefined"},{"id":"10646","book":"역대상","book_name":"역대상","chapter":9,"verse":30,"text":"또 제사장의 아들 중에 어떤 자는 향품으로 향기름을 만들었으며","reference":"역대상 9:30","category":"$undefined"},{"id":"10647","book":"역대상","book_name":"역대상","chapter":9,"verse":31,"text":"고라 자손 살룸의 장자 맛디댜라 하는 레위 사람은 남비에 지지는 것을 맡았으며","reference":"역대상 9:31","category":"$undefined"},{"id":"10648","book":"역대상","book_name":"역대상","chapter":9,"verse":32,"text":"또 그 형제 그핫 자손중에 어떤 자는 진설하는 떡을 맡아 안식일마다 준비하였더라","reference":"역대상 9:32","category":"$undefined"},{"id":"10649","book":"역대상","book_name":"역대상","chapter":9,"verse":33,"text":"또 찬송하는 자가 있으니 곧 레위 족장이라 저희가 골방에 거하여 주야로 자기 직분에 골몰하므로 다른 일은 하지 아니하였더라","reference":"역대상 9:33","category":"$undefined"},{"id":"10650","book":"역대상","book_name":"역대상","chapter":9,"verse":34,"text":"이상은 대대로 레위의 족장이요 으뜸이라 예루살렘에 거하였더라","reference":"역대상 9:34","category":"$undefined"},{"id":"10651","book":"역대상","book_name":"역대상","chapter":9,"verse":35,"text":"기브온의 조상 여이엘은 기브온에 거하였으니 그 아내의 이름은 마아가라","reference":"역대상 9:35","category":"$undefined"},{"id":"10652","book":"역대상","book_name":"역대상","chapter":9,"verse":36,"text":"그 장자는 압돈이요 다음은 술과 기스와 바알과 넬과 나답과","reference":"역대상 9:36","category":"$undefined"},{"id":"10653","book":"역대상","book_name":"역대상","chapter":9,"verse":37,"text":"그돌과 아히오와 스가랴와 미글롯이며","reference":"역대상 9:37","category":"$undefined"},{"id":"10654","book":"역대상","book_name":"역대상","chapter":9,"verse":38,"text":"미글롯은 시므암을 낳았으니 이 무리도 그 형제로 더불어 서로 대하여 예루살렘에 거하였더라","reference":"역대상 9:38","category":"$undefined"},{"id":"10655","book":"역대상","book_name":"역대상","chapter":9,"verse":39,"text":"넬은 기스를 낳았고 기스는 사울을 낳았고 사울은 요나단과 말기수아와 아비나답과 에스바알을 낳았으며","reference":"역대상 9:39","category":"$undefined"},{"id":"10656","book":"역대상","book_name":"역대상","chapter":9,"verse":40,"text":"요나단의 아들은 므립바알이라 므립바알이 미가를 낳았고","reference":"역대상 9:40","category":"$undefined"},{"id":"10657","book":"역대상","book_name":"역대상","chapter":9,"verse":41,"text":"미가의 아들들은 비돈과 멜렉과 다레아와 아하스며","reference":"역대상 9:41","category":"$undefined"},{"id":"10658","book":"역대상","book_name":"역대상","chapter":9,"verse":42,"text":"아하스는 야라를 낳았고 야라는 알레멧과 아스마웹과 시므리를 낳았고 시므리는 모사를 낳았고","reference":"역대상 9:42","category":"$undefined"},{"id":"10659","book":"역대상","book_name":"역대상","chapter":9,"verse":43,"text":"모사는 비느아를 낳았으며 비느아의 아들은 르바야요 그 아들은 엘르아사요 그 아들은 아셀이며","reference":"역대상 9:43","category":"$undefined"},{"id":"10660","book":"역대상","book_name":"역대상","chapter":9,"verse":44,"text":"아셀이 여섯 아들이 있으니 그 이름은 아스리감과 보그루와 이스마엘과 스아랴와 오바댜와 하난이라 아셀의 아들들이 이러하였더라","reference":"역대상 9:44","category":"$undefined"}],"bookSlug":"1chronicles"}]
