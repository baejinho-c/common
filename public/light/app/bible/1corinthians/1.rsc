2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":1,"verses":[{"id":"28365","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":1,"text":"하나님의 뜻을 따라 그리스도 예수의 사도로 부르심을 입은 바울과 및 형제 소스데네는","reference":"고린도전서 1:1","category":"$undefined"},{"id":"28366","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":2,"text":"고린도에 있는 하나님의 교회 곧 그리스도 예수 안에서 거룩하여지고 성도라 부르심을 입은 자들과 또 각처에서 우리의 주 곧 저희와 우리의 주 되신 예수 그리스도의 이름을 부르는 모든 자들 에게","reference":"고린도전서 1:2","category":"$undefined"},{"id":"28367","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":3,"text":"하나님 우리 아버지와 주 예수 그리스도로 좇아 은혜와 평강이 있기를 원하노라","reference":"고린도전서 1:3","category":"$undefined"},{"id":"28368","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":4,"text":"그리스도 예수 안에서 너희에게 주신 하나님의 은혜를 인하여 내가 너희를 위하여 항상 하나님께 감사하노니","reference":"고린도전서 1:4","category":"$undefined"},{"id":"28369","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":5,"text":"이는 너희가 그의 안에서 모든 일 곧 모든 구변과 모든 지식에 풍족하므로","reference":"고린도전서 1:5","category":"$undefined"},{"id":"28370","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":6,"text":"그리스도의 증거가 너희 중에 견고케 되어","reference":"고린도전서 1:6","category":"$undefined"},{"id":"28371","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":7,"text":"너희가 모든 은사에 부족함이 없이 우리 주 예수 그리스도의 나타나심을 기다림이라","reference":"고린도전서 1:7","category":"$undefined"},{"id":"28372","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":8,"text":"주께서 너희를 우리 주 예수 그리스도의 날에 책망할 것이 없는 자로 끝까지 견고케 하시리라","reference":"고린도전서 1:8","category":"$undefined"},{"id":"28373","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":9,"text":"너희를 불러 그의 아들 예수 그리스도 우리 주로 더불어 교제케 하시는 하나님은 미쁘시도다","reference":"고린도전서 1:9","category":"$undefined"},{"id":"28374","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":10,"text":"형제들아 내가 우리 주 예수 그리스도의 이름으로 너희를 권하노니 다 같은 말을 하고 너희 가운데 분쟁이 없이 같은 마음과 같은 뜻으로 온전히 합하라","reference":"고린도전서 1:10","category":"$undefined"},{"id":"28375","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":11,"text":"내 형제들아 글로에의 집 편으로서 너희에게 대한 말이 내게 들리니 곧 너희 가운데 분쟁이 있다는 것이라","reference":"고린도전서 1:11","category":"$undefined"},{"id":"28376","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":12,"text":"이는 다름아니라 너희가 각각 이르되 나는 바울에게, 나는 아볼로에게, 나는 게바에게, 나는 그리스도에게 속한 자라 하는 것이니","reference":"고린도전서 1:12","category":"$undefined"},{"id":"28377","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":13,"text":"그리스도께서 어찌 나뉘었느뇨 바울이 너희를 위하여 십자가에 못 박혔으며 바울의 이름으로 너희가 세례를 받았느뇨","reference":"고린도전서 1:13","category":"$undefined"},{"id":"28378","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":14,"text":"그리스보와 가이오 외에는 너희 중 아무에게도 내가 세례를 주지 아니한 것을 감사하노니","reference":"고린도전서 1:14","category":"$undefined"},{"id":"28379","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":15,"text":"이는 아무도 나의 이름으로 세례를 받았다 말하지 못하게 하려함이라","reference":"고린도전서 1:15","category":"$undefined"},{"id":"28380","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":16,"text":"내가 또한 스데바나 집 사람에게 세례를 주었고 그 외에는 다른 아무에게 세례를 주었는지 알지 못하노라","reference":"고린도전서 1:16","category":"$undefined"},{"id":"28381","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":17,"text":"그리스도께서 나를 보내심은 세례를 주게 하려 하심이 아니요 오직 복음을 전케 하려 하심이니 말의 지혜로 하지 아니함은 그리스도의 십자가가 헛되지 않게 하려 함이라","reference":"고린도전서 1:17","category":"$undefined"},{"id":"28382","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":18,"text":"십자가의 도가 멸망하는 자들에게는 미련한 것이요 구원을 얻는 우리에게는 하나님의 능력이라","reference":"고린도전서 1:18","category":"$undefined"},{"id":"28383","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":19,"text":"기록된 바 내가 지혜 있는 자들의 지혜를 멸하고 총명한 자들의 총명을 폐하리라 하였으니","reference":"고린도전서 1:19","category":"$undefined"},{"id":"28384","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":20,"text":"지혜 있는 자가 어디 있느뇨 선비가 어디 있느뇨 이 세대에 변사가 어디 있느뇨 하나님께서 이 세상의 지혜를 미련케 하신 것이 아니뇨","reference":"고린도전서 1:20","category":"$undefined"},{"id":"28385","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":21,"text":"하나님의 지혜에 있어서는 이 세상이 자기 지혜로 하나님을 알지 못하는고로 하나님께서 전도의 미련한 것으로 믿는 자들을 구원 하시기를 기뻐하셨도다","reference":"고린도전서 1:21","category":"$undefined"},{"id":"28386","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":22,"text":"유대인은 표적을 구하고 헬라인은 지혜를 찾으나","reference":"고린도전서 1:22","category":"$undefined"},{"id":"28387","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":23,"text":"우리는 십자가에 못 박힌 그리스도를 전하니 유대인에게는 거리끼는 것이요 이방인에게는 미련한 것이로되","reference":"고린도전서 1:23","category":"$undefined"},{"id":"28388","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":24,"text":"오직 부르심을 입은 자들에게는 유대인이나 헬라인이나 그리스도는 하나님의 능력이요 하나님의 지혜니라","reference":"고린도전서 1:24","category":"$undefined"},{"id":"28389","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":25,"text":"하나님의 미련한 것이 사람보다 지혜 있고 하나님의 약한 것이 사람보다 강하니라","reference":"고린도전서 1:25","category":"$undefined"},{"id":"28390","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":26,"text":"형제들아 너희를 부르심을 보라 육체를 따라 지혜 있는 자가 많지 아니하며 능한 자가 많지 아니하며 문벌 좋은 자가 많지 아니하도다","reference":"고린도전서 1:26","category":"$undefined"},{"id":"28391","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":27,"text":"그러나 하나님께서 세상의 미련한 것들을 택하사 지혜 있는 자들을 부끄럽게 하려 하시고 세상의 약한 것들을 택하사 강한 것들을 부끄럽게 하려 하시며","reference":"고린도전서 1:27","category":"$undefined"},{"id":"28392","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":28,"text":"하나님께서 세상의 천한 것들과 멸시 받는 것들과 없는 것들을 택하사 있는 것들을 폐하려 하시나니","reference":"고린도전서 1:28","category":"$undefined"},{"id":"28393","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":29,"text":"이는 아무 육체라도 하나님 앞에서 자랑하지 못하게 하려 하심이라","reference":"고린도전서 1:29","category":"$undefined"},{"id":"28394","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":30,"text":"너희는 하나님께로부터 나서 그리스도 예수 안에 있고 예수는 하나님께로서 나와서 우리에게 지혜와 의로움과 거룩함과 구속함이 되셨으니","reference":"고린도전서 1:30","category":"$undefined"},{"id":"28395","book":"고린도전서","book_name":"고린도전서","chapter":1,"verse":31,"text":"기록된 바 자랑하는 자는 주 안에서 자랑하라 함과 같게 하려 함이니라","reference":"고린도전서 1:31","category":"$undefined"}],"bookSlug":"1corinthians"}]
