2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":10,"verses":[{"id":"28569","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":1,"text":"형제들아 너희가 알지 못하기를 내가 원치 아니하노니 우리 조상들이 다 구름 아래 있고 바다 가운데로 지나며","reference":"고린도전서 10:1","category":"$undefined"},{"id":"28570","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":2,"text":"모세에게 속하여 다 구름과 바다에서 세례를 받고","reference":"고린도전서 10:2","category":"$undefined"},{"id":"28571","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":3,"text":"다 같은 신령한 식물을 먹으며","reference":"고린도전서 10:3","category":"$undefined"},{"id":"28572","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":4,"text":"다 같은 신령한 음료를 마셨으니 이는 저희를 따르는 신령한 반석으로부터 마셨으매 그 반석은 곧 그리스도시라","reference":"고린도전서 10:4","category":"$undefined"},{"id":"28573","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":5,"text":"그러나 저희의 다수(多數)를 하나님이 기뻐하지 아니하신고로 저희가 광야에서 멸망을 받았느니라","reference":"고린도전서 10:5","category":"$undefined"},{"id":"28574","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":6,"text":"그런 일은 우리의 거울이 되어 우리로 하여금 저희가 악을 즐겨한 것 같이 즐겨하는 자가 되지 않게 하려 함이니","reference":"고린도전서 10:6","category":"$undefined"},{"id":"28575","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":7,"text":"저희 중에 어떤 이들과 같이 너희는 우상 숭배하는 자가 되지 말라 기록된 바 백성이 앉아서 먹고 마시며 일어나서 뛰논다 함과 같으니라","reference":"고린도전서 10:7","category":"$undefined"},{"id":"28576","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":8,"text":"저희 중에 어떤 이들이 간음하다가 하루에 이만 삼천 명이 죽었나니 우리는 저희와 같이 간음하지 말자","reference":"고린도전서 10:8","category":"$undefined"},{"id":"28577","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":9,"text":"저희 중에 어떤 이들이 주를 시험하다가 뱀에게 멸망하였나니 우리는 저희와 같이 시험하지 말자","reference":"고린도전서 10:9","category":"$undefined"},{"id":"28578","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":10,"text":"저희 중에 어떤 이들이 원망하다가 멸망시키는 자에게 멸망하였나니 너희는 저희와 같이 원망하지 말라","reference":"고린도전서 10:10","category":"$undefined"},{"id":"28579","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":11,"text":"저희에게 당한 이런 일이 거울이 되고 또한 말세(末世)를 만난 우리의 경계로 기록하였느니라","reference":"고린도전서 10:11","category":"$undefined"},{"id":"28580","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":12,"text":"그런즉 선 줄로 생각하는 자는 넘어질까 조심하라","reference":"고린도전서 10:12","category":"$undefined"},{"id":"28581","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":13,"text":"사람이 감당할 시험 밖에는 너희에게 당한 것이 없나니 오직 하나님은 미쁘사 너희가 감당치 못할 시험 당함을 허락지 아니하시고 시험 당할 즈음에 또한 피할 길을 내사 너희로 능히 감당하게 하시느니라","reference":"고린도전서 10:13","category":"$undefined"},{"id":"28582","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":14,"text":"그런즉 내 사랑하는 자들아 우상 숭배하는 일을 피하라","reference":"고린도전서 10:14","category":"$undefined"},{"id":"28583","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":15,"text":"나는 지혜있는 자들에게 말함과 같이 하노니 너희는 내 이르는 말을 스스로 판단하라","reference":"고린도전서 10:15","category":"$undefined"},{"id":"28584","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":16,"text":"우리가 축복하는 바 축복의 잔은 그리스도의 피에 참예함이 아니며 우리가 떼는 떡은 그리스도의 몸에 참예함이 아니냐","reference":"고린도전서 10:16","category":"$undefined"},{"id":"28585","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":17,"text":"떡이 하나요 많은 우리가 한 몸이니 이는 우리가 다 한 떡에 참예함이라","reference":"고린도전서 10:17","category":"$undefined"},{"id":"28586","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":18,"text":"육신을 따라 난 이스라엘을 보라 제물을 먹는 자들이 제단에 참예하는 자들이 아니냐","reference":"고린도전서 10:18","category":"$undefined"},{"id":"28587","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":19,"text":"그런즉 내가 무엇을 말하느뇨 우상의 제물은 무엇이며 우상은 무엇이라 하느뇨","reference":"고린도전서 10:19","category":"$undefined"},{"id":"28588","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":20,"text":"대저 이방인의 제사하는 것은 귀신에게 하는 것이요 하나님께 제사하는 것이 아니니 나는 너희가 귀신과 교제하는 자 되기를 원치 아니하노라","reference":"고린도전서 10:20","category":"$undefined"},{"id":"28589","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":21,"text":"너희가 주(主)의 잔과 귀신(鬼神)의 잔을 겸하여 마시지 못하고 주의 상과 귀신의 상에 겸하여 참예치 못하리라","reference":"고린도전서 10:21","category":"$undefined"},{"id":"28590","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":22,"text":"그러면 우리가 주를 노여워하시게 하겠느냐 우리가 주보다 강한 자냐","reference":"고린도전서 10:22","category":"$undefined"},{"id":"28591","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":23,"text":"모든 것이 가하나 모든 것이 유익한 것이 아니요 모든 것이 가하나 모든 것이 덕을 세우는 것이 아니니","reference":"고린도전서 10:23","category":"$undefined"},{"id":"28592","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":24,"text":"누구든지 자기의 유익을 구치 말고 남의 유익을 구하라","reference":"고린도전서 10:24","category":"$undefined"},{"id":"28593","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":25,"text":"무릇 시장에서 파는 것은 양심을 위하여 묻지 말고 먹으라","reference":"고린도전서 10:25","category":"$undefined"},{"id":"28594","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":26,"text":"이는 땅과 거기 충만한 것이 주의 것임이니라","reference":"고린도전서 10:26","category":"$undefined"},{"id":"28595","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":27,"text":"불신자 중 누가 너희를 청하매 너희가 가고자 하거든 너희 앞에 무엇이든지 차려 놓은 것은 양심을 위하여 묻지 말고 먹으라","reference":"고린도전서 10:27","category":"$undefined"},{"id":"28596","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":28,"text":"누가 너희에게 이것이 제물이라 말하거든 알게 한 자와 및 양심을 위하여 먹지 말라","reference":"고린도전서 10:28","category":"$undefined"},{"id":"28597","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":29,"text":"내가 말한 양심은 너희의 것이 아니요 남의 것이니 어찌하여 내 자유가 남의 양심으로 말미암아 판단을 받으리요","reference":"고린도전서 10:29","category":"$undefined"},{"id":"28598","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":30,"text":"만일 내가 감사함으로 참예하면 어찌하여 내가 감사하다 하는 것에 대하여 비방을 받으리요","reference":"고린도전서 10:30","category":"$undefined"},{"id":"28599","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":31,"text":"그런즉 너희가 먹든지 마시든지 무엇을 하든지 다 하나님의 영광을 위하여 하라","reference":"고린도전서 10:31","category":"$undefined"},{"id":"28600","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":32,"text":"유대인에게나 헬라인에게나 하나님의 교회에나 거치는 자가 되지 말고","reference":"고린도전서 10:32","category":"$undefined"},{"id":"28601","book":"고린도전서","book_name":"고린도전서","chapter":10,"verse":33,"text":"나와 같이 모든 일에 모든 사람을 기쁘게 하여 나의 유익을 구치 아니하고 많은 사람의 유익을 구하여 저희로 구원을 얻게 하라","reference":"고린도전서 10:33","category":"$undefined"}],"bookSlug":"1corinthians"}]
