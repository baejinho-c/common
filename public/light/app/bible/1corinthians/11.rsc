2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":11,"verses":[{"id":"28602","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":1,"text":"내가 그리스도를 본받는 자 된 것같이 너희는 나를 본받는 자 되라","reference":"고린도전서 11:1","category":"$undefined"},{"id":"28603","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":2,"text":"너희가 모든 일에 나를 기억하고 또 내가 너희에게 전하여 준 대로 그 유전을 너희가 지키므로 너희를 칭찬하노라","reference":"고린도전서 11:2","category":"$undefined"},{"id":"28604","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":3,"text":"그러나 나는 너희가 알기를 원하노니 각 남자의 머리는 그리스도요, 여자의 머리는 남자요, 그리스도의 머리는 하나님이시라","reference":"고린도전서 11:3","category":"$undefined"},{"id":"28605","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":4,"text":"무릇 남자로서 머리에 무엇을 쓰고 기도나 예언을 하는 자는 그 머리를 욕되게 하는 것이요","reference":"고린도전서 11:4","category":"$undefined"},{"id":"28606","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":5,"text":"무릇 여자로서 머리에 쓴 것을 벗고 기도나 예언을 하는 자는 그 머리를 욕되게 하는 것이니 이는 머리민 것과 다름이 없음이니라","reference":"고린도전서 11:5","category":"$undefined"},{"id":"28607","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":6,"text":"만일 여자가 머리에 쓰지 않거든 깎을 것이요 만일 깎거나 미는 것이 여자에게 부끄러움이 되거든 쓸지니라","reference":"고린도전서 11:6","category":"$undefined"},{"id":"28608","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":7,"text":"남자는 하나님의 형상과 영광이니 그 머리에 마땅히 쓰지 않거니와 여자는 남자의 영광이니라","reference":"고린도전서 11:7","category":"$undefined"},{"id":"28609","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":8,"text":"남자가 여자에게서 난 것이 아니요 여자가 남자에게서 났으며","reference":"고린도전서 11:8","category":"$undefined"},{"id":"28610","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":9,"text":"또 남자가 여자를 위하여 지음을 받지 아니하고 여자가 남자를 위하여 지음을 받은 것이니","reference":"고린도전서 11:9","category":"$undefined"},{"id":"28611","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":10,"text":"이러므로 여자는 천사들을 인하여 권세 아래 있는 표를 그 머리위에 둘지니라","reference":"고린도전서 11:10","category":"$undefined"},{"id":"28612","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":11,"text":"그러나 주 안에는 남자 없이 여자만 있지 않고 여자 없이 남자만 있지 아니하니라","reference":"고린도전서 11:11","category":"$undefined"},{"id":"28613","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":12,"text":"여자가 남자에게서 난 것같이 남자도 여자로 말미암아 났으나 모든 것이 하나님에게서 났느니라","reference":"고린도전서 11:12","category":"$undefined"},{"id":"28614","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":13,"text":"너희는 스스로 판단하라 여자가 쓰지 않고 하나님께 기도하는 것이 마땅하냐","reference":"고린도전서 11:13","category":"$undefined"},{"id":"28615","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":14,"text":"만일 남자가 긴 머리가 있으면 자기에게 욕되는 것을 본성이 너희에게 가르치지 아니하느냐","reference":"고린도전서 11:14","category":"$undefined"},{"id":"28616","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":15,"text":"만일 여자가 긴 머리가 있으면 자기에게 영광이 되나니 긴 머리는 쓰는 것을 대신하여 주신 연고니라","reference":"고린도전서 11:15","category":"$undefined"},{"id":"28617","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":16,"text":"변론하려는 태도를 가진 자가 있을지라도 우리에게나 하나님의 모든 교회에는 이런 규례가 없느니라","reference":"고린도전서 11:16","category":"$undefined"},{"id":"28618","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":17,"text":"내가 명하는 이 일에 너희를 칭찬하지 아니하나니 이는 저희의 모임이 유익이 못되고 도리어 해로움이라","reference":"고린도전서 11:17","category":"$undefined"},{"id":"28619","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":18,"text":"첫째는 너희가 교회에 모일 때에 너희 중에 분쟁이 있다 함을 듣고 대강 믿노니","reference":"고린도전서 11:18","category":"$undefined"},{"id":"28620","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":19,"text":"너희 중에 편당이 있어야 너희 중에 옳다 인정함을 받은 자들이 나타나게 되리라","reference":"고린도전서 11:19","category":"$undefined"},{"id":"28621","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":20,"text":"그런즉 너희가 함께 모여서 주의 만찬을 먹을 수 없으니","reference":"고린도전서 11:20","category":"$undefined"},{"id":"28622","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":21,"text":"이는 먹을 때에 각각 자기의 만찬을 먼저 갖다 먹으므로 어떤 이는 시장하고 어떤 이는 취함이라","reference":"고린도전서 11:21","category":"$undefined"},{"id":"28623","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":22,"text":"너희가 먹고 마실 집이 없느냐 너희가 하나님의 교회를 업신여기고 빈궁한 자들을 부끄럽게 하느냐 내가 너희에게 무슨 말을 하랴 너희를 칭찬하랴 이것으로 칭찬하지 않노라","reference":"고린도전서 11:22","category":"$undefined"},{"id":"28624","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":23,"text":"내가 너희에게 전한 것은 주께 받은 것이니 곧 주 예수께서 잡히시던 밤에 떡을 가지사","reference":"고린도전서 11:23","category":"$undefined"},{"id":"28625","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":24,"text":"축사하시고 떼어 가라사대 이것은 너희를 위하는 내 몸이니 이것을 행하여 나를 기념하라 하시고","reference":"고린도전서 11:24","category":"$undefined"},{"id":"28626","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":25,"text":"식후에 또한 이와 같이 잔을 가지시고 가라사대 이 잔은 내 피로 세운 새 언약이니 이것을 행하여 마실 때마다 나를 기념하라 하셨으니","reference":"고린도전서 11:25","category":"$undefined"},{"id":"28627","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":26,"text":"너희가 이 떡을 먹으며 이 잔을 마실 때마다 주의 죽으심을 오실 때까지 전하는 것이니라","reference":"고린도전서 11:26","category":"$undefined"},{"id":"28628","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":27,"text":"그러므로 누구든지 주의 떡이나 잔을 합당치 않게 먹고 마시는 자는 주의 몸과 피를 범하는 죄가 있느니라","reference":"고린도전서 11:27","category":"$undefined"},{"id":"28629","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":28,"text":"사람이 자기를 살피고 그 후에야 이 떡을 먹고 이 잔을 마실지니","reference":"고린도전서 11:28","category":"$undefined"},{"id":"28630","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":29,"text":"주의 몸을 분변치 못하고 먹고 마시는 자는 자기의 죄를 먹고 마시는 것이니라","reference":"고린도전서 11:29","category":"$undefined"},{"id":"28631","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":30,"text":"이러므로 너희 중에 약한 자와 병든 자가 많고 잠자는 자도 적지 아니하니","reference":"고린도전서 11:30","category":"$undefined"},{"id":"28632","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":31,"text":"우리가 우리를 살폈으면 판단을 받지 아니하려니와","reference":"고린도전서 11:31","category":"$undefined"},{"id":"28633","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":32,"text":"우리가 판단을 받는 것은 주께 징계를 받는 것이니 이는 우리로 세상과 함께 죄 정함을 받지 않게 하려 하심이라","reference":"고린도전서 11:32","category":"$undefined"},{"id":"28634","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":33,"text":"그런즉 내 형제들아 먹으러 모일 때에 서로 기다리라","reference":"고린도전서 11:33","category":"$undefined"},{"id":"28635","book":"고린도전서","book_name":"고린도전서","chapter":11,"verse":34,"text":"만일 누구든지 시장하거든 집에서 먹을지니 이는 너희의 판단 받는 모임이 되지 않게 하려 함이라 그 남은 것은 내가 언제든지 갈 때에 귀정(歸正)하리라","reference":"고린도전서 11:34","category":"$undefined"}],"bookSlug":"1corinthians"}]
