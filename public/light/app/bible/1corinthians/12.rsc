2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":12,"verses":[{"id":"28636","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":1,"text":"형제들아 ! 신령한 것에 대하여는 내가 너희의 알지 못하기를 원치 아니하노니","reference":"고린도전서 12:1","category":"$undefined"},{"id":"28637","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":2,"text":"너희도 알거니와 너희가 이방인으로 있을 때에 말 못하는 우상에게로 끄는 그대로 끌려 갔느니라","reference":"고린도전서 12:2","category":"$undefined"},{"id":"28638","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":3,"text":"그러므로 내가 너희에게 알게 하노니 하나님의 영(靈)으로 말하는 자는 누구든지 예수를 저주할 자라 하지 않고 또 성령으로 아니하고는 누구든지 예수를 주(主)시라 할 수 없느니라","reference":"고린도전서 12:3","category":"$undefined"},{"id":"28639","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":4,"text":"은사는 여러 가지나 성령은 같고","reference":"고린도전서 12:4","category":"$undefined"},{"id":"28640","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":5,"text":"직임은 여러 가지나 주(主)는 같으며","reference":"고린도전서 12:5","category":"$undefined"},{"id":"28641","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":6,"text":"또 역사는 여러 가지나 모든 것을 모든 사람 가운데서 역사하시는 하나님은 같으니","reference":"고린도전서 12:6","category":"$undefined"},{"id":"28642","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":7,"text":"각 사람에게 성령의 나타남을 주심은 유익하게 하려 하심이라","reference":"고린도전서 12:7","category":"$undefined"},{"id":"28643","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":8,"text":"어떤 이에게는 성령으로 말미암아 지혜의 말씀을, 어떤 이에게는 같은 성령을 따라 지식의 말씀을,","reference":"고린도전서 12:8","category":"$undefined"},{"id":"28644","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":9,"text":"다른 이에게는 같은 성령으로 믿음을, 어떤 이에게는 한 성령으로 병 고치는 은사를,","reference":"고린도전서 12:9","category":"$undefined"},{"id":"28645","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":10,"text":"어떤 이에게는 능력 행함을, 어떤 이에게는 예언함을, 어떤 이에게는 영들 분별함을, 다른 이에게는 각종 방언 말함을, 어떤 이에게는 방언들 통역함을 주시나니","reference":"고린도전서 12:10","category":"$undefined"},{"id":"28646","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":11,"text":"이 모든 일은 같은 한 성령이 행하사 그 뜻대로 각 사람에게 나눠 주시느니라","reference":"고린도전서 12:11","category":"$undefined"},{"id":"28647","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":12,"text":"몸은 하나인데 많은 지체가 있고 몸의 지체가 많으나 한 몸임과 같이 그리스도도 그러하니라","reference":"고린도전서 12:12","category":"$undefined"},{"id":"28648","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":13,"text":"우리가 유대인이나 헬라인이나 종이나 자유자나 다 한 성령으로 세례를 받아 한 몸이 되었고 또 다 한 성령을 마시게 하셨느니라","reference":"고린도전서 12:13","category":"$undefined"},{"id":"28649","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":14,"text":"몸은 한 지체뿐 아니요 여럿이니","reference":"고린도전서 12:14","category":"$undefined"},{"id":"28650","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":15,"text":"만일 발이 이르되 나는 손이 아니니 몸에 붙지 아니하였다 할지라도 이로 인하여 몸에 붙지 아니한 것이 아니요","reference":"고린도전서 12:15","category":"$undefined"},{"id":"28651","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":16,"text":"또 귀가 이르되 나는 눈이 아니니 몸에 붙지 아니하였다 할지라도 이로 인하여 몸에 붙지 아니한 것이 아니니","reference":"고린도전서 12:16","category":"$undefined"},{"id":"28652","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":17,"text":"만일 온 몸이 눈이면 듣는 곳은 어디며 온 몸이 듣는 곳이면 냄새 맡는 곳은 어디뇨","reference":"고린도전서 12:17","category":"$undefined"},{"id":"28653","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":18,"text":"그러나 이제 하나님이 그 원하시는 대로 지체를 각각 몸에 두셨으니","reference":"고린도전서 12:18","category":"$undefined"},{"id":"28654","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":19,"text":"만일 다 한 지체뿐이면 몸은 어디뇨","reference":"고린도전서 12:19","category":"$undefined"},{"id":"28655","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":20,"text":"이제 지체는 많으나 몸은 하나라","reference":"고린도전서 12:20","category":"$undefined"},{"id":"28656","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":21,"text":"눈이 손더러 내가 너를 쓸데 없다 하거나 또한 머리가 발더러 내가 너를 쓸데 없다 하거나 하지 못하리라","reference":"고린도전서 12:21","category":"$undefined"},{"id":"28657","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":22,"text":"이뿐 아니라 몸의 더 약하게 보이는 지체가 도리어 요긴하고","reference":"고린도전서 12:22","category":"$undefined"},{"id":"28658","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":23,"text":"우리가 몸의 덜 귀히 여기는 그것들을 더욱 귀한 것들로 입혀주며 우리의 아름답지 못한 지체는 더욱 아름다운 것을 얻고","reference":"고린도전서 12:23","category":"$undefined"},{"id":"28659","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":24,"text":"우리의 아름다운 지체는 요구할 것이 없으니 오직 하나님이 몸을 고르게 하여 부족한 지체에게 존귀를 더하사","reference":"고린도전서 12:24","category":"$undefined"},{"id":"28660","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":25,"text":"몸 가운데서 분쟁이 없고 오직 여러 지체가 서로 같이하여 돌아보게 하셨으니","reference":"고린도전서 12:25","category":"$undefined"},{"id":"28661","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":26,"text":"만일 한 지체가 고통을 받으면 모든 지체도 함께 고통을 받고 한 지체가 영광을 얻으면 모든 지체도 함께 즐거워하나니","reference":"고린도전서 12:26","category":"$undefined"},{"id":"28662","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":27,"text":"너희는 그리스도의 몸이요 지체의 각 부분이라","reference":"고린도전서 12:27","category":"$undefined"},{"id":"28663","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":28,"text":"하나님이 교회 중에 몇을 세우셨으니 첫째는 사도요, 둘째는 선지자요, 세째는 교사요, 그 다음은 능력이요, 그 다음은 병 고치는 은사와, 서로 돕는 것과, 다스리는 것과, 각종 방언을 하는 것이라","reference":"고린도전서 12:28","category":"$undefined"},{"id":"28664","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":29,"text":"다 사도겠느냐 ? 다 선지자겠느냐 ? 다 교사겠느냐 ? 다 능력을 행하는 자겠느냐 ?","reference":"고린도전서 12:29","category":"$undefined"},{"id":"28665","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":30,"text":"다 병 고치는 은사를 가진 자겠느냐 ? 다 방언을 말하는 자겠느냐 ? 다 통역하는 자겠느냐 ?","reference":"고린도전서 12:30","category":"$undefined"},{"id":"28666","book":"고린도전서","book_name":"고린도전서","chapter":12,"verse":31,"text":"너희는 더욱 큰 은사를 사모하라 ! 내가 또한 제일 좋은 길을 너희에게 보이리라","reference":"고린도전서 12:31","category":"$undefined"}],"bookSlug":"1corinthians"}]
