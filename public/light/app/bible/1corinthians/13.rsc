2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":13,"verses":[{"id":"28667","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":1,"text":"내가 사람의 방언과 천사의 말을 할지라도 사랑이 없으면 소리나는 구리와 울리는 꽹과리가 되고","reference":"고린도전서 13:1","category":"$undefined"},{"id":"28668","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":2,"text":"내가 예언하는 능이 있어 모든 비밀과 모든 지식을 알고 또 산을 옮길 만한 모든 믿음이 있을지라도 사랑이 없으면 내가 아무 것도 아니요","reference":"고린도전서 13:2","category":"$undefined"},{"id":"28669","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":3,"text":"내가 내게 있는 모든 것으로 구제하고 또 내 몸을 불사르게 내어 줄지라도 사랑이 없으면 내게 아무 유익이 없느니라","reference":"고린도전서 13:3","category":"$undefined"},{"id":"28670","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":4,"text":"사랑은 오래 참고, 사랑은 온유하며, 투기하는 자가 되지 아니하며, 사랑은 자랑하지 아니하며, 교만하지 아니하며","reference":"고린도전서 13:4","category":"$undefined"},{"id":"28671","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":5,"text":"무례히 행치 아니하며, 자기의 유익을 구치 아니하며, 성내지 아니하며, 악한 것을 생각지 아니하며","reference":"고린도전서 13:5","category":"$undefined"},{"id":"28672","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":6,"text":"불의를 기뻐하지 아니하며, 진리와 함께 기뻐하고","reference":"고린도전서 13:6","category":"$undefined"},{"id":"28673","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":7,"text":"모든 것을 참으며, 모든 것을 믿으며, 모든 것을 바라며, 모든 것을 견디느니라 !","reference":"고린도전서 13:7","category":"$undefined"},{"id":"28674","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":8,"text":"사랑은 언제까지든지 떨어지지 아니하나 예언도 폐하고 방언도 그치고 지식도 폐하리라","reference":"고린도전서 13:8","category":"$undefined"},{"id":"28675","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":9,"text":"우리가 부분적으로 알고 부분적으로 예언하니","reference":"고린도전서 13:9","category":"$undefined"},{"id":"28676","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":10,"text":"온전한 것이 올 때에는 부분적으로 하던 것이 폐하리라","reference":"고린도전서 13:10","category":"$undefined"},{"id":"28677","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":11,"text":"내가 어렸을 때에는 말하는 것이 어린 아이와 같고 깨닫는 것이 어린 아이와 같고 생각하는 것이 어린 아이와 같다가 장성한 사람이 되어서는 어린 아이의 일을 버렸노라","reference":"고린도전서 13:11","category":"$undefined"},{"id":"28678","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":12,"text":"우리가 이제는 거울로 보는 것같이 희미하나 그 때에는 얼굴과 얼굴을 대하여 볼 것이요 이제는 내가 부분적으로 아나 그 때에는 주께서 나를 아신 것같이 내가 온전히 알리라","reference":"고린도전서 13:12","category":"$undefined"},{"id":"28679","book":"고린도전서","book_name":"고린도전서","chapter":13,"verse":13,"text":"그런즉 믿음, 소망, 사랑, 이 세가지는 항상 있을 것인데 그 중에 제일은 사랑이라 !","reference":"고린도전서 13:13","category":"$undefined"}],"bookSlug":"1corinthians"}]
