2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":14,"verses":[{"id":"28680","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":1,"text":"사랑을 따라 구하라 신령한 것을 사모하되 특별히 예언을 하려고 하라","reference":"고린도전서 14:1","category":"$undefined"},{"id":"28681","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":2,"text":"방언을 말하는 자는 사람에게 하지 아니하고 하나님께 하나니 이는 알아 듣는 자가 없고 그 영으로 비밀을 말함이니라","reference":"고린도전서 14:2","category":"$undefined"},{"id":"28682","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":3,"text":"그러나 예언하는 자는 사람에게 말하여 덕을 세우며 권면하며 안위하는 것이요","reference":"고린도전서 14:3","category":"$undefined"},{"id":"28683","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":4,"text":"방언을 말하는 자는 자기의 덕을 세우고 예언하는 자는 교회의 덕을 세우나니","reference":"고린도전서 14:4","category":"$undefined"},{"id":"28684","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":5,"text":"나는 너희가 다 방언 말하기를 원하나 특별히 예언하기를 원하노라 방언을 말하는 자가 만일 교회의 덕을 세우기 위하여 통역하지 아니하면 예언하는 자만 못하니라","reference":"고린도전서 14:5","category":"$undefined"},{"id":"28685","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":6,"text":"그런즉 형제들아 내가 너희에게 나아가서 방언을 말하고 계시나 지식이나 예언이나 가르치는 것이나 말하지 아니하면 너희에게 무엇이 유익하리요","reference":"고린도전서 14:6","category":"$undefined"},{"id":"28686","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":7,"text":"혹 저나 거문고와 같이 생명 없는 것이 소리를 낼 때에 그 음의 분별을 내지 아니하면 저 부는 것인지 거문고 타는 것인지 어찌 알게 되리요","reference":"고린도전서 14:7","category":"$undefined"},{"id":"28687","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":8,"text":"만일 나팔이 분명치 못한 소리를 내면 누가 전쟁을 예비하리요","reference":"고린도전서 14:8","category":"$undefined"},{"id":"28688","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":9,"text":"이와 같이 너희도 혀로서 알아 듣기 쉬운 말을 하지 아니하면 그 말하는 것을 어찌 알리요 이는 허공에다 말하는 것이라","reference":"고린도전서 14:9","category":"$undefined"},{"id":"28689","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":10,"text":"세상에 소리의 종류가 이같이 많되 뜻 없는 소리는 없나니","reference":"고린도전서 14:10","category":"$undefined"},{"id":"28690","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":11,"text":"그러므로 내가 그 소리의 뜻을 알지 못하면 내가 말하는 자에게 야만(野蠻)이 되고 말하는 자도 내게 야만이 되리니","reference":"고린도전서 14:11","category":"$undefined"},{"id":"28691","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":12,"text":"그러면 너희도 신령한 것을 사모하는 자인즉 교회의 덕 세우기를 위하여 풍성하기를 구하라","reference":"고린도전서 14:12","category":"$undefined"},{"id":"28692","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":13,"text":"그러므로 방언을 말하는 자는 통역하기를 기도할지니","reference":"고린도전서 14:13","category":"$undefined"},{"id":"28693","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":14,"text":"내가 만일 방언으로 기도하면 나의 영이 기도하거니와 나의 마음은 열매를 맺히지 못하리라","reference":"고린도전서 14:14","category":"$undefined"},{"id":"28694","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":15,"text":"그러면 어떻게 할꼬 ? 내가 영으로 기도하고 또 마음으로 기도하며 내가 영으로 찬미하고 또 마음으로 찬미하리라","reference":"고린도전서 14:15","category":"$undefined"},{"id":"28695","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":16,"text":"그렇지 아니하면 네가 영으로 축복할 때에 무식한 처지에 있는 자가 네가 무슨 말을 하는지 알지 못하고 네 감사에 어찌 아멘 하리요","reference":"고린도전서 14:16","category":"$undefined"},{"id":"28696","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":17,"text":"너는 감사를 잘하였으나 그러나 다른 사람은 덕 세움을 받지 못하리라","reference":"고린도전서 14:17","category":"$undefined"},{"id":"28697","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":18,"text":"내가 너희 모든 사람보다 방언을 더 말하므로 하나님께 감사하노라","reference":"고린도전서 14:18","category":"$undefined"},{"id":"28698","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":19,"text":"그러나 교회에서 네가 남을 가르치기 위하여 깨달은 마음으로 다섯 마디 말을 하는 것이 일만 마디 방언으로 말하는 것보다 나으니라","reference":"고린도전서 14:19","category":"$undefined"},{"id":"28699","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":20,"text":"형제들아 지혜에는 아이가 되지 말고 악에는 어린 아이가 되라 지혜에 장성한 사람이 되라","reference":"고린도전서 14:20","category":"$undefined"},{"id":"28700","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":21,"text":"율법에 기록된바 주께서 가라사대 내가 다른 방언하는 자와 다른 입술로 이 백성에게 말할지라도 저희가 오히려 듣지 아니하리라 하였으니","reference":"고린도전서 14:21","category":"$undefined"},{"id":"28701","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":22,"text":"그러므로 방언은 믿는 자들을 위하지 않고 믿지 아니하는 자들을 위하는 표적이나 예언은 믿지 아니하는 자들을 위하지 않고 믿는 자들을 위함이니","reference":"고린도전서 14:22","category":"$undefined"},{"id":"28702","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":23,"text":"그러므로 온 교회가 함께 모여 다 방언으로 말하면 무식한 자들이나 믿지 아니하는 자들이 들어와서 너희를 미쳤다 하지 아니하겠느냐 ?","reference":"고린도전서 14:23","category":"$undefined"},{"id":"28703","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":24,"text":"그러나 다 예언을 하면 믿지 아니하는 자들이나 무식한 자들이 들어와서 모든 사람에게 책망을 들으며 모든 사람에게 판단을 받고","reference":"고린도전서 14:24","category":"$undefined"},{"id":"28704","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":25,"text":"그 마음의 숨은 일이 드러나게 되므로 엎드리어 하나님께 경배하며 하나님이 참으로 너희 가운데 계시다 전파하리라","reference":"고린도전서 14:25","category":"$undefined"},{"id":"28705","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":26,"text":"그런즉 형제들아 어찌할꼬 너희가 모일 때에 각각 찬송시도 있으며 가르치는 말씀도 있으며 계시도 있으며 방언도 있으며 통역함도 있나니 모든 것을 덕을 세우기 위하여 하라","reference":"고린도전서 14:26","category":"$undefined"},{"id":"28706","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":27,"text":"만일 누가 방언으로 말하거든 두 사람이나 다불과 세 사람이 차서를 따라 하고 한 사람이 통역할 것이요","reference":"고린도전서 14:27","category":"$undefined"},{"id":"28707","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":28,"text":"만일 통역하는 자가 없거든 교회에서는 잠잠하고 자기와 및 하나님께 말할 것이요","reference":"고린도전서 14:28","category":"$undefined"},{"id":"28708","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":29,"text":"예언하는 자는 둘이나 셋이나 말하고 다른 이들은 분변할 것이요","reference":"고린도전서 14:29","category":"$undefined"},{"id":"28709","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":30,"text":"만일 곁에 앉은 다른 이에게 계시가 있거든 먼저 하던 자는 잠잠할지니라","reference":"고린도전서 14:30","category":"$undefined"},{"id":"28710","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":31,"text":"너희는 다 모든 사람으로 배우게 하고 모든 사람으로 권면을 받게 하기 위하여 하나씩 하나씩 예언할 수 있느니라","reference":"고린도전서 14:31","category":"$undefined"},{"id":"28711","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":32,"text":"예언하는 자들의 영이 예언하는 자들에게 제재를 받나니","reference":"고린도전서 14:32","category":"$undefined"},{"id":"28712","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":33,"text":"하나님은 어지러움의 하나님이 아니시요 오직 ! 화평의 하나님이시니라","reference":"고린도전서 14:33","category":"$undefined"},{"id":"28713","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":34,"text":"모든 성도의 교회에서 함과 같이 여자는 교회에서 잠잠하라 ! 저희의 말하는 것을 허락함이 없나니 율법에 이른 것같이 오직 복종할 것이요","reference":"고린도전서 14:34","category":"$undefined"},{"id":"28714","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":35,"text":"만일 무엇을 배우려거든 집에서 자기 남편에게 물을지니 여자가 교회에서 말하는 것은 부끄러운 것임이라","reference":"고린도전서 14:35","category":"$undefined"},{"id":"28715","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":36,"text":"하나님의 말씀이 너희에게로부터 난 것이냐 또는 너희에게만 임한 것이냐","reference":"고린도전서 14:36","category":"$undefined"},{"id":"28716","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":37,"text":"만일 누구든지 자기를 선지자나 혹 신령한 자로 생각하거든 내가 너희에게 편지한 것이 주의 명령인 줄 알라","reference":"고린도전서 14:37","category":"$undefined"},{"id":"28717","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":38,"text":"만일 누구든지 알지 못하면 그는 알지 못한 자니라","reference":"고린도전서 14:38","category":"$undefined"},{"id":"28718","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":39,"text":"그런즉 내 형제들아 예언하기를 사모하며 방언 말하기를 금하지 말라","reference":"고린도전서 14:39","category":"$undefined"},{"id":"28719","book":"고린도전서","book_name":"고린도전서","chapter":14,"verse":40,"text":"모든 것을 적당하게 하고 질서대로 하라 !","reference":"고린도전서 14:40","category":"$undefined"}],"bookSlug":"1corinthians"}]
