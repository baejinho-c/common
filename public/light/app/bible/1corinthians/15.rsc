2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":15,"verses":[{"id":"28720","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":1,"text":"형제들아 ! 내가 너희에게 전한 복음을 너희로 알게 하노니 이는 너희가 받은 것이요 또 그 가운데 선 것이라","reference":"고린도전서 15:1","category":"$undefined"},{"id":"28721","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":2,"text":"너희가 만일 나의 전한 그 말을 굳게 지키고 헛되이 믿지 아니하였으면 이로 말미암아 구원을 얻으리라","reference":"고린도전서 15:2","category":"$undefined"},{"id":"28722","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":3,"text":"내가 받은 것을 먼저 너희에게 전하였노니 이는 성경대로 그리스도께서 우리 죄를 위하여 죽으시고","reference":"고린도전서 15:3","category":"$undefined"},{"id":"28723","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":4,"text":"장사 지낸 바 되었다가 성경대로 사흘 만에 다시 살아나사","reference":"고린도전서 15:4","category":"$undefined"},{"id":"28724","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":5,"text":"게바에게 보이시고 후에 열 두 제자에게와","reference":"고린도전서 15:5","category":"$undefined"},{"id":"28725","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":6,"text":"그 후에 오백여 형제에게 일시에 보이셨나니 그 중에 지금까지 태반이나 살아 있고 어떤 이는 잠들었으며","reference":"고린도전서 15:6","category":"$undefined"},{"id":"28726","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":7,"text":"그 후에 야고보에게 보이셨으며 그 후에 모든 사도에게와","reference":"고린도전서 15:7","category":"$undefined"},{"id":"28727","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":8,"text":"맨 나중에 만삭되지 못하여 난 자 같은 내게도 보이셨느니라","reference":"고린도전서 15:8","category":"$undefined"},{"id":"28728","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":9,"text":"나는 사도 중에 지극히 작은 자라 내가 하나님의 교회를 핍박하였으므로 사도라 칭함을 받기에 감당치 못할 자로라","reference":"고린도전서 15:9","category":"$undefined"},{"id":"28729","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":10,"text":"그러나 나의 나 된 것은 하나님의 은혜로 된 것이니 내게 주신 그의 은혜가 헛되지 아니하여 내가 모든 사도보다 더 많이 수고하였으나 내가 아니요 오직 나와 함께 하신 하나님의 은혜로라","reference":"고린도전서 15:10","category":"$undefined"},{"id":"28730","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":11,"text":"그러므로 내나 저희나 이같이 전파하매 너희도 이같이 믿었느니라","reference":"고린도전서 15:11","category":"$undefined"},{"id":"28731","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":12,"text":"그리스도께서 죽은 자 가운데서 다시 살아나셨다 전파되었거늘 너희 중에서 어떤 이들은 어찌하여 죽은 자 가운데서 부활이 없다 하느냐","reference":"고린도전서 15:12","category":"$undefined"},{"id":"28732","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":13,"text":"만일 죽은 자의 부활이 없으면 그리스도도 다시 살지 못하셨으리라","reference":"고린도전서 15:13","category":"$undefined"},{"id":"28733","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":14,"text":"그리스도께서 만일 다시 살지 못하셨으면 우리의 전파하는 것도 헛것이요 또 너희 믿음도 헛것이며","reference":"고린도전서 15:14","category":"$undefined"},{"id":"28734","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":15,"text":"또 우리가 하나님의 거짓 증인으로 발견되리니 우리가 하나님이 그리스도를 다시 살리셨다고 증거하였음이라 만일 죽은 자가 다시 사는 것이 없으면 하나님이 그리스도를 다시 살리시지 아니하셨으리라","reference":"고린도전서 15:15","category":"$undefined"},{"id":"28735","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":16,"text":"만일 죽은 자가 다시 사는 것이 없으면 그리스도도 다시 사신 것이 없었을 터이요","reference":"고린도전서 15:16","category":"$undefined"},{"id":"28736","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":17,"text":"그리스도께서 다시 사신 것이 없으면 너희의 믿음도 헛되고 너희가 여전히 죄 가운데 있을 것이요","reference":"고린도전서 15:17","category":"$undefined"},{"id":"28737","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":18,"text":"또한 그리스도 안에서 잠 자는 자도 망하였으리니","reference":"고린도전서 15:18","category":"$undefined"},{"id":"28738","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":19,"text":"만일 그리스도 안에서 우리의 바라는 것이 다만 이생 뿐이면 모든 사람 가운데 우리가 더욱 불쌍한 자리라","reference":"고린도전서 15:19","category":"$undefined"},{"id":"28739","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":20,"text":"그러나 이제 그리스도께서 죽은 자 가운데서 다시 살아 잠 자는 자들의 첫 열매가 되셨도다","reference":"고린도전서 15:20","category":"$undefined"},{"id":"28740","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":21,"text":"사망이 사람으로 말미암았으니 죽은 자의 부활도 사람으로 말미암는도다","reference":"고린도전서 15:21","category":"$undefined"},{"id":"28741","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":22,"text":"아담 안에서 모든 사람이 죽은것 같이 그리스도 안에서 모든 사람이 삶을 얻으리라","reference":"고린도전서 15:22","category":"$undefined"},{"id":"28742","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":23,"text":"그러나 각각 자기 차례대로 되리니 먼저는 첫 열매인 그리스도요 다음에는 그리스도 강림하실 때에 그에게 붙은 자요","reference":"고린도전서 15:23","category":"$undefined"},{"id":"28743","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":24,"text":"그 후에는 나중이니 저가 모든 정사와 모든 권세와 능력을 멸하시고 나라를 아버지 하나님께 바칠 때라","reference":"고린도전서 15:24","category":"$undefined"},{"id":"28744","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":25,"text":"저가 모든 원수를 그 발 아래 둘때까지 불가불 왕노릇하시리니","reference":"고린도전서 15:25","category":"$undefined"},{"id":"28745","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":26,"text":"맨 나중에 멸망 받을 원수는 사망이니라","reference":"고린도전서 15:26","category":"$undefined"},{"id":"28746","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":27,"text":"만물을 저의 발 아래 두셨다 하셨으니 만물을 아래 둔다 말씀하실 때에 만물을 저의 아래 두신 이가 그 중에 들지 아니한 것이 분명하도다","reference":"고린도전서 15:27","category":"$undefined"},{"id":"28747","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":28,"text":"만물을 저에게 복종하게 하신 때에는 아들 자신도 그 때에 만물을 자기에게 복종케 하신 이에게 복종케 되리니 이는 하나님이 만유의 주로서 만유 안에 계시려 하심이라","reference":"고린도전서 15:28","category":"$undefined"},{"id":"28748","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":29,"text":"만일 죽은 자들이 도무지 다시 살지 못하면 죽은 자들을 위하여 세례 받는 자들이 무엇을 하겠느냐 어찌하여 저희를 위하여 세례를 받느뇨","reference":"고린도전서 15:29","category":"$undefined"},{"id":"28749","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":30,"text":"또 어찌하여 우리가 때마다 위험을 무릅쓰리요","reference":"고린도전서 15:30","category":"$undefined"},{"id":"28750","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":31,"text":"형제들아 내가 그리스도 예수 우리 주 안에서 가진 바 너희에게 대한 나의 자랑을 두고 단언하노니 나는 날마다 죽노라","reference":"고린도전서 15:31","category":"$undefined"},{"id":"28751","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":32,"text":"내가 범인처럼 에베소에서 맹수로 더불어 싸웠으면 내게 무슨 유익이 있느뇨 죽은 자가 다시 살지 못할 것이면 내일 죽을 터이니 먹고 마시자 하리라","reference":"고린도전서 15:32","category":"$undefined"},{"id":"28752","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":33,"text":"속지 말라 악한 동무들은 선한 행실을 더럽히나니","reference":"고린도전서 15:33","category":"$undefined"},{"id":"28753","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":34,"text":"깨어 의를 행하고 죄를 짓지 말라 하나님을 알지 못하는 자가 있기로 내가 너희를 부끄럽게 하기 위하여 말하노라","reference":"고린도전서 15:34","category":"$undefined"},{"id":"28754","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":35,"text":"누가 묻기를 죽은 자들이 어떻게 다시 살며 어떠한 몸으로 오느냐 하리니","reference":"고린도전서 15:35","category":"$undefined"},{"id":"28755","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":36,"text":"어리석은 자여 ! 너의 뿌리는 씨가 죽지 않으면 살아나지 못하겠고","reference":"고린도전서 15:36","category":"$undefined"},{"id":"28756","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":37,"text":"또 너의 뿌리는 것은 장래 형체를 뿌리는 것이 아니요 다만 밀이나 다른 것의 알갱이뿐이로되","reference":"고린도전서 15:37","category":"$undefined"},{"id":"28757","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":38,"text":"하나님이 그 뜻대로 저에게 형체를 주시되 각 종자에게 그 형체를 주시느니라","reference":"고린도전서 15:38","category":"$undefined"},{"id":"28758","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":39,"text":"육체는 다 같은 육체가 아니니 하나는 사람의 육체요, 하나는 짐승의 육체요, 하나는 새의 육체요, 하나는 물고기의 육체라","reference":"고린도전서 15:39","category":"$undefined"},{"id":"28759","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":40,"text":"하늘에 속한 형체도 있고, 땅에 속한 형체도 있으나, 하늘에 속한 자의 영광이 따로 있고, 땅에 속한 자의 영광이 따로 있으니","reference":"고린도전서 15:40","category":"$undefined"},{"id":"28760","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":41,"text":"해의 영광도 다르며, 달의 영광도 다르며, 별의 영광도 다른데, 별과 별의 영광이 다르도다","reference":"고린도전서 15:41","category":"$undefined"},{"id":"28761","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":42,"text":"죽은 자의 부활도 이와 같으니 썩을 것으로 심고 썩지 아니할 것으로 다시 살며","reference":"고린도전서 15:42","category":"$undefined"},{"id":"28762","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":43,"text":"욕된 것으로 심고 영광스러운 것으로 다시 살며 약한 것으로 심고 강한 것으로 다시 살며","reference":"고린도전서 15:43","category":"$undefined"},{"id":"28763","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":44,"text":"육의 몸으로 심고 신령한 몸으로 다시 사나니 육의 몸이 있은즉 또 신령한 몸이 있느니라","reference":"고린도전서 15:44","category":"$undefined"},{"id":"28764","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":45,"text":"기록된 바 첫 사람 아담은 산 영이 되었다 함과 같이 마지막 아담은 살려 주는 영이 되었나니","reference":"고린도전서 15:45","category":"$undefined"},{"id":"28765","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":46,"text":"그러나 먼저는 신령한 자가 아니요 육 있는 자요 그 다음에 신령한 자니라","reference":"고린도전서 15:46","category":"$undefined"},{"id":"28766","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":47,"text":"첫 사람은 땅에서 났으니 흙에 속한 자이거니와 둘째 사람은 하늘에서 나셨느니라","reference":"고린도전서 15:47","category":"$undefined"},{"id":"28767","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":48,"text":"무릇 흙에 속한 자는 저 흙에 속한 자들과 같고 무릇 하늘에 속한 자는 저 하늘에 속한 자들과 같으니","reference":"고린도전서 15:48","category":"$undefined"},{"id":"28768","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":49,"text":"우리가 흙에 속한 자의 형상을 입은 것같이 또한 하늘에 속한 자의 형상을 입으리라","reference":"고린도전서 15:49","category":"$undefined"},{"id":"28769","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":50,"text":"형제들아 내가 이것을 말하노니 혈과 육은 하나님 나라를 유업으로 받을 수 없고 또한 썩은 것은 썩지 아니한 것을 유업으로 받지 못하느니라","reference":"고린도전서 15:50","category":"$undefined"},{"id":"28770","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":51,"text":"보라 ! 내가 너희에게 비밀을 말하노니 우리가 다 잠잘 것이 아니요 마지막 나팔에 순식간에 홀연히 다 변화하리니","reference":"고린도전서 15:51","category":"$undefined"},{"id":"28771","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":52,"text":"나팔 소리가 나매 죽은 자들이 썩지 아니할 것으로 다시 살고 우리도 변화하리라","reference":"고린도전서 15:52","category":"$undefined"},{"id":"28772","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":53,"text":"이 썩을 것이 불가불 썩지 아니할 것을 입겠고 이 죽을 것이 죽지 아니함을 입으리로다","reference":"고린도전서 15:53","category":"$undefined"},{"id":"28773","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":54,"text":"이 썩을 것이 썩지 아니함을 입고 이 죽을 것이 죽지 아니함을 입을 때에는 사망이 이김의 삼킨 바 되리라고 기록된 말씀이 응하리라","reference":"고린도전서 15:54","category":"$undefined"},{"id":"28774","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":55,"text":"사망아 ! 너의 이기는 것이 어디 있느냐 사망아 ! 너의 쏘는 것이 어디 있느냐","reference":"고린도전서 15:55","category":"$undefined"},{"id":"28775","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":56,"text":"사망의 쏘는 것은 죄요 죄의 권능은 율법이라","reference":"고린도전서 15:56","category":"$undefined"},{"id":"28776","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":57,"text":"우리 주 예수 그리스도로 말미암아 우리에게 이김을 주시는 하나님께 감사하노니","reference":"고린도전서 15:57","category":"$undefined"},{"id":"28777","book":"고린도전서","book_name":"고린도전서","chapter":15,"verse":58,"text":"그러므로 내 사랑하는 형제들아 견고하며 흔들리지 말며 항상 주의 일에 더욱 힘쓰는 자들이 되라 이는 너희 수고가 주 안에서 헛되지 않은 줄을 앎이니라","reference":"고린도전서 15:58","category":"$undefined"}],"bookSlug":"1corinthians"}]
