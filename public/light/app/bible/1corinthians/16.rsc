2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":16,"verses":[{"id":"28778","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":1,"text":"성도를 위하는 연보에 대하여는 내가 갈라디아 교회들에게 명한 것같이 너희도 그렇게 하라","reference":"고린도전서 16:1","category":"$undefined"},{"id":"28779","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":2,"text":"매주일 첫날에 너희 각 사람이 이(利)를 얻은 대로 저축하여 두어서 내가 갈 때에 연보를 하지 않게 하라","reference":"고린도전서 16:2","category":"$undefined"},{"id":"28780","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":3,"text":"내가 이를 때에 너희의 인정한 사람에게 편지를 주어 너희의 은혜를 예루살렘으로 가지고 가게 하리니","reference":"고린도전서 16:3","category":"$undefined"},{"id":"28781","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":4,"text":"만일 나도 가는 것이 합당하면 저희가 나와 함께 가리라","reference":"고린도전서 16:4","category":"$undefined"},{"id":"28782","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":5,"text":"내가 마게도냐를 지날 터이니 마게도냐를 지난 후에 너희에게 나아가서","reference":"고린도전서 16:5","category":"$undefined"},{"id":"28783","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":6,"text":"혹 너희와 함께 머물며 과동(過冬)할 듯도 하니 이는 너희가 나를 나의 갈 곳으로 보내어 주게 하려 함이라","reference":"고린도전서 16:6","category":"$undefined"},{"id":"28784","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":7,"text":"이제는 지나는 길에 너희 보기를 원치 하니하노니 이는 주께서 만일 허락하시면 얼마 동안 너희와 함께 유하기를 바람이라","reference":"고린도전서 16:7","category":"$undefined"},{"id":"28785","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":8,"text":"내가 오순절까지 에베소에 유하려 함은","reference":"고린도전서 16:8","category":"$undefined"},{"id":"28786","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":9,"text":"내게 광대하고 공효(功效)를 이루는 문(門)이 열리고 대적하는 자가 많음이니라","reference":"고린도전서 16:9","category":"$undefined"},{"id":"28787","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":10,"text":"디모데가 이르거든 너희는 조심하여 저로 두려움이 없이 너희 가운데 있게 하라 이는 저도 나와 같이 주의 일을 힘쓰는 자임이니라","reference":"고린도전서 16:10","category":"$undefined"},{"id":"28788","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":11,"text":"그러므로 누구든지 저를 멸시하지 말고 평안히 보내어 내게로 오게하라 나는 저가 형제들과 함께 오기를 기다리노라","reference":"고린도전서 16:11","category":"$undefined"},{"id":"28789","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":12,"text":"형제 아볼로에 대하여는 저더러 형제들과 함께 너희에게 가라고 내가 많이 권하되 지금은 갈 뜻이 일절 없으나 기회가 있으면 가리라","reference":"고린도전서 16:12","category":"$undefined"},{"id":"28790","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":13,"text":"깨어 믿음에 굳게 서서 남자답게 강건하여라 !","reference":"고린도전서 16:13","category":"$undefined"},{"id":"28791","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":14,"text":"너희 모든 일을 사랑으로 행하라 !","reference":"고린도전서 16:14","category":"$undefined"},{"id":"28792","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":15,"text":"형제들아 스데바나의 집은 곧 아가야의 첫 열매요 또 성도 섬기기로 작정한 줄을 너희가 아는지라 내가 너희를 권하노니","reference":"고린도전서 16:15","category":"$undefined"},{"id":"28793","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":16,"text":"이 같은 자들과 또 함께 일하며 수고하는 모든 자에게 복종하라","reference":"고린도전서 16:16","category":"$undefined"},{"id":"28794","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":17,"text":"내가 스데바나와, 브드나도와, 아가이고의 온 것을 기뻐하노니 저희가 너희의 부족한 것을 보충하였음이니라","reference":"고린도전서 16:17","category":"$undefined"},{"id":"28795","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":18,"text":"저희가 나와 너희 마음을 시원케 하였으니 그러므로 너희는 이런 자들을 알아 주라","reference":"고린도전서 16:18","category":"$undefined"},{"id":"28796","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":19,"text":"아시아의 교회들이 너희에게 문안하고 아굴라와, 브리스가와 및 그 집에 있는 교회가 주 안에서 너희에게 간절히 문안하고","reference":"고린도전서 16:19","category":"$undefined"},{"id":"28797","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":20,"text":"모든 형제도 너희에게 문안하니 너희는 거룩하게 입맞춤으로 서로 문안하라","reference":"고린도전서 16:20","category":"$undefined"},{"id":"28798","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":21,"text":"나 바울은 친필로 너희에게 문안하노니","reference":"고린도전서 16:21","category":"$undefined"},{"id":"28799","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":22,"text":"만일 누구든지 주를 사랑하지 아니하거든 저주를 받을지어다 주께서 임하시느니라","reference":"고린도전서 16:22","category":"$undefined"},{"id":"28800","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":23,"text":"주 예수 그리스도의 은혜가 너희와 함께 하고","reference":"고린도전서 16:23","category":"$undefined"},{"id":"28801","book":"고린도전서","book_name":"고린도전서","chapter":16,"verse":24,"text":"나의 사랑이 그리스도 예수의 안에서 너희 무리와 함께 할지어다","reference":"고린도전서 16:24","category":"$undefined"}],"bookSlug":"1corinthians"}]
