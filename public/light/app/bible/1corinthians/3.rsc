2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":3,"verses":[{"id":"28412","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":1,"text":"형제들아 내가 신령한 자들을 대함과 같이 너희에게 말할 수 없어서 육신에 속한 자 곧 그리스도안에서 어린 아이들을 대함과 같이 하노라","reference":"고린도전서 3:1","category":"$undefined"},{"id":"28413","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":2,"text":"내가 너희를 젖으로 먹이고 밥으로 아니하였노니 이는 너희가 감당치 못하였음이거니와 지금도 못하리라","reference":"고린도전서 3:2","category":"$undefined"},{"id":"28414","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":3,"text":"너희가 아직도 육신에 속한 자로다 너희 가운데 시기와 분쟁이 있으니 어찌 육신에 속하여 사람을 따라 행함이 아니리요","reference":"고린도전서 3:3","category":"$undefined"},{"id":"28415","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":4,"text":"어떤 이는 말하되 나는 바울에게라 하고 다른 이는 나는 아볼로에게라 하니 너희가 사람이 아니리요","reference":"고린도전서 3:4","category":"$undefined"},{"id":"28416","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":5,"text":"그런즉 아볼로는 무엇이며 바울은 무엇이뇨 저희는 주께서 각각 주신 대로 너희로 하여금 믿게 한 사역자들이니라","reference":"고린도전서 3:5","category":"$undefined"},{"id":"28417","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":6,"text":"나는 심었고 아볼로는 물을 주었으되 오직 하나님은 자라나게 하셨나니","reference":"고린도전서 3:6","category":"$undefined"},{"id":"28418","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":7,"text":"그런즉 심는 이나 물 주는 이는 아무 것도 아니로되 오직 자라 나게 하시는 하나님뿐이니라","reference":"고린도전서 3:7","category":"$undefined"},{"id":"28419","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":8,"text":"심는 이와 물 주는 이가 일반이나 각각 자기의 일하는 대로 자기의 상을 받으리라","reference":"고린도전서 3:8","category":"$undefined"},{"id":"28420","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":9,"text":"우리는 하나님의 동역자들이요 너희는 하나님의 밭이요 하나님의 집이니라","reference":"고린도전서 3:9","category":"$undefined"},{"id":"28421","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":10,"text":"내게 주신 하나님의 은혜를 따라 내가 지혜로운 건축자와 같이 터를 닦아 두매 다른 이가 그 위에 세우나 그러나 각각 어떻게 그 위에 세우기를 조심할지니라","reference":"고린도전서 3:10","category":"$undefined"},{"id":"28422","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":11,"text":"이 닦아 둔 것 외에 능히 다른 터를 닦아 둘 자가 없으니 이 터는 곧 예수 그리스도라","reference":"고린도전서 3:11","category":"$undefined"},{"id":"28423","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":12,"text":"만일 누구든지 금이나 은이나 보석이나 나무나 풀이나 짚으로 이 터 위에 세우면","reference":"고린도전서 3:12","category":"$undefined"},{"id":"28424","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":13,"text":"각각 공력이 나타날 터인데 그 날이 공력을 밝히리니 이는 불로 나타내고 그 불이 각 사람의 공력이 어떠한 것을 시험할 것임이니라","reference":"고린도전서 3:13","category":"$undefined"},{"id":"28425","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":14,"text":"만일 누구든지 그 위에 세운 공력이 그대로 있으면 상을 받고","reference":"고린도전서 3:14","category":"$undefined"},{"id":"28426","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":15,"text":"누구든지 공력이 불타면 해를 받으리니 그러나 자기는 구원을 얻되 불 가운데서 얻은 것 같으리라","reference":"고린도전서 3:15","category":"$undefined"},{"id":"28427","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":16,"text":"너희가 하나님의 성전인 것과 하나님의 성령이 너희 안에 거하시는 것을 알지 못하느뇨","reference":"고린도전서 3:16","category":"$undefined"},{"id":"28428","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":17,"text":"누구든지 하나님의 성전을 더럽히면 하나님이 그 사람을 멸하시리라 하나님의 성전은 거룩하니 너희도 그러하니라","reference":"고린도전서 3:17","category":"$undefined"},{"id":"28429","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":18,"text":"아무도 자기를 속이지 말라 너희 중에 누구든지 이 세상에서 지혜 있는 줄로 생각하거든 미련한 자가 되어라 그리하여야 지혜로운 자가 되리라","reference":"고린도전서 3:18","category":"$undefined"},{"id":"28430","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":19,"text":"이 세상 지혜는 하나님께 미련한 것이니 기록된 바 지혜 있는 자들로 하여금 자기 궤휼에 빠지게 하시는 이라 하였고","reference":"고린도전서 3:19","category":"$undefined"},{"id":"28431","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":20,"text":"또 주께서 지혜 있는 자들의 생각을 헛 것으로 아신다 하셨느니라","reference":"고린도전서 3:20","category":"$undefined"},{"id":"28432","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":21,"text":"그런즉 누구든지 사람을 자랑하지 말라 만물이 다 너희 것임이라","reference":"고린도전서 3:21","category":"$undefined"},{"id":"28433","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":22,"text":"바울이나 아볼로나 게바나 세계나 생명이나 사망이나 지금 것이나 장래 것이나 다 너희의 것이요","reference":"고린도전서 3:22","category":"$undefined"},{"id":"28434","book":"고린도전서","book_name":"고린도전서","chapter":3,"verse":23,"text":"너희는 그리스도의 것이요 그리스도는 하나님의 것이니라","reference":"고린도전서 3:23","category":"$undefined"}],"bookSlug":"1corinthians"}]
