2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":4,"verses":[{"id":"28435","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":1,"text":"사람이 마땅히 우리를 그리스도의 일군이요 하나님의 비밀을 맡은 자로 여길지어다!","reference":"고린도전서 4:1","category":"$undefined"},{"id":"28436","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":2,"text":"그리고 맡은 자들에게 구할 것은 충성이니라","reference":"고린도전서 4:2","category":"$undefined"},{"id":"28437","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":3,"text":"너희에게나 다른 사람에게나 판단 받는 것이 내게는 매우 작은 일이라 나도 나를 판단치 아니하노니","reference":"고린도전서 4:3","category":"$undefined"},{"id":"28438","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":4,"text":"내가 자책할 아무것도 깨닫지 못하나 그러나 이를 인하여 의롭다 함을 얻지 못하노라 다만 나를 판단하실 이는 주시니라","reference":"고린도전서 4:4","category":"$undefined"},{"id":"28439","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":5,"text":"그러므로 때가 이르기 전 곧 주께서 오시기까지 아무 것도 판단치 말라 그가 어두움에 감추인 것들을 드러내고 마음의 뜻을 나타내시리니 그때에 각 사람에게 하나님께로부터 칭찬이 있으리라","reference":"고린도전서 4:5","category":"$undefined"},{"id":"28440","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":6,"text":"형제들아 내가 너희를 위하여 이 일에 나와 아볼로를 가지고 본을 보였으니 이는 너희로 하여금 기록한 말씀 밖에 넘어가지 말라 한 것을 우리에게서 배워 서로 대적하여 교만한 마음을 먹지 말게 하려 함이라","reference":"고린도전서 4:6","category":"$undefined"},{"id":"28441","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":7,"text":"누가 너를 구별하였느뇨 네게 있는 것 중에 받지 아니한 것이 무엇이뇨 네가 받았은즉 어찌하여 받지 아니한 것같이 자랑하느뇨","reference":"고린도전서 4:7","category":"$undefined"},{"id":"28442","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":8,"text":"너희가 이미 배부르며 이미 부요하며 우리 없이 왕 노릇 하였도다 우리가 너희와 함께 왕 노릇 하기 위하여 참으로 너희의 왕 노릇 하기를 원하노라","reference":"고린도전서 4:8","category":"$undefined"},{"id":"28443","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":9,"text":"내가 생각건대 하나님이 사도인 우리를 죽이기로 작정한 자같이 미말에 두셨으매 우리는 세계 곧 천사와 사람에게 구경거리가 되었노라","reference":"고린도전서 4:9","category":"$undefined"},{"id":"28444","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":10,"text":"우리는 그리스도의 연고로 미련하되 너희는 그리스도 안에서 지혜롭고 우리는 약하되 너희는 강하고 너희는 존귀하되 우리는 비천하여","reference":"고린도전서 4:10","category":"$undefined"},{"id":"28445","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":11,"text":"바로 이 시간까지 우리가 주리고 목마르며 헐벗고 매맞으며 정처가 없고","reference":"고린도전서 4:11","category":"$undefined"},{"id":"28446","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":12,"text":"또 수고하여 친히 손으로 일을 하며 후욕을 당한즉 축복하고 핍박을 당한즉 참고","reference":"고린도전서 4:12","category":"$undefined"},{"id":"28447","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":13,"text":"비방을 당한즉 권면하니 우리가 지금까지 세상의 더러운 것과 만물의 찌끼같이 되었도다","reference":"고린도전서 4:13","category":"$undefined"},{"id":"28448","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":14,"text":"내가 너희를 부끄럽게 하려고 이것을 쓰는 것이 아니라 오직 너희를 내 사랑하는 자녀같이 권하려 하는 것이라","reference":"고린도전서 4:14","category":"$undefined"},{"id":"28449","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":15,"text":"그리스도 안에서 일만 스승이 있으되 아비는 많지 아니하니 그리스도 예수 안에서 복음으로써 내가 너희를 낳았음이라","reference":"고린도전서 4:15","category":"$undefined"},{"id":"28450","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":16,"text":"그러므로 내가 너희에게 권하노니 너희는 나를 본받는 자 되라","reference":"고린도전서 4:16","category":"$undefined"},{"id":"28451","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":17,"text":"이를 인하여 내가 주 안에서 내 사랑하고 신실한 아들 디모데를 너희에게 보내었노니 저가 너희로 하여금 그리스도 예수 안에서 나의 행사 곧 내가 각처 교회에서 가르치는 것을 생각나게 하리라","reference":"고린도전서 4:17","category":"$undefined"},{"id":"28452","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":18,"text":"어떤 이들은 내가 너희에게 나아가지 아니할 것같이 스스로 교만하여졌으나","reference":"고린도전서 4:18","category":"$undefined"},{"id":"28453","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":19,"text":"그러나 주께서 허락하시면 내가 너희에게 속히 나아가서 교만한 자의 말을 알아 볼 것이 아니라 오직 그 능력을 알아 보겠노니","reference":"고린도전서 4:19","category":"$undefined"},{"id":"28454","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":20,"text":"하나님의 나라는 말에 있지 아니하고 오직 능력에 있음이라","reference":"고린도전서 4:20","category":"$undefined"},{"id":"28455","book":"고린도전서","book_name":"고린도전서","chapter":4,"verse":21,"text":"너희가 무엇을 원하느냐 내가 매를 가지고 너희에게 나아가랴 사랑과 온유한 마음으로 나아가랴","reference":"고린도전서 4:21","category":"$undefined"}],"bookSlug":"1corinthians"}]
