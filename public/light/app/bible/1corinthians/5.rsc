2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":5,"verses":[{"id":"28456","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":1,"text":"너희 중에 심지어 음행이 있다 함을 들으니 이런 음행은 이방인 중에라도 없는 것이라 누가 그 아비의 아내를 취하였다 하는도다","reference":"고린도전서 5:1","category":"$undefined"},{"id":"28457","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":2,"text":"그리하고도 너희가 오히려 교만하여져서 어찌하여 통한히 여기지 아니하고 그 일 행한 자를 너희 중에서 물리치지 아니하였느냐","reference":"고린도전서 5:2","category":"$undefined"},{"id":"28458","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":3,"text":"내가 실로 몸으로는 떠나 있으나 영으로는 함께 있어서 거기 있는 것같이 이 일 행한 자를 이미 판단하였노라","reference":"고린도전서 5:3","category":"$undefined"},{"id":"28459","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":4,"text":"주 예수의 이름으로 너희가 내 영과 함께 모여서 우리 주 예수의 능력으로","reference":"고린도전서 5:4","category":"$undefined"},{"id":"28460","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":5,"text":"이런 자를 사단에게 내어주었으니 이는 육신은 멸하고 영은 주 예수의 날에 구원 얻게 하려 함이라","reference":"고린도전서 5:5","category":"$undefined"},{"id":"28461","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":6,"text":"너희의 자랑하는 것이 옳지 아니하도다 적은 누룩이 온 덩어리에 퍼지는 것을 알지 못하느냐","reference":"고린도전서 5:6","category":"$undefined"},{"id":"28462","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":7,"text":"너희는 누룩 없는 자인데 새 덩어리가 되기 위하여 묵은 누룩을 내어 버리라 우리의 유월절 양 곧 그리스도께서 희생이 되셨느니라","reference":"고린도전서 5:7","category":"$undefined"},{"id":"28463","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":8,"text":"이러므로 우리가 명절을 지키되 묵은 누룩도 말고 괴악하고 악독한 누룩도 말고 오직 순전함과 진실함의 누룩 없는 떡으로 하자","reference":"고린도전서 5:8","category":"$undefined"},{"id":"28464","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":9,"text":"내가 너희에게 쓴 것에 음행하는 자들을 사귀지 말라 하였거니와","reference":"고린도전서 5:9","category":"$undefined"},{"id":"28465","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":10,"text":"이 말은 이 세상의 음행하는 자들이나 탐하는 자들과 토색하는 자들이나 우상 숭배하는 자들을 도무지 사귀지 말라 하는 것이 아니니 만일 그리하려면 세상 밖으로 나가야 할 것이라","reference":"고린도전서 5:10","category":"$undefined"},{"id":"28466","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":11,"text":"이제 내가 너희에게 쓴 것은 만일 어떤 형제라 일컫는 자가 음행하거나 탐람하거나 우상 숭배를 하거나 후욕하거나 술 취하거나 토색하거든 사귀지도 말고 그런 자와는 함께 먹지도 말라 함이라","reference":"고린도전서 5:11","category":"$undefined"},{"id":"28467","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":12,"text":"외인들을 판단하는데 내게 무슨 상관이 있으리요마는 교중 사람들이야 너희가 판단치 아니하랴","reference":"고린도전서 5:12","category":"$undefined"},{"id":"28468","book":"고린도전서","book_name":"고린도전서","chapter":5,"verse":13,"text":"외인들은 하나님이 판단 하시려니와 이 악한 사람은 너희 중에서 내어 쫓으라","reference":"고린도전서 5:13","category":"$undefined"}],"bookSlug":"1corinthians"}]
