2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":6,"verses":[{"id":"28469","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":1,"text":"너희 중에 누가 다른 이로 더불어 일이 있는데 구태여 불의한 자들 앞에서 송사하고 성도 앞에서 하지 아니하느냐","reference":"고린도전서 6:1","category":"$undefined"},{"id":"28470","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":2,"text":"성도가 세상을 판단할 것을 너희가 알지 못하느냐 세상도 너희에게 판단을 받겠거든 지극히 작은 일 판단하기를 감당치 못하겠느냐","reference":"고린도전서 6:2","category":"$undefined"},{"id":"28471","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":3,"text":"우리가 천사를 판단할 것을 너희가 알지 못하느냐 그러하거든 하물며 세상 일이랴","reference":"고린도전서 6:3","category":"$undefined"},{"id":"28472","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":4,"text":"그런즉 너희가 세상 사건이 있을 때에 교회에서 경히 여김을 받는 자들을 세우느냐","reference":"고린도전서 6:4","category":"$undefined"},{"id":"28473","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":5,"text":"내가 너희를 부끄럽게 하려 하여 이 말을 하노니 너희 가운데 그 형제간 일을 판단할 만한 지혜있는 자가 이같이 하나도 없느냐","reference":"고린도전서 6:5","category":"$undefined"},{"id":"28474","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":6,"text":"형제가 형제로 더불어 송사할 뿐더러 믿지 아니하는 자들 앞에서 하느냐","reference":"고린도전서 6:6","category":"$undefined"},{"id":"28475","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":7,"text":"너희가 피차 송사 함으로 너희 가운데 이미 완연한 허물이 있나니 차라리 불의를 당하는 것이 낫지 아니하며 차라리 속는 것이 낫지 아니하냐","reference":"고린도전서 6:7","category":"$undefined"},{"id":"28476","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":8,"text":"너희는 불의를 행하고 속이는구나 저는 너희 형제로다","reference":"고린도전서 6:8","category":"$undefined"},{"id":"28477","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":9,"text":"불의한 자가 하나님의 나라를 유업으로 받지 못할 줄을 알지 못하느냐 미혹을 받지 말라 음란하는 자나 우상 숭배하는 자나 간음 하는 자나 탐색하는 자나 남색하는 자나","reference":"고린도전서 6:9","category":"$undefined"},{"id":"28478","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":10,"text":"도적이나 탐람하는 자나 술취하는 자나 후욕하는 자나 토색하는 자들은 하나님의 나라를 유업으로 받지 못하리라","reference":"고린도전서 6:10","category":"$undefined"},{"id":"28479","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":11,"text":"너희 중에 이와 같은 자들이 있더니 주 예수 그리스도의 이름과 우리 하나님의 성령 안에서 씻음과 거룩함과 의롭다 하심을 얻었느니라","reference":"고린도전서 6:11","category":"$undefined"},{"id":"28480","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":12,"text":"모든 것이 내게 가하나 다 유익한 것이 아니요 모든 것이 내게 가하나 내가 아무에게든지 제재를 받지 아니하리라","reference":"고린도전서 6:12","category":"$undefined"},{"id":"28481","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":13,"text":"식물은 배를 위하고 배는 식물을 위하나 하나님이 이것 저것 다 폐하시리라 몸은 음란을 위하지 않고 오직 주를 위하며 주는 몸을 위하시느니라","reference":"고린도전서 6:13","category":"$undefined"},{"id":"28482","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":14,"text":"하나님이 주를 다시 살리셨고 또한 그의 권능으로 우리를 다시 살리시리라","reference":"고린도전서 6:14","category":"$undefined"},{"id":"28483","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":15,"text":"너희 몸이 그리스도의 지체인 줄을 알지 못하느냐 내가 그리스도의 지체를 가지고 창기의 지체를 만들겠느냐 결코 그럴 수 없느니라","reference":"고린도전서 6:15","category":"$undefined"},{"id":"28484","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":16,"text":"창기와 합하는 자는 저와 한 몸인 줄을 알지 못하느냐 일렀으되 둘이 한 육체가 된다 하셨나니","reference":"고린도전서 6:16","category":"$undefined"},{"id":"28485","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":17,"text":"주와 합하는 자는 한 영이니라","reference":"고린도전서 6:17","category":"$undefined"},{"id":"28486","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":18,"text":"음행을 피하라 사람이 범하는 죄마다 몸 밖에 있거니와 음행하는 자는 자기 몸에게 죄를 범하느니라","reference":"고린도전서 6:18","category":"$undefined"},{"id":"28487","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":19,"text":"너희 몸은 너희가 하나님께로부터 받은 바 너희 가운데 계신 성령의 전인 줄을 알지 못하느냐 너희는 너희의 것이 아니라","reference":"고린도전서 6:19","category":"$undefined"},{"id":"28488","book":"고린도전서","book_name":"고린도전서","chapter":6,"verse":20,"text":"값으로 산 것이 되었으니 그런즉 너희 몸으로 하나님께 영광을 돌리라","reference":"고린도전서 6:20","category":"$undefined"}],"bookSlug":"1corinthians"}]
