2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":7,"verses":[{"id":"28489","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":1,"text":"너희의 쓴 말에 대하여는 남자가 여자를 가까이 아니함이 좋으나","reference":"고린도전서 7:1","category":"$undefined"},{"id":"28490","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":2,"text":"음행의 연고로 남자마다 자기 아내를 두고 여자마다 자기 남편을 두라","reference":"고린도전서 7:2","category":"$undefined"},{"id":"28491","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":3,"text":"남편은 그 아내에게 대한 의무를 다하고 아내도 그 남편에게 그렇게 할지라","reference":"고린도전서 7:3","category":"$undefined"},{"id":"28492","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":4,"text":"아내가 자기 몸을 주장하지 못하고 오직 그 남편이 하며 남편도 이와 같이 자기 몸을 주장하지 못하고 오직 그 아내가 하나니","reference":"고린도전서 7:4","category":"$undefined"},{"id":"28493","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":5,"text":"서로 분방하지 말라 다만 기도할 틈을 얻기 위하여 합의상 얼마 동안은 하되 다시 합하라 이는 너희의 절제 못함을 인하여 사단으로 너희를 시험하지 못하게 하려 함이라","reference":"고린도전서 7:5","category":"$undefined"},{"id":"28494","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":6,"text":"그러나 내가 이 말을 함은 권도요 명령은 아니라","reference":"고린도전서 7:6","category":"$undefined"},{"id":"28495","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":7,"text":"나는 모든 사람이 나와 같기를 원하노라 그러나 각각 하나님께 받은 자기의 은사가 있으니 하나는 이러하고 하나는 저러하니라","reference":"고린도전서 7:7","category":"$undefined"},{"id":"28496","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":8,"text":"내가 혼인하지 아니한 자들과 및 과부들에게 이르노니 나와 같이 그냥 지내는 것이 좋으니라","reference":"고린도전서 7:8","category":"$undefined"},{"id":"28497","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":9,"text":"만일 절제할 수 없거든 혼인하라 정욕이 불같이 타는 것보다 혼인하는 것이 나으니라","reference":"고린도전서 7:9","category":"$undefined"},{"id":"28498","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":10,"text":"혼인한 자들에게 내가 명하노니 (명하는 자는 내가 아니요 주시라) 여자는 남편에게서 갈리지 말고","reference":"고린도전서 7:10","category":"$undefined"},{"id":"28499","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":11,"text":"(만일 갈릴지라도 그냥 지내든지 다시 그 남편과 화합하든지 하라) 남편도 아내를 버리지 말라","reference":"고린도전서 7:11","category":"$undefined"},{"id":"28500","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":12,"text":"그 남은 사람들에게 내가 말하노니(이는 주의 명령이 아니라)만일 어떤 형제에게 믿지 아니하는 아내가 있어 남편과 함께 살기를 좋아하거든 저를 버리지 말며","reference":"고린도전서 7:12","category":"$undefined"},{"id":"28501","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":13,"text":"어떤 여자에게 믿지 아니하는 남편이 있어 아내와 함께 살기를 좋아하거든 그 남편을 버리지 말라","reference":"고린도전서 7:13","category":"$undefined"},{"id":"28502","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":14,"text":"믿지 아니하는 남편이 아내로 인하여 거룩하게 되고 믿지 아니하는 아내가 남편으로 인하여 거룩하게 되나니 그렇지 아니하면 너희 자녀도 깨끗지 못하니라 그러나 이제 거룩하니라","reference":"고린도전서 7:14","category":"$undefined"},{"id":"28503","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":15,"text":"혹믿지 아니하는 자가 갈리거든 갈리게 하라 형제나 자매나 이런 일에 구속 받을 것이 없느니라 그러나 하나님은 화평 중에서 너희를 부르셨느니라","reference":"고린도전서 7:15","category":"$undefined"},{"id":"28504","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":16,"text":"아내된 자여 네가 남편을 구원할는지 어찌 알 수 있으며 남편된 자여 네가 네 아내를 구원할는지 어찌 알 수 있으리요","reference":"고린도전서 7:16","category":"$undefined"},{"id":"28505","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":17,"text":"오직 주께서 각 사람에게 나눠주신 대로 하나님이 각 사람을 부르신 그대로 행하라 내가 모든 교회에서 이와 같이 명하노라","reference":"고린도전서 7:17","category":"$undefined"},{"id":"28506","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":18,"text":"할례자로 부르심을 받은 자가 있느냐 무할례자가 되지 말며 무할례자로 부르심을 받은 자가 있느냐 할례를 받지 말라","reference":"고린도전서 7:18","category":"$undefined"},{"id":"28507","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":19,"text":"할례 받는 것도 아무 것도 아니요 할례 받지 아니하는 것도 아무것도 아니로되 오직 하나님의 계명을 지킬 따름이니라","reference":"고린도전서 7:19","category":"$undefined"},{"id":"28508","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":20,"text":"각 사람이 부르심을 받은 그 부르심 그대로 지내라","reference":"고린도전서 7:20","category":"$undefined"},{"id":"28509","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":21,"text":"네가 종으로 있을 때에 부르심을 받았느냐 염려하지 말라 그러나 자유할 수 있거든 차라리 사용하라","reference":"고린도전서 7:21","category":"$undefined"},{"id":"28510","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":22,"text":"주 안에서 부르심을 받은 자는 종이라도 주께 속한 자유자요 또 이와 같이 자유자로 있을 때에 부르심을 받은 자는 그리스도의 종이니라","reference":"고린도전서 7:22","category":"$undefined"},{"id":"28511","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":23,"text":"너희는 값으로 사신 것이니 사람들의 종이 되지 말라","reference":"고린도전서 7:23","category":"$undefined"},{"id":"28512","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":24,"text":"형제들아 각각 부르심을 받은 그대로 하나님과 함께 거하라","reference":"고린도전서 7:24","category":"$undefined"},{"id":"28513","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":25,"text":"처녀에 대하여는 내가 주께 받은 계명이 없으되 주의 자비하심을 받아서 충성된 자가 되어 의견을 고하노니","reference":"고린도전서 7:25","category":"$undefined"},{"id":"28514","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":26,"text":"내 생각에는 이것이 좋으니 곧 임박한 환난을 인하여 사람이 그냥 지내는 것이 좋으니라","reference":"고린도전서 7:26","category":"$undefined"},{"id":"28515","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":27,"text":"네가 아내에게 매였느냐 놓이기를 구하지 말며 아내에게서 놓였느냐 아내를 구하지 말라","reference":"고린도전서 7:27","category":"$undefined"},{"id":"28516","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":28,"text":"그러나 장가 가도 죄 짓는 것이 아니요 처녀가 시집 가도 죄 짓는 것이 아니로되 이런 이들은 육신에 고난이 있으리니 나는 너희를 아끼노라","reference":"고린도전서 7:28","category":"$undefined"},{"id":"28517","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":29,"text":"형제들아 내가 이 말을 하노니 때가 단축하여진고로 이 후부터 아내 있는 자들은 없는 자같이 하며","reference":"고린도전서 7:29","category":"$undefined"},{"id":"28518","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":30,"text":"우는 자들은 울지 않는 자같이 하며 기쁜 자들은 기쁘지 않은 자같이 하며 매매하는 자들은 없는 자같이 하며","reference":"고린도전서 7:30","category":"$undefined"},{"id":"28519","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":31,"text":"세상 물건을 쓰는 자들은 다 쓰지 못하는 자같이 하라 이 세상의 형적은 지나감이니라","reference":"고린도전서 7:31","category":"$undefined"},{"id":"28520","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":32,"text":"너희가 염려 없기를 원하노라 장가 가지 않은 자는 주의 일을 염려하여 어찌하여야 주를 기쁘시게 할꼬 하되","reference":"고린도전서 7:32","category":"$undefined"},{"id":"28521","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":33,"text":"장가 간 자는 세상 일을 염려하여 어찌하여야 아내를 기쁘게 할꼬 하여 마음이 나누이며","reference":"고린도전서 7:33","category":"$undefined"},{"id":"28522","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":34,"text":"시집 가지 않은 자와 처녀는 주의 일을 염려하여 몸과 영을 다 거룩하게 하려 하되 시집 간 자는 세상 일을 염려하여 어찌하여야 남편을 기쁘게 할꼬 하느니라","reference":"고린도전서 7:34","category":"$undefined"},{"id":"28523","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":35,"text":"내가 이것을 말함은 너희의 유익을 위함이요 너희에게 올무를 놓으려 함이 아니니 오직 너희로 하여금 이치에 합하게 하여 분요함이 없이 주를 섬기게 하려 함이라","reference":"고린도전서 7:35","category":"$undefined"},{"id":"28524","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":36,"text":"누가 자기의 처녀 딸에 대한 일이 이치에 합당치 못한 줄로 생각할 때에 혼기도 지나고 그같이 할 필요가 있거든 마음대로 하라 이것은 죄 짓는 것이 아니니 혼인하게 하라","reference":"고린도전서 7:36","category":"$undefined"},{"id":"28525","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":37,"text":"그러나 그 마음을 굳게 하고 또 부득이한 일도 없고 자기 뜻대로 할 권리가 있어서 그 처녀 딸을 머물러 두기로 마음에 작정하여도 잘 하는 것이니라","reference":"고린도전서 7:37","category":"$undefined"},{"id":"28526","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":38,"text":"그러므로 처녀 딸을 시집 보내는 자도 잘 하거니와 시집 보내지 아니하는 자가 더 잘 하는 것이니라","reference":"고린도전서 7:38","category":"$undefined"},{"id":"28527","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":39,"text":"아내가 그 남편이 살 동안에 매여 있다가 남편이 죽으면 자유하여 자기 뜻대로 시집 갈 것이나 주 안에서만 할 것이니라","reference":"고린도전서 7:39","category":"$undefined"},{"id":"28528","book":"고린도전서","book_name":"고린도전서","chapter":7,"verse":40,"text":"그러나 내 뜻에는 그냥 지내는 것이 더욱 복이 있으리로다 나도 또한 하나님의 영을 받은 줄로 생각하노라","reference":"고린도전서 7:40","category":"$undefined"}],"bookSlug":"1corinthians"}]
