2:["$","$L11",null,{"book":{"id":"1corinthians","name":"고린도전서","chapters":16,"testament":"new"},"chapter":9,"verses":[{"id":"28542","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":1,"text":"내가 자유자가 아니냐 사도가 아니냐 예수 우리 주를 보지 못하였느냐 주 안에서 행한 나의 일이 너희가 아니냐","reference":"고린도전서 9:1","category":"$undefined"},{"id":"28543","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":2,"text":"다른 사람들에게는 내가 사도가 아닐지라도 너희에게는 사도니 나의 사도 됨을 주 안에서 인친 것이 너희라","reference":"고린도전서 9:2","category":"$undefined"},{"id":"28544","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":3,"text":"나를 힐문하는 자들에게 발명할 것이 이것이니","reference":"고린도전서 9:3","category":"$undefined"},{"id":"28545","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":4,"text":"우리가 먹고 마시는 권이 없겠느냐","reference":"고린도전서 9:4","category":"$undefined"},{"id":"28546","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":5,"text":"우리가 다른 사도들과 주의 형제들과 게바와 같이 자매 된 아내를 데리고 다닐 권이 없겠느냐","reference":"고린도전서 9:5","category":"$undefined"},{"id":"28547","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":6,"text":"어찌 나와 바나바만 일하지 아니할 권(權)이 없겠느냐","reference":"고린도전서 9:6","category":"$undefined"},{"id":"28548","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":7,"text":"누가 자비량하고 병정을 다니겠느냐 누가 포도를 심고 그 실과를 먹지 않겠느냐 누가 양떼를 기르고 그 양떼의 젖을 먹지 않겠느냐","reference":"고린도전서 9:7","category":"$undefined"},{"id":"28549","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":8,"text":"내가 사람의 예대로 이것을 말하느냐 율법도 이것을 말하지 아니하느냐","reference":"고린도전서 9:8","category":"$undefined"},{"id":"28550","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":9,"text":"모세 율법에 곡식을 밟아 떠는 소에게 망을 씌우지 말라 기록하였으니 하나님께서 어찌 소들을 위하여 염려하심이냐","reference":"고린도전서 9:9","category":"$undefined"},{"id":"28551","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":10,"text":"전혀 우리를 위하여 말씀하심이 아니냐 과연 우리를 위하여 기록된 것이니 밭 가는 자는 소망을 가지고 갈며 곡식 떠는 자는 함께 얻을 소망을 가지고 떠는 것이라","reference":"고린도전서 9:10","category":"$undefined"},{"id":"28552","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":11,"text":"우리가 너희에게 신령한 것을 뿌렸은즉 너희 육신(肉身)의 것을 거두기로 과하다 하겠느냐","reference":"고린도전서 9:11","category":"$undefined"},{"id":"28553","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":12,"text":"다른 이들도 너희에게 이런 권을 가졌거든 하물며 우리일까보냐 그러나 우리가 이 권을 쓰지 아니하고 범사에 참는 것은 그리스도의 복음에 아무 장애가 없게 하려 함이로다","reference":"고린도전서 9:12","category":"$undefined"},{"id":"28554","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":13,"text":"성전의 일을 하는 이들은 성전에서 나는 것을 먹으며 제단을 모시는 이들은 제단과 함께 나누는 것을 너희가 알지 못하느냐","reference":"고린도전서 9:13","category":"$undefined"},{"id":"28555","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":14,"text":"이와 같이 주께서도 복음 전하는 자들이 복음으로 말미암아 살리라 명하셨느니라","reference":"고린도전서 9:14","category":"$undefined"},{"id":"28556","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":15,"text":"그러나 내가 이것을 하나도 쓰지 아니하였고 또 이 말을 쓰는 것은 내게 이같이 하여 달라는 것이 아니라 내가 차라리 죽을지언정 누구든지 내 자랑하는 것을 헛된 데로 돌리지 못하게 하리라","reference":"고린도전서 9:15","category":"$undefined"},{"id":"28557","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":16,"text":"내가 복음을 전할지라도 자랑할 것이 없음은 내가 부득불 할 일임이라 만일 복음을 전하지 아니하면 내게 화가 있을 것임이로라","reference":"고린도전서 9:16","category":"$undefined"},{"id":"28558","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":17,"text":"내가 내 임의로 이것을 행하면 상을 얻으려니와 임의로 아니한다 할지라도 나는 직분을 맡았노라","reference":"고린도전서 9:17","category":"$undefined"},{"id":"28559","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":18,"text":"그런즉 내 상이 무엇이냐 내가 복음을 전할 때에 값 없이 전하고 복음으로 인하여 내게 있는 권을 다 쓰지 아니하는 이것이로라","reference":"고린도전서 9:18","category":"$undefined"},{"id":"28560","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":19,"text":"내가 모든 사람에게 자유하였으나 스스로 모든 사람에게 종이 된 것은 더 많은 사람을 얻고자 함이라","reference":"고린도전서 9:19","category":"$undefined"},{"id":"28561","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":20,"text":"유대인들에게는 내가 유대인과 같이 된 것은 유대인들을 얻고자 함이요 율법 아래 있는 자들에게는 내가 율법 아래 있지 아니하나 율법 아래 있는 자같이 된 것은 율법 아래 있는 자들을 얻고자 함이요","reference":"고린도전서 9:20","category":"$undefined"},{"id":"28562","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":21,"text":"율법 없는 자에게는 내가 하나님께는 율법 없는 자가 아니요 도리어 그리스도의 율법 아래 있는 자나 율법 없는 자와 같이 된 것은 율법 없는 자들을 얻고자 함이라","reference":"고린도전서 9:21","category":"$undefined"},{"id":"28563","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":22,"text":"약한 자들에게는 내가 약한 자와 같이 된 것은 약한 자들을 얻고자 함이요 여러 사람에게 내가 여러 모양이 된 것은 아무쪼록 몇몇 사람들을 구원코자 함이니","reference":"고린도전서 9:22","category":"$undefined"},{"id":"28564","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":23,"text":"내가 복음을 위하여 모든 것을 행함은 복음에 참예하고자 함이라","reference":"고린도전서 9:23","category":"$undefined"},{"id":"28565","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":24,"text":"운동장에서 달음질하는 자들이 다 달아날지라도 오직 상(賞) 얻는 자는 하나인 줄을 너희가 알지 못하느냐 너희도 얻도록 이와 같이 달음질하라","reference":"고린도전서 9:24","category":"$undefined"},{"id":"28566","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":25,"text":"이기기를 다투는 자마다 모든 일에 절제(節制)하나니 저희는 썩을 면류관을 얻고자 하되 우리는 썩지 아니할 것을 얻고자 하노라","reference":"고린도전서 9:25","category":"$undefined"},{"id":"28567","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":26,"text":"그러므로 내가 달음질하기를 향방 없는 것같이 아니하고 싸우기를 허공을 치는 것같이 아니하여","reference":"고린도전서 9:26","category":"$undefined"},{"id":"28568","book":"고린도전서","book_name":"고린도전서","chapter":9,"verse":27,"text":"내가 내 몸을 쳐 복종하게 함은 내가 남에게 전파한 후에 자기가 도리어 버림이 될까 두려워함이로라","reference":"고린도전서 9:27","category":"$undefined"}],"bookSlug":"1corinthians"}]
