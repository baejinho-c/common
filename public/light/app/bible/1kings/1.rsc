2:["$","$L11",null,{"book":{"id":"1kings","name":"열왕기상","chapters":22,"testament":"old"},"chapter":1,"verses":[{"id":"8719","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":1,"text":"다윗 왕이 나이 많아 늙으니 이불을 덮어도 따뜻하지 아니한지라","reference":"열왕기상 1:1","category":"$undefined"},{"id":"8720","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":2,"text":"그 신복들이 왕께 고하되 `우리 주 왕을 위하여 젊은 처녀 하나를 구하여 저로 왕을 모셔 봉양하고 왕의 품에 누워 우리 주 왕으로 따뜻하시게 하리이다' 하고","reference":"열왕기상 1:2","category":"$undefined"},{"id":"8721","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":3,"text":"이스라엘 사방 경내에 아리따운 동녀(童女)를 구하다가 수넴 여자 아비삭을 얻어 왕께 데려 왔으니","reference":"열왕기상 1:3","category":"$undefined"},{"id":"8722","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":4,"text":"이 동녀는 심히 아리따운 자라 저가 왕을 봉양하며 수종하였으나 왕이 더불어 동침하지 아니하였더라","reference":"열왕기상 1:4","category":"$undefined"},{"id":"8723","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":5,"text":"때에 학깃의 아들 아도니야가 스스로 높여서 이르기를 `내가 왕이 되리라' 하고 자기를 위하여 병거와 기병과 전배 오십인을 예비하니","reference":"열왕기상 1:5","category":"$undefined"},{"id":"8724","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":6,"text":"저는 압살롬의 다음에 난 자요 체용이 심히 준수한 자라 그 부친이 네가 어찌하여 그리하였느냐 하는 말로 한번도 저를 섭섭하게 한 일이 없었더라","reference":"열왕기상 1:6","category":"$undefined"},{"id":"8725","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":7,"text":"아도니야가 스루야의 아들 요압과 제사장 아비아달과 모의하니 저희가 좇아 도우나","reference":"열왕기상 1:7","category":"$undefined"},{"id":"8726","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":8,"text":"제사장 사독과 여호야다의 아들 브나야와 선지자 나단과 시므이와 레이와 다윗에게 속한 용사들은 아도니야와 같이 하지 아니하였더라","reference":"열왕기상 1:8","category":"$undefined"},{"id":"8727","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":9,"text":"아도니야가 에느로겔 근방 소헬렛 돌 곁에서 양과 소와 살찐 송아지를 잡고 왕자 곧 자기의 모든 동생과 왕의 신복 유다 모든 사람을 다 청하였으나","reference":"열왕기상 1:9","category":"$undefined"},{"id":"8728","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":10,"text":"선지자 나단과 브나야와 용사들과 자기 동생 솔로몬은 청하지 아니하였더라","reference":"열왕기상 1:10","category":"$undefined"},{"id":"8729","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":11,"text":"나단이 솔로몬의 모친 밧세바에게 고하여 가로되 `학깃의 아들 아도니야가 왕이 됨을 듣지 못하였나이까 ? 우리 주 다윗은 알지 못하시나이다","reference":"열왕기상 1:11","category":"$undefined"},{"id":"8730","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":12,"text":"이제 나로 당신의 생명과 당신의 아들 솔로몬의 생명 구원할 계교 베풀기를 허락하소서","reference":"열왕기상 1:12","category":"$undefined"},{"id":"8731","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":13,"text":"당신은 다윗 왕 앞에 들어가서 고하기를 내 주 왕이여 ! 전에 왕이 계집종에게 맹세하여 이르시기를 네 아들 솔로몬이 정녕 나를 이어 왕이 되어 내 위에 앉으리라 하지 아니하셨나이까 ? 그런데 아도니야가 무슨 연고로 왕이 되었나이까 하소서","reference":"열왕기상 1:13","category":"$undefined"},{"id":"8732","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":14,"text":"당신이 거기서 왕과 말씀할 때에 나도 이어 들어가서 당신의 말씀을 증거하리이다'","reference":"열왕기상 1:14","category":"$undefined"},{"id":"8733","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":15,"text":"밧세바가 몸을 굽혀 왕께 절하니 왕이 이르되 `어찜이냐 ?'","reference":"열왕기상 1:15","category":"$undefined"},{"id":"8734","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":16,"text":"저가 왕께 대답하되 `내 주여 ! 왕이 전에 왕의 하나님 여호와를 가리켜 계집종에게 맹세하시기를 네 아들 솔로몬이 정녕 나를 이어 왕이 되어 내 위에 앉으리라 하셨거늘","reference":"열왕기상 1:16","category":"$undefined"},{"id":"8735","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":17,"text":"이제 아도니야가 왕이 되었어도 내 주 왕은 알지 못하시나이다","reference":"열왕기상 1:17","category":"$undefined"},{"id":"8736","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":18,"text":"저가 수소와 살진 송아지와 양을 많이 잡고 왕의 모든 아들과 제사장 아비아달과 군대장관 요압을 청하였으나 왕의 종 솔로몬은 청치 아니하였나이다","reference":"열왕기상 1:18","category":"$undefined"},{"id":"8737","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":19,"text":"내 주 왕이여 ! 온 이스라엘이 왕에게 다 주목하고 누가 내 주 왕을 이어 그 위에 앉을 것을 반포하시기를 기다리나이다","reference":"열왕기상 1:19","category":"$undefined"},{"id":"8738","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":20,"text":"그렇지 아니하면 내 주 왕께서 그 열조와 함께 잘 때에 나와 내 아들 솔로몬은 죄인이 되리이다'","reference":"열왕기상 1:20","category":"$undefined"},{"id":"8739","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":21,"text":"밧세바가 왕과 말씀할 때에 선지자 나단이 들어온지라","reference":"열왕기상 1:21","category":"$undefined"},{"id":"8740","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":22,"text":"혹이 왕께 고하여 가로되 `선지자 나단이 여기 있나이다' 하니 저가 왕 앞에 들어와서 얼굴을 땅에 대어 왕께 절하고","reference":"열왕기상 1:22","category":"$undefined"},{"id":"8741","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":23,"text":"가로되 `내 주 왕께서 이르시기를 아도니야가 나를 이어 왕이 되어 내 위에 앉으리라 하셨나이까 ?","reference":"열왕기상 1:23","category":"$undefined"},{"id":"8742","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":24,"text":"저가 오늘 내려가서 수소와 살진 송아지와 양을 많이 잡고 왕의 모든 아들과 군대장관들과 제사장 아비아달을 청하였는데 저희가 아도니야 앞에서 먹고 마시며 아도니야왕 만세를 불렀나이다","reference":"열왕기상 1:24","category":"$undefined"},{"id":"8743","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":25,"text":"그러나 왕의 종 나와 제사장 사독과 여호야다의 아들 브나야와 왕의 종 솔로몬은 청치 아니하였사오니","reference":"열왕기상 1:25","category":"$undefined"},{"id":"8744","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":26,"text":"이것이 내 주 왕의 하신 일이니이까 ? 그런데 왕께서 내 주 왕을 이어 그 위에 앉을 자를 종에게 알게 하지 아니하셨나이다'","reference":"열왕기상 1:26","category":"$undefined"},{"id":"8745","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":27,"text":"다윗 왕이 명하여 가로되 `밧세바를 내 앞으로 부르라' 하매 저가 왕의 앞으로 들어와 그 앞에 서는지라","reference":"열왕기상 1:27","category":"$undefined"},{"id":"8746","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":28,"text":"왕이 가로되 `내 생명을 모든 환난에서 구원하신 여호와의 사심을 가리켜 맹세하노라","reference":"열왕기상 1:28","category":"$undefined"},{"id":"8747","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":29,"text":"내가 이전에 이스라엘 하나님 여호와를 가리켜 네게 맹세하여 이르기를 네 아들 솔로몬이 정녕 나를 이어 왕이 되고 나를 대신하여 내 위에 앉으리라 하였으니 내가 오늘날 그대로 행하리라`","reference":"열왕기상 1:29","category":"$undefined"},{"id":"8748","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":30,"text":"밧세바가 얼굴을 땅에 대어 절하며 `내 주 다윗 왕은 만세수를 하옵소서' 하니라","reference":"열왕기상 1:30","category":"$undefined"},{"id":"8749","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":31,"text":"다윗 왕이 가로되 `제사장 사독과 선지자 나단과 여호야다의 아들 브나야를 내 앞으로 부르라' 하니 저희가 왕 앞에 이른지라","reference":"열왕기상 1:31","category":"$undefined"},{"id":"8750","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":32,"text":"왕이 저희에게 이르되 `너희는 너희 주의 신복들을 데리고 내 아들 솔로몬을 나의 노새에 태우고 기혼으로 인도하여 내려가고","reference":"열왕기상 1:32","category":"$undefined"},{"id":"8751","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":33,"text":"거기서 제사장 사독과 선지자 나단은 저에게 기름을 부어 이스라엘 왕을 삼고 너희는 양각을 불며 솔로몬 왕 만세를 부르고","reference":"열왕기상 1:33","category":"$undefined"},{"id":"8752","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":34,"text":"저를 따라 올라오라 저가 와서 내 위에 앉아 나를 대신하여 왕이 되리라 내가 저를 세워 이스라엘과 유다의 주권자가 되게 하기로 작정하였느니라'","reference":"열왕기상 1:34","category":"$undefined"},{"id":"8753","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":35,"text":"여호야다의 아들 브나야가 왕께 대답하여 가로되 `아멘, 내 주 왕의 하나님 여호와께서도 이렇게 말씀하시기를 원하오며","reference":"열왕기상 1:35","category":"$undefined"},{"id":"8754","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":36,"text":"또 여호와께서 내 주 왕과 함께 계심같이 솔로몬과 함께 계셔서 그 위를 내 주 다윗 왕의 위보다 더 크게 하시기를 원하나이다'하니라","reference":"열왕기상 1:36","category":"$undefined"},{"id":"8755","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":37,"text":"제사장 사독과 선지자 나단과 여호야다의 아들 브나야와 그렛 사람과 블렛 사람이 내려가서 솔로몬을 다윗 왕의 노새에 태우고 인도하여 기혼으로 가서","reference":"열왕기상 1:37","category":"$undefined"},{"id":"8756","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":38,"text":"제사장 사독이 성막 가운데서 기름 뿔을 가져다가 솔로몬에게 기름을 부으니 이에 양각을 불고 모든 백성이 솔로몬 왕 만세를 부르니라","reference":"열왕기상 1:38","category":"$undefined"},{"id":"8757","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":39,"text":"모든 백성이 왕을 따라 올라와서 피리를 불며 크게 즐거워하므로 땅이 저희 소리로 인하여 갈라질 듯하니","reference":"열왕기상 1:39","category":"$undefined"},{"id":"8758","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":40,"text":"아도니야와 저와 함께 한 손들이 먹기를 마칠 때에 다 들은지라 요압이 양각 소리를 듣고 가로되 `성중에서 소리가 어찌하여 요란하뇨'","reference":"열왕기상 1:40","category":"$undefined"},{"id":"8759","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":41,"text":"말할 때에 제사장 아비아달의 아들 요나단이 오는지라 아도니야가 가로되 `들어오라 너는 용사라 아름다운 소식을 가져오는도다'","reference":"열왕기상 1:41","category":"$undefined"},{"id":"8760","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":42,"text":"요나단이 아도니야에게 대답하여 가로되 `과연 우리 주 다윗 왕이 솔로몬으로 왕을 삼으셨나이다","reference":"열왕기상 1:42","category":"$undefined"},{"id":"8761","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":43,"text":"왕께서 제사장 사독과 선지자 나단과 여호야다의 아들 브나야와 그렛 사람과 블렛 사람을 솔로몬과 함께 보내셨는데 저희 무리가 왕의 노새에 솔로몬을 태워다가","reference":"열왕기상 1:43","category":"$undefined"},{"id":"8762","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":44,"text":"제사장 사독과 선지자 나단이 기혼에서 기름을 부어 왕을 삼고 무리가 그곳에서 올라오며 즐거워하므로 성중이 진동하였나니 당신들에게 들린 소리가 이것이라'","reference":"열왕기상 1:44","category":"$undefined"},{"id":"8763","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":45,"text":"솔로몬이 나라 위에 앉았고","reference":"열왕기상 1:45","category":"$undefined"},{"id":"8764","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":46,"text":"또 왕의 신복들이 와서 우리 주 다윗 왕에게 축복하여 이르기를 왕의 하나님이 솔로몬의 이름을 왕의 이름보다 아름답게 하시고 그 위를 왕의 위보다 크게 하시기를 원하나이다 하매 왕이 침상에서 몸을 굽히고","reference":"열왕기상 1:46","category":"$undefined"},{"id":"8765","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":47,"text":"이르시기를 `이스라엘의 하나님 여호와를 찬송하리로다 ! 여호와께서 오늘날 내 위에 앉을 자를 주사 나로 목도하게 하셨도다 하셨나이다' 하니","reference":"열왕기상 1:47","category":"$undefined"},{"id":"8766","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":48,"text":"아도니야와 함께 한 손들이 다 놀라 일어나 각기 갈 길로 간지라","reference":"열왕기상 1:48","category":"$undefined"},{"id":"8767","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":49,"text":"아도니야도 솔로몬을 두려워하여 일어나 가서 제단 뿔을 잡으니","reference":"열왕기상 1:49","category":"$undefined"},{"id":"8768","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":50,"text":"혹이 솔로몬에게 고하여 가로되 `아도니야가 솔로몬 왕을 두려워하여 지금 제단 뿔을 잡고 말하기를 솔로몬 왕이 오늘날 칼로 자기 종을 죽이지 않겠다고 내게 맹세하기를 원한다 하나이다'","reference":"열왕기상 1:50","category":"$undefined"},{"id":"8769","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":51,"text":"솔로몬이 가로되 `저가 만일 선한 사람이 될진대 그 머리카락 하나라도 땅에 떨어지지 아니하려니와 저의 가운데 악한 것이 보이면 죽으리라' 하고","reference":"열왕기상 1:51","category":"$undefined"},{"id":"8770","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":52,"text":"사람을 보내어 저를 제단에서 이끌어 내리니 저가 와서 솔로몬 왕께 절하매 솔로몬이 이르기를 `네 집으로 가라' 하였더라","reference":"열왕기상 1:52","category":"$undefined"},{"id":"8771","book":"열왕기상","book_name":"열왕기상","chapter":1,"verse":53,"text":"","reference":"열왕기상 1:53","category":"$undefined"}],"bookSlug":"1kings"}]
