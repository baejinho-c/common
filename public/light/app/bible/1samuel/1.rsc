2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":1,"verses":[{"id":"7214","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":1,"text":"에브라임 산지 라마다임소빔에 에브라임 사람 엘가나라 하는 자가 있으니 그는 여로함의 아들이요 엘리후의 손자요 도후의 증손이요 숩의 현손이더라","reference":"사무엘상 1:1","category":"$undefined"},{"id":"7215","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":2,"text":"그에게 두 아내가 있으니 하나의 이름은 한나요 하나의 이름은 브닌나라 브닌나는 자식이 있고 한나는 무자하더라","reference":"사무엘상 1:2","category":"$undefined"},{"id":"7216","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":3,"text":"이 사람이 매년에 자기 성읍에서 나와서 실로에 올라가서 만군의 여호와께 경배하며 제사를 드렸는데 엘리의 두 아들 홉니와 비느하스가 여호와의 제사장으로 거기 있었더라","reference":"사무엘상 1:3","category":"$undefined"},{"id":"7217","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":4,"text":"엘가나가 제사를 드리는 날에는 제물의 분깃을 그 아내 브닌나와 그 모든 자녀에게 주고","reference":"사무엘상 1:4","category":"$undefined"},{"id":"7218","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":5,"text":"한나에게는 갑절을 주니 이는 그를 사랑함이라 그러나 여호와께서 그로 성태치 못하게 하시니","reference":"사무엘상 1:5","category":"$undefined"},{"id":"7219","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":6,"text":"여호와께서 그로 성태치 못하게 하시므로 그 대적 브닌나가 그를 심히 격동하여 번민케 하더라","reference":"사무엘상 1:6","category":"$undefined"},{"id":"7220","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":7,"text":"매년에 한나가 여호와의 집에 올라갈 때마다 남편이 그같이 하매 브닌나가 그를 격동시키므로 그가 울고 먹지 아니하니","reference":"사무엘상 1:7","category":"$undefined"},{"id":"7221","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":8,"text":"그 남편 엘가나가 그에게 이르되 `한나여 어찌하여 울며 어찌하여 먹지 아니하며 어찌하여 그대의 마음이 슬프뇨 내가 그대에게 열아들보다 낫지 아니하뇨 ?'","reference":"사무엘상 1:8","category":"$undefined"},{"id":"7222","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":9,"text":"그들이 실로에서 먹고 마신 후에 한나가 일어나니 때에 제사장 엘리는 여호와의 전 문설주 곁 그 의자에 앉았더라","reference":"사무엘상 1:9","category":"$undefined"},{"id":"7223","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":10,"text":"한나가 마음이 괴로와서 여호와께 기도하고 통곡하며","reference":"사무엘상 1:10","category":"$undefined"},{"id":"7224","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":11,"text":"서원하여 가로되 `만군의 여호와여 만일 주의 여종의 고통을 돌아보시고 나를 생각하시고 주의 여종을 잊지 아니하사 아들을 주시면 내가 그의 평생에 그를 여호와께 드리고 삭도를 그 머리에 대지 아니하겠나이다'","reference":"사무엘상 1:11","category":"$undefined"},{"id":"7225","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":12,"text":"그가 여호와 앞에 오래 기도하는 동안에 엘리가 그의 입을 주목한즉","reference":"사무엘상 1:12","category":"$undefined"},{"id":"7226","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":13,"text":"한나가 속으로 말하매 입술만 동하고 음성은 들리지 아니하므로 엘리는 그가 취한 줄로 생각한지라","reference":"사무엘상 1:13","category":"$undefined"},{"id":"7227","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":14,"text":"엘리가 그에게 이르되 `네가 언제까지 취하여 있겠느냐 ? 포도주를 끊으라'","reference":"사무엘상 1:14","category":"$undefined"},{"id":"7228","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":15,"text":"한나가 대답하여 가로되 `나의 주여, 그렇지 아니하니이다 나는 마음이 슬픈 여자라 포도주나 독주를 마신 것이 아니요 여호와 앞에 나의 심정을 통한 것뿐이오니","reference":"사무엘상 1:15","category":"$undefined"},{"id":"7229","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":16,"text":"당신의 여종을 악한 여자로 여기지 마옵소서 내가 지금까지 말한 것은 나의 원통함과 격동됨이 많음을 인함이니이다'","reference":"사무엘상 1:16","category":"$undefined"},{"id":"7230","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":17,"text":"엘리가 대답하여 가로되 `평안히 가라 이스라엘의 하나님이 너의 기도하여 구한 것을 허락하시기를 원하노라'","reference":"사무엘상 1:17","category":"$undefined"},{"id":"7231","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":18,"text":"엘리가 대답하여 가로되 `평안히 가라 이스라엘의 하나님이 너의 기도하여 구한 것을 허락하시기를 원하노라'","reference":"사무엘상 1:18","category":"$undefined"},{"id":"7232","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":19,"text":"가로되 `당신의 여종이 당신께 은혜 입기를 원하나이다` 하고 가서 먹고 얼굴에 다시는 수색이 없으니라","reference":"사무엘상 1:19","category":"$undefined"},{"id":"7233","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":20,"text":"그들이 아침에 일찌기 일어나 여호와 앞에 경배하고 돌아가서 라마의 자기 집에 이르니라 엘가나가 그 아내 한나와 동침하매 여호와께서 그를 생각하신지라","reference":"사무엘상 1:20","category":"$undefined"},{"id":"7234","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":21,"text":"한나가 잉태하고 때가 이르매 아들을 낳아 사무엘이라 이름하였으니 이는 `내가 여호와께 그를 구하였다' 함이더라","reference":"사무엘상 1:21","category":"$undefined"},{"id":"7235","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":22,"text":"그 사람 엘가나와 그 온 집이 여호와께 매년제와 그 서원제를 드리러 올라갈 때에","reference":"사무엘상 1:22","category":"$undefined"},{"id":"7236","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":23,"text":"오직 한나는 올라가지 아니하고 그 남편에게 이르되 아이를 젖 떼거든 내가 그를 데리고 가서 여호와 앞에 뵈게 하고 거기 영영히 있게 하리이다","reference":"사무엘상 1:23","category":"$undefined"},{"id":"7237","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":24,"text":"그 남편 엘가나가 그에게 이르되 `그대의 소견에 선한 대로 하여 그를 젖 떼기까지 기다리라 오직 여호와께서 그 말씀대로 이루시기를 원하노라' 이에 그 여자가 그 아들을 양육하며 그 젖 떼기까지 기다리다가","reference":"사무엘상 1:24","category":"$undefined"},{"id":"7238","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":25,"text":"젖을 뗀 후에 그를 데리고 올라갈새 수소 셋과 가루 한 에바와 포도주 한 가죽부대를 가지고 실로 여호와의 집에 나아갔는데 아이가 어리더라","reference":"사무엘상 1:25","category":"$undefined"},{"id":"7239","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":26,"text":"그들이 수소를 잡고 아이를 데리고 엘리에게 가서","reference":"사무엘상 1:26","category":"$undefined"},{"id":"7240","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":27,"text":"한나가 가로되 `나의 주여 ! 당신의 사심으로 맹세하나이다 나는 여기서 나의 주 당신 곁에 서서 여호와께 기도하던 여자라","reference":"사무엘상 1:27","category":"$undefined"},{"id":"7241","book":"사무엘상","book_name":"사무엘상","chapter":1,"verse":28,"text":"이 아이를 위하여 내가 기도하였더니 여호와께서 나의 구하여 기도한 바를 허락하신지라 [ (I Samuel 1:29) 그러므로 나도 그를 여호와께 드리되 그의 평생을 여호와께 드리나이다' 하고 그 아이는 거기서 여호와께 경배하니라 ]","reference":"사무엘상 1:28","category":"$undefined"}],"bookSlug":"1samuel"}]
