2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":10,"verses":[{"id":"7420","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":1,"text":"이에 사무엘이 기름병을 취하여 사울의 머리에 붓고 입맞추어 가로되 `여호와께서 네게 기름을 부으사 그 기업의 지도자를 삼지 아니하셨느냐 ?","reference":"사무엘상 10:1","category":"$undefined"},{"id":"7421","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":2,"text":"네가 오늘 나를 떠나가다가 베냐민 경계 셀사에 있는 라헬의 묘실 곁에서 두 사람을 만나리니 그들이 네게 이르기를 네가 찾으러 갔던 암나귀들을 찾은지라 네 아비가 암나귀들의 염려는 놓았으나 너희를 인하여 걱정하여 가로되 내 아들을 위하여 어찌하리요 하더라 할 것이요","reference":"사무엘상 10:2","category":"$undefined"},{"id":"7422","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":3,"text":"네가 거기서 더 나아가서 다볼 상수리나무에 이르면 거기서 하나님께 뵈려고 벧엘로 올라가는 세 사람이 너와 만나리니 하나는 염소 새끼 셋을 이끌었고 하나는 떡 세덩이를 가졌고 하나는 포도주 한 가죽부대를 가진 자라","reference":"사무엘상 10:3","category":"$undefined"},{"id":"7423","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":4,"text":"그들이 네게 문안하고 떡 두 덩이를 주겠고 너는 그 손에서 받으리라","reference":"사무엘상 10:4","category":"$undefined"},{"id":"7424","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":5,"text":"그 후에 네가 하나님의 산에 이르리니 그곳에는 블레셋 사람의 영문이 있느니라 네가 그리로 가서 그 성읍으로 들어갈 때에 선지자의 무리가 산당에서부터 비파와 소고와 저와 수금을 앞세우고 예언하며 내려오는 것을 만날 것이요","reference":"사무엘상 10:5","category":"$undefined"},{"id":"7425","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":6,"text":"네게는 여호와의 신이 크게 임하리니 너도 그들과 함께 예언을 하고 변하여 새 사람이 되리라","reference":"사무엘상 10:6","category":"$undefined"},{"id":"7426","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":7,"text":"이 징조가 네게 임하거든 너는 기회를 따라 행하라 ! 하나님이 너와 함께 하시느니라 !","reference":"사무엘상 10:7","category":"$undefined"},{"id":"7427","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":8,"text":"너는 나보다 앞서 길갈로 내려가라 내가 네게로 내려가서 번제와 화목제를 드리리니 내가 네게 가서 너의 행할 것을 가르칠 때까지 칠일을 기다리라'","reference":"사무엘상 10:8","category":"$undefined"},{"id":"7428","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":9,"text":"그가 사무엘에게서 떠나려고 몸을 돌이킬 때에 하나님이 새 마음을 주셨고 그 날 그 징조도 다 응하니라","reference":"사무엘상 10:9","category":"$undefined"},{"id":"7429","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":10,"text":"그들이 산에 이를 때에 선지자의 무리가 그를 영접하고 하나님의 신이 사울에게 크게 임하므로 그가 그들 중에서 예언을 하니","reference":"사무엘상 10:10","category":"$undefined"},{"id":"7430","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":11,"text":"전에 사울을 알던 모든 사람이 사울의 선지자들과 함께 예언함을 보고 서로 이르되 `기스의 아들의 당한 일이 무엇이뇨 사울도 선지자들 중에 있느냐' 하고","reference":"사무엘상 10:11","category":"$undefined"},{"id":"7431","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":12,"text":"그곳의 어떤 사람은 말하여 이르되 `그들의 아비가 누구냐 ?' 한지라 그러므로 속담이 되어 가로되 `사울도 선지자들 중에 있느냐 ?' 하더라","reference":"사무엘상 10:12","category":"$undefined"},{"id":"7432","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":13,"text":"사울이 예언하기를 마치고 산당으로 가니라","reference":"사무엘상 10:13","category":"$undefined"},{"id":"7433","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":14,"text":"사울의 숙부가 사울과 그 사환에게 이르되 `너희가 어디로 갔더냐 ?' 사울이 가로되 `암나귀들을 찾다가 얻지 못하므로 사무엘에게 갔었나이다'","reference":"사무엘상 10:14","category":"$undefined"},{"id":"7434","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":15,"text":"사울의 숙부가 가로되 `청하노니 사무엘이 너희에게 이른 말을 내게 고하라'","reference":"사무엘상 10:15","category":"$undefined"},{"id":"7435","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":16,"text":"사울이 그 숙부에게 말하되 `그가 암나귀들을 찾았다고 우리에게 분명히 말하더이다' 하고 사무엘의 말하던 나라의 일은 고하지 아니하니라","reference":"사무엘상 10:16","category":"$undefined"},{"id":"7436","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":17,"text":"사무엘이 백성을 미스바로 불러 여호와 앞에 모으고","reference":"사무엘상 10:17","category":"$undefined"},{"id":"7437","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":18,"text":"이스라엘 자손에게 이르되 `이스라엘 하나님 여호와께서 이같이 말씀하시기를 내가 이스라엘을 애굽에서 인도하여 내고 너희를 애굽인의 손과 너희를 압제하는 모든 나라의 손에서 건져내었느니라 하셨거늘","reference":"사무엘상 10:18","category":"$undefined"},{"id":"7438","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":19,"text":"너희가 너희를 모든 재난과 고통 중에서 친히 구원하여 내신 너희 하나님을 오늘날 버리고 이르기를 우리 위에 왕을 세우라 하도다 그런즉 이제 너희 지파대로 천명씩 여호와 앞에 나아오라' 하고","reference":"사무엘상 10:19","category":"$undefined"},{"id":"7439","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":20,"text":"사무엘이 이에 이스라엘 모든 지파를 가까이 오게 하였더니 베냐민 지파가 뽑혔고","reference":"사무엘상 10:20","category":"$undefined"},{"id":"7440","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":21,"text":"베냐민 지파를 그 가족대로 가까이 오게 하였더니 마드리의 가족이 뽑혔고 그 중에서 기스의 아들 사울이 뽑혔으나 그를 찾아도 만나지 못한지라","reference":"사무엘상 10:21","category":"$undefined"},{"id":"7441","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":22,"text":"그러므로 그들이 또 여호와께 묻되 `그 사람이 여기 왔나이까 ?' 여호와께서 대답하시되 그가 행구 사이에 숨었느니라","reference":"사무엘상 10:22","category":"$undefined"},{"id":"7442","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":23,"text":"그들이 달려가서 거기서 데려오매 그가 백성 중에 서니 다른 사람보다 어깨 위나 더 크더라","reference":"사무엘상 10:23","category":"$undefined"},{"id":"7443","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":24,"text":"사무엘이 모든 백성에게 이르되 `너희는 여호와의 택하신 자를 보느냐 ? 모든 백성중에 짝할 이가 없느니라' 하니 모든 백성이 왕의 만세를 외쳐 부르니라","reference":"사무엘상 10:24","category":"$undefined"},{"id":"7444","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":25,"text":"사무엘이 나라의 제도를 백성에게 말하고 책에 기록하여 여호와앞에 두고 모든 백성을 각기 집으로 보내매","reference":"사무엘상 10:25","category":"$undefined"},{"id":"7445","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":26,"text":"사울도 기브아 자기 집으로 갈 때에 마음이 하나님께 감동된 유력한 자들은 그와 함께 갔어도","reference":"사무엘상 10:26","category":"$undefined"},{"id":"7446","book":"사무엘상","book_name":"사무엘상","chapter":10,"verse":27,"text":"어떤 비류는 가로되 `이 사람이 어떻게 우리를 구원하겠느냐 ?' 하고 멸시하며 예물을 드리지 아니하니라 그러나 그는 잠잠하였더라","reference":"사무엘상 10:27","category":"$undefined"}],"bookSlug":"1samuel"}]
