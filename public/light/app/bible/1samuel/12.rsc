2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":12,"verses":[{"id":"7462","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":1,"text":"사무엘이 온 이스라엘에게 이르되 `보라, 너희가 내게 한 말을 내가 다 듣고 너희 위에 왕을 세웠더니","reference":"사무엘상 12:1","category":"$undefined"},{"id":"7463","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":2,"text":"이제 왕이 너희 앞에 출입하느니라 보라, 나는 늙어 머리가 희었고 내 아들들도 너희와 함께 있느니라 내가 어려서부터 오늘날까지 너희 앞에 출입하였거니와","reference":"사무엘상 12:2","category":"$undefined"},{"id":"7464","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":3,"text":"내가 여기 있나니 여호와 앞과 그 기름 부음을 받은 자 앞에서 내게 대하여 증거하라 내가 뉘 소를 취하였느냐 ? 뉘 나귀를 취하였느냐 ? 누구를 속였느냐 ? 누구를 압제하였느냐 ? 내 눈을 흐리게 하는 뇌물을 뉘 손에서 취하였느냐 ? 그리하였으면 내가 그것을 너희에게 갚으리라'","reference":"사무엘상 12:3","category":"$undefined"},{"id":"7465","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":4,"text":"그들이 가로되 `당신이 우리를 속이지 아니하였고 압제하지 아니하였고 뉘 손에서 아무 것도 취한 것이 없나이다'","reference":"사무엘상 12:4","category":"$undefined"},{"id":"7466","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":5,"text":"사무엘이 백성에게 이르되 `너희가 내 손에서 아무 것도 찾아낸 것이 없음을 여호와께서 너희에게 대하여 증거하시며 그 기름 부음을 받은 자도 오늘날 증거하느니라' 그들이 가로되 `그가 증거하시나이다'","reference":"사무엘상 12:5","category":"$undefined"},{"id":"7467","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":6,"text":"사무엘이 백성에게 이르되 `모세와 아론을 세우시며 너희 열조를 애굽 땅에서 인도하여 내신 이는 여호와시니","reference":"사무엘상 12:6","category":"$undefined"},{"id":"7468","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":7,"text":"그런즉 가만히 섰으라 ! 여호와께서 너희와 너희 열조에게 행하신 모든 의로운 일에 대하여 내가 여호와 앞에서 너희와 담론하리라","reference":"사무엘상 12:7","category":"$undefined"},{"id":"7469","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":8,"text":"야곱이 애굽에 들어간 후 너희 열조가 여호와께 부르짖으매 여호와께서 모세와 아론을 보내사 그 두 사람으로 너희 열조를 애굽에서 인도하여 내어 이곳에 거하게 하셨으나","reference":"사무엘상 12:8","category":"$undefined"},{"id":"7470","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":9,"text":"그들이 그 하나님 여호와를 잊은지라 여호와께서 그들을 하솔 군장 시스라의 손과 블레셋 사람의 손과 모압 왕의 손에 붙이셨더니 그들이 치매","reference":"사무엘상 12:9","category":"$undefined"},{"id":"7471","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":10,"text":"백성이 여호와께 부르짖어 가로되 우리가 여호와를 버리고 바알들과 아스다롯을 섬기므로 범죄하였나이다 그러하오나 이제 우리를 원수들의 손에서 건져 내소서 그리하시면 우리가 주를 섬기겠나이다 하매","reference":"사무엘상 12:10","category":"$undefined"},{"id":"7472","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":11,"text":"여호와께서 여룹바알과 베단과 입다와 나 사무엘을 보내사 너희를 너희 사방 원수의 손에서 건져내사 너희로 안전히 거하게 하셨거늘","reference":"사무엘상 12:11","category":"$undefined"},{"id":"7473","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":12,"text":"너희가 암몬 자손의 왕 나하스의 너희를 치러 옴을 보고 너희 하나님 여호와께서는 너희의 왕이 되실지라도 너희가 내게 이르기를 아니라 우리를 다스릴 왕이 있어야 하겠다 하였도다","reference":"사무엘상 12:12","category":"$undefined"},{"id":"7474","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":13,"text":"이제 너희의 구한 왕 너희의 택한 왕을 보라 여호와께서 너희 위에 왕을 세우셨느니라","reference":"사무엘상 12:13","category":"$undefined"},{"id":"7475","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":14,"text":"너희가 만일 여호와를 경외하여 그를 섬기며 그 목소리를 듣고 여호와의 명령을 거역하지 아니하며 또 너희와 너희를 다스리는 왕이 너희 하나님 여호와를 좇으면 좋으니라마는","reference":"사무엘상 12:14","category":"$undefined"},{"id":"7476","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":15,"text":"너희가 만일 여호와의 목소리를 듣지 아니하고 여호와의 명령을 거역하면 여호와의 손이 너희의 열조를 치신 것 같이 너희를 치실 것이라","reference":"사무엘상 12:15","category":"$undefined"},{"id":"7477","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":16,"text":"너희는 이제 가만히 서서 여호와께서 너희 목전에 행하시는 이 큰 일을 보라,","reference":"사무엘상 12:16","category":"$undefined"},{"id":"7478","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":17,"text":"오늘은 밀 베는 때가 아니냐 ? 내가 여호와께 아뢰리니 여호와께서 우뢰와 비를 보내사 너희가 왕을 구한 일 곧 여호와의 목전에 범한 죄악이 큼을 너희로 밝히 알게 하시리라'","reference":"사무엘상 12:17","category":"$undefined"},{"id":"7479","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":18,"text":"이에 사무엘이 여호와께 아뢰매 여호와께서 그 날에 우뢰와 비를 보내시니 모든 백성이 여호와와 사무엘을 크게 두려워하니라","reference":"사무엘상 12:18","category":"$undefined"},{"id":"7480","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":19,"text":"모든 백성이 사무엘에게 이르되 `당신의 종들을 위하여 당신의 하나님 여호와께 기도하여 우리로 죽지 않게 하소서 ! 우리가 우리의 모든 죄에 왕을 구하는 악을 더하였나이다'","reference":"사무엘상 12:19","category":"$undefined"},{"id":"7481","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":20,"text":"사무엘이 백성에게 이르되 `두려워 말라 ! 너희가 과연 이 모든 악을 행하였으나 여호와를 좇는 데서 돌이키지 말고 오직 너희 마음을 다하여 여호와를 섬기라 !","reference":"사무엘상 12:20","category":"$undefined"},{"id":"7482","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":21,"text":"돌이켜 유익하게도 못하며 구원하지도 못하는 헛된 것을 좇지 말라 ! 그들은 헛되니라","reference":"사무엘상 12:21","category":"$undefined"},{"id":"7483","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":22,"text":"여호와께서는 너희로 자기 백성 삼으신 것을 기뻐하신 고로 그 크신 이름을 인하여 자기 백성을 버리지 아니하실 것이요","reference":"사무엘상 12:22","category":"$undefined"},{"id":"7484","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":23,"text":"나는 너희를 위하여 기도하기를 쉬는 죄를 여호와 앞에 결단코 범치 아니하고 선하고 의로운 도로 너희를 가르칠 것인즉","reference":"사무엘상 12:23","category":"$undefined"},{"id":"7485","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":24,"text":"너희는 여호와께서 너희를 위하여 행하신 그 큰 일을 생각하여 오직 그를 경외하며 너희의 마음을 다하여 진실히 섬기라 !","reference":"사무엘상 12:24","category":"$undefined"},{"id":"7486","book":"사무엘상","book_name":"사무엘상","chapter":12,"verse":25,"text":"만일 너희가 여전히 악을 행하면 너희와 너희 왕이 다 멸망하리라'","reference":"사무엘상 12:25","category":"$undefined"}],"bookSlug":"1samuel"}]
