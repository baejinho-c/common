2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":13,"verses":[{"id":"7487","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":1,"text":"사울이 왕이 될 때에 사십세라 그가 이스라엘을 다스린지 이년에","reference":"사무엘상 13:1","category":"$undefined"},{"id":"7488","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":2,"text":"이스라엘 사람 삼천을 택하여 그 중에서 이천은 자기와 함께 믹마스와 벧엘산에 있게 하고 일천은 요나단과 함께 베냐민 기브아에 있게 하고 남은 백성은 각기 장막으로 보내니라","reference":"사무엘상 13:2","category":"$undefined"},{"id":"7489","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":3,"text":"요나단이 게바에 있는 블레셋 사람의 수비대를 치매 블레셋 사람이 이를 들은지라 사울이 온 땅에 나팔을 불어 이르되 `히브리 사람들은 들으라' 하니","reference":"사무엘상 13:3","category":"$undefined"},{"id":"7490","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":4,"text":"온 이스라엘이 사울의 블레셋 사람의 수비대를 친 것과 이스라엘이 블레셋 사람의 가증히 여김이 되었다 함을 듣고 길갈로 모여 사울을 좇으니라","reference":"사무엘상 13:4","category":"$undefined"},{"id":"7491","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":5,"text":"블레셋 사람이 이스라엘과 싸우려 하여 모였는데 병거가 삼만이요 마병이 육천이요 백성은 해변의 모래 같이 많더라 그들이 올라와서 벧아웬 동편 믹마스에 진 치매","reference":"사무엘상 13:5","category":"$undefined"},{"id":"7492","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":6,"text":"이스라엘 사람들이 위급함을 보고 절박하여 굴과 수풀과 바위틈과 은밀한 곳과 웅덩이에 숨으며","reference":"사무엘상 13:6","category":"$undefined"},{"id":"7493","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":7,"text":"어떤 히브리 사람들은 요단을 건너 갓과 길르앗 땅으로 가되 사울은 아직 길갈에 있고 그를 좇은 모든 백성은 떨더라","reference":"사무엘상 13:7","category":"$undefined"},{"id":"7494","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":8,"text":"사울이 사무엘의 정한 기한대로 이레를 기다리되 사무엘이 길갈로 오지 아니하매 백성이 사울에게서 흩어지는지라","reference":"사무엘상 13:8","category":"$undefined"},{"id":"7495","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":9,"text":"사울이 가로되 `번제와 화목제물을 이리로 가져오라' 하여 번제를 드렸더니","reference":"사무엘상 13:9","category":"$undefined"},{"id":"7496","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":10,"text":"번제 드리기를 필하자 사무엘이 온지라 사울이 나가 맞으며 문안하매","reference":"사무엘상 13:10","category":"$undefined"},{"id":"7497","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":11,"text":"사무엘이 가로되 왕의 행한 것이 무엇이뇨 ? 사울이 가로되 백성은 나에게서 흩어지고 당신은 정한 날 안에 오지 아니하고 블레셋 사람은 믹마스에 모였음을 내가 보았으므로","reference":"사무엘상 13:11","category":"$undefined"},{"id":"7498","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":12,"text":"이에 내가 이르기를 블레셋 사람은 나를 치러 길갈로 내려오겠거늘 내가 여호와께 은혜를 간구치 못하였다 하고 부득이하여 번제를 드렸나이다","reference":"사무엘상 13:12","category":"$undefined"},{"id":"7499","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":13,"text":"사무엘이 사울에게 이르되 `왕이 망령되이 행하였도다 ! 왕이 왕의 하나님 여호와께서 왕에게 명하신 명령을 지키지 아니하였도다 그리하였더면 여호와께서 이스라엘 위에 왕의 나라를 영영히 세우셨을 것이어늘","reference":"사무엘상 13:13","category":"$undefined"},{"id":"7500","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":14,"text":"지금은 왕의 나라가 길지 못할 것이라 여호와께서 왕에게 명하신 바를 왕이 지키지 아니하였으므로 여호와께서 그 마음에 맞는 사람을 구하여 그 백성의 지도자를 삼으셨느니라' 하고","reference":"사무엘상 13:14","category":"$undefined"},{"id":"7501","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":15,"text":"사무엘이 일어나 길갈에서 떠나 베냐민 기브아로 올라가니라 사울이 자기와 함께 한 백성을 계수하니 육백명 가량이라","reference":"사무엘상 13:15","category":"$undefined"},{"id":"7502","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":16,"text":"사울과 그 아들 요나단과 그들과 함께한 백성은 베냐민 게바에 있고 블레셋 사람은 믹마스에 진쳤더니","reference":"사무엘상 13:16","category":"$undefined"},{"id":"7503","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":17,"text":"노략군들이 삼대로 블레셋 사람의 진에서 나와서 한 대는 오브라길로 말미암아 수알 땅에 이르렀고","reference":"사무엘상 13:17","category":"$undefined"},{"id":"7504","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":18,"text":"한 대는 벧호론 길로 향하였고 한 대는 광야를 향한 스보임 골짜기가 내려다 보이는 지경 길로 향하였더라","reference":"사무엘상 13:18","category":"$undefined"},{"id":"7505","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":19,"text":"때에 이스라엘 온 땅에 철공이 없어졌으니 이는 블레셋 사람이 말하기를 `히브리 사람이 칼이나 창을 만들까 두렵다' 하였음이라","reference":"사무엘상 13:19","category":"$undefined"},{"id":"7506","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":20,"text":"온 이스라엘 사람이 각기 보습이나 삽이나 도끼나 괭이를 벼리려면 블레셋 사람에게로 내려갔었는데","reference":"사무엘상 13:20","category":"$undefined"},{"id":"7507","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":21,"text":"곧 그들이 괭이나 삽이나 쇠스랑이나 도끼나 쇠채찍이 무딜 때에 그리하였으므로","reference":"사무엘상 13:21","category":"$undefined"},{"id":"7508","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":22,"text":"싸우는 날에 사울과 요나단과 함께한 백성의 손에는 칼이나 창이 없고 오직 사울과 그 아들 요나단에게만 있으니라","reference":"사무엘상 13:22","category":"$undefined"},{"id":"7509","book":"사무엘상","book_name":"사무엘상","chapter":13,"verse":23,"text":"블레셋 사람의 부대가 나와서 믹마스 어귀에 이르렀더라","reference":"사무엘상 13:23","category":"$undefined"}],"bookSlug":"1samuel"}]
