a.org\",\"@type\":\"Organization\",\"name\":\"빛\",\"url\":\"https://light.restyart.com\",\"logo\":\"https://light.restyart.com/logo-512.png\",\"description\":\"매일의 큐티와 기도를 나누는 기독교 커뮤니티\"}"}}],["$","$L7",null,{"id":"schema-website","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"빛\",\"alternateName\":\"빛 QT 나눔 플랫폼\",\"url\":\"https://light.restyart.com\",\"description\":\"매일의 큐티와 기도를 나누는 기독교 커뮤니티\",\"inLanguage\":\"ko-KR\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://light.restyart.com/bible/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}"}}],["$","$L7",null,{"id":"schema-faq","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"빛은 어떤 플랫폼인가요?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"빛은 매일 큐티, 기도 제목, 간증을 나누는 기독교 커뮤니티입니다. 성경 검색·교회 찾기·QT 작성을 지원합니다.\"}},{\"@type\":\"Question\",\"name\":\"회원가입 없이 이용할 수 있나요?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"익명 QT·기도 작성이 가능하며, 성경 검색·교회 찾기는 로그인 없이 이용할 수 있습니다.\"}}]}"}}]]}]]}]],null],[null,[],[]]],["$L10",null]]]]
