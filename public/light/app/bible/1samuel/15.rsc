2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":15,"verses":[{"id":"7562","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":1,"text":"사무엘이 사울에게 이르되 `여호와께서 나를 보내어 왕에게 기름을 부어 그 백성 이스라엘 위에 왕을 삼으셨은즉 이제 왕은 여호와의 말씀을 들으소서 !","reference":"사무엘상 15:1","category":"$undefined"},{"id":"7563","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":2,"text":"만군의 여호와께서 이같이 말씀하시기를 아말렉이 이스라엘에게 행한 일 곧 애굽에서 나올 때에 길에서 대적한 일을 내가 추억하노니","reference":"사무엘상 15:2","category":"$undefined"},{"id":"7564","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":3,"text":"지금 가서 아말렉을 쳐서 그들의 모든 소유를 남기지 말고 진멸하되 남녀와 소아와 젖먹는 아이와 우양과 약대와 나귀를 죽이라 하셨나이다'","reference":"사무엘상 15:3","category":"$undefined"},{"id":"7565","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":4,"text":"사울이 백성을 소집하고 그들을 들라임에서 계수하니 보병이 이십만이요 유다 사람이 일만이라","reference":"사무엘상 15:4","category":"$undefined"},{"id":"7566","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":5,"text":"사울이 아말렉성에 이르러 골짜기에 복병하니라","reference":"사무엘상 15:5","category":"$undefined"},{"id":"7567","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":6,"text":"사울이 겐 사람에게 이르되 `아말렉 사람 중에서 떠나 내려가라 그들과 함께 너희를 멸하게 될까 하노라 이스라엘 모든 자손이 애굽에서 올라올 때에 너희가 그들을 선대하였느니라' 이에 겐 사람이 아말렉 사람 중에서 떠나니라","reference":"사무엘상 15:6","category":"$undefined"},{"id":"7568","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":7,"text":"사울이 하윌라에서부터 애굽앞 술에 이르기까지 아말렉 사람을 치고","reference":"사무엘상 15:7","category":"$undefined"},{"id":"7569","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":8,"text":"아말렉 사람의 왕 아각을 사로잡고 칼날로 그 모든 백성을 진멸하였으되","reference":"사무엘상 15:8","category":"$undefined"},{"id":"7570","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":9,"text":"사울과 백성이 아각과 그 양과 소의 가장 좋은 것 또는 기름진 것과 어린 양과 모든 좋은 것을 남기고 진멸키를 즐겨 아니하고 가치 없고 낮은 것은 진멸하니라","reference":"사무엘상 15:9","category":"$undefined"},{"id":"7571","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":10,"text":"여호와의 말씀이 사무엘에게 임하니라 가라사대","reference":"사무엘상 15:10","category":"$undefined"},{"id":"7572","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":11,"text":"내가 사울을 세워 왕 삼은 것을 후회하노니 그가 돌이켜서 나를 좇지 아니하며 내 명령을 이루지 아니하였음이니라 하신지라 사무엘이 근심하여 온 밤을 여호와께 부르짖으니라","reference":"사무엘상 15:11","category":"$undefined"},{"id":"7573","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":12,"text":"사무엘이 사울을 만나려고 아침에 일찌기 일어났더니 혹이 사무엘에게 고하여 가로되 `사울이 갈멜에 이르러 자기를 위하여 기념비를 세우고 돌이켜 행하여 길갈로 내려 갔다' 하는지라","reference":"사무엘상 15:12","category":"$undefined"},{"id":"7574","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":13,"text":"사무엘이 사울에게 이른즉 사울이 그에게 이르되 `원컨대 당신은 여호와께 복을 받으소서 ! 내가 여호와의 명령을 행하였나이다'","reference":"사무엘상 15:13","category":"$undefined"},{"id":"7575","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":14,"text":"사무엘이 가로되 `그러면 내 귀에 들어오는 이 양의 소리와 내게 들리는 소의 소리는 어찜이니이까 ?'","reference":"사무엘상 15:14","category":"$undefined"},{"id":"7576","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":15,"text":"사울이 가로되 `그것은 무리가 아말렉 사람에게서 끌어 온 것인데 백성이 당신의 하나님 여호와께 제사하려 하여 양과 소의 가장 좋은 것을 남김이요 그 외의 것은 우리가 진멸하였나이다'","reference":"사무엘상 15:15","category":"$undefined"},{"id":"7577","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":16,"text":"사무엘이 사울에게 이르되 `가만히 계시옵소서 간 밤에 여호와께서 내게 이르신 것을 왕에게 말하리이다' 가로되 `말씀하소서'","reference":"사무엘상 15:16","category":"$undefined"},{"id":"7578","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":17,"text":"사무엘이 가로되 `왕이 스스로 작게 여길 그 때에 이스라엘 지파의 머리가 되지 아니하셨나이까 ? 여호와께서 왕에게 기름을 부어 이스라엘 왕을 삼으시고","reference":"사무엘상 15:17","category":"$undefined"},{"id":"7579","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":18,"text":"또 왕을 길로 보내시며 이르시기를 가서 죄인 아말렉 사람을 진멸하되 다 없어지기까지 치라 하셨거늘","reference":"사무엘상 15:18","category":"$undefined"},{"id":"7580","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":19,"text":"어찌하여 왕이 여호와의 목소리를 청종치 아니하고 탈취하기에만 급하여 여호와의 악하게 여기시는 것을 행하였나이까 ?'","reference":"사무엘상 15:19","category":"$undefined"},{"id":"7581","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":20,"text":"사울이 사무엘에게 이르되 `나는 실로 여호와의 목소리를 청종하여 여호와께서 보내신 길로 가서 아말렉 왕 아각을 끌어 왔고 아말렉 사람을 진멸하였으나","reference":"사무엘상 15:20","category":"$undefined"},{"id":"7582","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":21,"text":"다만 백성이 그 마땅히 멸할 것 중에서 가장 좋은 것으로 길갈에서 당신의 하나님 여호와께 제사하려고 양과 소를 취하였나이다'","reference":"사무엘상 15:21","category":"$undefined"},{"id":"7583","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":22,"text":"사무엘이 가로되 `여호와께서 번제와 다른 제사를 그 목소리 순종하는 것을 좋아하심 같이 좋아하시겠나이까 ? 순종이 제사보다 낫고 듣는 것이 수양의 기름보다 나으니","reference":"사무엘상 15:22","category":"$undefined"},{"id":"7584","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":23,"text":"이는 거역하는 것은 사술의 죄와 같고 완고한 것은 사신 우상에게 절하는 죄와 같음이라 왕이 여호와의 말씀을 버렸으므로 여호와께서도 왕을 버려 왕이 되지 못하게 하셨나이다'","reference":"사무엘상 15:23","category":"$undefined"},{"id":"7585","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":24,"text":"사울이 사무엘에게 이르되 `내가 범죄하였나이다 내가 여호와의 명령과 당신의 말씀을 어긴 것은 내가 백성을 두려워하여 그 말을 청종하였음이니이다","reference":"사무엘상 15:24","category":"$undefined"},{"id":"7586","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":25,"text":"청하오니 지금 내 죄를 사하고 나와 함께 돌아가서 나로 여호와께 경배하게 하소서'","reference":"사무엘상 15:25","category":"$undefined"},{"id":"7587","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":26,"text":"사무엘이 사울에게 이르되 `나는 왕과 함께 돌아가지 아니하리니 이는 왕이 여호와의 말씀을 버렸으므로 여호와께서 왕을 버려 이스라엘 왕이 되지 못하게 하셨음이니이다' 하고","reference":"사무엘상 15:26","category":"$undefined"},{"id":"7588","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":27,"text":"사무엘이 가려고 돌이킬 때에 사울이 그의 겉옷자락을 붙잡으매 찢어진지라","reference":"사무엘상 15:27","category":"$undefined"},{"id":"7589","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":28,"text":"사무엘이 그에게 이르되 `여호와께서 오늘 이스라엘 나라를 왕에게서 떼어서 왕보다 나은 왕의 이웃에게 주셨나이다","reference":"사무엘상 15:28","category":"$undefined"},{"id":"7590","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":29,"text":"이스라엘의 지존자는 거짓이나 변개함이 없으시니 그는 사람이 아니시므로 결코 변개치 않으심이니이다'","reference":"사무엘상 15:29","category":"$undefined"},{"id":"7591","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":30,"text":"사울이 가로되 `내가 범죄하였을지라도 청하옵나니 내 백성의 장로들의 앞과 이스라엘의 앞에서 나를 높이사 나와 함께 돌아가서 나로 당신의 하나님 여호와께 경배하게 하소서'","reference":"사무엘상 15:30","category":"$undefined"},{"id":"7592","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":31,"text":"이에 사무엘이 돌이켜 사울을 따라가매 사울이 여호와께 경배하니라","reference":"사무엘상 15:31","category":"$undefined"},{"id":"7593","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":32,"text":"사무엘이 가로되 `너희는 아말렉 사람의 왕 아각을 내게로 이끌어 오라' 하였더니 아각이 즐거이 오며 가로되 `진실로 사망의 괴로움이 지났도다' 하니라","reference":"사무엘상 15:32","category":"$undefined"},{"id":"7594","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":33,"text":"사무엘이 가로되 `네 칼이 여인들로 무자케 한 것같이 여인 중 네 어미가 무자하리라' 하고 그가 길갈에서 여호와 앞에서 아각을 찍어 쪼개니라","reference":"사무엘상 15:33","category":"$undefined"},{"id":"7595","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":34,"text":"이에 사무엘은 라마로 가고 사울은 사울 기브아 본집으로 올라가니라","reference":"사무엘상 15:34","category":"$undefined"},{"id":"7596","book":"사무엘상","book_name":"사무엘상","chapter":15,"verse":35,"text":"사무엘이 죽는 날까지 사울을 다시 가서 보지 아니하였으니 이는 그가 사울을 위하여 슬퍼함이었고 여호와께서는 사울로 이스라엘 왕 삼으신 것을 후회하셨더라","reference":"사무엘상 15:35","category":"$undefined"}],"bookSlug":"1samuel"}]
