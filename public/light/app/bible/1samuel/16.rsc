2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":16,"verses":[{"id":"7597","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":1,"text":"여호와께서 사무엘에게 이르시되 내가 이미 사울을 버려 이스라엘 왕이 되지 못하게 하였거늘 네가 그를 위하여 언제까지 슬퍼 하겠느냐 ? 너는 기름을 뿔에 채워 가지고 가라 내가 너를 베들레헴 사람 이새에게로 보내리니 이는 내가 그 아들 중에서 한 왕을 예선하였음이니라","reference":"사무엘상 16:1","category":"$undefined"},{"id":"7598","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":2,"text":"사무엘이 가로되 `내가 어찌 갈수 있으리이까 ? 사울이 들으면 나를 죽이리이다' 여호와께서 가라사대 너는 암송아지를 끌고 가서 말하기를 내가 여호와께 제사를 드리러 왔다 하고","reference":"사무엘상 16:2","category":"$undefined"},{"id":"7599","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":3,"text":"이새를 제사에 청하라 내가 너의 행할 일을 가르치리니 내가 네게 하는 자에게 나를 위하여 기름을 부을지니라","reference":"사무엘상 16:3","category":"$undefined"},{"id":"7600","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":4,"text":"사무엘이 여호와의 말씀대로 행하여 베들레헴에 이르매 성읍 장로들이 떨며 그를 영접하여 가로되 `평강을 위하여 오시나이까 ?'","reference":"사무엘상 16:4","category":"$undefined"},{"id":"7601","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":5,"text":"가로되 `평강을 위함이니라 내가 여호와께 제사하러 왔으니 스스로 성결케 하고 와서 나와 함께 제사하자' 하고 이새와 그 아들들을 성결케 하고 제사에 청하니라","reference":"사무엘상 16:5","category":"$undefined"},{"id":"7602","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":6,"text":"그들이 오매 사무엘이 엘리압을 보고 마음에 이르기를 `여호와의 기름 부으실 자가 과연 그 앞에 있도다' 하였더니","reference":"사무엘상 16:6","category":"$undefined"},{"id":"7603","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":7,"text":"여호와께서 사무엘에게 이르시되 그 용모와 신장을 보지 말라 내가 이미 그를 버렸노라 나의 보는 것은 사람과 같지 아니하니 사람은 외모를 보거니와 나 여호와는 중심을 보느니라 !","reference":"사무엘상 16:7","category":"$undefined"},{"id":"7604","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":8,"text":"이새가 아비나답을 불러 사무엘의 앞을 지나게 하매 사무엘이 가로되 `이도 여호와께서 택하지 아니하셨느니라'","reference":"사무엘상 16:8","category":"$undefined"},{"id":"7605","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":9,"text":"이새가 삼마로 지나게 하매 사무엘이 가로되 `이도 여호와께서 택하지 아니하셨느니라'","reference":"사무엘상 16:9","category":"$undefined"},{"id":"7606","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":10,"text":"이새가 그 아들 일곱으로 다 사무엘 앞을 지나게 하나 사무엘이 이새에게 이르되 `여호와께서 이들을 택하지 아니하셨느니라' 하고","reference":"사무엘상 16:10","category":"$undefined"},{"id":"7607","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":11,"text":"또 이새에게 이르되 네 아들들이 다 여기 있느냐 이새가 가로되 아직 말째가 남았는데 그가 양을 지키나이다 사무엘이 이새에게 이르되 보내어 그를 데려오라 그가 여기 오기까지는 우리가 식사자리에 앉지 아니하겠노라","reference":"사무엘상 16:11","category":"$undefined"},{"id":"7608","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":12,"text":"이에 보내어 그를 데려오매 그의 빛이 붉고 눈이 빼어나고 얼굴이 아름답더라 여호와께서 가라사대 이가 그니 일어나 기름을 부으라 !","reference":"사무엘상 16:12","category":"$undefined"},{"id":"7609","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":13,"text":"사무엘이 기름 뿔을 취하여 그 형제 중에서 그에게 부었더니 이날 이후로 다윗이 여호와의 신에게 크게 감동되니라 사무엘이 떠나서 라마로 가니라","reference":"사무엘상 16:13","category":"$undefined"},{"id":"7610","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":14,"text":"여호와의 신이 사울에게서 떠나고 여호와의 부리신 악신이 그를 번뇌케 한지라","reference":"사무엘상 16:14","category":"$undefined"},{"id":"7611","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":15,"text":"사울의 신하들이 그에게 이르되 `보소서 ! 하나님의 부리신 악신이 왕을 번뇌케 하온즉","reference":"사무엘상 16:15","category":"$undefined"},{"id":"7612","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":16,"text":"원컨대 우리 주는 주의 앞에 모시는 신하에게 명하여 수금 잘 탈줄 아는 사람을 구하게 하소서 하나님의 부리신 악신이 왕에게 이를 때에 그가 손으로 타면 왕이 나으시리이다'","reference":"사무엘상 16:16","category":"$undefined"},{"id":"7613","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":17,"text":"사울이 신하에게 이르되 `나를 위하여 잘 타는 사람을 구하여 내게로 데려오라'","reference":"사무엘상 16:17","category":"$undefined"},{"id":"7614","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":18,"text":"소년 중 한사람이 대답하여 가로되 `내가 베들레헴 사람 이새의 아들을 본즉 탈줄을 알고 호기와 무용과 구변이 있는 준수한 자라 여호와께서 그와 함께 계시더이다'","reference":"사무엘상 16:18","category":"$undefined"},{"id":"7615","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":19,"text":"사울이 이에 사자를 이새에게 보내어 이르되 `양 치는 네 아들 다윗을 내게로 보내라' 하매","reference":"사무엘상 16:19","category":"$undefined"},{"id":"7616","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":20,"text":"이새가 떡과 한 가죽부대의 포도주와 염소 새끼를 나귀에 실리고 그 아들 다윗의 손으로 사울에게 보내니","reference":"사무엘상 16:20","category":"$undefined"},{"id":"7617","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":21,"text":"다윗이 사울에게 이르러 그 앞에 모셔 서매 사울이 그를 크게 사랑하여 자기의 병기 든 자를 삼고","reference":"사무엘상 16:21","category":"$undefined"},{"id":"7618","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":22,"text":"이새에게 사람을 보내어 이르되 `청컨대 다윗으로 내 앞에 모셔 서게 하라 그가 내게 은총을 얻었느니라' 하니라","reference":"사무엘상 16:22","category":"$undefined"},{"id":"7619","book":"사무엘상","book_name":"사무엘상","chapter":16,"verse":23,"text":"하나님의 부리신 악신이 사울에게 이를 때에 다윗이 수금을 취하여 손으로 탄즉 사울이 상쾌하여 낫고 악신은 그에게서 떠나더라","reference":"사무엘상 16:23","category":"$undefined"}],"bookSlug":"1samuel"}]
