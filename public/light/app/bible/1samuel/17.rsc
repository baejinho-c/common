2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":17,"verses":[{"id":"7620","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":1,"text":"블레셋 사람들이 그 군대를 모으고 싸우고자 하여 유다에 속한 소고에 모여 소고와 아세가 사이의 에베스담밈에 진치매","reference":"사무엘상 17:1","category":"$undefined"},{"id":"7621","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":2,"text":"사울과 이스라엘 사람들이 모여서 엘라 골짜기에 진치고 블레셋 사람을 대하여 항오를 벌였으니","reference":"사무엘상 17:2","category":"$undefined"},{"id":"7622","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":3,"text":"블레셋 사람은 이편 산에 섰고 이스라엘은 저편 산에 섰고 사이에는 골짜기가 있었더라","reference":"사무엘상 17:3","category":"$undefined"},{"id":"7623","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":4,"text":"블레셋 사람의 진에서 싸움을 돋우는 자가 왔는데 그 이름은 골리앗이요 가드 사람이라 그 신장은 여섯 규빗 한 뼘이요","reference":"사무엘상 17:4","category":"$undefined"},{"id":"7624","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":5,"text":"머리에는 놋투구를 썼고 몸에는 어린갑을 입었으니 그 갑옷의 중수가 놋 오천 세겔이며","reference":"사무엘상 17:5","category":"$undefined"},{"id":"7625","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":6,"text":"그 다리에는 놋경갑을 쳤고 어깨 사이에는 놋단창을 메었으니","reference":"사무엘상 17:6","category":"$undefined"},{"id":"7626","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":7,"text":"그 창자루는 베틀 채 같고 창날은 철 육백 세겔이며 방패 든 자는 앞서 행하더라","reference":"사무엘상 17:7","category":"$undefined"},{"id":"7627","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":8,"text":"그가 서서 이스라엘 군대를 향하여 외쳐 가로되 `너희가 어찌하여 나와서 항오를 벌였느냐 ? 나는 블레셋 사람이 아니며 너희는 사울의 신복이 아니냐 ? 너희는 한 사람을 택하여 내게로 내려보내라","reference":"사무엘상 17:8","category":"$undefined"},{"id":"7628","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":9,"text":"그가 능히 싸워서 나를 죽이면 우리가 너희의 종이 되겠고 만일 내가 이기어 그를 죽이면 너희가 우리의 종이 되어 우리를 섬길 것이니라'","reference":"사무엘상 17:9","category":"$undefined"},{"id":"7629","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":10,"text":"그 블레셋 사람이 또 가로되 `내가 오늘날 이스라엘의 군대를 모욕하였으니 사람을 보내어 나로 더불어 싸우게 하라' 한지라","reference":"사무엘상 17:10","category":"$undefined"},{"id":"7630","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":11,"text":"사울과 온 이스라엘이 블레셋 사람의 이 말을 듣고 놀라 크게 두려워하니라","reference":"사무엘상 17:11","category":"$undefined"},{"id":"7631","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":12,"text":"다윗은 유다 베들레헴 에브랏 사람 이새라 하는 자의 아들이었는데 이새는 사울 당시 사람 중에 나이 많아 늙은 자로서 여덟 아들이 있는 중","reference":"사무엘상 17:12","category":"$undefined"},{"id":"7632","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":13,"text":"그 장성한 세 아들은 사울을 따라 싸움에 나갔으니 싸움에 나간 세 아들의 이름은 장자 엘리압이요, 그 다음은 아비나답이요, 제 삼은 삼마며","reference":"사무엘상 17:13","category":"$undefined"},{"id":"7633","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":14,"text":"다윗은 말째라 장성한 삼인은 사울을 좇았고","reference":"사무엘상 17:14","category":"$undefined"},{"id":"7634","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":15,"text":"다윗은 사울에게로 왕래하며 베들레헴에서 그 아비의 양을 칠때에","reference":"사무엘상 17:15","category":"$undefined"},{"id":"7635","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":16,"text":"그 블레셋 사람이 사십일을 조석으로 나와서 몸을 나타내었더라","reference":"사무엘상 17:16","category":"$undefined"},{"id":"7636","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":17,"text":"이 치스 열 덩이를 가져다가 그들의 천부장에게 주고 네 형들의 안부를 살피고 증표를 가져오라'","reference":"사무엘상 17:17","category":"$undefined"},{"id":"7637","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":18,"text":"때에 사울과 그들과 이스라엘 모든 사람이 엘라 골짜기에서 블레셋 사람과 싸우는 중이더라","reference":"사무엘상 17:18","category":"$undefined"},{"id":"7638","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":19,"text":"다윗이 아침에 일찌기 일어나서 양을 양 지키는 자에게 맡기고 이새의 명한 대로 가지고 가서 진영에 이른즉 싸우려고 고함하며","reference":"사무엘상 17:19","category":"$undefined"},{"id":"7639","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":20,"text":"이스라엘과 블레셋 사람이 항오를 벌이고 양군이 서로 대하였더라","reference":"사무엘상 17:20","category":"$undefined"},{"id":"7640","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":21,"text":"다윗이 그 짐을 짐 지키는 자의 손에 맡기고 군대로 달려가서 형들에게 문안하고","reference":"사무엘상 17:21","category":"$undefined"},{"id":"7641","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":22,"text":"그들과 함께 말할 때에 마침 블레셋 사람의 싸움 돋우는 가드 사람 골리앗이라 하는 자가 그 항오에서 나와서 전과 같은 말을 하매 다윗이 들으니라","reference":"사무엘상 17:22","category":"$undefined"},{"id":"7642","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":23,"text":"이스라엘 모든 사람이 그 사람을 보고 심히 두려워하여 그 앞에서 도망하며","reference":"사무엘상 17:23","category":"$undefined"},{"id":"7643","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":24,"text":"더러는 가로되 `너희가 이 올라온 사람을 보았느냐 ? 참으로 이스라엘을 모욕하러 왔도다 그를 죽이는 사람은 왕이 많은 재물로 부하게 하고 그 딸을 그에게 주고 그 아비의 집은 이스라엘 중에서 자유하게 하시리라'","reference":"사무엘상 17:24","category":"$undefined"},{"id":"7644","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":25,"text":"다윗이 곁에 섰는 사람들에게 말하여 가로되 `이 블레셋 사람을 죽여 이스라엘의 치욕을 제하는 사람에게는 어떠한 대우를 하겠느냐 ? 이 할례 없는 블레셋 사람이 누구관대 사시는 하나님의 군대를 모욕하겠느냐 ?'","reference":"사무엘상 17:25","category":"$undefined"},{"id":"7645","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":26,"text":"백성이 전과 같이 말하여 가로되 `그를 죽이는 사람에게는 여차 여차히 하시리라' 하니라","reference":"사무엘상 17:26","category":"$undefined"},{"id":"7646","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":27,"text":"장형 엘리압이 다윗이 사람들에게 하는 말을 들은지라 그가 다윗에게 노를 발하여 가로되 `네가 어찌하여 이리로 내려왔느냐 ? 들에 있는 몇 양을 뉘게 맡겼느냐 ? 나는 네 교만과 네 마음의 완악함을 아노니 네가 전쟁을 구경하러 왔도다'","reference":"사무엘상 17:27","category":"$undefined"},{"id":"7647","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":28,"text":"다윗이 가로되 `내가 무엇을 하였나이까 ? 어찌 이유가 없으리이까 ?' 하고","reference":"사무엘상 17:28","category":"$undefined"},{"id":"7648","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":29,"text":"돌이켜 다른 사람을 향하여 전과 같이 말하매 백성이 전과 같이 대답하니라","reference":"사무엘상 17:29","category":"$undefined"},{"id":"7649","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":30,"text":"혹이 다윗의 한 말을 듣고 그것을 사울에게 고하였으므로 사울이 다윗을 부른지라","reference":"사무엘상 17:30","category":"$undefined"},{"id":"7650","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":31,"text":"다윗이 사울에게 고하되 `그를 인하여 사람이 낙담하지 말 것이라 주의 종이 가서 저 블레셋 사람과 싸우리이다'","reference":"사무엘상 17:31","category":"$undefined"},{"id":"7651","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":32,"text":"사울이 다윗에게 이르되 `네가 가서 저 블레셋 사람과 싸우기에 능치 못하리니 너는 소년이요 그는 어려서부터 용사임이니라'","reference":"사무엘상 17:32","category":"$undefined"},{"id":"7652","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":33,"text":"다윗이 사울에게 고하되 `주의 종이 아비의 양을 지킬 때에 사자나 곰이 와서 양떼에서 새끼를 움키면","reference":"사무엘상 17:33","category":"$undefined"},{"id":"7653","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":34,"text":"내가 따라가서 그것을 치고 그 입에서 새끼를 건져 내었고 그것이 일어나 나를 해하고자 하면 내가 그 수염을 잡고 그것을 쳐 죽였나이다","reference":"사무엘상 17:34","category":"$undefined"},{"id":"7654","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":35,"text":"주의 종이 사자와 곰도 쳤은즉 사시는 하나님의 군대를 모욕한 이 할례 없는 블레셋 사람이리이까 ? 그가 그 짐승의 하나와 같이 되리이다'","reference":"사무엘상 17:35","category":"$undefined"},{"id":"7655","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":36,"text":"또 가로되 `여호와께서 나를 사자의 발톱과 곰의 발톱에서 건져 내셨은즉 나를 이 블레셋 사람의 손에서도 건져 내시리이다' 사울이 다윗에게 이르되 `가라 ! 여호와께서 너와 함께 계시기를 원하노라'","reference":"사무엘상 17:36","category":"$undefined"},{"id":"7656","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":37,"text":"이에 사울이 자기 군복을 다윗에게 입히고 놋투구를 그 머리에 씌우고 또 그에게 갑옷을 입히매","reference":"사무엘상 17:37","category":"$undefined"},{"id":"7657","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":38,"text":"다윗이 칼을 군복 위에 차고는 익숙치 못하므로 시험적으로 걸어 보다가 사울에게 고하되 `익숙치 못하니 이것을 입고 가지 못하겠나이다' 하고 곧 벗고","reference":"사무엘상 17:38","category":"$undefined"},{"id":"7658","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":39,"text":"손에 막대기를 가지고 시내에서 매끄러운 돌 다섯을 골라서 자기 목자의 제구 곧 주머니에 넣고 손에 물매를 가지고 블레셋 사람에게로 나아가니라","reference":"사무엘상 17:39","category":"$undefined"},{"id":"7659","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":40,"text":"블레셋 사람이 점점 행하여 다윗에게로 나아오는데 방패 든 자가 앞섰더라","reference":"사무엘상 17:40","category":"$undefined"},{"id":"7660","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":41,"text":"그 블레셋 사람이 둘러보다가 다윗을 보고 업신여기니 이는 그가 젊고 붉고 용모가 아름다움이라","reference":"사무엘상 17:41","category":"$undefined"},{"id":"7661","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":42,"text":"블레셋 사람이 다윗에게 이르되 `네가 나를 개로 여기고 막대기를 가지고 내게 나아왔느냐 ?' 하고 그 신들의 이름으로 다윗을 저주하고","reference":"사무엘상 17:42","category":"$undefined"},{"id":"7662","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":43,"text":"또 이르되 `내게로 오라 내가 네 고기를 공중의 새들과 들짐승들에게 주리라'","reference":"사무엘상 17:43","category":"$undefined"},{"id":"7663","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":44,"text":"다윗이 블레셋 사람에게 이르되 `너는 칼과 창과 단창으로 내게 오거니와 나는 만군의 여호와의 이름 곧 네가 모욕하는 이스라엘 군대의 하나님의 이름으로 네게 가노라 !","reference":"사무엘상 17:44","category":"$undefined"},{"id":"7664","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":45,"text":"오늘 여호와께서 너를 내 손에 붙이시리니 내가 너를 쳐서 네 머리를 베고 블레셋 군대의 시체로 오늘날 공중의 새와 땅의 들짐승에게 주어 온 땅으로 이스라엘에 하나님이 계신줄 알게 하겠고","reference":"사무엘상 17:45","category":"$undefined"},{"id":"7665","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":46,"text":"또 여호와의 구원하심이 칼과 창에 있지 아니함을 이 무리로 알게 하리라 전쟁은 여호와께 속한 것인즉 그가 너희를 우리 손에 붙이시리라'","reference":"사무엘상 17:46","category":"$undefined"},{"id":"7666","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":47,"text":"블레셋 사람이 일어나 다윗에게로 마주 가까이 올 때에 다윗이 블레셋 사람에게로 마주 그 항오를 향하여 빨리 달리며","reference":"사무엘상 17:47","category":"$undefined"},{"id":"7667","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":48,"text":"손을 주머니에 넣어 돌을 취하여 물매로 던져 블레셋 사람의 이마를 치매 돌이 그 이마에 박히니 땅에 엎드러지니라","reference":"사무엘상 17:48","category":"$undefined"},{"id":"7668","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":49,"text":"다윗이 이같이 물매와 돌로 블레셋 사람을 이기고 그를 쳐 죽였으나 자기 손에는 칼이 없었더라","reference":"사무엘상 17:49","category":"$undefined"},{"id":"7669","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":50,"text":"다윗이 달려가서 블레셋 사람을 밟고 그의 칼을 그 집에서 빼어 내어 그 칼로 그를 죽이고 그 머리를 베니 블레셋 사람들이 자기 용사의 죽음을 보고 도망하는지라","reference":"사무엘상 17:50","category":"$undefined"},{"id":"7670","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":51,"text":"이스라엘과 유다 사람들이 일어나서 소리지르며 블레셋 사람을 쫓아 가이와 에그론 성문까지 이르렀고 블레셋 사람의 상한 자들은 사아라임 가는 길에서부터 가드와 에그론까지 엎드러졌더라","reference":"사무엘상 17:51","category":"$undefined"},{"id":"7671","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":52,"text":"이스라엘 자손이 블레셋 사람을 쫓다가 돌아와서 그들의 진을 노략하였고","reference":"사무엘상 17:52","category":"$undefined"},{"id":"7672","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":53,"text":"다윗은 블레셋 사람의 머리를 예루살렘으로 가져 가고 갑주는 자기 장막에 두니라","reference":"사무엘상 17:53","category":"$undefined"},{"id":"7673","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":54,"text":"다윗이 블레셋 사람을 향하여 나감을 사울이 보고 군장 아브넬에게 묻되 `아브넬아 이 소년이 뉘 아들이냐 ?' 아브넬이 가로되 `왕이여 왕의 사심으로 맹세하옵나니 내가 알지 못하나이다' 하매","reference":"사무엘상 17:54","category":"$undefined"},{"id":"7674","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":55,"text":"왕이 가로되 `너는 이 청년이 누구의 아들인가 물어보라' 하였더니","reference":"사무엘상 17:55","category":"$undefined"},{"id":"7675","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":56,"text":"다윗이 블레셋 사람을 죽이고 돌아올 때에 블레셋 사람의 머리가 그 손에 있는 채 아브넬이 그를 사울의 앞으로 인도하니","reference":"사무엘상 17:56","category":"$undefined"},{"id":"7676","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":57,"text":"사울이 그에게 묻되 `소년이여 누구의 아들이뇨 ?' 다윗이 대답하되 `나는 주의 종 베들레헴 사람 이새의 아들이니이다'","reference":"사무엘상 17:57","category":"$undefined"},{"id":"7677","book":"사무엘상","book_name":"사무엘상","chapter":17,"verse":58,"text":"","reference":"사무엘상 17:58","category":"$undefined"}],"bookSlug":"1samuel"}]
