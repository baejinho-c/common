2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":18,"verses":[{"id":"7678","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":1,"text":"다윗이 사울에게 말하기를 마치매 요나단의 마음이 다윗의 마음과 연락되어 요나단이 그를 자기 생명 같이 사랑하니라","reference":"사무엘상 18:1","category":"$undefined"},{"id":"7679","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":2,"text":"그 날에 사울은 다윗을 머무르게 하고 그 아비의 집으로 다시 돌아가기를 허락지 아니하였고","reference":"사무엘상 18:2","category":"$undefined"},{"id":"7680","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":3,"text":"요나단은 다윗을 자기 생명 같이 사랑하여 더불어 언약을 맺었으며","reference":"사무엘상 18:3","category":"$undefined"},{"id":"7681","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":4,"text":"요나단이 자기의 입었던 겉옷을 벗어 다윗에게 주었고 그 군복과 칼과 활과 띠도 그리하였더라","reference":"사무엘상 18:4","category":"$undefined"},{"id":"7682","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":5,"text":"다윗이 사울의 보내는 곳마다 가서 지혜롭게 행하매 사울이 그로 군대의 장을 삼았더니 온 백성이 합당히 여겼고 사울의 신하들도 합당히 여겼더라","reference":"사무엘상 18:5","category":"$undefined"},{"id":"7683","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":6,"text":"무리가 돌아올 때 곧 다윗이 블레셋 사람을 죽이고 돌아올 때에 여인들이 이스라엘 모든 성에서 나와서 노래하며 춤추며 소고와 경쇠를 가지고 왕 사울을 환영하는데","reference":"사무엘상 18:6","category":"$undefined"},{"id":"7684","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":7,"text":"여인들이 뛰놀며 창화하여 가로되 `사울의 죽인 자는 천천이요, 다윗은 만만이로다' 한지라","reference":"사무엘상 18:7","category":"$undefined"},{"id":"7685","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":8,"text":"사울이 이 말에 불쾌하여 심히 노하여 가로되 `다윗에게는 만만을 돌리고 내게는 천천만 돌리니 그의 더 얻을 것이 나라 밖에 무엇이냐 ?'하고","reference":"사무엘상 18:8","category":"$undefined"},{"id":"7686","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":9,"text":"그 날 후로 사울이 다윗을 주목하였더라","reference":"사무엘상 18:9","category":"$undefined"},{"id":"7687","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":10,"text":"그 이튿날 하나님의 부리신 악신이 사울에게 힘있게 내리매 그가 집 가운데서 야료하는고로 다윗이 평일과 같이 손으로 수금을 타는데 때에 사울의 손에 창이 있는지라","reference":"사무엘상 18:10","category":"$undefined"},{"id":"7688","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":11,"text":"그가 스스로 이르기를 `내가 다윗을 벽에 박으리라' 하고 그 창을 던졌으나 다윗이 그 앞에서 두 번 피하였더라","reference":"사무엘상 18:11","category":"$undefined"},{"id":"7689","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":12,"text":"여호와께서 사울을 떠나 다윗과 함께 계시므로 사울이 그를 두려워한지라","reference":"사무엘상 18:12","category":"$undefined"},{"id":"7690","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":13,"text":"그러므로 사울이 그로 자기를 떠나게 하고 천부장을 삼으매 그가 백성 앞에 출입하며","reference":"사무엘상 18:13","category":"$undefined"},{"id":"7691","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":14,"text":"그 모든 일을 지혜롭게 행하니라 여호와께서 그와 함께 계시니라","reference":"사무엘상 18:14","category":"$undefined"},{"id":"7692","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":15,"text":"사울이 다윗의 크게 지혜롭게 행함을 보고 그를 두려워하였으나","reference":"사무엘상 18:15","category":"$undefined"},{"id":"7693","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":16,"text":"온 이스라엘과 유다는 다윗을 사랑하였으니 그가 자기들 앞에 출입함을 인함이었더라","reference":"사무엘상 18:16","category":"$undefined"},{"id":"7694","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":17,"text":"사울이 다윗에게 이르되 `내 맏딸 메랍을 네게 아내로 주리니 오직 너는 나를 위하여 용맹을 내어 여호와의 싸움을 싸우라' 하니 이는 그가 생각하기를 `내 손을 그에게 대지 말고 블레셋 사람의 손으로 그에게 대게 하리라' 함이라","reference":"사무엘상 18:17","category":"$undefined"},{"id":"7695","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":18,"text":"다윗이 사울에게 이르되 `내가 누구며 이스라엘 중에 내 친속이나 내 아비의 집이 무엇이관대 내가 왕의 사위가 되리이까 ?' 하였더니","reference":"사무엘상 18:18","category":"$undefined"},{"id":"7696","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":19,"text":"사울의 딸 메랍을 다윗에게 줄 시기에 므훌랏 사람 아드리엘에게 아내로 준 바 되었더라","reference":"사무엘상 18:19","category":"$undefined"},{"id":"7697","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":20,"text":"사울의 딸 미갈이 다윗을 사랑하매 혹이 사울에게 고한지라 사울이 그 일을 좋게 여겨","reference":"사무엘상 18:20","category":"$undefined"},{"id":"7698","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":21,"text":"스스로 이르되 `내가 딸을 그에게 주어서 그에게 올무가 되게 하고 블레셋 사람의 손으로 그를 치게 하리라' 하고 이에 다윗에게 이르되 `네가 오늘 다시 내 사위가 되리라' 하니라","reference":"사무엘상 18:21","category":"$undefined"},{"id":"7699","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":22,"text":"사울이 그 신하들에게 명하되 `너희는 다윗에게 비밀히 말하여 이르기를 보라 왕이 너를 기뻐하시고 모든 신하도 너를 사랑하나니 그런즉 네가 왕의 사위가 되는 것이 가하니라' 하라","reference":"사무엘상 18:22","category":"$undefined"},{"id":"7700","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":23,"text":"사울의 신하들이 이 말로 다윗의 귀에 고하매 다윗이 가로되 `왕의 사위 되는 것을 너희는 경한 일로 보느냐 ? 나는 가난하고 천한 사람이로라' 한지라","reference":"사무엘상 18:23","category":"$undefined"},{"id":"7701","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":24,"text":"사울의 신하들이 사울에게 고하여 가로되 `다윗이 여차여차히 말하더이다'","reference":"사무엘상 18:24","category":"$undefined"},{"id":"7702","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":25,"text":"사울이 가로되 `너희는 다윗에게 이같이 말하기를 왕이 아무 폐백도 원치 아니하고 다만 왕의 원수의 보복으로 블레셋 사람의 양피 일백을 원하신다 하라' 하였으니 이는 사울의 생각에 `다윗을 블레셋 사람의 손에 죽게 하리라' 함이라","reference":"사무엘상 18:25","category":"$undefined"},{"id":"7703","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":26,"text":"사울의 신하들이 이 말로 다윗에게 고하매 다윗이 왕의 사위 되는 것을 좋게 여기므로 만기가 되지 못하여서","reference":"사무엘상 18:26","category":"$undefined"},{"id":"7704","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":27,"text":"다윗이 일어나서 그 종자와 함께 가서 블레셋 사람 이백명을 죽이고 그 양피를 가져다가 수대로 왕께 드려 왕의 사위가 되고자 하니 사울이 그 딸 미갈을 다윗에게 아내로 주었더라","reference":"사무엘상 18:27","category":"$undefined"},{"id":"7705","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":28,"text":"여호와께서 다윗과 함께 계심을 사울이 보고 알았고 사울의 딸 미갈도 그를 사랑하므로","reference":"사무엘상 18:28","category":"$undefined"},{"id":"7706","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":29,"text":"사울이 다윗을 더욱 더욱 두려워하여 평생에 다윗의 대적이 되니라","reference":"사무엘상 18:29","category":"$undefined"},{"id":"7707","book":"사무엘상","book_name":"사무엘상","chapter":18,"verse":30,"text":"블레셋 사람의 방백들이 나오면 그들의 나올 때마다 다윗이 사울의 모든 신하보다 더 지혜롭게 행하매 이에 그 이름이 심히 귀중히 되니라","reference":"사무엘상 18:30","category":"$undefined"}],"bookSlug":"1samuel"}]
