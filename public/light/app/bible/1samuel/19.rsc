2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":19,"verses":[{"id":"7708","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":1,"text":"사울이 그아들 요나단과 그 모든 신하에게 다윗을 죽이라 말하였더니 사울의 아들 요나단이 다윗을 심히 기뻐하므로","reference":"사무엘상 19:1","category":"$undefined"},{"id":"7709","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":2,"text":"그가 다윗에게 고하여 가로되 `내 부친 사울이 너를 죽이기를 꾀하시느니라 그러므로 이제 청하노니 아침에 조심하여 은밀한 곳에 숨어 있으라","reference":"사무엘상 19:2","category":"$undefined"},{"id":"7710","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":3,"text":"내가 나가서 너 있는 들에서 내 부친 곁에 서서 네 일을 내 부친과 말하다가 무엇을 보거든 네게 알게 하리라' 하고","reference":"사무엘상 19:3","category":"$undefined"},{"id":"7711","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":4,"text":"요나단이 그 아비 사울에게 다윗을 포장하여 가로되 `원컨대 왕은 신하 다윗에게 범죄치 마옵소서 그는 왕께 득죄하지 아니하였고 그가 왕께 행한 일은 심히 선함이니이다","reference":"사무엘상 19:4","category":"$undefined"},{"id":"7712","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":5,"text":"그가 자기 생명을 아끼지 아니하고 블레셋 사람을 죽였고 여호와께서는 온 이스라엘을 위하여 큰 구원을 이루셨으므로 왕이 이를 보고 기뻐하셨거늘 어찌 무고히 다윗을 죽여 무죄한 피를 흘려 범죄하려 하시나이까 ?'","reference":"사무엘상 19:5","category":"$undefined"},{"id":"7713","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":6,"text":"사울이 요나단의 말을 듣고 맹세하되 `여호와께서 사시거니와 그가 죽임을 당치 아니하리라'","reference":"사무엘상 19:6","category":"$undefined"},{"id":"7714","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":7,"text":"요나단이 다윗을 불러 그 모든 일을 알게 하고 그를 사울에게로 인도하니 그가 사울 앞에 여전히 있으니라","reference":"사무엘상 19:7","category":"$undefined"},{"id":"7715","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":8,"text":"전쟁이 다시 있으므로 다윗이 나가서 블레셋 사람들과 싸워 그들을 크게 도륙하매 그들이 그 앞에서 도망하니라","reference":"사무엘상 19:8","category":"$undefined"},{"id":"7716","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":9,"text":"사울이 손에 단창을 가지고 그 집에 앉았을 때에 여호와의 부리신 악신이 사울에게 접하였으므로 다윗이 손으로 수금을 탈 때에","reference":"사무엘상 19:9","category":"$undefined"},{"id":"7717","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":10,"text":"사울이 단창으로 다윗을 벽에 박으려 하였으나 그는 사울의 앞을 피하고 사울의 창은 벽에 박힌지라 다윗이 그 밤에 도피하매","reference":"사무엘상 19:10","category":"$undefined"},{"id":"7718","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":11,"text":"사울이 사자들을 다윗의 집에 보내어 그를 지키다가 아침에 그를 죽이게 하려 한지라 다윗의 아내 미갈이 다윗에게 일러 가로되 `당신이 이 밤에 당신의 생명을 구하지 아니하면 내일에는 죽임을 당하리라' 하고","reference":"사무엘상 19:11","category":"$undefined"},{"id":"7719","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":12,"text":"미갈이 다윗을 창에서 달아 내리우매 그가 도망하여 피하니라","reference":"사무엘상 19:12","category":"$undefined"},{"id":"7720","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":13,"text":"미갈이 우상을 취하여 침상에 뉘고 염소털로 엮은 것을 그 머리에 씌우고 의복으로 그것을 덮었더니","reference":"사무엘상 19:13","category":"$undefined"},{"id":"7721","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":14,"text":"사울이 사자들을 보내어 다윗을 잡으려 하매 미갈이 가로되 `그가 병들었느니라'","reference":"사무엘상 19:14","category":"$undefined"},{"id":"7722","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":15,"text":"사울이 또 사자들을 보내어 다윗을 보라 하며 이르되 `그를 침상채 내게로 가져오라 내가 그를 죽이리라'","reference":"사무엘상 19:15","category":"$undefined"},{"id":"7723","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":16,"text":"사자들이 들어가 본즉 침상에 우상이 있고 염소털로 엮은 것이 그 머리에 있었더라","reference":"사무엘상 19:16","category":"$undefined"},{"id":"7724","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":17,"text":"사울이 미갈에게 이르되 `너는 어찌하여 이처럼 나를 속여 내 대적을 놓아 피하게 하였느냐 ?' 미갈이 사울에게 대답하되 `그가 내게 이르기를 나를 놓아 가게 하라 어찌하여 나로 너를 죽이게 하겠느냐 하더이다' 하니라","reference":"사무엘상 19:17","category":"$undefined"},{"id":"7725","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":18,"text":"다윗이 도피하여 라마로 가서 사무엘에게로 나아가서 사울이 자기에게 행한 일을 다 고하였고 다윗과 사무엘이 나욧으로 가서 거하였더라","reference":"사무엘상 19:18","category":"$undefined"},{"id":"7726","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":19,"text":"혹이 사울에게 고하여 가로되 `다윗이 라마 나욧에 있더이다' 하매","reference":"사무엘상 19:19","category":"$undefined"},{"id":"7727","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":20,"text":"사울이 다윗을 잡으려 사자들을 보내었더니 그들이 선지자 무리의 예언하는 것과 사무엘이 그들의 수령으로 선 것을 볼 때에 하나님의 신이 사울의 사자들에게 임하매 그들도 예언을 한지라","reference":"사무엘상 19:20","category":"$undefined"},{"id":"7728","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":21,"text":"혹이 그것을 사울에게 고하매 사울이 다른 사자들을 보내었더니 그들도 예언을 한고로 사울이 세번째 다시 사자들을 보내었더니 그들도 예언을 한지라","reference":"사무엘상 19:21","category":"$undefined"},{"id":"7729","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":22,"text":"이에 사울도 라마로 가서 세구에 있는 큰 우물에 이르러 물어 가로되 `사무엘과 다윗이 어디 있느냐 ?' 혹이 가로되 `라마 나욧에 있나이다'","reference":"사무엘상 19:22","category":"$undefined"},{"id":"7730","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":23,"text":"사울이 라마 나욧으로 가니라 하나님의 신이 그에게도 임하시니 그가 라마 나욧에 이르기까지 행하며 예언을 하였으며","reference":"사무엘상 19:23","category":"$undefined"},{"id":"7731","book":"사무엘상","book_name":"사무엘상","chapter":19,"verse":24,"text":"그가 또 그 옷을 벗고 사무엘 앞에서 예언을 하며 종일 종야에 벌거벗은 몸으로 누웠었더라 그러므로 속담에 이르기를 `사울도 선지자 중에 있느냐 ?' 하니라","reference":"사무엘상 19:24","category":"$undefined"}],"bookSlug":"1samuel"}]
