11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":2,"verses":[{"id":"7242","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":1,"text":"한나가 기도하여 가로되 내 마음이 여호와를 인하여 즐거워 하며 내 뿔이 여호와를 인하여 높아졌으며 내 입이 내 원수들을 향하여 크게 열렸으니 이는 내가 주의 구원을 인하여 기뻐함이니이다","reference":"사무엘상 2:1","category":"$undefined"},{"id":"7243","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":2,"text":"여호와와 같이 거룩하신 이가 없으시니 이는 주 밖에 다른 이가 없고 우리 하나님 같은 반석도 없으심이니이다","reference":"사무엘상 2:2","category":"$undefined"},{"id":"7244","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":3,"text":"심히 교만한 말을 다시 하지 말 것이며 오만한 말을 너희 입에서 내지 말지어다 ! 여호와는 지식의 하나님이시라 행동을 달아보시느니라","reference":"사무엘상 2:3","category":"$undefined"},{"id":"7245","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":4,"text":"용사의 활은 꺾이고 넘어진 자는 힘으로 띠를 띠도다","reference":"사무엘상 2:4","category":"$undefined"},{"id":"7246","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":5,"text":"유족하던 자들은 양식을 위하여 품을 팔고 주리던 자들은 다시 주리지 않도다 전에 잉태치 못하던 자는 일곱을 낳았고 많은 자녀를 둔 자는 쇠약하도다","reference":"사무엘상 2:5","category":"$undefined"},{"id":"7247","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":6,"text":"여호와는 죽이기도 하시고 살리기도 하시며 음부에 내리게도 하시고 올리기도 하시는도다","reference":"사무엘상 2:6","category":"$undefined"},{"id":"7248","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":7,"text":"여호와는 가난하게도 하시고 부하게도 하시며, 낮추기도 하시고 높이기도 하시는도다","reference":"사무엘상 2:7","category":"$undefined"},{"id":"7249","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":8,"text":"가난한 자를 진토에서 일으키시며 빈핍한 자를 거름더미에서 드사 귀족들과 함께 앉게 하시며 영광의 위를 차지하게 하시는도다 땅의 기둥들은 여호와의 것이라 여호와께서 세계를 그 위에 세우셨도다","reference":"사무엘상 2:8","category":"$undefined"},{"id":"7250","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":9,"text":"그가 그 거룩한 자들의 발을 지키실 것이요 악인으로 흑암 중에서 잠잠케 하시리니 힘으로는 이길 사람이 없음이로다","reference":"사무엘상 2:9","category":"$undefined"},{"id":"7251","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":10,"text":"여호와를 대적하는 자는 산산이 깨어질 것이라 하늘 우뢰로 그들을 치시리로다 여호와께서 땅끝까지 심판을 베푸시고 자기 왕에게 힘을 주시며 자기의 기름 부음을 받은 자의 뿔을 높이시리로다 하니라","reference":"사무엘상 2:10","category":"$undefined"},{"id":"7252","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":11,"text":"엘가나는 라마의 자기 집으로 돌아가고 그 아이는 제사장 엘리 앞에서 여호와를 섬기니라","reference":"사무엘상 2:11","category":"$undefined"},{"id":"7253","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":12,"text":"엘리의 아들들은 불량자라 여호와를 알지 아니하더라","reference":"사무엘상 2:12","category":"$undefined"},{"id":"7254","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":13,"text":"그 제사장들이 백성에게 행하는 습관은 이러하니 곧 아무 사람이 제사를 드리고 그 고기를 삶을 때에 제사장의 사환이 손에 세살 갈고리를 가지고 와서","reference":"사무엘상 2:13","category":"$undefined"},{"id":"7255","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":14,"text":"그것으로 남비에나 솥에나 큰 솥에나 가마에 찔러 넣어서 갈고리에 걸려 나오는 것은 제사장이 자기 것으로 취하되 실로에서 무릇 그 곳에 온 이스라엘 사람에게 이같이 할 뿐 아니라","reference":"사무엘상 2:14","category":"$undefined"},{"id":"7256","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":15,"text":"기름을 태우기 전에도 제사장의 사환이 와서 제사 드리는 사람에게 이르기를 `제사장에게 구워 드릴 고기를 내라 그가 네게 삶은 고기를 원치 아니하고 날것을 원하신다' 하다가","reference":"사무엘상 2:15","category":"$undefined"},{"id":"7257","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":16,"text":"그 사람이 이르기를 `반드시 먼저 기름을 태운 후에 네 마음에 원하는 대로 취하라` 하면 그가 말하기를 `아니라 지금 내게 내라 그렇지 아니하면 내가 억지로 빼앗으리라' 하였으니","reference":"사무엘상 2:16","category":"$undefined"},{"id":"7258","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":17,"text":"이 소년들의 죄가 여호와 앞에 심히 큼은 그들이 여호와의 제사를 멸시함이었더라","reference":"사무엘상 2:17","category":"$undefined"},{"id":"7259","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":18,"text":"사무엘이 어렸을 때에 세마포 에봇을 입고 여호와 앞에 섬겨더라","reference":"사무엘상 2:18","category":"$undefined"},{"id":"7260","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":19,"text":"그 어미가 매년제를 드리러 그 남편과 함께 올라갈 때마다 작은 겉옷을 지어다가 그에게 주었더니","reference":"사무엘상 2:19","category":"$undefined"},{"id":"7261","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":20,"text":"엘리가 엘가나와 그 아내에게 축복하여 가로되 `여호와께서 이 여인으로 말미암아 네게 후사를 주사 이가 여호와께 간구하여 얻어드린 아들을 대신하게 하시기를 원하노라' 하였더니 그들이 그 집으로 돌아가매","reference":"사무엘상 2:20","category":"$undefined"},{"id":"7262","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":21,"text":"여호와께서 한나를 권고하사 그로 잉태하여 세 아들과 두 딸을 낳게 하셨고 아이 사무엘은 여호와앞에서 자라니라","reference":"사무엘상 2:21","category":"$undefined"},{"id":"7263","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":22,"text":"엘리가 매우 늙었더니 그 아들들이 온 이스라엘에게 행한 모든 일과 회막문에서 수종드는 여인과 동침하였음을 듣고","reference":"사무엘상 2:22","category":"$undefined"},{"id":"7264","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":23,"text":"그들에게 이르되 `너희가 어찌하여 이런 일을 하느냐 ? 내가 너희의 악행을 이 모든 백성에게서 듣노라","reference":"사무엘상 2:23","category":"$undefined"},{"id":"7265","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":24,"text":"내 아들아 그리 말라 내게 들리는 소문이 좋지 아니하니라 너희가 여호와의 백성으로 범과케 하는도다","reference":"사무엘상 2:24","category":"$undefined"},{"id":"7266","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":25,"text":"사람이 사람에게 범죄하면 하나님이 판결하시려니와 사람이 여호와께 범죄하면 누가 위하여 간구하겠느냐 ?` 하되 그들이 그 아비의 말을 듣지 아니하였으니 이는 여호와께서 그들을 죽이기로 뜻하셨음이었더라","reference":"사무엘상 2:25","category":"$undefined"},{"id":"7267","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":26,"text":"아이 사무엘이 점점 자라매 여호와와 사람들에게 은총을 더욱 받더라","reference":"사무엘상 2:26","category":"$undefined"},{"id":"7268","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":27,"text":"하나님의 사람이 엘리에게 와서 그에게 이르되 `여호와의 말씀에 너희 조상의 집이 애굽에서 바로의 집에 속하였을 때에 내가 그들에게 나타나지 아니하였느냐 ?","reference":"사무엘상 2:27","category":"$undefined"},{"id":"7269","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":28,"text":"이스라엘 모든 지파 중에서 내가 그를 택하여 나의 제사장을 삼아 그로 내 단에 올라 분향하며 내 앞에서 에봇을 입게 하지 아니하였느냐 ? 이스라엘 자손의 드리는 모든 화제를 내가 네 조상의 집에 주지 아니하였느냐 ?","reference":"사무엘상 2:28","category":"$undefined"},{"id":"7270","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":29,"text":"너희는 어찌하여 내가 나의 처소에서 명한 나의 제물과 예물을 밟으며 네 아들들을 나보다 더 중히 여겨 내 백성 이스라엘의 드리는 가장 좋은 것으로 스스로 살지게 하느냐 ?","reference":"사무엘상 2:29","category":"$undefined"},{"id":"7271","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":30,"text":"그러므로 이스라엘의 하나님 나 여호와가 말하노라 내가 전에 네 집과 네 조상의 집이 내 앞에 영영히 행하리라 하였으나 이제 나 여호와가 말하노니 결단코 그렇게 아니하리라 나를 존중히 여기는 자를 내가 존중히 여기고 나를 멸시하는 자를 내가 경멸히 여기리라","reference":"사무엘상 2:30","category":"$undefined"},{"id":"7272","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":31,"text":"보라, 내가 네 팔과 네 조상의 집 팔을 끊어 네 집에 노인이 하나도 없게 하는 날이 이를지라","reference":"사무엘상 2:31","category":"$undefined"},{"id":"7273","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":32,"text":"이스라엘에게 모든 복을 베푸는 중에 너는 내 처소의 환난을 볼 것이요 네 집에 영영토록 노인이 없을 것이며","reference":"사무엘상 2:32","category":"$undefined"},{"id":"7274","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":33,"text":"내 단에서 내가 끊어 버리지 아니할 너의 사람이 네 눈을 쇠잔케 하고 네 마음을 슬프게 할 것이요 네 집에 생산하는 모든 자가 젊어서 죽으리라","reference":"사무엘상 2:33","category":"$undefined"},{"id":"7275","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":34,"text":"네 두 아들 홉니와 비느하스가 한 날에 죽으리니 그 둘의 당할 그 일이 네게 표징이 되리라","reference":"사무엘상 2:34","category":"$undefined"},{"id":"7276","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":35,"text":"내가 나를 위하여 충실한 제사장을 일으키리니 그 사람은 내 마음 내 뜻대로 행할 것이라 내가 그를 위하여 견고한 집을 세우리니 그가 나의 기름 부음을 받은 자 앞에서 영구히 행하리라","reference":"사무엘상 2:35","category":"$undefined"},{"id":"7277","book":"사무엘상","book_name":"사무엘상","chapter":2,"verse":36,"text":"네 집에 남은 사람이 각기 와서 은 한 조각과 떡 한 덩이를 위하여 그에게 엎드려 가로되 청하노니 내게 한 제사장의 직분을 맡 겨 나로 떡 조각을 먹게 하소서 하리라 하셨다' 하니라","reference":"사무엘상 2:36","category":"$undefined"}],"bookSlug":"1samuel"}]
