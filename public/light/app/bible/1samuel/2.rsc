rg\",\"@type\":\"Organization\",\"name\":\"빛\",\"url\":\"https://light.restyart.com\",\"logo\":\"https://light.restyart.com/logo-512.png\",\"description\":\"매일의 큐티와 기도를 나누는 기독교 커뮤니티\"}"}}],["$","$L7",null,{"id":"schema-website","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"빛\",\"alternateName\":\"빛 QT 나눔 플랫폼\",\"url\":\"https://light.restyart.com\",\"description\":\"매일의 큐티와 기도를 나누는 기독교 커뮤니티\",\"inLanguage\":\"ko-KR\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://light.restyart.com/bible/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}"}}],["$","$L7",null,{"id":"schema-faq","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"빛은 어떤 플랫폼인가요?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"빛은 매일 큐티, 기도 제목, 간증을 나누는 기독교 커뮤니티입니다. 성경 검색·교회 찾기·QT 작성을 지원합니다.\"}},{\"@type\":\"Question\",\"name\":\"회원가입 없이 이용할 수 있나요?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"익명 QT·기도 작성이 가능하며, 성경 검색·교회 찾기는 로그인 없이 이용할 수 있습니다.\"}}]}"}}]]}]]}]],null],[null,[],[]]],["$L10",null]]]]
10:[["$","meta","0",{"name":"viewport","content":"width=device-width, initial-scale=1, maximum-scale=5"}],["$","meta","1",{"name":"theme-color","content":"#FBBF24"}],["$","meta","2",{"charSet":"utf-8"}],["$","title","3",{"children":"빛 성경 사무엘상 2장 말씀"}],["$","meta","4",{"name":"description","content":"사무엘상 2장 말씀입니다. 하나님의 말씀을 묵상해보세요."}],["$","link","5",{"rel":"author","href":"https://light.restyart.com"}],["$","meta","6",{"name":"author","content":"빛"}],["$","link","7",{"rel":"manifest","href":"/site.webmanifest","crossOrigin":"use-credentials"}],["$","meta","8",{"name":"keywords","content":"빛,성경,사무엘상,2장,말씀,기도,QT"}],["$","meta","9",{"name":"creator","content":"빛"}],["$","meta","10",{"name":"publisher","content":"빛"}],["$","meta","11",{"name":"robots","content":"index, follow"}],["$","meta","12",{"name":"googlebot","content":"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"}],["$","link","13",{"rel":"canonical","href":"https://light.restyart.com/bible/1samuel/2"}],["$","meta","14",{"name":"format-detection","content":"telephone=no, address=no, email=no"}],["$","meta","15",{"property":"og:title","content":"빛 성경 사무엘상 2장 말씀"}],["$","meta","16",{"property":"og:description","content":"사무엘상 2장 말씀입니다."}],["$","meta","17",{"property":"og:url","content":"https://light.restyart.com/bible/1samuel/2"}],["$","meta","18",{"property":"og:site_name","content":"빛 - 매일의 기도와 말씀"}],["$","meta","19",{"property":"og:type","content":"article"}],["$","meta","20",{"name":"twitter:card","content":"summary"}],["$","meta","21",{"name":"twitter:title","content":"빛 성경 사무엘상 2장 말씀"}],["$","meta","22",{"name":"twitter:description","content":"사무엘상 2장 말씀입니다."}],["$","link","23",{"rel":"shortcut icon","href":"/favicon.png","type":"image/png"}],["$","link","24",{"rel":"icon","href":"/favicon.png","type":"image/png"}],["$","link","25",{"rel":"icon","href":"/favicon-48x48.png","sizes":"48x48","type":"image/png"}],["$","link","26",{"rel":"icon","href":"/favicon-32x32.png","sizes":