2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":20,"verses":[{"id":"7732","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":1,"text":"다윗이 라마 나욧에서 도망하여 와서 요나단에게 이르되 `내가 무엇을 하였으며 내 죄악이 무엇이며 네 부친 앞에서 나의 죄가 무엇이관대 그가 내 생명을 찾느뇨'","reference":"사무엘상 20:1","category":"$undefined"},{"id":"7733","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":2,"text":"요나단이 그에게 이르되 `결단코 아니라 네가 죽지 아니하리라 내 부친이 대소사를 내게 알게 아니하고는 행함이 없나니 내 부친이 어찌하여 이 일은 내게 숨기리요 그렇지 아니하니라'","reference":"사무엘상 20:2","category":"$undefined"},{"id":"7734","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":3,"text":"다윗이 또 맹세하여 가로되 `내가 네게 은혜 받은 줄을 네 부친이 밝히 알고 스스로 이르기를 요나단이 슬퍼할까 두려운즉 그로 이를 알게 하지 아니하리라 함이니라 그러나 진실로 여호와의 사심과 네 생명으로 맹세하노니 나와 사망의 사이는 한 걸음 뿐이니라'","reference":"사무엘상 20:3","category":"$undefined"},{"id":"7735","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":4,"text":"요나단이 다윗에게 이르되 `네 마음의 소원이 무엇이든지 내가 너를 위하여 그것을 이루리라'","reference":"사무엘상 20:4","category":"$undefined"},{"id":"7736","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":5,"text":"다윗이 요나단에게 이르되 `내일은 월삭인즉 내가 마땅히 왕을 모시고 앉아 식사를 하여야 할 것이나 나를 보내어 제 삼일 저녁까지 들에 숨게 하고","reference":"사무엘상 20:5","category":"$undefined"},{"id":"7737","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":6,"text":"네 부친이 만일 나를 자세히 묻거든 그 때에 너는 말하기를 다윗이 자기 성 베들레헴으로 급히 가기를 내게 허하라 간청하였사오니 이는 온 가족을 위하여 거기서 매년제를 드릴 때가 됨이니이다 하라","reference":"사무엘상 20:6","category":"$undefined"},{"id":"7738","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":7,"text":"그의 말이 좋다하면 네 종이 평안하려니와 그가 만일 노하면 나를 해하려고 결심한 줄을 알지니","reference":"사무엘상 20:7","category":"$undefined"},{"id":"7739","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":8,"text":"그런즉 원컨대 네 종에게 인자히 행하라 네가 네 종으로 여호와앞에서 너와 맹약케 하였음이니라 그러나 내게 죄악이 있거든 네가 친히 나를 죽이라 나를 네 부친에게로 데려갈 것이 무엇이뇨'","reference":"사무엘상 20:8","category":"$undefined"},{"id":"7740","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":9,"text":"요나단이 가로되 `이 일이 결코 네게 있지 아니하리라 내 부친이 너를 해하려 결심한줄 알면 내가 네게 이르지 아니하겠느냐 ?'","reference":"사무엘상 20:9","category":"$undefined"},{"id":"7741","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":10,"text":"다윗이 요나단에게 이르되 `네 부친이 혹 엄하게 네게 대답하면 누가 그것을 내게 고하겠느냐 ?'","reference":"사무엘상 20:10","category":"$undefined"},{"id":"7742","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":11,"text":"요나단이 다윗에게 이르되 `오라 ! 우리가 들로 가자' 하고 두 사람이 들로 가니라","reference":"사무엘상 20:11","category":"$undefined"},{"id":"7743","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":12,"text":"요나단이 다윗에게 이르되 `이스라엘의 하나님 여호와께서 증거하시거니와 내가 내일이나 모레 이맘때에 내 부친을 살펴서 너 다윗에게 대한 의향이 선하면 내가 보내어 네게 알게 하지 않겠느냐 ?","reference":"사무엘상 20:12","category":"$undefined"},{"id":"7744","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":13,"text":"그러나 만일 내 부친이 너를 해하려 하거늘 내가 이 일을 네게 알게 하여 너를 보내어 평안히 가게 하지 아니하면 여호와께서 나 요나단에게 벌을 내리시고 또 내리시기를 원하노라 여호와께서 내 부친과 함께 하신 것 같이 너와 함께 하시기를 원하노니","reference":"사무엘상 20:13","category":"$undefined"},{"id":"7745","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":14,"text":"너는 나의 사는 날 동안에 여호와의 인자를 내게 베풀어서 나로 죽지 않게 할 뿐 아니라","reference":"사무엘상 20:14","category":"$undefined"},{"id":"7746","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":15,"text":"여호와께서 너 다윗의 대적들을 지면에서 다 끊어버리신 때에도 너는 네 인자를 내 집에서 영영히 끊어 버리지 말라' 하고","reference":"사무엘상 20:15","category":"$undefined"},{"id":"7747","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":16,"text":"이에 요나단이 다윗의 집과 언약하기를 여호와께서는 다윗의 대적들을 치실지어다 하니라","reference":"사무엘상 20:16","category":"$undefined"},{"id":"7748","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":17,"text":"요나단이 다윗을 사랑하므로 그로 다시 맹세케 하였으니 이는 자기 생명을 사랑함 같이 그를 사랑함이었더라","reference":"사무엘상 20:17","category":"$undefined"},{"id":"7749","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":18,"text":"요나단이 다윗에게 이르되 `내일은 월삭인즉 네 자리가 비므로 네가 없음을 자세히 물으실 것이라","reference":"사무엘상 20:18","category":"$undefined"},{"id":"7750","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":19,"text":"너는 사흘을 있다가 빨리 내려가서 그 일이 있던 날에 숨었던 곳에 이르러 에셀 바위 곁에 있으라","reference":"사무엘상 20:19","category":"$undefined"},{"id":"7751","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":20,"text":"내가 과녁을 쏘려 함 같이 살 셋을 그 곁에 쏘고","reference":"사무엘상 20:20","category":"$undefined"},{"id":"7752","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":21,"text":"아이를 보내어 가서 살을 찾으라 하며 내가 짐짓 아이에게 이르기를 보라 살이 네 이편에 있으니 가져오라 하거든 너는 돌아올지니 여호와께서 사시거니와 네가 평안 무사할 것이요","reference":"사무엘상 20:21","category":"$undefined"},{"id":"7753","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":22,"text":"만일 아이에게 이르기를 보라 살이 네 앞편에 있다 하거든 네 길을 가라 여호와께서 너를 보내셨음이니라","reference":"사무엘상 20:22","category":"$undefined"},{"id":"7754","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":23,"text":"너와 내가 말한 일에 대하여는 여호와께서 너와 나 사이에 영영토록 계시느니라'","reference":"사무엘상 20:23","category":"$undefined"},{"id":"7755","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":24,"text":"다윗이 들에 숨으니라 월삭이 되매 왕이 앉아 음식을 먹을 때에","reference":"사무엘상 20:24","category":"$undefined"},{"id":"7756","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":25,"text":"왕은 평시와 같이 벽 곁 자기 자리에 앉았고 요나단은 섰고 아브넬은 사울의 곁에 앉았고 다윗의 자리는 비었으나","reference":"사무엘상 20:25","category":"$undefined"},{"id":"7757","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":26,"text":"그러나 그 날에는 사울이 아무 말도 아니하였으니 이는 생각하기를 그에게 무슨 사고가 있어서 부정한가보다 정녕히 부정한가보다 하였음이더니","reference":"사무엘상 20:26","category":"$undefined"},{"id":"7758","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":27,"text":"이튿날 곧 달의 제 이일에도 다윗의 자리가 오히려 비었으므로 사울이 그 아들 요나단에게 묻되 `이새의 아들이 어찌하여 어제와 오늘 식사에 나오지 아니하느뇨 ?'","reference":"사무엘상 20:27","category":"$undefined"},{"id":"7759","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":28,"text":"요나단이 사울에게 대답하되 `다윗이 내게 베들레헴으로 가기를 간청하여","reference":"사무엘상 20:28","category":"$undefined"},{"id":"7760","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":29,"text":"가로되 청컨대 나로 가게 하라 우리 가족이 그 성에서 제사할 일이 있으므로 나의 형이 내게 오기를 명하였으니 내가 네게 사랑을 받거든 나로 가서 내 형들을 보게 하라 하였으므로 그가 왕의 식사 자리에 오지 아니하였나이다'","reference":"사무엘상 20:29","category":"$undefined"},{"id":"7761","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":30,"text":"사울이 요나단에게 노를 발하고 그에게 이르되 `패역부도의 계집의 소생아 ! 네가 이새의 아들을 택한 것이 네 수치와 네 어미의 벌거벗은 수치됨을 내가 어찌 알지 못하랴","reference":"사무엘상 20:30","category":"$undefined"},{"id":"7762","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":31,"text":"이새의 아들이 땅에 사는 동안은 너와 네 나라가 든든히 서지 못하리라 그런즉 이제 보내어 그를 내게로 끌어오라 그는 죽어야 할 자니라'","reference":"사무엘상 20:31","category":"$undefined"},{"id":"7763","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":32,"text":"요나단이 그 부친 사울에게 대답하여 가로되 `그가 죽을 일이 무엇이니이까 무엇을 행하였나이까 ?'","reference":"사무엘상 20:32","category":"$undefined"},{"id":"7764","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":33,"text":"사울이 요나단에게 단창을 던져 치려 한지라 요나단이 그 부친이 다윗을 죽이기로 결심한 줄 알고","reference":"사무엘상 20:33","category":"$undefined"},{"id":"7765","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":34,"text":"심히 노하여 식사 자리에서 떠나고 달의 제 이일에는 먹지 아니하였으니 이는 그 부친이 다윗을 욕되게 하였으므로 다윗을 위하여 슬퍼함이었더라","reference":"사무엘상 20:34","category":"$undefined"},{"id":"7766","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":35,"text":"아침에 요나단이 작은 아이를 데리고 다윗과 정한 시간에 들로 나가서","reference":"사무엘상 20:35","category":"$undefined"},{"id":"7767","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":36,"text":"아이에게 이르되 `달려가서 나의 쏘는 살을 찾으라' 하고 아이가 달려 갈 때에 요나단이 살을 그의 위로 지나치게 쏘니라","reference":"사무엘상 20:36","category":"$undefined"},{"id":"7768","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":37,"text":"아이가 요나단의 쏜 살 있는 곳에 이를 즈음에 요나단이 아이 뒤에서 외쳐 가로되 `살이 네 앞편에 있지 아니하냐' 하고","reference":"사무엘상 20:37","category":"$undefined"},{"id":"7769","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":38,"text":"요나단이 아이 뒤에서 또 외치되 `지체 말고 빨리 달음질하라' 하매 요나단의 아이가 살을 주워가지고 주인에게로 돌아왔으나","reference":"사무엘상 20:38","category":"$undefined"},{"id":"7770","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":39,"text":"그 아이는 아무런지 알지 못하고 요나단과 다윗만 그일을 알았더라","reference":"사무엘상 20:39","category":"$undefined"},{"id":"7771","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":40,"text":"요나단이 그 병기를 아이에게 주며 이르되 `이것을 가지고 성으로 가라'","reference":"사무엘상 20:40","category":"$undefined"},{"id":"7772","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":41,"text":"아이가 가매 다윗이 곧 바위 남편에서 일어나서 땅에 엎드려 세번 절한 후에 피차 입맞추고 같이 울되 다윗이 더욱 심하더니","reference":"사무엘상 20:41","category":"$undefined"},{"id":"7773","book":"사무엘상","book_name":"사무엘상","chapter":20,"verse":42,"text":"요나단이 다윗에게 이르되 `평안히 가라 ! 우리 두 사람이 여호와의 이름으로 맹세하여 이르기를 여호와께서 영원히 나와 너 사이에 계시고 내 자손과 네 자손 사이에 계시리라' 하였느니라 다윗은 일어나 떠나고 요나단은 성으로 들어오니라","reference":"사무엘상 20:42","category":"$undefined"}],"bookSlug":"1samuel"}]
