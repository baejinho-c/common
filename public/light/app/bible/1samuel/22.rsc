2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":22,"verses":[{"id":"7789","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":1,"text":"그러므로 다윗이 그곳을 떠나 아둘람 굴로 도망하매 그 형제와 아비의 온 집이 듣고는 그리로 내려가서 그에게 이르렀고","reference":"사무엘상 22:1","category":"$undefined"},{"id":"7790","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":2,"text":"환난 당한 모든 자와 빚진 자와 마음이 원통한 자가 다 그에게로 모였고 그는 그 장관이 되었는데 그와 함께 한 자가 사백명 가량이었더라","reference":"사무엘상 22:2","category":"$undefined"},{"id":"7791","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":3,"text":"다윗이 거기서 모압 미스베로 가서 모압 왕에게 이르되 `하나님이 나를 위하여 어떻게 하실 것을 내가 알기까지 나의 부모로 나와서 당신들과 함께 있게 하기를 청하나이다' 하고","reference":"사무엘상 22:3","category":"$undefined"},{"id":"7792","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":4,"text":"부모를 인도하여 모압 왕 앞에 나아갔더니 그들이 다윗의 요새에 있을 동안에 모압 왕과 함께 있었더라","reference":"사무엘상 22:4","category":"$undefined"},{"id":"7793","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":5,"text":"선지자 갓이 다윗에게 이르되 `이 요새에 있지 말고 떠나 유다땅으로 들어가라' 다윗이 떠나 헤렛 수풀에 이르니라","reference":"사무엘상 22:5","category":"$undefined"},{"id":"7794","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":6,"text":"사울이 다윗과 그와 함께 있는 사람들이 나타났다함을 들으니라 때에 사울이 기브아 높은 곳에서 손에 단창을 들고 에셀나무 아래 앉았고 모든 신하들은 그 곁에 섰더니","reference":"사무엘상 22:6","category":"$undefined"},{"id":"7795","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":7,"text":"사울이 곁에 선 신하들에게 이르되 `너희 베냐민 사람들아, 들으라 ! 이새의 아들이 너희에게 각기 밭과 포도원을 주며 너희로 천부장 백부장을 삼겠느냐 ?","reference":"사무엘상 22:7","category":"$undefined"},{"id":"7796","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":8,"text":"너희가 다 공모하여 나를 대적하며 내 아들이 이새의 아들과 맹약하였으되 내게 고발하는 자가 하나도 없고 나를 위하여 슬퍼하거나 내 아들이 내 신하를 선동하여 오늘이라도 매복하였다가 나를 치려 하는 것을 내게 고발하는 자가 하나도 없도다'","reference":"사무엘상 22:8","category":"$undefined"},{"id":"7797","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":9,"text":"때에 에돔 사람 도엑이 사울의 신하 중에 섰더니 대답하여 가로되 이새의 아들이 놉에 와서 아히둡의 아들 아히멜렉에게 이른 것을 내가 보았었는데","reference":"사무엘상 22:9","category":"$undefined"},{"id":"7798","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":10,"text":"아히멜렉이 그를 위하여 여호와께 묻고 그에게 식물도 주고 블레셋 사람 골리앗의 칼도 주더이다","reference":"사무엘상 22:10","category":"$undefined"},{"id":"7799","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":11,"text":"왕이 보내어 아히둡의 아들 제사장 아히멜렉과 그 아비의 온 집 곧 놉에 있는 제사장들을 부르매 그들이 다 왕께 이른지라","reference":"사무엘상 22:11","category":"$undefined"},{"id":"7800","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":12,"text":"사울이 가로되 `너 아히둡의 아들아 들으라' 대답하되 `내 주여 내가 여기 있나이다'","reference":"사무엘상 22:12","category":"$undefined"},{"id":"7801","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":13,"text":"사울이 그에게 이르되 `네가 어찌하여 이새의 아들과 공모하여 나를 대적하여 그에게 떡과 칼을 주고 그를 위하여 하나님께 물어서 그로 오늘이라도 매복하였다가 나를 치게 하려 하였느뇨 ?'","reference":"사무엘상 22:13","category":"$undefined"},{"id":"7802","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":14,"text":"아히멜렉이 왕에게 대답하여 가로되 `왕의 모든 신하 중에 다윗 같이 충실한 자가 누구인지요 그는 왕의 사위도 되고 왕의 모신도 되고 왕실에서 존귀한 자가 아니니이까 ?","reference":"사무엘상 22:14","category":"$undefined"},{"id":"7803","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":15,"text":"내가 그를 위하여 하나님께 물은 것이 오늘이 처음이니이까 ? 결단코 아니니이다 원컨대 왕은 종과 종의 아비의 온 집에 아무것도 돌리지 마옵소서 왕의 종은 이 모든 일의 대소간에 아는 것이 없나이다'","reference":"사무엘상 22:15","category":"$undefined"},{"id":"7804","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":16,"text":"왕이 가로되 `아히멜렉아 네가 반드시 죽을 것이요 네 아비의 온 집도 그러하리라' 하고","reference":"사무엘상 22:16","category":"$undefined"},{"id":"7805","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":17,"text":"왕이 좌우의 시위자에게 이르되 `돌이켜 가서 여호와의 제사장들을 죽이라 그들도 다윗과 합력하였고 또 그들이 다윗의 도망한 것을 알고도 내게 고발치 아니하였음이니라' 하나 왕의 신하들이 손을 들어 여호와의 제사장들 죽이기를 싫어한지라","reference":"사무엘상 22:17","category":"$undefined"},{"id":"7806","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":18,"text":"왕이 도엑에게 이르되 `너는 돌이켜 제사장들을 죽이라' 하매 에돔 사람 도엑이 돌이켜 제사장들을 쳐서 그 날에 세마포 에봇 입은 자 팔십 오인을 죽였고","reference":"사무엘상 22:18","category":"$undefined"},{"id":"7807","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":19,"text":"제사장들의 성읍 놉의 남녀와 아이들과 젖먹는 자들과 소와 나귀와 양을 칼로 쳤더라","reference":"사무엘상 22:19","category":"$undefined"},{"id":"7808","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":20,"text":"아히둡의 아들 아히멜렉의 아들 중 하나가 피하였으니 그 이름은 아비아달이라 그가 도망하여 다윗에게로 가서","reference":"사무엘상 22:20","category":"$undefined"},{"id":"7809","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":21,"text":"사울이 여호와의 제사장들 죽인 일을 다윗에게 고하매","reference":"사무엘상 22:21","category":"$undefined"},{"id":"7810","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":22,"text":"다윗이 아비아달에게 이르되 `그 날에 에돔 사람 도엑이 거기 있기로 그가 반드시 사울에게 고할 줄 내가 알았노라 네 아비 집의 모든 사람 죽은 것이 나의 연고로다","reference":"사무엘상 22:22","category":"$undefined"},{"id":"7811","book":"사무엘상","book_name":"사무엘상","chapter":22,"verse":23,"text":"두려워 말고 내게 있으라 ! 내 생명을 찾는 자가 네 생명도 찾는 자니 네가 나와 함께 있으면 보전하리라' 하니라","reference":"사무엘상 22:23","category":"$undefined"}],"bookSlug":"1samuel"}]
