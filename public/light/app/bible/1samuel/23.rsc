2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":23,"verses":[{"id":"7812","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":1,"text":"혹이 다윗에게 고하여 가로되 `보소서 블레셋 사람이 그일라를 쳐서 그 타작 마당을 탈취하더이다'","reference":"사무엘상 23:1","category":"$undefined"},{"id":"7813","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":2,"text":"이에 다윗이 여호와께 묻자와 가로되 `내가 가서 이 블레셋 사람을 치리이까 ?' 여호와께서 다윗에게 이르시되 가서 블레셋 사람을 치고 그일라를 구원하라 하시니","reference":"사무엘상 23:2","category":"$undefined"},{"id":"7814","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":3,"text":"다윗의 사람들이 그에게 이르되 `보소서 우리가 유다에 있기도 두렵거든 하물며 그일라에 가서 블레셋 사람의 군대를 치는 일이리이까 ?'","reference":"사무엘상 23:3","category":"$undefined"},{"id":"7815","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":4,"text":"다윗이 여호와께 다시 묻자온대 여호와께서 대답하여 가라사대 일어나 그일라로 내려가라 내가 블레셋 사람을 네 손에 붙이리라 하신지라","reference":"사무엘상 23:4","category":"$undefined"},{"id":"7816","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":5,"text":"다윗과 그의 사람들이 그일라로 가서 블레셋 사람과 싸워 그들을 크게 도륙하고 그들의 가축을 끌어오니라 다윗이 이와 같이 그일라 거민을 구원하니라","reference":"사무엘상 23:5","category":"$undefined"},{"id":"7817","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":6,"text":"아히멜렉의 아들 아비아달이 그일라 다윗에게로 도망할 때에 손에 에봇을 가지고 내려왔었더라","reference":"사무엘상 23:6","category":"$undefined"},{"id":"7818","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":7,"text":"다윗이 그일라에 온 것을 혹이 사울에게 고하매 사울이 가로되 하나님이 그를 내 손에 붙이셨도다 그가 문과 문빗장이 있는 성에 들어갔으니 갇혔도다","reference":"사무엘상 23:7","category":"$undefined"},{"id":"7819","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":8,"text":"사울이 모든 백성을 군사로 불러 모으고 그일라로 내려가서 다윗과 그의 사람들을 에워싸려 하더니","reference":"사무엘상 23:8","category":"$undefined"},{"id":"7820","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":9,"text":"다윗이 사울의 자기를 해하려 하는 계교를 알고 제사장 아비아달에게 이르되 `에봇을 이리로 가져 오라' 하고","reference":"사무엘상 23:9","category":"$undefined"},{"id":"7821","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":10,"text":"다윗이 가로되 `이스라엘 하나님 여호와여 ! 사울이 나의 연고로 이성을 멸하려고 그일라로 내려오기를 꾀한다 함을 주의 종이 분명히 들었나이다","reference":"사무엘상 23:10","category":"$undefined"},{"id":"7822","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":11,"text":"그일라 사람들이 나를 그의 손에 붙이겠나이까 ? 주의 종의 들은대로 사울이 내려 오겠나이까 ? 이스라엘의 하나님 여호와여 ! 원컨대 주의 종에게 일러 주옵소서' 여호와께서 가라사대 그가 내려 오리라","reference":"사무엘상 23:11","category":"$undefined"},{"id":"7823","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":12,"text":"다윗이 가로되 `그일라 사람들이 나와 내 사람들을 사울의 손에 붙이겠나이까 ?' 여호와께서 가라사대 그들이 너를 붙이리라","reference":"사무엘상 23:12","category":"$undefined"},{"id":"7824","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":13,"text":"다윗과 그의 사람 육백명 가량이 일어나 그일라를 떠나서 갈 수 있는 곳으로 갔더니 다윗이 그일라에서 피한 것을 혹이 사울에게 고하매 사울이 가기를 그치니라","reference":"사무엘상 23:13","category":"$undefined"},{"id":"7825","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":14,"text":"다윗이 황무지 요새에도 있었고 또 십 황무지 산골에도 유하였으므로 사울이 매일 찾되 하나님이 그를 그의 손에 붙이지 아니하시니라","reference":"사무엘상 23:14","category":"$undefined"},{"id":"7826","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":15,"text":"다윗이 사울의 자기 생명을 찾으려고 나온 것을 보았으므로 그가 십 황무지 수풀에 있었더니","reference":"사무엘상 23:15","category":"$undefined"},{"id":"7827","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":16,"text":"사울의 아들 요나단이 일어나 수풀에 들어가서 다윗에게 이르러 그로 하나님을 힘있게 의지하게 하였는데","reference":"사무엘상 23:16","category":"$undefined"},{"id":"7828","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":17,"text":"곧 요나단이 그에게 이르기를 `두려워 말라 ! 내 부친 사울의 손이 네게 미치지 못할 것이요 너는 이스라엘 왕이 되고 나는 네 다음이 될 것을 내 부친 사울도 안다' 하니라","reference":"사무엘상 23:17","category":"$undefined"},{"id":"7829","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":18,"text":"두사람이 여호와 앞에서 언약하고 다윗은 수풀에 거하고 요나단은 자기 집으로 돌아가니라","reference":"사무엘상 23:18","category":"$undefined"},{"id":"7830","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":19,"text":"때에 십 사람들이 기브아에 이르러 사울에게 나아와 가로되 `다윗이 우리와 함께 광야 남편 하길라산 수풀 요새에 숨지 아니하였나이까 ?","reference":"사무엘상 23:19","category":"$undefined"},{"id":"7831","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":20,"text":"그러하온즉 왕은 내려오시기를 원하시는 대로 내려 오소서 그를 왕의 손에 붙일 것이 우리의 의무니이다'","reference":"사무엘상 23:20","category":"$undefined"},{"id":"7832","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":21,"text":"사울이 가로되 `너희가 나를 긍휼히 여겼으니 여호와께 복받기를 원하노라'","reference":"사무엘상 23:21","category":"$undefined"},{"id":"7833","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":22,"text":"혹이 내게 말하기를 `그가 심히 공교히 행동한다 하나니 너희는 가서 더 자세히 살펴서 그가 어디 은적하였으며 누가 거기서 그를 보았는지 알아보고","reference":"사무엘상 23:22","category":"$undefined"},{"id":"7834","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":23,"text":"그가 숨어 있는 모든 곳을 탐지하고 실상을 내게 회보하라 내가 너희와 함께 가리니 그가 이 땅에 있으면 유다 천천인 중에서 그를 찾아내리라'","reference":"사무엘상 23:23","category":"$undefined"},{"id":"7835","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":24,"text":"그들이 일어나 사울보다 먼저 십으로 가니라 다윗과 그의 사람들이 광야 남편 마온 황무지 아라바에 있더니","reference":"사무엘상 23:24","category":"$undefined"},{"id":"7836","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":25,"text":"사울과 그의 사람들이 찾으러 온 것을 혹이 다윗에게 고하매 이에 다윗이 바위로 내려 마온 황무지에 있더니 사울이 듣고 마온 황무지로 다윗을 따라가서는","reference":"사무엘상 23:25","category":"$undefined"},{"id":"7837","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":26,"text":"사울이 산 이편으로 가매 다윗과 그의 사람들은 산 저편으로 가며 다윗이 사울을 두려워하여 급히 피하려 하였으니 이는 사울과 그의 사람들이 다윗과 그의 사람들을 에워싸고 잡으려 함이었더라","reference":"사무엘상 23:26","category":"$undefined"},{"id":"7838","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":27,"text":"사자가 사울에게 와서 가로되 `급히 오소서 블레셋 사람이 땅을 침노하나이다`","reference":"사무엘상 23:27","category":"$undefined"},{"id":"7839","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":28,"text":"이에 사울이 다윗 쫓기를 그치고 돌아와서 블레셋 사람을 치러 갔으므로 그 곳을 셀라하마느곳이라 칭하니라","reference":"사무엘상 23:28","category":"$undefined"},{"id":"7840","book":"사무엘상","book_name":"사무엘상","chapter":23,"verse":29,"text":"다윗이 거기서 올라가서 엔게디 요새에 거하니라","reference":"사무엘상 23:29","category":"$undefined"}],"bookSlug":"1samuel"}]
