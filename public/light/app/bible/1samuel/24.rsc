2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":24,"verses":[{"id":"7841","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":1,"text":"사울이 블레셋 사람을 따르다가 돌아오매 혹이 그에게 고하여 가로되 `보소서 다윗이 엔게디 황무지에 있더이다'","reference":"사무엘상 24:1","category":"$undefined"},{"id":"7842","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":2,"text":"사울이 온 이스라엘에서 택한 사람 삼천을 거느리고 다윗과 그의 사람들을 찾으러 들염소 바위로 갈새","reference":"사무엘상 24:2","category":"$undefined"},{"id":"7843","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":3,"text":"길 가 양의 우리에 이른즉 굴이 있는지라 사울이 그 발을 가리우러 들어가니라 다윗과 그의 사람들이 그 굴 깊은 곳에 있더니","reference":"사무엘상 24:3","category":"$undefined"},{"id":"7844","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":4,"text":"다윗의 사람들이 가로되 `보소서 ! 여호와께서 당신에게 이르시기를 내가 원수를 네 손에 붙이리니 네 소견에 선한대로 그에게 행하라 하시더니 이것이 그 날이니이다' 다윗이 일어나서 사울의 겉옷자락을 가만히 베니라","reference":"사무엘상 24:4","category":"$undefined"},{"id":"7845","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":5,"text":"그리한 후에 사울의 옷자락 벰을 인하여 다윗의 마음이 찔려","reference":"사무엘상 24:5","category":"$undefined"},{"id":"7846","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":6,"text":"자기 사람들에게 이르되 `내가 손을 들어 여호와의 기름 부음을 받은 내 주를 치는 것은 여호와의 금하시는 것이니 그는 여호와의 기름 부음을 받은 자가 됨이니라' 하고","reference":"사무엘상 24:6","category":"$undefined"},{"id":"7847","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":7,"text":"다윗이 이 말로 자기 사람들을 금하여 사울을 해하지 못하게 하니라 사울이 일어나 굴에서 나가 자기 길을 가니라","reference":"사무엘상 24:7","category":"$undefined"},{"id":"7848","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":8,"text":"그 후에 다윗도 일어나 굴에서 나가 사울의 뒤에서 외쳐 가로되 `내 주 왕이여 !' 하매 사울이 돌아보는지라 다윗이 땅에 엎드려 절하고","reference":"사무엘상 24:8","category":"$undefined"},{"id":"7849","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":9,"text":"사울에게 이르되 `다윗이 왕을 해하려 한다고 하는 사람들의 말을 왕은 어찌하여 들으시나이까 ?","reference":"사무엘상 24:9","category":"$undefined"},{"id":"7850","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":10,"text":"오늘 여호와께서 굴에서 왕을 내 손에 붙이신 것을 왕이 아셨을 것이니이다 혹이 나를 권하여 왕을 죽이라 하였으나 내가 왕을 아껴 말하기를 나는 내 손을 들어 내 주를 해치 아니하리니 그는 여호와의 기름 부음을 받은 자가 됨이니라 하였나이다","reference":"사무엘상 24:10","category":"$undefined"},{"id":"7851","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":11,"text":"나의 아버지여 ! 보소서 내 손에 있는 왕의 옷자락을 보소서 내가 왕을 죽이지 아니하고 겉옷자락만 베었은즉 나의 손에 악이나 죄과가 없는 줄을 아실지니이다 왕은 내 생명을 찾아 해하려 하시나 나는 왕에게 범죄한 일이 없나이다","reference":"사무엘상 24:11","category":"$undefined"},{"id":"7852","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":12,"text":"여호와께서는 나와 왕 사이를 판단하사 나를 위하여 왕에게 보복하시려니와 내 손으로는 왕을 해하지 않겠나이다","reference":"사무엘상 24:12","category":"$undefined"},{"id":"7853","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":13,"text":"옛 속담에 말하기를 악은 악인에게서 난다 하였으니 내 손이 왕을 해하지 아니하리이다","reference":"사무엘상 24:13","category":"$undefined"},{"id":"7854","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":14,"text":"이스라엘 왕이 누구를 따라 나왔으며 누구를 쫓나이까 ? 죽은 개나 벼룩을 쫓음이니이다","reference":"사무엘상 24:14","category":"$undefined"},{"id":"7855","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":15,"text":"그런즉 여호와께서 재판장이 되어 나와 왕 사이에 판결하사 나의 사정을 살펴 신원하시고 나를 왕의 손에서 건지시기를 원하나이다'","reference":"사무엘상 24:15","category":"$undefined"},{"id":"7856","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":16,"text":"다윗이 사울에게 이같이 말하기를 마치매 사울이 가로되 `내 아들 다윗아 이것이 네 목소리냐 ?' 하고 소리를 높여 울며","reference":"사무엘상 24:16","category":"$undefined"},{"id":"7857","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":17,"text":"다윗에게 이르되 `나는 너를 학대하되 너는 나를 선대하니 너는 나보다 의롭도다","reference":"사무엘상 24:17","category":"$undefined"},{"id":"7858","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":18,"text":"네가 나 선대한 것을 오늘 나타내었나니 여호와께서 나를 네 손에 붙이셨으나 네가 나를 죽이지 아니하였도다","reference":"사무엘상 24:18","category":"$undefined"},{"id":"7859","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":19,"text":"사람이 그 원수를 만나면 그를 평안히 가게 하겠느냐 네가 오늘날 내게 행한 일을 인하여 여호와께서 네게 선으로 갚으시기를 원하노라","reference":"사무엘상 24:19","category":"$undefined"},{"id":"7860","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":20,"text":"보라 나는 네가 반드시 왕이 될 것을 알고 이스라엘 나라가 네 손에 견고히 설 것을 아노니","reference":"사무엘상 24:20","category":"$undefined"},{"id":"7861","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":21,"text":"그런즉 너는 내 후손을 끊지 아니하며 내 아비의 집에서 내 이름을 멸하지 아니할 것을 이제 여호와로 내게 맹세하라'","reference":"사무엘상 24:21","category":"$undefined"},{"id":"7862","book":"사무엘상","book_name":"사무엘상","chapter":24,"verse":22,"text":"다윗이 사울에게 맹세하매 사울은 집으로 돌아가고 다윗과 그의 사람들은 요새로 올라가니라","reference":"사무엘상 24:22","category":"$undefined"}],"bookSlug":"1samuel"}]
