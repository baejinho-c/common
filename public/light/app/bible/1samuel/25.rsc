2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":25,"verses":[{"id":"7863","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":1,"text":"사무엘이 죽으매 온 이스라엘 무리가 모여 그를 애곡하며 라마 그의 집에서 그를 장사한지라 다윗이 일어나 바란 광야로 내려가니라","reference":"사무엘상 25:1","category":"$undefined"},{"id":"7864","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":2,"text":"마온에 한 사람이 있는데 그 업이 갈멜에 있고 심히 부하여 양이 삼천이요 염소가 일천이므로 그가 갈멜에서 그 양털을 깎고 있었으니","reference":"사무엘상 25:2","category":"$undefined"},{"id":"7865","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":3,"text":"그 사람의 이름은 나발이요 그 아내의 이름은 아비가일이라 그 여자는 총명하고 용모가 아름다우나 남자는 완고하고 행사가 악하며 그는 갈멜 족속이었더라","reference":"사무엘상 25:3","category":"$undefined"},{"id":"7866","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":4,"text":"다윗이 광야에 있어서 나발이 자기 양털을 깎는다 함을 들은지라","reference":"사무엘상 25:4","category":"$undefined"},{"id":"7867","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":5,"text":"다윗이 이에 열 소년을 보내며 그 소년들에게 이르되 `너희는 갈멜로 올라가 나발에게 이르러 내 이름으로 그에게 문안하고","reference":"사무엘상 25:5","category":"$undefined"},{"id":"7868","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":6,"text":"이같이 그 부하게 사는 자에게 이르기를 너는 평강하라, 네 집도 평강하라, 네 소유의 모든 것도 평강하라,","reference":"사무엘상 25:6","category":"$undefined"},{"id":"7869","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":7,"text":"네게 양털 깎는 자들이 있다 함을 이제 내가 들었노라 네 목자들이 우리와 함께 있었으나 우리가 그들을 상치 아니하였고 그들이 갈멜에 있는 동안에 그들의 것을 하나도 잃지 아니하였나니","reference":"사무엘상 25:7","category":"$undefined"},{"id":"7870","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":8,"text":"네 소년들에게 물으면 그들이 네게 고하리라 그런즉 내 소년들로 네게 은혜를 얻게 하라 우리가 좋은 날에 왔은즉 네 손에 있는 대로 네 종들과 네 아들 다윗에게 주기를 원하노라 하더라' 하라","reference":"사무엘상 25:8","category":"$undefined"},{"id":"7871","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":9,"text":"다윗의 소년들이 가서 다윗의 이름으로 이 모든 말을 나발에게 고하기를 마치매","reference":"사무엘상 25:9","category":"$undefined"},{"id":"7872","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":10,"text":"나발이 다윗의 사환들에게 대답하여 가로되 `다윗은 누구며 이새의 아들은 누구뇨 근일에 각기 주인에게서 억지로 떠나는 종이 많도다","reference":"사무엘상 25:10","category":"$undefined"},{"id":"7873","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":11,"text":"내가 어찌 내 떡과 물과 내 양털 깎는 자를 위하여 잡은 고기를 가져 어디로서인지 알지도 못하는 자들에게 주겠느냐 ?' 한지라","reference":"사무엘상 25:11","category":"$undefined"},{"id":"7874","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":12,"text":"이에 다윗의 소년들이 돌이켜 자기 길로 행하여 돌아와서 이 모든 말로 그에게 고하매","reference":"사무엘상 25:12","category":"$undefined"},{"id":"7875","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":13,"text":"다윗이 자기 사람들에게 이르되 `너희는 각기 칼을 차라' 각기 칼을 차매 다윗도 자기 칼을 차고 사백명 가량은 데리고 올라가고 이백명은 소유물 곁에 있게 하니라","reference":"사무엘상 25:13","category":"$undefined"},{"id":"7876","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":14,"text":"소년중 하나가 나발의 아내 아비가일에게 고하여 가로되 `다윗이 우리 주인에게 문안하러 광야에서 사자들을 보내었거늘 주인이 그들을 수욕하였나이다","reference":"사무엘상 25:14","category":"$undefined"},{"id":"7877","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":15,"text":"우리가 들에 있어 그들과 상종할 동안에 그 사람들이 우리를 매우 선대하였으므로 우리가 상하거나 잃은 것이 없었으니","reference":"사무엘상 25:15","category":"$undefined"},{"id":"7878","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":16,"text":"우리가 양을 지키는 동안에 그들이 우리와 함께 있어 밤낮 우리에게 담이 되었음이라","reference":"사무엘상 25:16","category":"$undefined"},{"id":"7879","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":17,"text":"그런즉 이제 당신은 어떻게 할 것을 알아 생각하실지니 이는 다윗이 우리 주인과 주인의 온 집을 해하기로 결정하였음이니이다 주인은 불량한 사람이라 더불어 말할 수 없나이다'","reference":"사무엘상 25:17","category":"$undefined"},{"id":"7880","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":18,"text":"아비가일이 급히 떡 이백 덩이와 포도주 두 가죽 부대와 잡아 준비한 양 다섯과 볶은 곡식 다섯 세아와 건포도 백송이와 무화과뭉치 이백을 취하여 나귀들에게 싣고","reference":"사무엘상 25:18","category":"$undefined"},{"id":"7881","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":19,"text":"소년들에게 이르되 `내 앞서 가라 나는 너희 뒤에 가리라' 하고 그 남편 나발에게는 고하지 아니하니라","reference":"사무엘상 25:19","category":"$undefined"},{"id":"7882","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":20,"text":"아비가일이 나귀를 타고 산 유벽한 곳으로 좇아 내려가더니 다윗과 그의 사람들이 자기에게로 마주 내려오는 것을 만나니라","reference":"사무엘상 25:20","category":"$undefined"},{"id":"7883","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":21,"text":"다윗이 이미 말하기를 `내가 이 자의 소유물을 광야에서 지켜 그 모든 것을 하나도 손실이 없게 한 것이 진실로 허사라 그가 악으로 나의 선을 갚는도다","reference":"사무엘상 25:21","category":"$undefined"},{"id":"7884","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":22,"text":"내가 그에게 속한 모든 것 중 한 남자라도 아침까지 남겨두면 하나님은 다윗에게 벌을 내리시고 또 내리시기를 원하노라' 하였더라","reference":"사무엘상 25:22","category":"$undefined"},{"id":"7885","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":23,"text":"아비가일이 다윗을 보고 급히 나귀에서 내려 다윗의 앞에 엎드려 그 얼굴을 땅에 대니라","reference":"사무엘상 25:23","category":"$undefined"},{"id":"7886","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":24,"text":"그가 다윗의 발에 엎드려 가로되 `내 주여 ! 청컨대 이 죄악을 나 곧 내게로 돌리시고 여종으로 주의 귀에 말하게 하시고 이 여종의 말을 들으소서","reference":"사무엘상 25:24","category":"$undefined"},{"id":"7887","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":25,"text":"원하옵나니 내 주는 이 불량한 사람 나발을 개의치 마옵소서 그 이름이 그에게 적당하니 그 이름이 나발이라 그는 미련한 자니이다 여종은 내 주의 보내신 소년들을 보지 못하였나이다","reference":"사무엘상 25:25","category":"$undefined"},{"id":"7888","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":26,"text":"내 주여 여호와께서 사시고 내 주도 살아계시거니와 내 주의 손으로 피를 흘려 친히 보수하시는 일을 여호와께서 막으셨으니 내 주의 원수들과 내 주를 해하려 하는자들은 나발과 같이 되기를 원하나이다","reference":"사무엘상 25:26","category":"$undefined"},{"id":"7889","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":27,"text":"여종이 내 주에게 가져온 이 예물로 내 주를 좇는 이 소년들에게 주게 하시고","reference":"사무엘상 25:27","category":"$undefined"},{"id":"7890","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":28,"text":"주의 여종의 허물을 사하여 주옵소서 ! 여호와께서 반드시 내 주를 위하여 든든한 집을 세우시리니 이는 내 주께서 여호와의 싸움을 싸우심이요 내 주의 일생에 내 주에게서 악한 일을 찾을 수 없음이니이다","reference":"사무엘상 25:28","category":"$undefined"},{"id":"7891","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":29,"text":"사람이 일어나서 내 주를 쫓아 내 주의 생명을 찾을지라도 내 주의 생명은 내 주의 하나님 여호와와 함께 생명싸개 속에 싸였을 것이요 내 주의 원수들의 생명은 물매로 던지듯 여호와께서 그것을 던지시리이다","reference":"사무엘상 25:29","category":"$undefined"},{"id":"7892","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":30,"text":"여호와께서 내 주에 대하여 하신 말씀대로 모든 선을 내 주에게 행하사 내 주를 이스라엘의 지도자로 세우신 때에","reference":"사무엘상 25:30","category":"$undefined"},{"id":"7893","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":31,"text":"내 주께서 무죄한 피를 흘리셨다든지 내 주께서 친히 보수하셨다든지 함을 인하여 슬퍼하실 것도 없고 내 주의 마음에 걸리는 것도 없으시리니 다만 여호와께서 내 주를 후대하신 때에 원컨대 내 주의 여종을 생각하소서'","reference":"사무엘상 25:31","category":"$undefined"},{"id":"7894","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":32,"text":"다윗이 아비가일에게 이르되 `오늘날 너를 보내어 나를 영접케 하신 이스라엘의 하나님 여호와를 찬송할지로다 !","reference":"사무엘상 25:32","category":"$undefined"},{"id":"7895","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":33,"text":"또 네 지혜를 칭찬할지며 또 네게 복이 있을지로다 ! 오늘날 내가 피를 흘릴 것과 친히 보수하는 것을 네가 막았느니라","reference":"사무엘상 25:33","category":"$undefined"},{"id":"7896","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":34,"text":"나를 막아 너를 해하지 않게 하신 이스라엘의 하나님 여호와의 사심으로 맹세하노니 네가 급히 와서 나를 영접지 아니하였더면 밝는 아침에는 과연 나발에게 한 남자도 남겨두지 아니하였으리라'","reference":"사무엘상 25:34","category":"$undefined"},{"id":"7897","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":35,"text":"다윗이 그가 가져온 것을 그의 손에서 받고 그에게 이르되 `네 집으로 평안히 올라가라 내가 네 말을 듣고 네 청을 허락하노라'","reference":"사무엘상 25:35","category":"$undefined"},{"id":"7898","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":36,"text":"아비가일이 나발에게로 돌아오니 그가 왕의 잔치 같은 잔치를 그집에 배설하고 대취하여 마음에 기뻐하므로 아비가일이 밝는 아침까지는 다소간 말하지 아니하다가","reference":"사무엘상 25:36","category":"$undefined"},{"id":"7899","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":37,"text":"아침에 나발이 포도주가 깬 후에 그 아내가 그에게 이 일을 고하매 그가 낙담하여 몸이 돌과 같이 되었더니","reference":"사무엘상 25:37","category":"$undefined"},{"id":"7900","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":38,"text":"한 열흘 후에 여호와께서 나발을 치시매 그가 죽으니라","reference":"사무엘상 25:38","category":"$undefined"},{"id":"7901","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":39,"text":"다윗이 나발의 죽었다 함을 듣고 가로되 `나발에게 당한 나의 욕을 신설하사 종으로 악한 일을 하지 않게 하신 여호와를 찬송할지로다 ! 여호와께서 나발의 악행을 그 머리에 돌리셨도다' 하니라 다윗이 아비가일로 자기 아내를 삼으려고 보내어 그에게 말하게 하매","reference":"사무엘상 25:39","category":"$undefined"},{"id":"7902","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":40,"text":"다윗의 사환들이 갈멜에 가서 아비가일에게 이르러 그에게 일러 가로되 `다윗이 당신을 아내로 삼고자 하여 우리를 당신께 보내더이다'","reference":"사무엘상 25:40","category":"$undefined"},{"id":"7903","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":41,"text":"그가 일어나 몸을 굽혀 얼굴을 땅에 대고 가로되 `내 주의 여종은 내 주의 사환들의 발 씻길 종이니이다' 하고","reference":"사무엘상 25:41","category":"$undefined"},{"id":"7904","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":42,"text":"급히 일어나서 나귀를 타고 따르는 처녀 다섯과 함께 다윗의 사자들을 따라가서 다윗의 아내가 되니라","reference":"사무엘상 25:42","category":"$undefined"},{"id":"7905","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":43,"text":"다윗이 또 이스르엘 아히노암을 취하였더니 그들 두 사람이 자기 아내가 되니라","reference":"사무엘상 25:43","category":"$undefined"},{"id":"7906","book":"사무엘상","book_name":"사무엘상","chapter":25,"verse":44,"text":"사울이 그 딸 다윗의 아내 미갈을 갈림에 사는 라이스의 아들 발디에게 주었더라","reference":"사무엘상 25:44","category":"$undefined"}],"bookSlug":"1samuel"}]
