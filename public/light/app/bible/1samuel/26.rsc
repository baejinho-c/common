2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":26,"verses":[{"id":"7907","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":1,"text":"십 사람이 기브아에 와서 사울에게 이르러 가로되 `다윗이 광야 앞 하길라 산에 숨지 아니하였나이까 ?'","reference":"사무엘상 26:1","category":"$undefined"},{"id":"7908","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":2,"text":"사울이 일어나 십 황무지에서 다윗을 찾으려고 이스라엘에서 택한 사람 삼천과 함께 십 황무지로 내려가서","reference":"사무엘상 26:2","category":"$undefined"},{"id":"7909","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":3,"text":"광야 앞 하길라산 길 가에 진치니라 다윗이 황무지에 있더니 사울이 자기를 따라 황무지로 들어옴을 깨닫고","reference":"사무엘상 26:3","category":"$undefined"},{"id":"7910","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":4,"text":"이에 탐정을 보내어 사울이 과연 이른줄 알고","reference":"사무엘상 26:4","category":"$undefined"},{"id":"7911","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":5,"text":"일어나 사울의 진 친 곳에 이르러 사울과 넬의 아들 군대장관 아브넬의 유하는 곳을 본즉 사울이 진 가운데 누웠고 백성은 그를 둘러 진쳤더라","reference":"사무엘상 26:5","category":"$undefined"},{"id":"7912","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":6,"text":"이에 다윗이 헷 사람 아히멜렉과 스루야의 아들 요압의 아우 아비새에게 물어 가로되 `누가 나로 더불어 진에 내려가서 사울에게 이르겠느냐 ?' 아비새가 가로되 `내가 함께 가겠나이다'","reference":"사무엘상 26:6","category":"$undefined"},{"id":"7913","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":7,"text":"다윗과 아비새가 밤에 그 백성에게 나아가 본즉 사울이 진 가운데 누워 자고 창은 머리 곁 땅에 꽂혔고 아브넬과 백성들은 그를 둘러 누웠는지라","reference":"사무엘상 26:7","category":"$undefined"},{"id":"7914","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":8,"text":"아비새가 다윗에게 이르되 `하나님이 오늘날 당신의 원수를 당신의 손에 붙이셨나이다 그러므로 청하오니 나로 창으로 그를 찔러서 단번에 땅에 꽂게 하소서 내가 그를 두번 찌를 것이 없으리이다'","reference":"사무엘상 26:8","category":"$undefined"},{"id":"7915","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":9,"text":"다윗이 아비새에게 이르되 `죽이지 말라 누구든지 손을 들어 여호와의 기름 부음을 받은 자를 치면 죄가 없겠느냐 ?'","reference":"사무엘상 26:9","category":"$undefined"},{"id":"7916","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":10,"text":"또 가로되 `여호와께서 사시거니와 여호와께서 그를 치시리니 혹 죽을 날이 이르거나, 혹 전장에 들어가서 망하리라","reference":"사무엘상 26:10","category":"$undefined"},{"id":"7917","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":11,"text":"내가 손을 들어 여호와의 기름 부음을 받은 자를 치는 것을 여호와께서 금하시나니 너는 그의 머리 곁에 있는 창과 물병만 가지고 가자' 하고","reference":"사무엘상 26:11","category":"$undefined"},{"id":"7918","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":12,"text":"다윗이 사울의 머리 곁에서 창과 물병을 가지고 떠나가되 깨든지 이를 보든지 알든지 하는 사람이 없었으니 이는 여호와께서 그들로 깊이 잠들게 하셨으므로 그들이 다 잠이었더라","reference":"사무엘상 26:12","category":"$undefined"},{"id":"7919","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":13,"text":"이에 다윗이 건너편으로 가서 멀리 산꼭대기에 서니 상거가 멀더라","reference":"사무엘상 26:13","category":"$undefined"},{"id":"7920","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":14,"text":"다윗이 백성과 넬의 아들 아브넬을 대하여 외쳐 가로되 `아브넬아, 너는 대답지 아니하느냐 ?' 아브넬이 대답하여 가로되 `왕을 부르는 너는 누구냐 ?'","reference":"사무엘상 26:14","category":"$undefined"},{"id":"7921","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":15,"text":"다윗이 아브넬에게 이르되 `네가 용사가 아니냐 ? 이스라엘 중에 너 같은 자가 누구냐 ? 그러한데 네가 어찌하여 네 주 왕을 보호하지 아니하느냐 ? 백성 중 한 사람이 네 주 왕을 죽이려고 들어갔었느니라","reference":"사무엘상 26:15","category":"$undefined"},{"id":"7922","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":16,"text":"네 행한 이 일이 선치 못하도다 여호와께서 사시거니와 여호와의 기름 부음 받은 너희 주를 보호하지 아니하였으니 너희는 마땅히 죽을 자니라 이제 왕의 창과 왕의 머리곁에 있던 물병이 어디있나 보라'","reference":"사무엘상 26:16","category":"$undefined"},{"id":"7923","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":17,"text":"사울이 다윗의 음성을 알아 듣고 가로되 `내 아들 다윗아 ! 이것이 네 음성이냐 ?' 다윗이 가로되 `내 주 왕이여 ! 내 음성이니이다'","reference":"사무엘상 26:17","category":"$undefined"},{"id":"7924","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":18,"text":"또 가로되 `내 주는 어찌하여 주의 종을 쫓으시나이까 ? 내가 무엇을 하였으며 내 손에 무슨 악이 있나이까 ?","reference":"사무엘상 26:18","category":"$undefined"},{"id":"7925","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":19,"text":"청컨대 내 주 왕은 이제 종의 말을 들으소서 만일 왕을 격동시켜 나를 해하려 하는 이가 여호와시면 여호와께서는 제물을 받으시기를 원하나이다마는 만일 인자들이면 그들이 여호와 앞에 저주를 받으리니 이는 그들이 이르기를 너는 가서 다른 신들을 섬기라하고 오늘날 나를 쫓아내어 여호와의 기업에 붙지 못하게 함이니이다","reference":"사무엘상 26:19","category":"$undefined"},{"id":"7926","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":20,"text":"그런즉 청컨대 여호와 앞에서 먼 이곳에서 이제 나의 피로 땅에 흐르지 말게 하옵소서 이는 산에서 메추라기를 사냥하는 자와 같이 이스라엘 왕이 한 벼룩을 수색하러 나오셨음이니이다'","reference":"사무엘상 26:20","category":"$undefined"},{"id":"7927","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":21,"text":"사울이 가로되 `내가 범죄하였도다 내 아들 다윗아 ! 돌아오라 네가 오늘 내 생명을 귀중히 여겼은즉 내가 다시는 너를 해하려 하지 아니하리라 내가 어리석은 일을 하였으니 대단히 잘못되었도다'","reference":"사무엘상 26:21","category":"$undefined"},{"id":"7928","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":22,"text":"다윗이 대답하여 가로되 `왕은 창을 보소서 한 소년을 보내어 가져가게 하소서","reference":"사무엘상 26:22","category":"$undefined"},{"id":"7929","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":23,"text":"여호와께서 각 사람에게 그 의와 신실을 갚으시리니 이는 여호와께서 오늘날 왕을 내 손에 붙이셨으되 나는 손을 들어 여호와의 기름 부음을 받은 자 치기를 원치 아니하였음이니이다","reference":"사무엘상 26:23","category":"$undefined"},{"id":"7930","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":24,"text":"오늘날 왕의 생명을 내가 중히 여긴 것 같이 내 생명을 여호와께서 중히 여기셔서 모든 환난에서 나를 구하여 내시기를 바라나이다'","reference":"사무엘상 26:24","category":"$undefined"},{"id":"7931","book":"사무엘상","book_name":"사무엘상","chapter":26,"verse":25,"text":"사울이 다윗에게 이르되 `내 아들 다윗아 ! 네게 복이 있을지로다 ! 네가 큰 일을 행하겠고 반드시 승리를 얻으리라' 하니라 다윗은 자기 길로 가고 사울은 자기 곳으로 돌아가니라","reference":"사무엘상 26:25","category":"$undefined"}],"bookSlug":"1samuel"}]
