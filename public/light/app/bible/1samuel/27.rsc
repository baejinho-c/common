2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":27,"verses":[{"id":"7932","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":1,"text":"다윗이 그 마음에 생각하기를 `내가 후일에는 사울의 손에 망하리니 블레셋 사람의 땅으로 피하여 들어가는 것이 상책이로다 사울이 이스라엘 온 경내에서 나를 수색하다가 절망하리니 내가 그 손에서 벗어나리라` 하고","reference":"사무엘상 27:1","category":"$undefined"},{"id":"7933","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":2,"text":"일어나 함께 있는 육백인으로 더불어 가드 왕 마옥의 아들 아기스에게로 건너가니라","reference":"사무엘상 27:2","category":"$undefined"},{"id":"7934","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":3,"text":"다윗과 그의 사람들이 각기 가족을 거느리고 가드에서 아기스와 동거하였는데 다윗이 그 두 아내 이스르엘 여자 아히노암과 나발의 아내 되었던 갈멜 여자 아비가일과 함께 하였더니","reference":"사무엘상 27:3","category":"$undefined"},{"id":"7935","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":4,"text":"다윗이 가드에 도망한 것을 혹이 사울에게 고하매 사울이 다시는 그를 수색하지 아니하니라","reference":"사무엘상 27:4","category":"$undefined"},{"id":"7936","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":5,"text":"다윗이 아기스에게 이르되 `내가 당신께 은혜를 받았거든 지방 성읍 중 한 곳을 주어 나로 거하게 하소서 당신의 종이 어찌 당신과 함께 왕도에 거하리이까 ?'","reference":"사무엘상 27:5","category":"$undefined"},{"id":"7937","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":6,"text":"아기스가 그 날에 시글락을 그에게 주었으므로 시글락이 오늘까지 유다 왕에게 속하니라","reference":"사무엘상 27:6","category":"$undefined"},{"id":"7938","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":7,"text":"다윗이 블레셋 사람의 지방에 거한 날 수는 일년 넉달이었더라","reference":"사무엘상 27:7","category":"$undefined"},{"id":"7939","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":8,"text":"다윗과 그의 사람들이 올라가서 그술 사람과, 기르스 사람과, 아말렉 사람을 침노하였으니 그들은 옛적부터 술과 애굽 땅으로 지나가는 지방의 거민이라","reference":"사무엘상 27:8","category":"$undefined"},{"id":"7940","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":9,"text":"다윗이 그 땅을 쳐서 남녀를 살려 두지 아니하고 양과 소와 나귀와 약대와 의복을 취하고 돌아와서 아기스에게 이르매","reference":"사무엘상 27:9","category":"$undefined"},{"id":"7941","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":10,"text":"아기스가 가로되 `너희가 오늘은 누구를 침노하였느냐 ?' 다윗이 가로되 `유다 남방과 여라무엘 사람의 남방과 겐 사람의 남방이니이다'","reference":"사무엘상 27:10","category":"$undefined"},{"id":"7942","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":11,"text":"다윗이 그 남녀를 살려 가드로 데려가지 아니한 것은 그의 생각에 그들이 우리에게 대하여 이르기를 다윗의 행사가 이러하여 블레셋 사람의 지방에 거하는 동안에 이같이 행하는 습관이 있다 할까 두려워함이었더라","reference":"사무엘상 27:11","category":"$undefined"},{"id":"7943","book":"사무엘상","book_name":"사무엘상","chapter":27,"verse":12,"text":"아기스가 다윗을 믿고 말하기를 `다윗이 자기 백성 이스라엘에게 심히 미움을 받게 하였으니 그는 영영히 내 사역자가 되리라' 하니라","reference":"사무엘상 27:12","category":"$undefined"}],"bookSlug":"1samuel"}]
