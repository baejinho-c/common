2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":28,"verses":[{"id":"7944","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":1,"text":"그 때에 블레셋 사람이 이스라엘을 쳐서 싸우려고 군대를 모집한지라 아기스가 다윗에게 이르되 `너는 밝히 알라 너와 네 사람들이 나와 한 가지로 나가서 군대에 참가할 것이니라'","reference":"사무엘상 28:1","category":"$undefined"},{"id":"7945","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":2,"text":"다윗이 아기스에게 이르되 `그러면 당신이 종의 행할 바를 아시리이다' 아기스가 다윗에게 이르되 `그러면 내가 너로 영영히 내 머리 지키는 자를 삼으리라' 하니라","reference":"사무엘상 28:2","category":"$undefined"},{"id":"7946","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":3,"text":"사무엘이 죽었으므로 온 이스라엘이 그를 애곡하며 그의 본성 라마에 장사하였고 사울은 신접한 자와 박수를 그 땅에서 쫓아 내었었더라","reference":"사무엘상 28:3","category":"$undefined"},{"id":"7947","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":4,"text":"블레셋 사람이 모여 수넴에 이르러 진치매 사울이 온 이스라엘을 모아 길보아에 진쳤더니","reference":"사무엘상 28:4","category":"$undefined"},{"id":"7948","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":5,"text":"사울이 블레셋 사람의 군대를 보고 두려워서 그 마음이 크게 떨린지라","reference":"사무엘상 28:5","category":"$undefined"},{"id":"7949","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":6,"text":"사울이 여호와께 묻자오되 여호와께서 꿈으로도,우림으로도, 선지자로도 그에게 대답지 아니하시므로","reference":"사무엘상 28:6","category":"$undefined"},{"id":"7950","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":7,"text":"사울이 그 신하들에게 이르되 `나를 위하여 신접한 여인을 찾으라 내가 그리로 가서 그에게 물으리라' 그 신하들이 그에게 이르되 `보소서 ! 엔돌에 신접한 여인이 있나이다'","reference":"사무엘상 28:7","category":"$undefined"},{"id":"7951","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":8,"text":"사울이 다른 옷을 입어 변장하고 두 사람과 함께 갈새 그들이 밤에 그 여인에게 이르러는 사울이 가로되 `청하노니 나를 위하여 신접한 술법으로 내가 네게 말하는 사람을 불러올리라'","reference":"사무엘상 28:8","category":"$undefined"},{"id":"7952","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":9,"text":"여인이 그에게 이르되 `네가 사울의 행한 일 곧 그가 신접한 자와 박수를 이 땅에서 멸절시켰음을 아나니 네가 어찌하여 내 생명에 올무를 놓아 나를 죽게 하려느냐 ?'","reference":"사무엘상 28:9","category":"$undefined"},{"id":"7953","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":10,"text":"사울이 여호와로 그에게 맹세하여 가로되 `여호와께서 사시거니와 네가 이 일로는 벌을 당치 아니하리라'","reference":"사무엘상 28:10","category":"$undefined"},{"id":"7954","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":11,"text":"여인이 가로되 내가 누구를 네게로 불러 올리랴 사울이 가로되 사무엘을 불러 올리라","reference":"사무엘상 28:11","category":"$undefined"},{"id":"7955","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":12,"text":"여인이 사무엘을 보고 큰 소리로 외치며 사울에게 말하여 가로되 당신이 어찌하여 나를 속이셨나이까 ? 당신이 사울이시니이다","reference":"사무엘상 28:12","category":"$undefined"},{"id":"7956","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":13,"text":"왕이 그에게 이르되 `두려워 말라 ! 네가 무엇을 보았느냐 ?' 여인이 사울에게 이르되 `내가 신이 땅에서 올라오는 것을 보았나이다'","reference":"사무엘상 28:13","category":"$undefined"},{"id":"7957","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":14,"text":"사울이 그에게 이르되 `그 모양이 어떠하냐 ?' 그가 가로되 `한 노인이 올라 오는데 그가 겉옷을 입었나이다' 사울이 그가 사무엘인줄 알고 그 얼굴을 땅에 대고 절하니라","reference":"사무엘상 28:14","category":"$undefined"},{"id":"7958","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":15,"text":"사무엘이 사울에게 이르되 `네가 어찌하여 나를 불러 올려서 나로 분요케 하느냐 ?' 사울이 대답하되 `나는 심히 군급하니이다 블레셋 사람은 나를 향하여 군대를 일으켰고 하나님은 나를 떠나서 다시는 선지자로도 꿈으로도 내게 대답지 아니하시기로 나의 행할 일을 배우려고 당신을 불러 올렸나이다'","reference":"사무엘상 28:15","category":"$undefined"},{"id":"7959","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":16,"text":"사무엘이 가로되 `여호와께서 너를 떠나 네 대적이 되셨거늘 네가 어찌하여 내게 묻느냐 ?","reference":"사무엘상 28:16","category":"$undefined"},{"id":"7960","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":17,"text":"여호와께서 나로 말씀하신대로 네게 행하사 나라를 네 손에서 떼어 네 이웃 다윗에게 주셨느니라","reference":"사무엘상 28:17","category":"$undefined"},{"id":"7961","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":18,"text":"네가 여호와의 목소리를 순종치 아니하고 그의 진노를 아말렉에게 쏟지 아니하였으므로 여호와께서 오늘날 이 일을 네게 행하셨고","reference":"사무엘상 28:18","category":"$undefined"},{"id":"7962","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":19,"text":"여호와께서 이스라엘을 너와 함께 블레셋 사람의 손에 붙이시리니 내일 너와 네 아들들이 나와 함께 있으리라 여호와께서 또 이스라엘 군대를 블레셋 사람의 손에 붙이시리라'","reference":"사무엘상 28:19","category":"$undefined"},{"id":"7963","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":20,"text":"사울이 갑자기 땅에 온전히 엎드러지니 이는 사무엘의 말을 인하여 심히 두려워함이요 또 그 기력이 진하였으니 이는 그가 종일 종야에 식물을 먹지 못하였음이라","reference":"사무엘상 28:20","category":"$undefined"},{"id":"7964","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":21,"text":"그 여인이 사울에게 이르러 그 심히 고통함을 보고 그에게 이르되 여종이 왕의 말씀을 듣고 나의 생명을 아끼지 아니하고 왕이 내게 이르신 말씀을 청종하였사오니","reference":"사무엘상 28:21","category":"$undefined"},{"id":"7965","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":22,"text":"그런즉 청컨대 이제 여종의 말을 들으사 나로 왕의 앞에 한 조각떡을 드리게 하시고 왕은 잡수시고 길 가실 때에 기력을 얻으소서","reference":"사무엘상 28:22","category":"$undefined"},{"id":"7966","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":23,"text":"사울이 거절하여 가로되 `내가 먹지 아니하겠노라' 그 신하들과 여인이 강권하매 그 말을 듣고 땅에서 일어나 침상에 앉으니라","reference":"사무엘상 28:23","category":"$undefined"},{"id":"7967","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":24,"text":"여인의 집에 살진 송아지가 있으므로 그것을 급히 잡고 가루를 취하여 뭉쳐 무교병을 만들고 구워서","reference":"사무엘상 28:24","category":"$undefined"},{"id":"7968","book":"사무엘상","book_name":"사무엘상","chapter":28,"verse":25,"text":"사울의 앞에 와 그 신하들의 앞에 드리니 그들이 먹고 일어나서 그 밤에 가니라","reference":"사무엘상 28:25","category":"$undefined"}],"bookSlug":"1samuel"}]
