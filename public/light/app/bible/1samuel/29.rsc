2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":29,"verses":[{"id":"7969","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":1,"text":"블레셋 사람들은 그 모든 군대를 아벡에 모았고 이스라엘 사람들은 이스르엘에 있는 샘곁에 진쳤더라","reference":"사무엘상 29:1","category":"$undefined"},{"id":"7970","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":2,"text":"블레셋 사람의 장관들은 수백씩 수천씩 영솔하여 나아가고 다윗과 그의 사람들은 아기스와 함께 그 뒤에서 나아가더니","reference":"사무엘상 29:2","category":"$undefined"},{"id":"7971","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":3,"text":"블레셋 사람의 방백들이 가로되 이 히브리 사람들이 무엇을 하려느냐 아기스가 블레셋 사람의 방백들에게 이르되 `이는 이스라엘 왕 사울의 신하 다윗이 아니냐 ? 그가 나와 함께 있은지 여러 날 여러 해로되 그가 망명하여 온 날부터 오늘까지 내가 그의 허물을 보지 못하였노라'","reference":"사무엘상 29:3","category":"$undefined"},{"id":"7972","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":4,"text":"블레셋 사람의 방백들이 그에게 노한지라 블레셋 방백들이 그에게 이르되 `이 사람을 돌려보내어 왕이 그에게 정하신 그 처소로 가게 하소서 그는 우리와 함께 싸움에 내려가지 못하리니 그가 전장에서 우리의 대적이 될까 하나이다 그가 무엇으로 그 주와 다시 화합하리이까 이 사람들의 머리로 하지 아니하겠나이까 ?","reference":"사무엘상 29:4","category":"$undefined"},{"id":"7973","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":5,"text":"그들이 춤추며 창화하여 가로되 사울의 죽인 자는 천천이요 다윗은 만만이로다 하던 이 다윗이 아니니이까'","reference":"사무엘상 29:5","category":"$undefined"},{"id":"7974","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":6,"text":"아기스가 다윗을 불러 그에게 이르되 `여호와께서 사시거니와 네가 정직하여 내게 온 날부터 오늘까지 네게 악이 있음을 보지 못하였으니 나와 함께 군중에 출입하는 것이 나의 소견에는 좋으나 장관들이 너를 좋아하지 아니하니","reference":"사무엘상 29:6","category":"$undefined"},{"id":"7975","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":7,"text":"너는 돌이켜 평안히 가서 블레셋 사람의 장관들에게 거슬려 보이게 말라'","reference":"사무엘상 29:7","category":"$undefined"},{"id":"7976","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":8,"text":"다윗이 아기스에게 이르되 `내가 무엇을 하였나이까 ? 내가 당신의 앞에 오늘까지 있는 동안에 당신이 종에게서 무엇을 보셨기에 나로 가서 내 주 왕의 원수와 싸우지 못하게 하시나이까 ?'","reference":"사무엘상 29:8","category":"$undefined"},{"id":"7977","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":9,"text":"아기스가 다윗에게 대답하여 가로되 `네가 내 목전에 하나님의 사자같이 선한 것을 내가 아나 블레셋 사람의 방백들은 말하기를 그가 우리와 함께 전장에 올라가지 못하리라 하니","reference":"사무엘상 29:9","category":"$undefined"},{"id":"7978","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":10,"text":"그런즉 너는 너와 함께 온 네 주의 신하들로 더불어 새벽에 일어나라 너희는 새벽에 일어나서 밝거든 곧 떠나라'","reference":"사무엘상 29:10","category":"$undefined"},{"id":"7979","book":"사무엘상","book_name":"사무엘상","chapter":29,"verse":11,"text":"이에 다윗이 자기 사람들로 더불어 일찌기 아침에 일어나서 떠나 블레셋 사람의 땅으로 돌아가고 블레셋 사람은 이스르엘로 올라 가니라","reference":"사무엘상 29:11","category":"$undefined"}],"bookSlug":"1samuel"}]
