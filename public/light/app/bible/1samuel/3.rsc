2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":3,"verses":[{"id":"7278","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":1,"text":"아이 사무엘이 엘리 앞에서 여호와를 섬길 때에는 여호와의 말씀이 희귀하여 이상이 흔히 보이지 않았더라","reference":"사무엘상 3:1","category":"$undefined"},{"id":"7279","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":2,"text":"엘리의 눈이 점점 어두워 가서 잘 보지 못하는 그 때에 그가 자기 처소에 누웠고","reference":"사무엘상 3:2","category":"$undefined"},{"id":"7280","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":3,"text":"하나님의 등불은 아직 꺼지지 아니하였으며 사무엘은 하나님의 궤 있는 여호와의 전 안에 누웠더니","reference":"사무엘상 3:3","category":"$undefined"},{"id":"7281","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":4,"text":"여호와께서 사무엘을 부르시는지라 그가 대답하되 `내가 여기 있나이다' 하고","reference":"사무엘상 3:4","category":"$undefined"},{"id":"7282","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":5,"text":"엘리에게로 달려가서 가로되 `당신이 나를 부르셨기로 내가 여기 있나이다' 가로되 `나는 부르지 아니하였으니 다시 누우라' 그가 가서 누웠더니","reference":"사무엘상 3:5","category":"$undefined"},{"id":"7283","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":6,"text":"여호와께서 다시 사무엘을 부르시는지라 사무엘이 일어나서 엘리에게로 가서 가로되 `당신이 나를 부르셨기로 내가 여기 있나이다' 대답하되 `내 아들아 내가 부르지 아니 하였으니 다시 누우라' 하니라","reference":"사무엘상 3:6","category":"$undefined"},{"id":"7284","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":7,"text":"사무엘이 아직 여호와를 알지 못하고 여호와의 말씀도 아직 그에게 나타나지 아니한 때라","reference":"사무엘상 3:7","category":"$undefined"},{"id":"7285","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":8,"text":"여호와께서 세번째 사무엘을 부르시는지라 그가 일어나서 엘리에게로 가서 가로되 `당신이 나를 부르셨기로 내가 여기 있나이다' 엘리가 여호와께서 이 아이를 부르신 줄을 깨닫고","reference":"사무엘상 3:8","category":"$undefined"},{"id":"7286","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":9,"text":"이에 사무엘에게 이르되 `가서 누웠다가 그가 너를 부르시거든 네가 말하기를 여호와여 말씀하옵소서 주의 종이 듣겠나이다 하라' 이에 사무엘이 가서 자기 처소에 누우니라","reference":"사무엘상 3:9","category":"$undefined"},{"id":"7287","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":10,"text":"여호와께서 임하여 서서 전과 같이 사무엘아 ! 사무엘아 ! 부르시는지라 사무엘이 가로되 `말씀하옵소서 주의 종이 듣겠나이다'","reference":"사무엘상 3:10","category":"$undefined"},{"id":"7288","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":11,"text":"여호와께서 사무엘에게 이르시되 보라, 내가 이스라엘 중에 한 일을 행하리니 그것을 듣는 자마다 두 귀가 울리리라","reference":"사무엘상 3:11","category":"$undefined"},{"id":"7289","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":12,"text":"내가 엘리의 집에 대하여 말한 것을 처음부터 끝까지 그날에 그에게 다 이루리라","reference":"사무엘상 3:12","category":"$undefined"},{"id":"7290","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":13,"text":"내가 그 집을 영영토록 심판하겠다고 그에게 이른 것은 그의 아는 죄악을 인함이니 이는 그가 자기 아들들이 저주를 자청하되 금하지 아니하였음이니라","reference":"사무엘상 3:13","category":"$undefined"},{"id":"7291","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":14,"text":"그러므로 내가 엘리의 집에 대하여 맹세하기를 엘리 집의 죄악은 제물이나 예물로나 영영히 속함을 얻지 못하리라 하였노라","reference":"사무엘상 3:14","category":"$undefined"},{"id":"7292","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":15,"text":"사무엘이 아침까지 누웠다가 여호와의 집 문을 열었으나 그 이상을 엘리에게 알게 하기를 두려워하더니","reference":"사무엘상 3:15","category":"$undefined"},{"id":"7293","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":16,"text":"엘리가 사무엘을 불러 가로되 `내 아들 사무엘아' 하니 대답하되 `내가 여기 있나이다'","reference":"사무엘상 3:16","category":"$undefined"},{"id":"7294","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":17,"text":"가로되 `네게 무엇을 말씀하셨느냐 청하노니 내게 숨기지 말라 네게 말씀하신 모든 것을 하나라도 숨기면 하나님이 네게 벌을 내리시고 또 내리시기를 원하노라'","reference":"사무엘상 3:17","category":"$undefined"},{"id":"7295","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":18,"text":"사무엘이 세세히 말하고 조금도 숨기지 아니하니 그가 가로되 `이는 여호와시니 선하신 소견대로 하실 것이니라' 하니라","reference":"사무엘상 3:18","category":"$undefined"},{"id":"7296","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":19,"text":"사무엘이 자라매 여호와께서 그와 함께 계셔서 그 말로 하나도 땅에 떨어지지 않게 하시니","reference":"사무엘상 3:19","category":"$undefined"},{"id":"7297","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":20,"text":"단에서부터 브엘세바까지의 온 이스라엘이 사무엘은 여호와의 선지자로 세우심을 입은 줄을 알았더라","reference":"사무엘상 3:20","category":"$undefined"},{"id":"7298","book":"사무엘상","book_name":"사무엘상","chapter":3,"verse":21,"text":"여호와께서 실로에서 다시 나타나시되 여호와께서 실로에서 여호와의 말씀으로 사무엘에게 자기를 나타내시니","reference":"사무엘상 3:21","category":"$undefined"}],"bookSlug":"1samuel"}]
