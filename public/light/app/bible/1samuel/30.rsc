2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":30,"verses":[{"id":"7980","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":1,"text":"다윗과 그의 사람들이 제 삼일에 시글락에 이를 때에 아말렉 사람들이 이미 남방과 시글락을 침노하였는데 그들이 시글락을 쳐서 불사르고","reference":"사무엘상 30:1","category":"$undefined"},{"id":"7981","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":2,"text":"거기 있는 대소 여인들을 하나도 죽이지 아니하고 다 사로잡아 끌고 자기 길을 갔더라","reference":"사무엘상 30:2","category":"$undefined"},{"id":"7982","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":3,"text":"다윗과 그의 사람들이 성에 이르러 본즉 성이 불탔고 자기들의 아내와 자녀들이 사로 잡혔는지라","reference":"사무엘상 30:3","category":"$undefined"},{"id":"7983","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":4,"text":"다윗과 그와 함께 한 백성이 울 기력이 없도록 소리를 높여 울었더라","reference":"사무엘상 30:4","category":"$undefined"},{"id":"7984","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":5,"text":"(다윗의 두 아내 이스르엘 여인 아히노암과 갈멜 사람 나발의 아내 되었던 아비가일도 사로잡혔더라)","reference":"사무엘상 30:5","category":"$undefined"},{"id":"7985","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":6,"text":"백성이 각기 자녀들을 위하여 마음이 슬퍼서 다윗을 돌로 치자 하니 다윗이 크게 군급하였으나 그 하나님 여호와를 힘입고 용기를 얻었더라","reference":"사무엘상 30:6","category":"$undefined"},{"id":"7986","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":7,"text":"다윗이 아히멜렉의 아들 제사장 아비아달에게 이르되 `청컨대 에봇을 내게로 가져오라' 아비아달이 에봇을 다윗에게로 가져 오매","reference":"사무엘상 30:7","category":"$undefined"},{"id":"7987","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":8,"text":"다윗이 여호와께 묻자와 가로되 `내가 이 군대를 쫓아 가면 미치겠나이까 ?' 여호와께서 대답하시되 쫓아가라 네가 반드시 미치고 정녕 도로 찾으리라","reference":"사무엘상 30:8","category":"$undefined"},{"id":"7988","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":9,"text":"이에 다윗과 그와 함께 한 육백명이 가서 브솔 시내에 이르러는 뒤 떨어진 자를 거기 머물렀으되","reference":"사무엘상 30:9","category":"$undefined"},{"id":"7989","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":10,"text":"곧 피곤하여 브솔 시내를 건너지 못하는 이백인을 머물렀고 다윗은 사백인을 거느리고 쫓아가니라","reference":"사무엘상 30:10","category":"$undefined"},{"id":"7990","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":11,"text":"무리가 들에서 애굽 사람 하나를 만나 다윗에게로 데려다가 떡을 주어 먹게 하며 물을 마시우고","reference":"사무엘상 30:11","category":"$undefined"},{"id":"7991","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":12,"text":"무화과 뭉치에서 뗀 덩이 하나와 건포도 두 송이를 주었으니 그가 낮 사흘 밤, 사흘을 떡도 먹지 못하였고 물도 마시지 못하였음이라 그가 먹고 정신을 차리매","reference":"사무엘상 30:12","category":"$undefined"},{"id":"7992","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":13,"text":"다윗이 그에게 이르되 `너는 뉘게 속하였으며 어디로서냐 ?' 가로되 `나는 애굽 소년이요 아말렉 사람의 종이더니 사흘 전에 병이 들매 주인이 나를 버렸나이다","reference":"사무엘상 30:13","category":"$undefined"},{"id":"7993","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":14,"text":"우리가 그렛 사람의 남방과 유다에 속한 지방과 갈멜 남방을 침노하고 시글락을 불살랐나이다'","reference":"사무엘상 30:14","category":"$undefined"},{"id":"7994","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":15,"text":"다윗이 그에게 이르되 `네가 나를 그 군대에게로 인도하겠느냐 ?' 그가 가로되 `당신이 나를 죽이지도 아니하고 내 주인의 수중에 붙이지도 아니하겠다고 하나님으로 맹세하소서 그리하면 내가 당신을 이 군대에게로 인도하리이다'","reference":"사무엘상 30:15","category":"$undefined"},{"id":"7995","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":16,"text":"그가 인도하여 내려가니 그들이 온 땅에 편만하여 블레셋 사람의 땅과 유다 땅에서 크게 탈취하였음을 인하여 먹고 마시며 춤추는지라","reference":"사무엘상 30:16","category":"$undefined"},{"id":"7996","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":17,"text":"다윗이 새벽부터 이튿날 저물때까지 그들을 치매 약대 타고 도망한 소년 사백명 외에는 피한 사람이 없었더라","reference":"사무엘상 30:17","category":"$undefined"},{"id":"7997","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":18,"text":"다윗이 아말렉 사람의 취하였던 모든 것을 도로 찾고 그 두 아내를 구원하였고","reference":"사무엘상 30:18","category":"$undefined"},{"id":"7998","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":19,"text":"그들의 탈취하였던 것 곧 무리의 자녀들이나 빼앗겼던 것의 대소를 물론하고 아무것도 잃은 것이 없이 다윗이 도로 찾아왔고","reference":"사무엘상 30:19","category":"$undefined"},{"id":"7999","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":20,"text":"또 양떼와 소떼를 다 탈취하였더니 무리가 그 가축 앞에 몰고 가며 가로되 `이는 다윗의 탈취한 것이라' 하였더라","reference":"사무엘상 30:20","category":"$undefined"},{"id":"8000","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":21,"text":"다윗이 이왕에 피곤하여 능히 자기를 따르지 못하므로 브솔 시내에 머물게 한 이백인에게 오매 그들이 다윗과 그와 함께 한 백성을 영접하러 나온지라 다윗이 그 백성에게 이르러 문안하매","reference":"사무엘상 30:21","category":"$undefined"},{"id":"8001","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":22,"text":"다윗과 함께 갔던 자 중에 악한 자와 비류들이 다 가로되 `그들이 우리와 함께 가지 아니하였은즉 우리가 도로 찾은 물건은 무엇이든지 그들에게 주지 말고 각 사람의 처자만 주어서 데리고 떠나 가게 하라' 하는지라","reference":"사무엘상 30:22","category":"$undefined"},{"id":"8002","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":23,"text":"다윗이 가로되 `나의 형제들아 ! 여호와께서 우리를 보호하시고 우리를 치러 온 그 군대를 우리 손에 붙이셨은즉 그가 우리에게 주신 것을 너희가 이같이 못하리라","reference":"사무엘상 30:23","category":"$undefined"},{"id":"8003","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":24,"text":"이 일에 누가 너희를 듣겠느냐 ? 전장에 내려갔던 자의 분깃이나 소유물 곁에 머물렀던 자의 분깃이 일반일지니 같이 분배할 것이니라' 하고","reference":"사무엘상 30:24","category":"$undefined"},{"id":"8004","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":25,"text":"그 날부터 다윗이 이것으로 이스라엘의 율례와 규례를 삼았더니 오늘까지 이르니라","reference":"사무엘상 30:25","category":"$undefined"},{"id":"8005","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":26,"text":"다윗이 시글락에 이르러 탈취물을 그 친구 유다 장로들에게 보내어 가로되 `보라, 여호와의 원수에게서 탈취한 것을 너희에게 선사하노라' 하고","reference":"사무엘상 30:26","category":"$undefined"},{"id":"8006","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":27,"text":"벧엘에 있는 자와, 남방 라못에 있는 자와, 얏딜에 있는 자와,","reference":"사무엘상 30:27","category":"$undefined"},{"id":"8007","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":28,"text":"아로엘에 있는 자와, 십못에 있는 자와, 에스드모아에 있는 자와,","reference":"사무엘상 30:28","category":"$undefined"},{"id":"8008","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":29,"text":"라갈에 있는 자와, 여라므엘 사람의 성읍들에 있는 자와, 겐 사람의 성읍들에 있는 자와,","reference":"사무엘상 30:29","category":"$undefined"},{"id":"8009","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":30,"text":"홀마에 있는 자와, 고라산에 있는 자와, 아닥에 있는 자와, 헤브론에 있는 자에게와, 다윗과 그의 사람들의 왕래하던 모든 곳에 보내었더라","reference":"사무엘상 30:30","category":"$undefined"},{"id":"8010","book":"사무엘상","book_name":"사무엘상","chapter":30,"verse":31,"text":"","reference":"사무엘상 30:31","category":"$undefined"}],"bookSlug":"1samuel"}]
