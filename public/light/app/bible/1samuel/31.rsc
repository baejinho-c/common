2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":31,"verses":[{"id":"8011","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":1,"text":"블레셋 사람이 이스라엘을 치매 이스라엘 사람들이 블레셋 사람앞에서 도망하여 길보아 산에서 엎드러져 죽으니라","reference":"사무엘상 31:1","category":"$undefined"},{"id":"8012","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":2,"text":"블레셋 사람들이 사울과 그 아들들을 쫓아 미쳐서 사울의 아들 요나단과 아비나답과 말기수아를 죽이니라","reference":"사무엘상 31:2","category":"$undefined"},{"id":"8013","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":3,"text":"사울이 패전하매 활 쏘는 자가 따라 미치니 사울이 그 활 쏘는 자를 인하여 중상한지라","reference":"사무엘상 31:3","category":"$undefined"},{"id":"8014","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":4,"text":"그가 병기 든 자에게 이르되 `네 칼을 빼어 나를 찌르라 할례없는 자들이 와서 나를 찌르고 모욕할까 두려워하노라' 하나 병기 든 자가 심히 두려워하여 즐겨 행치 아니하는지라 이에 사울이 자기 칼을 취하고 그 위에 엎드러지매","reference":"사무엘상 31:4","category":"$undefined"},{"id":"8015","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":5,"text":"병기 든 자가 사울의 죽음을 보고 자기도 자기 칼 위에 엎드러져 그와 함께 죽으니라","reference":"사무엘상 31:5","category":"$undefined"},{"id":"8016","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":6,"text":"사울과 그 세 아들과 병기 든 자와 그의 모든 사람이 다 그 날에 함께 죽었더라","reference":"사무엘상 31:6","category":"$undefined"},{"id":"8017","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":7,"text":"골짜기 저편에 있는 이스라엘 사람과 요단 건너편에 있는 자들이 이스라엘 사람들의 도망한 것과 사울과 그 아들들의 죽었음을 보고 성읍들을 버리고 도망하매 블레셋 사람들이 이르러 거기 거하니라","reference":"사무엘상 31:7","category":"$undefined"},{"id":"8018","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":8,"text":"그 이튿날 블레셋 사람들이 죽은 자를 벗기러 왔다가 사울과 그 세 아들이 길보아산에서 죽은 것을 보고","reference":"사무엘상 31:8","category":"$undefined"},{"id":"8019","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":9,"text":"사울의 머리를 베고 그 갑옷을 벗기고 자기들의 신당과 백성에게 전파하기 위하여 그것을 블레셋 사람의 땅 사방에 보내고","reference":"사무엘상 31:9","category":"$undefined"},{"id":"8020","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":10,"text":"그 갑옷은 아스다롯의 집에 두고 그 시체는 벧산 성벽에 못박으매","reference":"사무엘상 31:10","category":"$undefined"},{"id":"8021","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":11,"text":"길르앗 야베스 거민들이 블레셋 사람들의 사울에게 행한 일을 듣고","reference":"사무엘상 31:11","category":"$undefined"},{"id":"8022","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":12,"text":"모든 장사가 일어나 밤새도록 가서 사울과 그 아들들의 시체를 벧산 성벽에서 취하여 가지고 야베스에 돌아와서 거기서 불사르고","reference":"사무엘상 31:12","category":"$undefined"},{"id":"8023","book":"사무엘상","book_name":"사무엘상","chapter":31,"verse":13,"text":"그 뼈를 가져다가 야베스 에셀나무 아래 장사하고 칠일을 금식하였더라","reference":"사무엘상 31:13","category":"$undefined"}],"bookSlug":"1samuel"}]
