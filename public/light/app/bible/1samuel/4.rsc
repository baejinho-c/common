2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":4,"verses":[{"id":"7299","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":1,"text":"사무엘의 말이 온 이스라엘에 전파되니라 이스라엘은 나가서 블레셋 사람과 싸우려고 에벤에셀 곁에 진 치고 블레셋 사람은 아벡에 진 쳤더니","reference":"사무엘상 4:1","category":"$undefined"},{"id":"7300","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":2,"text":"이스라엘을 대하여 항오를 벌이니라 그 둘이 싸우다가 이스라엘이 블레셋 사람 앞에서 패하여 그들에게 전쟁에서 죽임을 당한 군사가 사천명 가량이라","reference":"사무엘상 4:2","category":"$undefined"},{"id":"7301","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":3,"text":"백성이 진으로 돌아오매 이스라엘 장로들이 가로되 `여호와께서 어찌하여 우리로 오늘 블레셋 사람 앞에 패하게 하셨는고 여호와의 언약궤를 실로에서 우리에게로 가져다가 우리 중에 있게 하여 그것으로 우리를 우리 원수들의 손에서 구원하게 하자' 하니","reference":"사무엘상 4:3","category":"$undefined"},{"id":"7302","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":4,"text":"이에 백성이 실로에 보내어 그룹 사이에 계신 만군의 여호와의 언약궤를 거기서 가져 왔고 엘리의 두 아들 홉니와 비느하스는 하나님의 언약궤와 함께 거기 있었더라","reference":"사무엘상 4:4","category":"$undefined"},{"id":"7303","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":5,"text":"여호와의 언약궤가 진에 들어 올 때에 온 이스라엘이 큰 소리로 외치매 땅이 울린지라","reference":"사무엘상 4:5","category":"$undefined"},{"id":"7304","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":6,"text":"블레셋 사람이 그 외치는 소리를 듣고 가로되 `히브리 진에서 큰 소리로 외침은 어찜이뇨 ?' 하다가 여호와의 궤가 진에 들어온 줄을 깨달은지라","reference":"사무엘상 4:6","category":"$undefined"},{"id":"7305","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":7,"text":"블레셋 사람이 두려워하여 가로되 `신이 진에 이르렀도다' 하고 또 가로되 `우리에게 화로다 전일에는 이런 일이 없었도다","reference":"사무엘상 4:7","category":"$undefined"},{"id":"7306","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":8,"text":"우리에게 화로다 누가 우리를 이 능한 신들의 손에서 건지리요 그들은 광야에서 여러가지 재앙으로 애굽인을 친 신들이니라","reference":"사무엘상 4:8","category":"$undefined"},{"id":"7307","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":9,"text":"너희 블레셋 사람들아 강하게 되며 대장부가 되어라 너희가 히브리 사람의 종이 되기를 그들이 너희의 종이 되었던 것 같이 말고 대장부 같이 되어 싸우라' 하고","reference":"사무엘상 4:9","category":"$undefined"},{"id":"7308","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":10,"text":"블레셋 사람이 쳤더니 이스라엘이 패하여 각기 장막으로 도망하였고 살륙이 심히 커서 이스라엘 보병의 엎드러진 자가 삼만이었으며","reference":"사무엘상 4:10","category":"$undefined"},{"id":"7309","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":11,"text":"하나님의 궤는 빼앗겼고 엘리의 두 아들 홉니와 비느하스는 죽임을 당하였더라","reference":"사무엘상 4:11","category":"$undefined"},{"id":"7310","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":12,"text":"당일에 어떤 베냐민 사람이 진에서 달려나와 그 옷을 찢고 그 머리에 티끌을 무릅쓰고 실로에 이르니라","reference":"사무엘상 4:12","category":"$undefined"},{"id":"7311","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":13,"text":"그가 이를 때는 엘리가 길 곁 자기 의자에 앉아 기다리며 그 마음이 여호와의 궤로 인하여 떨릴 즈음이라 그 사람이 성에 들어 오며 고하매 온 성이 부르짖는지라","reference":"사무엘상 4:13","category":"$undefined"},{"id":"7312","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":14,"text":"엘리가 그 부르짖는 소리를 듣고 가로되 `이 훤화하는 소리는 어찜이뇨' 그 사람이 빨리 와서 엘리에게 고하니","reference":"사무엘상 4:14","category":"$undefined"},{"id":"7313","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":15,"text":"때에 엘리의 나이 구십 팔이라 그 눈이 어두워서 보지 못하더라","reference":"사무엘상 4:15","category":"$undefined"},{"id":"7314","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":16,"text":"그사람이 엘리에게 고하되 `나는 진 중에서 나온 자라 내가 오늘 진 중에서 도망하여 왔나이다' 엘리가 가로되 `내 아들아 일이 어찌되었느냐 ?'","reference":"사무엘상 4:16","category":"$undefined"},{"id":"7315","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":17,"text":"소식을 전하는 자가 대답하여 가로되 `이스라엘이 블레셋 사람 앞에서 도망하였고 백성 중에는 큰 살륙이 있었고 당신의 두 아들 홉니와 비느하스도 죽임을 당하였고 하나님의 궤는 빼앗겼나이다'","reference":"사무엘상 4:17","category":"$undefined"},{"id":"7316","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":18,"text":"하나님의 궤를 말할 때에 엘리가 자기 의자에서 자빠져 문 곁에서 목이 부러져 죽었으니 나이 많고 비둔한 연고라 그가 이스라엘 사사가 된지 사십년이었더라","reference":"사무엘상 4:18","category":"$undefined"},{"id":"7317","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":19,"text":"그의 며느리 비느하스의 아내가 잉태하여 산기가 가까왔더니 하나님의 궤 빼앗긴 것과 그 시부와 남편의 죽은 소문을 듣고 갑자기 아파서 몸을 구푸려 해산하고","reference":"사무엘상 4:19","category":"$undefined"},{"id":"7318","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":20,"text":"죽어갈 때에 곁에 섰던 여인들이 그에게 이르되 `두려워 말라 네가 아들을 낳았다' 하되 그가 대답지도 아니하며 관념치도 아니하고","reference":"사무엘상 4:20","category":"$undefined"},{"id":"7319","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":21,"text":"이르기를 `영광이 이스라엘에서 떠났다' 하고 아이 이름을 이가봇이라 하였으니 하나님의 궤가 빼앗겼고 그 시부와 남편이 죽었음을 인함이며","reference":"사무엘상 4:21","category":"$undefined"},{"id":"7320","book":"사무엘상","book_name":"사무엘상","chapter":4,"verse":22,"text":"또 이르기를 하나님의 궤를 빼앗겼으므로 영광이 이스라엘에서 떠났다 하였더라","reference":"사무엘상 4:22","category":"$undefined"}],"bookSlug":"1samuel"}]
