2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":6,"verses":[{"id":"7333","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":1,"text":"여호와의 궤가 블레셋 사람의 지방에 있은지 일곱 달이라","reference":"사무엘상 6:1","category":"$undefined"},{"id":"7334","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":2,"text":"블레셋 사람이 제사장들과 복술자들을 불러서 이르되 `우리가 여호와의 궤를 어떻게 할꼬 그것을 어떻게 본처로 보낼 것을 우리에게 가르치라'","reference":"사무엘상 6:2","category":"$undefined"},{"id":"7335","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":3,"text":"그들이 가로되 `이스라엘 신의 궤를 보내려거든 거저 보내지 말고 그에게 속건제를 드려야 할지니라 그리하면 병도 낫고 그 손을 너희에게서 옮기지 아니하는 연고도 알리라'","reference":"사무엘상 6:3","category":"$undefined"},{"id":"7336","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":4,"text":"그들이 가로되 `무엇으로 그에게 드릴 속건제를 삼을꼬' 가로되 `블레셋 사람의 방백의 수효대로 금독종 다섯과 금쥐 다섯이라야 하리니 너희와 너희 방백에게 내린 재앙이 일반임이니라","reference":"사무엘상 6:4","category":"$undefined"},{"id":"7337","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":5,"text":"그러므로 너희는 너희 독종의 형상과 땅을 해롭게 하는 쥐의 형상을 만들어 이스라엘 신께 영화를 돌리라 그가 혹 그 손을 너희와 너희 신들과 너희 땅에서 경하게 하실까 하노라","reference":"사무엘상 6:5","category":"$undefined"},{"id":"7338","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":6,"text":"애굽인과 바로가 그 마음을 강퍅케 한 것같이 어찌하여 너희가 너희 마음을 강퍅케 하겠느냐 ? 그가 그들 중에서 기이하게 행한 후에 그들이 백성을 가게 하므로 백성이 떠나지 아니하였느냐 ?","reference":"사무엘상 6:6","category":"$undefined"},{"id":"7339","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":7,"text":"그러므로 새 수레를 만들고 멍에 메어 보지 아니한 젖 나는 소 둘을 끌어다가 수레를 소에 메우고 그 송아지들은 떼어 집으로 돌려 보내고","reference":"사무엘상 6:7","category":"$undefined"},{"id":"7340","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":8,"text":"여호와의 궤를 가져다가 수레에 싣고 속건제 드릴 금 보물은 상자에 담아 궤 곁에 두고 그것을 보내어 가게 하고","reference":"사무엘상 6:8","category":"$undefined"},{"id":"7341","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":9,"text":"보아서 궤가 그 본 지경 길로 올라가서 벧세메스로 가면 이 큰 재앙은 그가 우리에게 내린 것이요 그렇지 아니하면 우리를 친 것이 그 손이 아니요 우연히 만난 것인 줄 알리라'","reference":"사무엘상 6:9","category":"$undefined"},{"id":"7342","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":10,"text":"그 사람들이 그같이 하여 젖나는 소 둘을 끌어다가 수레를 메우고 송아지들은 집에 가두고","reference":"사무엘상 6:10","category":"$undefined"},{"id":"7343","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":11,"text":"여호와의 궤와 및 금쥐와 그들의 독종의 형상을 담은 상자를 수레 위에 실으니","reference":"사무엘상 6:11","category":"$undefined"},{"id":"7344","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":12,"text":"암소가 벧세메스 길로 바로 행하여 대로로 가며 갈 때에 울고 좌우로 치우치지 아니하였고 블레셋 방백들은 벧세메스 경계까지 따라 가니라","reference":"사무엘상 6:12","category":"$undefined"},{"id":"7345","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":13,"text":"벧세메스 사람들이 골짜기에서 밀을 베다가 눈을 들어 궤를 보고 그것의 보임을 기뻐하더니","reference":"사무엘상 6:13","category":"$undefined"},{"id":"7346","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":14,"text":"수레가 벧세메스 사람 여호수아의 밭 큰 돌 있는 곳에 이르러 선지라 무리가 수레의 나무를 패고 그 소를 번제로 여호와께 드리고","reference":"사무엘상 6:14","category":"$undefined"},{"id":"7347","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":15,"text":"레위인은 여호와의 궤와 그 궤와 함께 있는 금 보물 담긴 상자를 내려다가 큰 돌 위에 두매 그 날에 벧세메스 사람들이 여호와께 번제와 다른 제를 드리니라","reference":"사무엘상 6:15","category":"$undefined"},{"id":"7348","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":16,"text":"블레셋 다섯 방백이 이것을 보고 그날에 에그론으로 돌아갔더라","reference":"사무엘상 6:16","category":"$undefined"},{"id":"7349","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":17,"text":"블레셋 사람이 여호와께 속건제로 드린 금독종은 이러하니 아스돗을 위하여 하나요, 가사를 위하여 하나요, 아스글론을 위하여 하나요, 가드를 위하여 하나요, 에그론을 위하여 하나이며,","reference":"사무엘상 6:17","category":"$undefined"},{"id":"7350","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":18,"text":"드린 바 금쥐는 여호와의 궤를 놓은 큰돌에 이르기까지의 모든 견고한 성읍과 시골 동리 곧 다섯 방백에게 속한 사람의 모든 성읍의 수효대로였더라 그 돌은 벧세메스 사람 여호수아의 밭에 오늘까지 있더라","reference":"사무엘상 6:18","category":"$undefined"},{"id":"7351","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":19,"text":"벧세메스 사람들이 여호와의 궤를 들여다 본 고로 그들을 치사 오만 칠십인을 죽이신지라 여호와께서 백성을 쳐서 크게 살륙하셨으므로 백성이 애곡하였더라","reference":"사무엘상 6:19","category":"$undefined"},{"id":"7352","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":20,"text":"벧세메스 사람들이 가로되 `이 거룩하신 하나님 여호와 앞에 누가 능히 서리요 그를 우리에게서 뉘게로 가시게 할꼬` 하고","reference":"사무엘상 6:20","category":"$undefined"},{"id":"7353","book":"사무엘상","book_name":"사무엘상","chapter":6,"verse":21,"text":"사자들을 기랏여아림 거민에게 보내어 가로되 `블레셋 사람이 여호와의 궤를 도로 가져왔으니 너희는 내려와서 그것을 너희에게로 옮겨 가라'","reference":"사무엘상 6:21","category":"$undefined"}],"bookSlug":"1samuel"}]
