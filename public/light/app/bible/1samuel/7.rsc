2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":7,"verses":[{"id":"7354","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":1,"text":"기랏여아림 사람들이 와서 여호와의 궤를 옮겨 산에 사는 아비나답의 집에 들여 놓고 그 아들 엘리아살을 거룩히 구별하여 여호와의 궤를 지키게 하였더니","reference":"사무엘상 7:1","category":"$undefined"},{"id":"7355","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":2,"text":"사무엘이 이스라엘 온 족속에게 일러 가로되 `너희가 전심으로 여호와께 돌아오려거든 이방 신들과 아스다롯을 너희 중에서 제하고 너희 마음을 여호와께로 향하여 그만 섬기라 너희를 블레셋 사람의 손에서 건져내시리라'","reference":"사무엘상 7:2","category":"$undefined"},{"id":"7356","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":3,"text":"이에 이스라엘 자손이 바알들과 아스다롯을 제하고 여호와만 섬기니라","reference":"사무엘상 7:3","category":"$undefined"},{"id":"7357","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":4,"text":"사무엘이 가로되 `온 이스라엘은 미스바로 모이라 내가 너희를 위하여 여호와께 기도하리라' 하매","reference":"사무엘상 7:4","category":"$undefined"},{"id":"7358","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":5,"text":"그들이 미스바에 모여 물을 길어 여호와 앞에 붓고 그날에 금식하고 거기서 가로되 `우리가 여호와께 범죄하였나이다' 하니라 사무엘이 미스바에서 이스라엘 자손을 다스리니라","reference":"사무엘상 7:5","category":"$undefined"},{"id":"7359","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":6,"text":"이스라엘 자손이 미스바에 모였다 함을 블레셋 사람이 듣고 그 방백들이 이스라엘을 치러 올라온지라 이스라엘 자손이 듣고 블레셋 사람을 두려워하여","reference":"사무엘상 7:6","category":"$undefined"},{"id":"7360","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":7,"text":"사무엘에게 이르되 `당신은 우리를 위하여 우리 하나님 여호와께 쉬지 말고 부르짖어 우리를 블레셋 사람의 손에서 구원하시게 하소서'","reference":"사무엘상 7:7","category":"$undefined"},{"id":"7361","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":8,"text":"사무엘이 젖 먹는 어린 양을 취하여 온전한 번제를 여호와께 드리고 이스라엘을 위하여 여호와께 부르짖으매 여호와께서 응답하셨더라","reference":"사무엘상 7:8","category":"$undefined"},{"id":"7362","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":9,"text":"사무엘이 번제를 드릴 때에 블레셋 사람이 이스라엘과 싸우려고 가까이 오매 그날에 여호와께서 블레셋 사람에게 큰 우뢰를 발하여 그들을 어지럽게 하시니 그들이 이스라엘 앞에 패한지라","reference":"사무엘상 7:9","category":"$undefined"},{"id":"7363","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":10,"text":"이스라엘 사람들이 미스바에서 나가서 블레셋 사람을 따라 벧갈 아래에 이르기까지 쳤더라","reference":"사무엘상 7:10","category":"$undefined"},{"id":"7364","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":11,"text":"사무엘이 돌을 취하여 미스바와 센 사이에 세워 가로되 `여호와께서 여기까지 우리를 도우셨다' 하고 그이름을 [에벤에셀]이라 하니라","reference":"사무엘상 7:11","category":"$undefined"},{"id":"7365","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":12,"text":"이에 블레셋 사람이 굴복하여 다시는 이스라엘 경내에 들어오지 못하였으며 여호와의 손이 사무엘의 사는 날 동안에 블레셋 사람을 막으시매","reference":"사무엘상 7:12","category":"$undefined"},{"id":"7366","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":13,"text":"블레셋 사람이 이스라엘에게서 빼앗았던 성읍이 에그론부터 가드까지 이스라엘에게 회복되니 이스라엘이 그 사방 지경을 블레셋 사람의 손에서 도로 찾았고 또 이스라엘과 아모리 사람 사이에 평화가 있었더라","reference":"사무엘상 7:13","category":"$undefined"},{"id":"7367","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":14,"text":"사무엘이 사는 날 동안에 이스라엘을 다스렸으되","reference":"사무엘상 7:14","category":"$undefined"},{"id":"7368","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":15,"text":"해마다 벧엘과 길갈과 미스바로 순회하여 그 모든 곳에서 이스라엘을 다스렸고","reference":"사무엘상 7:15","category":"$undefined"},{"id":"7369","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":16,"text":"라마로 돌아왔으니 이는 거기 자기 집이 있음이라 거기서도 이스라엘을 다스렸으며 또 거기 여호와를 위하여 단을 쌓았더라","reference":"사무엘상 7:16","category":"$undefined"},{"id":"7370","book":"사무엘상","book_name":"사무엘상","chapter":7,"verse":17,"text":"","reference":"사무엘상 7:17","category":"$undefined"}],"bookSlug":"1samuel"}]
