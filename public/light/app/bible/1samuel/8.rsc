2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":8,"verses":[{"id":"7371","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":1,"text":"사무엘이 늙으매 그 아들들로 이스라엘 사사를 삼으니","reference":"사무엘상 8:1","category":"$undefined"},{"id":"7372","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":2,"text":"장자의 이름은 요엘이요 차자의 이름은 아비야라 그들이 브엘세 바에서 사사가 되니라","reference":"사무엘상 8:2","category":"$undefined"},{"id":"7373","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":3,"text":"그 아들들이 그 아비의 행위를 따르지 아니하고 이를 따라서 뇌물을 취하고 판결을 굽게 하니라","reference":"사무엘상 8:3","category":"$undefined"},{"id":"7374","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":4,"text":"이스라엘 모든 장로가 모여 라마에 있는 사무엘에게 나아가서","reference":"사무엘상 8:4","category":"$undefined"},{"id":"7375","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":5,"text":"그에게 이르되 `보소서 당신은 늙고 당신의 아들들은 당신의 행위를 따르지 아니하니 열방과 같이 우리에게 왕을 세워 우리를 다스리게 하소서' 한지라","reference":"사무엘상 8:5","category":"$undefined"},{"id":"7376","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":6,"text":"우리에게 왕을 주어 우리를 다스리게 하라 한 그것을 사무엘이 기뻐하지 아니하여 여호와께 기도하매","reference":"사무엘상 8:6","category":"$undefined"},{"id":"7377","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":7,"text":"여호와께서 사무엘에게 이르시되 백성이 네게 한 말을 다 들으라 그들이 너를 버림이 아니요 나를 버려 자기들의 왕이 되지 못하게 함이니라","reference":"사무엘상 8:7","category":"$undefined"},{"id":"7378","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":8,"text":"내가 그들을 애굽에서 인도하여낸 날부터 오늘날까지 그들이 모든 행사로 나를 버리고 다른 신들을 섬김같이 네게도 그리하는도다","reference":"사무엘상 8:8","category":"$undefined"},{"id":"7379","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":9,"text":"그러므로 그들의 말을 듣되 너는 그들에게 엄히 경계하고 그들을 다스릴 왕의 제도를 알게 하라","reference":"사무엘상 8:9","category":"$undefined"},{"id":"7380","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":10,"text":"사무엘이 왕을 구하는 백성에게 여호와의 모든 말씀을 일러","reference":"사무엘상 8:10","category":"$undefined"},{"id":"7381","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":11,"text":"가로되 `너희를 다스릴 왕의 제도가 이러하니라 그가 너희 아들들을 취하여 그 병거와 말을 어거케 하리니 그들이 그 병거 앞에서 달릴 것이며","reference":"사무엘상 8:11","category":"$undefined"},{"id":"7382","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":12,"text":"그가 또 너희 아들들로 천부장과 오십부장을 삼을 것이며 자기 밭을 갈게 하고 자기 추수를 하게 할 것이며 자기 병거와 병거의 제구를 만들게 할 것이며","reference":"사무엘상 8:12","category":"$undefined"},{"id":"7383","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":13,"text":"그가 또 너희 딸들을 취하여 향료 만드는 자와 요리하는 자와 떡굽는 자를 삼을 것이며","reference":"사무엘상 8:13","category":"$undefined"},{"id":"7384","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":14,"text":"그가 또 너희 밭과 포도원과 감람원의 제일 좋은 것을 취하여 자기 신하들에게 줄 것이며","reference":"사무엘상 8:14","category":"$undefined"},{"id":"7385","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":15,"text":"그가 또 너희 곡식과 포도원 소산의 십일조를 취하여 자기 관리와 신하에게 줄 것이며","reference":"사무엘상 8:15","category":"$undefined"},{"id":"7386","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":16,"text":"그가 또 너희 노비와 가장 아름다운 소년과 나귀들을 취하여 자기 일을 시킬 것이며","reference":"사무엘상 8:16","category":"$undefined"},{"id":"7387","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":17,"text":"너희 양떼의 십분 일을 취하리니 너희가 그 종이 될 것이라","reference":"사무엘상 8:17","category":"$undefined"},{"id":"7388","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":18,"text":"그날에 너희가 너희 택한 왕을 인하여 부르짖되 그날에 여호와께서 너희에게 응답지 아니하시리라'","reference":"사무엘상 8:18","category":"$undefined"},{"id":"7389","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":19,"text":"백성이 사무엘의 말 듣기를 거절하여 가로되 `아니로소이다 우리도 우리 왕이 있어야 하리니","reference":"사무엘상 8:19","category":"$undefined"},{"id":"7390","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":20,"text":"우리도 열방과 같이 되어 우리 왕이 우리를 다스리며 우리 앞에 나가서 우리의 싸움을 싸워야 할 것이니이다'","reference":"사무엘상 8:20","category":"$undefined"},{"id":"7391","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":21,"text":"사무엘이 백성의 모든 말을 듣고 여호와께 고하매","reference":"사무엘상 8:21","category":"$undefined"},{"id":"7392","book":"사무엘상","book_name":"사무엘상","chapter":8,"verse":22,"text":"여호와께서 사무엘에게 이르시되 그들의 말을 들어 왕을 세우라 하시니 사무엘이 이스라엘 사람들에게 이르되 `너희는 각기 성읍으로 돌아가라' 하니라","reference":"사무엘상 8:22","category":"$undefined"}],"bookSlug":"1samuel"}]
