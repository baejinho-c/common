2:["$","$L11",null,{"book":{"id":"1samuel","name":"사무엘상","chapters":31,"testament":"old"},"chapter":9,"verses":[{"id":"7393","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":1,"text":"베냐민 지파에 기스라 이름하는 유력한 사람이 있으니 그는 아비엘의 아들이요 스롤의 손자요 베고랏의 증손이요 아비아의 현손 이라 베냐민 사람이더라","reference":"사무엘상 9:1","category":"$undefined"},{"id":"7394","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":2,"text":"기스가 아들이 있으니 그 이름은 사울이요 준수한 소년이라 이스라엘 자손 중에 그보다 더 준수한 자가 없고 키는 모든 백성보다 어깨 위는 더하더라","reference":"사무엘상 9:2","category":"$undefined"},{"id":"7395","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":3,"text":"사울의 아비 기스가 암나귀들을 잃고 그 아들 사울에게 이르되 `너는 한 사환을 데리고 일어나 가서 암나귀들을 찾으라' 하매","reference":"사무엘상 9:3","category":"$undefined"},{"id":"7396","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":4,"text":"그가 에브라임 산지와 살리사 땅으로 두루 다니되 찾지 못하고 사알림 땅으로 두루 다니되 없고 베냐민 사람의 땅으로 두루 다니되 찾지 못하니라","reference":"사무엘상 9:4","category":"$undefined"},{"id":"7397","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":5,"text":"그들이 숩 땅에 이른 때에 사울이 함께 하는 사환에게 이르되 돌아가자 내 부친이 암나귀 생각은 고사하고 우리를 위하여 걱정하실까 두려워하노라","reference":"사무엘상 9:5","category":"$undefined"},{"id":"7398","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":6,"text":"대답하되 `보소서 이 성에 하나님의 사람이 있는데 존중히 여김을 받는 사람이라 그가 말한 것은 반드시 다 응하나니 그리로 가사이다 그가 혹 우리의 갈 길을 가르칠까 하나이다'","reference":"사무엘상 9:6","category":"$undefined"},{"id":"7399","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":7,"text":"사울이 그 사환에게 이르되 `우리가 가면 그 사람에게 무엇을 드리겠느냐 ? 우리 그릇에 식물이 다하였으니 하나님의 사람에게 드릴 예물이 없도다 무엇이 있느냐 ?'","reference":"사무엘상 9:7","category":"$undefined"},{"id":"7400","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":8,"text":"사환이 사울에게 다시 대답하여 가로되 `보소서 내 손에 은 한 세겔의 사분 일이 있으니 하나님의 사람에게 드려 우리 길을 가르치게 하겠나이다'","reference":"사무엘상 9:8","category":"$undefined"},{"id":"7401","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":9,"text":"(옛적 이스라엘에 사람이 하나님께 가서 물으려 하면 말하기를 선견자에게로 가자 하였으니 지금 선지자라 하는 자를 옛적에는 선견자라 일컬었더라)","reference":"사무엘상 9:9","category":"$undefined"},{"id":"7402","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":10,"text":"사울이 그 사환에게 이르되 `네 말이 옳다 가자` 하고 그들이 하나님의 사람 있는 성으로 가니라","reference":"사무엘상 9:10","category":"$undefined"},{"id":"7403","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":11,"text":"그들이 성을 향한 비탈길로 올라가다가 물 길러 나오는 소녀들을 만나 그들에게 묻되 `선견자가 여기 있느냐 ?'","reference":"사무엘상 9:11","category":"$undefined"},{"id":"7404","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":12,"text":"그들이 대답하여 가로되 `있나이다 보소서 그가 당신보다 앞섰으니 빨리 가소서 백성이 오늘 산당에서 제사를 드리므로 그가 오늘 성에 들어오셨나이다","reference":"사무엘상 9:12","category":"$undefined"},{"id":"7405","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":13,"text":"당신들이 성으로 들어가면 그가 먹으러 산당에 올라가기 전에 곧 만나리이다 그가 오기 전에는 백성이 먹지 아니하나니 이는 그가 제물을 축사한 후에야 청함을 받은 자가 먹음이라 그러므로 지금올라 가소서 금시로 만나리이다' 하는지라","reference":"사무엘상 9:13","category":"$undefined"},{"id":"7406","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":14,"text":"그들이 성읍으로 올라가서 그리로 들어갈 때에 사무엘이 마침 산당으로 올라가려고 마주 나오더라","reference":"사무엘상 9:14","category":"$undefined"},{"id":"7407","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":15,"text":"사울의 오기 전 날에 여호와께서 사무엘에게 알게 하여 가라사대","reference":"사무엘상 9:15","category":"$undefined"},{"id":"7408","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":16,"text":"내일 이맘 때에 내가 베냐민 땅에서 한 사람을 네게 보내리니 너는 그에게 기름을 부어 내 백성 이스라엘의 지도자를 삼으라 그가 내 백성을 블레셋 사람의 손에서 구원하리라 내 백성의 부르짖음이 내게 상달하였으므로 내가 그들을 돌아 보았노라 하시더니","reference":"사무엘상 9:16","category":"$undefined"},{"id":"7409","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":17,"text":"사무엘이 사울을 볼 때에 여호와께서 그에게 이르시되 보라, 이는 내가 네게 말한 사람이니 이가 내 백성을 통할하리라 하시니라","reference":"사무엘상 9:17","category":"$undefined"},{"id":"7410","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":18,"text":"사울이 성문 가운데 사무엘에게 나아가 가로되 `선견자의 집이 어디인지 청컨대 내게 가르치소서'","reference":"사무엘상 9:18","category":"$undefined"},{"id":"7411","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":19,"text":"사무엘이 사울에게 대답하여 가로되 `내가 선견자니라 너는 내 앞서 산당으로 올라가라 너희가 오늘날 나와 함께 먹을 것이요 아침에는 내가 너를 보내되 네 마음에 있는 것을 다 네게 말하리라","reference":"사무엘상 9:19","category":"$undefined"},{"id":"7412","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":20,"text":"사흘 전에 잃은 네 암나귀들을 염려하지 말라 찾았느니라 온 이스라엘의 사모하는 자가 누구냐 ? 너와 네 아비의 온 집이 아니냐 ?'","reference":"사무엘상 9:20","category":"$undefined"},{"id":"7413","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":21,"text":"사울이 대답하여 가로되 `나는 이스라엘 지파의 가장 작은 지파 베냐민 사람이 아니오며 나의 가족은 베냐민 지파 모든 가족 중에 가장 미약하지 아니하니이까 당신이 어찌하여 내게 이같이 말씀하시나이까 ?'","reference":"사무엘상 9:21","category":"$undefined"},{"id":"7414","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":22,"text":"사무엘이 사울과 그 사환을 인도하여 객실로 들어가서 청한 자 중 수석에 앉게 하였는데 객은 삼십명 가량이었더라","reference":"사무엘상 9:22","category":"$undefined"},{"id":"7415","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":23,"text":"사무엘이 요리인에게 이르되 `내가 네게 주며 네게 두라고 말한 그 부분을 가져오라'","reference":"사무엘상 9:23","category":"$undefined"},{"id":"7416","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":24,"text":"요리인이 넓적다리와 그것에 붙은 것을 가져다가 사울 앞에 놓는지라 사무엘이 가로되 `보라, 이는 두었던 것이니 네 앞에 놓고 먹으라 내가 백성을 청할 때부터 너를 위하여 이것을 두어서 이때를 기다리게 하였느니라' 그 날에 사울이 사무엘과 함께 먹으니라","reference":"사무엘상 9:24","category":"$undefined"},{"id":"7417","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":25,"text":"그들이 산당에서 내려 성에 들어가서는 사무엘이 사울과 함께 지붕에서 담화하고","reference":"사무엘상 9:25","category":"$undefined"},{"id":"7418","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":26,"text":"그들이 일찌기 일어날새 동틀 때 즈음이라 사무엘이 지붕에서 사울을 불러 가로되 `일어나라 내가 너를 보내리라' 하매 사울이 일어나고 그 두 사람 사울과 사무엘이 함께 밖으로 나가서","reference":"사무엘상 9:26","category":"$undefined"},{"id":"7419","book":"사무엘상","book_name":"사무엘상","chapter":9,"verse":27,"text":"성읍 끝에 이르매 사무엘이 사울에게 이르되 `사환으로 우리를 앞서게 하라' 사환이 앞서매 또 가로되 `너는 이제 잠간 서 있으라 내가 하나님의 말씀을 네게 들리리라'","reference":"사무엘상 9:27","category":"$undefined"}],"bookSlug":"1samuel"}]
