2:["$","$L11",null,{"book":{"id":"1thessalonians","name":"데살로니가전서","chapters":5,"testament":"new"},"chapter":2,"verses":[{"id":"29572","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":1,"text":"형제들아 우리가 너희 가운데 들어감이 헛되지 않은 줄을 너희가 친히 아나니","reference":"데살로니가전서 2:1","category":"$undefined"},{"id":"29573","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":2,"text":"너희 아는 바와 같이 우리가 먼저 빌립보에서 고난과 능욕을 당하였으나 우리 하나님을 힘입어 많은 싸움 중에 하나님의 복음을 너희에게 말하였노라","reference":"데살로니가전서 2:2","category":"$undefined"},{"id":"29574","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":3,"text":"우리의 권면은 간사에서나 부정에서 난 것도 아니요 궤계에 있는 것도 아니라","reference":"데살로니가전서 2:3","category":"$undefined"},{"id":"29575","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":4,"text":"오직 하나님의 옳게 여기심을 입어 복음 전할 부탁을 받았으니 우리가 이와 같이 말함은 사람을 기쁘게 하려 함이 아니요 오직 우리 마음을 감찰하시는 하나님을 기쁘시게 하려 함이라","reference":"데살로니가전서 2:4","category":"$undefined"},{"id":"29576","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":5,"text":"너희도 알거니와 우리가 아무 때에도 아첨의 말이나 탐심의 탈을 쓰지 아니한 것을 하나님이 증거하시느니라","reference":"데살로니가전서 2:5","category":"$undefined"},{"id":"29577","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":6,"text":"우리가 그리스도의 사도로 능히 존중할 터이나 그러나 너희에게든지 다른 이에게든지 사람에게는 영광을 구치 아니하고","reference":"데살로니가전서 2:6","category":"$undefined"},{"id":"29578","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":7,"text":"오직 우리가 너희 가운데서 유순한 자 되어 유모가 자기 자녀를 기름과 같이 하였으니","reference":"데살로니가전서 2:7","category":"$undefined"},{"id":"29579","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":8,"text":"우리가 이같이 너희를 사모하여 하나님의 복음으로만 아니라 우리 목숨까지 너희에게 주기를 즐겨 함은 너희가 우리의 사랑하는자 됨이니라","reference":"데살로니가전서 2:8","category":"$undefined"},{"id":"29580","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":9,"text":"형제들아 우리의 수고와 애쓴 것을 너희가 기억하리니 너희 아무에게도 누를 끼치지 아니하려고 밤과 낮으로 일하면서 너희에게 하나님의 복음을 전파하였노라","reference":"데살로니가전서 2:9","category":"$undefined"},{"id":"29581","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":10,"text":"우리가 너희 믿는 자들을 향하여 어떻게 거룩하고 옳고 흠없이 행한 것에 대하여 너희가 증인이요 하나님도 그러하시도다","reference":"데살로니가전서 2:10","category":"$undefined"},{"id":"29582","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":11,"text":"너희도 아는 바와 같이 우리가 너희 각 사람에게 아비가 자기 자녀에게 하듯 권면하고 위로하고 경계하노니","reference":"데살로니가전서 2:11","category":"$undefined"},{"id":"29583","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":12,"text":"이는 너희를 부르사 자기 나라와 영광에 이르게 하시는 하나님께 합당히 행하게 하려 함이니라","reference":"데살로니가전서 2:12","category":"$undefined"},{"id":"29584","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":13,"text":"이러므로 우리가 하나님께 쉬지 않고 감사함은 너희가 우리에게 들은 바 하나님의 말씀을 받을 때에 사람의 말로 아니하고 하나님의 말씀으로 받음이니 진실로 그러하다 이 말씀이 또한 너희 믿는 자 속에서 역사하느니라 !","reference":"데살로니가전서 2:13","category":"$undefined"},{"id":"29585","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":14,"text":"형제들아 너희가 그리스도 예수 안에서 유대에 있는 하나님의 교회들을 본받은 자 되었으니 저희가 유대인들에게 고난을 받음과 같이 너희도 너희 나라 사람들에게 동일한 것을 받았느니라","reference":"데살로니가전서 2:14","category":"$undefined"},{"id":"29586","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":15,"text":"유대인은 주 예수와 선지자들을 죽이고 우리를 쫓아내고 하나님을 기쁘시게 아니하고 모든 사람에게 대적이 되어","reference":"데살로니가전서 2:15","category":"$undefined"},{"id":"29587","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":16,"text":"우리가 이방인에게 말하여 구원 얻게 함을 저희가 금하여 자기 죄를 항상 채우매 노하심이 끝까지 저희에게 임하였느니라","reference":"데살로니가전서 2:16","category":"$undefined"},{"id":"29588","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":17,"text":"형제들아 우리가 잠시 너희를 떠난 것은 얼굴이요 마음은 아니니 너희 얼굴 보기를 열정으로 더욱 힘썼노라","reference":"데살로니가전서 2:17","category":"$undefined"},{"id":"29589","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":18,"text":"그러므로 나 바울은 한 번 두 번 너희에게 가고자 하였으나 사단이 우리를 막았도다","reference":"데살로니가전서 2:18","category":"$undefined"},{"id":"29590","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":19,"text":"우리의 소망이나 기쁨이나 자랑의 면류관이 무엇이냐 ? 그의 강림하실 때 우리 주 예수 앞에 너희가 아니냐","reference":"데살로니가전서 2:19","category":"$undefined"},{"id":"29591","book":"데살로니가전서","book_name":"데살로니가전서","chapter":2,"verse":20,"text":"너희는 우리의 영광이요 기쁨이니라","reference":"데살로니가전서 2:20","category":"$undefined"}],"bookSlug":"1thessalonians"}]
