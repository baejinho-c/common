2:["$","$L11",null,{"book":{"id":"1thessalonians","name":"데살로니가전서","chapters":5,"testament":"new"},"chapter":3,"verses":[{"id":"29592","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":1,"text":"이러므로 우리가 참다 못하여 우리만 아덴에 머물기를 좋게 여겨","reference":"데살로니가전서 3:1","category":"$undefined"},{"id":"29593","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":2,"text":"우리 형제 곧 그리스도 복음의 하나님의 일군인 디모데를 보내노니 이는 너희를 굳게 하고 너희 믿음에 대하여 위로함으로","reference":"데살로니가전서 3:2","category":"$undefined"},{"id":"29594","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":3,"text":"누구든지 이 여러 환난 중에 요동치 않게 하려 함이라 우리로 이것을 당하게 세우신 줄을 너희가 친히 알리라","reference":"데살로니가전서 3:3","category":"$undefined"},{"id":"29595","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":4,"text":"우리가 너희와 함께 있을 때에 장차 받을 환난을 너희에게 미리 말하였더니 과연 그렇게 된 것을 너희가 아느니라","reference":"데살로니가전서 3:4","category":"$undefined"},{"id":"29596","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":5,"text":"이러므로 나도 참다 못하여 너희 믿음을 알기 위하여 보내었노니 이는 혹 시험하는 자가 너희를 시험하여 우리 수고를 헛되게 할까 함일러니","reference":"데살로니가전서 3:5","category":"$undefined"},{"id":"29597","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":6,"text":"지금은 디모데가 너희에게로부터 와서 너희 믿음과 사랑의 기쁜 소식을 우리에게 전하고 또 너희가 항상 우리를 잘 생각하여 우리가 너희를 간절히 보고자 함과 같이 너희도 우리를 간절히 보고자 한다 하니","reference":"데살로니가전서 3:6","category":"$undefined"},{"id":"29598","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":7,"text":"이러므로 형제들아 ! 우리가 모든 궁핍과 환난 가운데서 너희 믿음으로 말미암아 너희에게 위로를 받았노라","reference":"데살로니가전서 3:7","category":"$undefined"},{"id":"29599","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":8,"text":"그러므로 너희가 주 안에 굳게 선즉 우리가 이제는 살리라","reference":"데살로니가전서 3:8","category":"$undefined"},{"id":"29600","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":9,"text":"우리가 우리 하나님 앞에서 너희를 인하여 모든 기쁨으로 기뻐하니 너희를 위하여 능히 어떠한 감사함으로 하나님께 보답할꼬","reference":"데살로니가전서 3:9","category":"$undefined"},{"id":"29601","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":10,"text":"주야로 심히 간구함은 너희 얼굴을 보고 너희 믿음의 부족함을 온전케 하려 함이라","reference":"데살로니가전서 3:10","category":"$undefined"},{"id":"29602","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":11,"text":"하나님 우리 아버지와 우리 주 예수는 우리 길을 너희에게로 직행하게 하옵시며","reference":"데살로니가전서 3:11","category":"$undefined"},{"id":"29603","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":12,"text":"또 주께서 우리가 너희를 사랑함과 같이 너희도 피차간과 모든 사람에 대한 사랑이 더욱 많아 넘치게 하사","reference":"데살로니가전서 3:12","category":"$undefined"},{"id":"29604","book":"데살로니가전서","book_name":"데살로니가전서","chapter":3,"verse":13,"text":"너희 마음을 굳게 하시고 우리 주 예수께서 그의 모든 성도와 함께 강림하실 때에 하나님 우리 아버지 앞에서 거룩함에 흠이 없게 하시기를 원하노라","reference":"데살로니가전서 3:13","category":"$undefined"}],"bookSlug":"1thessalonians"}]
