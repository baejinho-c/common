2:["$","$L11",null,{"book":{"id":"1thessalonians","name":"데살로니가전서","chapters":5,"testament":"new"},"chapter":4,"verses":[{"id":"29605","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":1,"text":"종말로 형제들아 우리가 주 예수 안에서 너희에게 구하고 권면하노니 너희가 마땅히 어떻게 행하며 하나님께 기쁘시게 할 것을 우리에게 받았으니 곧 너희 행하는 바라 더욱 많이 힘쓰라","reference":"데살로니가전서 4:1","category":"$undefined"},{"id":"29606","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":2,"text":"우리가 주 예수로 말미암아 너희에게 무슨 명령으로 준 것을 너희가 아느니라","reference":"데살로니가전서 4:2","category":"$undefined"},{"id":"29607","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":3,"text":"하나님의 뜻은 이것이니 너희의 거룩함이라 곧 음란을 버리고","reference":"데살로니가전서 4:3","category":"$undefined"},{"id":"29608","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":4,"text":"각각 거룩함과 존귀함으로 자기의 아내 취할 줄을 알고","reference":"데살로니가전서 4:4","category":"$undefined"},{"id":"29609","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":5,"text":"하나님을 모르는 이방인과 같이 색욕을 좇지 말고","reference":"데살로니가전서 4:5","category":"$undefined"},{"id":"29610","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":6,"text":"이 일에 분수를 넘어서 형제를 해하지 말라 이는 우리가 너희에게 미리 말하고 증거한 것과 같이 이 모든 일에 주께서 신원하여 주심이니라","reference":"데살로니가전서 4:6","category":"$undefined"},{"id":"29611","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":7,"text":"하나님이 우리를 부르심은 부정케 하심이 아니요 거룩케 하심이니","reference":"데살로니가전서 4:7","category":"$undefined"},{"id":"29612","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":8,"text":"그러므로 저버리는 자는 사람을 저버림이 아니요 너희에게 그의 성령을 주신 하나님을 저버림이니라","reference":"데살로니가전서 4:8","category":"$undefined"},{"id":"29613","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":9,"text":"형제 사랑에 관하여는 너희에게 쓸 것이 없음은 너희가 친히 하나님의 가르치심을 받아 서로 사랑함이라","reference":"데살로니가전서 4:9","category":"$undefined"},{"id":"29614","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":10,"text":"너희가 온 마게도냐 모든 형제를 대하여 과연 이것을 행하도다 형제들아 권하노니 더 많이 하고","reference":"데살로니가전서 4:10","category":"$undefined"},{"id":"29615","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":11,"text":"또 너희에게 명한 것같이 종용하여 자기 일을 하고 너희 손으로 일하기를 힘쓰라","reference":"데살로니가전서 4:11","category":"$undefined"},{"id":"29616","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":12,"text":"이는 외인을 대하여 단정히 행하고 또한 아무 궁핍함이 없게 하려 함이라","reference":"데살로니가전서 4:12","category":"$undefined"},{"id":"29617","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":13,"text":"형제들아 자는 자들에 관하여는 너희가 알지 못함을 우리가 원치 아니하노니 이는 소망 없는 다른 이와 같이 슬퍼하지 않게 하려 함이라","reference":"데살로니가전서 4:13","category":"$undefined"},{"id":"29618","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":14,"text":"우리가 예수의 죽었다가 다시 사심을 믿을진대 이와 같이 예수 안에서 자는 자들도 하나님이 저와 함께 데리고 오시리라","reference":"데살로니가전서 4:14","category":"$undefined"},{"id":"29619","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":15,"text":"우리가 주의 말씀으로 너희에게 이것을 말하노니 주 강림하실 때까지 우리 살아 남아 있는 자도 자는 자보다 결단코 앞서지 못하리라","reference":"데살로니가전서 4:15","category":"$undefined"},{"id":"29620","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":16,"text":"주께서 호령과 천사장의 소리와 하나님의 나팔로 친히 하늘로 좇아 강림하시리니 그리스도 안에서 죽은 자들이 먼저 일어나고","reference":"데살로니가전서 4:16","category":"$undefined"},{"id":"29621","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":17,"text":"그 후에 우리 살아 남은 자도 저희와 함께 구름 속으로 끌어올려 공중에서 주를 영접하게 하시리니 그리하여 우리가 항상 주와 함께 있으리라","reference":"데살로니가전서 4:17","category":"$undefined"},{"id":"29622","book":"데살로니가전서","book_name":"데살로니가전서","chapter":4,"verse":18,"text":"그러므로 이 여러 말로 서로 위로하라","reference":"데살로니가전서 4:18","category":"$undefined"}],"bookSlug":"1thessalonians"}]
