2:["$","$L11",null,{"book":{"id":"1thessalonians","name":"데살로니가전서","chapters":5,"testament":"new"},"chapter":5,"verses":[{"id":"29623","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":1,"text":"형제들아 때와 시기에 관하여는 너희에게 쓸 것이 없음은","reference":"데살로니가전서 5:1","category":"$undefined"},{"id":"29624","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":2,"text":"주의 날이 밤에 도적같이 이를 줄을 너희 자신이 자세히 앎이라","reference":"데살로니가전서 5:2","category":"$undefined"},{"id":"29625","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":3,"text":"저희가 평안하다, 안전하다 할 그 때에 잉태된 여자에게 해산 고통이 이름과 같이 멸망이 홀연히 저희에게 이르리니 결단코 피하지 못하리라","reference":"데살로니가전서 5:3","category":"$undefined"},{"id":"29626","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":4,"text":"형제들아 너희는 어두움에 있지 아니하매 그 날이 도적같이 너희에게 임하지 못하리니","reference":"데살로니가전서 5:4","category":"$undefined"},{"id":"29627","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":5,"text":"너희는 다 빛의 아들이요 낮의 아들이라 우리가 밤이나 어두움에 속하지 아니하나니","reference":"데살로니가전서 5:5","category":"$undefined"},{"id":"29628","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":6,"text":"그러므로 우리는 다른 이들과 같이 자지 말고 오직 깨어 근신할지라","reference":"데살로니가전서 5:6","category":"$undefined"},{"id":"29629","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":7,"text":"자는 자들은 밤에 자고 취하는 자들은 밤에 취하되","reference":"데살로니가전서 5:7","category":"$undefined"},{"id":"29630","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":8,"text":"우리는 낮에 속하였으니 근신하여 믿음과 사랑의 흉배를 붙이고 구원의 소망의 투구를 쓰자","reference":"데살로니가전서 5:8","category":"$undefined"},{"id":"29631","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":9,"text":"하나님이 우리를 세우심은 노하심에 이르게 하심이 아니요 오직 우리 주 예수 그리스도로 말미암아 구원을 얻게 하신 것이라","reference":"데살로니가전서 5:9","category":"$undefined"},{"id":"29632","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":10,"text":"예수께서 우리를 위하여 죽으사 우리로 하여금 깨든지 자든지 자기와 함께 살게 하려 하셨느니라","reference":"데살로니가전서 5:10","category":"$undefined"},{"id":"29633","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":11,"text":"그러므로 피차 권면하고 피차 덕을 세우기를 너희가 하는 것같이 하라","reference":"데살로니가전서 5:11","category":"$undefined"},{"id":"29634","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":12,"text":"형제들아 우리가 너희에게 구하노니 너희 가운데서 수고하고 주 안에서 너희를 다스리며 권하는 자들을 너희가 알고","reference":"데살로니가전서 5:12","category":"$undefined"},{"id":"29635","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":13,"text":"저의 역사로 말미암아 사랑 안에서 가장 귀히 여기며 너희끼리 화목하라","reference":"데살로니가전서 5:13","category":"$undefined"},{"id":"29636","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":14,"text":"또 형제들아 너희를 권면하노니 규모없는 자들을 권계하며 마음이 약한 자들을 안위하고 힘이 없는 자들을 붙들어 주며 모든 사람을 대하여 오래 참으라","reference":"데살로니가전서 5:14","category":"$undefined"},{"id":"29637","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":15,"text":"삼가 누가 누구에게든지 악으로 악을 갚지 말게 하고 오직 피차 대하든지 모든 사람을 대하든지 항상 선을 좇으라","reference":"데살로니가전서 5:15","category":"$undefined"},{"id":"29638","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":16,"text":"항상 기뻐하라 !","reference":"데살로니가전서 5:16","category":"$undefined"},{"id":"29639","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":17,"text":"쉬지 말고 기도하라 !","reference":"데살로니가전서 5:17","category":"$undefined"},{"id":"29640","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":18,"text":"범사에 감사하라 ! 이는 그리스도 예수 안에서 너희를 향하신 하나님의 뜻이니라","reference":"데살로니가전서 5:18","category":"$undefined"},{"id":"29641","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":19,"text":"성령을 소멸치 말며","reference":"데살로니가전서 5:19","category":"$undefined"},{"id":"29642","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":20,"text":"예언을 멸시치 말고","reference":"데살로니가전서 5:20","category":"$undefined"},{"id":"29643","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":21,"text":"범사에 헤아려 좋은 것을 취하고","reference":"데살로니가전서 5:21","category":"$undefined"},{"id":"29644","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":22,"text":"악은 모든 모양이라도 버리라 !","reference":"데살로니가전서 5:22","category":"$undefined"},{"id":"29645","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":23,"text":"평강의 하나님이 친히 너희로 온전히 거룩하게 하시고 또 너희 온 영과 혼과 몸이 우리 주 예수 그리스도 강림하실 때에 흠 없게 보전되기를 원하노라","reference":"데살로니가전서 5:23","category":"$undefined"},{"id":"29646","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":24,"text":"너희를 부르시는 이는 미쁘시니 그가 또한 이루시리라","reference":"데살로니가전서 5:24","category":"$undefined"},{"id":"29647","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":25,"text":"형제들아 우리를 위하여 기도하라","reference":"데살로니가전서 5:25","category":"$undefined"},{"id":"29648","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":26,"text":"거룩하게 입맞춤으로 모든 형제에게 문안하라","reference":"데살로니가전서 5:26","category":"$undefined"},{"id":"29649","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":27,"text":"내가 주를 힘입어 너희를 명하노니 모든 형제에게 이 편지를 읽어 들리라","reference":"데살로니가전서 5:27","category":"$undefined"},{"id":"29650","book":"데살로니가전서","book_name":"데살로니가전서","chapter":5,"verse":28,"text":"우리 주 예수 그리스도의 은혜가 너희에게 있을지어다 !","reference":"데살로니가전서 5:28","category":"$undefined"}],"bookSlug":"1thessalonians"}]
