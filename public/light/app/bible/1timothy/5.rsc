2:["$","$L11",null,{"book":{"id":"1timothy","name":"디모데전서","chapters":6,"testament":"new"},"chapter":5,"verses":[{"id":"29765","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":1,"text":"늙은이를 꾸짖지 말고 권하되 아비에게 하듯하며 젊은이를 형제에게 하듯하고","reference":"디모데전서 5:1","category":"$undefined"},{"id":"29766","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":2,"text":"늙은 여자를 어미에게 하듯하며 젊은 여자를 일절 깨끗함으로 자매에게 하듯 하라","reference":"디모데전서 5:2","category":"$undefined"},{"id":"29767","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":3,"text":"참 과부인 과부를 경대하라","reference":"디모데전서 5:3","category":"$undefined"},{"id":"29768","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":4,"text":"만일 어떤 과부에게 자녀나 손자들이 있거든 저희로 먼저 자기 집에서 효를 행하여 부모에게 보답하기를 배우게 하라 이것이 하나님 앞에 받으실 만한 것이니라","reference":"디모데전서 5:4","category":"$undefined"},{"id":"29769","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":5,"text":"참 과부로서 외로운 자는 하나님께 소망을 두어 주야로 항상 간구와 기도를 하거니와","reference":"디모데전서 5:5","category":"$undefined"},{"id":"29770","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":6,"text":"일락을 좋아하는 이는 살았으나 죽었느니라","reference":"디모데전서 5:6","category":"$undefined"},{"id":"29771","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":7,"text":"네가 또한 이것을 명하여 그들로 책망 받을 것이 없게 하라","reference":"디모데전서 5:7","category":"$undefined"},{"id":"29772","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":8,"text":"누구든지 자기 친족 특히 자기 가족을 돌아보지 아니하면 믿음을 배반한 자요 불신자보다 더 악한 자니라","reference":"디모데전서 5:8","category":"$undefined"},{"id":"29773","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":9,"text":"과부로 명부에 올릴 자는 나이 육십이 덜 되지 아니하고 한 남편의 아내이었던 자로서","reference":"디모데전서 5:9","category":"$undefined"},{"id":"29774","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":10,"text":"선한 행실의 증거가 있어 혹은 자녀를 양육하며 혹은 나그네를 대접하며 혹은 성도들의 발을 씻기며 혹은 환난 당한 자들을 구제하며 혹은 모든 선한 일을 좇은 자라야 할 것이요","reference":"디모데전서 5:10","category":"$undefined"},{"id":"29775","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":11,"text":"젊은 과부는 거절하라 이는 정욕으로 그리스도를 배반할 때에 시집가고자 함이니","reference":"디모데전서 5:11","category":"$undefined"},{"id":"29776","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":12,"text":"처음 믿음을 저버렸으므로 심판을 받느니라","reference":"디모데전서 5:12","category":"$undefined"},{"id":"29777","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":13,"text":"또 저희가 게으름을 익혀 집집에 돌아다니고 게으를 뿐 아니라 망령된 폄론을 하며 일을 만들며 마땅히 아니할 말을 하나니","reference":"디모데전서 5:13","category":"$undefined"},{"id":"29778","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":14,"text":"그러므로 젊은이는 시집가서 아이를 낳고 집을 다스리고 대적에게 훼방할 기회를 조금도 주지 말기를 원하노라","reference":"디모데전서 5:14","category":"$undefined"},{"id":"29779","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":15,"text":"이미 사단에게 돌아간 자들도 있도다","reference":"디모데전서 5:15","category":"$undefined"},{"id":"29780","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":16,"text":"만일 믿는 여자에게 과부 친척이 있거든 자기가 도와주고 교회로 짐지지 말게 하라 이는 참 과부를 도와주게 하려 함이니라","reference":"디모데전서 5:16","category":"$undefined"},{"id":"29781","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":17,"text":"잘 다스리는 장로들을 배나 존경할 자로 알되 말씀과 가르침에 수고하는 이들을 더할 것이니라","reference":"디모데전서 5:17","category":"$undefined"},{"id":"29782","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":18,"text":"성경에 일렀으되 곡식을 밟아 떠는 소의 입에 망을 씌우지 말라 하였고 또 일군이 그 삯을 받는 것이 마땅하다 하였느니라","reference":"디모데전서 5:18","category":"$undefined"},{"id":"29783","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":19,"text":"장로에 대한 송사는 두 세 증인이 없으면 받지 말 것이요","reference":"디모데전서 5:19","category":"$undefined"},{"id":"29784","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":20,"text":"범죄한 자들을 모든 사람 앞에 꾸짖어 나머지 사람으로 두려워 하게 하라","reference":"디모데전서 5:20","category":"$undefined"},{"id":"29785","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":21,"text":"하나님과 그리스도 예수와 택하심을 받은 천사들 앞에서 내가 엄히 명하노니 너는 편견이 없이 이것들을 지켜 아무 일도 편벽되이 하지 말며","reference":"디모데전서 5:21","category":"$undefined"},{"id":"29786","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":22,"text":"아무에게나 경솔히 안수하지 말고 다른 사람의 죄에 간섭지 말고 네 자신을 지켜 정결케 하라","reference":"디모데전서 5:22","category":"$undefined"},{"id":"29787","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":23,"text":"이제부터는 물만 마시지 말고 네 비위와 자주 나는 병을 인하여 포도주를 조금씩 쓰라","reference":"디모데전서 5:23","category":"$undefined"},{"id":"29788","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":24,"text":"어떤 사람들의 죄는 밝히 드러나 먼저 심판에 나아가고 어떤 사람들의 죄는 그 뒤를 좇나니","reference":"디모데전서 5:24","category":"$undefined"},{"id":"29789","book":"디모데전서","book_name":"디모데전서","chapter":5,"verse":25,"text":"이와 같이 선행도 밝히 드러나고 그렇지 아니한 것도 숨길 수 없느니라","reference":"디모데전서 5:25","category":"$undefined"}],"bookSlug":"1timothy"}]
