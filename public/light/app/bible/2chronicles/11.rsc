2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":11,"verses":[{"id":"11416","book":"역대하","book_name":"역대하","chapter":11,"verse":1,"text":"르호보암이 예루살렘에 이르러 유다와 베냐민 족속을 모으니 택한 용사가 십 팔만이라 이스라엘과 싸워 나라를 회복하여 르호보암에게 돌리려 하더니","reference":"역대하 11:1","category":"$undefined"},{"id":"11417","book":"역대하","book_name":"역대하","chapter":11,"verse":2,"text":"여호와의 말씀이 하나님의 사람 스마야에게 임하여 가라사대","reference":"역대하 11:2","category":"$undefined"},{"id":"11418","book":"역대하","book_name":"역대하","chapter":11,"verse":3,"text":"솔로몬의 아들 유다 왕 르호보암과 유다와 베냐민의 이스라엘 무리에게 고하여 이르기를","reference":"역대하 11:3","category":"$undefined"},{"id":"11419","book":"역대하","book_name":"역대하","chapter":11,"verse":4,"text":"여호와의 말씀이 너희는 올라 가지 말라 너희 형제와 싸우지 말고 각기 집으로 돌아가라 이 일이 내게로 말미암아 난 것이라 하셨다 하라 하신지라 저희가 여호와의 말씀을 듣고 돌아가고 여로보암을 치러 가지 아니하였더라","reference":"역대하 11:4","category":"$undefined"},{"id":"11420","book":"역대하","book_name":"역대하","chapter":11,"verse":5,"text":"르호보암이 예루살렘에 거하여 유다 땅에 방비하는 성읍들을 건축하였으니","reference":"역대하 11:5","category":"$undefined"},{"id":"11421","book":"역대하","book_name":"역대하","chapter":11,"verse":6,"text":"곧 베들레헴과, 에담과, 드고아와,","reference":"역대하 11:6","category":"$undefined"},{"id":"11422","book":"역대하","book_name":"역대하","chapter":11,"verse":7,"text":"벧술과, 소고와, 아둘람과,","reference":"역대하 11:7","category":"$undefined"},{"id":"11423","book":"역대하","book_name":"역대하","chapter":11,"verse":8,"text":"가드와, 마레사와, 십과,","reference":"역대하 11:8","category":"$undefined"},{"id":"11424","book":"역대하","book_name":"역대하","chapter":11,"verse":9,"text":"아도라임과, 라기스와, 아세가와,","reference":"역대하 11:9","category":"$undefined"},{"id":"11425","book":"역대하","book_name":"역대하","chapter":11,"verse":10,"text":"소라와, 아얄론과, 헤브론이니 다 유다와 베냐민 땅에 있어 견고한 성읍이라","reference":"역대하 11:10","category":"$undefined"},{"id":"11426","book":"역대하","book_name":"역대하","chapter":11,"verse":11,"text":"르호보암이 이 모든 성읍을 더욱 견고케 하고 장관을 그 가운데 두고 양식과 기름과 포도주를 저축하고","reference":"역대하 11:11","category":"$undefined"},{"id":"11427","book":"역대하","book_name":"역대하","chapter":11,"verse":12,"text":"각 성읍에 방패와 창을 두어 심히 강하게 하니라 유다와 베냐민이 르호보암에게 속하였더라","reference":"역대하 11:12","category":"$undefined"},{"id":"11428","book":"역대하","book_name":"역대하","chapter":11,"verse":13,"text":"온 이스라엘의 제사장과 레위 사람이 그 모든 지방에서부터 르호보암에게 돌아오되","reference":"역대하 11:13","category":"$undefined"},{"id":"11429","book":"역대하","book_name":"역대하","chapter":11,"verse":14,"text":"레위 사람이 그 향리와 산업을 떠나 유다와 예루살렘에 이르렀으니 이는 여로보암과 그 아들들이 저희를 폐하여 여호와께 제사장의 직분을 행치 못하게 하고","reference":"역대하 11:14","category":"$undefined"},{"id":"11430","book":"역대하","book_name":"역대하","chapter":11,"verse":15,"text":"여로보암이 여러 산당과 수염소 우상과 자기가 만든 송아지 우상을 위하여 스스로 제사장들을 세움이라","reference":"역대하 11:15","category":"$undefined"},{"id":"11431","book":"역대하","book_name":"역대하","chapter":11,"verse":16,"text":"이스라엘 모든 지파 중에 마음을 오로지하여 이스라엘 하나님 여호와를 구하는 자들이 레위사람을 따라 예루살렘에 이르러 그 열조의 하나님 여호와께 제사하고자 한지라","reference":"역대하 11:16","category":"$undefined"},{"id":"11432","book":"역대하","book_name":"역대하","chapter":11,"verse":17,"text":"그러므로 삼년동안 유다 나라를 도와 솔로몬의 아들 르호보암을 강성하게 하였으니 이는 무리가 삼년을 다윗과 솔로몬의 길로 행하였음이더라","reference":"역대하 11:17","category":"$undefined"},{"id":"11433","book":"역대하","book_name":"역대하","chapter":11,"verse":18,"text":"르호보암이 다윗의 아들 여리못의 딸 마할랏으로 아내를 삼았으니 마할랏은 이새의 아들 엘리압의 딸 아비하일의 소생이라","reference":"역대하 11:18","category":"$undefined"},{"id":"11434","book":"역대하","book_name":"역대하","chapter":11,"verse":19,"text":"그가 아들들 곧 여우스와 스마랴와 사함을 낳았으며","reference":"역대하 11:19","category":"$undefined"},{"id":"11435","book":"역대하","book_name":"역대하","chapter":11,"verse":20,"text":"그 후에 압살롬의 딸 마아가에게 장가들었더니 저가 아비야와 앗대와 시사와 슬로밋을 낳았더라","reference":"역대하 11:20","category":"$undefined"},{"id":"11436","book":"역대하","book_name":"역대하","chapter":11,"verse":21,"text":"르호보암이 아내 십 팔과 첩 육십을 취하여 아들 이십 팔과 딸 육십을 낳았으나 압살롬의 딸 마아가를 모든 처첩보다 더 사랑하여","reference":"역대하 11:21","category":"$undefined"},{"id":"11437","book":"역대하","book_name":"역대하","chapter":11,"verse":22,"text":"마아가의 아들 아비야를 세워 장자를 삼아 형제 중에 머리가 되게 하였으니 이는 저로 왕이 되게 하고자 함이라","reference":"역대하 11:22","category":"$undefined"},{"id":"11438","book":"역대하","book_name":"역대하","chapter":11,"verse":23,"text":"르호보암이 지혜롭게 행하여 그 모든 아들을 유다와 베냐민의 온 땅 모든 견고한 성읍에 흩어 살게 하고 양식을 후히 주고 아내를 많이 구하여 주었더라","reference":"역대하 11:23","category":"$undefined"}],"bookSlug":"2chronicles"}]
