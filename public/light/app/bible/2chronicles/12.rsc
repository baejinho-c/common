2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":12,"verses":[{"id":"11439","book":"역대하","book_name":"역대하","chapter":12,"verse":1,"text":"르호보암이 나라가 견고하고 세력이 강하매 여호와의 율법을 버리니 온 이스라엘이 본받은지라","reference":"역대하 12:1","category":"$undefined"},{"id":"11440","book":"역대하","book_name":"역대하","chapter":12,"verse":2,"text":"저희가 여호와께 범죄하였으므로 르호보암 왕 오년에 애굽 왕 시삭이 예루살렘을 치러 올라오니","reference":"역대하 12:2","category":"$undefined"},{"id":"11441","book":"역대하","book_name":"역대하","chapter":12,"verse":3,"text":"저에게 병거가 일천 이백승이요 마병이 육만이며 애굽에서 좇아 나온 무리 곧 훔과 숩과 구스 사람이 불가승수라","reference":"역대하 12:3","category":"$undefined"},{"id":"11442","book":"역대하","book_name":"역대하","chapter":12,"verse":4,"text":"시삭이 유다의 견고한 성읍을 취하고 예루살렘에 이르니","reference":"역대하 12:4","category":"$undefined"},{"id":"11443","book":"역대하","book_name":"역대하","chapter":12,"verse":5,"text":"때에 유다 방백들이 시삭을 인하여 예루살렘에 모였는지라 선지자 스마야가 르호보암과 방백들에게 나아와 가로되 여호와의 말씀이 너희가 나를 버렸으므로 나도 너희를 버려 시삭의 손에 붙였노라 하셨다 한지라","reference":"역대하 12:5","category":"$undefined"},{"id":"11444","book":"역대하","book_name":"역대하","chapter":12,"verse":6,"text":"이에 이스라엘 방백들과 왕이 스스로 겸비하여 가로되 여호와는 의로우시다 하매","reference":"역대하 12:6","category":"$undefined"},{"id":"11445","book":"역대하","book_name":"역대하","chapter":12,"verse":7,"text":"여호와께서 저희의 스스로 겸비함을 보신지라 여호와의 말씀이 스마야에게 임하여 가라사대 저희가 스스로 겸비하였으니 내가 멸하지 아니하고 대강 구원하여 나의 노를 시삭의 손으로 예루살렘에 쏟지 아니하리라","reference":"역대하 12:7","category":"$undefined"},{"id":"11446","book":"역대하","book_name":"역대하","chapter":12,"verse":8,"text":"그러나 저희가 시삭의 종이 되어 나를 섬기는 것과 열국을 섬기는 것이 어떠한지 알게 되리라 하셨더라","reference":"역대하 12:8","category":"$undefined"},{"id":"11447","book":"역대하","book_name":"역대하","chapter":12,"verse":9,"text":"애굽 왕 시삭이 올라와서 예루살렘을 치고 여호와의 전 보물과 왕궁의 보물을 몰수히 빼앗고 솔로몬의 만든 금방패도 빼앗은지라","reference":"역대하 12:9","category":"$undefined"},{"id":"11448","book":"역대하","book_name":"역대하","chapter":12,"verse":10,"text":"르호보암 왕이 그 대신에 놋으로 방패를 만들어 궁문을 지키는 시위대 장관들의 손에 맡기매","reference":"역대하 12:10","category":"$undefined"},{"id":"11449","book":"역대하","book_name":"역대하","chapter":12,"verse":11,"text":"왕이 여호와의 전에 들어갈 때마다 시위하는 자가 그 방패를 들고 갔다가 시위소로 도로 가져갔더라","reference":"역대하 12:11","category":"$undefined"},{"id":"11450","book":"역대하","book_name":"역대하","chapter":12,"verse":12,"text":"르호보암이 스스로 겸비하였고 유다에 선한 일도 있으므로 여호와께서 노를 돌이키사 다 멸하지 아니하셨더라","reference":"역대하 12:12","category":"$undefined"},{"id":"11451","book":"역대하","book_name":"역대하","chapter":12,"verse":13,"text":"르호보암 왕이 예루살렘에서 스스로 강하게 하여 치리하니라 르호보암이 위에 나아갈때에 나이 사십일세라 예루살렘 곧 여호와께서 이스라엘 모든 지파중에서 택하여 그 이름을 두신 성에서 십 칠년을 치리하니라 르호보암의 모친의 이름은 나아마라 암몬 여인이더라","reference":"역대하 12:13","category":"$undefined"},{"id":"11452","book":"역대하","book_name":"역대하","chapter":12,"verse":14,"text":"르호보암이 마음을 오로지하여 여호와를 구하지 아니함으로 악을 행하였더라","reference":"역대하 12:14","category":"$undefined"},{"id":"11453","book":"역대하","book_name":"역대하","chapter":12,"verse":15,"text":"르호보암의 시종 행적은 선지자 스마야와 선견자 잇도의 족보책에 기록되지 아니하였느냐 르호보암과 여로보암 사이에 항상 전쟁이 있으니라","reference":"역대하 12:15","category":"$undefined"},{"id":"11454","book":"역대하","book_name":"역대하","chapter":12,"verse":16,"text":"르호보암이 그 열조와 함께 자매 다윗 성에 장사되고 그 아들 아비야가 대신하여 왕이 되니라","reference":"역대하 12:16","category":"$undefined"}],"bookSlug":"2chronicles"}]
