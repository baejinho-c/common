2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":13,"verses":[{"id":"11455","book":"역대하","book_name":"역대하","chapter":13,"verse":1,"text":"여로보암 왕 제 십팔년에 아비야가 유다 왕이 되고","reference":"역대하 13:1","category":"$undefined"},{"id":"11456","book":"역대하","book_name":"역대하","chapter":13,"verse":2,"text":"예루살렘에서 삼년을 치리하니라 그 모친의 이름은 미가야라 기브아사람 우리엘의 딸이더라 아비야가 여로보암으로 더불어 싸울새","reference":"역대하 13:2","category":"$undefined"},{"id":"11457","book":"역대하","book_name":"역대하","chapter":13,"verse":3,"text":"아비야는 택한 바 싸움에 용맹한 군사 사십만으로 싸움을 예비하였고 여로보암은 택한 바 큰 용사 팔십만으로 대진한지라","reference":"역대하 13:3","category":"$undefined"},{"id":"11458","book":"역대하","book_name":"역대하","chapter":13,"verse":4,"text":"아비야가 에브라임산 중 스마라임산 위에 서서 가로되 여로보암과 이스라엘 무리들아 다 들으라","reference":"역대하 13:4","category":"$undefined"},{"id":"11459","book":"역대하","book_name":"역대하","chapter":13,"verse":5,"text":"이스라엘 하나님 여호와께서 소금 언약으로 이스라엘 나라를 영원히 다윗과 그 자손에게 주신 것을 너희가 알 것이 아니냐","reference":"역대하 13:5","category":"$undefined"},{"id":"11460","book":"역대하","book_name":"역대하","chapter":13,"verse":6,"text":"다윗의 아들 솔로몬의 신복 느밧의 아들 여로보암이 일어나 그 주를 배반하고","reference":"역대하 13:6","category":"$undefined"},{"id":"11461","book":"역대하","book_name":"역대하","chapter":13,"verse":7,"text":"난봉과 비류가 모여 좇으므로 스스로 강하게 하여 솔로몬의 아들 르호보암을 대적하나 그 때에 르호보암이 어리고 마음이 연약하여 능히 막지 못하였었느니라","reference":"역대하 13:7","category":"$undefined"},{"id":"11462","book":"역대하","book_name":"역대하","chapter":13,"verse":8,"text":"이제 너희가 또 다윗자손의 손으로 다스리는 여호와의 나라를 대적하려 하는도다 너희는 큰 무리요 또 여로보암이 너희를 위하여 신으로 만든 금송아지가 너희와 함께 있도다","reference":"역대하 13:8","category":"$undefined"},{"id":"11463","book":"역대하","book_name":"역대하","chapter":13,"verse":9,"text":"너희가 아론 자손된 여호와의 제사장과 레위 사람을 쫓아내고 이방 백성의 풍속을 좇아 제사장을 삼지 아니하였느냐 무론 누구든지 수송아지 하나와 수양 일곱을 끌고 와서 장립을 받고자 하는 자마다 허무한 신의 제사장이 될 수 있도다","reference":"역대하 13:9","category":"$undefined"},{"id":"11464","book":"역대하","book_name":"역대하","chapter":13,"verse":10,"text":"우리에게는 여호와께서 우리 하나님이 되시니 그를 우리가 배반치 아니하였고 여호와를 섬기는 제사장들이 있으니 아론의 자손이요 또 레위 사람이 수종을 들어","reference":"역대하 13:10","category":"$undefined"},{"id":"11465","book":"역대하","book_name":"역대하","chapter":13,"verse":11,"text":"조석으로 여호와 앞에 번제를 드리며 분향하며 또 깨끗한 상에 진설병을 놓고 또 금등대가 있어 그 등에 저녁마다 불을 켜나니 우리는 우리하나님 여호와의 계명을 지키나 너희는 그를 배반하 였느니라","reference":"역대하 13:11","category":"$undefined"},{"id":"11466","book":"역대하","book_name":"역대하","chapter":13,"verse":12,"text":"하나님이 우리와 함께 하사 우리의 머리가 되시고 그 제사장들도 우리와 함께하여 경고의 나팔을 불어 너희를 공격하느니라 이스라엘 자손들아 너희 열조의 하나님 여호와와 싸우지 말라 너희가 형통치 못하리라","reference":"역대하 13:12","category":"$undefined"},{"id":"11467","book":"역대하","book_name":"역대하","chapter":13,"verse":13,"text":"여로보암이 유다의 뒤를 둘러 복병하였으므로 그 앞에는 이스라엘 사람이 있고 그 뒤에는 복병이 있는지라","reference":"역대하 13:13","category":"$undefined"},{"id":"11468","book":"역대하","book_name":"역대하","chapter":13,"verse":14,"text":"유다 사람이 돌이켜 보고 자기 앞뒤의 적병을 인하여 여호와께 부르짖고 제사장은 나팔을 부니라","reference":"역대하 13:14","category":"$undefined"},{"id":"11469","book":"역대하","book_name":"역대하","chapter":13,"verse":15,"text":"유다 사람이 소리지르매 유다 사람의 소리지를 때에 하나님이 여로보암과 온 이스라엘을 아비야와 유다 앞에서 쳐서 패하게 하시니라","reference":"역대하 13:15","category":"$undefined"},{"id":"11470","book":"역대하","book_name":"역대하","chapter":13,"verse":16,"text":"이스라엘 자손이 유다 앞에서 도망하는지라 하나님이 그 손에 붙이신고로","reference":"역대하 13:16","category":"$undefined"},{"id":"11471","book":"역대하","book_name":"역대하","chapter":13,"verse":17,"text":"아비야와 그 백성이 크게 도륙하니 이스라엘의 택한 병정이 죽임을 입고 엎드러진 자가 오십만이었더라","reference":"역대하 13:17","category":"$undefined"},{"id":"11472","book":"역대하","book_name":"역대하","chapter":13,"verse":18,"text":"그 때에 이스라엘 자손이 항복하고 유다 자손이 이기었으니 이는 저희가 그 열조의 하나님 여호와를 의지하였음이라","reference":"역대하 13:18","category":"$undefined"},{"id":"11473","book":"역대하","book_name":"역대하","chapter":13,"verse":19,"text":"아비야가 여로보암을 쫓아가서 그 성읍들을 빼앗았으니 곧 벧엘과 그 동네와 여사나와 그 동네와 에브론과 그 동네라","reference":"역대하 13:19","category":"$undefined"},{"id":"11474","book":"역대하","book_name":"역대하","chapter":13,"verse":20,"text":"아비야 때에 여로보암이 다시 강성하지 못하고 여호와의 치심을 입어 죽었고","reference":"역대하 13:20","category":"$undefined"},{"id":"11475","book":"역대하","book_name":"역대하","chapter":13,"verse":21,"text":"아비야는 점점 강성하며 아내 열 넷을 취하여 아들 스물 둘과 딸 열 여섯을 낳았더라","reference":"역대하 13:21","category":"$undefined"},{"id":"11476","book":"역대하","book_name":"역대하","chapter":13,"verse":22,"text":"아비야의 남은 사적과 그 행위와 그 말은 선지자 잇도의 주석책에 기록되니라","reference":"역대하 13:22","category":"$undefined"}],"bookSlug":"2chronicles"}]
