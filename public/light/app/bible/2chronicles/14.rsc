2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":14,"verses":[{"id":"11477","book":"역대하","book_name":"역대하","chapter":14,"verse":1,"text":"아비야가 그 열조와 함께 자매 다윗성에 장사되고 그 아들 아사가 대신하여 왕이 되니 그 시대에 그 땅이 십년을 평안하니라","reference":"역대하 14:1","category":"$undefined"},{"id":"11478","book":"역대하","book_name":"역대하","chapter":14,"verse":2,"text":"아사가 그 하나님 여호와 보시기에 선과 정의를 행하여","reference":"역대하 14:2","category":"$undefined"},{"id":"11479","book":"역대하","book_name":"역대하","chapter":14,"verse":3,"text":"이방 제단과 산당을 없이하고 주상을 훼파하며 아세라 상을 찍고","reference":"역대하 14:3","category":"$undefined"},{"id":"11480","book":"역대하","book_name":"역대하","chapter":14,"verse":4,"text":"유다 사람을 명하여 그 열조의 하나님 여호와를 구하게 하며 그 율법과 명령을 행하게 하고","reference":"역대하 14:4","category":"$undefined"},{"id":"11481","book":"역대하","book_name":"역대하","chapter":14,"verse":5,"text":"또 유다 모든 성읍에서 산당과 태양상을 없이하매 나라가 그 앞에서 평안함을 얻으니라","reference":"역대하 14:5","category":"$undefined"},{"id":"11482","book":"역대하","book_name":"역대하","chapter":14,"verse":6,"text":"여호와께서 아사에게 평안을 주셨으므로 그 땅이 평안하여 여러해 싸움이 없은지라 저가 견고한 성읍들을 유다에 건축하니라","reference":"역대하 14:6","category":"$undefined"},{"id":"11483","book":"역대하","book_name":"역대하","chapter":14,"verse":7,"text":"아사가 일찌기 유다사람에게 이르되 우리가 우리 하나님 여호와를 찾았으므로 이 땅이 아직 우리 앞에 있나니 우리가 이 성읍들을 건축하고 그 주위에 성곽과 망대와 문과 빗장을 만들자 우리가 주를 찾았으므로 주께서 우리에게 사방의 평안을 주셨느니라 하고 이에 저희가 성읍을 형통하게 건축하였더라","reference":"역대하 14:7","category":"$undefined"},{"id":"11484","book":"역대하","book_name":"역대하","chapter":14,"verse":8,"text":"아사의 군대는 유다 중에서 큰 방패와 창을 잡는 자가 삼십만이요 베냐민 중에서 작은 방패를 잡으며 활을 당기는 자가 이십 팔만이라 다 큰 용사더라","reference":"역대하 14:8","category":"$undefined"},{"id":"11485","book":"역대하","book_name":"역대하","chapter":14,"verse":9,"text":"구스 사람 세라가 저희를 치려하여 군사 백만과 병거 삼백승을 거느리고 마레사에 이르매","reference":"역대하 14:9","category":"$undefined"},{"id":"11486","book":"역대하","book_name":"역대하","chapter":14,"verse":10,"text":"아사가 마주 나아가서 마레사의 스바다 골짜기에 진치고","reference":"역대하 14:10","category":"$undefined"},{"id":"11487","book":"역대하","book_name":"역대하","chapter":14,"verse":11,"text":"그 하나님 여호와께 부르짖어 가로되 여호와여 강한 자와 약한자 사이에는 주밖에 도와줄 이가 없사오니 우리 하나님 여호와여, 우리를 도우소서 우리가 주를 의지하오며 주의 이름을 의탁하옵고 이 많은 무리를 치러왔나이다 여호와여, 주는 우리 하나님이시오니 원컨대 사람으로 주를 이기지 못하게 하옵소서 하였더니","reference":"역대하 14:11","category":"$undefined"},{"id":"11488","book":"역대하","book_name":"역대하","chapter":14,"verse":12,"text":"여호와께서 구스 사람을 아사와 유다 사람 앞에서 쳐서 패하게 하시니 구스 사람이 도망하는지라","reference":"역대하 14:12","category":"$undefined"},{"id":"11489","book":"역대하","book_name":"역대하","chapter":14,"verse":13,"text":"아사와 그 좇는자가 구스 사람을 쫓아 그랄까지 이르매 이에 구스 사람이 엎드러지고 살아 남은 자가 없었으니 이는 여호와 앞에서와 그 군대 앞에서 패망하였음이라 노략한 물건이 심히 많았더라","reference":"역대하 14:13","category":"$undefined"},{"id":"11490","book":"역대하","book_name":"역대하","chapter":14,"verse":14,"text":"여호와께서 그랄 사면 모든 성읍 백성을 두렵게 하시니 무리가 그 모든 성읍을 치고 그 가운데 있는 많은 물건을 노략하고","reference":"역대하 14:14","category":"$undefined"},{"id":"11491","book":"역대하","book_name":"역대하","chapter":14,"verse":15,"text":"또 짐승 지키는 천막을 치고 양과 약대를 많이 이끌고 예루살렘으로 돌아왔더라","reference":"역대하 14:15","category":"$undefined"}],"bookSlug":"2chronicles"}]
