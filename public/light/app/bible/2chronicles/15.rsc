2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":15,"verses":[{"id":"11492","book":"역대하","book_name":"역대하","chapter":15,"verse":1,"text":"하나님의 신이 오뎃의 아들 아사랴에게 임하시매","reference":"역대하 15:1","category":"$undefined"},{"id":"11493","book":"역대하","book_name":"역대하","chapter":15,"verse":2,"text":"저가 나가서 아사를 맞아 이르되 아사와 및 유다와 베냐민의 무리들아 내말을 들으라 너희가 여호와와 함께하면 여호와께서 너희와 함께하실지라 너희가 만일 저를 찾으면 저가 너희의 만난바 되시려니와 너희가 만일 저를 버리면 저도 너희를 버리시리라","reference":"역대하 15:2","category":"$undefined"},{"id":"11494","book":"역대하","book_name":"역대하","chapter":15,"verse":3,"text":"이스라엘에는 참 신이 없고 가르치는 제사장도 없고 율법도 없은 지가 이제 오래였으나","reference":"역대하 15:3","category":"$undefined"},{"id":"11495","book":"역대하","book_name":"역대하","chapter":15,"verse":4,"text":"그 환난 때에 이스라엘 하나님 여호와께 돌아가서 찾으매 저가 그들의 만난 바가 되셨나니","reference":"역대하 15:4","category":"$undefined"},{"id":"11496","book":"역대하","book_name":"역대하","chapter":15,"verse":5,"text":"그 때에 열국에 거한 모든 백성이 크게 요란하여 사람의 출입이 평안치 못하며","reference":"역대하 15:5","category":"$undefined"},{"id":"11497","book":"역대하","book_name":"역대하","chapter":15,"verse":6,"text":"이 나라가 저나라와 서로 치고 이 성읍이 저 성읍과 또한 그러하여 피차 상한 바 되었나니 이는 하나님이 모든 고난으로 요란케 하셨음이니라","reference":"역대하 15:6","category":"$undefined"},{"id":"11498","book":"역대하","book_name":"역대하","chapter":15,"verse":7,"text":"그런즉 너희는 강하게 하라 손이 약하지 않게 하라 너희 행위에는 상급이 있음이니라","reference":"역대하 15:7","category":"$undefined"},{"id":"11499","book":"역대하","book_name":"역대하","chapter":15,"verse":8,"text":"아사가 이 말 곧 선지자 오뎃의 예언을 듣고 마음을 강하게 하여 가증한 물건을 유다와 베냐민 온 땅에서 제하고 또 에브라임 산 지에서 빼앗은 성읍들에서 제하고 또 여호와의 낭실 앞 여호와의단을 중수하고","reference":"역대하 15:8","category":"$undefined"},{"id":"11500","book":"역대하","book_name":"역대하","chapter":15,"verse":9,"text":"또 유다와 베냐민의 무리를 모으고 에브라임과 므낫세와 시므온 가운데서 나와서 저희중에 우거하는 자를 모았으니 이는 이스라엘 사람들이 아사의 하나님 여호와께서 그와 함께하심을 보고 아사에게로 돌아오는 자가 많았음이더라","reference":"역대하 15:9","category":"$undefined"},{"id":"11501","book":"역대하","book_name":"역대하","chapter":15,"verse":10,"text":"아사 왕 십 오년 삼월에 저희가 예루살렘에 모이고","reference":"역대하 15:10","category":"$undefined"},{"id":"11502","book":"역대하","book_name":"역대하","chapter":15,"verse":11,"text":"그 날에 노략하여 온 물건 중에서 소 칠백과 양 칠천으로 여호와께 제사를 드리고","reference":"역대하 15:11","category":"$undefined"},{"id":"11503","book":"역대하","book_name":"역대하","chapter":15,"verse":12,"text":"또 마음을 다하고 성품을 다하여 열조의 하나님 여호와를 찾기로 언약하고","reference":"역대하 15:12","category":"$undefined"},{"id":"11504","book":"역대하","book_name":"역대하","chapter":15,"verse":13,"text":"무릇 이스라엘 하나님 여호와를 찾지 아니하는 자는 대소 남녀를 무론하고 죽이는 것이 마땅하다 하고","reference":"역대하 15:13","category":"$undefined"},{"id":"11505","book":"역대하","book_name":"역대하","chapter":15,"verse":14,"text":"무리가 큰 소리로 부르며 피리와 나팔을 불어 여호와께 맹세하매","reference":"역대하 15:14","category":"$undefined"},{"id":"11506","book":"역대하","book_name":"역대하","chapter":15,"verse":15,"text":"온 유다가 이 맹세를 기뻐한지라 무리가 마음을 다하여 맹세하고 뜻을 다하여 여호와를 찾았으므로 여호와께서도 저희의 만난 바가 되시고 그 사방에 평안을 주셨더라","reference":"역대하 15:15","category":"$undefined"},{"id":"11507","book":"역대하","book_name":"역대하","chapter":15,"verse":16,"text":"아사 왕의 모친 마아가가 아세라의 가증한 목상을 만들었으므로 아사가 그 태후의 위를 폐하고 그 우상을 찍고 빻아 기드론 시냇가에서 불살랐으니","reference":"역대하 15:16","category":"$undefined"},{"id":"11508","book":"역대하","book_name":"역대하","chapter":15,"verse":17,"text":"산당은 이스라엘 중에서 제하지 아니하였으나 아사의 마음이 일평생 온전하였더라","reference":"역대하 15:17","category":"$undefined"},{"id":"11509","book":"역대하","book_name":"역대하","chapter":15,"verse":18,"text":"저가 또 그 부친의 구별한 물건과 자기의 구별한 물건 곧 은과 금과 기명들을 하나님의 전에 드렸더니","reference":"역대하 15:18","category":"$undefined"},{"id":"11510","book":"역대하","book_name":"역대하","chapter":15,"verse":19,"text":"이 때부터 아사 왕 삼십 오년까지 다시는 전쟁이 없으니라","reference":"역대하 15:19","category":"$undefined"}],"bookSlug":"2chronicles"}]
