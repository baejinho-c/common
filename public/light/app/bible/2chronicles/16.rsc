2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":16,"verses":[{"id":"11511","book":"역대하","book_name":"역대하","chapter":16,"verse":1,"text":"아사 왕 삼십 륙년에 이스라엘왕 바아사가 유다를 치러 올라와서 라마를 건축하여 사람을 유다 왕 아사에게 왕래하지 못하게 하려한지라","reference":"역대하 16:1","category":"$undefined"},{"id":"11512","book":"역대하","book_name":"역대하","chapter":16,"verse":2,"text":"아사가 여호와의 전 곳간과 왕궁 곳간의 은,금을 취하여 다메섹에 거한 아람 왕 벤하닷에게 보내며 가로되","reference":"역대하 16:2","category":"$undefined"},{"id":"11513","book":"역대하","book_name":"역대하","chapter":16,"verse":3,"text":"내 부친과 당신의 부친 사이에와 같이 나와 당신 사이에 약조하자 내가 당신에게 은금을 보내노니 와서 이스라엘 왕 바아사와 세운 약조를 깨뜨려서 저로 나를 떠나게 하라 하매","reference":"역대하 16:3","category":"$undefined"},{"id":"11514","book":"역대하","book_name":"역대하","chapter":16,"verse":4,"text":"벤하닷이 아사 왕의 말을 듣고 그 군대 장관들을 보내어 이스라엘 두어 성읍을 치되 이욘과 단과 아벨마임과 납달리의 모든 국고 성을 쳤더니","reference":"역대하 16:4","category":"$undefined"},{"id":"11515","book":"역대하","book_name":"역대하","chapter":16,"verse":5,"text":"바아사가 듣고 라마 건축하는 일을 파하여 그 공역을 그친지라","reference":"역대하 16:5","category":"$undefined"},{"id":"11516","book":"역대하","book_name":"역대하","chapter":16,"verse":6,"text":"아사 왕이 온 유다 무리를 거느리고 바아사가 라마를 건축하던 돌과 재목을 수운하여다가 게바와 미스바를 건축하였더라","reference":"역대하 16:6","category":"$undefined"},{"id":"11517","book":"역대하","book_name":"역대하","chapter":16,"verse":7,"text":"때에 선견자 하나니가 유다 왕 아사에게 나아와서 이르되 `왕이 아람 왕을 의지하고 왕의 하나님 여호와를 의지하지 아니한고로 아람 왕의 군대가 왕의 손에서 벗어났나이다","reference":"역대하 16:7","category":"$undefined"},{"id":"11518","book":"역대하","book_name":"역대하","chapter":16,"verse":8,"text":"구스 사람과 룹 사람의 군대가 크지 아니하며 말과 병거가 심히 많지 아니하더이까 그러나 왕이 여호와를 의지한고로 여호와께서 왕의 손에 붙이셨나이다","reference":"역대하 16:8","category":"$undefined"},{"id":"11519","book":"역대하","book_name":"역대하","chapter":16,"verse":9,"text":"여호와의 눈은 온 땅을 두루 감찰하사 전심으로 자기에게 향하는 자를 위하여 능력을 베푸시나니 이 일은 왕이 망령되이 행하였은즉 이후부터는 왕에게 전쟁이 있으리이다' 하매","reference":"역대하 16:9","category":"$undefined"},{"id":"11520","book":"역대하","book_name":"역대하","chapter":16,"verse":10,"text":"아사가 노하여 선견자를 옥에 가두었으니 이는 그 말에 크게 노하였음이며 그 때에 아사가 또 몇 백성을 학대하였더라","reference":"역대하 16:10","category":"$undefined"},{"id":"11521","book":"역대하","book_name":"역대하","chapter":16,"verse":11,"text":"아사의 시종 행적은 유다와 이스라엘 열왕기에 기록되니라","reference":"역대하 16:11","category":"$undefined"},{"id":"11522","book":"역대하","book_name":"역대하","chapter":16,"verse":12,"text":"아사가 왕이 된지 삼십 구년에 그 발이 병들어 심히 중하나 병이 있을 때에 저가 여호와께 구하지 아니하고 의원들에게 구하였더라","reference":"역대하 16:12","category":"$undefined"},{"id":"11523","book":"역대하","book_name":"역대하","chapter":16,"verse":13,"text":"아사가 위에 있은지 사십 일년에 죽어 그 열조와 함께 자매","reference":"역대하 16:13","category":"$undefined"},{"id":"11524","book":"역대하","book_name":"역대하","chapter":16,"verse":14,"text":"다윗 성에 자기를 위하여 파 두었던 묘실에 무리가 장사하되 그 시체를 법대로 만든 각양 향재료를 가득히 채운 상에 두고 또 위하여 많이 분향하였더라","reference":"역대하 16:14","category":"$undefined"}],"bookSlug":"2chronicles"}]
