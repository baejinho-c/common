2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":17,"verses":[{"id":"11525","book":"역대하","book_name":"역대하","chapter":17,"verse":1,"text":"아사의 아들 여호사밧이 대신하여 왕이 되어 스스로 강하게 하여 이스라엘을 방비하되","reference":"역대하 17:1","category":"$undefined"},{"id":"11526","book":"역대하","book_name":"역대하","chapter":17,"verse":2,"text":"유다 모든 견고한 성읍에 군대를 주둔하고 또 유다 땅과 그 아비아사의 취한바 에브라임 성읍들에 영문을 두었더라","reference":"역대하 17:2","category":"$undefined"},{"id":"11527","book":"역대하","book_name":"역대하","chapter":17,"verse":3,"text":"여호와께서 여호사밧과 함께 하셨으니 이는 저가 그 조상 다윗의 처음 길로 행하여 바알들에게 구하지 아니하고","reference":"역대하 17:3","category":"$undefined"},{"id":"11528","book":"역대하","book_name":"역대하","chapter":17,"verse":4,"text":"오직 그 부친의 하나님께 구하며 그 계명을 행하고 이스라엘의 행위를 좇지 아니하였음이라","reference":"역대하 17:4","category":"$undefined"},{"id":"11529","book":"역대하","book_name":"역대하","chapter":17,"verse":5,"text":"그러므로 여호와께서 나라를 그 손에서 견고하게 하시매 유다 무리가 여호사밧에게 예물을 드렸으므로 저가 부귀와 영광이 극하였더라","reference":"역대하 17:5","category":"$undefined"},{"id":"11530","book":"역대하","book_name":"역대하","chapter":17,"verse":6,"text":"저가 전심으로 여호와의 도를 행하여 산당과 아세라 목상들도 유다에서 제하였더라","reference":"역대하 17:6","category":"$undefined"},{"id":"11531","book":"역대하","book_name":"역대하","chapter":17,"verse":7,"text":"저가 위에 있은지 삼년에 그 방백 벤하일과, 오바댜와, 스가랴와, 느다넬과, 미가야를 보내어 유다 여러 성읍에 가서 가르치게 하고","reference":"역대하 17:7","category":"$undefined"},{"id":"11532","book":"역대하","book_name":"역대하","chapter":17,"verse":8,"text":"또 저희와 함께 레위 사람 스마야와, 느다냐와, 스바댜와, 아사헬과, 스미라못과, 여호나단과, 아도니야와, 도비야와, 도바도니야 등 레위 사람을 보내고 또 저희와 함께 제사장 엘리사마와 여호람을 보내었더니","reference":"역대하 17:8","category":"$undefined"},{"id":"11533","book":"역대하","book_name":"역대하","chapter":17,"verse":9,"text":"저희가 여호와의 율법책을 가지고 유다에서 가르치되 그 모든 성읍으로 순행하며 인민을 가르쳤더라","reference":"역대하 17:9","category":"$undefined"},{"id":"11534","book":"역대하","book_name":"역대하","chapter":17,"verse":10,"text":"여호와께서 유다 사면 열국에 두려움을 주사 여호사밧과 싸우지 못하게 하시매","reference":"역대하 17:10","category":"$undefined"},{"id":"11535","book":"역대하","book_name":"역대하","chapter":17,"verse":11,"text":"블레셋 중에서는 여호사밧에게 예물을 드리며 은으로 공을 바쳤고 아라비아 사람도 짐승떼 곧 수양 칠천 칠백과 수염소 칠천 칠백을 드렸더라","reference":"역대하 17:11","category":"$undefined"},{"id":"11536","book":"역대하","book_name":"역대하","chapter":17,"verse":12,"text":"여호사밧이 점점 강대하여 유다에 견고한 채와 국고성을 건축하고","reference":"역대하 17:12","category":"$undefined"},{"id":"11537","book":"역대하","book_name":"역대하","chapter":17,"verse":13,"text":"유다 각 성에 역사를 많이 하고 또 예루살렘에 크게 용맹한 군사를 두었으니","reference":"역대하 17:13","category":"$undefined"},{"id":"11538","book":"역대하","book_name":"역대하","chapter":17,"verse":14,"text":"군사의 수효가 그 족속대로 이러하니라 유다에 속한 천부장 중에는 아드나가 으뜸이 되어 큰 용사 삼십만을 거느렸고","reference":"역대하 17:14","category":"$undefined"},{"id":"11539","book":"역대하","book_name":"역대하","chapter":17,"verse":15,"text":"그 다음은 장관 여호하난이니 이십 팔만을 거느렸고","reference":"역대하 17:15","category":"$undefined"},{"id":"11540","book":"역대하","book_name":"역대하","chapter":17,"verse":16,"text":"그 다음은 시그리의 아들 아마시야니 저는 자기를 여호와께 즐거이 드린 자라 큰 용사 이십만을 거느렸고","reference":"역대하 17:16","category":"$undefined"},{"id":"11541","book":"역대하","book_name":"역대하","chapter":17,"verse":17,"text":"베냐민에 속한 자 중에 큰 용사 엘리아다는 활과 방패를 잡은 자 이십만을 거느렸고","reference":"역대하 17:17","category":"$undefined"},{"id":"11542","book":"역대하","book_name":"역대하","chapter":17,"verse":18,"text":"그 다음은 여호사밧이라 싸움을 예비한 자 십 팔만을 거느렸으니","reference":"역대하 17:18","category":"$undefined"},{"id":"11543","book":"역대하","book_name":"역대하","chapter":17,"verse":19,"text":"이는 다 왕을 섬기는 자요 이 외에 또 온 유다 견고한 성에 왕이 군사를 두었더라","reference":"역대하 17:19","category":"$undefined"}],"bookSlug":"2chronicles"}]
