2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":18,"verses":[{"id":"11544","book":"역대하","book_name":"역대하","chapter":18,"verse":1,"text":"여호사밧이 부귀와 영광이 극하였고 아합으로 더불어 연혼하였더라","reference":"역대하 18:1","category":"$undefined"},{"id":"11545","book":"역대하","book_name":"역대하","chapter":18,"verse":2,"text":"두어해 후에 저가 사마리아에 내려가서 아합에게 나아갔더니 아합이 저와 종자를 위하여 우양을 많이 잡고 함께 가서 길르앗 라못 치기를 권하더라","reference":"역대하 18:2","category":"$undefined"},{"id":"11546","book":"역대하","book_name":"역대하","chapter":18,"verse":3,"text":"이스라엘 왕 아합이 유다 왕 여호사밧에게 이르되 `당신은 나와 함께 길르앗 라못으로 가시겠느뇨 ?' 대답하되 '나는 당신과 일반이요 내 백성은 당신의 백성과 일반이니 당신과 함께 싸우리이다'","reference":"역대하 18:3","category":"$undefined"},{"id":"11547","book":"역대하","book_name":"역대하","chapter":18,"verse":4,"text":"여호사밧이 또 이스라엘 왕에게 이르되 `청컨대 먼저 여호와의 말씀이 어떠하신지 물어 보소서'","reference":"역대하 18:4","category":"$undefined"},{"id":"11548","book":"역대하","book_name":"역대하","chapter":18,"verse":5,"text":"이스라엘 왕이 이에 선지자 사백인을 모으고 저희에게 이르되 `우리가 길르앗 라못에 가서 싸우랴 말랴' 저희가 가로되 '올라 가소서 하나님이 그 성을 왕의 손에 붙이시리이다'","reference":"역대하 18:5","category":"$undefined"},{"id":"11549","book":"역대하","book_name":"역대하","chapter":18,"verse":6,"text":"여호사밧이 가로되 `이 외에 우리가 물을 만한 여호와의 선지자가 여기 있지 아니하니이까 ?'","reference":"역대하 18:6","category":"$undefined"},{"id":"11550","book":"역대하","book_name":"역대하","chapter":18,"verse":7,"text":"이스라엘 왕이 여호사밧에게 이르되 `오히려 이믈라의 아들 미가야 한 사람이 있으니 저로 말미암아 여호와께 물을 수 있으나 저는 내게 대하여 길한 일은 예언하지 아니하고 항상 흉한 일만 예언하기로 내가 저를 미워하나이다' 여호사밧이 가로되 '왕은 그런 말씀을 마소서'","reference":"역대하 18:7","category":"$undefined"},{"id":"11551","book":"역대하","book_name":"역대하","chapter":18,"verse":8,"text":"이스라엘 왕이 한 내시를 불러 이르되 `이믈라의 아들 미가야로 속히 오게 하라' 하니라","reference":"역대하 18:8","category":"$undefined"},{"id":"11552","book":"역대하","book_name":"역대하","chapter":18,"verse":9,"text":"이스라엘 왕과 유다 왕 여호사밧이 왕복을 입고 사마리아 성문 어귀 광장에서 각기 보좌에 앉았고 모든 선지자가 그 앞에서 예언을 하는데","reference":"역대하 18:9","category":"$undefined"},{"id":"11553","book":"역대하","book_name":"역대하","chapter":18,"verse":10,"text":"그나아나의 아들 시드기야는 철로 뿔들을 만들어 가지고 말하되 `여호와의 말씀이 왕이 이것들로 아람 사람을 찔러 진멸하리라 하셨다' 하고","reference":"역대하 18:10","category":"$undefined"},{"id":"11554","book":"역대하","book_name":"역대하","chapter":18,"verse":11,"text":"모든 선지자도 그와 같이 예언하여 이르기를 `길르앗 라못으로 올라가서 승리를 얻으소서 여호와께서 그 성을 왕의 손에 붙이시리이다' 하더라","reference":"역대하 18:11","category":"$undefined"},{"id":"11555","book":"역대하","book_name":"역대하","chapter":18,"verse":12,"text":"미가야를 부르러 간 사자가 일러 가로되 `선지자들의 말이 여출일구하여 왕에게 길하게 하니 청컨대 당신의 말도 저희 중 한 사람처럼 길하게 하소서'","reference":"역대하 18:12","category":"$undefined"},{"id":"11556","book":"역대하","book_name":"역대하","chapter":18,"verse":13,"text":"미가야가 가로되 `여호와의 사심을 가리켜 맹세하노니 내 하나님의 말씀하시는 것 곧 그것을 내가 말하리라' 하고","reference":"역대하 18:13","category":"$undefined"},{"id":"11557","book":"역대하","book_name":"역대하","chapter":18,"verse":14,"text":"이에 왕에게 이르니 왕이 저에게 이르되 `미가야야 우리가 길르앗 라못으로 싸우러 가랴' 가로되 '올라가서 승리를 얻으소서 저희가 왕의 손에 붙인 바 되리이다'","reference":"역대하 18:14","category":"$undefined"},{"id":"11558","book":"역대하","book_name":"역대하","chapter":18,"verse":15,"text":"왕이 저에게 이르되 `여호와의 이름으로 진실한 것만 말하라고 내가 몇번이나 너로 맹세케 하여야 하겠느냐 ?'","reference":"역대하 18:15","category":"$undefined"},{"id":"11559","book":"역대하","book_name":"역대하","chapter":18,"verse":16,"text":"저가 가로되 `내가 보니 온 이스라엘이 목자 없는 양 같이 산에 흩어졌는데 여호와의 말씀이 이 무리가 주인이 없으니 각각 평안히 그 집으로 돌아갈 것이니라 하셨나이다'","reference":"역대하 18:16","category":"$undefined"},{"id":"11560","book":"역대하","book_name":"역대하","chapter":18,"verse":17,"text":"이스라엘 왕이 여호사밧에게 이르되 `저 사람이 내게 대하여 길한 것을 예언하지 아니하고 흉한 것만 예언하겠다고 당신에게 말씀하지 아니하였나이까 ?'","reference":"역대하 18:17","category":"$undefined"},{"id":"11561","book":"역대하","book_name":"역대하","chapter":18,"verse":18,"text":"미가야가 가로되 `그런즉 왕은 여호와의 말씀을 들으소서 내가 보니 여호와께서 그 보좌에 앉으셨고 하늘의 만군이 그 좌우편에 모시고 섰는데","reference":"역대하 18:18","category":"$undefined"},{"id":"11562","book":"역대하","book_name":"역대하","chapter":18,"verse":19,"text":"여호와께서 말씀하시기를 누가 이스라엘 왕 아합을 꾀어 저로 길르앗 라못에 올라가서 죽게 할꼬 하시니 하나는 이렇게 하겠다 하고 하나는 저렇게 하겠다 하였는데","reference":"역대하 18:19","category":"$undefined"},{"id":"11563","book":"역대하","book_name":"역대하","chapter":18,"verse":20,"text":"한 영(靈)이 나아와 여호와 앞에 서서 말하되 내가 저를 꾀이겠나이다 여호와께서 저에게 이르시되 어떻게 하겠느냐 ?","reference":"역대하 18:20","category":"$undefined"},{"id":"11564","book":"역대하","book_name":"역대하","chapter":18,"verse":21,"text":"가로되 내가 나가서 거짓말하는 영이 되어 그 모든 선지자의 입에 있겠나이다 여호와께서 가라사대 너는 꾀이겠고 또 이루리라 나가서 그리하라 하셨은즉","reference":"역대하 18:21","category":"$undefined"},{"id":"11565","book":"역대하","book_name":"역대하","chapter":18,"verse":22,"text":"이제 여호와께서 거짓말하는 영을 왕의 이 모든 선지자의 입에 넣으셨고 또 여호와께서 왕에게 대하여 화를 말씀하셨나이다'","reference":"역대하 18:22","category":"$undefined"},{"id":"11566","book":"역대하","book_name":"역대하","chapter":18,"verse":23,"text":"그나아나의 아들 시드기야가 가까이 와서 미가야의 뺨을 치며 이르되 `여호와의 영이 나를 떠나 어디로 말미암아 가서 네게 말씀 하더냐 ?'","reference":"역대하 18:23","category":"$undefined"},{"id":"11567","book":"역대하","book_name":"역대하","chapter":18,"verse":24,"text":"미가야가 가로되 `네가 골방에 들어가서 숨는 그 날에 보리라'","reference":"역대하 18:24","category":"$undefined"},{"id":"11568","book":"역대하","book_name":"역대하","chapter":18,"verse":25,"text":"이스라엘 왕이 가로되 `미가야를 잡아 부윤 아몬과 왕자 요아스에게로 끌고 돌아가서","reference":"역대하 18:25","category":"$undefined"},{"id":"11569","book":"역대하","book_name":"역대하","chapter":18,"verse":26,"text":"말하기를 왕의 말씀이 이 놈을 옥에 가두고 내가 평안히 돌아올때까지 고생의 떡과 고생의 물로 먹이라' 하라","reference":"역대하 18:26","category":"$undefined"},{"id":"11570","book":"역대하","book_name":"역대하","chapter":18,"verse":27,"text":"미가야가 가로되 `왕이 참으로 평안히 돌아오시게 될진대 여호와께서 나로 말씀하지 아니하셨으리이다' 또 가로되 '너희 백성들아 다 들을지어다 !' 하니라","reference":"역대하 18:27","category":"$undefined"},{"id":"11571","book":"역대하","book_name":"역대하","chapter":18,"verse":28,"text":"이스라엘 왕과 유다 왕 여호사밧이 길르앗 라못으로 올라가니라","reference":"역대하 18:28","category":"$undefined"},{"id":"11572","book":"역대하","book_name":"역대하","chapter":18,"verse":29,"text":"이스라엘 왕이 여호사밧에게 이르되 `나는 변장하고 군중으로 들어가려 하노니 당신은 왕복을 입으소서' 하고 이스라엘 왕이 변장하고 둘이 군중으로 들어가니라","reference":"역대하 18:29","category":"$undefined"},{"id":"11573","book":"역대하","book_name":"역대하","chapter":18,"verse":30,"text":"아람 왕이 그 병거 장관들에게 이미 명하여 이르기를 `너희는 작은 자나 큰 자나 더불어 싸우지 말고 오직 이스라엘 왕과 싸우라' 한지라","reference":"역대하 18:30","category":"$undefined"},{"id":"11574","book":"역대하","book_name":"역대하","chapter":18,"verse":31,"text":"병거의 장관들이 여호사밧을 보고 이르되 `이가 이스라엘 왕이라' 하고 돌이켜 저와 싸우려 한즉 여호사밧이 소리를 지르매 여호와께서 저를 도우시며 하나님이 저희를 감동시키사 저를 떠나가게 하신지라","reference":"역대하 18:31","category":"$undefined"},{"id":"11575","book":"역대하","book_name":"역대하","chapter":18,"verse":32,"text":"병거의 장관들이 저가 이스라엘 왕이 아님을 보고 쫓기를 그치고 돌이켰더라","reference":"역대하 18:32","category":"$undefined"},{"id":"11576","book":"역대하","book_name":"역대하","chapter":18,"verse":33,"text":"한 사람이 우연히 활을 당기어 이스라엘 왕의 갑옷 솔기를 쏜지라 왕이 그 병거 모는 자에게 이르되 '내가 부상하였으니 네 손을 돌이켜 나로 군중에서 나가게 하라' 하였으나","reference":"역대하 18:33","category":"$undefined"},{"id":"11577","book":"역대하","book_name":"역대하","chapter":18,"verse":34,"text":"이 날의 전쟁이 맹렬하였으므로 이스라엘 왕이 병거에서 스스로 부지하며 저녁때까지 아람 사람을 막다가 해가 질 즈음에 죽었더라","reference":"역대하 18:34","category":"$undefined"}],"bookSlug":"2chronicles"}]
