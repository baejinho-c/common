2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":20,"verses":[{"id":"11589","book":"역대하","book_name":"역대하","chapter":20,"verse":1,"text":"그 후에 모압 자손과 암몬 자손이 몇 마온 사람과 함께와서 여호사밧을 치고자 한지라","reference":"역대하 20:1","category":"$undefined"},{"id":"11590","book":"역대하","book_name":"역대하","chapter":20,"verse":2,"text":"혹이 와서 여호사밧에게 고하여 가로되 `큰 무리가 바다 저편 아람에서 왕을 치러 오는데 이제 하사손다말 곧 엔게디에 있나이다'","reference":"역대하 20:2","category":"$undefined"},{"id":"11591","book":"역대하","book_name":"역대하","chapter":20,"verse":3,"text":"여호사밧이 두려워하여 여호와께로 낯을 향하여 간구하고 온 유다 백성에게 금식하라 공포하매","reference":"역대하 20:3","category":"$undefined"},{"id":"11592","book":"역대하","book_name":"역대하","chapter":20,"verse":4,"text":"유다 사람이 여호와께 도우심을 구하려 하여 유다 모든 성읍에서 모여와서 여호와께 간구하더라","reference":"역대하 20:4","category":"$undefined"},{"id":"11593","book":"역대하","book_name":"역대하","chapter":20,"verse":5,"text":"여호사밧이 여호와의 전 새 뜰 앞에서 유다와 예루살렘의 회중 가운데 서서","reference":"역대하 20:5","category":"$undefined"},{"id":"11594","book":"역대하","book_name":"역대하","chapter":20,"verse":6,"text":"가로되 '우리 열조의 하나님 여호와여, 주는 하늘에서 하나님이 아니시니이까 ? 이방 사람의 모든 나라를 다스리지 아니하시나이까 ? 주의 손에 권세와 능력이 있사오니 능히 막을 사람이 없나이다","reference":"역대하 20:6","category":"$undefined"},{"id":"11595","book":"역대하","book_name":"역대하","chapter":20,"verse":7,"text":"우리 하나님이시여 ! 전에 이 땅 거민을 주의 백성 이스라엘 앞에서 쫓아내시고 그 땅으로 주의 벗 아브라함의 자손에게 영영히 주지 아니하셨나이까 ?","reference":"역대하 20:7","category":"$undefined"},{"id":"11596","book":"역대하","book_name":"역대하","chapter":20,"verse":8,"text":"저희가 이 땅에 거하여 주의 이름을 위하여 한 성소를 건축하고 이르기를","reference":"역대하 20:8","category":"$undefined"},{"id":"11597","book":"역대하","book_name":"역대하","chapter":20,"verse":9,"text":"만일 재앙이나, 난리나, 견책이나, 온역이나, 기근이 우리에게 임하면 주의 이름이 이 전에 있으니 우리가 이 전 앞과 주의 앞에 서서 이 환난 가운데서 주께 부르짖은즉 들으시고 구원하시리라 하였나이다","reference":"역대하 20:9","category":"$undefined"},{"id":"11598","book":"역대하","book_name":"역대하","chapter":20,"verse":10,"text":"옛적에 이스라엘이 애굽 땅에서 나올 때에 암몬 자손과 모압 자손과 세일산 사람을 침노하기를 주께서 용납하지 아니하시므로 이에 치우쳐 저희를 떠나고 멸하지 아니하였거늘","reference":"역대하 20:10","category":"$undefined"},{"id":"11599","book":"역대하","book_name":"역대하","chapter":20,"verse":11,"text":"이제 저희가 우리에게 갚는 것을 보옵소서 저희가 와서 주께서 우리에게 주신 주의 기업에서 우리를 쫓아 내고자 하나이다","reference":"역대하 20:11","category":"$undefined"},{"id":"11600","book":"역대하","book_name":"역대하","chapter":20,"verse":12,"text":"우리 하나님이여, 저희를 징벌하지 아니하시나이까 ? 우리를 치러 오는 이 큰 무리를 우리가 대적할 능력이 없고 어떻게 할 줄도 알지 못하옵고 오직 주만 바라보나이다' 하고","reference":"역대하 20:12","category":"$undefined"},{"id":"11601","book":"역대하","book_name":"역대하","chapter":20,"verse":13,"text":"유다 모든 사람은 그 아내와 자녀와 어린 자로 더불어 여호와 앞에 섰더라","reference":"역대하 20:13","category":"$undefined"},{"id":"11602","book":"역대하","book_name":"역대하","chapter":20,"verse":14,"text":"여호와의 신이 회중 가운데서 레위 사람 야하시엘에게 임하셨으니 저는 아삽 자손 맛다냐의 현손이요, 여이엘의 증손이요, 브나야의 손자요, 스가랴의 아들이더라","reference":"역대하 20:14","category":"$undefined"},{"id":"11603","book":"역대하","book_name":"역대하","chapter":20,"verse":15,"text":"야하시엘이 가로되 `온 유다와 예루살렘 거민과 여호사밧 왕이여 들을지어다 ! 여호와께서 너희에게 말씀하시기를 이 큰 무리로 인하여 두려워하거나 놀라지 말라 이 전쟁이 너희에게 속한 것이 아니요 하나님께 속한 것이니라","reference":"역대하 20:15","category":"$undefined"},{"id":"11604","book":"역대하","book_name":"역대하","chapter":20,"verse":16,"text":"내일 너희는 마주 내려 가라 저희가 시스 고개로 말미암아 올라오리니 너희가 골짜기 어귀 여루엘 들 앞에서 만나려니와","reference":"역대하 20:16","category":"$undefined"},{"id":"11605","book":"역대하","book_name":"역대하","chapter":20,"verse":17,"text":"이 전쟁에는 너희가 싸울 것이 없나니 항오를 이루고 서서 너희와 함께한 여호와가 구원하는 것을 보라 ! 유다와 예루살렘아 ! 너희는 두려워하며 놀라지 말고 내일 저희를 마주 나가라 여호와가 너희와 함께 하리라 하셨느니라' 하매","reference":"역대하 20:17","category":"$undefined"},{"id":"11606","book":"역대하","book_name":"역대하","chapter":20,"verse":18,"text":"여호사밧이 몸을 굽혀 얼굴을 땅에 대니 온 유다와 예루살렘 거민들도 여호와 앞에 엎드려 경배하고","reference":"역대하 20:18","category":"$undefined"},{"id":"11607","book":"역대하","book_name":"역대하","chapter":20,"verse":19,"text":"그핫 자손과 고라 자손에게 속한 레위 사람들은 서서 심히 큰 소리로 이스라엘 하나님 여호와를 찬송하니라","reference":"역대하 20:19","category":"$undefined"},{"id":"11608","book":"역대하","book_name":"역대하","chapter":20,"verse":20,"text":"이에 백성들이 일찌기 일어나서 드고아 들로 나가니라 나갈 때에 여호사밧이 서서 가로되 '유다와 예루살렘 거민들아 내 말을 들을지어다 ! 너희는 너희 하나님 여호와를 신뢰하라 ! 그리하면 견고히 서리라 그 선지자를 신뢰하라 ! 그리하면 형통하리라' 하고","reference":"역대하 20:20","category":"$undefined"},{"id":"11609","book":"역대하","book_name":"역대하","chapter":20,"verse":21,"text":"백성으로 더불어 의논하고 노래하는 자를 택하여 거룩한 예복을 입히고 군대 앞에서 행하며 여호와를 찬송하여 이르기를 `여호와께 감사하세 ! 그 자비하심이 영원하도다' 하게 하였더니","reference":"역대하 20:21","category":"$undefined"},{"id":"11610","book":"역대하","book_name":"역대하","chapter":20,"verse":22,"text":"그 노래와 찬송이 시작될 때에 여호와께서 복병을 두어 유다를 치러 온 암몬 자손과 모압과 세일산 사람을 치게 하시므로 저희가 패하였으니","reference":"역대하 20:22","category":"$undefined"},{"id":"11611","book":"역대하","book_name":"역대하","chapter":20,"verse":23,"text":"곧 암몬과 모압 자손이 일어나 세일산 거민을 쳐서 진멸하고 세일 거민을 멸한 후에는 저희가 피차에 살륙하였더라","reference":"역대하 20:23","category":"$undefined"},{"id":"11612","book":"역대하","book_name":"역대하","chapter":20,"verse":24,"text":"유다 사람이 들 망대에 이르러 그 무리를 본즉 땅에 엎드러진 시체뿐이요 하나도 피한 자가 없는지라","reference":"역대하 20:24","category":"$undefined"},{"id":"11613","book":"역대하","book_name":"역대하","chapter":20,"verse":25,"text":"여호사밧과 그 백성이 가서 적군의 물건을 취할새 본즉 그 가운 데에 재물과 의복과 보물이 많이 있는 고로 각기 취하는데 그 물건이 너무 많아 능히 가져갈 수 없을만큼 많으므로 사흘 동안에 취하고","reference":"역대하 20:25","category":"$undefined"},{"id":"11614","book":"역대하","book_name":"역대하","chapter":20,"verse":26,"text":"제 사일에 무리가 브라가 골짜기에 모여서 거기서 여호와를 송축한지라 그러므로 오늘날까지 그 곳을 브라가 골짜기라 일컫더라","reference":"역대하 20:26","category":"$undefined"},{"id":"11615","book":"역대하","book_name":"역대하","chapter":20,"verse":27,"text":"유다와 예루살렘 모든 사람이 여호사밧을 선두로 즐거이 예루살렘으로 돌아왔으니 이는 여호와께서 저희로 그 적군을 이김을 인하여 즐거워하게 하셨음이라","reference":"역대하 20:27","category":"$undefined"},{"id":"11616","book":"역대하","book_name":"역대하","chapter":20,"verse":28,"text":"무리가 비파와 수금과 나팔을 합주하고 예루살렘에 이르러 여호와의 전에 나아가니라","reference":"역대하 20:28","category":"$undefined"},{"id":"11617","book":"역대하","book_name":"역대하","chapter":20,"verse":29,"text":"이방 모든 나라가 여호와께서 이스라엘의 적군을 치셨다 함을 듣고 하나님을 두려워한고로","reference":"역대하 20:29","category":"$undefined"},{"id":"11618","book":"역대하","book_name":"역대하","chapter":20,"verse":30,"text":"여호사밧의 나라가 태평하였으니 이는 그 하나님이 사방에서 저희에게 평강을 주셨음이더라","reference":"역대하 20:30","category":"$undefined"},{"id":"11619","book":"역대하","book_name":"역대하","chapter":20,"verse":31,"text":"여호사밧이 유다 왕이 되어 위에 나아갈 때에 나이 삼십 오세라 예루살렘에서 이십 오년을 치리하니라 그 모친의 이름은 아수바라 실히의 딸이더라","reference":"역대하 20:31","category":"$undefined"},{"id":"11620","book":"역대하","book_name":"역대하","chapter":20,"verse":32,"text":"여호사밧이 그 부친 아사의 길로 행하여 돌이켜 떠나지 아니하고 여호와 보시기에 정직히 행하였으나","reference":"역대하 20:32","category":"$undefined"},{"id":"11621","book":"역대하","book_name":"역대하","chapter":20,"verse":33,"text":"산당은 폐하지 아니하였으므로 백성이 오히려 마음을 정하여 그 열조의 하나님께로 돌아오지 아니하였더라","reference":"역대하 20:33","category":"$undefined"},{"id":"11622","book":"역대하","book_name":"역대하","chapter":20,"verse":34,"text":"이 외에 여호사밧의 시종 행적이 하나니의 아들 예후의 글에 다 기록되었고 그 글은 이스라엘 열왕기에 올랐더라","reference":"역대하 20:34","category":"$undefined"},{"id":"11623","book":"역대하","book_name":"역대하","chapter":20,"verse":35,"text":"유다왕 여호사밧이 나중에 이스라엘 왕 아하시야와 교제하였는데 아하시야는 심히 악을 행하는 자이었더라","reference":"역대하 20:35","category":"$undefined"},{"id":"11624","book":"역대하","book_name":"역대하","chapter":20,"verse":36,"text":"두 왕이 서로 결합하고 배를 지어 다시스로 보내고자 하여 에시온게벨에서 배를 지었더니","reference":"역대하 20:36","category":"$undefined"},{"id":"11625","book":"역대하","book_name":"역대하","chapter":20,"verse":37,"text":"마레사 사람 도다와후의 아들 엘리에셀이 여호사밧을 향하여 예언하여 가로되 '왕이 아하시야와 교제하는고로 여호와께서 왕의 지은 것을 파하시리라' 하더니 이에 그 배가 파상하여 다시스로 가지 못하였더라","reference":"역대하 20:37","category":"$undefined"}],"bookSlug":"2chronicles"}]
