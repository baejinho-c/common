2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":3,"verses":[{"id":"11231","book":"역대하","book_name":"역대하","chapter":3,"verse":1,"text":"솔로몬이 예루살렘 모리아 산에 여호와의 전 건축하기를 시작하니 그곳은 전에 여호와께서 그 아비 다윗에게 나타나신 곳이요 여부스 사람 오르난의 타작마당에 다윗이 정한 곳이라","reference":"역대하 3:1","category":"$undefined"},{"id":"11232","book":"역대하","book_name":"역대하","chapter":3,"verse":2,"text":"솔로몬이 왕위에 나아간지 사년 이월 초이일에 건축하기를 시작하였더라","reference":"역대하 3:2","category":"$undefined"},{"id":"11233","book":"역대하","book_name":"역대하","chapter":3,"verse":3,"text":"솔로몬이 하나님의 전을 위하여 놓은 지대는 이러하니 옛적 재는 법대로 장이 육십 규빗이요 광이 이십규빗이며","reference":"역대하 3:3","category":"$undefined"},{"id":"11234","book":"역대하","book_name":"역대하","chapter":3,"verse":4,"text":"그 전 앞 낭실의 장이 전의 광과 같이 이십 규빗이요 고가 일백 이십 규빗이니 안에는 정금으로 입혔으며","reference":"역대하 3:4","category":"$undefined"},{"id":"11235","book":"역대하","book_name":"역대하","chapter":3,"verse":5,"text":"그 대전 천장은 잣나무로 만들고 또 정금으로 입히고 그 위에 종려나무와 사슬 형상을 새겼고","reference":"역대하 3:5","category":"$undefined"},{"id":"11236","book":"역대하","book_name":"역대하","chapter":3,"verse":6,"text":"또 보석으로 전을 꾸며 화려하게 하였으니 그 금은 바르와임 금이며","reference":"역대하 3:6","category":"$undefined"},{"id":"11237","book":"역대하","book_name":"역대하","chapter":3,"verse":7,"text":"또 금으로 전과 그 들보와 문지방과 벽과 문짝에 입히고 벽에 그룹들을 아로새겼더라","reference":"역대하 3:7","category":"$undefined"},{"id":"11238","book":"역대하","book_name":"역대하","chapter":3,"verse":8,"text":"또 지성소를 지었으니 전 넓이대로 장이 이십 규빗이요 광도 이십 규빗이라 정금 육백 달란트로 입혔으니","reference":"역대하 3:8","category":"$undefined"},{"id":"11239","book":"역대하","book_name":"역대하","chapter":3,"verse":9,"text":"못 중수가 오십 금 세겔이요 다락들도 금으로 입혔더라","reference":"역대하 3:9","category":"$undefined"},{"id":"11240","book":"역대하","book_name":"역대하","chapter":3,"verse":10,"text":"지성소 안에 두 그룹의 형상을 새겨 만들어 금으로 입혔으니","reference":"역대하 3:10","category":"$undefined"},{"id":"11241","book":"역대하","book_name":"역대하","chapter":3,"verse":11,"text":"두 그룹의 날개 길이가 모두 이십 규빗이라 좌편 그룹의 한 날개는 다섯 규빗이니 전 벽에 닿았고 그 한 날개도 다섯 규빗이니 우편 그룹의 날개에 닿았으며","reference":"역대하 3:11","category":"$undefined"},{"id":"11242","book":"역대하","book_name":"역대하","chapter":3,"verse":12,"text":"우편 그룹의 한 날개도 다섯 규빗이니 전 벽에 닿았고 그 한 날개도 다섯 규빗이니 좌편 그룹의 날개에 닿았으며","reference":"역대하 3:12","category":"$undefined"},{"id":"11243","book":"역대하","book_name":"역대하","chapter":3,"verse":13,"text":"이 두 그룹의 편 날개가 모두 이십 규빗이라 그 얼굴을 외소로 향하고 서 있으며","reference":"역대하 3:13","category":"$undefined"},{"id":"11244","book":"역대하","book_name":"역대하","chapter":3,"verse":14,"text":"청색, 자색, 홍색실과, 고운 베로 문장을 짓고 그 위에 그룹의 형상을 수놓았더라","reference":"역대하 3:14","category":"$undefined"},{"id":"11245","book":"역대하","book_name":"역대하","chapter":3,"verse":15,"text":"전 앞에 기둥 둘을 만들었으니 고가 삼십 오 규빗이요, 각 기둥 꼭대기의 머리가 다섯 규빗이라","reference":"역대하 3:15","category":"$undefined"},{"id":"11246","book":"역대하","book_name":"역대하","chapter":3,"verse":16,"text":"성소 같이 사슬을 만들어 그 기둥 머리에 두르고 석류 일백개를 만들어 사슬에 달았으며","reference":"역대하 3:16","category":"$undefined"},{"id":"11247","book":"역대하","book_name":"역대하","chapter":3,"verse":17,"text":"그 두 기둥을 외소 앞에 세웠으니 좌편에 하나요, 우편에 하나라 우편 것은 야긴이라 칭하고 좌편 것은 보아스라 칭하였더라","reference":"역대하 3:17","category":"$undefined"}],"bookSlug":"2chronicles"}]
