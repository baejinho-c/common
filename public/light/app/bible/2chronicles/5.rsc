2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":5,"verses":[{"id":"11270","book":"역대하","book_name":"역대하","chapter":5,"verse":1,"text":"솔로몬이 여호와의 전을 위하여 만드는 모든 것을 마친지라 이에 그 부친 다윗이 드린 은과 금과 모든 기구를 가져다가 하나님의 전 곳간에 두었더라","reference":"역대하 5:1","category":"$undefined"},{"id":"11271","book":"역대하","book_name":"역대하","chapter":5,"verse":2,"text":"이에 솔로몬이 여호와의 언약궤를 다윗 성 곧 시온에서 메어 올리고자 하여 이스라엘 장로들과 모든 지파의 두목 곧 이스라엘 자손의 족장들을 다 예루살렘으로 소집하니","reference":"역대하 5:2","category":"$undefined"},{"id":"11272","book":"역대하","book_name":"역대하","chapter":5,"verse":3,"text":"칠월 절기에 이스라엘 모든 사람이 다 왕에게로 모이고","reference":"역대하 5:3","category":"$undefined"},{"id":"11273","book":"역대하","book_name":"역대하","chapter":5,"verse":4,"text":"이스라엘 장로들이 다 이르매 레위 사람이 궤를 메니라","reference":"역대하 5:4","category":"$undefined"},{"id":"11274","book":"역대하","book_name":"역대하","chapter":5,"verse":5,"text":"궤와 회막과 장막안에 모든 거룩한 기구를 메고 올라가되 제사장과 레위 사람이 그것들을 메고 올라가매","reference":"역대하 5:5","category":"$undefined"},{"id":"11275","book":"역대하","book_name":"역대하","chapter":5,"verse":6,"text":"솔로몬 왕과 그 앞에 모인 이스라엘 회중이 궤 앞에 있어 양과 소로 제사를 드렸으니 그 수가 많아 기록할 수도 없고 셀 수도 없었더라","reference":"역대하 5:6","category":"$undefined"},{"id":"11276","book":"역대하","book_name":"역대하","chapter":5,"verse":7,"text":"제사장들이 여호와의 언약궤를 그 처소로 메어 들였으니 곧 내전 지성소 그룹들의 날개 아래라","reference":"역대하 5:7","category":"$undefined"},{"id":"11277","book":"역대하","book_name":"역대하","chapter":5,"verse":8,"text":"그룹들이 궤 처소 위에서 날개를 펴서 궤와 그 채를 덮었는데","reference":"역대하 5:8","category":"$undefined"},{"id":"11278","book":"역대하","book_name":"역대하","chapter":5,"verse":9,"text":"그 채가 길어서 궤에서 나오므로 그 끝이 내전 앞에서 보이나 밖에서는 보이지 아니하며 그 궤가 오늘까지 그 곳에 있으며","reference":"역대하 5:9","category":"$undefined"},{"id":"11279","book":"역대하","book_name":"역대하","chapter":5,"verse":10,"text":"궤 안에는 두 돌판 외에 아무 것도 없으니 이것은 이스라엘 자손이 애굽에서 나온 후 여호와께서 저희와 언약을 세우실 때에 모세가 호렙에서 그 안에 넣은 것이더라","reference":"역대하 5:10","category":"$undefined"},{"id":"11280","book":"역대하","book_name":"역대하","chapter":5,"verse":11,"text":"이 때에는 제사장들이 그 반차대로 하지 아니하고 스스로 정결케하고 성소에 있다가 나오매","reference":"역대하 5:11","category":"$undefined"},{"id":"11281","book":"역대하","book_name":"역대하","chapter":5,"verse":12,"text":"노래하는 레위 사람 아삽과 헤만과 여두둔과 그 아들들과 형제들이 다 세마포를 입고 단 동편에 서서 제금과 비파와 수금을 잡고 또 나팔 부는 제사장 일백 이십 인이 함께 서 있다가","reference":"역대하 5:12","category":"$undefined"},{"id":"11282","book":"역대하","book_name":"역대하","chapter":5,"verse":13,"text":"나팔 부는 자와 노래하는 자가 일제히 소리를 발하여 여호와를 찬송하며 감사하는데 나팔 불고 제금치고 모든 악기를 울리며 소리를 높여 여호와를 찬송하여 가로되 선하시도다 그 자비하심이 영원히 있도다 하매 그 때에 여호와의 전에 구름이 가득한지라","reference":"역대하 5:13","category":"$undefined"},{"id":"11283","book":"역대하","book_name":"역대하","chapter":5,"verse":14,"text":"제사장이 그 구름으로 인하여 능히 서서 섬기지 못하였으니 이는 여호와의 영광이 하나님의 전에 가득함이었더라","reference":"역대하 5:14","category":"$undefined"}],"bookSlug":"2chronicles"}]
