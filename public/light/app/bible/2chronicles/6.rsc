2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":6,"verses":[{"id":"11284","book":"역대하","book_name":"역대하","chapter":6,"verse":1,"text":"그때에 솔로몬이 가로되 여호와께서 캄캄한데 계시겠다 말씀하셨사오나","reference":"역대하 6:1","category":"$undefined"},{"id":"11285","book":"역대하","book_name":"역대하","chapter":6,"verse":2,"text":"내가 주를 위하여 거하실 전을 건축하였사오니 주께서 영원히 거하실 처소로소이다 하고","reference":"역대하 6:2","category":"$undefined"},{"id":"11286","book":"역대하","book_name":"역대하","chapter":6,"verse":3,"text":"얼굴을 돌이켜 이스라엘의 온 회중을 위하여 축복하니 때에 이스라엘의 온 회중이 서 있더라","reference":"역대하 6:3","category":"$undefined"},{"id":"11287","book":"역대하","book_name":"역대하","chapter":6,"verse":4,"text":"왕이 가로되 이스라엘 하나님 여호와를 송축할지로다 여호와께서 그 입으로 나의 부친 다윗에게 말씀하신 것을 이제 그 손으로 이루셨도다 이르시기를","reference":"역대하 6:4","category":"$undefined"},{"id":"11288","book":"역대하","book_name":"역대하","chapter":6,"verse":5,"text":"내가 내 백성을 애굽 땅에서 인도하여 낸 날부터 내 이름을 둘 만한 집을 건축하기 위하여 이스라엘 모든 지파 가운데서 아무 성읍도 택하지 아니하였으며 내 백성 이스라엘의 주권자를 삼기 위하여 아무 사람도 택하지 아니하였더니","reference":"역대하 6:5","category":"$undefined"},{"id":"11289","book":"역대하","book_name":"역대하","chapter":6,"verse":6,"text":"예루살렘을 택하여 내 이름을 거기 두고 또 다윗을 택하여 내 백성 이스라엘을 다스리게 하였노라 하신지라","reference":"역대하 6:6","category":"$undefined"},{"id":"11290","book":"역대하","book_name":"역대하","chapter":6,"verse":7,"text":"내 부친 다윗이 이스라엘 하나님 여호와의 이름을 위하여 전을 건축할 마음이 있었더니","reference":"역대하 6:7","category":"$undefined"},{"id":"11291","book":"역대하","book_name":"역대하","chapter":6,"verse":8,"text":"여호와께서 내 부친 다윗에게 이르시되 네가 내 이름을 위하여 전을 건축할 마음이 있으니 이 마음이 네게 있는 것이 좋도다","reference":"역대하 6:8","category":"$undefined"},{"id":"11292","book":"역대하","book_name":"역대하","chapter":6,"verse":9,"text":"그러나 너는 그 전을 건축하지 못할 것이요 네 몸에서 낳을 네 아들 그가 내 이름을 위하여 전을 건축하리라 하시더니","reference":"역대하 6:9","category":"$undefined"},{"id":"11293","book":"역대하","book_name":"역대하","chapter":6,"verse":10,"text":"이제 여호와께서 말씀하신 대로 이루시도다 내가 여호와의 허하신 대로 내 부친 다윗을 대신하여 일어나서 이스라엘 위에 앉고 이스라엘 하나님 여호와의 이름을 위하여 전을 건축하고","reference":"역대하 6:10","category":"$undefined"},{"id":"11294","book":"역대하","book_name":"역대하","chapter":6,"verse":11,"text":"내가 또 그 곳에 여호와께서 이스라엘 자손으로 더불어 세우신 언약 넣은 궤를 두었노라","reference":"역대하 6:11","category":"$undefined"},{"id":"11295","book":"역대하","book_name":"역대하","chapter":6,"verse":12,"text":"솔로몬이 여호와의 단 앞에서 이스라엘의 회중을 마주 서서 그 손을 펴니라","reference":"역대하 6:12","category":"$undefined"},{"id":"11296","book":"역대하","book_name":"역대하","chapter":6,"verse":13,"text":"솔로몬이 이왕에 놋으로 대를 만들었으니 장이 다섯 규빗이요 광이 다섯 규빗이요 고가 세 규빗이라 뜰 가운데 두었더니 저가 그위에 서서 이스라엘의 회중앞에서 무릎을 꿇고 하늘을 향하여 손을 펴고","reference":"역대하 6:13","category":"$undefined"},{"id":"11297","book":"역대하","book_name":"역대하","chapter":6,"verse":14,"text":"가로되 이스라엘 하나님 여호와여, 천지에 주와 같은 신이 없나이다 주께서는 온 마음으로 주의 앞에서 행하는 주의 종들에게 언약을 지키시고 은혜를 베푸시나이다","reference":"역대하 6:14","category":"$undefined"},{"id":"11298","book":"역대하","book_name":"역대하","chapter":6,"verse":15,"text":"주께서 주의 종 내 아비 다윗에게 허하신 말씀을 지키시되 주의 입으로 말씀하신 것을 손으로 이루심이 오늘날과 같으니이다","reference":"역대하 6:15","category":"$undefined"},{"id":"11299","book":"역대하","book_name":"역대하","chapter":6,"verse":16,"text":"이스라엘 하나님 여호와여, 주께서 주의 종 내 아비 다윗에게 말씀하시기를 네 자손이 자기 길을 삼가서 네가 내 앞에서 행한 것같이 내 율법대로 행하기만 하면 네게로 좇아 나서 이스라엘 위에 앉을 사람이 내 앞에서 끊어지지 아니하리라 하셨사오니 이제 다윗을 위하여 그 허하신 말씀을 지키시옵소서","reference":"역대하 6:16","category":"$undefined"},{"id":"11300","book":"역대하","book_name":"역대하","chapter":6,"verse":17,"text":"그런즉 이스라엘 하나님 여호와여, 원컨대 주는 주의 종 다윗에게 하신 말씀이 확실하게 하옵소서","reference":"역대하 6:17","category":"$undefined"},{"id":"11301","book":"역대하","book_name":"역대하","chapter":6,"verse":18,"text":"하나님이 참으로 사람과 함께 땅에 거하시리이까 하늘과 하늘들의 하늘이라도 주를 용납지 못하겠거든 하물며 내가 건축한 이 전이오리이까","reference":"역대하 6:18","category":"$undefined"},{"id":"11302","book":"역대하","book_name":"역대하","chapter":6,"verse":19,"text":"그러나 나의 하나님 여호와여, 종의 기도와 간구를 돌아보시며 종이 주의 앞에서 부르짖음과 비는 기도를 들으시옵소서","reference":"역대하 6:19","category":"$undefined"},{"id":"11303","book":"역대하","book_name":"역대하","chapter":6,"verse":20,"text":"주께서 전에 말씀하시기를 내 이름을 거기 두리라 하신 곳 이 전을 향하여 주의 눈이 주야로 보옵시며 종이 이 곳을 향하여 비는 기도를 들으시옵소서","reference":"역대하 6:20","category":"$undefined"},{"id":"11304","book":"역대하","book_name":"역대하","chapter":6,"verse":21,"text":"종과 주의 백성 이스라엘이 이곳을 향하여 기도할때에 주는 그 간구함을 들으시되 주의 계신 곳 하늘에서 들으시고 들으시사 사하여 주옵소서","reference":"역대하 6:21","category":"$undefined"},{"id":"11305","book":"역대하","book_name":"역대하","chapter":6,"verse":22,"text":"만일 어떤 사람이 그 이웃에게 범죄하므로 맹세시킴을 받고 저가 와서 이 전에 있는 주의 단 앞에서 맹세하거든","reference":"역대하 6:22","category":"$undefined"},{"id":"11306","book":"역대하","book_name":"역대하","chapter":6,"verse":23,"text":"주는 하늘에서 들으시고 행하시되 주의 종들을 국문하사 악한 자의 죄를 정하여 그 행위대로 그 머리에 돌리시고 의로운 자를 의롭다 하사 그 의로운 대로 갚으시옵소서","reference":"역대하 6:23","category":"$undefined"},{"id":"11307","book":"역대하","book_name":"역대하","chapter":6,"verse":24,"text":"만일 주의 백성 이스라엘이 주께 범죄하여 적국 앞에 패하게 되므로 주께로 돌아와서 주의 이름을 인정하고 이 전에서 주께 빌며 간구하거든","reference":"역대하 6:24","category":"$undefined"},{"id":"11308","book":"역대하","book_name":"역대하","chapter":6,"verse":25,"text":"주는 하늘에서 들으시고 주의 백성 이스라엘의 죄를 사하시고 그와 그 열조에게 주신 땅으로 돌아오게 하옵소서","reference":"역대하 6:25","category":"$undefined"},{"id":"11309","book":"역대하","book_name":"역대하","chapter":6,"verse":26,"text":"만일 저희가 주께 범죄함을 인하여 하늘이 닫히고 비가 없어서 주의 벌을 받을 때에 이 곳을 향하여 빌며 주의 이름을 인정하고 그 죄에서 떠나거든","reference":"역대하 6:26","category":"$undefined"},{"id":"11310","book":"역대하","book_name":"역대하","chapter":6,"verse":27,"text":"주는 하늘에서 들으사 주의 종들과 주의 백성 이스라엘의 죄를 사하시고 그 마땅히 행할 선한 길을 가르쳐 주옵시며 주의 백성에게 기업으로 주신 주의 땅에 비를 내리시옵소서","reference":"역대하 6:27","category":"$undefined"},{"id":"11311","book":"역대하","book_name":"역대하","chapter":6,"verse":28,"text":"만일 이 땅에 기근이나 온역이 있거나 곡식이 시들거나 깜부기가 나거나 메뚜기나 황충이 나거나 적국이 와서 성읍을 에워 싸거나 무슨 재앙이나 무슨 질병이 있든지 무론하고","reference":"역대하 6:28","category":"$undefined"},{"id":"11312","book":"역대하","book_name":"역대하","chapter":6,"verse":29,"text":"한 사람이나 혹 주의 온 백성 이스라엘이 다 각각 자기의 마음에 재앙과 고통을 깨닫고 이 전을 향하여 손을 펴고 무슨 기도나 무슨 간구를 하거든","reference":"역대하 6:29","category":"$undefined"},{"id":"11313","book":"역대하","book_name":"역대하","chapter":6,"verse":30,"text":"주는 계신 곳 하늘에서 들으시며 사유하시되 각 사람의 마음을 아시오니 그 모든 행위대로 갚으시옵소서 주만 홀로 인생의 마음을 아심이니이다","reference":"역대하 6:30","category":"$undefined"},{"id":"11314","book":"역대하","book_name":"역대하","chapter":6,"verse":31,"text":"그리하시면 저희가 주께서 우리 열조에게 주신 땅에서 사는 동안에 항상 주를 경외하며 주의 길로 행하리이다","reference":"역대하 6:31","category":"$undefined"},{"id":"11315","book":"역대하","book_name":"역대하","chapter":6,"verse":32,"text":"주의 백성 이스라엘에 속하지 않은 이방인에게 대하여도 저희가 주의 큰 이름과 능한 손과 펴신 팔을 위하여 먼 지방에서 와서 이 전을 향하여 기도하거든","reference":"역대하 6:32","category":"$undefined"},{"id":"11316","book":"역대하","book_name":"역대하","chapter":6,"verse":33,"text":"주는 계신 곳 하늘에서 들으시고 무릇 이방인이 주께 부르짖는 대로 이루사 땅의 만민으로 주의 이름을 알고 주의 백성 이스라엘처럼 경외하게 하옵시며 또 내가 건축한 이 전을 주의 이름으로 일컫는 줄을 알게 하옵소서","reference":"역대하 6:33","category":"$undefined"},{"id":"11317","book":"역대하","book_name":"역대하","chapter":6,"verse":34,"text":"주의 백성이 그 적국으로 더불어 싸우고자 하여 주의 보내신 길로 나갈때에 저희가 주의 빼신 이 성과 내가 주의 이름을 위하여 건축한 전있는 편을 향하여 여호와께 기도하거든","reference":"역대하 6:34","category":"$undefined"},{"id":"11318","book":"역대하","book_name":"역대하","chapter":6,"verse":35,"text":"주는 하늘에서 저희의 기도와 간구를 들으시고 그 일을 돌아보옵소서","reference":"역대하 6:35","category":"$undefined"},{"id":"11319","book":"역대하","book_name":"역대하","chapter":6,"verse":36,"text":"범죄치 아니하는 사람이 없사오니 저희가 주께 범죄하므로 주께서 저희에게 진노하사 저희를 적국에게 붙이시매 적국이 저희를 사로잡아 땅의 원근을 물론하고 끌어간 후에","reference":"역대하 6:36","category":"$undefined"},{"id":"11320","book":"역대하","book_name":"역대하","chapter":6,"verse":37,"text":"저희가 사로잡혀 간 땅에서 스스로 깨닫고 그 사로잡은 자의 땅에서 돌이켜 주께 간구하기를 우리가 범죄하여 패역을 행하며 악을 지었나이다 하며","reference":"역대하 6:37","category":"$undefined"},{"id":"11321","book":"역대하","book_name":"역대하","chapter":6,"verse":38,"text":"자기를 사로잡아 간 적국의 땅에서 온 마음과 온 뜻으로 주께 돌아와서 주께서 그 열조에게 주신 땅과 주의 빼신 성과 내가 주의 이름을 위하여 건축한 전 있는 편을 향하여 기도하거든","reference":"역대하 6:38","category":"$undefined"},{"id":"11322","book":"역대하","book_name":"역대하","chapter":6,"verse":39,"text":"주는 계신 곳 하늘에서 저희의 기도와 간구를 들으시고 저희의 일을 돌아보옵시며 주께 득죄한 주의 백성을 용서하옵소서","reference":"역대하 6:39","category":"$undefined"},{"id":"11323","book":"역대하","book_name":"역대하","chapter":6,"verse":40,"text":"나의 하나님이여, 이제 이곳에서 하는 기도에 눈을 드시고 귀를 기울이소서","reference":"역대하 6:40","category":"$undefined"},{"id":"11324","book":"역대하","book_name":"역대하","chapter":6,"verse":41,"text":"여호와 하나님이여, 일어나 들어가사 주의 능력의 궤와 함께 주의 평안한 처소에 계시옵소서 여호와 하나님이여 원컨대 주의 제사장으로 구원을 입게 하시고 또 주의 성도로 은혜를 기뻐하게 하옵소서","reference":"역대하 6:41","category":"$undefined"},{"id":"11325","book":"역대하","book_name":"역대하","chapter":6,"verse":42,"text":"여호와 하나님이여, 주의 기름부음 받은 자에게서 얼굴을 돌이키지 마옵시고 주의 종 다윗에게 베푸신 은총을 기억하옵소서","reference":"역대하 6:42","category":"$undefined"}],"bookSlug":"2chronicles"}]
