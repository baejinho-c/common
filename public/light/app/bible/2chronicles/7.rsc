2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":7,"verses":[{"id":"11326","book":"역대하","book_name":"역대하","chapter":7,"verse":1,"text":"솔로몬이 기도를 마치매 불이 하늘에서부터 내려와서 그 번제물과 제물들을 사르고 여호와의 영광이 그 전에 가득하니","reference":"역대하 7:1","category":"$undefined"},{"id":"11327","book":"역대하","book_name":"역대하","chapter":7,"verse":2,"text":"여호와의 영광이 여호와의 전에 가득하므로 제사장이 그 전에 능히 들어가지 못하였고","reference":"역대하 7:2","category":"$undefined"},{"id":"11328","book":"역대하","book_name":"역대하","chapter":7,"verse":3,"text":"이스라엘 모든 자손은 불이 내리는 것과 여호와의 영광이 전에 있는 것을 보고 박석 깐 땅에 엎드려 경배하며 여호와께 감사하여 가로되 선하시도다 그 인자하심이 영원하도다 하니라","reference":"역대하 7:3","category":"$undefined"},{"id":"11329","book":"역대하","book_name":"역대하","chapter":7,"verse":4,"text":"이에 왕과 모든 백성이 여호와 앞에 제사를 드리니","reference":"역대하 7:4","category":"$undefined"},{"id":"11330","book":"역대하","book_name":"역대하","chapter":7,"verse":5,"text":"솔로몬 왕의 드린 제물이 소가 이만 이천이요 양이 십 이만이라 이와 같이 왕과 모든 백성이 하나님의 전의 낙성식을 행하니라","reference":"역대하 7:5","category":"$undefined"},{"id":"11331","book":"역대하","book_name":"역대하","chapter":7,"verse":6,"text":"때에 제사장들은 직분대로 모셔서고 레위 사람도 여호와의 악기를 가지고 섰으니 이 악기는 전에 다윗 왕이 레위 사람으로 여호와를 찬송하려고 만들어서 여호와의 인자하심이 영원함을 감사케하던 것이라 제사장은 무리 앞에서 나팔을 불고 온 이스라엘은 섰더라","reference":"역대하 7:6","category":"$undefined"},{"id":"11332","book":"역대하","book_name":"역대하","chapter":7,"verse":7,"text":"솔로몬이 또 여호와의 전 앞뜰 가운데를 거룩히 구별하고 거기서 번제물과 화목제의 기름을 드렸으니 이는 솔로몬의 지은 놋단이 능히 그 번제물과 소제물과 기름을 용납할 수 없음이더라","reference":"역대하 7:7","category":"$undefined"},{"id":"11333","book":"역대하","book_name":"역대하","chapter":7,"verse":8,"text":"그때에 솔로몬이 칠일동안 절기를 지켰는데 하맛 어귀에서부터 애굽 하수까지의 온 이스라엘의 심히 큰 회중이 모여 저와 함께 하였더니","reference":"역대하 7:8","category":"$undefined"},{"id":"11334","book":"역대하","book_name":"역대하","chapter":7,"verse":9,"text":"제 팔일에 무리가 한 성회를 여니라 단의 낙성식을 칠일 동안 행한 후 이 절기를 칠일 동안 지키니라","reference":"역대하 7:9","category":"$undefined"},{"id":"11335","book":"역대하","book_name":"역대하","chapter":7,"verse":10,"text":"칠월 이십 삼일에 왕이 백성을 그 장막으로 돌려보내매 백성이 여호와께서 다윗과 솔로몬과 그 백성 이스라엘에게 베푸신 은혜를 인하여 기뻐하며 마음에 즐거워하였더라","reference":"역대하 7:10","category":"$undefined"},{"id":"11336","book":"역대하","book_name":"역대하","chapter":7,"verse":11,"text":"솔로몬이 여호와의 전과 왕궁을 필역하고 무릇 그 심중에 여호와의 전과 자기의 궁궐에 어떻게 만들고자 한 것을 다 형통하게 이루니라","reference":"역대하 7:11","category":"$undefined"},{"id":"11337","book":"역대하","book_name":"역대하","chapter":7,"verse":12,"text":"밤에 여호와께서 솔로몬에게 나타나사 이르시되 내가 이미 네 기도를 듣고 이 곳을 택하여 내게 제사하는 전을 삼았으니","reference":"역대하 7:12","category":"$undefined"},{"id":"11338","book":"역대하","book_name":"역대하","chapter":7,"verse":13,"text":"혹 내가 하늘을 닫고 비를 내리지 아니하거나 혹 메뚜기로 토산을 먹게 하거나 혹 염병으로 내 백성 가운데 유행하게 할 때에","reference":"역대하 7:13","category":"$undefined"},{"id":"11339","book":"역대하","book_name":"역대하","chapter":7,"verse":14,"text":"내 이름으로 일컫는 내 백성이 그 악한 길에서 떠나 스스로 겸비하고 기도하여 내 얼굴을 구하면 내가 하늘에서 듣고 그 죄를 사하고 그 땅을 고칠지라","reference":"역대하 7:14","category":"$undefined"},{"id":"11340","book":"역대하","book_name":"역대하","chapter":7,"verse":15,"text":"이 곳에서 하는 기도에 내가 눈을 들고 귀를 기울이리니","reference":"역대하 7:15","category":"$undefined"},{"id":"11341","book":"역대하","book_name":"역대하","chapter":7,"verse":16,"text":"이는 내가 이미 이 전을 택하고 거룩하게 하여 내 이름으로 여기 영영히 있게 하였음이라 내 눈과 내 마음이 항상 여기 있으리라","reference":"역대하 7:16","category":"$undefined"},{"id":"11342","book":"역대하","book_name":"역대하","chapter":7,"verse":17,"text":"네가 만일 내 앞에서 행하기를 네 아비 다윗 같이 하여 내가 네게 명한 모든 것을 행하여 내 율례와 규례를 지키면","reference":"역대하 7:17","category":"$undefined"},{"id":"11343","book":"역대하","book_name":"역대하","chapter":7,"verse":18,"text":"그러나 너희가 만일 돌이켜 내가 너희 앞에 둔 내 율례와 명령을 버리고 가서 다른 신을 섬겨 숭배하면","reference":"역대하 7:18","category":"$undefined"},{"id":"11344","book":"역대하","book_name":"역대하","chapter":7,"verse":19,"text":"내가 저희에게 준 땅에서 그 뿌리를 뽑아내고 내 이름을 위하여 거룩하게 한 이 전을 내 앞에서 버려 모든 민족 중에 속담거리와 이야기거리가 되게 하리니","reference":"역대하 7:19","category":"$undefined"},{"id":"11345","book":"역대하","book_name":"역대하","chapter":7,"verse":20,"text":"이 전이 비록 높을지라도 무릇 그리로 지나가는 자가 놀라 가로되 여호와께서 무슨 까닭으로 이땅과 이 전에 이같이 행하셨는고하면","reference":"역대하 7:20","category":"$undefined"},{"id":"11346","book":"역대하","book_name":"역대하","chapter":7,"verse":21,"text":"대답하기를 저희가 자기 열조를 애굽 땅에서 인도하여 내신 자기 하나님 여호와를 버리고 다른 신에게 부종하여 그를 숭배하여 섬기므로 여호와께서 이 모든 재앙을 저희에게 내리셨다 하리라 하셨더라","reference":"역대하 7:21","category":"$undefined"},{"id":"11347","book":"역대하","book_name":"역대하","chapter":7,"verse":22,"text":"","reference":"역대하 7:22","category":"$undefined"}],"bookSlug":"2chronicles"}]
