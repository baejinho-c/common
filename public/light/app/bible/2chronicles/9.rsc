2:["$","$L11",null,{"book":{"id":"2chronicles","name":"역대하","chapters":36,"testament":"old"},"chapter":9,"verses":[{"id":"11366","book":"역대하","book_name":"역대하","chapter":9,"verse":1,"text":"스바 여왕이 솔로몬의 명예를 듣고와서 어려운 문제로 솔로몬을 시험코자하여 예루살렘에 이르니 수원이 심히 많고 향품과 많은 금과 보석을 약대에 실었더라 저가 솔로몬에게 나아와 자기 마음에 있는 것을 다 말하매","reference":"역대하 9:1","category":"$undefined"},{"id":"11367","book":"역대하","book_name":"역대하","chapter":9,"verse":2,"text":"솔로몬이 그 묻는 말을 다 대답하였으니 솔로몬이 은미(隱黴)하여 대답지 못한 것이 없었더라","reference":"역대하 9:2","category":"$undefined"},{"id":"11368","book":"역대하","book_name":"역대하","chapter":9,"verse":3,"text":"스바 여왕이 솔로몬의 지혜와 그 건축한 궁과","reference":"역대하 9:3","category":"$undefined"},{"id":"11369","book":"역대하","book_name":"역대하","chapter":9,"verse":4,"text":"그 상의 식물과 그 신복들의 좌석과 그 신하들의 시립한 것과 그들의 공복과 술 관원들과 그들의 공복과 여호와의 전에 올라가는 층계를 보고 정신이 현황하여","reference":"역대하 9:4","category":"$undefined"},{"id":"11370","book":"역대하","book_name":"역대하","chapter":9,"verse":5,"text":"왕께 고하되 내가 내 나라에서 당신의 행위와 당신의 지혜에 대하여 들은 소문이 진실하도다","reference":"역대하 9:5","category":"$undefined"},{"id":"11371","book":"역대하","book_name":"역대하","chapter":9,"verse":6,"text":"내가 그 말들을 믿지 아니하였더니 이제 와서 목도한즉 당신의 지혜가 크다 한 말이 그 절반도 못되니 당신은 내가 들은 소문보다 지나도다","reference":"역대하 9:6","category":"$undefined"},{"id":"11372","book":"역대하","book_name":"역대하","chapter":9,"verse":7,"text":"복되도다, 당신의 사람들이여 ! 복되도다, 당신의 이 신복들이여 ! 항상 당신의 앞에 서서 당신의 지혜를 들음이로다","reference":"역대하 9:7","category":"$undefined"},{"id":"11373","book":"역대하","book_name":"역대하","chapter":9,"verse":8,"text":"당신의 하나님 여호와를 송축할지로다 ! 하나님이 당신을 기뻐하시고 그 위에 올리사 당신의 하나님 여호와를 위하여 왕이 되게 하셨도다 당신의 하나님이 이스라엘을 사랑하사 영원히 견고하게 하시려고 당신을 세워 저희 왕을 삼아 공과 의를 행하게 하셨도다 하고","reference":"역대하 9:8","category":"$undefined"},{"id":"11374","book":"역대하","book_name":"역대하","chapter":9,"verse":9,"text":"이에 저가 금 일백 이십 달란트와 심히 많은 향품과 보석을 왕께 드렸으니 스바 여왕이 솔로몬 왕께 드린 향품 같은 것이 전에는 없었더라","reference":"역대하 9:9","category":"$undefined"},{"id":"11375","book":"역대하","book_name":"역대하","chapter":9,"verse":10,"text":"(후람의 신복들과 솔로몬의 신복들도 도빌에서 금을 실어 올때에 백단목과 보석을 가져온지라","reference":"역대하 9:10","category":"$undefined"},{"id":"11376","book":"역대하","book_name":"역대하","chapter":9,"verse":11,"text":"왕이 백단목으로 여호와의 전과 왕궁의 층대를 만들고 또 노래하는 자를 위하여 수금과 비파를 만들었으니 이같은 것들은 유다 땅에서 전에는 보지 못하였더라)","reference":"역대하 9:11","category":"$undefined"},{"id":"11377","book":"역대하","book_name":"역대하","chapter":9,"verse":12,"text":"솔로몬 왕이 스바 여왕의 가져온대로 답례하고 그외에 또 저의 소원대로 무릇 구하는 것을 주니 이에 저가 그 신복들로 더불어 본국으로 돌아갔더라","reference":"역대하 9:12","category":"$undefined"},{"id":"11378","book":"역대하","book_name":"역대하","chapter":9,"verse":13,"text":"솔로몬의 세입금의 중수가 육백 육십 륙 금 달란트요","reference":"역대하 9:13","category":"$undefined"},{"id":"11379","book":"역대하","book_name":"역대하","chapter":9,"verse":14,"text":"그외에 또 상고와 객상들의 가져온 것이 있고 아라비아 왕들과 그 나라 방백들도 금과 은을 솔로몬에게 가져온지라","reference":"역대하 9:14","category":"$undefined"},{"id":"11380","book":"역대하","book_name":"역대하","chapter":9,"verse":15,"text":"솔로몬 왕이 쳐서 늘인 금으로 큰 방패 이백을 만들었으니 매(每)방패에 든 금이 육백 세겔이며","reference":"역대하 9:15","category":"$undefined"},{"id":"11381","book":"역대하","book_name":"역대하","chapter":9,"verse":16,"text":"또 쳐서 늘인 금으로 작은 방패 삼백을 만들었으니 매(每)방패에 든 금이 삼백 세겔이라 왕이 이것들을 레바논 나무 궁에 두었더라","reference":"역대하 9:16","category":"$undefined"},{"id":"11382","book":"역대하","book_name":"역대하","chapter":9,"verse":17,"text":"왕이 또 상아로 큰 보좌를 만들고 정금으로 입혔으니","reference":"역대하 9:17","category":"$undefined"},{"id":"11383","book":"역대하","book_name":"역대하","chapter":9,"verse":18,"text":"그 보좌에는 여섯 층계와 금 족대가 있어 보좌와 연하였고 앉는 자리 양편에는 팔걸이가 있고 팔걸이 곁에는 사자가 하나씩 섰으며","reference":"역대하 9:18","category":"$undefined"},{"id":"11384","book":"역대하","book_name":"역대하","chapter":9,"verse":19,"text":"또 열 두 사자가 있어 그 여섯 층계 좌우편에 섰으니 아무 나라에도 이같이 만든 것이 없었더라","reference":"역대하 9:19","category":"$undefined"},{"id":"11385","book":"역대하","book_name":"역대하","chapter":9,"verse":20,"text":"솔로몬 왕의 마시는 그릇은 다 금이요 레바논나무 궁의 그릇들도 다 정금이라 솔로몬의 시대에 은을 귀히 여기지 아니함은","reference":"역대하 9:20","category":"$undefined"},{"id":"11386","book":"역대하","book_name":"역대하","chapter":9,"verse":21,"text":"왕의 배들이 후람의 종들과 함께 다시스로 다니며 그 배가 삼년에 일차씩 금과 은과 상아와 잔나비와 공작을 실어옴이더라","reference":"역대하 9:21","category":"$undefined"},{"id":"11387","book":"역대하","book_name":"역대하","chapter":9,"verse":22,"text":"솔로몬 왕의 재산과 지혜가 천하 열왕보다 큰지라","reference":"역대하 9:22","category":"$undefined"},{"id":"11388","book":"역대하","book_name":"역대하","chapter":9,"verse":23,"text":"천하 열왕이 하나님께서 솔로몬의 마음에 주신 지혜를 들으며 그 얼굴을 보기 원하여","reference":"역대하 9:23","category":"$undefined"},{"id":"11389","book":"역대하","book_name":"역대하","chapter":9,"verse":24,"text":"각기 예물을 가지고 왔으니 곧 은그릇과 금그릇과 의복과 갑옷과 향품과 말과 노새라 해마다 정한 수가 있었더라","reference":"역대하 9:24","category":"$undefined"},{"id":"11390","book":"역대하","book_name":"역대하","chapter":9,"verse":25,"text":"솔로몬의 병거 메는 말의 외양간이 사천이요 마병이 일만 이천이라 병거성에도 두고 예루살렘 왕에게도 두었으며","reference":"역대하 9:25","category":"$undefined"},{"id":"11391","book":"역대하","book_name":"역대하","chapter":9,"verse":26,"text":"솔로몬이 유브라데강에서부터 블레셋 땅과 애굽 지경까지의 열왕을 관할하였으며","reference":"역대하 9:26","category":"$undefined"},{"id":"11392","book":"역대하","book_name":"역대하","chapter":9,"verse":27,"text":"왕이 예루살렘에서 은을 돌같이 흔하게 하고 백향목을 평지의 뽕나무같이 많게 하였더라","reference":"역대하 9:27","category":"$undefined"},{"id":"11393","book":"역대하","book_name":"역대하","chapter":9,"verse":28,"text":"솔로몬을 위하여 애굽과 각국에서 말들을 내어왔더라","reference":"역대하 9:28","category":"$undefined"},{"id":"11394","book":"역대하","book_name":"역대하","chapter":9,"verse":29,"text":"이 외에 솔로몬의 시종 행적은 선지자 나단의 글과 실로 사람 아히야의 예언과 선견자 잇도의 묵시책 곧 잇도가 느밧의 아들 여로보암에게 대하여 쓴 책에 기록되지 아니하였느냐","reference":"역대하 9:29","category":"$undefined"},{"id":"11395","book":"역대하","book_name":"역대하","chapter":9,"verse":30,"text":"솔로몬이 예루살렘에서 온 이스라엘을 다스린 지 사십년이라","reference":"역대하 9:30","category":"$undefined"},{"id":"11396","book":"역대하","book_name":"역대하","chapter":9,"verse":31,"text":"솔로몬이 그 열조와 함께 자매 그 부친 다윗의 성에 장사되고 그 아들 르호보암이 대신하여 왕이 되니라","reference":"역대하 9:31","category":"$undefined"}],"bookSlug":"2chronicles"}]
