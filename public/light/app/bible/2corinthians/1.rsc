2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":1,"verses":[{"id":"28802","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":1,"text":"하나님의 뜻으로 말미암아 그리스도 예수의 사도 된 바울과 및 형제 디모데는 고린도에 있는 하나님의 교회와 또 온 아가야에 있는 모든 성도에게","reference":"고린도후서 1:1","category":"$undefined"},{"id":"28803","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":2,"text":"하나님 우리 아버지와 주 예수 그리스도로 좇아 은혜와 평강이 있기를 원하노라 !","reference":"고린도후서 1:2","category":"$undefined"},{"id":"28804","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":3,"text":"찬송하리로다 ! 그는 우리 주 예수 그리스도의 하나님이시요 자비의 아버지시요 모든 위로의 하나님이시며","reference":"고린도후서 1:3","category":"$undefined"},{"id":"28805","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":4,"text":"우리의 모든 환난 중에서 우리를 위로하사 우리로 하여금 하나님께 받는 위로로써 모든 환난 중에 있는 자들을 능히 위로하게 하시는 이시로다","reference":"고린도후서 1:4","category":"$undefined"},{"id":"28806","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":5,"text":"그리스도의 고난이 우리에게 넘친 것같이 우리의 위로도 그리스도로 말미암아 넘치는도다","reference":"고린도후서 1:5","category":"$undefined"},{"id":"28807","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":6,"text":"우리가 환난 받는 것도 너희의 위로와 구원을 위함이요 혹 위로 받는 것도 너희의 위로를 위함이니 이 위로가 너희 속에 역사하여 우리가 받는 것같은 고난을 너희도 견디게 하느니라","reference":"고린도후서 1:6","category":"$undefined"},{"id":"28808","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":7,"text":"너희를 위한 우리의 소망이 견고함은 너희가 고난에 참예하는 자가 된 것같이 위로에도 그러할 줄을 앎이라","reference":"고린도후서 1:7","category":"$undefined"},{"id":"28809","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":8,"text":"형제들아 우리가 아시아에서 당한 환난을 너희가 알지 못하기를 원치 아니하노니 힘에 지나도록 심한 고생을 받아 살 소망까지 끊어지고","reference":"고린도후서 1:8","category":"$undefined"},{"id":"28810","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":9,"text":"우리 마음에 사형선고를 받은 줄 알았으니 이는 우리로 자기를 의뢰하지 말고 오직 죽은 자를 다시 살리시는 하나님만 의뢰하게 하심이라","reference":"고린도후서 1:9","category":"$undefined"},{"id":"28811","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":10,"text":"그가 이같이 큰 사망에서 우리를 건지셨고 또 건지시리라 또한 이후에라도 건지시기를 그를 의지하여 바라노라","reference":"고린도후서 1:10","category":"$undefined"},{"id":"28812","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":11,"text":"너희도 우리를 위하여 간구함으로 도우라 이는 우리가 많은 사람의 기도로 얻은 은사를 인하여 많은 사람도 우리를 위하여 감사하게 하려 함이라","reference":"고린도후서 1:11","category":"$undefined"},{"id":"28813","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":12,"text":"우리가 세상에서 특별히 너희에게 대하여 하나님의 거룩함과 진실함으로써 하되 육체의 지혜로 하지 아니하고 하나님의 은혜로 행함은 우리 양심의 증거하는 바니 이것이 우리의 자랑이라","reference":"고린도후서 1:12","category":"$undefined"},{"id":"28814","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":13,"text":"오직 너희가 읽고 아는 것 외에 우리가 다른 것을 쓰지 아니하노니 너희가 끝까지 알기를 내가 바라는 것은","reference":"고린도후서 1:13","category":"$undefined"},{"id":"28815","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":14,"text":"너희가 대강 우리를 아는 것같이 우리 주 예수의 날에 너희가 우리의 자랑이 되고 우리가 너희의 자랑이 되는 것이라","reference":"고린도후서 1:14","category":"$undefined"},{"id":"28816","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":15,"text":"내가 이 확신을 가지고 너희로 두 번 은혜를 얻게 하기 위하여 먼저 너희에게 이르렀다가","reference":"고린도후서 1:15","category":"$undefined"},{"id":"28817","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":16,"text":"너희를 지나 마게도냐에 갔다가 다시 마게도냐에서 너희에게 가서 너희가 보내줌으로 유대로 가기를 경영하였으니","reference":"고린도후서 1:16","category":"$undefined"},{"id":"28818","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":17,"text":"이렇게 경영할 때에 어찌 경홀히 하였으리요 혹 경영하기를 육체를 좇아 경영하여 예, 예 하고 아니, 아니라 하는 일이 내게 있었겠느냐","reference":"고린도후서 1:17","category":"$undefined"},{"id":"28819","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":18,"text":"하나님은 미쁘시니라 우리가 너희에게 한 말은 예 하고 아니라 함이 없노라","reference":"고린도후서 1:18","category":"$undefined"},{"id":"28820","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":19,"text":"우리 곧 나와 실루아노와 디모데로 말미암아 너희 가운데 전파된 하나님의 아들 예수 그리스도는 예 하고 아니라 함이 되지 아니하였으니 저에게는 예만 되었느니라","reference":"고린도후서 1:19","category":"$undefined"},{"id":"28821","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":20,"text":"하나님의 약속은 얼마든지 그리스도 안에서 예가 되니 그런즉 그로 말미암아 우리가 아멘 하여 하나님께 영광을 돌리게 되느니라","reference":"고린도후서 1:20","category":"$undefined"},{"id":"28822","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":21,"text":"우리를 너희와 함께 그리스도 안에서 견고케 하시고 우리에게 기름을 부으신 이는 하나님이시니","reference":"고린도후서 1:21","category":"$undefined"},{"id":"28823","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":22,"text":"저가 또한 우리에게 인치시고 보증으로 성령을 우리 마음에 주셨느니라","reference":"고린도후서 1:22","category":"$undefined"},{"id":"28824","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":23,"text":"내가 내 영혼을 두고 하나님을 불러 증거하시게 하노니 다시 고린도에 가지 아니한 것은 너희를 아끼려 함이라","reference":"고린도후서 1:23","category":"$undefined"},{"id":"28825","book":"고린도후서","book_name":"고린도후서","chapter":1,"verse":24,"text":"우리가 너희 믿음을 주관하려는 것이 아니요 오직 너희 기쁨을 돕는 자가 되려 함이니 이는 너희가 믿음에 섰음이라","reference":"고린도후서 1:24","category":"$undefined"}],"bookSlug":"2corinthians"}]
