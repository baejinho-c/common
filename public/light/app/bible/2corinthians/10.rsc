2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":10,"verses":[{"id":"28973","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":1,"text":"너희를 대하여 대면하면 겸비하고 떠나 있으면 담대한 나 바울은 이제 그리스도의 온유와 관용으로 친히 너희를 권하고","reference":"고린도후서 10:1","category":"$undefined"},{"id":"28974","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":2,"text":"또한 우리를 육체대로 행하는 자로 여기는 자들을 대하여 내가 담대히 대하려는 것같이 너희와 함께 있을 때에 나로 하여금 이 담대한 태도로 대하지 않게 하기를 구하노라","reference":"고린도후서 10:2","category":"$undefined"},{"id":"28975","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":3,"text":"우리가 육체에 있어 행하나 육체대로 싸우지 아니하노니","reference":"고린도후서 10:3","category":"$undefined"},{"id":"28976","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":4,"text":"우리의 싸우는 병기는 육체에 속한 것이 아니요 오직 하나님 앞에서 견고한 진을 파하는 강력이라","reference":"고린도후서 10:4","category":"$undefined"},{"id":"28977","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":5,"text":"모든 이론을 파하며 하나님 아는 것을 대적하여 높아진 것을 다 파하고 모든 생각을 사로잡아 그리스도에게 복종케 하니","reference":"고린도후서 10:5","category":"$undefined"},{"id":"28978","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":6,"text":"너희의 복종이 온전히 될 때에 모든 복종치 않는 것을 벌하려고 예비하는 중에 있노라","reference":"고린도후서 10:6","category":"$undefined"},{"id":"28979","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":7,"text":"너희는 외모만 보는도다 만일 사람이 자기가 그리스도에게 속한 줄을 믿을진대 자기가 그리스도에게 속한 것같이 우리도 그러한 줄을 자기 속으로 다시 생각할 것이라","reference":"고린도후서 10:7","category":"$undefined"},{"id":"28980","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":8,"text":"주께서 주신 권세는 너희를 파하려고 하신 것이 아니요 세우려고 하신 것이니 내가 이에 대하여 지나치게 자랑하여도 부끄럽지 아니하리라","reference":"고린도후서 10:8","category":"$undefined"},{"id":"28981","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":9,"text":"이는 내가 편지들로 너희를 놀라게 하려는 것같이 생각지 않게 함이니","reference":"고린도후서 10:9","category":"$undefined"},{"id":"28982","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":10,"text":"저희 말이 그 편지들은 중하고 힘이 있으나 그 몸으로 대할 때는 약하고 말이 시원치 않다 하니","reference":"고린도후서 10:10","category":"$undefined"},{"id":"28983","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":11,"text":"이런 사람은 우리가 떠나 있을 때에 편지들로 말하는 자가 어떠한 자이면 함께 있을 때에 행하는 자도 그와 같은 자인줄 알라","reference":"고린도후서 10:11","category":"$undefined"},{"id":"28984","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":12,"text":"우리가 어떤 자기를 칭찬하는 자로 더불어 감히 짝하며 비교할 수 없노라 그러나 저희가 자기로서 자기를 헤아리고 자기로서 자기를 비교하니 지혜가 없도다","reference":"고린도후서 10:12","category":"$undefined"},{"id":"28985","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":13,"text":"그러나 우리는 분량밖의 자랑을 하지 않고 오직 하나님이 우리에게 분량으로 나눠 주신 그 분량의 한계를 따라 하노니 곧 너희에게까지 이른 것이라","reference":"고린도후서 10:13","category":"$undefined"},{"id":"28986","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":14,"text":"우리가 너희에게 미치지 못할 자로서 스스로 지나쳐 나아간 것이 아니요 그리스도의 복음으로 너희에게까지 이른 것이라","reference":"고린도후서 10:14","category":"$undefined"},{"id":"28987","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":15,"text":"우리는 남의 수고를 가지고 분량밖의 자랑하는 것이 아니라 오직 너희 믿음이 더 할수록 우리의 한계를 따라 너희 가운데서 더욱 위대하여지기를 바라노라","reference":"고린도후서 10:15","category":"$undefined"},{"id":"28988","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":16,"text":"이는 남의 한계 안에 예비한 것으로 자랑하지 아니하고 너희 지경을 넘어 복음을 전하려 함이라","reference":"고린도후서 10:16","category":"$undefined"},{"id":"28989","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":17,"text":"자랑하는 자는 주 안에서 자랑할지니라 !","reference":"고린도후서 10:17","category":"$undefined"},{"id":"28990","book":"고린도후서","book_name":"고린도후서","chapter":10,"verse":18,"text":"옳다 인정함을 받는 자는 자기를 칭찬하는 자가 아니요 오직 주께서 칭찬하시는 자니라","reference":"고린도후서 10:18","category":"$undefined"}],"bookSlug":"2corinthians"}]
