2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":11,"verses":[{"id":"28991","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":1,"text":"원컨대 너희는 나의 좀 어리석은 것을 용납하라 청컨대 나를 용납하라","reference":"고린도후서 11:1","category":"$undefined"},{"id":"28992","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":2,"text":"내가 하나님의 열심으로 너희를 위하여 열심 내노니 내가 너희를 정결한 처녀로 한 남편인 그리스도께 드리려고 중매함이로다","reference":"고린도후서 11:2","category":"$undefined"},{"id":"28993","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":3,"text":"뱀이 그 간계로 이와를 미혹케 한 것같이 너희 마음이 그리스도를 향하는 진실함과 깨끗함에서 떠나 부패할까 두려워하노라","reference":"고린도후서 11:3","category":"$undefined"},{"id":"28994","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":4,"text":"만일 누가 가서 우리의 전파하지 아니한 다른 예수를 전파하거나 혹 너희의 받지 아니한 다른 영을 받게 하거나 혹 너희의 받지 아니한 다른 복음을 받게할 때에는 너희가 잘 용납하는구나","reference":"고린도후서 11:4","category":"$undefined"},{"id":"28995","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":5,"text":"내가 지극히 큰 사도들보다 부족한 것이 조금도 없는 줄 생각하노라","reference":"고린도후서 11:5","category":"$undefined"},{"id":"28996","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":6,"text":"내가 비록 말에는 졸(拙)하나 지식에는 그렇지 아니하니 이것을 우리가 모든 사람 가운데서 모든 일로 너희에게 나타내었노라","reference":"고린도후서 11:6","category":"$undefined"},{"id":"28997","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":7,"text":"내가 너희를 높이려고 나를 낮추어 하나님의 복음을 값 없이 너희에게 전함으로 죄를 지었느냐","reference":"고린도후서 11:7","category":"$undefined"},{"id":"28998","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":8,"text":"내가 너희를 섬기기 위하여 다른 여러 교회에서 요(料)를 받은 것이 탈취한 것이라","reference":"고린도후서 11:8","category":"$undefined"},{"id":"28999","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":9,"text":"또 내가 너희에게 있어 용도가 부족하되 아무에게도 누를 끼치지 아니함은 마게도냐에서 온 형제들이 나의 부족한 것을 보충하였음이라 내가 모든 일에 너희에게 폐를 끼치지 않기 위하여 스스로 조심하였거니와 또 조심하리라","reference":"고린도후서 11:9","category":"$undefined"},{"id":"29000","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":10,"text":"그리스도의 진리가 내 속에 있으니 아가야 지방에서 나의 이 자랑이 막히지 아니하리라","reference":"고린도후서 11:10","category":"$undefined"},{"id":"29001","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":11,"text":"어떠한 연고뇨 내가 너희를 사랑하지 아니함이냐 하나님이 아시느니라","reference":"고린도후서 11:11","category":"$undefined"},{"id":"29002","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":12,"text":"내가 하는 것을 또 하리니 기회를 찾는 자들의 그 기회를 끊어 저희로 하여금 그 자랑하는 일에 대하여 우리와 같이 되게 하려 함이로라","reference":"고린도후서 11:12","category":"$undefined"},{"id":"29003","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":13,"text":"저런 사람들은 거짓 사도요 궤휼의 역군(役軍)이니 자기를 그리스도의 사도로 가장하는 자들이니라","reference":"고린도후서 11:13","category":"$undefined"},{"id":"29004","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":14,"text":"이것이 이상한 일이 아니라 사단도 자기를 광명의 천사로 가장하나니","reference":"고린도후서 11:14","category":"$undefined"},{"id":"29005","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":15,"text":"그러므로 사단의 일군들도 자기를 의의 일군으로 가장하는 것이 또한 큰 일이 아니라 저희의 결국은 그 행위대로 되리라","reference":"고린도후서 11:15","category":"$undefined"},{"id":"29006","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":16,"text":"내가 다시 말하노니 누구든지 나를 어리석은 자로 여기지 말라 만일 그러하더라도 나로 조금 자랑하게 어리석은 자로 받으라","reference":"고린도후서 11:16","category":"$undefined"},{"id":"29007","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":17,"text":"내가 말하는 것은 주를 따라 하는 말이 아니요 오직 어리석은 자와 같이 기탄 없이 자랑하노라","reference":"고린도후서 11:17","category":"$undefined"},{"id":"29008","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":18,"text":"여러 사람이 육체를 따라 자랑하니 나도 자랑하겠노라","reference":"고린도후서 11:18","category":"$undefined"},{"id":"29009","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":19,"text":"너희는 지혜로운 자로서 어리석은 자들을 기쁘게 용납하는구나","reference":"고린도후서 11:19","category":"$undefined"},{"id":"29010","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":20,"text":"누가 너희로 종을 삼거나 잡아 먹거나 사로잡거나 자고하다 하거나 뺨을 칠지라도 너희가 용납하는도다","reference":"고린도후서 11:20","category":"$undefined"},{"id":"29011","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":21,"text":"우리가 약한 것같이 내가 욕되게 말하노라 그러나 누가 무슨 일에 담대하면 어리석은 말이나마 나도 담대하리라","reference":"고린도후서 11:21","category":"$undefined"},{"id":"29012","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":22,"text":"저희가 히브리인이냐 나도 그러하며 저희가 이스라엘인이냐 ? 나도 그러하며 저희가 아브라함의 씨냐 ? 나도 그러하며","reference":"고린도후서 11:22","category":"$undefined"},{"id":"29013","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":23,"text":"저희가 그리스도의 일군이냐 정신 없는 말을 하거니와 나도 더욱 그러하도다 내가 수고를 넘치도록 하고 옥에 갇히기도 더 많이 하고, 매도 수없이 맞고, 여러 번 죽을 뻔하였으니","reference":"고린도후서 11:23","category":"$undefined"},{"id":"29014","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":24,"text":"유대인들에게 사십에 하나 감한 매를 다섯 번 맞았으며","reference":"고린도후서 11:24","category":"$undefined"},{"id":"29015","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":25,"text":"세 번 태장으로 맞고 한 번 돌로 맞고 세 번 파선하는데 일주야를 깊음에서 지냈으며","reference":"고린도후서 11:25","category":"$undefined"},{"id":"29016","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":26,"text":"여러 번 여행에 강의 위험과, 강도의 위험과, 동족의 위험과, 이방인의 위험과, 시내의 위험과, 광야의 위험과, 바다의 위험과, 거짓 형제 중의 위험을 당하고","reference":"고린도후서 11:26","category":"$undefined"},{"id":"29017","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":27,"text":"또 수고하며 애쓰고 여러 번 자지 못하고 주리며 목마르고 여러번 굶고 춥고 헐벗었노라","reference":"고린도후서 11:27","category":"$undefined"},{"id":"29018","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":28,"text":"이 외의 일은 고사하고 오히려 날마다 내 속에 눌리는 일이 있으니 곧 모든 교회를 위하여 염려하는 것이라","reference":"고린도후서 11:28","category":"$undefined"},{"id":"29019","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":29,"text":"누가 약하면 내가 약하지 아니하며 누가 실족하게 되면 내가 애타하지 않더냐","reference":"고린도후서 11:29","category":"$undefined"},{"id":"29020","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":30,"text":"내가 부득불 자랑할진대 나의 약한 것을 자랑하리라 !","reference":"고린도후서 11:30","category":"$undefined"},{"id":"29021","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":31,"text":"주 예수의 아버지 영원히 찬송할 하나님이 나의 거짓말 아니하는 줄을 아시느니라","reference":"고린도후서 11:31","category":"$undefined"},{"id":"29022","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":32,"text":"다메섹에서 아레다 왕의 방백이 나를 잡으려고 다메섹 성을 지킬새","reference":"고린도후서 11:32","category":"$undefined"},{"id":"29023","book":"고린도후서","book_name":"고린도후서","chapter":11,"verse":33,"text":"내가 광주리를 타고 들창문으로 성벽을 내려가 그 손에서 벗어났노라","reference":"고린도후서 11:33","category":"$undefined"}],"bookSlug":"2corinthians"}]
