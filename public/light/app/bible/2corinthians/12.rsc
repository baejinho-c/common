2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":12,"verses":[{"id":"29024","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":1,"text":"무익하나마 내가 부득불 자랑하노니 주의 환상과 계시를 말하리라","reference":"고린도후서 12:1","category":"$undefined"},{"id":"29025","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":2,"text":"내가 그리스도 안에 있는 한 사람을 아노니 십 사년 전에 그가 세째 하늘에 이끌려 간 자라 (그가 몸 안에 있었는지 몸 밖에 있었는지 나는 모르거니와 하나님은 아시느니라)","reference":"고린도후서 12:2","category":"$undefined"},{"id":"29026","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":3,"text":"내가 이런 사람을 아노니 (그가 몸 안에 있었는지 몸 밖에 있었는지 나는 모르거니와 하나님은 아시느니라)","reference":"고린도후서 12:3","category":"$undefined"},{"id":"29027","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":4,"text":"그가 낙원으로 이끌려 가서 말할 수 없는 말을 들었으니 사람이 가히 이르지 못할 말이로다","reference":"고린도후서 12:4","category":"$undefined"},{"id":"29028","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":5,"text":"내가 이런 사람을 위하여 자랑하겠으나 나를 위하여는 약한 것들 외에 자랑치 아니하리라","reference":"고린도후서 12:5","category":"$undefined"},{"id":"29029","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":6,"text":"내가 만일 자랑하고자 하여도 어리석은 자가 되지 아니할 것은 내가 참말을 함이라 그러나 누가 나를 보는 바와 내게 듣는 바에 지나치게 생각할까 두려워하여 그만 두노라","reference":"고린도후서 12:6","category":"$undefined"},{"id":"29030","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":7,"text":"여러 계시를 받은 것이 지극히 크므로 너무 자고(自高)하지 않게 하시려고 내 육체에 가시 곧 사단의 사자를 주셨으니 이는 나를 쳐서 너무 자고하지 않게 하려 하심이니라","reference":"고린도후서 12:7","category":"$undefined"},{"id":"29031","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":8,"text":"이것이 내게서 떠나기 위하여 내가 세 번 주께 간구하였더니","reference":"고린도후서 12:8","category":"$undefined"},{"id":"29032","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":9,"text":"내게 이르시기를 내 은혜가 네게 족하도다 ! 이는 내 능력이 약한데서 온전하여짐이라 하신지라 이러므로 도리어 크게 기뻐함으로나의 여러 약한 것들에 대하여 자랑하리니 이는 그리스도의 능력으로 내게 머물게 하려 함이라","reference":"고린도후서 12:9","category":"$undefined"},{"id":"29033","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":10,"text":"그러므로 내가 그리스도를 위하여 약한 것들과, 능욕과, 궁핍과, 핍박과, 곤란을 기뻐하노니 이는 내가 약할 그 때에 곧 강함이니라","reference":"고린도후서 12:10","category":"$undefined"},{"id":"29034","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":11,"text":"내가 어리석은 자가 되었으나 너희에게 억지로 시킨 것이니 내가 너희에게 칭찬을 받아야 마땅하도다 내가 아무 것도 아니나 지극히 큰 사도들보다 조금도 부족하지 아니하니라","reference":"고린도후서 12:11","category":"$undefined"},{"id":"29035","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":12,"text":"사도의 표(標)된 것은 내가 너희 가운데서 모든 참음과, 표적과, 기사와, 능력을 행한 것이라","reference":"고린도후서 12:12","category":"$undefined"},{"id":"29036","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":13,"text":"내 자신이 너희에게 폐를 끼치지 아니한 일밖에 다른 교회보다 부족하게 한 것이 무엇이 있느냐 ? 너희는 나의 이 공평치 못한 것을 용서하라","reference":"고린도후서 12:13","category":"$undefined"},{"id":"29037","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":14,"text":"보라 이제 세 번째 너희에게 가기를 예비하였으나 너희에게 폐를 끼치지 아니하리라 나의 구하는 것은 너희 재물이 아니요 오직 너희니라 어린 아이가 부모를 위하여 재물을 저축하는 것이 아니요 이에 부모가 어린 아이를 위하여 하느니라","reference":"고린도후서 12:14","category":"$undefined"},{"id":"29038","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":15,"text":"내가 너희 영혼을 위하여 크게 기뻐함으로 재물을 허비하고 또 내 자신까지 허비하리니 너희를 더욱 사랑할 수록 나는 덜 사랑을 받겠느냐","reference":"고린도후서 12:15","category":"$undefined"},{"id":"29039","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":16,"text":"하여간 어떤 이의 말이 내가 너희에게 짐을 지우지는 아니하였을지라도 공교한 자가 되어 궤계로 너희를 취하였다 하니","reference":"고린도후서 12:16","category":"$undefined"},{"id":"29040","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":17,"text":"내가 너희에게 보낸 자 중에 누구로 너희의 이(利)를 취하더냐 ?","reference":"고린도후서 12:17","category":"$undefined"},{"id":"29041","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":18,"text":"내가 디도를 권하고 함께 한 형제를 보내었으니 디도가 너희의 이(利)를 취하더냐 우리가 동일한 성령으로 행하지 아니하더냐 동일한 보조로 하지 아니하더냐 ?","reference":"고린도후서 12:18","category":"$undefined"},{"id":"29042","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":19,"text":"이 때까지 우리가 우리를 너희에게 변명하는 줄로 생각하는구나 우리가 그리스도 안에서 하나님 앞에 말하노라 사랑하는 자들아 ! 이 모든 것은 너희의 덕을 세우기 위함이니라","reference":"고린도후서 12:19","category":"$undefined"},{"id":"29043","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":20,"text":"내가 갈 때에 너희를 나의 원하는 것과 같이 보지 못하고 또 내가 너희에게 너희의 원치 않는 것과 같이 보일까 두려워하며 또 다툼과, 시기와, 분냄과, 당 짓는 것과, 중상함과, 수군수군하는 것과, 거만함과, 어지러운 것이 있을까 두려워하고","reference":"고린도후서 12:20","category":"$undefined"},{"id":"29044","book":"고린도후서","book_name":"고린도후서","chapter":12,"verse":21,"text":"또 내가 다시 갈 때에 내 하나님이 나를 너희 앞에서 낮추실까 두려워하고 또 내가 전에 죄를 지은 여러 사람의 그 행한 바 더러움과, 음란함과, 호색함을 회개치 아니함을 인하여 근심할까 두려워하노라","reference":"고린도후서 12:21","category":"$undefined"}],"bookSlug":"2corinthians"}]
