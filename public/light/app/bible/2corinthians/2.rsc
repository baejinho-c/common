2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":2,"verses":[{"id":"28826","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":1,"text":"내가 다시 근심으로 너희에게 나아가지 않기로 스스로 결단하였노니","reference":"고린도후서 2:1","category":"$undefined"},{"id":"28827","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":2,"text":"내가 너희를 근심하게 하면 나의 근심하게 한 자 밖에 나를 기쁘게 하는 자가 누구냐","reference":"고린도후서 2:2","category":"$undefined"},{"id":"28828","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":3,"text":"내가 이같이 쓴 것은 내가 갈 때에 마땅히 나를 기쁘게 할 자로부터 도리어 근심을 얻을까 염려함이요 또 너희 무리를 대하여 나의 기쁨이 너희 무리의 기쁨인 줄 확신함이로라","reference":"고린도후서 2:3","category":"$undefined"},{"id":"28829","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":4,"text":"내가 큰 환난과 애통한 마음이 있어 많은 눈물로 너희에게 썼노니 이는 너희로 근심하게 하려 한 것이 아니요 오직 내가 너희를 향하여 넘치는 사랑이 있음을 너희로 알게 하려 함이라","reference":"고린도후서 2:4","category":"$undefined"},{"id":"28830","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":5,"text":"근심하게 한 자가 있었을지라도 나를 근심하게 한 것이 아니요 어느 정도 너희 무리를 근심하게 한 것이니 어느 정도라 함은 내가 너무 심하게 하지 아니하려 함이라","reference":"고린도후서 2:5","category":"$undefined"},{"id":"28831","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":6,"text":"이러한 사람이 많은 사람에게서 벌받은 것이 족하도다","reference":"고린도후서 2:6","category":"$undefined"},{"id":"28832","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":7,"text":"그런즉 너희는 차라리 저를 용서하고 위로할 것이니 저가 너무 많은 근심에 잠길까 두려워하노라","reference":"고린도후서 2:7","category":"$undefined"},{"id":"28833","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":8,"text":"그러므로 너희를 권하노니 사랑을 저희에게 나타내라","reference":"고린도후서 2:8","category":"$undefined"},{"id":"28834","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":9,"text":"너희가 범사에 순종하는지 그 증거를 알고자 하여 내가 이것을 너희에게 썼노라","reference":"고린도후서 2:9","category":"$undefined"},{"id":"28835","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":10,"text":"너희가 무슨 일이든지 뉘게 용서하면 나도 그리하고 내가 만일 용서한 일이 있으면 용서한 그것은 너희를 위하여 그리스도 앞에서 한 것이니","reference":"고린도후서 2:10","category":"$undefined"},{"id":"28836","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":11,"text":"이는 우리로 사단에게 속지 않게 하려 함이라 우리가 그 궤계를 알지 못하는 바가 아니로라","reference":"고린도후서 2:11","category":"$undefined"},{"id":"28837","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":12,"text":"내가 그리스도의 복음을 위하여 드로아에 이르매 주 안에서 문이 내게 열렸으되","reference":"고린도후서 2:12","category":"$undefined"},{"id":"28838","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":13,"text":"내가 내 형제 디도를 만나지 못하므로 내 심령이 편치 못하여 저희를 작별하고 마게도냐로 갔노라","reference":"고린도후서 2:13","category":"$undefined"},{"id":"28839","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":14,"text":"항상 우리를 그리스도 안에서 이기게 하시고 우리로 말미암아 각처에서 그리스도를 아는 냄새를 나타내시는 하나님께 감사하노라","reference":"고린도후서 2:14","category":"$undefined"},{"id":"28840","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":15,"text":"우리는 구원 얻는 자들에게나 망하는 자들에게나 하나님 앞에서 그리스도의 향기니","reference":"고린도후서 2:15","category":"$undefined"},{"id":"28841","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":16,"text":"이 사람에게는 사망으로 좇아 사망에 이르는 냄새요 저 사람에게는 생명으로 좇아 생명에 이르는 냄새라 누가 이것을 감당하리요","reference":"고린도후서 2:16","category":"$undefined"},{"id":"28842","book":"고린도후서","book_name":"고린도후서","chapter":2,"verse":17,"text":"우리는 수다한 사람과 같이 하나님의 말씀을 혼잡하게 하지 아니하고 곧 순전함으로 하나님께 받은 것같이 하나님 앞에서와 그리스도 안에서 말하노라","reference":"고린도후서 2:17","category":"$undefined"}],"bookSlug":"2corinthians"}]
