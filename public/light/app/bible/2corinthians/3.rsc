2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":3,"verses":[{"id":"28843","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":1,"text":"우리가 다시 자천하기를 시작하겠느냐 우리가 어찌 어떤 사람처럼 천거서(薦擧書)를 너희에게 부치거나 혹 너희에게 맡거나 할 필요가 있느냐 ?","reference":"고린도후서 3:1","category":"$undefined"},{"id":"28844","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":2,"text":"너희가 우리의 편지라 우리 마음에 썼고 뭇사람이 알고 읽는 바라","reference":"고린도후서 3:2","category":"$undefined"},{"id":"28845","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":3,"text":"너희는 우리로 말미암아 나타난 그리스도의 편지니 이는 먹으로 쓴 것이 아니요 오직 살아 계신 하나님의 영으로 한 것이며 또 돌비에 쓴 것이 아니요 오직 육의 심비에 한 것이라","reference":"고린도후서 3:3","category":"$undefined"},{"id":"28846","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":4,"text":"우리가 그리스도로 말미암아 하나님을 향하여 이같은 확신이 있으니","reference":"고린도후서 3:4","category":"$undefined"},{"id":"28847","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":5,"text":"우리가 무슨 일이든지 우리에게서 난 것같이 생각하여 스스로 만족할 것이 아니니 우리의 만족은 오직 하나님께로서 났느니라","reference":"고린도후서 3:5","category":"$undefined"},{"id":"28848","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":6,"text":"저가 또 우리로 새 언약의 일군 되기에 만족케 하셨으니 의문으로 하지 아니하고 오직 영으로 함이니 의문은 죽이는 것이요 영은 살리는 것임이니라","reference":"고린도후서 3:6","category":"$undefined"},{"id":"28849","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":7,"text":"돌에 써서 새긴 죽게 하는 의문(儀文)의 직분도 영광이 있어 이스라엘 자손들이 모세의 얼굴의 없어질 영광을 인하여 그 얼굴을 주목하지 못하였거든","reference":"고린도후서 3:7","category":"$undefined"},{"id":"28850","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":8,"text":"하물며 영의 직분이 더욱 영광이 있지 아니하겠느냐","reference":"고린도후서 3:8","category":"$undefined"},{"id":"28851","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":9,"text":"정죄의 직분도 영광이 있은즉 의의 직분은 영광이 더욱 넘치리라","reference":"고린도후서 3:9","category":"$undefined"},{"id":"28852","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":10,"text":"영광되었던 것이 더 큰 영광을 인하여 이에 영광될 것이 없으나","reference":"고린도후서 3:10","category":"$undefined"},{"id":"28853","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":11,"text":"없어질 것도 영광으로 말미암았은즉 길이 있을 것은 더욱 영광 가운데 있느니라","reference":"고린도후서 3:11","category":"$undefined"},{"id":"28854","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":12,"text":"우리가 이같은 소망이 있으므로 담대히 말하노니","reference":"고린도후서 3:12","category":"$undefined"},{"id":"28855","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":13,"text":"우리는 모세가 이스라엘 자손들로 장차 없어질 것의 결국을 주목치 못하게 하려고 수건을 그 얼굴에 쓴 것같이 아니하노라","reference":"고린도후서 3:13","category":"$undefined"},{"id":"28856","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":14,"text":"그러나 저희 마음이 완고하여 오늘까지라도 구약을 읽을 때에 그 수건이 오히려 벗어지지 아니하고 있으니 그 수건은 그리스도 안에서 없어질 것이라","reference":"고린도후서 3:14","category":"$undefined"},{"id":"28857","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":15,"text":"오늘까지 모세의 글을 읽을 때에 수건이 오히려 그 마음을 덮었도다","reference":"고린도후서 3:15","category":"$undefined"},{"id":"28858","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":16,"text":"그러나 언제든지 주께로 돌아가면 그 수건이 벗어지리라","reference":"고린도후서 3:16","category":"$undefined"},{"id":"28859","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":17,"text":"주는 영이시니 주의 영이 계신 곳에는 자유함이 있느니라 !","reference":"고린도후서 3:17","category":"$undefined"},{"id":"28860","book":"고린도후서","book_name":"고린도후서","chapter":3,"verse":18,"text":"우리가 다 수건을 벗은 얼굴로 거울을 보는것 같이 주의 영광을 보매 저와 같은 형상으로 화하여 영광으로 영광에 이르니 곧 주의 영으로 말미암음이니라","reference":"고린도후서 3:18","category":"$undefined"}],"bookSlug":"2corinthians"}]
