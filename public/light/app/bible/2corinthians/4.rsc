2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":4,"verses":[{"id":"28861","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":1,"text":"이러하므로 우리가 이 직분을 받아 긍휼하심을 입은대로 낙심하지 아니하고","reference":"고린도후서 4:1","category":"$undefined"},{"id":"28862","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":2,"text":"이에 숨은 부끄러움의 일을 버리고 궤휼 가운데 행하지 아니하며 하나님의 말씀을 혼잡케 아니하고 오직 진리를 나타냄으로 하나님 앞에서 각 사람의 양심에 대하여 스스로 천거하노라","reference":"고린도후서 4:2","category":"$undefined"},{"id":"28863","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":3,"text":"만일 우리 복음이 가리웠으면 망하는 자들에게 가리운 것이라","reference":"고린도후서 4:3","category":"$undefined"},{"id":"28864","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":4,"text":"그 중에 이 세상 신이 믿지 아니하는 자들의 마음을 혼미케하여 그리스도의 영광의 복음의 광채를 비취지 못하게 함이니 그리스도는 하나님의 형상이니라","reference":"고린도후서 4:4","category":"$undefined"},{"id":"28865","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":5,"text":"우리가 우리를 전파하는 것이 아니라 오직 그리스도 예수의 주되신 것과 또 예수를 위하여 우리가 너희의 종 된 것을 전파함이라","reference":"고린도후서 4:5","category":"$undefined"},{"id":"28866","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":6,"text":"어두운데서 빛이 비취리라 하시던 그 하나님께서 예수 그리스도의 얼굴에 있는 하나님의 영광을 아는 빛을 우리 마음에 비취셨느니라","reference":"고린도후서 4:6","category":"$undefined"},{"id":"28867","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":7,"text":"우리가 이 보배를 질그릇에 가졌으니 이는 능력의 심히 큰 것이 하나님께 있고 우리에게 있지 아니함을 알게 하려 함이라","reference":"고린도후서 4:7","category":"$undefined"},{"id":"28868","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":8,"text":"우리가 사방으로 우겨쌈을 당하여도 싸이지 아니하며 답답한 일을 당하여도 낙심하지 아니하며","reference":"고린도후서 4:8","category":"$undefined"},{"id":"28869","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":9,"text":"핍박을 받아도 버린 바 되지 아니하며 거꾸러뜨림을 당하여도 망하지 아니하고","reference":"고린도후서 4:9","category":"$undefined"},{"id":"28870","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":10,"text":"우리가 항상 예수 죽인 것을 몸에 짊어짐은 예수의 생명도 우리 몸에 나타나게 하려 함이라","reference":"고린도후서 4:10","category":"$undefined"},{"id":"28871","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":11,"text":"우리 산 자가 항상 예수를 위하여 죽음에 넘기움은 예수의 생명이 또한 우리 죽을 육체에 나타나게 하려 함이니라","reference":"고린도후서 4:11","category":"$undefined"},{"id":"28872","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":12,"text":"그런즉 사망은 우리 안에서 역사하고 생명은 너희 안에서 하느니라","reference":"고린도후서 4:12","category":"$undefined"},{"id":"28873","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":13,"text":"기록한 바 내가 믿는 고로 말하였다 한 것 같이 우리가 같은 믿음의 마음을 가졌으니 우리도 믿는 고로 또한 말하노라","reference":"고린도후서 4:13","category":"$undefined"},{"id":"28874","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":14,"text":"주 예수를 다시 살리신 이가 예수와 함께 우리도 다시 살리사 너희와 함께 그 앞에 서게 하실 줄을 아노니","reference":"고린도후서 4:14","category":"$undefined"},{"id":"28875","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":15,"text":"모든 것을 너희를 위하여 하는 것은 은혜가 많은 사람의 감사함으로 말미암아 더하여 넘쳐서 하나님께 영광을 돌리게 하려 함이라","reference":"고린도후서 4:15","category":"$undefined"},{"id":"28876","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":16,"text":"그러므로 우리가 낙심하지 아니하노니 겉 사람은 후패하나 우리의 속은 날로 새롭도다","reference":"고린도후서 4:16","category":"$undefined"},{"id":"28877","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":17,"text":"우리의 잠시 받는 환난의 경(輕)한 것이 지극히 크고 영원한 영광의 중(重)한 것을 우리에게 이루게 함이니","reference":"고린도후서 4:17","category":"$undefined"},{"id":"28878","book":"고린도후서","book_name":"고린도후서","chapter":4,"verse":18,"text":"우리의 돌아보는 것은 보이는 것이 아니요, 보이지 않는 것이니 보이는 것은 잠간이요, 보이지 않는 것은 영원함이니라","reference":"고린도후서 4:18","category":"$undefined"}],"bookSlug":"2corinthians"}]
