2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":5,"verses":[{"id":"28879","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":1,"text":"만일 땅에 있는 우리의 장막 집이 무너지면 하나님께서 지으신 집 곧 손으로 지은 것이 아니요, 하늘에 있는 영원한 집이 우리에게 있는 줄 아나니","reference":"고린도후서 5:1","category":"$undefined"},{"id":"28880","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":2,"text":"과연 우리가 여기 있어 탄식하며 하늘로부터 오는 우리 처소로 덧입기를 간절히 사모하노니","reference":"고린도후서 5:2","category":"$undefined"},{"id":"28881","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":3,"text":"이렇게 입음은 벗은 자들로 발견되지 않으려 함이라","reference":"고린도후서 5:3","category":"$undefined"},{"id":"28882","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":4,"text":"이 장막에 있는 우리가 짐 진것 같이 탄식하는 것은 벗고자 함이 아니요, 오직 덧입고자 함이니 죽을 것이 생명에게 삼킨바 되게 하려 함이라","reference":"고린도후서 5:4","category":"$undefined"},{"id":"28883","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":5,"text":"곧 이것을 우리에게 이루게 하시고 보증으로 성령을 우리에게 주신 이는 하나님이시니라","reference":"고린도후서 5:5","category":"$undefined"},{"id":"28884","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":6,"text":"이러므로 우리가 항상 담대하여 몸에 거할때에는 주와 따로 거하는 줄을 아노니","reference":"고린도후서 5:6","category":"$undefined"},{"id":"28885","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":7,"text":"이는 우리가 믿음으로 행하고 보는 것으로 하지 아니함이로라","reference":"고린도후서 5:7","category":"$undefined"},{"id":"28886","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":8,"text":"우리가 담대하여 원하는 바는 차라리 몸을 떠나 주와 함께 거하는 그것이라","reference":"고린도후서 5:8","category":"$undefined"},{"id":"28887","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":9,"text":"그런즉 우리는 거하든지, 떠나든지 주를 기쁘시게 하는 자 되기를 힘쓰노라","reference":"고린도후서 5:9","category":"$undefined"},{"id":"28888","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":10,"text":"이는 우리가 다 반드시 그리스도의 심판대 앞에 드러나 각각 선악간에 그 몸으로 행한 것을 따라 받으려 함이라","reference":"고린도후서 5:10","category":"$undefined"},{"id":"28889","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":11,"text":"우리가 주의 두려우심을 알므로 사람을 권하노니 우리가 하나님 앞에 알리워졌고 또 너희의 양심에도 알리워졌기를 바라노라","reference":"고린도후서 5:11","category":"$undefined"},{"id":"28890","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":12,"text":"우리가 다시 너희에게 자천하는 것이 아니요, 오직 우리를 인하여 자랑할 기회를 너희에게 주어 마음으로 하지 않고 외모로 자랑하는 자들을 대하게 하려 하는 것이라","reference":"고린도후서 5:12","category":"$undefined"},{"id":"28891","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":13,"text":"우리가 만일 미쳤어도 하나님을 위한 것이요, 만일 정신이 온전하여도 너희를 위한 것이니","reference":"고린도후서 5:13","category":"$undefined"},{"id":"28892","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":14,"text":"그리스도의 사랑이 우리를 강권하시는도다 우리가 생각건대 한 사람이 모든 사람을 대신하여 죽었은즉 모든 사람이 죽은 것이라","reference":"고린도후서 5:14","category":"$undefined"},{"id":"28893","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":15,"text":"저가 모든 사람을 대신하여 죽으심은 산 자들로 하여금 다시는 저희 자신을 위하여 살지 않고 오직 저희를 대신하여 죽었다가 다시 사신 자를 위하여 살게 하려 함이니라","reference":"고린도후서 5:15","category":"$undefined"},{"id":"28894","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":16,"text":"그러므로 우리가 이제부터는 아무 사람도 육체대로 알지 아니하노라 비록 우리가 그리스도도 육체대로 알지 아니하노라 비록 우리가 그리스도도 육체대로 알았으나 이제부터는 이같이 알지 아니하노라","reference":"고린도후서 5:16","category":"$undefined"},{"id":"28895","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":17,"text":"그런즉 누구든지 그리스도 안에 있으면 새로운 피조물이라 이전 것은 지나갔으니 보라! 새것이 되었도다","reference":"고린도후서 5:17","category":"$undefined"},{"id":"28896","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":18,"text":"모든 것이 하나님께로 났나니 저가 그리스도로 말미암아 우리를 자기와 화목하게 하시고 또 우리에게 화목하게 하는 직책을 주셨으니","reference":"고린도후서 5:18","category":"$undefined"},{"id":"28897","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":19,"text":"이는 하나님께서 그리스도 안에 계시사 세상을 자기와 화목하게 하시며 저희의 죄를 저희에게 돌리지 아니하시고 화목하게 하는 말씀을 우리에게 부탁하셨느니라","reference":"고린도후서 5:19","category":"$undefined"},{"id":"28898","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":20,"text":"이러므로 우리가 그리스도를 대신하여 사신이 되어 하나님이 우리로 너희를 권면하시는 것 같이 그리스도를 대신하여 간구하노니 너희는 하나님과 화목하라 !","reference":"고린도후서 5:20","category":"$undefined"},{"id":"28899","book":"고린도후서","book_name":"고린도후서","chapter":5,"verse":21,"text":"하나님이 죄를 알지도 못하신 자로 우리를 대신하여 죄를 삼으신 것은 우리로 하여금 저의 안에서 하나님의 의가 되게 하려 하심이니라","reference":"고린도후서 5:21","category":"$undefined"}],"bookSlug":"2corinthians"}]
