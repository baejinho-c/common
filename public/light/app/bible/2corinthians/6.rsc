2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":6,"verses":[{"id":"28900","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":1,"text":"우리가 하나님과 함께 일하는 일하는 자로서 너희를 권하노니 하나님의 은혜를 헛되이 받지 말라","reference":"고린도후서 6:1","category":"$undefined"},{"id":"28901","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":2,"text":"가라사대 내가 은혜를 베풀 때에 너를 듣고 구원의 날에 너를 도왔다 하셨으니 보라 ! 지금은 은혜 받을만한 때요, 보라 ! 지금은 구원의 날이로다","reference":"고린도후서 6:2","category":"$undefined"},{"id":"28902","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":3,"text":"우리가 이 직책이 훼방을 받지 않게 하려고 무엇에든지 아무에게도 거리끼지 않게 하고","reference":"고린도후서 6:3","category":"$undefined"},{"id":"28903","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":4,"text":"오직 모든 일에 하나님의 일군으로 자천하여 많이 견디는 것과, 환난과, 궁핍과, 곤난과","reference":"고린도후서 6:4","category":"$undefined"},{"id":"28904","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":5,"text":"매맞음과, 갇힘과, 요란한 것과, 수고로움과, 자지 못함과, 먹지 못함과,","reference":"고린도후서 6:5","category":"$undefined"},{"id":"28905","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":6,"text":"깨끗함과, 지식과, 오래 참음과, 자비함과, 성령의 감화와, 거짓이 없는 사랑과 ,","reference":"고린도후서 6:6","category":"$undefined"},{"id":"28906","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":7,"text":"진리의 말씀과, 하나님의 능력 안에 있어 의의 병기로 좌우하고","reference":"고린도후서 6:7","category":"$undefined"},{"id":"28907","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":8,"text":"영광과 욕됨으로 말미암으며 악한 이름과 아름다운 이름으로 말미암으며 속이는 자 같으나 참되고","reference":"고린도후서 6:8","category":"$undefined"},{"id":"28908","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":9,"text":"무명한 자 같으나 유명한 자요 죽는 자 같으나 보라 ! 우리가 살고 징계를 받는 자 같으나 죽임을 당하지 아니하고","reference":"고린도후서 6:9","category":"$undefined"},{"id":"28909","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":10,"text":"근심하는 자 같으나 항상 기뻐하고, 가난한 자 같으나 많은 사람을 부요하게 하고, 아무 것도 없는 자 같으나 모든 것을 가진 자로다","reference":"고린도후서 6:10","category":"$undefined"},{"id":"28910","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":11,"text":"고린도인들이여 ! 너희를 향하여 우리의 입이 열리고 우리의 마음이 넓었으니","reference":"고린도후서 6:11","category":"$undefined"},{"id":"28911","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":12,"text":"너희가 우리 안에서 좁아진 것이 아니라 오직 너희 심정에서 좁아진 것이니라","reference":"고린도후서 6:12","category":"$undefined"},{"id":"28912","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":13,"text":"내가 자녀에게 말하듯 하노니 보답하는 양으로 너희도 마음을 넓히라","reference":"고린도후서 6:13","category":"$undefined"},{"id":"28913","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":14,"text":"너희는 믿지 않는 자와 멍에를 같이 하지 말라 의와 불법이 어찌 함께 하며 빛과 어두움이 어찌 사귀며","reference":"고린도후서 6:14","category":"$undefined"},{"id":"28914","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":15,"text":"그리스도와 벨리알이 어찌 조화되며 믿는 자와 믿지 않는 자가 어찌 상관하며","reference":"고린도후서 6:15","category":"$undefined"},{"id":"28915","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":16,"text":"하나님의 성전과 우상이 어찌 일치가 되리요 우리는 살아계신 하나님의 성전이라 이와 같이 하나님께서 가라사대 내가 저희 가운데 거하며 두루 행하여 나는 저희 하나님이 되고 저희는 나의 백성이 되리라 하셨느니라","reference":"고린도후서 6:16","category":"$undefined"},{"id":"28916","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":17,"text":"그러므로 주께서 말씀하시기를 너희는 저희 중에서 나와서 따로 있고 부정한 것을 만지지 말라 내가 너희를 영접하여","reference":"고린도후서 6:17","category":"$undefined"},{"id":"28917","book":"고린도후서","book_name":"고린도후서","chapter":6,"verse":18,"text":"너희에게 아버지가 되고 너희는 내게 자녀가 되리라 전능하신 주의 말씀이니라 하셨느니라","reference":"고린도후서 6:18","category":"$undefined"}],"bookSlug":"2corinthians"}]
