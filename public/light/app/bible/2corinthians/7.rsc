2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":7,"verses":[{"id":"28918","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":1,"text":"그런즉 사랑하는 자들아 이 약속을 가진 우리가 하나님을 두려워하는 가운데서 거룩함을 온전히 이루어 육과 영의 온갖 더러운 것에서 자신을 깨끗케 하자","reference":"고린도후서 7:1","category":"$undefined"},{"id":"28919","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":2,"text":"마음으로 우리를 영접하라 우리가 아무에게도 불의를 하지 않고 아무에게도 해롭게 하지 않고 아무에게도 속여 빼앗은 일이 없노라","reference":"고린도후서 7:2","category":"$undefined"},{"id":"28920","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":3,"text":"내가 정죄하려고 이 말을 하는 것이 아니라 이전에 말하였거니와 너희로 우리 마음에 있어 함께 죽고 함께 살게 하고자 함이라","reference":"고린도후서 7:3","category":"$undefined"},{"id":"28921","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":4,"text":"내가 너희를 향하여 하는 말이 담대한 것도 많고 너희를 위하여 자랑하는 것도 많으니 내가 우리의 모든 환난 가운데서도 위로가 가득하고 기쁨이 넘치는도다","reference":"고린도후서 7:4","category":"$undefined"},{"id":"28922","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":5,"text":"우리가 마게도냐에 이르렀을때에도 우리 육체가 편치 못하고 사방으로 환난을 당하여 밖으로는 다툼이요 안으로는 두려움이라","reference":"고린도후서 7:5","category":"$undefined"},{"id":"28923","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":6,"text":"그러나 비천한 자들을 위로하시는 하나님이 디도의 옴으로 우리를 위로하셨으니","reference":"고린도후서 7:6","category":"$undefined"},{"id":"28924","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":7,"text":"저의 온 것뿐 아니요 오직 저가 너희에게 받은 그 위로로 위로하고 너희의 사모함과 애통함과 나를 위하여 열심 있는 것을 우리에게 고함으로 나로 더욱 기쁘게 하였느니라","reference":"고린도후서 7:7","category":"$undefined"},{"id":"28925","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":8,"text":"그러므로 내가 편지로 너희를 근심하게 한 것을 후회하였으나 지금은 후회하지 아니함은 그 편지가 너희로 잠시만 근심하게 한 줄을 앎이라","reference":"고린도후서 7:8","category":"$undefined"},{"id":"28926","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":9,"text":"내가 지금 기뻐함은 너희로 근심하게 한 까닭이 아니요 도리어 너희가 근심함으로 회개함에 이른 까닭이라 너희가 하나님의 뜻대로 근심하게 된 것은 우리에게서 아무 해(害)도 받지 않게 하려 함이라","reference":"고린도후서 7:9","category":"$undefined"},{"id":"28927","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":10,"text":"하나님의 뜻대로 하는 근심은 후회할 것이 없는 구원에 이르게 하는 회개를 이루는 것이요 세상 근심은 사망을 이루는 것이니라","reference":"고린도후서 7:10","category":"$undefined"},{"id":"28928","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":11,"text":"보라 ! 하나님의 뜻대로 하게 한 이 근심이 너희로 얼마나 간절하게 하며, 얼마나 변명하게 하며, 얼마나 분하게 하며, 얼마나 두렵게 하며, 얼마나 사모하게 하며, 얼마나 열심 있게 하며, 얼마나 벌하게 하였는가 너희가 저 일에 대하여 일절 너희 자신의 깨끗함을 나타내었느니라","reference":"고린도후서 7:11","category":"$undefined"},{"id":"28929","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":12,"text":"그런즉 내가 너희에게 쓴 것은 그 불의 행한 자를 위한 것도 아니요 그 불의 당한 자를 위한 것도 아니요 오직 우리를 위한 너희의 간절함이 하나님 앞에서 너희에게 나타나게 하려 함이로라","reference":"고린도후서 7:12","category":"$undefined"},{"id":"28930","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":13,"text":"이로 인하여 우리가 위로를 받았고 우리의 받은 위로 위에 디도의 기쁨으로 우리가 더욱 많이 기뻐함은 그의 마음이 너희 무리를 인하여 안심함을 얻었음이니라","reference":"고린도후서 7:13","category":"$undefined"},{"id":"28931","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":14,"text":"내가 그에게 너희를 위하여 자랑한 것이 있더라도 부끄럽지 아니하니 우리가 너희에게 이른 말이 다 참된 것같이 디도 앞에서 우리의 자랑한 것도 참되게 되었도다","reference":"고린도후서 7:14","category":"$undefined"},{"id":"28932","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":15,"text":"저가 너희 모든 사람들이 두려워하고 떪으로 자기를 영접하여 순종한 것을 생각하고 너희를 향하여 그의 심정이 더욱 깊었으니","reference":"고린도후서 7:15","category":"$undefined"},{"id":"28933","book":"고린도후서","book_name":"고린도후서","chapter":7,"verse":16,"text":"내가 너희를 인하여 범사에 담대한 고로 기뻐하노라","reference":"고린도후서 7:16","category":"$undefined"}],"bookSlug":"2corinthians"}]
