2:["$","$L11",null,{"book":{"id":"2corinthians","name":"고린도후서","chapters":13,"testament":"new"},"chapter":8,"verses":[{"id":"28934","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":1,"text":"형제들아 ! 하나님께서 마게도냐 교회들에게 주신 은혜를 우리가 너희에게 알게 하노니","reference":"고린도후서 8:1","category":"$undefined"},{"id":"28935","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":2,"text":"환난의 많은 시련 가운데서 저희 넘치는 기쁨과 극한 가난이 저희로 풍성한 연보를 넘치도록 하게 하였느니라","reference":"고린도후서 8:2","category":"$undefined"},{"id":"28936","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":3,"text":"내가 증거하노니 저희가 힘대로 할 뿐 아니라 힘에 지나도록 자원하여","reference":"고린도후서 8:3","category":"$undefined"},{"id":"28937","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":4,"text":"이 은혜와 성도 섬기는 일에 참여함에 대하여 우리에게 간절히 구하니","reference":"고린도후서 8:4","category":"$undefined"},{"id":"28938","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":5,"text":"우리의 바라던 것뿐 아니라 저희가 먼저 자신을 주께 드리고 또 하나님 뜻을 좇아 우리에게 주었도다","reference":"고린도후서 8:5","category":"$undefined"},{"id":"28939","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":6,"text":"이러므로 우리가 디도를 권하여 너희 가운데서 시작하였은즉 이 은혜를 그대로 성취케 하라 하였노라","reference":"고린도후서 8:6","category":"$undefined"},{"id":"28940","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":7,"text":"오직 너희는 믿음과 말과 지식과 모든 간절함과 우리를 사랑하는 이 모든 일에 풍성한 것같이 이 은혜에도 풍성하게 할지니라","reference":"고린도후서 8:7","category":"$undefined"},{"id":"28941","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":8,"text":"내가 명령으로 하는 말이 아니요 오직 다른 이들의 간절함을 가지고 너희의 사랑의 진실함을 증명코자 함이로라","reference":"고린도후서 8:8","category":"$undefined"},{"id":"28942","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":9,"text":"우리 주 예수 그리스도의 은혜를 너희가 알거니와 부요하신 자로서 너희를 위하여 가난하게 되심은 그의 가난함을 인하여 너희로 부요케 하려 하심이니라","reference":"고린도후서 8:9","category":"$undefined"},{"id":"28943","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":10,"text":"이 일에 내가 뜻만 보이노니 이것은 너희에게 유익함이라 너희가 일 년 전에 행하기를 먼저 시작할 뿐 아니라 원하기도 하였은즉","reference":"고린도후서 8:10","category":"$undefined"},{"id":"28944","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":11,"text":"이제는 행하기를 성취할지니 마음에 원하던 것과 같이 성취하되 있는 대로 하라","reference":"고린도후서 8:11","category":"$undefined"},{"id":"28945","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":12,"text":"할 마음만 있으면 있는 대로 받으실 터이요 없는 것을 받지 아니하시리라","reference":"고린도후서 8:12","category":"$undefined"},{"id":"28946","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":13,"text":"이는 다른 사람들은 평안하게 하고 너희는 곤고하게 하려는 것이 아니요 평균케 하려 함이니","reference":"고린도후서 8:13","category":"$undefined"},{"id":"28947","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":14,"text":"이제 너희의 유여한 것으로 저희 부족한 것을 보충함은 후에 저희 유여(有餘)한 것으로 너희 부족한 것을 보충하여 평균하게 하려 함이라","reference":"고린도후서 8:14","category":"$undefined"},{"id":"28948","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":15,"text":"기록한 것같이 많이 거둔 자도 남지 아니하였고 적게 거둔 자도 모자라지 아니하였느니라","reference":"고린도후서 8:15","category":"$undefined"},{"id":"28949","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":16,"text":"너희를 위하여 같은 간절함을 디도의 마음에도 주시는 하나님께 감사하노니","reference":"고린도후서 8:16","category":"$undefined"},{"id":"28950","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":17,"text":"저가 권함을 받고 더욱 간절함으로 자원하여 너희에게 나아갔고","reference":"고린도후서 8:17","category":"$undefined"},{"id":"28951","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":18,"text":"또 저와 함께 한 형제를 보내었으니 이 사람은 복음으로서 모든 교회에서 칭찬을 받는 자요","reference":"고린도후서 8:18","category":"$undefined"},{"id":"28952","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":19,"text":"이뿐 아니라 저는 동일한 주의 영광과 우리의 원(願)을 나타내기 위하여 여러 교회의 택함을 입어 우리의 맡은 은혜의 일로 우리와 동행하는 자라","reference":"고린도후서 8:19","category":"$undefined"},{"id":"28953","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":20,"text":"이것을 조심함은 우리가 맡은 이 거액의 연보로 인하여 아무도 우리를 훼방하지 못하게 하려 함이니","reference":"고린도후서 8:20","category":"$undefined"},{"id":"28954","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":21,"text":"이는 우리가 주 앞에서만 아니라 사람 앞에서도 선한 일에 조심하려 함이라","reference":"고린도후서 8:21","category":"$undefined"},{"id":"28955","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":22,"text":"또 저희와 함께 우리의 한 형제를 보내었노니 우리가 여러 가지 일에 그 간절한 것을 여러 번 시험하였거니와 이제 저가 너희를 크게 믿은고로 더욱 간절하니라","reference":"고린도후서 8:22","category":"$undefined"},{"id":"28956","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":23,"text":"디도로 말하면 나의 동무요 너희를 위한 나의 동역자요 우리 형제들로 말하면 여러 교회의 사자들이요 그리스도의 영광이니라","reference":"고린도후서 8:23","category":"$undefined"},{"id":"28957","book":"고린도후서","book_name":"고린도후서","chapter":8,"verse":24,"text":"그러므로 너희는 여러 교회 앞에서 너희의 사랑과 너희를 대한 우리 자랑의 증거를 저희에게 보이라","reference":"고린도후서 8:24","category":"$undefined"}],"bookSlug":"2corinthians"}]
