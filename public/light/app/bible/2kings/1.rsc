2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":1,"verses":[{"id":"9535","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":1,"text":"아합이 죽은 후에 모압이 이스라엘을 배반하였더라","reference":"열왕기하 1:1","category":"$undefined"},{"id":"9536","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":2,"text":"아하시야가 사마리아에 있는 그 다락 난간에서 떨어져 병들매 사자를 보내며 저희더러 이르되 `가서 에그론의 신 바알세붑에게 이 병이 낫겠나 물어 보라' 하니라","reference":"열왕기하 1:2","category":"$undefined"},{"id":"9537","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":3,"text":"여호와의 사자가 디셉 사람 엘리야에게 이르시되 `너는 일어나 올라가서 사마리아 왕의 사자를 만나서 저에게 이르기를 이스라엘에 하나님이 없어서 너희가 에그론의 신 바알세붑에게 물으러 가느냐","reference":"열왕기하 1:3","category":"$undefined"},{"id":"9538","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":4,"text":"그러므로 여호와의 말씀이 네가 올라간 침상에서 내려오지 못할지라 네가 반드시 죽으리라 하셨다 하라' 엘리야가 이에 가니라","reference":"열왕기하 1:4","category":"$undefined"},{"id":"9539","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":5,"text":"사자들이 왕에게 돌아오니 왕이 이르되 `너희는 어찌하여 돌아왔느냐'","reference":"열왕기하 1:5","category":"$undefined"},{"id":"9540","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":6,"text":"저희가 고하되 `한 사람이 올라와서 우리를 만나 이르되 너희는 너희를 보낸 왕에게로 돌아가서 저에게 고하기를 여호와의 말씀이 이스라엘에 하나님이 없어서 네가 에그론의 신 바알세붑에게 물으려고 보내느냐 그러므로 네가 올라간 침상에서 내려오지 못할지라 네가 반드시 죽으리라 하셨다 하라 하더이다'","reference":"열왕기하 1:6","category":"$undefined"},{"id":"9541","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":7,"text":"왕이 저희에게 이르되 `올라와서 너희를 만나 이 말을 너희에게 고한 그 사람의 모양이 어떠하더냐'","reference":"열왕기하 1:7","category":"$undefined"},{"id":"9542","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":8,"text":"저희가 대답하되 `그는 털이 많은 사람인데 허리에 가죽 띠를 띠었더이다' 왕이 가로되 `그는 디셉 사람 엘리야로다'","reference":"열왕기하 1:8","category":"$undefined"},{"id":"9543","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":9,"text":"이에 오십부장과 그 오십인을 엘리야에게로 보내매 저가 엘리야에게로 올라가서 본즉 산꼭대기에 앉았는지라 저가 엘리야에게 이르되 하나님의 사람이여 왕의 말씀이 내려오라 하셨나이다","reference":"열왕기하 1:9","category":"$undefined"},{"id":"9544","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":10,"text":"엘리야가 오십부장에게 대답하여 가로되 `내가 만일 하나님의 사람이면 불이 하늘에서 내려와서 너와 너의 오십인을 사를지로다' 하매 불이 곧 하늘에서 내려와서 저와 그 오십인을 살랐더라","reference":"열왕기하 1:10","category":"$undefined"},{"id":"9545","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":11,"text":"왕이 다시 다른 오십부장과 그 오십인을 엘리야에게로 보내니 저가 엘리야에게 일러 가로되 하나님의 사람이여 왕의 말씀이 속히 내려 오라 하셨나이다","reference":"열왕기하 1:11","category":"$undefined"},{"id":"9546","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":12,"text":"엘리야가 저희에게 대답하여 가로되 `내가 만일 하나님의 사람이면 불이 하늘에서 내려와서 너와 너의 오십인을 사를지로다' 하매 하나님의 불이 곧 하늘에서 내려와서 저와 그 오십인을 살랐더라","reference":"열왕기하 1:12","category":"$undefined"},{"id":"9547","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":13,"text":"왕이 세번째 오십부장과 그 오십인을 보낸지라 세째 오십부장이 올라가서 엘리야의 앞에 이르러 꿇어 엎드려 간구하여 가로되 하나님의 사람이여 원컨대 나의 생명과 당신의 종인 이 오십인의 생명을 당신은 귀히 보소서","reference":"열왕기하 1:13","category":"$undefined"},{"id":"9548","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":14,"text":"불이 하늘에서 내려와서 전번의 오십부장 둘과 그 오십인들을 살랐거니와 나의 생명을 당신은 귀히 보소서 하매","reference":"열왕기하 1:14","category":"$undefined"},{"id":"9549","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":15,"text":"여호와의 사자가 엘리야에게 이르되 `너는 저를 두려워 말고 함께 내려가라' 하신지라 엘리야가 곧 일어나 저와 함께 내려와서 왕에게 이르러","reference":"열왕기하 1:15","category":"$undefined"},{"id":"9550","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":16,"text":"고하되 `여호와의 말씀이 네가 사자를 보내어 에그론의 신 바알세붑에게 물으려 하니 이스라엘에 그 말을 물을만한 하나님이 없음이냐 그러므로 네가 그 올라간 침상에서 내려오지 못할지라 네가 반드시 죽으리라 하셨다' 하니라","reference":"열왕기하 1:16","category":"$undefined"},{"id":"9551","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":17,"text":"왕이 엘리야의 전한 여호와의 말씀대로 죽고 저가 아들이 없으므로 여호람이 대신하여 왕이 되니 유다 왕 여호사밧의 아들 여호람의 제 이년이었더라","reference":"열왕기하 1:17","category":"$undefined"},{"id":"9552","book":"열왕기하","book_name":"열왕기하","chapter":1,"verse":18,"text":"아하시야의 남은 사적은 모두 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 1:18","category":"$undefined"}],"bookSlug":"2kings"}]
