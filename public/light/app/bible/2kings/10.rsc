2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":10,"verses":[{"id":"9795","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":1,"text":"아합의 아들 칠십인이 사마리아에 있는지라 예후가 편지들을 써서 사마리아에 보내어 이스르엘 방백 곧 장로들과 아합의 여러 아들을 교육하는 자들에게 전하니 일렀으되","reference":"열왕기하 10:1","category":"$undefined"},{"id":"9796","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":2,"text":"너희 주의 아들들이 너희와 함께 있고 또 병거와 말과 견고한 성과 병기가 너희에게 있으니 이 편지가 너희에게 이르거든","reference":"열왕기하 10:2","category":"$undefined"},{"id":"9797","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":3,"text":"너희 주의 아들들 중에서 가장 어질고 정직한 자를 택하여 그 아비의 위에 두고 너희 주의 집을 위하여 싸우라 하였더라","reference":"열왕기하 10:3","category":"$undefined"},{"id":"9798","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":4,"text":"저희가 심히 두려워하여 가로되 두 왕이 저를 당치 못하였거든 우리가 어찌 당하리요 하고","reference":"열왕기하 10:4","category":"$undefined"},{"id":"9799","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":5,"text":"궁내 대신과 부윤과 장로들과 왕자를 교육하는 자들이 예후에게 말을 전하여 가로되 우리는 당신의 종이라 무릇 명하는 것을 우리가 행하고 아무 사람이든지 왕으로 세우지 아니하리니 당신의 소견에 좋은대로 행하라 한지라","reference":"열왕기하 10:5","category":"$undefined"},{"id":"9800","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":6,"text":"예후가 다시 저희에게 편지를 부치니 일렀으되 만일 너희가 내 편이 되어 내 말을 들으려거든 너희 주의 아들된 사람들의 머리를 취하고 내일 이맘때에 이스르엘에 이르러 내게 나아오라 하였더라 왕자 칠십인이 성중에서 그 교육하는 존귀한 자들과 함께 있는 중에","reference":"열왕기하 10:6","category":"$undefined"},{"id":"9801","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":7,"text":"편지가 이르매 저희가 왕자 칠십인을 잡아 몰수히 죽이고 그 머리를 광주리에 담아 이스르엘 예후에게로 보내니라","reference":"열왕기하 10:7","category":"$undefined"},{"id":"9802","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":8,"text":"사자가 와서 예후에게 고하여 가로되 무리가 왕자들의 머리를 가지고 왔나이다 가로되 두 무더기로 쌓아 내일 아침까지 문 어귀에 두라 하고","reference":"열왕기하 10:8","category":"$undefined"},{"id":"9803","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":9,"text":"이튿날 아침에 저가 나가 서서 뭇백성에게 이르되 너희는 의롭도다 나는 내 주를 배반하여 죽였거니와 이 여러 사람을 죽인 자는 누구냐","reference":"열왕기하 10:9","category":"$undefined"},{"id":"9804","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":10,"text":"그런즉 너희는 알라 곧 여호와께서 아합의 집에 대하여 하신 말씀은 하나도 땅에 떨어지지 아니하리라 여호와께서 그 종 엘리야로 하신 말씀을 이제 이루셨도다 하니라","reference":"열왕기하 10:10","category":"$undefined"},{"id":"9805","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":11,"text":"예후가 무릇 아합의 집에 속한 이스르엘에 남아 있는 자를 다 죽이고 또 그 존귀한 자와 가까운 친구와 제사장들을 죽이되 저에게 속한 자를 하나도 남기지 아니하였더라","reference":"열왕기하 10:11","category":"$undefined"},{"id":"9806","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":12,"text":"예후가 일어나서 사마리아로 가더니 노중에 목자가 양털 깎는 집에 이르러","reference":"열왕기하 10:12","category":"$undefined"},{"id":"9807","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":13,"text":"유다 왕 아하시야의 형제들을 만나 묻되 너희는 누구냐 대답하되 우리는 아하시야의 형제라 이제 왕자들과 태후의 아들들에게 문안하러 내려가노라","reference":"열왕기하 10:13","category":"$undefined"},{"id":"9808","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":14,"text":"가로되 사로잡으라 하매 곧 사로잡아 목자가 양털 깎는 집 웅덩이 곁에서 죽이니 사십 이인이 하나도 남지 아니하였더라","reference":"열왕기하 10:14","category":"$undefined"},{"id":"9809","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":15,"text":"예후가 거기서 떠나가다가 레갑의 아들 여호나답이 맞으러 오는 것을 만난지라 그 안부를 묻고 가로되 내 마음이 네 마음을 향하여 진실함과 같이 네 마음도 진실하냐 여호나답이 대답하되 그러하니이다 가로되 그러면 나와 손을 잡자 손을 잡으니 예후가 끌어 병거에 올리며","reference":"열왕기하 10:15","category":"$undefined"},{"id":"9810","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":16,"text":"가로되 나와 함께 가서 여호와를 위한 나의 열심을 보라 하고 이에 자기 병거에 태우고","reference":"열왕기하 10:16","category":"$undefined"},{"id":"9811","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":17,"text":"사마리아에 이르러 거기 남아있는바 아합에게 속한 자를 죽여 진멸하였으니 여호와께서 엘리야에게 이르신 말씀과 같이 되었더라","reference":"열왕기하 10:17","category":"$undefined"},{"id":"9812","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":18,"text":"예후가 뭇백성을 모으고 이르되 아합은 바알을 조금 섬겼으나 예후는 많이 섬기리라","reference":"열왕기하 10:18","category":"$undefined"},{"id":"9813","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":19,"text":"그러므로 내가 이제 큰 제사를 바알에게 드리고자 하노니 바알의 모든 선지자와 모든 섬기는 자와 모든 제사장들을 한 사람도 빠치지 말고 불러 내게로 나오게 하라 무릇 오지 아니하는 자는 살리지 아니하리라 하니 이는 예후가 바알 섬기는자를 멸하려 하여 궤계를 씀이라","reference":"열왕기하 10:19","category":"$undefined"},{"id":"9814","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":20,"text":"예후가 바알을 위하는 대회를 거룩히 열라 하매 드디어 공포하였더라","reference":"열왕기하 10:20","category":"$undefined"},{"id":"9815","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":21,"text":"예후가 온 이스라엘에 두루 보내었더니 무릇 바알을 섬기는 사람이 하나도 빠진 자가 없이 다 이르렀고 무리가 바알의 당에 들어가매 이편부터 저편까지 가득하였더라","reference":"열왕기하 10:21","category":"$undefined"},{"id":"9816","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":22,"text":"예후가 예복 맡은 자에게 이르되 예복을 내어다가 무릇 바알 섬기는 자에게 주라 하매 저희에게로 예복을 가져온지라","reference":"열왕기하 10:22","category":"$undefined"},{"id":"9817","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":23,"text":"예후가 레갑의 아들 여호나답으로 더불어 바알의 당에 들어가서 바알을 섬기는 자에게 이르되 너희는 살펴보아 바알을 섬기는 자만 여기 있게 하고 여호와의 종은 하나도 너희 중에 있지 못하게 하라 하고","reference":"열왕기하 10:23","category":"$undefined"},{"id":"9818","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":24,"text":"무리가 번제와 다른 제사를 드리려고 들어간 때에 예후가 팔십인을 밖에 두며 이르되 내가 너희 손에 붙이는 사람을 한 사람이라도 도망하게 하는 자는 자기의 생명으로 그 사람의 생명을 대신하리라 하니라","reference":"열왕기하 10:24","category":"$undefined"},{"id":"9819","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":25,"text":"번제 드리기를 다하매 예후가 호위병과 장관들에게 이르되 들어가서 한 사람도 나가지 못하게 하고 죽이라 하매 호위병과 장관 들이 칼로 저희를 죽여 밖에 던지고","reference":"열왕기하 10:25","category":"$undefined"},{"id":"9820","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":26,"text":"바알의 당있는 성으로 가서 바알의 당에서 목상들을 가져다가 불사르고","reference":"열왕기하 10:26","category":"$undefined"},{"id":"9821","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":27,"text":"바알의 목상을 헐며 바알의 당을 훼파하여 변소를 만들었더니 오늘날까지 이르니라","reference":"열왕기하 10:27","category":"$undefined"},{"id":"9822","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":28,"text":"예후가 이와 같이 이스라엘 중에서 바알을 멸하였으나","reference":"열왕기하 10:28","category":"$undefined"},{"id":"9823","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":29,"text":"이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄 곧 벧엘과 단에 있는 금송아지를 섬기는 죄에서는 떠나지 아니하였더라","reference":"열왕기하 10:29","category":"$undefined"},{"id":"9824","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":30,"text":"여호와께서 예후에게 이르시되 네가 나 보기에 정직한 일을 행하되 잘 행하여 내 마음에 있는대로 아합집에 다 행하였은즉 네 자손이 이스라엘 왕위를 이어 사대를 지나리라 하시니라","reference":"열왕기하 10:30","category":"$undefined"},{"id":"9825","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":31,"text":"그러나 예후가 전심으로 이스라엘 하나님 여호와의 율법을 지켜 행하지 아니하며 여로보암이 이스라엘로 범하게 한 그 죄에서 떠나지 아니하였더라","reference":"열왕기하 10:31","category":"$undefined"},{"id":"9826","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":32,"text":"이때에 여호와께서 비로소 이스라엘을 찢으시매 하사엘이 그 사방을 치되","reference":"열왕기하 10:32","category":"$undefined"},{"id":"9827","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":33,"text":"요단 동편 길르앗 온 땅 곧 갓 사람과 르우벤 사람과 므낫세 사람의 땅 아르논 골짜기에 있는 아로엘에서부터 길르앗과 바산까지 하였더라","reference":"열왕기하 10:33","category":"$undefined"},{"id":"9828","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":34,"text":"예후의 남은 사적과 무릇 행한 일과 모든 권세는 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 10:34","category":"$undefined"},{"id":"9829","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":35,"text":"예후가 그 열조와 함께 자매 사마리아에 장사되고 그 아들 여호아하스가 대신하여 왕이 되니라","reference":"열왕기하 10:35","category":"$undefined"},{"id":"9830","book":"열왕기하","book_name":"열왕기하","chapter":10,"verse":36,"text":"예후가 사마리아에서 이스라엘을 다스린 햇수는 이십 팔년이더라","reference":"열왕기하 10:36","category":"$undefined"}],"bookSlug":"2kings"}]
