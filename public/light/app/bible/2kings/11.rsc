2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":11,"verses":[{"id":"9831","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":1,"text":"아하시야의 모친 아달랴가 그 아들의 죽은 것을 보고 일어나 왕의 씨를 진멸하였으나","reference":"열왕기하 11:1","category":"$undefined"},{"id":"9832","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":2,"text":"요람 왕의 딸 아하시야의 누이 여호세바가 아하시야의 아들 요아스를 왕자들의 죽임을 당하는 중에서 도적하여 내고 저와 그 유모를 침실에 숨겨 아달랴를 피하여 죽임을 당치 않게 한지라","reference":"열왕기하 11:2","category":"$undefined"},{"id":"9833","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":3,"text":"요아스가 저와 함께 여호와의 전에 육년을 숨어 있는 동안에 아달랴가 나라를 다스렸더라","reference":"열왕기하 11:3","category":"$undefined"},{"id":"9834","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":4,"text":"제 칠년에 여호야다가 보내어 가리 사람의 백부장들과 호위병의 백부장들을 불러 데리고 여호와의 전으로 들어가서 저희와 언약을 세우고 저희로 여호와의 전에서 맹세케 한 후에 왕자를 보이 고","reference":"열왕기하 11:4","category":"$undefined"},{"id":"9835","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":5,"text":"명하여 가로되 너희의 행할 것이 이러하니 안식일에 입번한 너희중 삼분 일은 왕궁을 주의하여 지키고","reference":"열왕기하 11:5","category":"$undefined"},{"id":"9836","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":6,"text":"삼분 일은 수르문에 있고 삼분 일은 호위대 뒤에 있는 문에 있어서 이와 같이 왕궁을 주의하여 지켜 방어하고","reference":"열왕기하 11:6","category":"$undefined"},{"id":"9837","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":7,"text":"안식일에 출번하는 너희중 두 대는 여호와의 전을 주의하여 지켜 왕을 호위하되","reference":"열왕기하 11:7","category":"$undefined"},{"id":"9838","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":8,"text":"너희는 각각 손에 병기를 잡고 왕을 호위하며 무릇 너희 반열을 침범하는 자는 죽이고 왕의 출입할 때에 시위할지니라","reference":"열왕기하 11:8","category":"$undefined"},{"id":"9839","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":9,"text":"백부장들이 이에 제사장 여호야다의 모든 명대로 행하여 각기 관할하는 바 안식일에 입번할 자와 출번할 자를 거느리고 제사장 여호야다에게 나아오매","reference":"열왕기하 11:9","category":"$undefined"},{"id":"9840","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":10,"text":"제사장이 여호와의 전에 있는 다윗왕의 창과 방패를 백부장들에게 주니","reference":"열왕기하 11:10","category":"$undefined"},{"id":"9841","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":11,"text":"호위병이 각각 손에 병기를 잡고 왕을 호위하되 전 우편에서부터 전 좌편까지 단과 전 곁에 서고","reference":"열왕기하 11:11","category":"$undefined"},{"id":"9842","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":12,"text":"여호야다가 왕자를 인도하여 내어 면류관을 씌우며 율법 책을 주고 기름을 부어 왕을 삼으매 무리가 박수하며 왕의 만세를 부르니라","reference":"열왕기하 11:12","category":"$undefined"},{"id":"9843","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":13,"text":"아달랴가 호위병과 백성의 소리를 듣고 여호와의 전에 들어가서 백성에게 이르러","reference":"열왕기하 11:13","category":"$undefined"},{"id":"9844","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":14,"text":"보매 왕이 규례대로 대 위에 섰고 장관들과 나팔수가 왕의 곁에 모셨으며 온 국민이 즐거워하여 나팔을 부는지라 아달랴가 옷을 찢으며 외치되 반역이로다 반역이로다 하매","reference":"열왕기하 11:14","category":"$undefined"},{"id":"9845","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":15,"text":"제사장 여호야다가 군대를 거느린 백부장들에게 명하여 가로되 반열 밖으로 몰아내라 무릇 저를 따르는 자는 칼로 죽이라 하니 제사장의 이 말은 여호와의 전에서는 저를 죽이지 말라 함이라","reference":"열왕기하 11:15","category":"$undefined"},{"id":"9846","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":16,"text":"이에 저의 길을 열어주매 저가 왕궁 말 다니는 길로 통과하다가 거기서 죽임을 당하였더라","reference":"열왕기하 11:16","category":"$undefined"},{"id":"9847","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":17,"text":"여호야다가 왕과 백성으로 여호와와 언약을 세워 여호와의 백성이 되게 하고 왕과 백성 사이에도 언약을 세우게 하매","reference":"열왕기하 11:17","category":"$undefined"},{"id":"9848","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":18,"text":"온 국민이 바알의 당으로 가서 그 당을 훼파하고 그 단들과 우상들을 깨뜨리고 그 단 앞에서 바알의 제사장 맛단을 죽이니라 제 사장이 관리들을 세워 여호와의 전을 수직하게 하고","reference":"열왕기하 11:18","category":"$undefined"},{"id":"9849","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":19,"text":"또 백부장들과 가리 사람과 호위병과 온 국민을 거느리고 왕을 인도하여 여호와의 전에서 내려와서 호위병의 문 길로 말미암아 왕궁에 이르매 저가 왕의 보좌에 앉으니","reference":"열왕기하 11:19","category":"$undefined"},{"id":"9850","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":20,"text":"온 국민이 즐거워하고 성중이 평온하더라 아달랴를 무리가 왕궁에서 칼로 죽였었더라","reference":"열왕기하 11:20","category":"$undefined"},{"id":"9851","book":"열왕기하","book_name":"열왕기하","chapter":11,"verse":21,"text":"요아스가 위에 나아갈 때에 나이 칠세였더라","reference":"열왕기하 11:21","category":"$undefined"}],"bookSlug":"2kings"}]
