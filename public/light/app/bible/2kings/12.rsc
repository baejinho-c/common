2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":12,"verses":[{"id":"9852","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":1,"text":"예후의 칠년에 요아스가 위에 올라 예루살렘에서 사십년을 치리하니라 그 모친의 이름은 시비아라 브엘세바 사람이더라","reference":"열왕기하 12:1","category":"$undefined"},{"id":"9853","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":2,"text":"요아스가 제사장 여호야다의 교훈을 받을 동안에 여호와 보시기에 정직히 행하였으되","reference":"열왕기하 12:2","category":"$undefined"},{"id":"9854","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":3,"text":"오직 산당을 제하지 아니하였으므로 백성이 오히려 산당에서 제사하며 분향하였더라","reference":"열왕기하 12:3","category":"$undefined"},{"id":"9855","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":4,"text":"요아스가 제사장들에게 이르되 무릇 여호와의 전에 거룩하게 하여 드리는 은 곧 사람의 통용하는 은이나 각 사람의 몸값으로 드리는 은이나 자원하여 여호와의 전에 드리는 모든 은을","reference":"열왕기하 12:4","category":"$undefined"},{"id":"9856","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":5,"text":"제사장들이 각각 아는 자에게서 받아 들여서 전의 어느 곳이든지 퇴락한 것을 보거든 그것으로 수리하라 하였더니","reference":"열왕기하 12:5","category":"$undefined"},{"id":"9857","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":6,"text":"요아스왕 이십 삼년에 이르도록 제사장들이 오히려 전의 퇴락한데를 수리하지 아니하였는지라","reference":"열왕기하 12:6","category":"$undefined"},{"id":"9858","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":7,"text":"요아스왕이 대제사장 여호야다와 제사장들을 불러서 이르되 너희가 어찌하여 전의 퇴락한 데를 수리하지 아니하였느냐 이제부터는 너희 아는 사람에게서 은을 받지 말고 저희로 전 퇴락한 데를 위하여 드리게 하라","reference":"열왕기하 12:7","category":"$undefined"},{"id":"9859","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":8,"text":"제사장들이 다시는 백성에게 은을 받지도 아니하고 전 퇴락한 것을 수리하지도 아니하기로 응락하니라","reference":"열왕기하 12:8","category":"$undefined"},{"id":"9860","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":9,"text":"제사장 여호야다가 한 궤를 취하여 그 뚜껑에 구멍을 뚫어 여호와의 전문 어귀 우편 곧 단 옆에 두매 무릇 여호와의 전에 가져 오는 은을 다 문을 지키는 제사장들이 그 궤에 넣더라","reference":"열왕기하 12:9","category":"$undefined"},{"id":"9861","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":10,"text":"이에 그 궤 가운데 은이 많은 것을 보면 왕의 서기와 대제사장 이 올라와서 여호와의 전에 있는대로 그 은을 계수하여 봉하고","reference":"열왕기하 12:10","category":"$undefined"},{"id":"9862","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":11,"text":"그 달아본 은을 일하는 자 곧 여호와의 전을 맡은 자의 손에 붙이면 저희는 또 여호와의 전을 수리하는 목수와 건축하는 자들에게 주고","reference":"열왕기하 12:11","category":"$undefined"},{"id":"9863","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":12,"text":"또 미장이와 석수에게 주고 또 여호와의 전 퇴락한 데를 수리할 재목과 다듬은 돌을 사게 하며 그 전을 수리할 모든 물건을 위하여 쓰게 하였으되","reference":"열왕기하 12:12","category":"$undefined"},{"id":"9864","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":13,"text":"여호와의 전에 드린 그 은으로 그 전의 은대접이나 불집게나 주발이나 나팔이나 아무 금그릇이나 은그릇을 만들지 아니하고","reference":"열왕기하 12:13","category":"$undefined"},{"id":"9865","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":14,"text":"오직 그 은을 일하는 자에게 주어 그것으로 여호와의 전을 수리하게 하였으며","reference":"열왕기하 12:14","category":"$undefined"},{"id":"9866","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":15,"text":"또 그 은을 받아 일군에게 주는 사람들과 회계하지 아니하였으니 이는 성실히 일을 하였음이라","reference":"열왕기하 12:15","category":"$undefined"},{"id":"9867","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":16,"text":"속건제의 은과 속죄제의 은은 여호와의 전에 드리지 아니하고 제사장에게 돌렸더라","reference":"열왕기하 12:16","category":"$undefined"},{"id":"9868","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":17,"text":"때에 아람 왕 하사엘이 올라와서 가드를 쳐서 취하고 예루살렘을 향하여 올라오고자 한고로","reference":"열왕기하 12:17","category":"$undefined"},{"id":"9869","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":18,"text":"유다 왕 요아스가 그 열조 유다 왕 여호사밧과 여호람과 아하시야가 구별하여 드린 모든 성물과 자기가 구별하여 드린 성물과 여호와의 전 곳간과 왕궁에 있는 금을 다 취하여 아람 왕 하사엘에게 보내었더니 하사엘이 예루살렘에서 떠나갔더라","reference":"열왕기하 12:18","category":"$undefined"},{"id":"9870","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":19,"text":"요아스의 남은 사적과 그 모든 행한 것은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 12:19","category":"$undefined"},{"id":"9871","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":20,"text":"요아스의 신복들이 일어나서 모반하여 실라로 내려가는 길 가의 밀로궁에서 저를 죽였고","reference":"열왕기하 12:20","category":"$undefined"},{"id":"9872","book":"열왕기하","book_name":"열왕기하","chapter":12,"verse":21,"text":"저를 쳐서 죽인 신복은 시므앗의 아들 요사갈과 소멜의 아들 여호사바드이었더라 저는 다윗 성에 그 열조와 함께 장사되고 그 아들 아마샤가 대신하여 왕이 되니라","reference":"열왕기하 12:21","category":"$undefined"}],"bookSlug":"2kings"}]
