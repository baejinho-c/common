2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":13,"verses":[{"id":"9873","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":1,"text":"유다 왕 아하시야의 아들 요아스의 이십 삼년에 예후의 아들 여호아하스가 사마리아에서 이스라엘 왕이 되어 십 칠년을 치리하며","reference":"열왕기하 13:1","category":"$undefined"},{"id":"9874","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":2,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄를 좇고 떠나지 아니하였으므로","reference":"열왕기하 13:2","category":"$undefined"},{"id":"9875","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":3,"text":"여호와께서 이스라엘을 향하여 노를 발하사 늘 아람 왕 하사엘의 손과 그 아들 벤하닷의 손에 붙이셨더니","reference":"열왕기하 13:3","category":"$undefined"},{"id":"9876","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":4,"text":"아람 왕이 이스라엘을 학대하므로 여호아하스가 여호와께 간구하매 여호와께서 들으셨으니 이는 저희의 학대 받음을 보셨음이라","reference":"열왕기하 13:4","category":"$undefined"},{"id":"9877","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":5,"text":"여호와께서 이에 구원자를 이스라엘에게 주시매 이스라엘 자손이 아람 사람의 손에서 벗어나 전과 같이 자기 장막에 거하였으나","reference":"열왕기하 13:5","category":"$undefined"},{"id":"9878","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":6,"text":"저희가 이스라엘로 범죄케 한 여로보암 집의 죄에서 떠나지 아니하고 좇아 행하며 또 사마리아에 아세라 목상을 그저 두었더라","reference":"열왕기하 13:6","category":"$undefined"},{"id":"9879","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":7,"text":"아람 왕이 여호아하스의 백성을 진멸하여 타작마당의 티끌같이 되게 하고 마병 오십과 병거 십승과 보병 일만 외에는 여호아하스에게 남겨두지 아니하였더라","reference":"열왕기하 13:7","category":"$undefined"},{"id":"9880","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":8,"text":"여호아하스의 남은 사적과 모든 행한 것과 그 권력은 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 13:8","category":"$undefined"},{"id":"9881","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":9,"text":"여호아하스가 그 열조와 함께 자매 사마리아에 장사되고 그 아들 요아스가 대신하여 왕이 되니라","reference":"열왕기하 13:9","category":"$undefined"},{"id":"9882","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":10,"text":"유다 왕 요아스의 삼십 칠년에 여호아하스의 아들 요아스가 사마리아에서 이스라엘 왕이 되어 십륙년을 치리하며","reference":"열왕기하 13:10","category":"$undefined"},{"id":"9883","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":11,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 모든 죄에서 떠나지 아니하고 좇아 행하였더라","reference":"열왕기하 13:11","category":"$undefined"},{"id":"9884","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":12,"text":"요아스의 남은 사적과 무릇 행한 일과 유다 왕 아마샤와 싸운 권력은 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 13:12","category":"$undefined"},{"id":"9885","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":13,"text":"요아스가 그 열조와 함께 자매 이스라엘 왕들과 함께 사마리아에 장사되고 여로보암이 그 위에 앉으니라","reference":"열왕기하 13:13","category":"$undefined"},{"id":"9886","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":14,"text":"엘리사가 죽을 병이 들매 이스라엘 왕 요아스가 저에게로 내려가서 그 얼굴에 눈물을 흘리며 가로되 `내 아버지여 내 아버지여 이스라엘의 병거와 마병이여' 하매","reference":"열왕기하 13:14","category":"$undefined"},{"id":"9887","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":15,"text":"엘리사가 저에게 이르되 `활과 살들을 취하소서' 활과 살들을 취하매","reference":"열왕기하 13:15","category":"$undefined"},{"id":"9888","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":16,"text":"또 이스라엘 왕에게 이르되 `왕의 손으로 활을 잡으소서' 곧 손으로 잡으매 엘리사가 자기 손으로 왕의 손을 안찰하고","reference":"열왕기하 13:16","category":"$undefined"},{"id":"9889","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":17,"text":"가로되 `동편 창을 여소서' 곧 열매 엘리사가 가로되 `쏘소서' 곧 쏘매 엘리사가 가로되 이는 여호와의 구원의 살 곧 아람에 대한 구원의 살이니 왕이 아람 사람을 진멸하도록 아벡에서 치리이다","reference":"열왕기하 13:17","category":"$undefined"},{"id":"9890","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":18,"text":"또 가로되 `살들을 취하소서' 곧 취하매 엘리사가 또 이스라엘 왕에게 이르되 `땅을 치소서' 이에 세번 치고 그친지라","reference":"열왕기하 13:18","category":"$undefined"},{"id":"9891","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":19,"text":"하나님의 사람이 노하여 가로되 `왕이 오륙번을 칠 것이니이다 그리하였더면 왕이 아람을 진멸하도록 쳤으리이다 그런즉 이제는 왕이 아람을 세번만 치리이다' 하니라","reference":"열왕기하 13:19","category":"$undefined"},{"id":"9892","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":20,"text":"엘리사가 죽으매 장사하였더니 해가 바뀌매 모압 적당이 지경을 범한지라","reference":"열왕기하 13:20","category":"$undefined"},{"id":"9893","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":21,"text":"마침 사람을 장사하는 자들이 그 적당을 보고 그 시체를 엘리사의 묘실에 들이던지매 시체가 엘리사의 뼈에 닿자 곧 회생하여 일어섰더라","reference":"열왕기하 13:21","category":"$undefined"},{"id":"9894","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":22,"text":"여호아하스 왕의 시대에 아람왕 하사엘이 항상 이스라엘을 학대하였으나","reference":"열왕기하 13:22","category":"$undefined"},{"id":"9895","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":23,"text":"여호와께서 아브라함과 이삭과 야곱으로 더불어 세우신 언약을 인하여 이스라엘에게 은혜를 베풀어 긍휼히 여기시며 권고하사 멸하기를 즐겨 아니하시고 이때까지 자기 앞에서 쫓아내지 아니하셨더라","reference":"열왕기하 13:23","category":"$undefined"},{"id":"9896","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":24,"text":"아람 왕 하사엘이 죽고 그 아들 벤하닷이 대신하여 왕이 되매","reference":"열왕기하 13:24","category":"$undefined"},{"id":"9897","book":"열왕기하","book_name":"열왕기하","chapter":13,"verse":25,"text":"여호아하스의 아들 요아스가 하사엘의 아들 벤하닷의 손에서 두어 성읍을 회복하였으니 이 성읍들은 자기 부친 여호아하스가 전쟁 중에 빼앗겼던 것이라 요아스가 벤하닷을 세번 쳐서 파하고 이스라엘 성읍들을 회복하였더라","reference":"열왕기하 13:25","category":"$undefined"}],"bookSlug":"2kings"}]
