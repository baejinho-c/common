2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":14,"verses":[{"id":"9898","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":1,"text":"이스라엘 왕 여호아하스의 아들 요아스 이년에 유다 왕 요아스의 아들 아마샤가 왕이 되니","reference":"열왕기하 14:1","category":"$undefined"},{"id":"9899","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":2,"text":"위에 나아갈 때에 나이 이십오세라 예루살렘에서 이십 구년을 치리하니라 그 모친의 이름은 여호앗단이라 예루살렘 사람이더라","reference":"열왕기하 14:2","category":"$undefined"},{"id":"9900","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":3,"text":"아마샤가 여호와 보시기에 정직히 행하였으나 그 조상 다윗과는 같지 아니하였으며 그 부친 요아스의 행한 대로 다 행하였어도","reference":"열왕기하 14:3","category":"$undefined"},{"id":"9901","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":4,"text":"산당을 제하지 아니하였으므로 백성이 오히려 산당에서 제사를 드리며 분향하였더라","reference":"열왕기하 14:4","category":"$undefined"},{"id":"9902","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":5,"text":"나라가 그 손에 굳게 서매 그 부왕을 죽인 신복들을 죽였으나","reference":"열왕기하 14:5","category":"$undefined"},{"id":"9903","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":6,"text":"왕을 죽인 자의 자녀들은 죽이지 아니하였으니 이는 모세의 율법책에 기록된 대로 함이라 곧 여호와께서 명하여 이르시기를 자녀로 인하여 아비를 죽이지 말 것이요 아비로 인하여 자녀를 죽이지 말 것이라 오직 사람마다 자기의 죄로 인하여 죽을 것이니라 하셨더라","reference":"열왕기하 14:6","category":"$undefined"},{"id":"9904","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":7,"text":"아마샤가 염곡에서 에돔 사람 일만을 죽이고 또 셀라를 쳐서 취하고 이름을 욕드엘이라 하였더니 오늘까지 그러하니라","reference":"열왕기하 14:7","category":"$undefined"},{"id":"9905","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":8,"text":"아마샤가 예후의 손자 여호아하스의 아들 이스라엘 왕 요아스에게 사자를 보내어 이르되 오라 우리가 서로 대면하자 한지라","reference":"열왕기하 14:8","category":"$undefined"},{"id":"9906","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":9,"text":"이스라엘 왕 요아스가 유다 왕 아마샤에게 보내어 이르되 레바논 가시나무가 레바논 백향목에게 보내어 이르기를 네 딸을 내 아들들에게 주어 아내를 삼게 하라 하였더니 레바논 들짐승이 지나가다가 그 가시나무를 짓밟았느니라","reference":"열왕기하 14:9","category":"$undefined"},{"id":"9907","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":10,"text":"네가 에돔을 쳐서 파하였으므로 마음이 교만하였으니 스스로 영광을 삼아 궁에나 거하라 어찌하여 화를 자취하여 너와 유다가 함께 망하고자 하느냐 하나","reference":"열왕기하 14:10","category":"$undefined"},{"id":"9908","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":11,"text":"아마샤가 듣지 아니하므로 이스라엘 왕 요아스가 올라와서 유다 왕 아마샤로 더불어 유다의 벧세메스에서 대면하였더니","reference":"열왕기하 14:11","category":"$undefined"},{"id":"9909","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":12,"text":"유다가 이스라엘 앞에서 패하여 각기 장막으로 도망한지라","reference":"열왕기하 14:12","category":"$undefined"},{"id":"9910","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":13,"text":"이스라엘 왕 요아스가 벧세메스에서 아하시야의 손자 요아스의 아들 유다 왕 아마샤를 사로잡고 예루살렘에 이르러 예루살렘 성벽을 에브라임 문에서부터 성 모퉁이 문까지 사백 규빗을 헐고","reference":"열왕기하 14:13","category":"$undefined"},{"id":"9911","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":14,"text":"또 여호와의 전과 왕궁 곳간에 있는 금은과 모든 기명을 취하고 또 사람을 볼모로 잡아가지고 사마리아로 돌아갔더라","reference":"열왕기하 14:14","category":"$undefined"},{"id":"9912","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":15,"text":"요아스의 남은 사적과 그 권력과 또 유다 왕 아마샤와 서로 싸운 일은 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 14:15","category":"$undefined"},{"id":"9913","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":16,"text":"요아스가 그 열조와 함께 자매 이스라엘 왕들과 사마리아에 함께 장사되고 그 아들 여로보암이 대신하여 왕이 되니라","reference":"열왕기하 14:16","category":"$undefined"},{"id":"9914","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":17,"text":"이스라엘 왕 여호아하스의 아들 요아스가 죽은 후에도 유다 왕 요아스의 아들 아마샤가 십 오년을 생존하였더라","reference":"열왕기하 14:17","category":"$undefined"},{"id":"9915","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":18,"text":"아마샤의 남은 행적은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 14:18","category":"$undefined"},{"id":"9916","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":19,"text":"예루살렘에서 무리가 저를 모반한고로 저가 라기스로 도망하였더니 모반한 무리가 사람을 라기스로 따라 보내어 저를 거기서 죽이게 하고","reference":"열왕기하 14:19","category":"$undefined"},{"id":"9917","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":20,"text":"그 시체를 말에 실어다가 예루살렘에서 그 열조와 함께 다윗성에 장사하니라","reference":"열왕기하 14:20","category":"$undefined"},{"id":"9918","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":21,"text":"유다 온 백성이 아사랴로 그 부친 아마샤를 대신하여 왕을 삼으니 때에 나이 십 륙세라","reference":"열왕기하 14:21","category":"$undefined"},{"id":"9919","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":22,"text":"아마샤가 그 열조와 함께 잔 후에 아사랴가 엘랏을 건축하여 유다에 돌렸더라","reference":"열왕기하 14:22","category":"$undefined"},{"id":"9920","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":23,"text":"유다 왕 요아스의 아들 아마샤 십 오년에 이스라엘 왕 요아스의 아들 여로보암이 사마리아에서 왕이 되어 사십 일년을 위에 있으며","reference":"열왕기하 14:23","category":"$undefined"},{"id":"9921","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":24,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 모든 죄에서 떠나지 아니하였더라","reference":"열왕기하 14:24","category":"$undefined"},{"id":"9922","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":25,"text":"이스라엘 하나님 여호와께서 그 종 가드헤벨 아밋대의 아들 선지자 요나로 하신 말씀과 같이 여로보암이 이스라엘 지경을 회복하되 하맛 어귀에서부터 아라바 바다까지 하였으니","reference":"열왕기하 14:25","category":"$undefined"},{"id":"9923","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":26,"text":"이는 여호와께서 이스라엘의 고난이 심하여 매인 자도 없고 놓인 자도 없고 이스라엘을 도울 자도 없음을 보셨고","reference":"열왕기하 14:26","category":"$undefined"},{"id":"9924","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":27,"text":"여호와께서 또 이스라엘의 이름을 도말하여 천하에 없이 하겠다고도 아니하셨으므로 요아스의 아들 여로보암의 손으로 구원하심이었더라","reference":"열왕기하 14:27","category":"$undefined"},{"id":"9925","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":28,"text":"여로보암의 남은 사적과 모든 행한 일과 그 권력으로 싸운 일과 다메섹을 회복한 일과 이전에 유다에 속하였던 하맛을 이스라엘에 돌린 일은 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 14:28","category":"$undefined"},{"id":"9926","book":"열왕기하","book_name":"열왕기하","chapter":14,"verse":29,"text":"여로보암이 그 열조 이스라엘 왕들과 함께 자고 그 아들 스가랴가 대신하여 왕이 되니라","reference":"열왕기하 14:29","category":"$undefined"}],"bookSlug":"2kings"}]
