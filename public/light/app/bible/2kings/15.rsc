2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":15,"verses":[{"id":"9927","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":1,"text":"이스라엘 왕 여로보암 이십 칠년에 유다 왕 아마샤의 아들 아사랴가 왕이 되니","reference":"열왕기하 15:1","category":"$undefined"},{"id":"9928","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":2,"text":"위에 나아갈 때에 나이 십 륙세라 예루살렘에서 오십 이년을 치리하니라 그 모친의 이름은 여골리야라 예루살렘 사람이더라","reference":"열왕기하 15:2","category":"$undefined"},{"id":"9929","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":3,"text":"아사랴가 그 부친 아마샤의 모든 행위대로 여호와 보시기에 정직히 행하였으나","reference":"열왕기하 15:3","category":"$undefined"},{"id":"9930","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":4,"text":"오직 산당은 제하지 아니하였으므로 백성이 오히려 그 산당에서 제사를 드리며 분향하였고","reference":"열왕기하 15:4","category":"$undefined"},{"id":"9931","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":5,"text":"여호와께서 왕을 치셨으므로 그 죽는 날까지 문둥이가 되어 별궁에 거하고 왕자 요담이 궁중 일을 다스리며 국민을 치리하였더라","reference":"열왕기하 15:5","category":"$undefined"},{"id":"9932","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":6,"text":"아사랴의 남은 사적과 모든 행한 일은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 15:6","category":"$undefined"},{"id":"9933","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":7,"text":"아사랴가 그 열조와 함께 자매 다윗성에 그 열조와 함께 장사되고 그 아들 요담이 대신하여 왕이 되니라","reference":"열왕기하 15:7","category":"$undefined"},{"id":"9934","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":8,"text":"유다 왕 아사랴의 삼십 팔년에 여로보암의 아들 스가랴가 사마리아에서 이스라엘 왕이 되어 여섯달을 치리하며","reference":"열왕기하 15:8","category":"$undefined"},{"id":"9935","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":9,"text":"그 열조의 행위대로 여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄에서 떠나지 아니한지라","reference":"열왕기하 15:9","category":"$undefined"},{"id":"9936","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":10,"text":"야베스의 아들 살룸이 저를 모반하여 백성앞에서 쳐 죽이고 대신하여 왕이 되니라","reference":"열왕기하 15:10","category":"$undefined"},{"id":"9937","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":11,"text":"스가랴의 남은 사적은 이스라엘 왕 역대지략에 기록되니라","reference":"열왕기하 15:11","category":"$undefined"},{"id":"9938","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":12,"text":"여호와께서 예후에게 말씀하여 이르시기를 네 자손이 이스라엘 위를 이어 사대까지 이르리라 하신 그 말씀대로 과연 그렇게 되니라","reference":"열왕기하 15:12","category":"$undefined"},{"id":"9939","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":13,"text":"유다 왕 웃시야 삼십 구년에 야베스의 아들 살룸이 사마리아에서 왕이 되어 한 달을 치리하니라","reference":"열왕기하 15:13","category":"$undefined"},{"id":"9940","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":14,"text":"가디의 아들 므나헴이 디르사에서부터 사마리아로 올라가서 야베스의 아들 살룸을 거기서 죽이고 대신하여 왕이 되니라","reference":"열왕기하 15:14","category":"$undefined"},{"id":"9941","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":15,"text":"살룸의 남은 사적과 그 모반한 일은 이스라엘 왕 역대지략에 기록되니라","reference":"열왕기하 15:15","category":"$undefined"},{"id":"9942","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":16,"text":"그 때에 므나헴이 디르사에서 와서 딥사와 그 가운데 있는 모든 사람과 그 사방을 쳤으니 이는 저희가 성문을 열지 아니하였음이라 그러므로 치고 그 가운데 아이 밴 부녀를 갈랐더라","reference":"열왕기하 15:16","category":"$undefined"},{"id":"9943","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":17,"text":"유다 왕 아사랴 삼십 구년에 가디의 아들 므나헴이 이스라엘 왕이 되어 사마리아에서 십년을 치리하며","reference":"열왕기하 15:17","category":"$undefined"},{"id":"9944","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":18,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄에서 평생 떠나지 아니하였더라","reference":"열왕기하 15:18","category":"$undefined"},{"id":"9945","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":19,"text":"앗수르 왕 불이 와서 그 땅을 치려 하매 므나헴이 은 일천 달란트를 불에게 주어서 저로 자기를 도와 주게 함으로 나라를 자기 손에 굳게 세우고자 하여","reference":"열왕기하 15:19","category":"$undefined"},{"id":"9946","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":20,"text":"그 은을 이스라엘 모든 큰 부자에게서 토색하여 각 사람에게 은 오십 세겔씩 내게 하여 앗수르 왕에게 주었더니 이에 앗수르 왕이 돌이키고 그 땅에 머물지 아니하였더라","reference":"열왕기하 15:20","category":"$undefined"},{"id":"9947","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":21,"text":"므나헴의 남은 사적과 그 모든 행한 일은 이스라엘 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 15:21","category":"$undefined"},{"id":"9948","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":22,"text":"므나헴이 그 열조와 함께 자고 그 아들 브가히야가 대신하여 왕이 되니라","reference":"열왕기하 15:22","category":"$undefined"},{"id":"9949","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":23,"text":"유다 왕 아사랴 오십년에 므나헴의 아들 브가히야가 사마리아에서 이스라엘 왕이 되어 이년을 치리하며","reference":"열왕기하 15:23","category":"$undefined"},{"id":"9950","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":24,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄에서 떠나지 아니한지라","reference":"열왕기하 15:24","category":"$undefined"},{"id":"9951","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":25,"text":"그 장관 르말랴의 아들 베가가 반역하여 사마리아 왕궁 호위소에서 왕과 아르곱과 아리에를 죽이되 길르앗 사람 오십명으로 더불어 죽이고 대신하여 왕이 되었더라","reference":"열왕기하 15:25","category":"$undefined"},{"id":"9952","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":26,"text":"브가히야의 남은 사적과 그 모든 행한 일은 이스라엘 왕 역대지략에 기록되니라","reference":"열왕기하 15:26","category":"$undefined"},{"id":"9953","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":27,"text":"유다 왕 아사랴 오십 이년에 르말랴의 아들 베가가 이스라엘 왕이 되어 사마리아에서 이십년을 치리하며","reference":"열왕기하 15:27","category":"$undefined"},{"id":"9954","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":28,"text":"여호와 보시기에 악을 행하여 이스라엘로 범죄케 한 느밧의 아들 여로보암의 죄에서 떠나지 아니하였더라","reference":"열왕기하 15:28","category":"$undefined"},{"id":"9955","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":29,"text":"이스라엘 왕 베가 때에 앗수르 왕 디글랏 빌레셀이 와서 이욘과 아벨벳마아가와 야노아와 게데스와 하솔과 길르앗과 갈릴리와 납달리 온 땅을 취하고 그 백성을 사로잡아 앗수르로 옮겼더라","reference":"열왕기하 15:29","category":"$undefined"},{"id":"9956","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":30,"text":"웃시야의 아들 요담 이십년에 엘라의 아들 호세아가 반역하여 르말랴의 아들 베가를 쳐서 죽이고 대신하여 왕이 되니라","reference":"열왕기하 15:30","category":"$undefined"},{"id":"9957","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":31,"text":"베가의 남은 사적과 그 모든 행한 일은 이스라엘 왕 역대지략에 기록되니라","reference":"열왕기하 15:31","category":"$undefined"},{"id":"9958","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":32,"text":"이스라엘 왕 르말랴의 아들 베가 이년에 유다 왕 웃시야의 아들 요담이 왕이 되니","reference":"열왕기하 15:32","category":"$undefined"},{"id":"9959","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":33,"text":"위에 나아갈 때에 나이 이십 오세라 예루살렘에서 십 륙년을 치리하니라 그 모친의 이름은 여루사라 사독의 딸이더라","reference":"열왕기하 15:33","category":"$undefined"},{"id":"9960","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":34,"text":"요담이 그 부친 웃시야의 모든 행위대로 여호와 보시기에 정직히 행하였으나","reference":"열왕기하 15:34","category":"$undefined"},{"id":"9961","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":35,"text":"오직 산당을 제하지 아니하였으므로 백성이 오히려 그 산당에서 제사를 드리며 분향하였더라 요담이 여호와의 전의 윗문을 건축 하니라","reference":"열왕기하 15:35","category":"$undefined"},{"id":"9962","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":36,"text":"요담의 남은 사적과 그 모든 행한 일은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 15:36","category":"$undefined"},{"id":"9963","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":37,"text":"그 때에 여호와께서 비로소 아람 왕 르신과 르말랴의 아들 베가를 보내어 유다를 치게 하셨더라","reference":"열왕기하 15:37","category":"$undefined"},{"id":"9964","book":"열왕기하","book_name":"열왕기하","chapter":15,"verse":38,"text":"요담이 그 열조와 함께 자매 그 조상 다윗성에 열조와 함께 장사되고 그 아들 아하스가 대신하여 왕이 되니라","reference":"열왕기하 15:38","category":"$undefined"}],"bookSlug":"2kings"}]
