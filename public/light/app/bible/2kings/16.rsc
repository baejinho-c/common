2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":16,"verses":[{"id":"9965","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":1,"text":"르말랴의 아들 베가 십 칠년에 유다 왕 요담의 아들 아하스가 왕이 되니","reference":"열왕기하 16:1","category":"$undefined"},{"id":"9966","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":2,"text":"아하스가 위에 나아갈 때에 나이 이십세라 예루살렘에서 십 륙년을 치리하였으나 그 조상 다윗과 같지 아니하여 그 하나님 여호와 보시기에 정직히 행치 아니하고","reference":"열왕기하 16:2","category":"$undefined"},{"id":"9967","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":3,"text":"이스라엘 열왕의 길로 행하며 또 여호와께서 이스라엘 자손 앞에서 쫓아내신 이방 사람의 가증한 일을 본받아 자기 아들을 불 가운데로 지나가게 하며","reference":"열왕기하 16:3","category":"$undefined"},{"id":"9968","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":4,"text":"또 산당과 작은 산 위와 모든 푸른 나무 아래서 제사를 드리며 분향하였더라","reference":"열왕기하 16:4","category":"$undefined"},{"id":"9969","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":5,"text":"이 때에 아람 왕 르신과 이스라엘 왕 르말랴의 아들 베가가 예루살렘에 올라와서 싸우려 하여 아하스를 에워쌌으나 이기지 못하 니라","reference":"열왕기하 16:5","category":"$undefined"},{"id":"9970","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":6,"text":"당시에 아람 왕 르신이 엘랏을 회복하여 아람에 돌리고 유다 사람을 엘랏에서 쫓아내었고 아람 사람이 엘랏에 이르러 거하여 오늘날까지 이르렀더라","reference":"열왕기하 16:6","category":"$undefined"},{"id":"9971","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":7,"text":"아하스가 앗수르 왕 디글랏 빌레셀에게 사자를 보내어 이르되 나는 왕의 신복이요 왕의 아들이라 이제 아람 왕과 이스라엘 왕이 나를 치니 청컨대 올라와서 나를 그 손에서 구원하소서 하고","reference":"열왕기하 16:7","category":"$undefined"},{"id":"9972","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":8,"text":"여호와의 전과 왕궁 곳간에 있는 은금을 취하여 앗수르 왕에게 예물로 보내었더니","reference":"열왕기하 16:8","category":"$undefined"},{"id":"9973","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":9,"text":"앗수르 왕이 그 청을 듣고 곧 올라와서 다메섹을 쳐서 취하여 그 백성을 사로잡아 길로 옮기고 또 르신을 죽였더라","reference":"열왕기하 16:9","category":"$undefined"},{"id":"9974","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":10,"text":"아하스왕이 앗수르 왕 디글랏 빌레셀을 만나러 다메섹에 갔다가 거기 있는 단을 보고 드디어 그 구조와 제도의 식양을 그려 제사장 우리야에게 보내었더니","reference":"열왕기하 16:10","category":"$undefined"},{"id":"9975","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":11,"text":"아하스왕이 다메섹에서 돌아오기 전에 제사장 우리야가 아하스왕이 다메섹에서 보낸 모든 것대로 단을 만든지라","reference":"열왕기하 16:11","category":"$undefined"},{"id":"9976","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":12,"text":"왕이 다메섹에서 돌아와서 단을 보고 단 앞에 나아가 그 위에 제사를 드리되","reference":"열왕기하 16:12","category":"$undefined"},{"id":"9977","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":13,"text":"자기의 번제와 소제를 불사르고 또 전제를 붓고 수은제 짐승의 피를 단에 뿌리고","reference":"열왕기하 16:13","category":"$undefined"},{"id":"9978","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":14,"text":"또 여호와의 앞 곧 전 앞에 있던 놋단을 옮기되 새 단과 여호와의 전 사이에서 옮겨다가 그 단 북편에 두니라","reference":"열왕기하 16:14","category":"$undefined"},{"id":"9979","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":15,"text":"아하스 왕이 제사장 우리야에게 명하여 가로되 `아침 번제와 저녁소제와 왕의 번제와 그 소제와 모든 국민의 번제와 그 소제와 전제를 다 이 큰 단 위에 불사르고 또 번제물의 피와 다른 제물의 피를 다 그 위에 뿌리고 오직 놋단은 나의 물을 일에 쓰게 하라' 하매","reference":"열왕기하 16:15","category":"$undefined"},{"id":"9980","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":16,"text":"제사장 우리야가 아하스 왕의 모든 명대로 행하였더라","reference":"열왕기하 16:16","category":"$undefined"},{"id":"9981","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":17,"text":"아하스 왕이 물두멍 받침의 옆판을 떼어내고 물두멍을 그 자리에서 옮기고 또 놋바다를 놋소 위에서 내려다가 돌판 위에 두며","reference":"열왕기하 16:17","category":"$undefined"},{"id":"9982","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":18,"text":"또 안식일에 쓰기 위하여 성전에 건축한 낭실과 왕이 밖에서 들어가는 낭실을 앗수르 왕을 인하여 여호와의 전에 옮겨 세웠더라","reference":"열왕기하 16:18","category":"$undefined"},{"id":"9983","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":19,"text":"아하스의 그 남은 사적은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 16:19","category":"$undefined"},{"id":"9984","book":"열왕기하","book_name":"열왕기하","chapter":16,"verse":20,"text":"아하스가 그 열조와 함께 자매 다윗성에 그 열조와 함께 장사되고 그 아들 히스기야가 대신하여 왕이 되니라","reference":"열왕기하 16:20","category":"$undefined"}],"bookSlug":"2kings"}]
