2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":17,"verses":[{"id":"9985","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":1,"text":"유다 왕 아하스 십 이년에 엘라의 아들 호세아가 사마리아에서 이스라엘 왕이 되어 구년을 치리하며","reference":"열왕기하 17:1","category":"$undefined"},{"id":"9986","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":2,"text":"여호와 보시기에 악을 행하였으나 그전 이스라엘 여러 왕들과 같이 하지는 아니하였더라","reference":"열왕기하 17:2","category":"$undefined"},{"id":"9987","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":3,"text":"앗수르 왕 살만에셀이 올라와서 호세아를 친고로 호세아가 신복하여 조공을 드리더니","reference":"열왕기하 17:3","category":"$undefined"},{"id":"9988","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":4,"text":"저가 애굽 왕 소에게 사자들을 보내고 해마다 하던대로 앗수르 왕에게 조공을 드리지 아니하매 앗수르 왕이 호세아의 배반함을 보고 저를 옥에 금고하여 두고","reference":"열왕기하 17:4","category":"$undefined"},{"id":"9989","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":5,"text":"올라와서 그 온 땅에 두루 다니고 사마리아로 올라와서 삼년을 에워쌌더라","reference":"열왕기하 17:5","category":"$undefined"},{"id":"9990","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":6,"text":"호세아 구년에 앗수르 왕이 사마리아를 취하고 이스라엘 사람을 사로잡아 앗수르로 끌어다가 할라와 고산 하볼 하숫가와 메대 사람의 여러 고을에 두었더라","reference":"열왕기하 17:6","category":"$undefined"},{"id":"9991","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":7,"text":"이 일은 이스라엘 자손이 자기를 애굽에서 인도하여 내사 애굽 왕 바로의 손에서 벗어나게 하신 그 하나님 여호와께 죄를 범하고 또 다른 신들을 경외하며","reference":"열왕기하 17:7","category":"$undefined"},{"id":"9992","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":8,"text":"여호와께서 이스라엘 자손 앞에서 쫓아내신 이방 사람의 규례와 이스라엘 여러 왕의 세운 율례를 행하였음이라","reference":"열왕기하 17:8","category":"$undefined"},{"id":"9993","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":9,"text":"이스라엘 자손이 가만히 불의를 행하여 그 하나님 여호와를 배역하여 모든 성읍에 망대로부터 견고한 성에 이르도록 산당을 세우고","reference":"열왕기하 17:9","category":"$undefined"},{"id":"9994","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":10,"text":"모든 산 위에와 모든 푸른 나무 아래에 목상과 아세라상을 세우고","reference":"열왕기하 17:10","category":"$undefined"},{"id":"9995","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":11,"text":"또 여호와께서 저희 앞에서 물리치신 이방 사람같이 그곳 모든 산당에서 분향하며 또 악을 행하여 여호와를 격노케 하였으며","reference":"열왕기하 17:11","category":"$undefined"},{"id":"9996","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":12,"text":"또 우상을 섬겼으니 이는 여호와께서 행치 말라 명하신 일이라","reference":"열왕기하 17:12","category":"$undefined"},{"id":"9997","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":13,"text":"여호와께서 각 선지자와 각 선견자로 이스라엘과 유다를 경계하여 이르시기를 너희는 돌이켜 너희 악한 길에서 떠나 나의 명령과 율례를 지키되 내가 너희 열조에게 명하고 또 나의 종 선지자들로 너희에게 전한 모든 율법대로 행하라 하셨으나","reference":"열왕기하 17:13","category":"$undefined"},{"id":"9998","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":14,"text":"저희가 듣지 아니하고 그 목을 굳게 하기를 그 하나님 여호와를 믿지 아니하던 저희 열조의 목 같이 하여","reference":"열왕기하 17:14","category":"$undefined"},{"id":"9999","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":15,"text":"여호와의 율례와 여호와께서 그 열조로 더불어 세우신 언약과 경계하신 말씀을 버리고 허무한 것을 좇아 허망하며 또 여호와께 서명하사 본받지 말라 하신 사면 이방 사람을 본받아","reference":"열왕기하 17:15","category":"$undefined"},{"id":"10000","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":16,"text":"그 하나님 여호와의 모든 명령을 버리고 자기를 위하여 두 송아지 형상을 부어 만들고 또 아세라 목상을 만들고 하늘의 일월 성신을 숭배하며 또 바알을 섬기고","reference":"열왕기하 17:16","category":"$undefined"},{"id":"10001","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":17,"text":"또 자기 자녀를 불 가운데로 지나가게 하며 복술과 사술을 행하고 스스로 팔려 여호와 보시기에 악을 행하여 그 노를 격발케 하였으므로","reference":"열왕기하 17:17","category":"$undefined"},{"id":"10002","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":18,"text":"여호와께서 이스라엘을 심히 노하사 그 앞에서 제하시니 유다 지파 외에는 남은 자가 없으니라","reference":"열왕기하 17:18","category":"$undefined"},{"id":"10003","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":19,"text":"유다도 그 하나님 여호와의 명령을 지키지 아니하고 이스라엘 사람의 세운 율례를 행하였으므로","reference":"열왕기하 17:19","category":"$undefined"},{"id":"10004","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":20,"text":"여호와께서 이스라엘의 온 족속을 버리사 괴롭게 하시며 노략군의 손에 붙이시고 심지어 그 앞에서 쫓아내시니라","reference":"열왕기하 17:20","category":"$undefined"},{"id":"10005","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":21,"text":"이스라엘을 다윗의 집에서 찢어 나누시매 저희가 느밧의 아들 여로보암으로 왕을 삼았더니 여로보암이 이스라엘을 몰아 여호와를 떠나고 큰 죄를 범하게 하매","reference":"열왕기하 17:21","category":"$undefined"},{"id":"10006","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":22,"text":"이스라엘 자손이 여로보암의 행한 모든 죄를 따라 행하여 떠나지 아니하므로","reference":"열왕기하 17:22","category":"$undefined"},{"id":"10007","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":23,"text":"여호와께서 그 종 모든 선지자로 하신 말씀대로 심지어 이스라엘을 그 앞에서 제하신지라 이스라엘이 고향에서 앗수르에 사로잡혀 가서 오늘까지 미쳤더라","reference":"열왕기하 17:23","category":"$undefined"},{"id":"10008","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":24,"text":"앗수르 왕이 바벨론과 구다와 아와와 하맛과 스발와임에서 사람을 옮겨다가 이스라엘 자손을 대신하여 사마리아 여러 성읍에 두매 저희가 사마리아를 차지하여 그 여러 성읍에 거하니라","reference":"열왕기하 17:24","category":"$undefined"},{"id":"10009","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":25,"text":"저희가 처음으로 거기 거할 때에 여호와를 경외치 아니한고로 여호와께서 사자들을 그 가운데 보내시매 몇 사람을 죽인지라","reference":"열왕기하 17:25","category":"$undefined"},{"id":"10010","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":26,"text":"그러므로 혹이 앗수르 왕에게 고하여 가로되 왕께서 사마리아 여러 성읍에 옮겨 거하게 하신 열방 사람이 그 땅 신의 법을 알지 못하므로 그 신이 사자들을 저희 가운데 보내매 저희를 죽였사오니 이는 저희가 그 땅 신의 법을 알지 못함이니이다","reference":"열왕기하 17:26","category":"$undefined"},{"id":"10011","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":27,"text":"앗수르 왕이 명하여 가로되 너희는 그곳에서 사로잡아 온 제사장 하나를 그곳으로 데려가되 저로 그 곳에 가서 거하며 그 땅 신의 법으로 무리에게 가르치게 하라","reference":"열왕기하 17:27","category":"$undefined"},{"id":"10012","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":28,"text":"이에 사마리아에서 사로잡혀 간 제사장 중 하나가 와서 벧엘에 거하며 백성에게 어떻게 여호와 경외할 것을 가르쳤더라","reference":"열왕기하 17:28","category":"$undefined"},{"id":"10013","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":29,"text":"그러나 각 민족이 각기 자기의 신상들을 만들어 사마리아 사람의 지은 여러 산당에 두되 각 민족이 자기의 거한 성읍에서 그렇게 하여","reference":"열왕기하 17:29","category":"$undefined"},{"id":"10014","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":30,"text":"바벨론 사람들은 숙곳브놋을 만들었고 굿 사람들은 네르갈을 만들었고 하맛 사람들은 아시마를 만들었고","reference":"열왕기하 17:30","category":"$undefined"},{"id":"10015","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":31,"text":"아와 사람들은 닙하스와 다르닥을 만들었고 스발와임 사람들은 그 자녀를 불살라 그 신 아드람멜렉과 아남멜렉에게 드렸으며","reference":"열왕기하 17:31","category":"$undefined"},{"id":"10016","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":32,"text":"저희가 또 여호와를 경외하여 자기 중에서 사람을 산당의 제사장으로 택하여 그 산당에서 자기를 위하여 제사를 드리게 하니라","reference":"열왕기하 17:32","category":"$undefined"},{"id":"10017","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":33,"text":"이와 같이 저희가 여호와도 경외하고 또한 어디서부터 옮겨왔든지 그 민족의 풍속대로 자기의 신들도 섬겼더라","reference":"열왕기하 17:33","category":"$undefined"},{"id":"10018","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":34,"text":"저희가 오늘까지 이전 풍속대로 행하여 여호와를 경외치 아니하며 또 여호와께서 이스라엘이라 이름을 주신 야곱의 자손에게 명하신 율례와 법도와 율법과 계명을 준행치 아니하는도다","reference":"열왕기하 17:34","category":"$undefined"},{"id":"10019","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":35,"text":"옛적에 여호와께서 야곱의 자손에게 언약을 세우시고 저희에게 명하여 가라사대 너희는 다른 신을 경외하지 말며 그를 숭배하지말며 그를 섬기지 말며 그에게 제사하지 말고","reference":"열왕기하 17:35","category":"$undefined"},{"id":"10020","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":36,"text":"오직 큰 능력과 편 팔로 너희를 애굽에서 인도하여 낸 여호와만 너희가 경외하여 그를 숭배하며 그에게 제사를 드릴 것이며","reference":"열왕기하 17:36","category":"$undefined"},{"id":"10021","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":37,"text":"또 여호와가 너희를 위하여 기록한 율례와 법도와 율법과 계명을 너희가 지켜 영원히 행하고 다른 신들을 경외치 말며","reference":"열왕기하 17:37","category":"$undefined"},{"id":"10022","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":38,"text":"또 내가 너희와 세운 언약을 잊지 말며 다른 신들을 경외치 말고","reference":"열왕기하 17:38","category":"$undefined"},{"id":"10023","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":39,"text":"오직 너희 하나님 여호와를 경외하라 그가 너희를 모든 원수의 손에서 건져내리라 하셨으나","reference":"열왕기하 17:39","category":"$undefined"},{"id":"10024","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":40,"text":"그러나 저희가 듣지 아니하고 오히려 이전 풍속대로 행하였느니라","reference":"열왕기하 17:40","category":"$undefined"},{"id":"10025","book":"열왕기하","book_name":"열왕기하","chapter":17,"verse":41,"text":"그 여러 민족이 여호와를 경외하고 또 그 아로새긴 우상을 섬기더니 그 자자 손손이 그 열조의 행한 것을 좇아 오늘까지 그대로 하니라","reference":"열왕기하 17:41","category":"$undefined"}],"bookSlug":"2kings"}]
