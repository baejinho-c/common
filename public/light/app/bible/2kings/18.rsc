2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":18,"verses":[{"id":"10026","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":1,"text":"이스라엘 왕 엘라의 아들 호세아 삼년에 유다 왕 아하스의 아들 히스기야가 왕이 되니","reference":"열왕기하 18:1","category":"$undefined"},{"id":"10027","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":2,"text":"위에 나아갈 때에 나이 이십 오세라 예루살렘에서 이십 구년을 치리하니라 그 모친의 이름은 아비라 스가리야의 딸이더라","reference":"열왕기하 18:2","category":"$undefined"},{"id":"10028","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":3,"text":"히스기야가 그 조상 다윗의 모든 행위와 같이 여호와 보시기에 정직히 행하여","reference":"열왕기하 18:3","category":"$undefined"},{"id":"10029","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":4,"text":"여러 산당을 제하며 주상을 깨뜨리며 아세라 목상을 찍으며 모세가 만들었던 놋뱀을 이스라엘 자손이 이때까지 향하여 분향하므로 그것을 부수고 느후스단이라 일컬었더라","reference":"열왕기하 18:4","category":"$undefined"},{"id":"10030","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":5,"text":"히스기야가 이스라엘 하나님 여호와를 의지하였는데 그의 전후 유다 여러 왕 중에 그러한 자가 없었으니","reference":"열왕기하 18:5","category":"$undefined"},{"id":"10031","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":6,"text":"곧 저가 여호와께 연합하여 떠나지 아니하고 여호와께서 모세에게 명하신 계명을 지켰더라","reference":"열왕기하 18:6","category":"$undefined"},{"id":"10032","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":7,"text":"여호와께서 저와 함께 하시매 저가 어디로 가든지 형통하였더라 저가 앗수르 왕을 배척하고 섬기지 아니하였고","reference":"열왕기하 18:7","category":"$undefined"},{"id":"10033","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":8,"text":"블레셋 사람을 쳐서 가사와 그 사방에 이르고 망대에서부터 견고한 성까지 이르렀더라","reference":"열왕기하 18:8","category":"$undefined"},{"id":"10034","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":9,"text":"히스기야 왕 사년 곧 이스라엘 왕 엘라의 아들 호세아 칠년에 앗수르 왕 살만에셀이 사마리아로 올라와서 에워쌌더라","reference":"열왕기하 18:9","category":"$undefined"},{"id":"10035","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":10,"text":"삼년후에 그 성이 함락되니 곧 히스기야의 육년이요 이스라엘 왕 호세아의 구년이라 사마리아가 함락되매","reference":"열왕기하 18:10","category":"$undefined"},{"id":"10036","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":11,"text":"앗수르 왕이 이스라엘을 사로잡아 앗수르에 이르러 할라와 고산하볼 하숫가와 메대 사람의 여러 성읍에 두었으니","reference":"열왕기하 18:11","category":"$undefined"},{"id":"10037","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":12,"text":"이는 저희가 그 하나님 여호와의 말씀을 준행치 아니하고 그 언약을 배반하고 여호와의 종 모세의 모든 명한 것을 거스려 듣지도 아니하며 행치도 아니하였음이더라","reference":"열왕기하 18:12","category":"$undefined"},{"id":"10038","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":13,"text":"히스기야 왕 십 사년에 앗수르 왕 산헤립이 올라와서 유다 모든 견고한 성읍들을 쳐서 취하매","reference":"열왕기하 18:13","category":"$undefined"},{"id":"10039","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":14,"text":"유다 왕 히스기야가 라기스로 보내어 앗수르 왕에게 이르되 내가 범죄하였나이다 나를 떠나 돌아가소서 왕이 내게 지우시는 것을 내가 당하리이다 하였더니 앗수르 왕이 곧 은 삼백 달란트와 금 삼십 달란트를 정하여 유다 왕 히스기야로 내게 한지라","reference":"열왕기하 18:14","category":"$undefined"},{"id":"10040","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":15,"text":"히스기야가 이에 여호와의 전과 왕궁 곳간에 있는 은을 다 주었고","reference":"열왕기하 18:15","category":"$undefined"},{"id":"10041","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":16,"text":"또 그때에 유다 왕 히스기야가 여호와의 전 문의 금과 자기가 모든 기둥에 입힌 금을 벗겨 모두 앗수르 왕에게 주었더라","reference":"열왕기하 18:16","category":"$undefined"},{"id":"10042","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":17,"text":"앗수르 왕이 다르단과 랍사리스와 랍사게로 대군을 거느리고 라기스에서부터 예루살렘으로 가서 히스기야 왕을 치게 하매 저희가 예루살렘으로 올라가니라 저희가 올라가서 윗못 수도 곁 곧 세 탁자의 밭에 있는 큰 길에 이르러 서니라","reference":"열왕기하 18:17","category":"$undefined"},{"id":"10043","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":18,"text":"저희가 왕을 부르매 힐기야의 아들 궁내대신 엘리야김과 서기관 셉나와 아삽의 아들 사관 요아가 저에게 나가니","reference":"열왕기하 18:18","category":"$undefined"},{"id":"10044","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":19,"text":"랍사게가 저희에게 이르되 너희는 히스기야에게 고하라 대왕 앗수르 왕의 말씀이 너의 의뢰하는 이 의뢰가 무엇이냐","reference":"열왕기하 18:19","category":"$undefined"},{"id":"10045","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":20,"text":"네가 싸울만한 계교와 용력이 있다고 한다마는 이는 입에 붙은 말 뿐이라 네가 이제 누구를 의뢰하고 나를 반역하였느냐","reference":"열왕기하 18:20","category":"$undefined"},{"id":"10046","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":21,"text":"이제 네가 저 상한 갈대 지팡이 애굽을 의뢰하도다 사람이 그것을 의지하면 그 손에 찔려 들어갈지라 애굽 왕 바로는 무릇 의뢰하는 자에게 이와 같으니라","reference":"열왕기하 18:21","category":"$undefined"},{"id":"10047","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":22,"text":"너희가 혹시 내게 이르기를 우리는 우리 하나님 여호와를 의뢰하노라 하리라마는 히스기야가 여호와의 산당과 제단을 제하고 유다와 예루살렘 사람에게 명하기를 예루살렘 이 단 앞에서만 숭배하라 하지 아니하였느냐 하셨나니","reference":"열왕기하 18:22","category":"$undefined"},{"id":"10048","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":23,"text":"이제 너는 내 주 앗수르 왕과 내기하라 네가 만일 그 말 탈 사람을 낼 수 있다면 나는 네게 말 이천 필을 주리라","reference":"열왕기하 18:23","category":"$undefined"},{"id":"10049","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":24,"text":"네가 어찌 내 주의 신복 중 지극히 작은 장관 하나인들 물리치며 애굽을 의뢰하고 그 병거와 기병을 얻을듯하냐","reference":"열왕기하 18:24","category":"$undefined"},{"id":"10050","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":25,"text":"내가 어찌 여호와의 뜻이 아니고야 이제 이곳을 멸하러 올라왔겠느냐 여호와께서 전에 내게 이르시기를 이 땅으로 올라와서 쳐서 멸하라 하셨느니라","reference":"열왕기하 18:25","category":"$undefined"},{"id":"10051","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":26,"text":"힐기야의 아들 엘리야김과 셉나와 요아가 랍사게에게 이르되 우리가 알아듣겠사오니 청컨대 아람 방언으로 당신의 종들에게 말씀하시고 성 위에 있는 백성의 듣는데 유다 방언으로 우리에게 말씀하지 마옵소서","reference":"열왕기하 18:26","category":"$undefined"},{"id":"10052","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":27,"text":"랍사게가 저에게 이르되 내 주께서 네 주와 네게만 이 말을 하라고 나를 보내신 것이냐 성 위에 앉은 사람들로도 너희와 함께 자기의 대변을 먹게 하고 자기의 소변을 마시게 하신 것이 아니냐 하고","reference":"열왕기하 18:27","category":"$undefined"},{"id":"10053","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":28,"text":"랍사게가 드디어 일어서서 유다 방언으로 크게 소리질러 불러 가로되 너희는 대왕 앗수르 왕의 말씀을 들으라","reference":"열왕기하 18:28","category":"$undefined"},{"id":"10054","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":29,"text":"왕의 말씀이 너희는 히스기야에게 속지 말라 저가 너희를 내 손에서 건져내지 못하리라","reference":"열왕기하 18:29","category":"$undefined"},{"id":"10055","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":30,"text":"또한 히스기야가 너희로 여호와를 의뢰하라 함을 듣지 말라 저가 이르기를 여호와께서 정녕 우리를 건지실지라 이 성이 앗수르 왕의 손에 함락되지 않게 하시리라 할지라도","reference":"열왕기하 18:30","category":"$undefined"},{"id":"10056","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":31,"text":"너희는 히스기야의 말을 듣지 말라 앗수르 왕의 말씀이 너희는 내게 항복하고 내게로 나아오라 그리하고 너희는 각각 그 포도와 무화과를 먹고 또한 각각 자기의 우물의 물을 마시라","reference":"열왕기하 18:31","category":"$undefined"},{"id":"10057","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":32,"text":"내가 장차 와서 너희를 한 지방으로 옮기리니 그곳은 너희 본토와 같은 지방 곧 곡식과 포도주가 있는 지방이요 떡과 포도원이 있는 지방이요 기름나는 감람과 꿀이 있는 지방이라 너희가 살고 죽지 아니하리라 히스기야가 너희를 면려하여 이르기를 여호와께서 우리를 건지시리라 하여도 듣지 말라","reference":"열왕기하 18:32","category":"$undefined"},{"id":"10058","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":33,"text":"열국의 신들 중에 그 땅을 앗수르 왕의 손에서 건진 자가 있느냐","reference":"열왕기하 18:33","category":"$undefined"},{"id":"10059","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":34,"text":"하맛과 아르밧의 신들이 어디 있으며 스발와임과 헤나와 아와의 신들이 어디 있느냐 그들이 사마리아를 내 손에서 건졌느냐","reference":"열왕기하 18:34","category":"$undefined"},{"id":"10060","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":35,"text":"열국의 모든 신중에 누가 그 땅을 내 손에서 건졌기에 여호와가 예루살렘을 내 손에서 능히 건지겠느냐 하셨느니라","reference":"열왕기하 18:35","category":"$undefined"},{"id":"10061","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":36,"text":"그러나 백성이 잠잠하고 한 말도 대답지 아니하니 이는 왕이 명하여 대답하지 말라 하였음이라","reference":"열왕기하 18:36","category":"$undefined"},{"id":"10062","book":"열왕기하","book_name":"열왕기하","chapter":18,"verse":37,"text":"이에 힐기야의 아들 궁내대신 엘리야김과 서기관 셉나와 아삽의 아들 사관 요아가 그 옷을 찢고 히스기야에게 나아가서 랍사게의 말을 고하니라","reference":"열왕기하 18:37","category":"$undefined"}],"bookSlug":"2kings"}]
