2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":19,"verses":[{"id":"10063","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":1,"text":"히스기야왕이 듣고 그 옷을 찢고 굵은 베를 입고 여호와의 전에 들어가서","reference":"열왕기하 19:1","category":"$undefined"},{"id":"10064","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":2,"text":"궁내대신 엘리야김과 서기관 셉나와 제사장 중 장로들에게 굵은 베를 입혀서 아모스의 아들 선지자 이사야에게로 보내매","reference":"열왕기하 19:2","category":"$undefined"},{"id":"10065","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":3,"text":"저희가 이사야에게 이르되 히스기야의 말씀이 오늘은 곤란과 책벌과 능욕의 날이라 아이가 임산하였으나 해산할 힘이 없도다","reference":"열왕기하 19:3","category":"$undefined"},{"id":"10066","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":4,"text":"랍사게가 그 주 앗수르 왕의 보냄을 받고 와서 사신 하나님을 훼방하였으니 당신의 하나님 여호와께서 혹시 저의 말을 들으셨을지라 당신의 하나님 여호와께서 그 들으신 말을 인하여 꾸짖으실듯하니 당신은 이 남아 있는 자를 위하여 기도하소서 하더이다","reference":"열왕기하 19:4","category":"$undefined"},{"id":"10067","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":5,"text":"이와 같이 히스기야 왕의 신복이 이사야에게 나아가니","reference":"열왕기하 19:5","category":"$undefined"},{"id":"10068","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":6,"text":"이사야가 저희에게 이르되 너희는 너희 주에게 이렇게 고하라 여호와의 말씀이 너는 앗수르 왕의 신복에게 들은바 나를 능욕하는 말을 인하여 두려워하지 말라","reference":"열왕기하 19:6","category":"$undefined"},{"id":"10069","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":7,"text":"내가 한 영을 저의 속에 두어 저로 풍문을 듣고 그 본국으로 돌아가게 하고 또 그 본국에서 저로 칼에 죽게 하리라 하셨느니라","reference":"열왕기하 19:7","category":"$undefined"},{"id":"10070","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":8,"text":"랍사게가 돌아가다가 앗수르 왕이 이미 라기스에서 떠났다 함을 듣고 립나로 가서 왕을 만났으니 왕이 거기서 싸우는 중이더라","reference":"열왕기하 19:8","category":"$undefined"},{"id":"10071","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":9,"text":"앗수르 왕이 구스 왕 디르하가가 나와서 더불어 싸우고자 한다 함을 듣고 다시 히스기야에게 사자를 보내며 가로되","reference":"열왕기하 19:9","category":"$undefined"},{"id":"10072","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":10,"text":"너희는 유다 왕 히스기야에게 이같이 말하여 이르기를 너의 의뢰하는 네 하나님이 예루살렘을 앗수르 왕의 손에 붙이지 않겠다 하는 말에 속지 말라","reference":"열왕기하 19:10","category":"$undefined"},{"id":"10073","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":11,"text":"앗수르의 열왕이 열방에 행한바 진멸한 일을 네가 들었나니 네가 어찌 구원을 얻겠느냐","reference":"열왕기하 19:11","category":"$undefined"},{"id":"10074","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":12,"text":"내 열조가 멸하신 열방 곧 고산과 하란과 레셉과 들라살에 있는 에덴 족속을 그 나라의 신들이 건졌느냐","reference":"열왕기하 19:12","category":"$undefined"},{"id":"10075","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":13,"text":"하맛 왕과 아르밧 왕과 스발와임성의 왕과 헤나와 아와의 왕들이다 어디 있느냐 하라 하니라","reference":"열왕기하 19:13","category":"$undefined"},{"id":"10076","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":14,"text":"히스기야가 사자의 손에서 편지를 받아보고 여호와의 전에 올라가서 그 편지를 여호와 앞에 펴놓고","reference":"열왕기하 19:14","category":"$undefined"},{"id":"10077","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":15,"text":"그 앞에서 기도하여 가로되 그룹들의 위에 계신 이스라엘 하나님 여호와여 주는 천하 만국에 홀로 하나님이시라 주께서 천지를 조성하셨나이다","reference":"열왕기하 19:15","category":"$undefined"},{"id":"10078","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":16,"text":"여호와여 귀를 기울여 들으소서 여호와여 눈을 떠서 보시옵소서 산헤립이 사신 하나님을 훼방하러 보낸 말을 들으시옵소서","reference":"열왕기하 19:16","category":"$undefined"},{"id":"10079","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":17,"text":"여호와여 앗수르 열왕이 과연 열방과 그 땅을 황폐케 하고","reference":"열왕기하 19:17","category":"$undefined"},{"id":"10080","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":18,"text":"또 그 신들을 불에 던졌사오니 이는 저희가 신이 아니요 사람의 손으로 지은 것 곧 나무와 돌 뿐이므로 멸하였나이다","reference":"열왕기하 19:18","category":"$undefined"},{"id":"10081","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":19,"text":"우리 하나님 여호와여 원컨대 이제 우리를 그 손에서 구원하옵소서 그리하시면 천하 만국이 주 여호와는 홀로 하나님이신줄 알리이다 하니라","reference":"열왕기하 19:19","category":"$undefined"},{"id":"10082","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":20,"text":"아모스의 아들 이사야가 히스기야에게 기별하여 가로되 이스라엘 하나님 여호와의 말씀이 네가 앗수르 왕 산헤립 까닭에 내게 기도하는 것을 내가 들었노라 하셨나이다","reference":"열왕기하 19:20","category":"$undefined"},{"id":"10083","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":21,"text":"여호와께서 앗수르 왕에게 대하여 이같이 말씀하시기를 처녀 딸 시온이 너를 멸시하며 너를 비웃었으며 딸 예루살렘이 너를 향하여 머리를 흔들었느니라","reference":"열왕기하 19:21","category":"$undefined"},{"id":"10084","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":22,"text":"네가 누구를 꾸짖었으며 훼방하였느냐 누구를 향하여 소리를 높였으며 눈을 높이 떴느냐 이스라엘의 거룩한 자에게 그리하였도다","reference":"열왕기하 19:22","category":"$undefined"},{"id":"10085","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":23,"text":"네가 사자로 주를 훼방하여 이르기를 내가 많은 병거를 거느리고 여러 산꼭대기에 올라가며 레바논 깊은 곳에 이르러 높은 백향목과 아름다운 잣나무를 베고 내가 그 지경 끝에 들어가며 그 동산의 무성한 수풀에 이르리라","reference":"열왕기하 19:23","category":"$undefined"},{"id":"10086","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":24,"text":"내가 땅을 파서 이방의 물을 마셨고 나의 발바닥으로 애굽의 모든 하수를 말렸노라 하였도다","reference":"열왕기하 19:24","category":"$undefined"},{"id":"10087","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":25,"text":"네가 듣지 못하였느냐 이 일은 내가 태초부터 행하였고 상고부터 정한 바라 이제 내가 이루어 너로 견고한 성들을 멸하여 돌무더기가 되게 함이니라","reference":"열왕기하 19:25","category":"$undefined"},{"id":"10088","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":26,"text":"그러므로 그 거한 백성의 힘이 약하여 두려워하며 놀랐나니 저희는 마치 들의 풀 같고 나물 같고 지붕의 풀 같고 자라기 전에 마른 곡초같으니라","reference":"열왕기하 19:26","category":"$undefined"},{"id":"10089","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":27,"text":"네 거처와 네 출입과 네가 내게 향한 분노를 내가 다 아노니","reference":"열왕기하 19:27","category":"$undefined"},{"id":"10090","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":28,"text":"네가 내게 향한 분노와 네 교만한 말이 내 귀에 들렸도다 그러므로 내가 갈고리로 네 코에 꿰고 자갈을 네 입에 먹여 너를 오던 길로 끌어 돌이키리라 하셨나이다","reference":"열왕기하 19:28","category":"$undefined"},{"id":"10091","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":29,"text":"또 네게 보일 징조가 이러하니 너희가 금년에는 스스로 자라난 것을 먹고 명년에는 그것에서 난 것을 먹되 제 삼년에는 심고 거두며 포도원을 심고 그 열매를 먹으리라","reference":"열왕기하 19:29","category":"$undefined"},{"id":"10092","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":30,"text":"유다 족속의 피하고 남은 자는 다시 아래로 뿌리가 서리고 위로 열매를 맺을지라","reference":"열왕기하 19:30","category":"$undefined"},{"id":"10093","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":31,"text":"남은 자는 예루살렘에서부터 나올 것이요 피하는 자는 시온산에서부터 나오리니 여호와의 열심이 이 일을 이루리라 하셨나이다","reference":"열왕기하 19:31","category":"$undefined"},{"id":"10094","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":32,"text":"그러므로 여호와께서 앗수르 왕을 가리켜 이르시기를 저가 이 성에 이르지 못하며 이리로 살을 쏘지 못하며 방패를 성을 향하여 세우지 못하며 치려고 토성을 쌓지도 못하고","reference":"열왕기하 19:32","category":"$undefined"},{"id":"10095","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":33,"text":"오던 길로 돌아가고 이 성에 이르지 못하리라 하셨으니 이는 여호와의 말씀이시라","reference":"열왕기하 19:33","category":"$undefined"},{"id":"10096","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":34,"text":"내가 나와 나의 종 다윗을 위하여 이 성을 보호하여 구원하리라 하셨나이다 하였더라","reference":"열왕기하 19:34","category":"$undefined"},{"id":"10097","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":35,"text":"이 밤에 여호와의 사자가 나와서 앗수르 진에서 군사 십 팔만 오천을 친지라 아침에 일찌기 일어나 보니 다 송장이 되었더라","reference":"열왕기하 19:35","category":"$undefined"},{"id":"10098","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":36,"text":"앗수르 왕 산헤립이 떠나 돌아가서 니느웨에 거하더니","reference":"열왕기하 19:36","category":"$undefined"},{"id":"10099","book":"열왕기하","book_name":"열왕기하","chapter":19,"verse":37,"text":"그 신 니스록의 묘에 경배할 때에 아드람멜렉과 사레셀이 저를 칼로 쳐죽이고 아라랏 땅으로 도망하매 그 아들 에살핫돈이 대신하여 왕이 되니라","reference":"열왕기하 19:37","category":"$undefined"}],"bookSlug":"2kings"}]
