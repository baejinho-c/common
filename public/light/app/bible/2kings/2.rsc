2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":2,"verses":[{"id":"9553","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":1,"text":"여호와께서 회리바람으로 엘리야를 하늘에 올리고자 하실 때에 엘리야가 엘리사로 더불어 길갈에서 나가더니","reference":"열왕기하 2:1","category":"$undefined"},{"id":"9554","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":2,"text":"엘리야가 엘리사에게 이르되 `청컨대 너는 여기 머물라 여호와께서 나를 벧엘로 보내시느니라' 엘리사가 가로되 `여호와의 사심과 당신의 혼의 삶을 가리켜 맹세하노니 내가 당신을 떠나지 아니하겠나이다' 이에 두 사람이 벧엘로 내려가니","reference":"열왕기하 2:2","category":"$undefined"},{"id":"9555","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":3,"text":"벧엘에 있는 선지자의 생도들이 엘리사에게로 나아와 이르되 `여호와께서 오늘날 당신의 선생을 당신의 머리 위로 취하실 줄을 아나이까' 가로되 `나도 아노니 너희는 잠잠하라'","reference":"열왕기하 2:3","category":"$undefined"},{"id":"9556","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":4,"text":"엘리야가 저에게 이르되 `엘리사야 청컨대 너는 여기 머물라 여호와께서 나를 여리고로 보내시느니라' 엘리사가 가로되 `여호와의 사심과 당신의 혼의 삶을 가리켜 맹세하노니 내가 당신을 떠나지아니하겠나이다' 하니라 저희가 여리고에 이르매","reference":"열왕기하 2:4","category":"$undefined"},{"id":"9557","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":5,"text":"여리고에 있는 선지자의 생도들이 엘리사에게 나아와 이르되 `여호와께서 오늘날 당신의 선생을 당신의 머리 위로 취하실 줄을 아나이까' 엘리사가 가로되 `나도 아노니 너희는 잠잠하라'","reference":"열왕기하 2:5","category":"$undefined"},{"id":"9558","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":6,"text":"엘리야가 또 엘리사에게 이르되 `청컨대 너는 여기 머물라 여호와께서 나를 요단으로 보내시느니라' 저가 가로되 `여호와의 사심과 당신의 혼의 삶을 가리켜 맹세하노니 내가 당신을 떠나지 아니하겠나이다' 이에 두 사람이 행하니라","reference":"열왕기하 2:6","category":"$undefined"},{"id":"9559","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":7,"text":"선지자의 생도 오십인이 가서 멀리 서서 바라보매 그 두 사람이 요단가에 섰더니","reference":"열왕기하 2:7","category":"$undefined"},{"id":"9560","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":8,"text":"엘리야가 겉옷을 취하여 말아 물을 치매 물이 이리 저리 갈라지고 두 사람이 육지 위로 건너더라","reference":"열왕기하 2:8","category":"$undefined"},{"id":"9561","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":9,"text":"건너매 엘리야가 엘리사에게 이르되 `나를 네게서 취하시기 전에 내가 네게 어떻게 할 것을 구하라' 엘리사가 가로되 `당신의 영감이 갑절이나 내게 있기를 구하나이다'","reference":"열왕기하 2:9","category":"$undefined"},{"id":"9562","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":10,"text":"가로되 `네가 어려운 일을 구하는도다 그러나 나를 네게서 취하시는 것을 네가 보면 그 일이 네게 이루려니와 그렇지 않으면 이루지 아니하리라' 하고","reference":"열왕기하 2:10","category":"$undefined"},{"id":"9563","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":11,"text":"두 사람이 행하며 말하더니 홀연히 불수레와 불말들이 두 사람을 격하고 엘리야가 회리바람을 타고 승천하더라","reference":"열왕기하 2:11","category":"$undefined"},{"id":"9564","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":12,"text":"엘리사가 보고 소리 지르되 `내 아버지여 내 아버지여 이스라엘의 병거와 그 마병이여' 하더니 다시 보이지 아니하는지라 이에 엘리사가 자기의 옷을 잡아 둘에 찢고","reference":"열왕기하 2:12","category":"$undefined"},{"id":"9565","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":13,"text":"엘리야의 몸에서 떨어진 겉옷을 주워가지고 돌아와서 요단 언덕에 서서","reference":"열왕기하 2:13","category":"$undefined"},{"id":"9566","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":14,"text":"엘리야의 몸에서 떨어진 그 겉옷을 가지고 물을 치며 가로되 `엘리야의 하나님 여호와는 어디 계시니이까' 하고 저도 물을 치매 물이 이리 저리 갈라지고 엘리사가 건너니라","reference":"열왕기하 2:14","category":"$undefined"},{"id":"9567","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":15,"text":"맞은편 여리고에 있는 선지자의 생도들이 저를 보며 말하기를 `엘리야의 영감(靈感)이 엘리사의 위에 머물렀다' 하고 가서 저를 영접하여 그 앞에서 땅에 엎드리고","reference":"열왕기하 2:15","category":"$undefined"},{"id":"9568","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":16,"text":"가로되 `당신의 종들에게 용사 오십인이 있으니 청컨대 저희로 가서 당신의 주를 찾게 하소서 염려컨대 여호와의 신이 저를 들어 가다가 어느 산에나 어느 골짜기에 던지셨을까 하나이다' 엘리사가 가로되 `보내지 말라' 하나","reference":"열왕기하 2:16","category":"$undefined"},{"id":"9569","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":17,"text":"무리가 저로 부끄러워 하도록 강청하매 보내라 한지라 저희가 오십인을 보내었더니 사흘을 찾되 발견하지 못하고","reference":"열왕기하 2:17","category":"$undefined"},{"id":"9570","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":18,"text":"엘리사가 여리고에 머무는 중에 무리가 저에게 돌아오니 엘리사가 저희에게 이르되 `내가 가지 말라고 너희에게 이르지 아니하였느냐' 하였더라","reference":"열왕기하 2:18","category":"$undefined"},{"id":"9571","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":19,"text":"그 성 사람들이 엘리사에게 고하되 `우리 주께서 보시는 바와 같이 이 성읍의 터는 아름다우나 물이 좋지 못하므로 토산이 익지 못하고 떨어지나이다'","reference":"열왕기하 2:19","category":"$undefined"},{"id":"9572","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":20,"text":"엘리사가 가로되 `새 그릇에 소금을 담아 내게로 가져오라' 하매 곧 가져온지라","reference":"열왕기하 2:20","category":"$undefined"},{"id":"9573","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":21,"text":"엘리사가 물 근원으로 나아가서 소금을 그 가운데 던지며 가로되 `여호와의 말씀이 내가 이 물을 고쳤으니 이로 좇아 다시는 죽음이나 토산이 익지 못하고 떨어짐이 없을지니라 하셨느니라' 하니","reference":"열왕기하 2:21","category":"$undefined"},{"id":"9574","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":22,"text":"그 물이 엘리사의 말과 같이 고쳐져서 오늘날에 이르렀더라","reference":"열왕기하 2:22","category":"$undefined"},{"id":"9575","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":23,"text":"엘리사가 거기서 벧엘로 올라가더니 길에 행할 때에 젊은 아이들이 성에서 나와서 저를 조롱하여 가로되 `대머리여 올라가라 대머리여 올라가라' 하는지라","reference":"열왕기하 2:23","category":"$undefined"},{"id":"9576","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":24,"text":"엘리사가 돌이켜 저희를 보고 여호와의 이름으로 저주하매 곧 수풀에서 암콤 둘이 나와서 아이들 중에 사십 이명을 찢었더라","reference":"열왕기하 2:24","category":"$undefined"},{"id":"9577","book":"열왕기하","book_name":"열왕기하","chapter":2,"verse":25,"text":"엘리사가 거기서부터 갈멜산으로 가고 거기서 사마리아로 돌아왔더라","reference":"열왕기하 2:25","category":"$undefined"}],"bookSlug":"2kings"}]
