2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":20,"verses":[{"id":"10100","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":1,"text":"그 때에 히스기야가 병들어 죽게 되매 아모스의 아들 선지자 이사야가 저에게 나아와서 이르되 여호와의 말씀이 너는 집을 처치하라 네가 죽고 살지 못하리라 하셨나이다","reference":"열왕기하 20:1","category":"$undefined"},{"id":"10101","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":2,"text":"히스기야가 낯을 벽으로 향하고 여호와께 기도하여 가로되","reference":"열왕기하 20:2","category":"$undefined"},{"id":"10102","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":3,"text":"여호와여 구하오니 내가 진실과 전심으로 주 앞에 행하며 주의 보시기에 선하게 행한 것을 기억하옵소서 하고 심히 통곡하더라","reference":"열왕기하 20:3","category":"$undefined"},{"id":"10103","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":4,"text":"이사야가 성읍 가운데까지도 이르기 전에 여호와의 말씀이 저에게 임하여 가라사대","reference":"열왕기하 20:4","category":"$undefined"},{"id":"10104","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":5,"text":"너는 돌아가서 내 백성의 주권자 히스기야에게 이르기를 왕의 조상 다윗의 하나님 여호와의 말씀이 내가 네 기도를 들었고 네 눈물을 보았노라 내가 너를 낫게 하리니 네가 삼일만에 여호와의 전에 올라가겠고","reference":"열왕기하 20:5","category":"$undefined"},{"id":"10105","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":6,"text":"내가 네 날을 십 오년을 더할 것이며 내가 너와 이 성을 앗수르 왕의 손에서 구원하고 내가 나를 위하고 또 내 종 다윗을 위하므로 이 성을 보호하리라 하셨다 하라 하셨더라","reference":"열왕기하 20:6","category":"$undefined"},{"id":"10106","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":7,"text":"이사야가 가로되 무화과 반죽을 가져오라 하매 무리가 가져다가 그 종처에 놓으니 나으니라","reference":"열왕기하 20:7","category":"$undefined"},{"id":"10107","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":8,"text":"히스기야가 이사야에게 이르되 여호와께서 나를 낫게 하시고 삼일만에 여호와의 전에 올라가게 하실 무슨 징조가 있나이까","reference":"열왕기하 20:8","category":"$undefined"},{"id":"10108","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":9,"text":"이사야가 가로되 여호와의 하신 말씀을 응하게 하실 일에 대하여 여호와께로서 왕에게 한 징조가 임하리이다 해 그림자가 십도를 나아 갈것이니이까 혹 십도를 물러갈 것이니이까","reference":"열왕기하 20:9","category":"$undefined"},{"id":"10109","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":10,"text":"히스기야가 대답하되 그림자가 십도를 나아가기는 쉬우니 그리할 것이 아니라 십도가 물러갈 것이니이다","reference":"열왕기하 20:10","category":"$undefined"},{"id":"10110","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":11,"text":"선지자 이사야가 여호와께 간구하매 아하스의 일영표 위에 나아갔던 해 그림자로 십도를 물러가게 하셨더라","reference":"열왕기하 20:11","category":"$undefined"},{"id":"10111","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":12,"text":"그 때에 발라단의 아들 바벨론 왕 부로닥발라단이 히스기야가 병들었다 함을 듣고 편지와 예물을 저에게 보낸지라","reference":"열왕기하 20:12","category":"$undefined"},{"id":"10112","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":13,"text":"히스기야가 사자의 말을 듣고 자기 보물고의 금,은과 향품과 보배로운 기름과 그 군기고와 내탕고의 모든 것을 다 사자에게 보였는데 무릇 왕궁과 그 나라 안에 있는 것을 저에게 보이지 아니한 것이 없으니라","reference":"열왕기하 20:13","category":"$undefined"},{"id":"10113","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":14,"text":"선지자 이사야가 히스기야 왕에게 나아와서 이르되 이 사람들이 무슨 말을 하였으며 어디서부터 왕에게 왔나이까 히스기야가 가로되 먼 지방 바벨론에서 왔나이다","reference":"열왕기하 20:14","category":"$undefined"},{"id":"10114","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":15,"text":"이사야가 가로되 저희가 왕궁에서 무엇을 보았나이까 히스기야가 대답하되 내 궁에 있는 것을 저희가 다 보았나니 나의 내탕고에서 하나도 보이지 아니한 것이 없나이다","reference":"열왕기하 20:15","category":"$undefined"},{"id":"10115","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":16,"text":"이사야가 히스기야에게 이르되 여호와의 말씀을 들으소서","reference":"열왕기하 20:16","category":"$undefined"},{"id":"10116","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":17,"text":"여호와의 말씀이 날이 이르리니 무릇 왕궁의 모든 것과 왕의 열조가 오늘까지 쌓아 두었던 것을 바벨론으로 옮긴바 되고 하나도 남지 아니할 것이요","reference":"열왕기하 20:17","category":"$undefined"},{"id":"10117","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":18,"text":"또 왕의 몸에서 날 아들 중에서 사로잡혀 바벨론 왕궁의 환관이 되리라 하셨나이다","reference":"열왕기하 20:18","category":"$undefined"},{"id":"10118","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":19,"text":"히스기야가 이사야에게 이르되 당신의 전한바 여호와의 말씀이 선하니이다 하고 또 가로되 만일 나의 사는 날에 태평과 진실이 있을진대 어찌 선하지 아니하리요 하니라","reference":"열왕기하 20:19","category":"$undefined"},{"id":"10119","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":20,"text":"히스기야의 남은 사적과 그 모든 권력과 못과 수도를 만들어 물을 성중으로 인도하여 들인 일은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 20:20","category":"$undefined"},{"id":"10120","book":"열왕기하","book_name":"열왕기하","chapter":20,"verse":21,"text":"히스기야가 그 열조와 함께 자고 그 아들 므낫세가 대신하여 왕이 되니라","reference":"열왕기하 20:21","category":"$undefined"}],"bookSlug":"2kings"}]
