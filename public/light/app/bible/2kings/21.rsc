2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":21,"verses":[{"id":"10121","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":1,"text":"므낫세가 위에 나아갈 때에 나이 십이세라 예루살렘에서 오십 오년을 치리하니라 그 모친의 이름은 헵시바더라","reference":"열왕기하 21:1","category":"$undefined"},{"id":"10122","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":2,"text":"므낫세가 여호와 보시기에 악을 행하여 여호와께서 이스라엘 자손 앞에서 쫓아내신 이방 사람의 가증한 일을 본받아서","reference":"열왕기하 21:2","category":"$undefined"},{"id":"10123","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":3,"text":"그 부친 히스기야의 헐어버린 산당을 다시 세우며 이스라엘 왕 아합의 소위를 본받아 바알을 위하여 단을 쌓으며 아세라 목상을 만들며 하늘의 일월 성신을 숭배하여 섬기며","reference":"열왕기하 21:3","category":"$undefined"},{"id":"10124","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":4,"text":"여호와께서 전에 이르시기를 내가 내 이름을 예루살렘에 두리라 하신 여호와의 전의 단들을 쌓고","reference":"열왕기하 21:4","category":"$undefined"},{"id":"10125","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":5,"text":"또 여호와의 전 두 마당에 하늘의 일월 성신을 위하여 단들을 쌓고","reference":"열왕기하 21:5","category":"$undefined"},{"id":"10126","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":6,"text":"또 그 아들을 불 가운데로 지나게 하며 점치며 사술을 행하며 신접한 자와 박수를 신임하여 여호와 보시기에 악을 많이 행하여 그 진노를 격발하였으며","reference":"열왕기하 21:6","category":"$undefined"},{"id":"10127","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":7,"text":"또 자기가 만든 아로새긴 아세라 목상을 전에 세웠더라 옛적에 여호와께서 이 전에 대하여 다윗과 그 아들 솔로몬에게 이르시기를 내가 이스라엘 모든 지파중에서 택한 이 전과 예루살렘에 내 이름을 영원히 둘지라","reference":"열왕기하 21:7","category":"$undefined"},{"id":"10128","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":8,"text":"만일 이스라엘이 나의 모든 명령과 나의 종 모세의 명한 모든 율법을 지켜 행하면 내가 그들의 발로 다시는 그 열조에게 준 땅에서 떠나 유리하지 않게 하리라 하셨으나","reference":"열왕기하 21:8","category":"$undefined"},{"id":"10129","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":9,"text":"이 백성이 듣지 아니하였고 므낫세의 꾀임을 받고 악을 행한 것이 여호와께서 이스라엘 자손 앞에서 멸하신 열방보다 더욱 심하였더라","reference":"열왕기하 21:9","category":"$undefined"},{"id":"10130","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":10,"text":"여호와께서 그 종 모든 선지자들로 말씀하여 가라사대","reference":"열왕기하 21:10","category":"$undefined"},{"id":"10131","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":11,"text":"유다 왕 므낫세가 이 가증한 일과 악을 행함이 그 전에 있던 아모리 사람의 행위보다 더욱 심하였고 또 그 우상으로 유다를 범죄케 하였도다","reference":"열왕기하 21:11","category":"$undefined"},{"id":"10132","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":12,"text":"그러므로 이스라엘 하나님 여호와가 말하노니 내가 이제 예루살렘과 유다에 재앙을 내리리니 듣는 자마다 두 귀가 울리리라","reference":"열왕기하 21:12","category":"$undefined"},{"id":"10133","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":13,"text":"내가 사마리아를 잰 줄과 아합의 집을 다림보던 추로 예루살렘에 베풀고 또 사람이 그릇을 씻어 엎음 같이 예루살렘을 씻어 버릴지라","reference":"열왕기하 21:13","category":"$undefined"},{"id":"10134","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":14,"text":"내가 나의 기업에서 남은 자를 버려 그 대적의 손에 붙인즉 저희가 모든 대적에게 노략과 겁탈이 되리니","reference":"열왕기하 21:14","category":"$undefined"},{"id":"10135","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":15,"text":"이는 애굽에서 나온 그 열조 때부터 오늘까지 나의 보기에 악을 행하여 나의 노를 격발하였음이니라 하셨더라","reference":"열왕기하 21:15","category":"$undefined"},{"id":"10136","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":16,"text":"므낫세가 여호와 보시기에 악을 행하여 유다로 범하게한 그 죄외에 또 무죄한 자의 피를 심히 많이 흘려 예루살렘 이 가에서 저 가까지 가득하게 하였더라","reference":"열왕기하 21:16","category":"$undefined"},{"id":"10137","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":17,"text":"므낫세의 남은 사적과 무릇 그 행한바와 범한 죄는 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 21:17","category":"$undefined"},{"id":"10138","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":18,"text":"므낫세가 그 열조와 함께 자매 그 궁궐 동산 곧 웃사의 동산에 장사되고 그 아들 아몬이 대신하여 왕이 되니라","reference":"열왕기하 21:18","category":"$undefined"},{"id":"10139","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":19,"text":"아몬이 위에 나아갈 때에 나이 이십 이세라 예루살렘에서 이년을 치리하니라 그 모친의 이름은 므술레멧이라 욧바 하루스의 딸이더라","reference":"열왕기하 21:19","category":"$undefined"},{"id":"10140","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":20,"text":"아몬이 그 부친 므낫세의 행함 같이 여호와 보시기에 악을 행하되","reference":"열왕기하 21:20","category":"$undefined"},{"id":"10141","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":21,"text":"그 부친의 행한 모든 길로 행하여 그 부친의 섬기던 우상을 섬겨 경배하고","reference":"열왕기하 21:21","category":"$undefined"},{"id":"10142","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":22,"text":"그 열조의 하나님 여호와를 버리고 그 길로 행치 아니하더니","reference":"열왕기하 21:22","category":"$undefined"},{"id":"10143","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":23,"text":"그 신복들이 반역하여 왕을 궁중에서 죽이매","reference":"열왕기하 21:23","category":"$undefined"},{"id":"10144","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":24,"text":"그 국민이 아몬 왕을 반역한 사람들을 다 죽이고 그 아들 요시야로 대신하여 왕을 삼았더라","reference":"열왕기하 21:24","category":"$undefined"},{"id":"10145","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":25,"text":"아몬의 행한바 남은 사적은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 21:25","category":"$undefined"},{"id":"10146","book":"열왕기하","book_name":"열왕기하","chapter":21,"verse":26,"text":"아몬이 웃시야의 동산 자기 묘실에 장사되고 그 아들 요시야가 대신하여 왕이 되니라","reference":"열왕기하 21:26","category":"$undefined"}],"bookSlug":"2kings"}]
