2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":22,"verses":[{"id":"10147","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":1,"text":"요시야가 위에 나아갈 때에 나이 팔세라 예루살렘에서 삼십 일년을 치리하니라 그 모친의 이름은 여디다라 보스갓 아다야의 딸이더라","reference":"열왕기하 22:1","category":"$undefined"},{"id":"10148","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":2,"text":"요시야가 여호와 보시기에 정직히 행하여 그 조상 다윗의 모든 길로 행하고 좌우로 치우치지 아니하였더라","reference":"열왕기하 22:2","category":"$undefined"},{"id":"10149","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":3,"text":"요시야 왕 십 팔년에 왕이 므술람의 손자 아살리야의 아들 서기관 사반을 여호와의 전에 보내며 가로되","reference":"열왕기하 22:3","category":"$undefined"},{"id":"10150","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":4,"text":"너는 대제사장 힐기야에게 올라가서 백성이 여호와의 전에 드린은 곧 문 지킨 자가 수납한 은을 계수하여","reference":"열왕기하 22:4","category":"$undefined"},{"id":"10151","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":5,"text":"여호와의 전 역사 감독자의 손에 붙여 저희로 여호와의 전에 있는 공장에게 주어 전의 퇴락한 것을 수리하게 하되","reference":"열왕기하 22:5","category":"$undefined"},{"id":"10152","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":6,"text":"곧 목수와 건축자와 미장이에게 주게 하고 또 재목과 다듬은 돌을 사서 그 전을 수리하게 하라 하니라","reference":"열왕기하 22:6","category":"$undefined"},{"id":"10153","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":7,"text":"그러나 저희 손에 붙인 은을 회계하지 아니하였으니 이는 그 행하는 것이 진실함이었더라","reference":"열왕기하 22:7","category":"$undefined"},{"id":"10154","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":8,"text":"대제사장 힐기야가 서기관 사반에게 이르되 내가 여호와의 전에서 율법책을 발견하였노라 하고 그 책을 사반에게 주니 사반이 읽으니라","reference":"열왕기하 22:8","category":"$undefined"},{"id":"10155","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":9,"text":"서기관 사반이 왕에게 돌아가서 복명하여 가로되 왕의 신복들이 전에 있던 돈을 쏟아 여호와의 전 역사 감독자의 손에 붙였나이다 하고","reference":"열왕기하 22:9","category":"$undefined"},{"id":"10156","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":10,"text":"또 왕에게 고하여 가로되 제사장 힐기야가 내게 책을 주더이다 하고 왕의 앞에서 읽으매","reference":"열왕기하 22:10","category":"$undefined"},{"id":"10157","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":11,"text":"왕이 율법책의 말을 듣자 곧 그 옷을 찢으니라","reference":"열왕기하 22:11","category":"$undefined"},{"id":"10158","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":12,"text":"왕이 제사장 힐기야와 사반의 아들 아히감과 미가야의 아들 악볼과 서기관 사반과 왕의 시신 아사야에게 명하여 가로되","reference":"열왕기하 22:12","category":"$undefined"},{"id":"10159","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":13,"text":"너희는 가서 나와 백성과 온 유다를 위하여 이 발견한 책의 말씀에 대하여 여호와께 물으라 우리 열조가 이 책의 말씀을 듣지 아니하며 이 책에 우리를 위하여 기록된 모든 것을 준행치 아니하였으므로 여호와께서 우리에게 발하신 진노가 크도다","reference":"열왕기하 22:13","category":"$undefined"},{"id":"10160","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":14,"text":"이에 제사장 힐기야와 또 아히감과 악볼과 사반과 아사야가 여선지 훌다에게로 나아가니 저는 할하스의 손자 디과의 아들 예복을 주관하는 살룸의 아내라 예루살렘 둘째 구역에 거하였더라 저희가 더불어 말하매","reference":"열왕기하 22:14","category":"$undefined"},{"id":"10161","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":15,"text":"훌다가 저희에게 이르되 이스라엘 하나님 여호와의 말씀이 너희는 너희를 내게 보낸 사람에게 고하기를","reference":"열왕기하 22:15","category":"$undefined"},{"id":"10162","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":16,"text":"여호와의 말씀이 내가 이 곳과 그 거민에게 재앙을 내리되 곧 유다 왕의 읽은 책의 모든 말대로 하리니","reference":"열왕기하 22:16","category":"$undefined"},{"id":"10163","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":17,"text":"이는 이 백성이 나를 버리고 다른 신에게 분향하며 그 손의 모든 소위로 나의 노를 격발하였음이라 그러므로 나의 이 곳을 향하여 발한 진노가 꺼지지 아니하리라 하라 하셨느니라","reference":"열왕기하 22:17","category":"$undefined"},{"id":"10164","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":18,"text":"너희를 보내어 여호와께 묻게 한 유다 왕에게는 너희가 이렇게 고하라 이스라엘 하나님 여호와의 말씀이 네가 들은 말을 의논컨대","reference":"열왕기하 22:18","category":"$undefined"},{"id":"10165","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":19,"text":"내가 이곳과 그 거민에게 대하여 빈 터가 되고 저주가 되리라 한말을 네가 듣고 마음이 연하여 여호와 앞 곧 내 앞에서 겸비하여 옷을 찢고 통곡하였으므로 나도 네 말을 들었노라 여호와가 말하였느니라","reference":"열왕기하 22:19","category":"$undefined"},{"id":"10166","book":"열왕기하","book_name":"열왕기하","chapter":22,"verse":20,"text":"그러므로 내가 너로 너의 열조에게 돌아가서 평안히 묘실로 들어가게 하리니 내가 이 곳에 내리는 모든 재앙을 네가 눈으로 보지 못하리라 하셨느니라 사자들이 왕에게 복명하니라","reference":"열왕기하 22:20","category":"$undefined"}],"bookSlug":"2kings"}]
