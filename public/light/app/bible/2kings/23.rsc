2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":23,"verses":[{"id":"10167","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":1,"text":"왕이 보내어 유다와 예루살렘의 모든 장로를 자기에게로 모으고","reference":"열왕기하 23:1","category":"$undefined"},{"id":"10168","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":2,"text":"이에 여호와의 전에 올라가매 유다 모든 사람과 예루살렘 거민과 제사장들과 선지자들과 모든 백성이 무론 노소하고 다 왕과 함께 한지라 왕이 여호와의 전 안에서 발견한 언약책의 모든 말씀을 읽어 무리의 귀에 들리고","reference":"열왕기하 23:2","category":"$undefined"},{"id":"10169","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":3,"text":"왕이 대(臺) 위에 서서 여호와 앞에서 언약을 세우되 마음을 다하고 성품을 다하여 여호와를 순종하고 그 계명과 법도와 율례를 지켜 이 책에 기록된 이 언약의 말씀을 이루게 하리라 하매 백성이 다 그 언약을 좇기로 하니라","reference":"열왕기하 23:3","category":"$undefined"},{"id":"10170","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":4,"text":"왕이 대제사장 힐기야와 모든 버금 제사장들과 문을 지킨 자들에게 명하여 바알과 아세라와 하늘의 일월 성신을 위하여 만든 모든 기명을 여호와의 전에서 내어다가 예루살렘 바깥 기드론 밭에서 불사르고 그 재를 벧엘로 가져가게 하고","reference":"열왕기하 23:4","category":"$undefined"},{"id":"10171","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":5,"text":"옛적에 유다 왕들이 세워서 유다 모든 고을과 예루살렘 사면 산당에서 분향하며 우상을 섬기게 한 제사장들을 폐하며 또 바알과 해와 달과 열두 궁성과 하늘의 모든 별에게 분향하는 자들을 폐하고","reference":"열왕기하 23:5","category":"$undefined"},{"id":"10172","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":6,"text":"또 여호와의 전에서 아세라 상을 내어 예루살렘 바깥 기드론 시내로 가져다가 거기서 불사르고 빻아서 가루를 만들어 그 가루를 평민의 묘지에 뿌리고","reference":"열왕기하 23:6","category":"$undefined"},{"id":"10173","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":7,"text":"또 여호와의 전 가운데 미동의 집을 헐었으니 그곳은 여인이 아세라를 위하여 휘장을 짜는 처소이었더라","reference":"열왕기하 23:7","category":"$undefined"},{"id":"10174","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":8,"text":"유다 각 성읍에서 모든 제사장을 불러오고 또 제사장이 분향하던 산당을 게바에서부터 브엘세바까지 더럽게하고 또 성문의 산당들을 헐어 버렸으니 이 산당들은 부윤 여호수아의 대문 어구 곧 성문 왼편에 있었더라","reference":"열왕기하 23:8","category":"$undefined"},{"id":"10175","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":9,"text":"산당의 제사장들은 예루살렘 여호와의 단에 올라가지 못하고 다만 그 형제 중에서 무교병을 먹을 뿐이었더라","reference":"열왕기하 23:9","category":"$undefined"},{"id":"10176","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":10,"text":"왕이 또 힌놈의 아들 골짜기의 도벳을 더럽게 하여 사람으로 몰록에게 드리기 위하여 그 자녀를 불로 지나가게 하지 못하게 하고","reference":"열왕기하 23:10","category":"$undefined"},{"id":"10177","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":11,"text":"또 유다 열왕이 태양을 위하여 드린 말들을 제하여 버렸으니 이 말들은 여호와의 전으로 들어가는 곳의 근처 시종 나단멜렉의 집곁에 있던 것이며 또 태양수레를 불사르고","reference":"열왕기하 23:11","category":"$undefined"},{"id":"10178","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":12,"text":"유다 열왕이 아하스의 다락지붕에 세운 단들과 므낫세가 여호와의 전 두 마당에 세운 단들을 왕이 다 헐고 거기서 빻아내려서 그 가루를 기드론 시내에 쏟아버리고","reference":"열왕기하 23:12","category":"$undefined"},{"id":"10179","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":13,"text":"또 예루살렘 앞 멸망산 우편에 세운 산당을 더럽게 하였으니 이는 옛적에 이스라엘왕 솔로몬이 시돈 사람의 가증한 아스다롯과 모압 사람의 가증한 그모스와 암몬 자손의 가증한 밀곰을 위하여 세웠던 것이며","reference":"열왕기하 23:13","category":"$undefined"},{"id":"10180","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":14,"text":"왕이 또 석상들을 깨뜨리며 아세라 목상들을 찍고 사람의 해골로 그곳에 채웠더라","reference":"열왕기하 23:14","category":"$undefined"},{"id":"10181","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":15,"text":"이스라엘로 범죄케 한 느밧의 아들 여로보암이 벧엘에 세운 단과 산당을 왕이 헐고 또 그 산당을 불사르고 빻아서 가루를 만들며 또 아세라 목상을 불살랐더라","reference":"열왕기하 23:15","category":"$undefined"},{"id":"10182","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":16,"text":"요시야가 몸을 돌이켜 산에 있는 묘실들을 보고 보내어 그 묘실에서 해골을 취하여다가 단 위에 불살라 그 단을 더럽게 하니라 이 일을 하나님의 사람이 전하였더니 그 전한 여호와의 말씀대로 되었더라","reference":"열왕기하 23:16","category":"$undefined"},{"id":"10183","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":17,"text":"요시야가 이르되 내게 보이는 저것은 무슨 비석이냐 성읍 사람들이 고하되 왕께서 벧엘의 단에 향하여 행하신 이 일을 전하러 유다에서 왔던 하나님의 사람의 묘실이니이다","reference":"열왕기하 23:17","category":"$undefined"},{"id":"10184","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":18,"text":"가로되 그대로 두고 그 뼈를 옮기지 말라 하매 무리가 그 뼈와 사마리아에서 온 선지자의 뼈는 그대로 두었더라","reference":"열왕기하 23:18","category":"$undefined"},{"id":"10185","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":19,"text":"전에 이스라엘 열왕이 사마리아 각 성읍에 지어서 여호와의 노를 격발한 산당을 요시야가 다 제하되 벧엘에서 행한 모든 일대로 행하고","reference":"열왕기하 23:19","category":"$undefined"},{"id":"10186","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":20,"text":"또 거기 있는 산당의 제사장들을 다 단 위에서 죽이고 사람의 해골을 단 위에 불사르고 예루살렘으로 돌아왔더라","reference":"열왕기하 23:20","category":"$undefined"},{"id":"10187","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":21,"text":"왕이 뭇백성에게 명하여 가로되 이 언약책에 기록된대로 너희의 하나님 여호와를 위하여 유월절을 지키라 하매","reference":"열왕기하 23:21","category":"$undefined"},{"id":"10188","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":22,"text":"사사가 이스라엘을 다스리던 시대부터 이스라엘 열왕의 시대에든지 유다 열왕의 시대에든지 이렇게 유월절을 지킨 일이 없었더니","reference":"열왕기하 23:22","category":"$undefined"},{"id":"10189","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":23,"text":"요시야 왕 십 팔년에 예루살렘에서 여호와 앞에 이 유월절을 지켰더라","reference":"열왕기하 23:23","category":"$undefined"},{"id":"10190","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":24,"text":"요시야가 또 유다 땅과 예루살렘에 보이는 신접한 자와 박수와 드라빔과 우상과 모든 가증한 것을 다 제하였으니 이는 대제사장 힐기야가 여호와의 전에서 발견한 책에 기록된 율법 말씀을 이루려 함이라","reference":"열왕기하 23:24","category":"$undefined"},{"id":"10191","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":25,"text":"요시야와 같이 마음을 다하며 성품을 다하며 힘을 다하여 여호와를 향하여 모세의 모든 율법을 온전히 준행한 임금은 요시야 전에도 없었고 후에도 그와 같은 자가 없었더라","reference":"열왕기하 23:25","category":"$undefined"},{"id":"10192","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":26,"text":"그러나 여호와께서 유다를 향하여 진노하신 그 크게 타오르는 진노를 돌이키지 아니하셨으니 이는 므낫세가 여호와를 격노케 한 그 모든 격노를 인함이라","reference":"열왕기하 23:26","category":"$undefined"},{"id":"10193","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":27,"text":"여호와께서 가라사대 내가 이스라엘을 물리친 것 같이 유다도 내 앞에서 물리치며 내가 뺀 이 성 예루살렘과 내 이름을 거기 두리라 한 이 전을 버리리라 하셨더라","reference":"열왕기하 23:27","category":"$undefined"},{"id":"10194","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":28,"text":"요시야의 남은 사적과 모든 행한 일은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 23:28","category":"$undefined"},{"id":"10195","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":29,"text":"요시야 당시에 애굽 왕 바로느고가 앗수르 왕을 치고자하여 유브라데 하수로 올라가므로 요시야 왕이 나가서 방비하더니 애굽 왕이 요시야를 므깃도에서 만나본 후에 죽인지라","reference":"열왕기하 23:29","category":"$undefined"},{"id":"10196","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":30,"text":"신복들이 그 시체를 병거에 싣고 므깃도에서 예루살렘으로 돌아와서 그 묘실에 장사하니 국민이 요시야의 아들 여호아하스를 데려다가 저에게 기름을 붓고 그 부친을 대신하여 왕을 삼았더라","reference":"열왕기하 23:30","category":"$undefined"},{"id":"10197","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":31,"text":"여호아하스가 위에 나아갈 때에 나이 이십 삼세라 예루살렘에서 석달을 치리하니라 그 모친의 이름은 하무달이라 립나 예레미야 의 딸이더라","reference":"열왕기하 23:31","category":"$undefined"},{"id":"10198","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":32,"text":"여호아하스가 그 열조의 모든 행위대로 여호와 보시기에 악을 행하였더니","reference":"열왕기하 23:32","category":"$undefined"},{"id":"10199","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":33,"text":"바로느고가 저를 하맛 땅 립나에 가두어 예루살렘에서 왕이 되지 못하게 하고 또 그 나라로 은 일백 달란트와 금 한 달란트를 벌금으로 내게 하고","reference":"열왕기하 23:33","category":"$undefined"},{"id":"10200","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":34,"text":"바로느고가 요시야의 아들 엘리아김으로 그 아비 요시야를 대신하여 왕을 삼고 그 이름을 고쳐 여호야김이라 하고 여호아하스는 애굽으로 잡아갔더니 저가 거기서 죽으니라","reference":"열왕기하 23:34","category":"$undefined"},{"id":"10201","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":35,"text":"여호야김이 은과 금을 바로에게 주니라 저가 바로느고의 명령대로 그에게 그 돈을 주기 위하여 나라에 부과하되 국민 각 사람의 힘대로 액수를 정하고 은금을 늑봉하였더라","reference":"열왕기하 23:35","category":"$undefined"},{"id":"10202","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":36,"text":"여호야김이 왕이 될 때에 나이 이십 오세라 예루살렘에서 십 일년을 치리하니라 그 모친의 이름은 스비다라 루마 브다야의 딸이더라","reference":"열왕기하 23:36","category":"$undefined"},{"id":"10203","book":"열왕기하","book_name":"열왕기하","chapter":23,"verse":37,"text":"여호야김이 그 열조의 모든 행한 일을 본받아 여호와 보시기에 악을 행하였더라","reference":"열왕기하 23:37","category":"$undefined"}],"bookSlug":"2kings"}]
