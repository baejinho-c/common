2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":24,"verses":[{"id":"10204","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":1,"text":"여호야김 시대에 바벨론 왕 느부갓네살이 올라오매 여호야김이 삼년을 섬기다가 돌이켜 저를 배반하였더니","reference":"열왕기하 24:1","category":"$undefined"},{"id":"10205","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":2,"text":"여호와께서 그 종 선지자들로 하신 말씀과 같이 갈대아의 부대와 아람의 부대와 모압의 부대와 암몬자손의 부대를 여호야김에게로 보내어 유다를 쳐 멸하려 하시니","reference":"열왕기하 24:2","category":"$undefined"},{"id":"10206","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":3,"text":"이 일이 유다에 임함은 곧 여호와의 명하신바로 저희를 자기 앞에서 물리치고자 하심이니 이는 므낫세의 지은 모든 죄로 인함이며","reference":"열왕기하 24:3","category":"$undefined"},{"id":"10207","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":4,"text":"또 저가 무죄한 자의 피를 흘려 그 피로 예루살렘에 가득하게 하였음이라 여호와께서 사하시기를 즐겨하지 아니하시니라","reference":"열왕기하 24:4","category":"$undefined"},{"id":"10208","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":5,"text":"여호야김의 남은 사적과 모든 행한 일은 유다 왕 역대지략에 기록 되지 아니하였느냐","reference":"열왕기하 24:5","category":"$undefined"},{"id":"10209","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":6,"text":"여호야김이 그 열조와 함께 자매 그 아들 여호야긴이 대신하여 왕이 되니라","reference":"열왕기하 24:6","category":"$undefined"},{"id":"10210","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":7,"text":"애굽 왕이 다시는 그 나라에서 나오지 못하였으니 이는 바벨론 왕이 애굽 하수에서부터 유브라데 하수까지 애굽 왕에게 속한 땅을 다 취하였음이더라","reference":"열왕기하 24:7","category":"$undefined"},{"id":"10211","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":8,"text":"여호야긴이 위에 나아갈 때에 나이 십 팔세라 예루살렘에서 석달을 치리하니라 그 모친의 이름은 느후스다라 예루살렘 엘라단의 딸이더라","reference":"열왕기하 24:8","category":"$undefined"},{"id":"10212","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":9,"text":"여호야긴이 그 부친의 모든 행위를 본받아 여호와 보시기에 악을 행하였더라","reference":"열왕기하 24:9","category":"$undefined"},{"id":"10213","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":10,"text":"그 때에 바벨론 왕 느부갓네살의 신복들이 예루살렘에 올라와서 그 성을 에워싸니라","reference":"열왕기하 24:10","category":"$undefined"},{"id":"10214","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":11,"text":"그 신복들이 에워쌀 때에 바벨론 왕 느부갓네살도 그 성에 이르니","reference":"열왕기하 24:11","category":"$undefined"},{"id":"10215","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":12,"text":"유다 왕 여호야긴이 그 모친과 신복과 방백들과 내시들과 함께 바벨론 왕에게 나아가매 왕이 잡으니 때는 바벨론 왕 팔년이라","reference":"열왕기하 24:12","category":"$undefined"},{"id":"10216","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":13,"text":"저가 여호와의 전의 모든 보물과 왕궁 보물을 집어내고 또 이스라엘 왕 솔로몬이 만든 것 곧 여호와의 전의 금 기명을 다 훼파하였으니 여호와의 말씀과 같이 되었더라","reference":"열왕기하 24:13","category":"$undefined"},{"id":"10217","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":14,"text":"저가 또 예루살렘의 모든 백성과 모든 방백과 모든 용사 합 일만명과 모든 공장과 대장장이를 사로잡아 가매 빈천한 자 외에는 그 땅에 남은 자가 없었더라","reference":"열왕기하 24:14","category":"$undefined"},{"id":"10218","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":15,"text":"저가 여호야긴을 바벨론으로 사로잡아 가고 왕의 모친과 왕의 아내들과 내시와 나라에 권세 있는 자도 예루살렘에서 바벨론으로 사로잡아 가고","reference":"열왕기하 24:15","category":"$undefined"},{"id":"10219","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":16,"text":"또 용사 칠천과 공장과 대장장이 일천 곧 다 강장하여 싸움에 능한 자들을 바벨론으로 사로잡아가고","reference":"열왕기하 24:16","category":"$undefined"},{"id":"10220","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":17,"text":"바벨론 왕이 또 여호야긴의 아자비 맛다니야로 대신하여 왕을 삼고 그 이름을 고쳐 시드기야라 하였더라","reference":"열왕기하 24:17","category":"$undefined"},{"id":"10221","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":18,"text":"시드기야가 위에 나아갈 때에 나이 이십 일세라 예루살렘에서 십일년을 치리하니라 그 모친의 이름은 하무달이라 립나 예레미야의 딸이더라","reference":"열왕기하 24:18","category":"$undefined"},{"id":"10222","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":19,"text":"시드기야가 여호야김의 모든 행위를 본받아 여호와 보시기에 악을 행한지라","reference":"열왕기하 24:19","category":"$undefined"},{"id":"10223","book":"열왕기하","book_name":"열왕기하","chapter":24,"verse":20,"text":"여호와께서 예루살렘과 유다를 진노하심이 저희를 그 앞에서 쫓아 내실 때까지 이르렀더라 시드기야가 바벨론 왕을 배반하니라","reference":"열왕기하 24:20","category":"$undefined"}],"bookSlug":"2kings"}]
