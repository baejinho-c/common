2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":25,"verses":[{"id":"10224","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":1,"text":"시드기야 구년 시월 십일에 바벨론 왕 느부갓네살이 그 모든 군대를 거느리고 예루살렘을 치러 올라와서 진을 치고 사면으로 토성을 쌓으매","reference":"열왕기하 25:1","category":"$undefined"},{"id":"10225","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":2,"text":"성이 시드기야 왕 십 일년까지 에워싸였더니","reference":"열왕기하 25:2","category":"$undefined"},{"id":"10226","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":3,"text":"그 사월 구일에 성중에 기근이 심하여 그 땅 백성의 양식이 진하였고","reference":"열왕기하 25:3","category":"$undefined"},{"id":"10227","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":4,"text":"갈대아 사람이 그 성읍을 에워쌌으므로 성벽에 구멍을 뚫은지라 모든 군사가 밤중에 두 성벽 사이 왕의 동산 곁문 길로 도망하여 아라바 길로 가더니","reference":"열왕기하 25:4","category":"$undefined"},{"id":"10228","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":5,"text":"갈대아 군사가 왕을 쫓아가서 여리고 평지에 미치매 왕의 모든 군사가 저를 떠나 흩어진지라","reference":"열왕기하 25:5","category":"$undefined"},{"id":"10229","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":6,"text":"갈대아 군사가 왕을 잡아 립나 바벨론 왕에게로 끌고 가매 저에게 신문하고","reference":"열왕기하 25:6","category":"$undefined"},{"id":"10230","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":7,"text":"시드기야의 아들들을 저의 목전에서 죽이고 시드기야의 두 눈을 빼고 사슬로 결박하여 바벨론으로 끌어갔더라","reference":"열왕기하 25:7","category":"$undefined"},{"id":"10231","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":8,"text":"바벨론 왕 느부갓네살의 십 구년 오월 칠일에 바벨론 왕의 신하 시위대 장관 느부사라단이 예루살렘에 이르러","reference":"열왕기하 25:8","category":"$undefined"},{"id":"10232","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":9,"text":"여호와의 전과 왕궁을 사르고 예루살렘의 모든 집을 귀인의 집까지 불살랐으며","reference":"열왕기하 25:9","category":"$undefined"},{"id":"10233","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":10,"text":"시위대 장관을 좇는 갈대아 온 군대가 예루살렘 사면 성벽을 헐었으며","reference":"열왕기하 25:10","category":"$undefined"},{"id":"10234","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":11,"text":"성중에 남아 있는 백성과 바벨론 왕에게 항복한 자와 무리의 남은 자는 시위대 장관 느부사라단이 다 사로잡아가고","reference":"열왕기하 25:11","category":"$undefined"},{"id":"10235","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":12,"text":"빈천한 국민을 그 땅에 남겨두어 포도원을 다스리는 자와 농부가 되게 하였더라","reference":"열왕기하 25:12","category":"$undefined"},{"id":"10236","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":13,"text":"갈대아 사람이 또 여호와의 전의 두 놋기둥과 받침들과 여호와의 전의 놋바다를 깨뜨려 그 놋을 바벨론으로 가져가고","reference":"열왕기하 25:13","category":"$undefined"},{"id":"10237","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":14,"text":"또 가마들과 부삽들과 불집게들과 숟가락들과 섬길 때에 쓰는 모든 놋그릇을 다 가져갔으며","reference":"열왕기하 25:14","category":"$undefined"},{"id":"10238","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":15,"text":"시위대 장관이 또 불 옮기는 그릇들과 주발들 곧 금물의 금과 은물의 은을 가져갔으며","reference":"열왕기하 25:15","category":"$undefined"},{"id":"10239","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":16,"text":"또 솔로몬이 여호와의 전을 위하여 만든 두 기둥과 한 바다와 받침들을 취하였는데 이 모든 기구의 놋 중수를 헤아릴 수 없었으니","reference":"열왕기하 25:16","category":"$undefined"},{"id":"10240","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":17,"text":"그 한 기둥은 고가 십팔 규빗이요 그 꼭대기에 놋머리가 있어 고가 삼 규빗이요 그 머리에 둘린 그물과 석류가 다 놋이라 다른 기둥의 장식과 그물도 이와 같았더라","reference":"열왕기하 25:17","category":"$undefined"},{"id":"10241","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":18,"text":"시위대 장관이 대제사장 스라야와 부제사장 스바냐와 전 문지기 세 사람을 잡고","reference":"열왕기하 25:18","category":"$undefined"},{"id":"10242","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":19,"text":"또 성중에서 사람을 잡았으니 곧 군사를 거느린 내시 하나와 또 성중에서 만난바 왕의 시종 다섯 사람과 국민을 초모하는 장관의 서기관 하나와 성중에서 만난바 국민 육십명이라","reference":"열왕기하 25:19","category":"$undefined"},{"id":"10243","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":20,"text":"시위대 장관 느부사라단이 저희를 잡아가지고 립나 바벨론 왕에게 나아가매","reference":"열왕기하 25:20","category":"$undefined"},{"id":"10244","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":21,"text":"바벨론 왕이 하맛 땅 립나에서 다 쳐 죽였더라 이와 같이 유다가 사로잡혀 본토에서 떠났더라","reference":"열왕기하 25:21","category":"$undefined"},{"id":"10245","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":22,"text":"유다 땅에 머물러 있는 백성은 곧 바벨론 왕 느부갓네살이 남긴 자라 왕이 사반의 손자 아히감의 아들 그달리야로 관할하게 하였더라","reference":"열왕기하 25:22","category":"$undefined"},{"id":"10246","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":23,"text":"모든 군대 장관과 그 좇는 자가 바벨론 왕이 그달리야로 방백을 삼았다 함을 듣고 이에 느다니야의 아들 이스마엘과 가레아의 아들 요하난과 느도바 사람 단후멧의 아들 스라야와 마아가 사람의아들 야아사니야와 그 좇는 사람이 모두 미스바로 가서 그달리야에게 나아가매","reference":"열왕기하 25:23","category":"$undefined"},{"id":"10247","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":24,"text":"그달리야가 저희와 그 좇는 자들에게 맹세하여 이르되 너희는 갈대아 신복을 인하여 두려워 말고 이 땅에 거하여 바벨론 왕을 섬기라 그리하면 너희가 평안하리라 하니라","reference":"열왕기하 25:24","category":"$undefined"},{"id":"10248","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":25,"text":"칠월에 왕족 엘리사마의 손자 느다니야의 아들 이스마엘이 십인을 거느리고 와서 그달리야를 쳐서 죽이고 또 저와 함께 미스바에 있는 유다 사람과 갈대아 사람을 죽인지라","reference":"열왕기하 25:25","category":"$undefined"},{"id":"10249","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":26,"text":"대소 백성과 군대 장관들이 다 일어나서 애굽으로 갔으니 이는 갈대아 사람을 두려워함이었더라","reference":"열왕기하 25:26","category":"$undefined"},{"id":"10250","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":27,"text":"유다 왕 여호야긴이 사로잡혀 간지 삼십 칠년 곧 바벨론 왕 에윌므로닥의 즉위한 원년 십 이월 이십 칠일에 유다 왕 여호야긴을 옥에서 내어놓아 그 머리를 들게 하고","reference":"열왕기하 25:27","category":"$undefined"},{"id":"10251","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":28,"text":"선히 말하고 그 위를 바벨론에 저와 함께 있는 모든 왕의 위보다 높이고","reference":"열왕기하 25:28","category":"$undefined"},{"id":"10252","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":29,"text":"그 죄수의 의복을 바꾸게 하고 그 일평생에 항상 왕의 앞에서 먹게 하였고","reference":"열왕기하 25:29","category":"$undefined"},{"id":"10253","book":"열왕기하","book_name":"열왕기하","chapter":25,"verse":30,"text":"저의 쓸 것은 날마다 왕에게서 받는 정수가 있어서 종신토록 끊이지 아니하였더라","reference":"열왕기하 25:30","category":"$undefined"}],"bookSlug":"2kings"}]
