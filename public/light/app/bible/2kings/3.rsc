2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":3,"verses":[{"id":"9578","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":1,"text":"유다 왕 여호사밧의 십팔년에 아합의 아들 여호람이 사마리아에서 이스라엘 왕이 되어 십 이년을 치리하니라","reference":"열왕기하 3:1","category":"$undefined"},{"id":"9579","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":2,"text":"저가 여호와 보시기에 악을 행하였으나 그 부모와 같이 하지는 아니하였으니 이는 저가 그 아비의 만든 바알의 주상을 제하였음이라","reference":"열왕기하 3:2","category":"$undefined"},{"id":"9580","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":3,"text":"그러나 저가 느밧의 아들 여로보암이 이스라엘로 범하게 한 그 죄를 따라 행하고 떠나지 아니하였더라","reference":"열왕기하 3:3","category":"$undefined"},{"id":"9581","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":4,"text":"모압 왕 메사는 양을 치는 자라 새끼 양 십만의 털과 수양 십만의 털을 이스라엘 왕에게 바치더니","reference":"열왕기하 3:4","category":"$undefined"},{"id":"9582","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":5,"text":"아합이 죽은 후에 모압 왕이 이스라엘 왕을 배반한지라","reference":"열왕기하 3:5","category":"$undefined"},{"id":"9583","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":6,"text":"그 때에 여호람 왕이 사마리아에서 나가서 온 이스라엘을 점고하고","reference":"열왕기하 3:6","category":"$undefined"},{"id":"9584","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":7,"text":"또 가서 유다 왕 여호사밧에게 보내어 이르되 `모압 왕이 나를 배반하였으니 당신은 나와 함께 가서 모압을 치시겠느뇨' 저가 가로되 `내가 올라가리이다 나는 당신과 일반이요 내 백성은 당신의 백성과 일반이요 내 말들도 당신의 말들과 일반이니이다'","reference":"열왕기하 3:7","category":"$undefined"},{"id":"9585","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":8,"text":"여호람이 가로되 `우리가 어느 길로 올라가리이까' 저가 대답하되 `에돔 광야 길로니이다'","reference":"열왕기하 3:8","category":"$undefined"},{"id":"9586","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":9,"text":"이스라엘 왕이 유다 왕과 에돔 왕으로 더불어 행하더니 길을 둘러 행한 지 칠일에 군사와 따라가는 생축을 먹일 물이 없는지라","reference":"열왕기하 3:9","category":"$undefined"},{"id":"9587","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":10,"text":"이스라엘 왕이 가로되 `슬프다 여호와께서 이 세 왕을 불러 모아 모압의 손에 붙이려 하시는도다'","reference":"열왕기하 3:10","category":"$undefined"},{"id":"9588","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":11,"text":"여호사밧이 가로되 `우리가 여호와께 물을 만한 여호와의 선지자가 여기 없느냐' 이스라엘 왕의 신복 중에 한 사람이 대답하여 가로되 `전에 엘리야의 손에 물을 붓던 사밧의 아들 엘리사가 여기있나이다'","reference":"열왕기하 3:11","category":"$undefined"},{"id":"9589","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":12,"text":"여호사밧이 가로되 `여호와의 말씀이 저에게 있도다' 이에 이스라엘 왕이 여호사밧과 에돔 왕으로 더불어 그에게로 내려가니라","reference":"열왕기하 3:12","category":"$undefined"},{"id":"9590","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":13,"text":"엘리사가 이스라엘 왕에게 이르되 `내가 당신과 무슨 상관이 있나이까 당신의 부친의 선지자들과 당신의 모친의 선지자들에게로 가소서' 이스라엘 왕이 저에게 이르되 `그렇지 아니하니이다 여호와께서 이 세 왕을 불러 모아 모압의 손에 붙이려 하시나이다'","reference":"열왕기하 3:13","category":"$undefined"},{"id":"9591","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":14,"text":"엘리사가 가로되 `내가 섬기는 만군의 여호와의 사심을 가리켜 맹세하노니 내가 만일 유다 왕 여호사밧의 낯을 봄이 아니면 당신을 향하지도 아니하고 보지도 아니하였으리이다","reference":"열왕기하 3:14","category":"$undefined"},{"id":"9592","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":15,"text":"이제 내게로 거문고 탈 자를 불러 오소서' 하니라 거문고 타는 자가 거문고를 탈 때에 여호와께서 엘리사를 감동하시니","reference":"열왕기하 3:15","category":"$undefined"},{"id":"9593","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":16,"text":"저가 가로되 `여호와의 말씀이 이 골짜기에 개천을 많이 파라 하셨나이다","reference":"열왕기하 3:16","category":"$undefined"},{"id":"9594","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":17,"text":"여호와께서 이르시기를 너희가 바람도 보지 못하고 비도 보지 못하되 이 골짜기에 물이 가득하여 너희와 너희 육축과 짐승이 마시리라 하셨나이다","reference":"열왕기하 3:17","category":"$undefined"},{"id":"9595","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":18,"text":"이것은 여호와 보시기에 오히려 작은 일이라 여호와께서 모압 사람도 당신의 손에 붙이시리니","reference":"열왕기하 3:18","category":"$undefined"},{"id":"9596","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":19,"text":"당신들이 모든 견고한 성과 모든 아름다운 성을 치고 모든 좋은 나무를 베고 모든 샘을 메우고 돌로 모든 좋은 밭을 헐리이다' 하더니","reference":"열왕기하 3:19","category":"$undefined"},{"id":"9597","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":20,"text":"아침에 미쳐 소제 드릴 때에 물이 에돔 편에서부터 흘러와서 그 땅에 가득하였더라","reference":"열왕기하 3:20","category":"$undefined"},{"id":"9598","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":21,"text":"모압 모든 사람이 왕들이 올라와서 자기를 치려 한다 함을 듣고 갑옷 입을 만한 자로부터 그 이상이 다 모여 그 경계에 섰더라","reference":"열왕기하 3:21","category":"$undefined"},{"id":"9599","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":22,"text":"아침에 모압 사람이 일찌기 일어나서 해가 물에 비취므로 맞은편 물이 붉어 피와 같음을 보고","reference":"열왕기하 3:22","category":"$undefined"},{"id":"9600","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":23,"text":"가로되 `이는 피라 필연 저 왕들이 싸워 서로 죽인 것이로다 모압 사람들아 이제 노략하러 가자' 하고","reference":"열왕기하 3:23","category":"$undefined"},{"id":"9601","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":24,"text":"이스라엘 진(陣)에 이르니 이스라엘 사람이 일어나 모압 사람을 쳐서 그 앞에서 도망하게 하고 그 지경에 들어가며 모압 사람을 치고","reference":"열왕기하 3:24","category":"$undefined"},{"id":"9602","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":25,"text":"그 성읍을 쳐서 헐고 각기 돌을 던져 모든 좋은 밭에 가득하게 하고 모든 샘을 메우고 모든 좋은 나무를 베고 길하라셋의 돌들은 남기고 물맷군이 두루 다니며 치니라","reference":"열왕기하 3:25","category":"$undefined"},{"id":"9603","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":26,"text":"모압 왕이 전세가 극렬하여 당하기 어려움을 보고 칼 찬 군사 칠백을 거느리고 충돌하여 지나서 에돔 왕에게로 가고자 하되 능히 못하고","reference":"열왕기하 3:26","category":"$undefined"},{"id":"9604","book":"열왕기하","book_name":"열왕기하","chapter":3,"verse":27,"text":"이에 자기 위를 이어 왕이 될 맏아들을 취하여 성 위에서 번제를 드린지라 이스라엘에게 크게 통분함이 임하매 저희가 떠나 각기 고국으로 돌아갔더라","reference":"열왕기하 3:27","category":"$undefined"}],"bookSlug":"2kings"}]
