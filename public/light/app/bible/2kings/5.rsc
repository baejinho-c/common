2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":5,"verses":[{"id":"9649","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":1,"text":"아람 왕의 군대장관 나아만은 그 주인 앞에서 크고 존귀한 자니 이는 여호와께서 전에 저로 아람을 구원하게 하셨음이라 저는 큰 용사나 문둥병자더라","reference":"열왕기하 5:1","category":"$undefined"},{"id":"9650","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":2,"text":"전에 아람 사람이 떼를 지어 나가서 이스라엘 땅에서 작은 계집아이 하나를 사로잡으매 저가 나아만의 아내에게 수종들더니","reference":"열왕기하 5:2","category":"$undefined"},{"id":"9651","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":3,"text":"그 주모에게 이르되 `우리 주인이 사마리아에 계신 선지자 앞에 계셨으면 좋겠나이다 저가 그 문둥병을 고치리이다'","reference":"열왕기하 5:3","category":"$undefined"},{"id":"9652","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":4,"text":"나아만이 들어가서 그 주인에게 고하여 가로되 `이스라엘 땅에서 온 계집아이의 말이 이러이러하더이다'","reference":"열왕기하 5:4","category":"$undefined"},{"id":"9653","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":5,"text":"아람 왕이 가로되 `갈지어다 이제 내가 이스라엘 왕에게 글을 보내리라' 나아만이 곧 떠날새 은 십 달란트와 금 육천개와 의복 열벌을 가지고 가서","reference":"열왕기하 5:5","category":"$undefined"},{"id":"9654","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":6,"text":"이스라엘 왕에게 그 글을 전하니 일렀으되 `내가 내 신하 나아만을 당신에게 보내오니 이 글이 당신에게 이르거든 당신은 그 문둥병을 고쳐주소서' 하였더라","reference":"열왕기하 5:6","category":"$undefined"},{"id":"9655","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":7,"text":"이스라엘 왕이 그 글을 읽고 자기 옷을 찢으며 가로되 `내가 어찌 하나님이관대 능히 사람을 죽이며 살릴 수 있으랴 저가 어찌하여 사람을 내게 보내어 그 문둥병을 고치라 하느냐 너희는 깊이 생각하고 저 왕이 틈을 타서 나로 더불어 시비하려 함인줄 알라' 하니라","reference":"열왕기하 5:7","category":"$undefined"},{"id":"9656","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":8,"text":"하나님의 사람 엘리사가 이스라엘 왕이 자기 옷을 찢었다 함을 듣고 왕에게 보내어 가로되 왕이 어찌하여 옷을 찢었나이까 그 사람을 내게로 오게 하소서 저가 이스라엘 중에 선지자가 있는 줄을 알리이다","reference":"열왕기하 5:8","category":"$undefined"},{"id":"9657","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":9,"text":"나아만이 이에 말들과 병거들을 거느리고 이르러 엘리사의 집 문에 서니","reference":"열왕기하 5:9","category":"$undefined"},{"id":"9658","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":10,"text":"엘리사가 사자를 저에게 보내어 가로되 `너는 가서 요단강에 몸을 일곱번 씻으라 네 살이 여전하여 깨끗하리라'","reference":"열왕기하 5:10","category":"$undefined"},{"id":"9659","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":11,"text":"나아만이 노하여 물러가며 가로되 `내 생각에는 저가 내게로 나아와 서서 그 하나님 여호와의 이름을 부르고 당처 위에 손을 흔들어 문둥병을 고칠까 하였도다","reference":"열왕기하 5:11","category":"$undefined"},{"id":"9660","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":12,"text":"다메섹강 아마나와 바르발은 이스라엘 모든 강물보다 낫지 아니하냐 내가 거기서 몸을 씻으면 깨끗하게 되지 아니하랴' 하고 몸을 돌이켜 분한 모양으로 떠나니","reference":"열왕기하 5:12","category":"$undefined"},{"id":"9661","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":13,"text":"그 종들이 나아와서 말하여 가로되 `내 아버지여 선지자가 당신을 명하여 큰 일을 행하라 하였더면 행치 아니하였으리이까 하물며 당신에게 이르기를 씻어 깨끗하게 하라 함이리이까'","reference":"열왕기하 5:13","category":"$undefined"},{"id":"9662","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":14,"text":"나아만이 이에 내려가서 하나님의 사람의 말씀대로 요단강에 일곱번 몸을 잠그니 그 살이 여전하여 어린아이의 살 같아서 깨끗하게 되었더라","reference":"열왕기하 5:14","category":"$undefined"},{"id":"9663","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":15,"text":"나아만이 모든 종자와 함께 하나님의 사람에게로 도로 와서 그 앞에 서서 가로되 내가 이제 이스라엘 외에는 온 천하에 신이 없는 줄을 아나이다 청컨대 당신의 종에게서 예물을 받으소서","reference":"열왕기하 5:15","category":"$undefined"},{"id":"9664","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":16,"text":"가로되 나의 섬기는 여호와의 사심을 가리켜 맹세하노니 내가 받지 아니하리라 나아만이 받으라 강권하되 저가 고사한지라","reference":"열왕기하 5:16","category":"$undefined"},{"id":"9665","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":17,"text":"나아만이 가로되 그러면 청컨대 노새 두 바리에 실을 흙을 당신의 종에게 주소서 이제부터는 종이 번제든지 다른 제든지 다른 신에게는 드리지 아니하고 다만 여호와께 드리겠나이다","reference":"열왕기하 5:17","category":"$undefined"},{"id":"9666","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":18,"text":"오직 한가지 일이 있사오니 여호와께서 당신의 종을 사유하시기를 원하나이다 곧 내 주인께서 림몬의 당에 들어가 거기서 숭배하며 내 손을 의지하시매 내가 림몬의 당에서 몸을 굽히오니 내가 림몬의 당에서 몸을 굽힐때에 여호와께서 이일에 대하여 당신의 종을 사유하시기를 원하나이다","reference":"열왕기하 5:18","category":"$undefined"},{"id":"9667","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":19,"text":"엘리사가 가로되 너는 평안히 가라 저가 엘리사를 떠나 조금 진행하니라","reference":"열왕기하 5:19","category":"$undefined"},{"id":"9668","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":20,"text":"하나님의 사람 엘리사의 사환 게하시가 스스로 이르되 내 주인이 이 아람 사람 나아만에게 면하여 주고 그 가지고 온 것을 그 손에서 받지 아니하였도다 여호와의 사심을 가리켜 맹세하노니 내가 저를 쫓아 가서 무엇이든지 그에게서 취하리라 하고","reference":"열왕기하 5:20","category":"$undefined"},{"id":"9669","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":21,"text":"나아만의 뒤를 쫓아 가니 나아만이 자기 뒤에 달려옴을 보고 수레에 내려서 맞아 가로되 평안이냐","reference":"열왕기하 5:21","category":"$undefined"},{"id":"9670","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":22,"text":"저가 가로되 평안이니이다 우리 주인께서 나를 보내시며 말씀하시기를 지금 선지자의 생도 중에 두 소년이 에브라임 산지에서부터 내게 왔으니 청컨대 당신은 저희에게 은 한 달란트와 옷 두벌을 주라 하시더이다","reference":"열왕기하 5:22","category":"$undefined"},{"id":"9671","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":23,"text":"나아만이 가로되 바라건대 두 달란트를 받으라 하고 저를 억제 하여 은 두 달란트를 두 전대에 넣어 매고 옷 두 벌을 아울러 두사환에게 지우매 저희가 게하시 앞에서 지고 가니라","reference":"열왕기하 5:23","category":"$undefined"},{"id":"9672","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":24,"text":"언덕에 이르러는 게하시가 그 물건을 두 사환의 손에서 취하여 집에 감추고 저희를 보내어 가게 한 후","reference":"열왕기하 5:24","category":"$undefined"},{"id":"9673","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":25,"text":"들어가서 그 주인 앞에 서니 엘리사가 이르되 게하시야 네가 어디서 오느냐 대답하되 종이 아무데도 가지 아니하였나이다","reference":"열왕기하 5:25","category":"$undefined"},{"id":"9674","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":26,"text":"엘리사가 이르되 그 사람이 수레에서 내려 너를 맞을 때에 내 심령이 감각되지 아니하였느냐 지금이 어찌 은을 받으며 옷을 받으며 감람원이나 포도원이나 양이나 소나 남종이나 여종을 받을 때냐","reference":"열왕기하 5:26","category":"$undefined"},{"id":"9675","book":"열왕기하","book_name":"열왕기하","chapter":5,"verse":27,"text":"그러므로 나아만의 문둥병이 네게 들어 네 자손에게 미쳐 영원토록 이르리라 게하시가 그 앞에서 물러 나오매 문둥병이 발하여 눈 같이 되었더라","reference":"열왕기하 5:27","category":"$undefined"}],"bookSlug":"2kings"}]
