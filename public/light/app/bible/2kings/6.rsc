2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":6,"verses":[{"id":"9676","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":1,"text":"선지자의 생도가 엘리사에게 이르되 보소서 우리가 당신과 함께 거한 곳이 우리에게는 좁으니","reference":"열왕기하 6:1","category":"$undefined"},{"id":"9677","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":2,"text":"우리가 요단으로 가서 거기서 각각 한 재목을 취하여 그곳에 우리의 거할 처소를 세우사이다 엘리사가 가로되 가라","reference":"열왕기하 6:2","category":"$undefined"},{"id":"9678","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":3,"text":"그 하나가 가로되 청컨대 당신도 종들과 함께 하소서 엘리사가 가로되 내가 가리라 하고","reference":"열왕기하 6:3","category":"$undefined"},{"id":"9679","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":4,"text":"드디어 저희와 함께 가니라 무리가 요단에 이르러 나무를 베더니","reference":"열왕기하 6:4","category":"$undefined"},{"id":"9680","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":5,"text":"한 사람이 나무를 벨 때에 도끼가 자루에서 빠져 물에 떨어진지라 이에 외쳐 가로되 아아 내 주여 이는 빌어온 것이니이다","reference":"열왕기하 6:5","category":"$undefined"},{"id":"9681","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":6,"text":"하나님의 사람이 가로되 어디 빠졌느냐 하매 그 곳을 보이는지라 엘리사가 나무가지를 베어 물에 던져서 도끼로 떠오르게 하고","reference":"열왕기하 6:6","category":"$undefined"},{"id":"9682","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":7,"text":"가로되 너는 취하라 그 사람이 손을 내밀어 취하니라","reference":"열왕기하 6:7","category":"$undefined"},{"id":"9683","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":8,"text":"때에 아람 왕이 이스라엘로 더불어 싸우며 그 신복들과 의논하여 이르기를 우리가 아무데 아무데 진을 치리라 하였더니","reference":"열왕기하 6:8","category":"$undefined"},{"id":"9684","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":9,"text":"하나님의 사람이 이스라엘 왕에게 기별하여 가로되 왕은 삼가 아무 곳으로 지나가지 마소서 아람 사람이 그 곳으로 나오나이다","reference":"열왕기하 6:9","category":"$undefined"},{"id":"9685","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":10,"text":"이스라엘 왕이 하나님의 사람의 자기에게 고하여 경계한 곳으로 사람을 보내어 방비하기가 한 두번이 아닌지라","reference":"열왕기하 6:10","category":"$undefined"},{"id":"9686","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":11,"text":"이러므로 아람 왕의 마음이 번뇌하여 그 신복들을 불러 이르되 우리 중에 누가 이스라엘 왕의 내응이 된 것을 내게 고하지 아니하느냐","reference":"열왕기하 6:11","category":"$undefined"},{"id":"9687","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":12,"text":"그 신복 중에 하나가 가로되 우리 주 왕이여 아니로소이다 오직 이스라엘 선지자 엘리사가 왕이 침실에서 하신 말씀이라도 이스라엘 왕에게 고하나이다","reference":"열왕기하 6:12","category":"$undefined"},{"id":"9688","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":13,"text":"왕이 가로되 너희는 가서 엘리사가 어디 있나 보라 내가 보내어 잡으리라 혹이 왕에게 고하여 가로되 엘리사가 도단에 있나이다","reference":"열왕기하 6:13","category":"$undefined"},{"id":"9689","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":14,"text":"왕이 이에 말과 병거와 많은 군사를 보내매 저희가 밤에 가서 그 성을 에워쌌더라","reference":"열왕기하 6:14","category":"$undefined"},{"id":"9690","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":15,"text":"하나님의 사람의 수종드는 자가 일찌기 일어나서 나가보니 군사와 말과 병거가 성을 에워쌌는지라 그 사환이 엘리사에게 고하되 아아 ! 내 주여 우리가 어찌하리이까","reference":"열왕기하 6:15","category":"$undefined"},{"id":"9691","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":16,"text":"대답하되 두려워하지 말라 우리와 함께한 자가 저와 함께한 자보다 많으니라 하고","reference":"열왕기하 6:16","category":"$undefined"},{"id":"9692","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":17,"text":"기도하여 가로되 여호와여 원컨대 저의 눈을 열어서 보게 하옵소서 하니 여호와께서 그 사환의 눈을 여시매 저가 보니 불말과 불병거가 산에 가득하여 엘리사를 둘렀더라","reference":"열왕기하 6:17","category":"$undefined"},{"id":"9693","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":18,"text":"아람 사람이 엘리사에게 내려오매 엘리사가 여호와께 기도하여 가로되 원컨대 저 무리의 눈을 어둡게 하옵소서 하매 엘리사의 말대로 그 눈을 어둡게 하신지라","reference":"열왕기하 6:18","category":"$undefined"},{"id":"9694","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":19,"text":"엘리사가 저희에게 이르되 `이는 그 길이 아니요 이는 그 성도 아니니 나를 따라 오라 내가 너희를 인도하여 너희의 찾는 사람에게로 나아가리라' 하고 저희를 인도하여 사마리아에 이르니라","reference":"열왕기하 6:19","category":"$undefined"},{"id":"9695","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":20,"text":"사마리아에 들어갈 때에 엘리사가 가로되 `여호와여 이 무리의 눈을 열어서 보게 하옵소서' 하니 여호와께서 저희의 눈을 여시매 저희가 보니 자기가 사마리아 가운데 있더라","reference":"열왕기하 6:20","category":"$undefined"},{"id":"9696","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":21,"text":"이스라엘 왕이 저희를 보고 엘리사에게 이르되 `내 아버지여 내가 치리이까 내가 치리이까'","reference":"열왕기하 6:21","category":"$undefined"},{"id":"9697","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":22,"text":"대답하되 `치지 마소서 칼과 활로 사로잡은 자인들 어찌 치리이까 떡과 물을 그 앞에 두어 먹고 마시게 하고 그 주인에게로 돌려 보내소서'","reference":"열왕기하 6:22","category":"$undefined"},{"id":"9698","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":23,"text":"왕이 위하여 식물을 많이 베풀고 저희가 먹고 마시매 놓아보내니 저희가 그 주인에게로 돌아가니라 이로부터 아람 군사의 부대가 다시는 이스라엘 땅에 들어오지 못하니라","reference":"열왕기하 6:23","category":"$undefined"},{"id":"9699","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":24,"text":"이 후에 아람 왕 벤하닷이 그 온 군대를 모아 올라와서 사마리아를 에워싸니","reference":"열왕기하 6:24","category":"$undefined"},{"id":"9700","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":25,"text":"아람 사람이 사마리아를 에워싸므로 성중이 크게 주려서 나귀 머리 하나에 은 팔십 세겔이요 합분태 사분 일 갑에 은 다섯 세겔이라","reference":"열왕기하 6:25","category":"$undefined"},{"id":"9701","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":26,"text":"이스라엘 왕이 성 위로 통과할 때에 한 여인이 외쳐 가로되 `나의 주 왕이여 도우소서'","reference":"열왕기하 6:26","category":"$undefined"},{"id":"9702","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":27,"text":"왕이 가로되 `여호와께서 너를 돕지 아니하시면 내가 무엇으로 너를 도우랴 타작마당으로 말미암아 하겠느냐 포도주 틀로 말미암아 하겠느냐'","reference":"열왕기하 6:27","category":"$undefined"},{"id":"9703","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":28,"text":"또 가로되 `무슨 일이냐' 여인이 대답하되 `이 여인이 내게 이르기를 네 아들을 내라 우리가 오늘날 먹고 내일은 내 아들을 먹자 하매","reference":"열왕기하 6:28","category":"$undefined"},{"id":"9704","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":29,"text":"우리가 드디어 내 아들을 삶아 먹었더니 이튿날에 내가 이르되 네 아들을 내라 우리가 먹으리라 하나 저가 그 아들을 숨겼나이다'","reference":"열왕기하 6:29","category":"$undefined"},{"id":"9705","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":30,"text":"왕이 그 여인의 말을 듣고 자기 옷을 찢으니라 저가 성 위로 지나갈 때에 백성이 본즉 그 속살에 굵은 베를 입었더라","reference":"열왕기하 6:30","category":"$undefined"},{"id":"9706","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":31,"text":"왕이 가로되 `사밧의 아들 엘리사의 머리가 오늘날 그 몸에 붙어 있으면 하나님이 내게 벌 위에 벌을 내리실지로다' 하니라","reference":"열왕기하 6:31","category":"$undefined"},{"id":"9707","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":32,"text":"그 때에 엘리사가 그 집에 앉았고 장로들이 저와 함께 앉았는데 왕이 자기 처소에서 사람을 보내었더니 그 사자가 이르기 전에 엘리사가 장로들에게 이르되 `너희는 이 살인한 자의 자식이 내 머리를 취하려고 사람을 보내는 것을 보느냐 너희는 보다가 사자가 오거든 문을 닫고 문안에 들이지말라 그 주인의 발소리가 그 뒤에서 나지 아니하느냐' 하고","reference":"열왕기하 6:32","category":"$undefined"},{"id":"9708","book":"열왕기하","book_name":"열왕기하","chapter":6,"verse":33,"text":"무리와 말씀할 때에 그 사자가 이르니라 왕이 가로되 `이 재앙이 여호와께로부터 나왔으니 어찌 더 여호와를 기다리리요'","reference":"열왕기하 6:33","category":"$undefined"}],"bookSlug":"2kings"}]
