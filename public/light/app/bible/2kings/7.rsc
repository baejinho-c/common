2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":7,"verses":[{"id":"9709","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":1,"text":"엘리사가 가로되 `여호와의 말씀을 들을지어다 여호와께서 가라사대 내일 이맘때에 사마리아 성문에서 고운 가루 한 스아에 한 세겔을 하고 보리 두 스아에 한 세겔을 하리라 하셨느니라'","reference":"열왕기하 7:1","category":"$undefined"},{"id":"9710","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":2,"text":"그 때에 한 장관 곧 왕이 그 손에 의지하는 자가 하나님의 사람에게 대답하여 가로되 `여호와께서 하늘에 창을 내신들 어찌 이런 일이 있으리요 엘리사가 가로되 네가 네 눈으로 보리라 그러나 그것을 먹지는 못하리라' 하니라","reference":"열왕기하 7:2","category":"$undefined"},{"id":"9711","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":3,"text":"성문 어귀에 문둥이 네 사람이 있더니 서로 말하되 `우리가 어찌하여 여기 앉아서 죽기를 기다리랴","reference":"열왕기하 7:3","category":"$undefined"},{"id":"9712","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":4,"text":"우리가 성에 들어가자고 할지라도 성 중은 주리니 우리가 거기서 죽을 것이요 여기 앉아 있어도 죽을지라 그런즉 우리가 가서 아람 군대에게 항복하자 저희가 우리를 살려 두면 살려니와 우리를 죽이면 죽을 따름이라' 하고","reference":"열왕기하 7:4","category":"$undefined"},{"id":"9713","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":5,"text":"아람 진으로 가려하여 황혼에 일어나서 아람 진 가에 이르러 본즉 그 곳에 한 사람도 없으니","reference":"열왕기하 7:5","category":"$undefined"},{"id":"9714","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":6,"text":"이는 주께서 아람 군대로 병거 소리와 말 소리와 큰 군대의 소리를 듣게 하셨으므로 아람 사람이 서로 말하기를 이스라엘 왕이 우리를 치려하여 헷 사람의 왕들과 애굽 왕들에게 값을 주고 저희로 우리에게 오게 하였다 하고","reference":"열왕기하 7:6","category":"$undefined"},{"id":"9715","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":7,"text":"황혼에 일어나서 도망하되 그 장막과 말과 나귀를 버리고 진을 그대로 두고 목숨을 위하여 도망하였음이라","reference":"열왕기하 7:7","category":"$undefined"},{"id":"9716","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":8,"text":"그 문둥이들이 진 가에 이르자 한 장막에 들어가서 먹고 마시고 거기서 은과 금과 의복을 가지고 가서 감추고 다시 와서 다른 장막에 들어가서 거기서도 가지고 가서 감추니라","reference":"열왕기하 7:8","category":"$undefined"},{"id":"9717","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":9,"text":"문둥이가 서로 말하되 우리의 소위가 선치 못하도다 오늘날은 아름다운 소식이 있는 날이어늘 우리가 잠잠하고 있도다 만일 밝은 아침까지 기다리면 벌이 우리에게 미칠지니 이제 떠나 왕궁에 가서 고하자 하고","reference":"열왕기하 7:9","category":"$undefined"},{"id":"9718","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":10,"text":"드디어 가서 성 문지기를 불러 고하여 가로되 우리가 아람 진에 이르러 보니 거기 한 사람도 없고 사람의 소리도 없고 오직 말과 나귀만 매여 있고 장막들이 그대로 있더이다","reference":"열왕기하 7:10","category":"$undefined"},{"id":"9719","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":11,"text":"저가 문지기들을 부르매 저희가 왕궁에 있는 자에게 고하니","reference":"열왕기하 7:11","category":"$undefined"},{"id":"9720","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":12,"text":"왕이 밤에 일어나 그 신복들에게 이르되 아람 사람이 우리에게 행한 것을 내가 너희에게 알게 하노니 저희가 우리의 주린 것을 아는고로 그 진을 떠나서 들에 매복하고 스스로 이르기를 저희들이 성에서 나오거든 우리가 사로잡고 성에 들어가겠다 한 것이니라","reference":"열왕기하 7:12","category":"$undefined"},{"id":"9721","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":13,"text":"그 신복중 하나가 대답하여 가로되 청컨대 아직 성중에 남아 있는 말 다섯 필을 취하고 사람을 보내어 정탐하게 하소서 이 말들이 성중에 남아 있는 이스라엘 온 무리 곧 멸망한 이스라엘 온 무리와 같으니이다 하고","reference":"열왕기하 7:13","category":"$undefined"},{"id":"9722","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":14,"text":"저희가 병거 둘과 그 말을 취한지라 왕이 아람 군대 뒤로 보내며 가서 정탐하라 하였더니","reference":"열왕기하 7:14","category":"$undefined"},{"id":"9723","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":15,"text":"저희가 그 뒤를 따라 요단에 이른즉 아람 사람이 급히 도망하느라고 버린 의복과 군물이 길에 가득하였더라 사자가 돌아와서 왕에게 고하매","reference":"열왕기하 7:15","category":"$undefined"},{"id":"9724","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":16,"text":"백성들이 나가서 아람 사람의 진을 노략한지라 이에 고운 가루 한 스아에 한 세겔이 되고 보리 두 스아에 한 세겔이 되니 여호와의 말씀과 같이 되었고","reference":"열왕기하 7:16","category":"$undefined"},{"id":"9725","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":17,"text":"왕이 그 손에 의지하였던 그 장관을 세워 성문을 지키게 하였더니 백성이 성문에서 저를 밟으매 하나님의 사람의 말대로 죽었으니 곧 왕이 내려왔을 때에 그의 한 말대로라","reference":"열왕기하 7:17","category":"$undefined"},{"id":"9726","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":18,"text":"일찌기 하나님의 사람이 왕에게 고하여 이르기를 내일 이맘때에 사마리아 성문에서 보리 두 스아에 한 세겔을 하고 고운 가루 한스아에 한 세겔을 하리라 한즉","reference":"열왕기하 7:18","category":"$undefined"},{"id":"9727","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":19,"text":"그 때에 이 장관이 하나님의 사람에게 대답하여 가로되 여호와께서 하늘에 창을 내신들 어찌 이 일이 있으랴 하매 대답하기를 네가 네 눈으로 보리라 그러나 그것을 먹지는 못하리라 하였더니","reference":"열왕기하 7:19","category":"$undefined"},{"id":"9728","book":"열왕기하","book_name":"열왕기하","chapter":7,"verse":20,"text":"그 장관에게 그대로 이루었으되 곧 백성이 성문에서 저를 밟으매 죽었더라","reference":"열왕기하 7:20","category":"$undefined"}],"bookSlug":"2kings"}]
