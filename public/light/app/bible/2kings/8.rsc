2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":8,"verses":[{"id":"9729","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":1,"text":"엘리사가 이전에 아들을 다시 살려준 여인에게 이르되 너는 일어나서 네 권속과 함께 거할만한 곳으로 가서 거하라 여호와께서 기근을 명하셨으니 그대로 이 땅에 칠년 동안 임하리라","reference":"열왕기하 8:1","category":"$undefined"},{"id":"9730","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":2,"text":"여인이 일어나서 하나님의 사람의 말대로 행하여 그 권속과 함께 가서 블레셋 사람의 땅에 칠년을 우거하다가","reference":"열왕기하 8:2","category":"$undefined"},{"id":"9731","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":3,"text":"칠년이 다하매 여인이 블레셋 사람의 땅에서 돌아와서 자기 집과 전토를 위하여 호소하려 하여 왕에게 나아갔더라","reference":"열왕기하 8:3","category":"$undefined"},{"id":"9732","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":4,"text":"때에 왕이 하나님의 사람의 사환 게하시와 서로 말씀하며 가로되 너는 엘리사의 행한 모든 큰 일을 내게 고하라 하니","reference":"열왕기하 8:4","category":"$undefined"},{"id":"9733","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":5,"text":"게하시가 곧 엘리사가 죽은 자를 다시 살린 일을 왕에게 이야기 할때에 그 다시 살린 아이의 어미가 자기 집과 전토를 위하여 왕에게 호소하는지라 게하시가 가로되 내 주 왕이여 이는 그 여인 이요 저는 그 아들이니 곧 엘리사가 다시 살린 자니이다","reference":"열왕기하 8:5","category":"$undefined"},{"id":"9734","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":6,"text":"왕이 그 여인에게 물으매 여인이 고한지라 왕이 저를 위하여 한 관리를 임명하여 가로되 무릇 이 여인에게 속한 것과 이 땅에서 떠날 때부터 이제까지 그 밭의 소출을 다 돌려주라 하였더라","reference":"열왕기하 8:6","category":"$undefined"},{"id":"9735","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":7,"text":"엘리사가 다메섹에 갔을 때에 아람 왕 벤하닷이 병들었더니 혹이 왕에게 고하여 가로되 하나님의 사람이 여기 이르렀나이다","reference":"열왕기하 8:7","category":"$undefined"},{"id":"9736","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":8,"text":"왕이 하사엘에게 이르되 너는 손에 예물을 가지고 가서 하나님의 사람을 맞고 저로 말미암아 여호와께 나의 이 병이 낫겠나 물으라","reference":"열왕기하 8:8","category":"$undefined"},{"id":"9737","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":9,"text":"하사엘이 드디어 맞으러 갈새 다메섹 모든 아름다운 물품으로 예물을 삼아가지고 약대 사십에 싣고 나아가서 저의 앞에 서서 가로되 당신의 아들 아람 왕 벤하닷이 나를 당신에게 보내어 가로 되 나의 이 병이 낫겠나이까 하더이다","reference":"열왕기하 8:9","category":"$undefined"},{"id":"9738","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":10,"text":"엘리사가 가로되 너는 가서 저에게 고하기를 왕이 정녕 나으리라 하라 그러나 여호와께서 저가 정녕 죽으리라고 내게 알게 하셨느니라 하고","reference":"열왕기하 8:10","category":"$undefined"},{"id":"9739","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":11,"text":"하나님의 사람이 저가 부끄러워하기까지 쏘아보다가 우니","reference":"열왕기하 8:11","category":"$undefined"},{"id":"9740","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":12,"text":"하사엘이 가로되 내 주여 어찌하여 우시나이까 대답하되 네가 이스라엘 자손에게 행할 모든 악을 내가 앎이라 네가 저희 성에 불을 놓으며 장정을 칼로 죽이며 어린 아이를 메어차며 아이 밴 부녀를 가르리라","reference":"열왕기하 8:12","category":"$undefined"},{"id":"9741","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":13,"text":"하사엘이 가로되 당신의 개 같은 종이 무엇이관대 이런 큰 일을 행하오리이까 엘리사가 대답하되 여호와께서 네가 아람 왕이 될 것을 내게 알게 하셨느니라","reference":"열왕기하 8:13","category":"$undefined"},{"id":"9742","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":14,"text":"저가 엘리사를 떠나가서 그 주인에게 나아가니 왕이 묻되 엘리사가 네게 무슨 말을 하더냐 대답하되 저가 내게 이르기를 왕이 정녕 나으시리라 하더이다","reference":"열왕기하 8:14","category":"$undefined"},{"id":"9743","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":15,"text":"그 이튿날에 하사엘이 이불을 물에 적시어 왕의 얼굴에 덮으매 왕이 죽은지라 저가 대신하여 왕이 되니라","reference":"열왕기하 8:15","category":"$undefined"},{"id":"9744","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":16,"text":"이스라엘 왕 아합의 아들 요람 제 오년에 유다 왕 여호사밧이 오히려 위에 있을 때에 그 아들 여호람이 왕이 되니라","reference":"열왕기하 8:16","category":"$undefined"},{"id":"9745","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":17,"text":"여호람이 위에 나아갈 때에 나이 삼십 이세라 예루살렘에서 팔년을 치리하니라","reference":"열왕기하 8:17","category":"$undefined"},{"id":"9746","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":18,"text":"저가 이스라엘 왕들의 길로 행하여 아합의 집과 같이 하였으니 이는 아합의 딸이 그 아내가 되었음이라 저가 여호와 보시기에 악을 행하였으나","reference":"열왕기하 8:18","category":"$undefined"},{"id":"9747","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":19,"text":"여호와께서 그 종 다윗을 위하여 유다 멸하기를 즐겨하지 아니하셨으니 이는 저와 그 자손에게 항상 등불을 주겠다고 허하셨음이더라","reference":"열왕기하 8:19","category":"$undefined"},{"id":"9748","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":20,"text":"여호람 때에 에돔이 배반하여 유다의 수하에서 벗어나 자기 위에 왕을 세운고로","reference":"열왕기하 8:20","category":"$undefined"},{"id":"9749","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":21,"text":"여호람이 모든 병거를 거느리고 사일로 갔더니 밤에 일어나 자기를 에워싼 에돔 사람과 그 병거의 장관들을 치니 이에 백성이 도망하여 각각 그 장막으로 돌아갔더라","reference":"열왕기하 8:21","category":"$undefined"},{"id":"9750","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":22,"text":"이와 같이 에돔이 배반하여 유다의 수하에서 벗어났더니 오늘날 까지 그러하였으며 그 때에 립나도 배반하였더라","reference":"열왕기하 8:22","category":"$undefined"},{"id":"9751","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":23,"text":"여호람의 남은 사적과 그 행한 모든 일은 유다 왕 역대지략에 기록되지 아니하였느냐","reference":"열왕기하 8:23","category":"$undefined"},{"id":"9752","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":24,"text":"여호람이 그 열조와 함께 자매 그 열조들과 함께 다윗 성에 장사되고 그 아들 아하시야가 대신하여 왕이 되니라","reference":"열왕기하 8:24","category":"$undefined"},{"id":"9753","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":25,"text":"이스라엘 왕 아합의 아들 요람 제 십 이년에 유다 왕 여호람의 아들 아하시야가 왕이 되니","reference":"열왕기하 8:25","category":"$undefined"},{"id":"9754","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":26,"text":"아하시야가 위에 나아갈 때에 나이 이십 이세라 예루살렘에서 일년을 치리하니라 그 모친의 이름은 아달랴라 이스라엘 왕 오므리의 손녀더라","reference":"열왕기하 8:26","category":"$undefined"},{"id":"9755","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":27,"text":"아하시야가 아합의 집 길로 행하여 아합의 집과 같이 여호와 보시기에 악을 행하였으니 저는 아합의 집의 사위가 되었음이러라","reference":"열왕기하 8:27","category":"$undefined"},{"id":"9756","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":28,"text":"저가 아합의 아들 요람과 함께 길르앗 라못으로 가서 아람 왕 하사엘로 더불어 싸우더니 아람 사람들이 요람을 상하게 한지라","reference":"열왕기하 8:28","category":"$undefined"},{"id":"9757","book":"열왕기하","book_name":"열왕기하","chapter":8,"verse":29,"text":"요람 왕이 아람 왕 하사엘과 싸울 때에 라마에서 아람 사람에게 맞아 상한 것을 치료하려 하여 이스르엘로 돌아왔더라 아합의 아들 요람이 병이 있으므로 유다 왕 여호람의 아들 아하시야가 이스르엘에 내려가서 방문하였더라","reference":"열왕기하 8:29","category":"$undefined"}],"bookSlug":"2kings"}]
