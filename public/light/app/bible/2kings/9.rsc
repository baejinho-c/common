2:["$","$L11",null,{"book":{"id":"2kings","name":"열왕기하","chapters":25,"testament":"old"},"chapter":9,"verses":[{"id":"9758","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":1,"text":"선지자 엘리사가 선지자의 생도 중 하나를 불러 이르되 너는 허리를 동이고 이 기름병을 손에 가지고 길르앗 라못으로 가라","reference":"열왕기하 9:1","category":"$undefined"},{"id":"9759","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":2,"text":"거기 이르거든 님시의 손자 여호사밧의 아들 예후를 찾아 들어가서 그 형제 중에서 일어나게 하고 데리고 골방으로 들어가서","reference":"열왕기하 9:2","category":"$undefined"},{"id":"9760","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":3,"text":"기름병을 가지고 그 머리에 부으며 이르기를 여호와의 말씀이 내가 네게 기름을 부어 이스라엘 왕을 삼노라 하셨느니라 하고 곧 문을 열고 도망하되 지체치 말지니라","reference":"열왕기하 9:3","category":"$undefined"},{"id":"9761","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":4,"text":"그 소년 곧 소년 선지자가 드디어 길르앗 라못으로 가니라","reference":"열왕기하 9:4","category":"$undefined"},{"id":"9762","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":5,"text":"저가 이르러 보니 군대 장관들이 앉았는지라 소년이 가로되 `장관이여 내가 당신에게 할 말씀이 있나이다' 예후가 가로되 `우리 모든 사람중에 뉘게 하려느냐' 가로되 `장관이여 당신에게니이다'","reference":"열왕기하 9:5","category":"$undefined"},{"id":"9763","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":6,"text":"예후가 일어나 집으로 들어가니 소년이 그 머리에 기름을 부으며 이르되 `이스라엘 하나님 여호와의 말씀이 내가 네게 기름을 부어 여호와의 백성 곧 이스라엘의 왕을 삼노니","reference":"열왕기하 9:6","category":"$undefined"},{"id":"9764","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":7,"text":"너는 네 주 아합의 집을 치라 내가 나의 종 곧 선지자들의 피와 여호와의 종들의 피를 이세벨에게 갚아주리라","reference":"열왕기하 9:7","category":"$undefined"},{"id":"9765","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":8,"text":"아합의 온 집이 멸망하리니 이스라엘 중에 매인 자나 놓인 자나 아합에게 속한 모든 남자는 내가 다 멸절하되","reference":"열왕기하 9:8","category":"$undefined"},{"id":"9766","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":9,"text":"아합의 집을 느밧의 아들 여로보암의 집과 같게 하며 또 아히야의 아들 바아사의 집과 같게 할지라","reference":"열왕기하 9:9","category":"$undefined"},{"id":"9767","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":10,"text":"이스르엘 지방에서 개들이 이세벨을 먹으리니 저를 장사할 사람이 없으리라 하셨느니라' 하고 곧 문을 열고 도망하니라","reference":"열왕기하 9:10","category":"$undefined"},{"id":"9768","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":11,"text":"예후가 나와서 그 주의 신복들에게 이르니 한 사람이 묻되 평안이뇨 그 미친 자가 무슨 까닭으로 그대에게 왔더뇨 대답하되 그대들이 그 사람과 그 말한 것을 알리라","reference":"열왕기하 9:11","category":"$undefined"},{"id":"9769","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":12,"text":"무리가 가로되 당치 않은 말이라 그대는 우리에게 이르라 대답하되 저가 이리 이리 내게 말하여 이르기를 여호와의 말씀이 내가 네게 기름을 부어 이스라엘 왕을 삼는다 하셨다 하더라","reference":"열왕기하 9:12","category":"$undefined"},{"id":"9770","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":13,"text":"무리가 각각 자기의 옷을 급히 취하여 섬돌 위 곧 예후의 밑에 깔고 나팔을 불며 가로되 예후는 왕이라 하니라","reference":"열왕기하 9:13","category":"$undefined"},{"id":"9771","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":14,"text":"이에 님시의 손자 여호사밧의 아들 예후가 요람을 배반하였으니 곧 요람이 온 이스라엘로 더불어 아람 왕 하사엘을 인하여 길르앗 라못을 지키다가","reference":"열왕기하 9:14","category":"$undefined"},{"id":"9772","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":15,"text":"아람 왕 하사엘로 더불어 싸울 때에 아람 사람에게 상한 것을 치료하려 하여 이스르엘로 돌아왔던 때라 예후가 이르되 너희 뜻에 합당하거든 한 사람이라도 이 성에서 도망하여 이스르엘에 전하러 가지 못하게 하라 하니라","reference":"열왕기하 9:15","category":"$undefined"},{"id":"9773","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":16,"text":"예후가 병거를 타고 이스르엘로 가니 요람이 거기 누웠음이라 유다왕 아하시야는 요람을 보러 내려 왔더라","reference":"열왕기하 9:16","category":"$undefined"},{"id":"9774","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":17,"text":"이스르엘 망대에 파숫군 하나가 섰더니 예후의 무리의 오는 것을보고 가로되 내가 한 무리를 보나이다 요람이 가로되 한 사람을 말을 태워 보내어 맞아 평안이냐 묻게 하라","reference":"열왕기하 9:17","category":"$undefined"},{"id":"9775","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":18,"text":"한 사람이 말을 타고 가서 만나 가로되 왕의 말씀이 평안이냐 하시더이다 하매 예후가 가로되 평안이 네게 상관이 있느냐 내 뒤로 돌이키라 하니라 파숫군이 고하여 가로되 사자가 저희에게 갔으나 돌아오지 아니하나이다 하는지라","reference":"열왕기하 9:18","category":"$undefined"},{"id":"9776","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":19,"text":"다시 한 사람을 말을 태워 보내었더니 저희에게 가서 가로되 왕의 말씀이 평안이냐 하시더이다 하매 예후가 가로되 평안이 네게 상관이 있느냐 내 뒤로 돌이키라 하니라","reference":"열왕기하 9:19","category":"$undefined"},{"id":"9777","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":20,"text":"파숫군이 또 고하여 가로되 저도 저희에게까지 갔으나 돌아오지 아니하고 그 병거 모는 것이 님시의 손자 예후의 모는 것 같이 미치게 모나이다","reference":"열왕기하 9:20","category":"$undefined"},{"id":"9778","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":21,"text":"요람이 가로되 메우라 하매 그 병거를 메운지라 이스라엘 왕 요람과 유다 왕 아하시야가 각각 그 병거를 타고 가서 예후를 맞을새 이스르엘 사람 나봇의 토지에서 만나매","reference":"열왕기하 9:21","category":"$undefined"},{"id":"9779","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":22,"text":"요람이 예후를 보고 가로되 예후야 평안이냐 대답하되 네 어미 이세벨의 음행과 술수가 이렇게 많으니 어찌 평안이 있으랴","reference":"열왕기하 9:22","category":"$undefined"},{"id":"9780","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":23,"text":"요람이 곧 손을 돌이켜 도망하며 아하시야에게 이르되 아하시야여 반역이로다","reference":"열왕기하 9:23","category":"$undefined"},{"id":"9781","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":24,"text":"예후가 힘을 다하여 활을 당기어 요람의 두 팔 사이를 쏘니 살이 그 염통을 꿰뚫고 나오매 저가 병거 가운데 엎드러진지라","reference":"열왕기하 9:24","category":"$undefined"},{"id":"9782","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":25,"text":"예후가 그 장관 빗갈에게 이르되 그 시체를 취하여 이스르엘 사람 나봇의 밭에 던지라 네가 기억하려니와 이전에 너와 내가 함께 타고 그 아비 아합을 좇았을 때에 여호와께서 이 아래 같이 저의 일을 예언하셨느니라","reference":"열왕기하 9:25","category":"$undefined"},{"id":"9783","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":26,"text":"여호와께서 말씀하시기를 내가 어젯날에 나봇의 피와 그 아들들의 피를 분명히 보았노라 또 말씀하시기를 이 토지에서 네게 갚으리라 하셨으니 그런즉 여호와의 말씀대로 그 시체를 취하여 이 밭에 던질지니라","reference":"열왕기하 9:26","category":"$undefined"},{"id":"9784","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":27,"text":"유다 왕 아하시야가 이를 보고 동산 정자 길로 도망하니 예후가 쫓아가며 이르되 저도 병거 가운데서 죽이라 하매 이블르암 가까운 구르 비탈에서 치니 저가 므깃도까지 도망하여 거기서 죽은지라","reference":"열왕기하 9:27","category":"$undefined"},{"id":"9785","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":28,"text":"그 신복들이 저를 병거에 싣고 예루살렘에 이르러 다윗성에서 그 열조와 함께 그 묘실에 장사하니라","reference":"열왕기하 9:28","category":"$undefined"},{"id":"9786","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":29,"text":"아합의 아들 요람의 십 일년에 아하시야가 유다 왕이 되었었더라","reference":"열왕기하 9:29","category":"$undefined"},{"id":"9787","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":30,"text":"예후가 이스르엘에 이르니 이세벨이 듣고 눈을 그리고 머리를 꾸미고 창에서 바라보다가","reference":"열왕기하 9:30","category":"$undefined"},{"id":"9788","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":31,"text":"예후가 문에 들어오매 가로되 주인을 죽인 너 시므리여 평안하냐","reference":"열왕기하 9:31","category":"$undefined"},{"id":"9789","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":32,"text":"예후가 얼굴을 들어 창을 향하고 가로되 내 편이 될 자가 누구냐 누구냐 하니 두어 내시가 예후를 내다보는지라","reference":"열왕기하 9:32","category":"$undefined"},{"id":"9790","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":33,"text":"가로되 저를 내려던지라 하니 내려던지매 그 피가 담과 말에게 뛰더라 예후가 그 시체를 밟으니라","reference":"열왕기하 9:33","category":"$undefined"},{"id":"9791","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":34,"text":"예후가 들어가서 먹고 마시고 가로되 가서 이 저주 받은 계집을 찾아 장사하라 저는 왕의 딸이니라 하매","reference":"열왕기하 9:34","category":"$undefined"},{"id":"9792","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":35,"text":"가서 장사하려 한즉 그 두골과 발과 손바닥 외에는 찾지 못한지라","reference":"열왕기하 9:35","category":"$undefined"},{"id":"9793","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":36,"text":"돌아와서 고한대 예후가 가로되 이는 여호와께서 그 종 디셉 사람 엘리야로 말씀하신바라 이르시기를 이스르엘 토지에서 개들이 이세벨의 고기를 먹을지라","reference":"열왕기하 9:36","category":"$undefined"},{"id":"9794","book":"열왕기하","book_name":"열왕기하","chapter":9,"verse":37,"text":"그 시체가 이스르엘 토지에서 거름 같이 밭 면에 있으리니 이것이 이세벨이라고 가리켜 말하지 못하게 되리라 하셨느니라","reference":"열왕기하 9:37","category":"$undefined"}],"bookSlug":"2kings"}]
