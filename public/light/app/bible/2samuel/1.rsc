2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":1,"verses":[{"id":"8024","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":1,"text":"사울의 죽은 후라 다윗이 아말렉 사람을 도륙하고 돌아와서 시글락에서 이틀을 유하더니","reference":"사무엘하 1:1","category":"$undefined"},{"id":"8025","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":2,"text":"제 삼일에 한 사람이 사울의 진에서 나왔는데 그 옷은 찢어졌고 머리에는 흙이 있더라 저가 다윗에게 나아와 땅에 엎드려 절하매","reference":"사무엘하 1:2","category":"$undefined"},{"id":"8026","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":3,"text":"다윗이 저에게 묻되 `너는 어디서 왔느냐 ?' 대답하되 `이스라엘 진에서 도망하여 왔나이다'","reference":"사무엘하 1:3","category":"$undefined"},{"id":"8027","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":4,"text":"다윗이 가로되 `일이 어떻게 되었느뇨 너는 내게 고하라' 저가 대답하되 `군사가 전쟁 중에서 도망하기도 하였고 무리 중에 엎드러져 죽은 자도 많았고 사울과 그 아들 요나단도 죽었나이다'","reference":"사무엘하 1:4","category":"$undefined"},{"id":"8028","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":5,"text":"다윗이 자기에게 고하는 소년에게 묻되 `사울과 그 아들 요나단의 죽은 줄을 네가 어떻게 아느냐 ?'","reference":"사무엘하 1:5","category":"$undefined"},{"id":"8029","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":6,"text":"그에게 고하는 소년이 가로되 `내가 우연히 길보아산에 올라 보니 사울이 자기 창을 의지하였고 병거와 기병은 저를 촉급히 따르는데","reference":"사무엘하 1:6","category":"$undefined"},{"id":"8030","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":7,"text":"사울이 뒤로 돌이켜 나를 보고 부르시기로 내가 대답하되 내가 여기 있나이다 한즉","reference":"사무엘하 1:7","category":"$undefined"},{"id":"8031","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":8,"text":"내게 이르되 너는 누구냐 하시기로 내가 대답하되 나는 아말렉 사람이니이다 한즉","reference":"사무엘하 1:8","category":"$undefined"},{"id":"8032","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":9,"text":"또 내게 이르되 내 목숨이 아직 내게 완전히 있으므로 내가 고통에 들었나니 너는 내 곁에 서서 나를 죽이라 하시기로","reference":"사무엘하 1:9","category":"$undefined"},{"id":"8033","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":10,"text":"저가 엎드러진 후에는 살 수 없는 줄을 내가 알고 그 곁에 서서 죽이고 그 머리에 있는 면류관과 팔에 있는 고리를 벗겨서 내 주께로 가져 왔나이다'","reference":"사무엘하 1:10","category":"$undefined"},{"id":"8034","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":11,"text":"이에 다윗이 자기 옷을 잡아 찢으매 함께 있는 모든 사람도 그리하고","reference":"사무엘하 1:11","category":"$undefined"},{"id":"8035","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":12,"text":"사울과 그 아들 요나단과 여호와의 백성과 이스라엘 족속이 칼에 죽음을 인하여 저녁때까지 슬퍼하여 울며 금식하니라","reference":"사무엘하 1:12","category":"$undefined"},{"id":"8036","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":13,"text":"다윗이 그 고한 소년에게 묻되 너는 어디 사람이냐 ? 대답하되 나는 아말렉 사람 곧 외국인의 아들이니이다","reference":"사무엘하 1:13","category":"$undefined"},{"id":"8037","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":14,"text":"다윗이 저에게 이르되 `네가 어찌하여 손을 들어 여호와의 기름부음 받은 자 죽이기를 두려워하지 아니하였느냐 ?' 하고","reference":"사무엘하 1:14","category":"$undefined"},{"id":"8038","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":15,"text":"소년 중 하나를 불러 이르되 `가까이 가서 저를 죽이라' 하매 그가 치매 곧 죽으니라","reference":"사무엘하 1:15","category":"$undefined"},{"id":"8039","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":16,"text":"다윗이 저에게 이르기를 `네 피가 네 머리로 돌아갈지어다 네 입이 네게 대하여 증거하기를 내가 여호와의 기름 부음 받은 자를 죽였노라 함이니라' 하였더라","reference":"사무엘하 1:16","category":"$undefined"},{"id":"8040","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":17,"text":"다윗이 이 슬픈 노래로 사울과 그 아들 요나단을 조상하고","reference":"사무엘하 1:17","category":"$undefined"},{"id":"8041","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":18,"text":"명하여 그것을 유다 족속에게 가르치라 하였으니 곧 활 노래라 야살의 책에 기록되었으되","reference":"사무엘하 1:18","category":"$undefined"},{"id":"8042","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":19,"text":"이스라엘아 ! 너의 영광이 산 위에서 죽임을 당하였도다 오호라 ! 두용사가 엎드러졌도다","reference":"사무엘하 1:19","category":"$undefined"},{"id":"8043","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":20,"text":"이 일을 가드에도 고하지 말며 아스글론 거리에도 전파하지 말지어다 블레셋 사람의 딸들이 즐거워할까, 할례받지 못한 자의 딸들이 개가를 부를까 염려로다","reference":"사무엘하 1:20","category":"$undefined"},{"id":"8044","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":21,"text":"길보아산들아 너희 위에 우로가 내리지 아니하며 제물 낼 밭도 없을지어다 거기서 두 용사의 방패가 버린 바 됨이라 곧 사울의 방패가 기름 부음을 받지 않음 같이 됨이로다","reference":"사무엘하 1:21","category":"$undefined"},{"id":"8045","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":22,"text":"죽은 자의 피에서, 용사의 기름에서 요나단의 활이 물러가지 아니하였으며 사울의 칼이 헛되이 돌아오지 아니하였도다","reference":"사무엘하 1:22","category":"$undefined"},{"id":"8046","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":23,"text":"사울과 요나단이 생전에 사랑스럽고 아름다운 자러니 죽을 때에도 서로 떠나지 아니하였도다 저희는 독수리보다 빠르고 사자보다 강하였도다","reference":"사무엘하 1:23","category":"$undefined"},{"id":"8047","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":24,"text":"이스라엘 딸들아 ! 사울을 슬퍼하여 울지어다 ! 저가 붉은 옷으로 너희에게 화려하게 입혔고 금 노리개를 너희 옷에 채웠도다","reference":"사무엘하 1:24","category":"$undefined"},{"id":"8048","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":25,"text":"오호라 ! 두 용사가 전쟁 중에 엎드러졌도다 요나단이 너의 산위에서 죽임을 당하였도다","reference":"사무엘하 1:25","category":"$undefined"},{"id":"8049","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":26,"text":"내 형 요나단이여 ! 내가 그대를 애통함은 그대는 내게 심히 아름다움이라 그대가 나를 사랑함이 기이하여 여인의 사랑보다 승하였도다","reference":"사무엘하 1:26","category":"$undefined"},{"id":"8050","book":"사무엘하","book_name":"사무엘하","chapter":1,"verse":27,"text":"오호라 ! 두 용사가 엎드러졌으며 싸우는 병기가 망하였도다 하였더라","reference":"사무엘하 1:27","category":"$undefined"}],"bookSlug":"2samuel"}]
