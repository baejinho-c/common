2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":12,"verses":[{"id":"8288","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":1,"text":"여호와께서 나단을 다윗에게 보내시니 와서 저에게 이르되 `한 성에 두 사람이 있는데 하나는 부하고 하나는 가난하니","reference":"사무엘하 12:1","category":"$undefined"},{"id":"8289","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":2,"text":"그 부한 자는 양과 소가 심히 많으나","reference":"사무엘하 12:2","category":"$undefined"},{"id":"8290","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":3,"text":"가난한 자는 아무것도 없고 자기가 사서 기르는 작은 암양 새끼 하나뿐이라 그 암양 새끼는 저와 저의 자식과 함께 있어 자라며 저의 먹는 것을 먹으며 저의 잔에서 마시며 저의 품에 누우므로 저에게는 딸처럼 되었거늘","reference":"사무엘하 12:3","category":"$undefined"},{"id":"8291","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":4,"text":"어떤 행인이 그 부자에게 오매 부자가 자기의 양과 소를 아껴 자기에게 온 행인을 위하여 잡지 아니하고 가난한 사람의 양 새끼를 빼앗아다가 자기에게 온 사람을 위하여 잡았나이다'","reference":"사무엘하 12:4","category":"$undefined"},{"id":"8292","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":5,"text":"다윗이 그 사람을 크게 노하여 나단에게 이르되 `여호와의 사심을 가리켜 맹세하노니 이 일을 행한 사람은 마땅히 죽을 자라","reference":"사무엘하 12:5","category":"$undefined"},{"id":"8293","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":6,"text":"저가 불쌍히 여기지 않고 이 일을 행하였으니 그 양 새끼를 사배나 갚아 주어야 하리라'","reference":"사무엘하 12:6","category":"$undefined"},{"id":"8294","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":7,"text":"나단이 다윗에게 이르되 `당신이 그 사람이라 ! 이스라엘의 하나님 여호와께서 이처럼 이르시기를 내가 너로 이스라엘 왕을 삼기 위하여 네게 기름을 붓고 너를 사울의 손에서 구원하고","reference":"사무엘하 12:7","category":"$undefined"},{"id":"8295","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":8,"text":"네 주인의 집을 네게 주고 네 주인의 처들을 네 품에 두고 이스라엘과 유다 족속을 네게 맡겼느니라 만일 그것이 부족하였을 것같으면 내가 네게 이것 저것을 더 주었으리라","reference":"사무엘하 12:8","category":"$undefined"},{"id":"8296","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":9,"text":"그러한데 어찌하여 네가 여호와의 말씀을 업신여기고 나 보기에 악을 행하였느뇨 네가 칼로 헷 사람 우리아를 죽이되 암몬 자손의 칼로 죽이고 그 처를 빼앗아 네 처를 삼았도다","reference":"사무엘하 12:9","category":"$undefined"},{"id":"8297","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":10,"text":"이제 네가 나를 업신여기고 헷 사람 우리아의 처를 빼앗아 네 처를 삼았은즉 칼이 네 집에 영영히 떠나지 아니하리라 하셨고","reference":"사무엘하 12:10","category":"$undefined"},{"id":"8298","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":11,"text":"여호와께서 또 이처럼 이르시기를 내가 네 집에 재화를 일으키고 내가 네 처들을 가져 네 눈 앞에서 다른 사람에게 주리니 그 사람이 네 처들로 더불어 백주에 동침하리라","reference":"사무엘하 12:11","category":"$undefined"},{"id":"8299","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":12,"text":"너는 은밀히 행하였으나 나는 이스라엘 무리 앞 백주에 이 일을 행하리라 하셨나이다'","reference":"사무엘하 12:12","category":"$undefined"},{"id":"8300","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":13,"text":"다윗이 나단에게 이르되 `내가 여호와께 죄를 범하였노라 !' 하매 나단이 다윗에게 대답하되 `여호와께서도 당신의 죄를 사하셨나니 당신이 죽지 아니하려니와","reference":"사무엘하 12:13","category":"$undefined"},{"id":"8301","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":14,"text":"이 일로 인하여 여호와의 원수로 크게 훼방할 거리를 얻게 하였으니 당신의 낳은 아이가 정녕 죽으리이다' 하고","reference":"사무엘하 12:14","category":"$undefined"},{"id":"8302","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":15,"text":"나단이 자기 집으로 돌아가니라 우리아의 처가 다윗에게 낳은 아이를 여호와께서 치시매 심히 앓는 지라","reference":"사무엘하 12:15","category":"$undefined"},{"id":"8303","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":16,"text":"다윗이 그 아이를 위하여 하나님께 간구하되 금식하고 안에 들어가서 밤새도록 땅에 엎드렸으니","reference":"사무엘하 12:16","category":"$undefined"},{"id":"8304","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":17,"text":"그 집의 늙은 자들이 곁에 이르러 다윗을 일으키려 하되 왕이 듣지 아니하고 저희로 더불어 먹지도 아니하더라","reference":"사무엘하 12:17","category":"$undefined"},{"id":"8305","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":18,"text":"이레만에 그 아이가 죽으니라 그러나 다윗의 신복들이 아이의 죽은 것을 왕에게 고하기를 두려워하니 이는 저희가 말하기를 `아이가 살았을 때에 우리가 말하여도 왕이 그 말을 듣지 아니하셨나니 어떻게 그 아이의 죽은 것을 고할 수 있으랴 왕이 훼상하시리로다'함이라","reference":"사무엘하 12:18","category":"$undefined"},{"id":"8306","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":19,"text":"다윗이 그 신복들의 서로 수군거리는 것을 보고 그 아이가 죽은 줄을 깨닫고 그 신복들에게 묻되 `아이가 죽었느냐 ?' 대답하되 `죽었나이다'","reference":"사무엘하 12:19","category":"$undefined"},{"id":"8307","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":20,"text":"다윗이 땅에서 일어나 몸을 씻고 기름을 바르고 의복을 갈아입고 여호와의 전에 들어가서 경배하고 궁으로 돌아와서 명하여 음식을 그 앞에 베풀게 하고 먹은지라","reference":"사무엘하 12:20","category":"$undefined"},{"id":"8308","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":21,"text":"신복들이 왕께 묻되 `아이가 살았을 때에는 위하여 금식하고 우시니 죽은 후에는 일어나서 잡수시니 어찜이니이까 ?'","reference":"사무엘하 12:21","category":"$undefined"},{"id":"8309","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":22,"text":"가로되 `아이가 살았을 때에 내가 금식하고 운 것은 혹시 여호와께서 나를 불쌍히 여기사 아이를 살려 주실는지 누가 알까 생각함이어니와","reference":"사무엘하 12:22","category":"$undefined"},{"id":"8310","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":23,"text":"시방은 죽었으니 어찌 금식하랴 내가 다시 돌아오게 할 수 있느냐 ? 나는 저에게로 가려니와 저는 내게로 돌아오지 아니하리라'","reference":"사무엘하 12:23","category":"$undefined"},{"id":"8311","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":24,"text":"다윗이 그 처 밧세바를 위로하고 저에게 들어가 동침하였더니 저가 아들을 낳으매 그 이름을 솔로몬이라 하니라 여호와께서 그를 사랑하사","reference":"사무엘하 12:24","category":"$undefined"},{"id":"8312","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":25,"text":"선지자 나단을 보내사 그 이름을 여디디야라 하시니 이는 여호와께서 사랑하심을 인함이더라","reference":"사무엘하 12:25","category":"$undefined"},{"id":"8313","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":26,"text":"요압이 암몬 자손의 왕성(王城) 랍바를 쳐서 취하게 되매","reference":"사무엘하 12:26","category":"$undefined"},{"id":"8314","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":27,"text":"사자를 다윗에게 보내어 가로되 `내가 랍바 곧 물들의 성을 쳐서 취하게 되었으니","reference":"사무엘하 12:27","category":"$undefined"},{"id":"8315","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":28,"text":"이제 왕은 남은 군사를 모아 진치고 이 성을 쳐서 취하소서 ! 내가 이 성을 취하면 이 성이 내 이름으로 일컬음을 받을까 두려워하나이다'","reference":"사무엘하 12:28","category":"$undefined"},{"id":"8316","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":29,"text":"다윗이 모든 군사를 모아 랍바로 가서 쳐서 취하고","reference":"사무엘하 12:29","category":"$undefined"},{"id":"8317","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":30,"text":"그 왕의 머리에서 보석 있는 면류관을 취하니 그 중량이 한 금 달란트라 다윗이 머리에 쓰니라 다윗이 또 그 성에서 노략한 물건을 무수히 내어오고","reference":"사무엘하 12:30","category":"$undefined"},{"id":"8318","book":"사무엘하","book_name":"사무엘하","chapter":12,"verse":31,"text":"그 가운데 백성들을 끌어 내어 톱질과, 써레질과, 도끼질과, 벽돌구이를 하게 하니라 암몬 자손의 모든 성을 이같이 하고 다윗과 모든 백성이 예루살렘으로 돌아오니라","reference":"사무엘하 12:31","category":"$undefined"}],"bookSlug":"2samuel"}]
