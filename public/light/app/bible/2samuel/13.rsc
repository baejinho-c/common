2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":13,"verses":[{"id":"8319","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":1,"text":"그 후에 이일이 있으니라 다윗의 아들 압살롬에게 아름다운 누이가 있으니 이름은 다말이라 다윗의 아들 암논이 저를 연애하나","reference":"사무엘하 13:1","category":"$undefined"},{"id":"8320","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":2,"text":"저는 처녀이므로 어찌할 수 없는 줄을 알고 암논이 그 누이 다말을 인하여 심화로 병이 되니라","reference":"사무엘하 13:2","category":"$undefined"},{"id":"8321","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":3,"text":"암논에게 요나답이라 하는 친구가 있으니 저는 다윗의 형 시므아의 아들이요 심히 간교한자라","reference":"사무엘하 13:3","category":"$undefined"},{"id":"8322","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":4,"text":"저가 암논에게 이르되 `왕자여 어찌하여 나날이 이렇게 파리하여 가느뇨 내게 고하지 아니하겠느뇨 ?' 암논이 말하되 `내가 아우 압살롬의 누이 다말을 연애함이니라'","reference":"사무엘하 13:4","category":"$undefined"},{"id":"8323","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":5,"text":"요나답이 저에게 이르되 `침상에 누워 병든 체하다가 네 부친이 너를 보러 오거든 너는 말하기를 청컨대 내 누이 다말로 와서 내게 식물을 먹이되 나 보는데서 식물을 차려 그 손으로 먹여 주게 하옵소서 하라'","reference":"사무엘하 13:5","category":"$undefined"},{"id":"8324","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":6,"text":"암논이 곧 누워 병든 체하다가 왕이 와서 저를 볼 때에 왕께 고하되 `청컨대 내 누이 다말로 와서 내가 보는데서 과자 두어개를 만들어 그 손으로 내게 먹여 주게 하옵소서'","reference":"사무엘하 13:6","category":"$undefined"},{"id":"8325","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":7,"text":"다윗이 사람을 그 집으로 보내어 다말에게 이르되 `네 오라비 암논의 집으로 가서 저를 위하여 음식을 차리라' 한지라","reference":"사무엘하 13:7","category":"$undefined"},{"id":"8326","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":8,"text":"다말이 그 오라비 암논의 집에 이르매 암논이 누었더라 다말이 밀가루를 가지고 반죽하여 그 보는 데서 과자를 만들고 그 과자를 굽고","reference":"사무엘하 13:8","category":"$undefined"},{"id":"8327","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":9,"text":"그 남비를 가져다가 그 앞에 쏟아 놓아도 암논이 먹기를 싫어하고 가로되 `모든 사람을 나가게 하라' 하니 다 저를 떠나 나가니라","reference":"사무엘하 13:9","category":"$undefined"},{"id":"8328","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":10,"text":"암논이 다말에게 이르되 `식물을 가지고 침실로 들어오라 내가 네 손에서 먹으리라' 다말이 자기의 만든 과자를 가지고 침실에 들어가 그 오라비 암논에게 이르러","reference":"사무엘하 13:10","category":"$undefined"},{"id":"8329","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":11,"text":"저에게 먹이려고 가까이 가지고 갈 때에 암논이 그를 붙잡고 이르되 `누이야 와서 나와 동침하자'","reference":"사무엘하 13:11","category":"$undefined"},{"id":"8330","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":12,"text":"저가 대답하되 `아니라 내 오라비여 나를 욕되게 말라 이런 일은 이스라엘에서 마땅히 행치 못할 것이니 이 괴악한 일을 행치 말라","reference":"사무엘하 13:12","category":"$undefined"},{"id":"8331","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":13,"text":"내가 이 수치를 무릅쓰고 어디로 가겠느냐 ? 너도 이스라엘에서 괴악한 자 중 하나가 되리라 청컨대 왕께 말하라 저가 나를 네게 주기를 거절치 아니하시리라' 하되","reference":"사무엘하 13:13","category":"$undefined"},{"id":"8332","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":14,"text":"암논이 그 말을 듣지 아니하고 다말보다 힘이 세므로 억지로 동침하니라","reference":"사무엘하 13:14","category":"$undefined"},{"id":"8333","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":15,"text":"그리하고 암논이 저를 심히 미워하니 이제 미워하는 미움이 이왕 연애하던 연애보다 더한지라 곧 저에게 이르되 `일어나 가라'","reference":"사무엘하 13:15","category":"$undefined"},{"id":"8334","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":16,"text":"다말이 가로되 `가치 아니하다 나를 쫓아 보내는 이 큰 악은 아까 내게 행한 그 악보다 더하다' 하되 암논이 듣지 아니하고","reference":"사무엘하 13:16","category":"$undefined"},{"id":"8335","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":17,"text":"그 부리는 종을 불러 이르되 `이 계집을 내어보내고 곧 문빗장을 지르라` 하니","reference":"사무엘하 13:17","category":"$undefined"},{"id":"8336","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":18,"text":"암논의 하인이 저를 끌어내고 곧 문빗장을 지르니라 다말이 채색옷을 입었으니 출가하지 아니한 공주는 이런 옷으로 단장하는 법이라","reference":"사무엘하 13:18","category":"$undefined"},{"id":"8337","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":19,"text":"다말이 재를 그 머리에 무릅쓰고 그 채색옷을 찢고 손을 머리 위에 얹고 크게 울며 가니라","reference":"사무엘하 13:19","category":"$undefined"},{"id":"8338","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":20,"text":"그 오라비 압살롬이 저에게 이르되 `네 오라비 암논이 너와 함께 있었느냐 ? 그러나 저는 네 오라비니 누이야 시방은 잠잠히 있고 이것으로 인하여 근심하지 말라' 이에 다말이 그 오라비 압살롬의 집에 있어 처량하게 지내니라","reference":"사무엘하 13:20","category":"$undefined"},{"id":"8339","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":21,"text":"다윗 왕이 이 모든 일을 듣고 심히 노하니라","reference":"사무엘하 13:21","category":"$undefined"},{"id":"8340","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":22,"text":"압살롬이 그 누이 다말을 암논이 욕되게 하였으므로 저를 미워하여 시비간에 말하지 아니하니라","reference":"사무엘하 13:22","category":"$undefined"},{"id":"8341","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":23,"text":"이 주년 후에 에브라임 곁 바알하솔에서 압살롬의 양털을 깎는 일이 있으매 압살롬이 왕의 모든 아들을 청하고","reference":"사무엘하 13:23","category":"$undefined"},{"id":"8342","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":24,"text":"왕께 나아와 말하되 `이제 종에게 양털 깎는 일이 있사오니 청컨대 왕은 신복들을 데리시고 이 종과 함께 가사이다'","reference":"사무엘하 13:24","category":"$undefined"},{"id":"8343","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":25,"text":"왕이 압살롬에게 이르되 `아니라 내 아들아 우리가 다 갈 것이 없다 네게 누를 끼칠까 하노라' 압살롬이 간청하되 저가 가지 아니하고 위하여 복을 비는지라","reference":"사무엘하 13:25","category":"$undefined"},{"id":"8344","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":26,"text":"압살롬이 가로되 `그렇게 아니하시려거든 청컨대 내 형 암논으로 우리와 함께 가게 하옵소서' 왕이 저에게 이르되 `그가 너와 함께 갈 것이 무엇이냐 ?' 하되","reference":"사무엘하 13:26","category":"$undefined"},{"id":"8345","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":27,"text":"압살롬이 간청하매 왕이 암논과 왕의 모든 아들을 저와 함께 보내니라","reference":"사무엘하 13:27","category":"$undefined"},{"id":"8346","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":28,"text":"압살롬이 이미 그 사환들에게 분부하여 이르기를 `너희는 암논의 마음이 술로 즐거워할 때를 자세히 보다가 내가 너희에게 암논을 치라 하거든 저를 죽이라 두려워 말라 내가 너희에게 명한 것이 아니냐 ? 너희는 담대히 용맹을 내라' 한지라","reference":"사무엘하 13:28","category":"$undefined"},{"id":"8347","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":29,"text":"압살롬의 사환들이 그 분부대로 암논에게 행하매 왕의 모든 아들이 일어나 각기 노새를 타고 도망하니라","reference":"사무엘하 13:29","category":"$undefined"},{"id":"8348","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":30,"text":"저희가 길에 있을 때에 압살롬이 왕의 모든 아들을 죽이고 하나도 남기지 아니하였다는 소문이 다윗에게 이르매","reference":"사무엘하 13:30","category":"$undefined"},{"id":"8349","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":31,"text":"왕이 곧 일어나서 그 옷을 찢고 땅에 엎드러지고 그 신복들도 다 옷을 찢고 모셔 선지라","reference":"사무엘하 13:31","category":"$undefined"},{"id":"8350","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":32,"text":"다윗의 형 시므아의 아들 요나답이 고하여 가로되 `내 주여 소년 왕자들이 다 죽임을 당한 줄로 생각지 마옵소서 오직 암논만 죽었으리이다 저가 압살롬의 누이 다말을 욕되게 한 날부터 압살롬이 결심한 것이니이다","reference":"사무엘하 13:32","category":"$undefined"},{"id":"8351","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":33,"text":"그러하온즉 내 주 왕이여 ! 왕자들이 다 죽은줄로 생각하여 괘념(掛念)하지 마옵소서 암논만 죽었으리이다'","reference":"사무엘하 13:33","category":"$undefined"},{"id":"8352","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":34,"text":"이에 압살롬은 도망하니라 파수하는 소년이 눈을 들어 보니 뒷산 언덕길로 여러 사람이 오더라","reference":"사무엘하 13:34","category":"$undefined"},{"id":"8353","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":35,"text":"요나답이 왕께 고하되 `왕자들이 오나이다 종의 말한대로 되었나이다'","reference":"사무엘하 13:35","category":"$undefined"},{"id":"8354","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":36,"text":"말을 마치자 왕자들이 이르러 대성통곡하니 왕과 그 모든 신복도 심히 통곡하니라","reference":"사무엘하 13:36","category":"$undefined"},{"id":"8355","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":37,"text":"압살롬은 도망하여 그술 왕 암미훌의 아들 달매에게로 갔고 다윗은 날마다 그 아들을 인하여 슬퍼하니라","reference":"사무엘하 13:37","category":"$undefined"},{"id":"8356","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":38,"text":"압살롬이 도망하여 그술로 가서 거한지 삼년이라","reference":"사무엘하 13:38","category":"$undefined"},{"id":"8357","book":"사무엘하","book_name":"사무엘하","chapter":13,"verse":39,"text":"다윗 왕의 마음이 압살롬에게 향하여 간절하니 암논은 이미 죽었으므로 왕이 위로를 받았음이더라","reference":"사무엘하 13:39","category":"$undefined"}],"bookSlug":"2samuel"}]
