2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":15,"verses":[{"id":"8391","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":1,"text":"이 후에 압살롬이 자기를 위하여 병거와 말들을 준비하고 전배(前倍) 오십명을 세우니라","reference":"사무엘하 15:1","category":"$undefined"},{"id":"8392","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":2,"text":"압살롬이 일찌기 일어나 성문길 곁에 서서 어떤 사람이든지 송사가 있어 왕에게 재판을 청하러 올 때에 그 사람을 불러서 이르되 `너는 어느 성 사람이냐' 그 사람의 대답이 `종은 이스라엘 아무 지파에 속하였나이다' 하면","reference":"사무엘하 15:2","category":"$undefined"},{"id":"8393","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":3,"text":"압살롬이 저에게 이르기를 `네 일이 옳고 바르다마는 네 송사 들을 사람을 왕께서 세우지 아니하셨다' 하고","reference":"사무엘하 15:3","category":"$undefined"},{"id":"8394","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":4,"text":"또 이르기를 `내가 이 땅에서 재판관이 되고 누구든지 송사나 재판 할 일이 있어 내게로 오는 자에게 내가 공의 베풀기를 원하노라' 하고","reference":"사무엘하 15:4","category":"$undefined"},{"id":"8395","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":5,"text":"사람이 가까이 와서 절하려 하면 압살롬이 손을 펴서 그 사람을 붙들고 입을 맞추니","reference":"사무엘하 15:5","category":"$undefined"},{"id":"8396","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":6,"text":"무릇 이스라엘 무리 중에 왕께 재판을 청하러 오는 자들에게 압살롬의 행함이 이 같아서 이스라엘 사람의 마음을 도적하니라","reference":"사무엘하 15:6","category":"$undefined"},{"id":"8397","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":7,"text":"사년만에 압살롬이 왕께 고하되 `내가 여호와께 서원한 것이 있사오니 청컨대 나로 헤브론에 가서 그 서원을 이루게 하소서","reference":"사무엘하 15:7","category":"$undefined"},{"id":"8398","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":8,"text":"종이 아람 그술에 있을 때에 서원하기를 만일 여호와께서 나를 예루살렘으로 돌아가게 하시면 내가 여호와를 섬기리이다' 하였나이다","reference":"사무엘하 15:8","category":"$undefined"},{"id":"8399","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":9,"text":"왕이 저에게 이르되 `평안히 가라' 하니 저가 일어나 헤브론으로 가니라","reference":"사무엘하 15:9","category":"$undefined"},{"id":"8400","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":10,"text":"이에 압살롬이 정탐을 이스라엘 모든 지파 가운데 두루 보내어 이르기를 `너희는 나팔소리를 듣거든 곧 부르기를 압살롬이 헤브론에서 왕이 되었다 하라' 하니라","reference":"사무엘하 15:10","category":"$undefined"},{"id":"8401","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":11,"text":"그 때에 압살롬에게 청함을 받은 이백명이 그 사기를 알지 못하고 아무 뜻 없이 예루살렘에서 저와 함께 갔으며","reference":"사무엘하 15:11","category":"$undefined"},{"id":"8402","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":12,"text":"제사 드릴 때에 압살롬이 사람을 보내어 다윗의 모사 길로 사람 아히도벨을 그 성읍 길로에서 청하여 온지라 반역하는 일이 커 가매 압살롬에게로 돌아오는 백성이 많아지니라","reference":"사무엘하 15:12","category":"$undefined"},{"id":"8403","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":13,"text":"사자가 다윗에게 와서 고하되 `이스라엘의 인심이 다 압살롬에게로 돌아갔나이다' 한지라","reference":"사무엘하 15:13","category":"$undefined"},{"id":"8404","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":14,"text":"다윗이 예루살렘에 함께 있는 모든 신복에게 이르되 `일어나 도망하자 그렇지 아니하면 우리 한사람도 압살롬에게서 피하지 못하리라 빨리 가자 두렵건대 저가 우리를 급히 따라와서 해하고 칼로 성을 칠까 하노라'","reference":"사무엘하 15:14","category":"$undefined"},{"id":"8405","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":15,"text":"왕의 신복들이 왕께 고하되 `우리 주 왕의 하고자 하시는 대로 우리가 행하리이다' 하더라","reference":"사무엘하 15:15","category":"$undefined"},{"id":"8406","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":16,"text":"왕이 나갈 때에 권속을 다 따르게 하고 후궁 열명을 남겨 두어 궁을 지키게 하니라","reference":"사무엘하 15:16","category":"$undefined"},{"id":"8407","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":17,"text":"왕이 나가매 모든 백성이 다 따라서 벧메르학에 이르러 머무니","reference":"사무엘하 15:17","category":"$undefined"},{"id":"8408","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":18,"text":"모든 신복이 그 곁으로 지나가고 모든 그렛 사람과 모든 블렛 사람과 및 왕을 따라 가드에서 온 육백인이 왕의 앞으로 진행하니라","reference":"사무엘하 15:18","category":"$undefined"},{"id":"8409","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":19,"text":"그 때에 왕이 가드 사람 잇대에게 이르되 `어찌하여 너도 우리와 함께 가느냐 ? 너는 쫓겨난 나그네니 돌아가서 왕과 함께 네 곳에 있으라","reference":"사무엘하 15:19","category":"$undefined"},{"id":"8410","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":20,"text":"너는 어제 왔고 나는 정처 없이 가니 오늘날 어찌 너로 우리와 함께 유리하게 하리요 너도 돌아가고 네 동포들도 데려가라 은혜와 진리가 너와 함께 있기를 원하노라 !'","reference":"사무엘하 15:20","category":"$undefined"},{"id":"8411","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":21,"text":"잇대가 왕께 대답하여 가로되 `여호와의 사심과 우리 주 왕의 사심으로 맹세하옵나니 진실로 내 주 왕께서 어느 곳에 계시든지 무론 사생하고 종도 그곳에 있겠나이다 !'","reference":"사무엘하 15:21","category":"$undefined"},{"id":"8412","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":22,"text":"다윗이 잇대에게 이르되 `앞서 건너가라` 하매 가드 사람 잇대와 그 종자들과 그와 함께 한 아이들이 다 건너가고","reference":"사무엘하 15:22","category":"$undefined"},{"id":"8413","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":23,"text":"온 땅 사람이 대성통곡하며 모든 인민이 앞서 건너가매 왕도 기드론 시내를 건너가니 건너간 모든 백성이 광야 길로 향하니라","reference":"사무엘하 15:23","category":"$undefined"},{"id":"8414","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":24,"text":"사독과 그와 함께 한 모든 레위 사람이 하나님의 언약궤를 메어다가 내려놓고 아비아달도 올라와서 모든 백성이 성에서 나오기를 기다리더니","reference":"사무엘하 15:24","category":"$undefined"},{"id":"8415","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":25,"text":"왕이 사독에게 이르되 `하나님의 궤를 성으로 도로 메어 가라 만일 내가 여호와 앞에서 은혜를 얻으면 도로 나를 인도하사 내게 그 궤와 그 계신 데를 보이시리라","reference":"사무엘하 15:25","category":"$undefined"},{"id":"8416","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":26,"text":"그러나 저가 말씀하시기를 내가 너를 기뻐하지 아니한다 하시면 종이 여기 있사오니 선히 여기시는 대로 내게 행하시옵소서 하리라'","reference":"사무엘하 15:26","category":"$undefined"},{"id":"8417","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":27,"text":"왕이 또 제사장 사독에게 이르되 `네가 선견자가 아니냐 ? 너는 너희의 두 아들 곧 네 아들 아히마아스와 아비아달의 아들 요나단을 데리고 평안히 성으로 돌아가라","reference":"사무엘하 15:27","category":"$undefined"},{"id":"8418","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":28,"text":"너희에게서 내게 고하는 기별이 올 때까지 내가 광야 나룻터에서 기다리리라'","reference":"사무엘하 15:28","category":"$undefined"},{"id":"8419","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":29,"text":"사독과 아비아달이 하나님의 궤를 예루살렘으로 도로 메어다 놓고 거기 유하니라","reference":"사무엘하 15:29","category":"$undefined"},{"id":"8420","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":30,"text":"다윗이 감람산 길로 올라갈 때에 머리를 가리우고 맨발로 울며 행하고 저와 함께 가는 백성들도 각각 그 머리를 가리우고 울며 올라가니라","reference":"사무엘하 15:30","category":"$undefined"},{"id":"8421","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":31,"text":"혹이 다윗에게 고하되 `압살롬과 함께 모반한 자들 가운데 아히도벨이 있나이다' 하니 다윗이 가로되 `여호와여, 원컨대 아히도벨의 모략을 어리석게 하옵소서' 하니라","reference":"사무엘하 15:31","category":"$undefined"},{"id":"8422","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":32,"text":"다윗이 하나님을 경배하는 마루턱에 이를 때에 아렉 사람 후새가 옷을 찢고 흙을 머리에 무릅쓰고 다윗을 맞으러 온지라","reference":"사무엘하 15:32","category":"$undefined"},{"id":"8423","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":33,"text":"다윗이 저에게 이르되 `네가 만일 나와 함께 나아가면 내게 누를 끼치리라","reference":"사무엘하 15:33","category":"$undefined"},{"id":"8424","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":34,"text":"그러나 네가 만일 성으로 돌아가서 압살롬에게 말하기를 왕이여 ! 내가 왕의 종이니이다 이왕에는 왕의 부친의 종이었더니 내가 이제는 왕의 종이니이다 하면 네가 나를 위하여 아히도벨의 모략을 패하게 하리라","reference":"사무엘하 15:34","category":"$undefined"},{"id":"8425","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":35,"text":"사독과 아비아달 두 제사장이 너와 함께 거기 있지 아니하냐 네가 궁중에서 무엇을 듣든지 사독과 아비아달 두 제사장에게 고하라","reference":"사무엘하 15:35","category":"$undefined"},{"id":"8426","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":36,"text":"저희의 두 아들 곧 사독의 아히마아스와 아비아달의 요나단이 저희와 함께 거기 있나니 무릇 너희 듣는 것을 저희 편으로 내게 기별할지니라'","reference":"사무엘하 15:36","category":"$undefined"},{"id":"8427","book":"사무엘하","book_name":"사무엘하","chapter":15,"verse":37,"text":"다윗의 친구 후새가 곧 성으로 들어가고 압살롬도 예루살렘으로 들어갔더라","reference":"사무엘하 15:37","category":"$undefined"}],"bookSlug":"2samuel"}]
