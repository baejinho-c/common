11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":22,"verses":[{"id":"8604","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":1,"text":"여호와께서 다윗을 모든 대적의 손과 사울의 손에서 구원하신 그 날에 다윗이 이 노래의 말씀으로 여호와께 아뢰어","reference":"사무엘하 22:1","category":"$undefined"},{"id":"8605","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":2,"text":"가로되 여호와는 나의 반석이시요, 나의 요새시요, 나를 건지시는 자시요,","reference":"사무엘하 22:2","category":"$undefined"},{"id":"8606","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":3,"text":"나의 하나님이시요, 나의 피할 바위시요, 나의 방패시요, 나의 구원의 뿔이시요, 나의 높은 망대시요, 나의 피난처시요, 나의 구원자시라 ! 나를 흉악에서 구원하셨도다","reference":"사무엘하 22:3","category":"$undefined"},{"id":"8607","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":4,"text":"내가 찬송받으실 여호와께 아뢰리니 내 원수들에게서 구원을 얻으리로다","reference":"사무엘하 22:4","category":"$undefined"},{"id":"8608","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":5,"text":"사망의 물결이 나를 에우고 불의의 창수가 나를 두렵게 하였으며","reference":"사무엘하 22:5","category":"$undefined"},{"id":"8609","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":6,"text":"음부의 줄이 나를 두르고 사망의 올무가 내게 이르렀도다","reference":"사무엘하 22:6","category":"$undefined"},{"id":"8610","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":7,"text":"내가 환난 중에서 여호와께 아뢰며 나의 하나님께 아뢰었더니 저가 그 전에서 내 소리를 들으심이여 나의 부르짖음이 그 귀에 들렸도다","reference":"사무엘하 22:7","category":"$undefined"},{"id":"8611","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":8,"text":"이에 땅이 진동하고 떨며 하늘 기초가 요동하고 흔들렸으니 그의 진노를 인함이로다","reference":"사무엘하 22:8","category":"$undefined"},{"id":"8612","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":9,"text":"그 코에서 연기가 오르고 입에서 불이 나와 사름이여 그 불에 숯이 피었도다","reference":"사무엘하 22:9","category":"$undefined"},{"id":"8613","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":10,"text":"저가 또 하늘을 드리우고 강림하시니 그 발 아래는 어둑캄캄하도다","reference":"사무엘하 22:10","category":"$undefined"},{"id":"8614","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":11,"text":"그룹을 타고 날으심이여 ! 바람 날개 위에 나타나셨도다","reference":"사무엘하 22:11","category":"$undefined"},{"id":"8615","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":12,"text":"저가 흑암 곧 모인 물과 공중의 빽빽한 구름으로 둘린 장막을 삼으심이여 !","reference":"사무엘하 22:12","category":"$undefined"},{"id":"8616","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":13,"text":"그 앞에 있는 광채로 인하여 숯불이 피었도다","reference":"사무엘하 22:13","category":"$undefined"},{"id":"8617","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":14,"text":"여호와께서 하늘에서 뇌성을 발하시며 지존하신 자가 음성을 내심이여 !","reference":"사무엘하 22:14","category":"$undefined"},{"id":"8618","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":15,"text":"살을 날려 저희를 흩으시며 번개로 파하셨도다","reference":"사무엘하 22:15","category":"$undefined"},{"id":"8619","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":16,"text":"이럴 때에 여호와의 꾸지람과 콧김을 인하여 물 밑이 드러나고 땅의 기초가 나타났도다","reference":"사무엘하 22:16","category":"$undefined"},{"id":"8620","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":17,"text":"저가 위에서 보내사 나를 취하심이여 많은 물에서 나를 건져내셨도다","reference":"사무엘하 22:17","category":"$undefined"},{"id":"8621","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":18,"text":"나를 강한 원수와 미워하는 자에게서 건지셨음이여 ! 저희는 나보다 힘센 연고로다","reference":"사무엘하 22:18","category":"$undefined"},{"id":"8622","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":19,"text":"저희가 나의 재앙의 날에 내게 이르렀으나 여호와께서 나의 의지가 되셨도다","reference":"사무엘하 22:19","category":"$undefined"},{"id":"8623","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":20,"text":"나를 또 넓은 곳으로 인도하시고 나를 기뻐하시므로 구원하셨도다","reference":"사무엘하 22:20","category":"$undefined"},{"id":"8624","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":21,"text":"여호와께서 내 의를 따라 상 주시며 내 손의 깨끗함을 좇아 갚으셨으니","reference":"사무엘하 22:21","category":"$undefined"},{"id":"8625","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":22,"text":"이는 내가 여호와의 도를 지키고 악을 행하여 내 하나님을 떠나지 아니하였으며","reference":"사무엘하 22:22","category":"$undefined"},{"id":"8626","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":23,"text":"그 모든 규례를 내 앞에 두고 그 율례를 버리지 아니하였음이로다","reference":"사무엘하 22:23","category":"$undefined"},{"id":"8627","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":24,"text":"내가 또 그 앞에 완전하여 스스로 지켜 죄악을 피하였나니","reference":"사무엘하 22:24","category":"$undefined"},{"id":"8628","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":25,"text":"그러므로 여호와께서 내 의대로, 그 목전에 내 깨끗한 대로 내게 갚으셨도다","reference":"사무엘하 22:25","category":"$undefined"},{"id":"8629","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":26,"text":"자비한 자에게는 주의 자비하심을 나타내시며 완전한 자에게는 주의 완전하심을 보이시며","reference":"사무엘하 22:26","category":"$undefined"},{"id":"8630","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":27,"text":"깨끗한 자에게는 주의 깨끗하심을 보이시며 사특한 자에게는 주의 거스리심을 보이시리이다","reference":"사무엘하 22:27","category":"$undefined"},{"id":"8631","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":28,"text":"주께서 곤고한 백성은 구원하시고 교만한 자를 살피사 낮추시리이다","reference":"사무엘하 22:28","category":"$undefined"},{"id":"8632","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":29,"text":"여호와여, 주는 나의 등불이시니 여호와께서 나의 흑암을 밝히시리이다","reference":"사무엘하 22:29","category":"$undefined"},{"id":"8633","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":30,"text":"내가 주를 의뢰하고 적군에 달리며 내 하나님을 의지하고 성벽을 뛰어 넘나이다","reference":"사무엘하 22:30","category":"$undefined"},{"id":"8634","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":31,"text":"하나님의 도는 완전하고 여호와의 말씀은 정미하니 저는 자기에게 피하는 모든 자에게 방패시로다","reference":"사무엘하 22:31","category":"$undefined"},{"id":"8635","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":32,"text":"여호와 외에 누가 하나님이며 우리 하나님 외에 누가 바위뇨","reference":"사무엘하 22:32","category":"$undefined"},{"id":"8636","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":33,"text":"하나님은 나의 견고한 요새시며 나를 온전한 곳으로 인도하시며","reference":"사무엘하 22:33","category":"$undefined"},{"id":"8637","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":34,"text":"나의 발로 암사슴 발 같게 하시며 나를 나의 높은 곳에 세우시며","reference":"사무엘하 22:34","category":"$undefined"},{"id":"8638","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":35,"text":"내 손을 가르쳐 싸우게 하시니 내 팔이 놋활을 당기도다","reference":"사무엘하 22:35","category":"$undefined"},{"id":"8639","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":36,"text":"주께서 또 주의 구원의 방패를 내게 주시며 주의 온유함이 나를 크게 하셨나이다","reference":"사무엘하 22:36","category":"$undefined"},{"id":"8640","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":37,"text":"내 걸음을 넓게 하셨고 나로 실족지 않게 하셨나이다","reference":"사무엘하 22:37","category":"$undefined"},{"id":"8641","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":38,"text":"내가 내 원수를 따라 멸하였사오며 저희를 무찌르기 전에는 돌이키지 아니하였나이다","reference":"사무엘하 22:38","category":"$undefined"},{"id":"8642","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":39,"text":"내가 저희를 무찔러 파하였더니 저희가 내 발 아래 엎드러지고 능히 일어나지 못하였나이다","reference":"사무엘하 22:39","category":"$undefined"},{"id":"8643","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":40,"text":"이는 주께서 나로 전쟁케 하려고 능력으로 내게 띠 띠우사 일어나 나를 치는 자로 내게 굴복케 하셨사오며","reference":"사무엘하 22:40","category":"$undefined"},{"id":"8644","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":41,"text":"주께서 또 내 원수들로 등을 내게로 향하게 하시고 나로 나를 미워하는 자를 끊어버리게 하셨음이니이다","reference":"사무엘하 22:41","category":"$undefined"},{"id":"8645","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":42,"text":"저희가 둘러보아도 구원할 자가 없었고 여호와께 부르짖어도 대답지 아니하셨나이다","reference":"사무엘하 22:42","category":"$undefined"},{"id":"8646","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":43,"text":"내가 저희를 땅의 티끌같이 부스러뜨리고 거리의 진흙같이 밟아 헤쳤나이다","reference":"사무엘하 22:43","category":"$undefined"},{"id":"8647","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":44,"text":"주께서 또 나를 내 백성의 다툼에서 건지시고 나를 보존하사 열방의 으뜸을 삼으셨으니 내가 알지 못하는 백성이 나를 섬기리이다","reference":"사무엘하 22:44","category":"$undefined"},{"id":"8648","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":45,"text":"이방인들이 내게 굴복함이여 ! 저희가 내 풍성을 듣고 곧 순복하리로다","reference":"사무엘하 22:45","category":"$undefined"},{"id":"8649","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":46,"text":"이방인들이 쇠미하여 그 견고한 곳에서 떨며 나오리로다","reference":"사무엘하 22:46","category":"$undefined"},{"id":"8650","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":47,"text":"여호와는 생존하시니 나의 바위를 찬송하며 내 구원의 바위이신 하나님을 높일지로다 !","reference":"사무엘하 22:47","category":"$undefined"},{"id":"8651","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":48,"text":"이 하나님이 나를 위하여 보수하시고 민족들로 내게 복종케 하시며","reference":"사무엘하 22:48","category":"$undefined"},{"id":"8652","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":49,"text":"나를 원수들에게서 나오게 하시며 나를 대적하는 자 위에 나를 드시고 나를 강포한 자에게서 건지시는도다","reference":"사무엘하 22:49","category":"$undefined"},{"id":"8653","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":50,"text":"이러므로 여호와여 내가 열방 중에서 주께 감사하며 주의 이름을 찬양하리이다 !","reference":"사무엘하 22:50","category":"$undefined"},{"id":"8654","book":"사무엘하","book_name":"사무엘하","chapter":22,"verse":51,"text":"여호와께서 그 왕에게 큰 구원을 주시며 기름 부음 받은 자에게 인자를 베푸심이여 ! 영원토록 다윗과 그 후손에게로다 하였더라","reference":"사무엘하 22:51","category":"$undefined"}],"bookSlug":"2samuel"}]
