11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":23,"verses":[{"id":"8655","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":1,"text":"이는 다윗의 마지막 말이라 이새의 아들 다윗이 말함이여 높이 올리운 자,야곱의 하나님에게 기름 부음 받은자 이스라엘의 노래 잘하는 자가 말하도다","reference":"사무엘하 23:1","category":"$undefined"},{"id":"8656","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":2,"text":"여호와의 신이 나를 빙자하여 말씀하심이여 그 말씀이 내 혀에 있도다","reference":"사무엘하 23:2","category":"$undefined"},{"id":"8657","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":3,"text":"이스라엘의 하나님이 말씀하시며 이스라엘의 바위가 내게 이르시기를 사람을 공의로 다스리는 자,하나님을 경외함으로 다스리는 자여 !","reference":"사무엘하 23:3","category":"$undefined"},{"id":"8658","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":4,"text":"저는 돋는 해 아침 빛 같고 구름 없는 아침 같고 비 후의 광선으로 땅에서 움이 돋는 새 풀 같으니라 하시도다","reference":"사무엘하 23:4","category":"$undefined"},{"id":"8659","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":5,"text":"내 집이 하나님 앞에 이같지 아니하냐 하나님이 나로 더불어 영원한 언약을 세우사 만사에 구비하고 견고케 하셨으니 나의 모든 구원과 나의 모든 소원을 어찌 이루지 아니하시랴","reference":"사무엘하 23:5","category":"$undefined"},{"id":"8660","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":6,"text":"그러나 사악한 자는 다 내어 버리울 가시나무 같으니 이는 손으로 잡을 수 없음이로다","reference":"사무엘하 23:6","category":"$undefined"},{"id":"8661","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":7,"text":"그것들을 만지는 자는 철과 창자루를 가져야 하리니 그것들이 당장에 불사르이리로다 하니라","reference":"사무엘하 23:7","category":"$undefined"},{"id":"8662","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":8,"text":"다윗의 용사들의 이름이 이러하니라 다그몬 사람 요셉밧세벳이라고도 하고 에센 사람 아디노라고도 하는 자는 군장의 두목이라 저가 한 때에 팔백인을 쳐 죽였더라","reference":"사무엘하 23:8","category":"$undefined"},{"id":"8663","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":9,"text":"그 다음은 아호아 사람 도대의 아들 엘르아살이니 다윗과 함께 한 세 용사 중에 하나이라 블레셋 사람이 싸우려고 모이매 이스라엘 사람들이 물러간지라 세 용사가 싸움을 돋우고","reference":"사무엘하 23:9","category":"$undefined"},{"id":"8664","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":10,"text":"저가 나가서 손이 피곤하여 칼에 붙기까지 블레셋 사람을 치니라 그 날에 여호와께서 크게 이기게 하셨으므로 백성들은 돌아와서 저의 뒤를 따라가며 노략할 뿐이었더라","reference":"사무엘하 23:10","category":"$undefined"},{"id":"8665","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":11,"text":"그 다음은 하랄 사람 아게의 아들 삼마라 블레셋 사람이 떼를 지어 녹두나무가 가득한 밭에 모이매 백성들은 블레셋 사람 앞에서 도망하되","reference":"사무엘하 23:11","category":"$undefined"},{"id":"8666","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":12,"text":"저는 그 밭 가운데 서서 막아 블레셋 사람을 친지라 여호와께서 큰 구원을 이루시니라","reference":"사무엘하 23:12","category":"$undefined"},{"id":"8667","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":13,"text":"또 삼십 두목 중 세 사람이 곡식 벨 때에 아둘람 굴에 이르러 다윗에게 나아갔는데 때에 블레셋 사람의 떼가 르바임 골짜기에 진쳤더라","reference":"사무엘하 23:13","category":"$undefined"},{"id":"8668","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":14,"text":"그 때에 다윗은 산성에 있고 블레셋 사람의 영채는 베들레헴에 있는지라","reference":"사무엘하 23:14","category":"$undefined"},{"id":"8669","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":15,"text":"다윗이 사모하여 가로되 `베들레헴 성문 곁 우물 물을 누가 나로 마시게 할꼬' 하매","reference":"사무엘하 23:15","category":"$undefined"},{"id":"8670","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":16,"text":"세 용사가 블레셋 사람의 군대를 충돌하고 지나가서 베들레헴 성문 곁 우물 물을 길어 가지고 다윗에게로 왔으나 다윗이 마시기를 기뻐 아니하고 그 물을 여호와께 부어 드리며","reference":"사무엘하 23:16","category":"$undefined"},{"id":"8671","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":17,"text":"가로되 `여호와여, 내가 결단코 이런 일을 하지 아니하리이다 이는 생명을 돌아보지 아니하고 갔던 사람들의 피니이다' 하고 마시기를 즐겨 아니하니라 세 용사가 이런 일을 행하였더라","reference":"사무엘하 23:17","category":"$undefined"},{"id":"8672","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":18,"text":"또 스루야의 아들 요압의 아우 아비새니 저는 그 삼인의 두목이라 저가 창을 들어 삼백인을 죽이고 그 삼인 중에 이름을 얻었으니","reference":"사무엘하 23:18","category":"$undefined"},{"id":"8673","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":19,"text":"저는 삼인 중에 가장 존귀한 자가 아니냐 저가 저희의 두목이 되 었으나 그러나 첫 삼인에게는 미치지 못하였더라","reference":"사무엘하 23:19","category":"$undefined"},{"id":"8674","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":20,"text":"또 갑스엘 용사의 손자 여호야다의 아들 브나야니 저는 효용한 일을 행한 자라 일찌기 모압 아리엘의 아들 둘을 죽였고 또 눈 올 때에 함정에 내려가서 한 사자를 죽였으며","reference":"사무엘하 23:20","category":"$undefined"},{"id":"8675","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":21,"text":"또 장대한 애굽 사람을 죽였는데 그의 손에 창이 있어도 저가 막대를 가지고 내려가서 그 애굽 사람의 손에서 창을 빼앗아 그 창으로 죽였더라","reference":"사무엘하 23:21","category":"$undefined"},{"id":"8676","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":22,"text":"여호야다의 아들 브나야가 이런 일을 행하였으므로 세 용사 중에 이름을 얻고","reference":"사무엘하 23:22","category":"$undefined"},{"id":"8677","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":23,"text":"삼십인보다 존귀하나 그러나 첫 삼인에게는 미치지 못하였더라 다윗이 저를 세워 시위대 장관을 삼았더라","reference":"사무엘하 23:23","category":"$undefined"},{"id":"8678","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":24,"text":"요압의 아우 아사헬은 삼십인중에 하나요 또 베들레헴 도도의 아들 엘하난과","reference":"사무엘하 23:24","category":"$undefined"},{"id":"8679","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":25,"text":"하롯 사람 삼훗과, 하롯 사람 엘리가와","reference":"사무엘하 23:25","category":"$undefined"},{"id":"8680","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":26,"text":"발디 사람 헬레스와, 드고아 사람 익게스의 아들 이라와","reference":"사무엘하 23:26","category":"$undefined"},{"id":"8681","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":27,"text":"아나돗 사람 아비에셀과, 후사 사람 므분내와","reference":"사무엘하 23:27","category":"$undefined"},{"id":"8682","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":28,"text":"아호아 사람 살몬과, 느도바 사람 마하래와","reference":"사무엘하 23:28","category":"$undefined"},{"id":"8683","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":29,"text":"느도바 사람 바아나의 아들 헬렙과, 베냐민 자손에 속한 기브아 사람 리배의 아들 잇대와","reference":"사무엘하 23:29","category":"$undefined"},{"id":"8684","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":30,"text":"비라돈 사람 브나야와, 가아스 시냇가에 사는 힛대와","reference":"사무엘하 23:30","category":"$undefined"},{"id":"8685","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":31,"text":"아르바 사람 아비알본과, 바르훔 사람 아스마웹과","reference":"사무엘하 23:31","category":"$undefined"},{"id":"8686","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":32,"text":"사알본 사람 엘리아바와, 야센의 아들 요나단과","reference":"사무엘하 23:32","category":"$undefined"},{"id":"8687","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":33,"text":"하랄 사람 삼마와, 아랄 사람 사랄의 아들 아히암과","reference":"사무엘하 23:33","category":"$undefined"},{"id":"8688","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":34,"text":"마아가 사람의 손자 아하스배의 아들 엘리벨렛과, 길로 사람 아히도벨의 아들 엘리암과","reference":"사무엘하 23:34","category":"$undefined"},{"id":"8689","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":35,"text":"갈멜 사람 헤스래와, 아랍 사람 바아래와","reference":"사무엘하 23:35","category":"$undefined"},{"id":"8690","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":36,"text":"소바 나단의 아들 이갈과, 갓 사람 바니와","reference":"사무엘하 23:36","category":"$undefined"},{"id":"8691","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":37,"text":"암몬 사람 셀렉과, 스루야의 아들 요압의 병기 잡은 자 브에롯 사람 나하래와","reference":"사무엘하 23:37","category":"$undefined"},{"id":"8692","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":38,"text":"이델 사람 이라와, 이델 사람 가렙과","reference":"사무엘하 23:38","category":"$undefined"},{"id":"8693","book":"사무엘하","book_name":"사무엘하","chapter":23,"verse":39,"text":"헷 사람 우리아라 이상 도합이 삼십 칠인이었더라","reference":"사무엘하 23:39","category":"$undefined"}],"bookSlug":"2samuel"}]
