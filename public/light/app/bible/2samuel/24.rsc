2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":24,"verses":[{"id":"8694","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":1,"text":"여호와께서 다시 이스라엘을 향하여 진노하사 저희를 치시려고 다윗을 감동시키사 가서 이스라엘과 유다의 인구를 조사하라 하신지라","reference":"사무엘하 24:1","category":"$undefined"},{"id":"8695","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":2,"text":"왕이 이에 그 곁에 있는 군대 장관 요압에게 이르되 `너는 이스라엘 모든 지파 가운데로 다니며 단에서부터 브엘세바까지 인구를 조사하여 그 도수를 내게 알게 하라'","reference":"사무엘하 24:2","category":"$undefined"},{"id":"8696","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":3,"text":"요압이 왕께 고하되 `이 백성은 얼마든지 왕의 하나님 여호와께서 백배나 더하게 하사 내 주 왕의 눈으로 보게 하시기를 원하나이다 그런데 내 주 왕은 어찌하여 이런 일을 기뻐하시나이까' 하되","reference":"사무엘하 24:3","category":"$undefined"},{"id":"8697","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":4,"text":"왕의 명령이 요압과 군대 장관들을 재촉한지라 요압과 장관들이 이스라엘 인구를 조사하려고 왕의 앞에서 물러나서","reference":"사무엘하 24:4","category":"$undefined"},{"id":"8698","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":5,"text":"요단을 건너 갓 골짜기 가운데 성읍 아로엘 우편 곧 야셀 맞은편에 이르러 장막을 치고","reference":"사무엘하 24:5","category":"$undefined"},{"id":"8699","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":6,"text":"길르앗에 이르고 닷딤홋시 땅에 이르고 또 다냐안에 이르러서는 시돈으로 돌아서","reference":"사무엘하 24:6","category":"$undefined"},{"id":"8700","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":7,"text":"두로 견고한 성에 이르고 히위 사람과 가나안 사람의 모든 성읍에 이르고 유다 남편으로 나와서 브엘세바에 이르니라","reference":"사무엘하 24:7","category":"$undefined"},{"id":"8701","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":8,"text":"저희 무리가 국중을 두루 돌아 아홉달 스무날만에 예루살렘에 이르러","reference":"사무엘하 24:8","category":"$undefined"},{"id":"8702","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":9,"text":"요압이 인구 도수를 왕께 고하니 곧 이스라엘에서 칼을 빼는 담대한 자가 팔십만이요, 유다 사람이 오십만이었더라","reference":"사무엘하 24:9","category":"$undefined"},{"id":"8703","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":10,"text":"다윗이 인구 수를 조사한 후에 그 마음에 자책하고 여호와께 아뢰되 `내가 이 일을 행함으로 큰 죄를 범하였나이다 여호와여, 이제 간구하옵나니 종의 죄를 사하여 주옵소서 내가 심히 미련하게 행하였나이다' 하니라","reference":"사무엘하 24:10","category":"$undefined"},{"id":"8704","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":11,"text":"다윗이 아침에 일어날 때에 여호와의 말씀이 다윗의 선견자 된 선지자 갓에게 임하여 가라사대","reference":"사무엘하 24:11","category":"$undefined"},{"id":"8705","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":12,"text":"가서 다윗에게 말하기를 여호와의 말씀에 내가 네게 세가지를 보이노니 너는 그 중에서 하나를 택하라 ! 내가 그것을 네게 행하리라 하셨다 하라","reference":"사무엘하 24:12","category":"$undefined"},{"id":"8706","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":13,"text":"갓이 다윗에게 이르러 고하여 가로되 `왕의 땅에 칠년 기근이 있을 것이니이까 혹시 왕이 왕의 대적에게 쫓겨 석달을 그 앞에서 도망하실 것이니이까 혹시 왕의 땅에 삼일동안 온역이 있을 것이니이까 왕은 생각하여 보고 나를 보내신 이에게 대답하게 하소서'","reference":"사무엘하 24:13","category":"$undefined"},{"id":"8707","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":14,"text":"다윗이 갓에게 이르되 `내가 곤경에 있도다 여호와께서는 긍휼이 크시니 우리가 여호와의 손에 빠지고 내가 사람의 손에 빠지지 않기를 원하노라'","reference":"사무엘하 24:14","category":"$undefined"},{"id":"8708","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":15,"text":"이에 여호와께서 그 아침부터 정하신 때까지 온역을 이스라엘에게 내리시니 단부터 브엘세바까지 백성의 죽은 자가 칠만인이라","reference":"사무엘하 24:15","category":"$undefined"},{"id":"8709","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":16,"text":"천사가 예루살렘을 향하여 그 손을 들어 멸하려 하더니 여호와께서 이 재앙 내림을 뉘우치사 백성을 멸하는 천사에게 이르시되 족하다 이제는 네 손을 거두라 ! 하시니 때에 여호와의 사자가 여부스 사람 아라우나의 타작 마당 곁에 있는지라","reference":"사무엘하 24:16","category":"$undefined"},{"id":"8710","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":17,"text":"다윗이 백성을 치는 천사를 보고 곧 여호와께 아뢰어 가로되 `나는 범죄하였고 악을 행하였삽거니와 이 양무리는 무엇을 행하였나이까 청컨대 주의 손으로 나와 내 아비의 집을 치소서' 하니라","reference":"사무엘하 24:17","category":"$undefined"},{"id":"8711","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":18,"text":"이 날에 갓이 다윗에게 이르러 고하되 `올라가서 여부스 사람 아라우나의 타작마당에서 여호와를 위하여 단을 쌓으소서' 하매","reference":"사무엘하 24:18","category":"$undefined"},{"id":"8712","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":19,"text":"다윗이 여호와의 명하신 바 갓의 말대로 올라가니라","reference":"사무엘하 24:19","category":"$undefined"},{"id":"8713","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":20,"text":"아라우나가 바라보다가 왕과 그 신복들이 자기를 향하여 옴을 보고 나가서 왕의 앞에서 얼굴을 땅에 대고 절하며","reference":"사무엘하 24:20","category":"$undefined"},{"id":"8714","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":21,"text":"가로되 `어찌하여 내 주 왕께서 종에게 임하시나이까' 다윗이 가로되 `네게서 타작 마당을 사서 여호와께 단을 쌓아 백성에게 내리는 재앙을 그치게 하려 함이로라'","reference":"사무엘하 24:21","category":"$undefined"},{"id":"8715","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":22,"text":"아라우나가 다윗에게 고하되 `원컨대 내 주 왕은 좋게 여기시는 대로 취하여 드리소서 번제에 대하여는 소가 있고 땔 나무에 대하여는 마당질하는 제구와 소의 멍에가 있나이다","reference":"사무엘하 24:22","category":"$undefined"},{"id":"8716","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":23,"text":"왕이여 ! 아라우나가 이것을 다 왕께 드리나이다' 하고 또 왕께 고하되 `왕의 하나님 여호와께서 왕을 기쁘게 받으시기를 원하나이다'","reference":"사무엘하 24:23","category":"$undefined"},{"id":"8717","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":24,"text":"왕이 아라우나에게 이르되 `그렇지 아니하다 내가 값을 주고 네게서 사리라 값 없이는 내 하나님 여호와께 번제를 드리지 아니하리라' 하고 은 오십 세겔로 타작 마당과 소를 사고","reference":"사무엘하 24:24","category":"$undefined"},{"id":"8718","book":"사무엘하","book_name":"사무엘하","chapter":24,"verse":25,"text":"그 곳에서 여호와를 위하여 단을 쌓고 번제와 화목제를 드렸더니 이에 여호와께서 그 땅을 위하여 기도를 들으시매 이스라엘에게 내리는 재앙이 그쳤더라","reference":"사무엘하 24:25","category":"$undefined"}],"bookSlug":"2samuel"}]
