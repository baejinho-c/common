2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":5,"verses":[{"id":"8134","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":1,"text":"이스라엘 모든 지파가 헤브론에 이르러 다윗에게 나아와 말하여 가로되 `보소서 ! 우리는 왕의 골육이니이다","reference":"사무엘하 5:1","category":"$undefined"},{"id":"8135","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":2,"text":"전일 곧 사울이 우리의 왕이 되었을 때에도 이스라엘을 거느려 출입하게 한 자는 왕이시었고 여호와께서도 왕에게 말씀하시기를 네가 내 백성 이스라엘의 목자가 되며 이스라엘의 주권자가 되리라 하셨나이다' 하니라","reference":"사무엘하 5:2","category":"$undefined"},{"id":"8136","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":3,"text":"이에 이스라엘 모든 장로가 헤브론에 이르러 왕에게 나아오매 다윗 왕이 헤브론에서 여호와 앞에서 저희와 언약을 세우매 저희가 다윗에게 기름을 부어 이스라엘 왕을 삼으니라","reference":"사무엘하 5:3","category":"$undefined"},{"id":"8137","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":4,"text":"다윗이 삼십세에 위에 나아가서 사십년을 다스렸으되","reference":"사무엘하 5:4","category":"$undefined"},{"id":"8138","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":5,"text":"헤브론에서 칠년 육개월 동안 유다를 다스렸고 예루살렘에서 삼십 삼년 동안 온 이스라엘과 유다를 다스렸더라","reference":"사무엘하 5:5","category":"$undefined"},{"id":"8139","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":6,"text":"왕과 그 종자들이 예루살렘으로 가서 그 땅 거민 여부스 사람을 치려 하매 그 사람들이 다윗에게 말하여 가로되 `네가 이리로 들어 오지 못하리라 소경과 절뚝발이라도 너를 물리치리라' 하니 저희 생각에는 다윗이 이리로 들어오지 못하리라 함이나","reference":"사무엘하 5:6","category":"$undefined"},{"id":"8140","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":7,"text":"다윗이 시온 산성을 빼앗았으니 이는 다윗성이더라","reference":"사무엘하 5:7","category":"$undefined"},{"id":"8141","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":8,"text":"그 날에 다윗이 이르기를 `누구든지 여부스 사람을 치거든 수구로 올라가서 다윗의 마음에 미워하는 절뚝발이와 소경을 치라' 하였으므로 속담이 되어 이르기를 `소경과 절뚝발이는 집에 들어오지 못하리라' 하더라","reference":"사무엘하 5:8","category":"$undefined"},{"id":"8142","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":9,"text":"다윗이 그 산성에 거하여 다윗 성이라 이름하고 밀로에서부터 안으로 성을 둘러 쌓으니라","reference":"사무엘하 5:9","category":"$undefined"},{"id":"8143","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":10,"text":"만군의 하나님 여호와께서 함께 계시니 다윗이 점점 강성하여 가니라","reference":"사무엘하 5:10","category":"$undefined"},{"id":"8144","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":11,"text":"두로 왕 히람이 다윗에게 사자들과 백향목과 목수와 석수를 보내매 저희가 다윗을 위하여 집을 지으니","reference":"사무엘하 5:11","category":"$undefined"},{"id":"8145","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":12,"text":"다윗이 여호와께서 자기를 세우사 이스라엘 왕을 삼으신 것과 그 백성 이스라엘을 위하여 그 나라를 높이신 것을 아니라","reference":"사무엘하 5:12","category":"$undefined"},{"id":"8146","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":13,"text":"다윗이 헤브론에서 올라온 후에 예루살렘에서 처첩들을 더 취하였으므로 아들과 딸들이 또 다윗에게서 나니","reference":"사무엘하 5:13","category":"$undefined"},{"id":"8147","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":14,"text":"예루살렘에서 그에게서 난 자의 이름은 삼무아와, 소밥과, 나단과, 솔로몬과,","reference":"사무엘하 5:14","category":"$undefined"},{"id":"8148","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":15,"text":"입할과, 엘리수아와, 네벡과, 야비아와,","reference":"사무엘하 5:15","category":"$undefined"},{"id":"8149","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":16,"text":"엘리사마와, 엘랴다와, 엘리벨렛이었더라","reference":"사무엘하 5:16","category":"$undefined"},{"id":"8150","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":17,"text":"이스라엘이 다윗에게 기름을 부어 이스라엘 왕을 삼았다 함을 블레셋 사람이 듣고 다윗을 찾으러 다 올라오매 다윗이 듣고 요해처로 나가니라","reference":"사무엘하 5:17","category":"$undefined"},{"id":"8151","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":18,"text":"블레셋 사람이 이미 이르러 르바임 골짜기에 편만한지라","reference":"사무엘하 5:18","category":"$undefined"},{"id":"8152","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":19,"text":"다윗이 여호와께 물어 가로되 `내가 블레셋 사람에게로 올라가리이까 ? 여호와께서 저희를 내 손에 붙이시겠나이까 ?' 여호와께서 다윗에게 말씀하시되 올라가라 내가 단정코 블레셋 사람을 네 손에 붙이리라 하신지라","reference":"사무엘하 5:19","category":"$undefined"},{"id":"8153","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":20,"text":"다윗이 바알브라심에 이르러 거기서 저희를 치고 가로되 여호와께서 물을 흩음같이 내 앞에서 내 대적을 흩으셨다하므로 그 곳 이름을 바알브라심이라 칭하니라","reference":"사무엘하 5:20","category":"$undefined"},{"id":"8154","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":21,"text":"거기서 블레셋 사람들이 그 우상을 버렸으므로 다윗과 그 종자들이 치우니라","reference":"사무엘하 5:21","category":"$undefined"},{"id":"8155","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":22,"text":"블레셋 사람이 다시 올라와서 르바임 골짜기에 편만한지라","reference":"사무엘하 5:22","category":"$undefined"},{"id":"8156","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":23,"text":"다윗이 여호와께 묻자온대 가라사대 올라가지 말고 저희 뒤로 돌아서 뽕나무 수풀 맞은편에서 저희를 엄습하되","reference":"사무엘하 5:23","category":"$undefined"},{"id":"8157","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":24,"text":"뽕나무 꼭대기에서 걸음 걷는 소리가 들리거든 곧 동작하라 그 때에 여호와가 네 앞서 나아가서 블레셋 군대를 치리라 하신지라","reference":"사무엘하 5:24","category":"$undefined"},{"id":"8158","book":"사무엘하","book_name":"사무엘하","chapter":5,"verse":25,"text":"이에 다윗이 여호와의 명대로 행하여 블레셋 사람을 쳐서 게바에서 게셀까지 이르니라","reference":"사무엘하 5:25","category":"$undefined"}],"bookSlug":"2samuel"}]
