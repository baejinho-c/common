11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":7,"verses":[{"id":"8182","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":1,"text":"여호와께서 사방의 모든 대적을 파하사 왕으로 궁에 평안히 거하게 하신 때에","reference":"사무엘하 7:1","category":"$undefined"},{"id":"8183","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":2,"text":"왕이 선지자 나단에게 이르되 `볼지어다 ! 나는 백향목 궁에 거하거늘 하나님의 궤는 휘장 가운데 있도다'","reference":"사무엘하 7:2","category":"$undefined"},{"id":"8184","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":3,"text":"나단이 왕께 고하되 `여호와께서 왕과 함께 계시니 무릇 마음에 있는 바를 행하소서'","reference":"사무엘하 7:3","category":"$undefined"},{"id":"8185","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":4,"text":"그 밤에 여호와의 말씀이 나단에게 임하여 가라사대","reference":"사무엘하 7:4","category":"$undefined"},{"id":"8186","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":5,"text":"가서 내 종 다윗에게 말하기를 여호와의 말씀이 네가 나를 위하여 나의 거할 집을 건축하겠느냐 ?","reference":"사무엘하 7:5","category":"$undefined"},{"id":"8187","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":6,"text":"내가 이스라엘 자손을 애굽에서 인도하여 내던 날부터 오늘날까지 집에 거하지 아니하고 장막과 회막에 거하며 행하였나니","reference":"사무엘하 7:6","category":"$undefined"},{"id":"8188","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":7,"text":"무릇 이스라엘 자손으로 더불어 행하는 곳에서 내가 내 백성 이스라엘을 먹이라고 명한 이스라엘 어느 지파에게 내가 말하기를 너희가 어찌하여 나를 위하어 백향목 집을 건축하지 아니하였느냐고 말하였느냐","reference":"사무엘하 7:7","category":"$undefined"},{"id":"8189","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":8,"text":"그러므로 이제 내 종 다윗에게 이처럼 말하라 만군의 여호와께서 이처럼 말씀하시기를 내가 너를 목장 곧 양을 따르는 데서 취하여 내 백성 이스라엘의 주권자를 삼고","reference":"사무엘하 7:8","category":"$undefined"},{"id":"8190","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":9,"text":"네가 어디를 가든지 내가 너와 함께 있어 네 모든 대적을 네 앞에서 멸하였은즉 세상에서 존귀한 자의 이름같이 네 이름을 존귀케 만들어 주리라","reference":"사무엘하 7:9","category":"$undefined"},{"id":"8191","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":10,"text":"내가 또 내 백성 이스라엘을 위하여 한 곳을 정하여 저희를 심고 저희로 자기 곳에 거하여 다시 옮기지 않게 하며 악한 유로 전과 같이 저희를 해하지 못하게 하여","reference":"사무엘하 7:10","category":"$undefined"},{"id":"8192","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":11,"text":"전에 내가 사사를 명하여 내 백성 이스라엘을 다스리던 때와 같지 않게 하고 너를 모든 대적에게서 벗어나 평안케 하리라 여호와가 또 네게 이르노니 여호와가 너를 위하여 집을 이루고","reference":"사무엘하 7:11","category":"$undefined"},{"id":"8193","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":12,"text":"네 수한이 차서 네 조상들과 함께 잘 때에 내가 네 몸에서 날 자식을 네 뒤에 세워 그 나라를 견고케 하리라","reference":"사무엘하 7:12","category":"$undefined"},{"id":"8194","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":13,"text":"저는 내 이름을 위하여 집을 건축할 것이요 나는 그 나라 위를 영원히 견고케 하리라","reference":"사무엘하 7:13","category":"$undefined"},{"id":"8195","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":14,"text":"나는 그 아비가 되고 그는 내 아들이 되리니 저가 만일 죄를 범하면 내가 사람 막대기와 인생 채찍으로 징계하려니와","reference":"사무엘하 7:14","category":"$undefined"},{"id":"8196","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":15,"text":"내가 네 앞에서 폐한 사울에게서 내 은총을 빼앗은 것 같이 그에게서는 빼앗지 아니하리라","reference":"사무엘하 7:15","category":"$undefined"},{"id":"8197","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":16,"text":"네 집과 네 나라가 네 앞에서 영원히 보전되고 네 위가 영원히 견고하리라 하셨다 하라","reference":"사무엘하 7:16","category":"$undefined"},{"id":"8198","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":17,"text":"나단이 이 모든 말씀과 이 모든 묵시대로 다윗에게 고하니라","reference":"사무엘하 7:17","category":"$undefined"},{"id":"8199","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":18,"text":"다윗 왕이 여호와 앞에 들어가 앉아서 가로되 `주 여호와여, 나는 누구오며 내 집은 무엇이관대 나로 이에 이르게 하셨나이까 ?","reference":"사무엘하 7:18","category":"$undefined"},{"id":"8200","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":19,"text":"주 여호와여, 주께서 이것을 오히려 적게 여기시고 또 종의 집에 영구히 이를 일을 말씀하실 뿐 아니라 주 여호와여 인간의 규례대로 하셨나이다","reference":"사무엘하 7:19","category":"$undefined"},{"id":"8201","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":20,"text":"주 여호와는 종을 아시오니 다윗이 다시 주께 무슨 말씀을 하오리이까 ?","reference":"사무엘하 7:20","category":"$undefined"},{"id":"8202","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":21,"text":"주의 말씀을 인하여 주의 뜻대로 이 모든 큰 일을 행하사 주의 종에게 알게 하셨나이다","reference":"사무엘하 7:21","category":"$undefined"},{"id":"8203","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":22,"text":"여호와 하나님이여 이러므로 주는 광대하시니 이는 우리 귀로 들은 대로는 주와 같은 이가 없고 주 외에는 참 신이 없음이니이다 !","reference":"사무엘하 7:22","category":"$undefined"},{"id":"8204","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":23,"text":"땅의 어느 한 나라가 주의 백성 이스라엘과 같으리이까 하나님이 가서 구속하사 자기 백성을 삼아 주의 명성을 내시며 저희를 위하여 큰 일을 주의 땅을 위하여 두려운 일을 애굽과 열국과 그 신들에게서 구속하신 백성 앞에서 행하셨사오며","reference":"사무엘하 7:23","category":"$undefined"},{"id":"8205","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":24,"text":"주께서 주의 백성 이스라엘을 세우사 영원히 주의 백성을 삼으셨사오니 여호와여, 주께서 저희 하나님이 되셨나이다","reference":"사무엘하 7:24","category":"$undefined"},{"id":"8206","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":25,"text":"여호와 하나님이여, 이제 주의 종과 종의 집에 대하여 말씀하신 것을 영원히 확실케 하옵시며 말씀하신 대로 행하사","reference":"사무엘하 7:25","category":"$undefined"},{"id":"8207","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":26,"text":"사람으로 영원히 주의 이름을 높여 이르기를 만군의 여호와는 이스라엘의 하나님이라 하게 하옵시며 주의 종 다윗의 집으로 주 앞에 견고하게 하옵소서","reference":"사무엘하 7:26","category":"$undefined"},{"id":"8208","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":27,"text":"만군의 여호와 이스라엘의 하나님이여, 주의 종에게 알게 하여 이르시기를 내가 너를 위하여 집을 세우리라 하신고로 주의 종이 이 기도로 구할 마음이 생겼나이다","reference":"사무엘하 7:27","category":"$undefined"},{"id":"8209","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":28,"text":"주 여호와여, 오직 주는 하나님이시며 말씀이 참되시니이다 ! 주께서 이 좋은 것으로 종에게 허락하셨사오니","reference":"사무엘하 7:28","category":"$undefined"},{"id":"8210","book":"사무엘하","book_name":"사무엘하","chapter":7,"verse":29,"text":"이제 청컨대 종의 집에 복을 주사 주 앞에 영원히 있게 하옵소서 ! 주 여호와께서 말씀하셨사오니 주의 은혜로 종의 집이 영원히 복을 받게 하옵소서 !` 하니라","reference":"사무엘하 7:29","category":"$undefined"}],"bookSlug":"2samuel"}]
