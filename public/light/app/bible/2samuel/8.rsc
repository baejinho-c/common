2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":8,"verses":[{"id":"8211","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":1,"text":"이 후에 다윗이 블레셋 사람을 쳐서 항복 받고 블레셋 사람의 손에서 메덱암마를 빼앗으니라","reference":"사무엘하 8:1","category":"$undefined"},{"id":"8212","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":2,"text":"다윗이 또 모압을 쳐서 저희로 땅에 엎드리게 하고 줄로 재어 그 두줄 길이의 사람은 죽이고 한 줄 길이의 사람은 살리니 모압 사람이 다윗의 종이 되어 조공을 바치니라","reference":"사무엘하 8:2","category":"$undefined"},{"id":"8213","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":3,"text":"르홉의 아들 소바 왕 하닷에셀이 자기 권세를 회복하려고 유브라데강으로 갈 때에 다윗이 저를 쳐서","reference":"사무엘하 8:3","category":"$undefined"},{"id":"8214","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":4,"text":"그 마병 일천 칠백과 보병 이만을 사로잡고 병거 일백승의 말만 남기고 그 외의 병거의 말은 다 발의 힘줄을 끊었더니","reference":"사무엘하 8:4","category":"$undefined"},{"id":"8215","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":5,"text":"다메섹 아람 사람들이 소바 왕 하닷에셀을 도우러 온지라 다윗이 아람 사람 이만 이천을 죽이고","reference":"사무엘하 8:5","category":"$undefined"},{"id":"8216","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":6,"text":"다메섹 아람에 수비대를 두매 아람 사람이 다윗의 종이 되어 조공을 바치니라 다윗이 어디를 가든지 여호와께서 이기게 하시니라","reference":"사무엘하 8:6","category":"$undefined"},{"id":"8217","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":7,"text":"다윗이 하닷에셀의 신복들의 가진 금방패를 빼앗아 예루살렘으로 가져오고","reference":"사무엘하 8:7","category":"$undefined"},{"id":"8218","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":8,"text":"또 하닷에셀의 고을 베다와 베로대에서 매우 많은 놋을 빼앗으니라","reference":"사무엘하 8:8","category":"$undefined"},{"id":"8219","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":9,"text":"하맛 왕 도이가 다윗이 하닷에셀의 온 군대를 쳐서 파하였다 함을 듣고","reference":"사무엘하 8:9","category":"$undefined"},{"id":"8220","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":10,"text":"그 아들 요람을 보내어 다윗 왕에게 문안하고 축복하게 하니 이는 하닷에셀이 도이로 더불어 전쟁이 있던 터에 다윗이 하닷에셀을 쳐서 파함이라 요람이 은 그릇과 금 그릇과 놋 그릇을 가지고 온지라","reference":"사무엘하 8:10","category":"$undefined"},{"id":"8221","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":11,"text":"다윗 왕이 그것도 여호와께 드리되 저가 정복한 모든 나라에서 얻은 은금","reference":"사무엘하 8:11","category":"$undefined"},{"id":"8222","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":12,"text":"곧 아람과, 모압과, 암몬 자손과, 블레셋 사람과, 아말렉에게서 얻은 것들과 소바 왕 르홉의 아들 하닷에셀에게서 노략한 것과 같이 드리니라","reference":"사무엘하 8:12","category":"$undefined"},{"id":"8223","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":13,"text":"다윗이 염곡(鹽谷)에서 에돔 사람 일만 팔천을 쳐 죽이고 돌아와서 명예를 얻으니라","reference":"사무엘하 8:13","category":"$undefined"},{"id":"8224","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":14,"text":"다윗이 에돔에 수비대를 두되 온 에돔에 수비대를 두니 에돔 사람이 다 다윗의 종이 되니라 다윗이 어디를 가든지 여호와께서 이기게 하셨더라","reference":"사무엘하 8:14","category":"$undefined"},{"id":"8225","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":15,"text":"다윗이 온 이스라엘을 다스려 모든 백성에게 공과 의를 행할새","reference":"사무엘하 8:15","category":"$undefined"},{"id":"8226","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":16,"text":"스루야의 아들 요압은 군대장관이 되고 아힐룻의 아들 여호사밧은 사관이 되고","reference":"사무엘하 8:16","category":"$undefined"},{"id":"8227","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":17,"text":"아히둡의 아들 사독과 아비아달의 아들 아히멜렉은 제사장이 되고 스라야는 서기관이 되고","reference":"사무엘하 8:17","category":"$undefined"},{"id":"8228","book":"사무엘하","book_name":"사무엘하","chapter":8,"verse":18,"text":"여호야다의 아들 브나야는 그렛 사람과 블렛 사람을 관할하고 다윗의 아들들은 대신이 되니라","reference":"사무엘하 8:18","category":"$undefined"}],"bookSlug":"2samuel"}]
