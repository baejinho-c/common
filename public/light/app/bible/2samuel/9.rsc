2:["$","$L11",null,{"book":{"id":"2samuel","name":"사무엘하","chapters":24,"testament":"old"},"chapter":9,"verses":[{"id":"8229","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":1,"text":"다윗이 가로되 `사울의 집에 오히려 남은 사람이 있느냐 ? 내가 요나단을 인하여 그 사람에게 은총을 베풀리라 !' 하니라","reference":"사무엘하 9:1","category":"$undefined"},{"id":"8230","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":2,"text":"사울의 종 하나가 있으니 그 이름은 시바라 저를 다윗의 앞으로 부르매 왕이 저에게 묻되 `네가 시바냐 ?' 가로되 `종이 그로소이다'","reference":"사무엘하 9:2","category":"$undefined"},{"id":"8231","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":3,"text":"왕이 가로되 `사울의 집에 남은 사람이 없느냐 ? 내가 그 사람에게 하나님의 은총을 베풀고자 하노라' 시바가 왕께 고하되 `요나단의 아들 하나가 있는데 절뚝발이니이다'","reference":"사무엘하 9:3","category":"$undefined"},{"id":"8232","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":4,"text":"왕이 저에게 묻되 그가 어디 있느냐 ? 시바가 왕에게 고하되 로드발 암미엘의 아들 마길의 집에 있나이다","reference":"사무엘하 9:4","category":"$undefined"},{"id":"8233","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":5,"text":"다윗 왕이 사람을 보내어 로드발 암미엘의 아들 마길의 집에서 저를 데려오니","reference":"사무엘하 9:5","category":"$undefined"},{"id":"8234","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":6,"text":"사울의 손자 요나단의 아들 므비보셋이 다윗에게 나아와서 엎드려 절하매 다윗이 가로되 `므비보셋이여 !' 하니 대답하되 `주의 종이 여기 있나이다'","reference":"사무엘하 9:6","category":"$undefined"},{"id":"8235","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":7,"text":"다윗이 가로되 `무서워 말라 ! 내가 반드시 네 아비 요나단을 인하여 네게 은총을 베풀리라 내가 네 조부 사울의 밭을 다 네게 도로 주겠고 또 너는 항상 내 상에서 먹을지니라'","reference":"사무엘하 9:7","category":"$undefined"},{"id":"8236","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":8,"text":"저가 절하여 가로되 `이 종이 무엇이관대 왕께서 죽은 개 같은 나를 돌아보시나이까 ?`","reference":"사무엘하 9:8","category":"$undefined"},{"id":"8237","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":9,"text":"왕이 사울의 사환 시바를 불러서 이르되 `사울과 그 온 집에 속한 것은 내가 다 네 주인의 아들에게 주었노니","reference":"사무엘하 9:9","category":"$undefined"},{"id":"8238","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":10,"text":"너와 네 아들들과 네 종들은 저를 위하여 밭을 갈고 거두어 네 주인의 아들을 공궤하라 그러나 네 주인의 아들 므비보셋은 항상 내 상에서 먹으리라' 하니라 시바는 아들이 열 다섯이요 종이 스물이라","reference":"사무엘하 9:10","category":"$undefined"},{"id":"8239","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":11,"text":"시바가 왕께 고하되 `내 주 왕께서 온갖 일을 종에게 명하신 대로 종이 준행하겠나이다' 하니라 므비보셋은 왕자 중 하나처럼 왕의 상에서 먹으니라","reference":"사무엘하 9:11","category":"$undefined"},{"id":"8240","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":12,"text":"므비보셋에게 젊은 아들 하나가 있으니 이름은 미가더라 무릇 시바의 집에 거하는 자들은 므비보셋의 종이 되니라","reference":"사무엘하 9:12","category":"$undefined"},{"id":"8241","book":"사무엘하","book_name":"사무엘하","chapter":9,"verse":13,"text":"므비보셋이 항상 왕의 상에서 먹으므로 예루살렘에 거하니라 그는 두 발이 다 절뚝이더라","reference":"사무엘하 9:13","category":"$undefined"}],"bookSlug":"2samuel"}]
