2:["$","$L11",null,{"book":{"id":"2thessalonians","name":"데살로니가후서","chapters":3,"testament":"new"},"chapter":1,"verses":[{"id":"29651","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":1,"text":"바울과 실루아노와 디모데는 하나님 우리 아버지와 주 예수 그리스도 안에 있는 데살로니가인의 교회에 편지하노니","reference":"데살로니가후서 1:1","category":"$undefined"},{"id":"29652","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":2,"text":"하나님 아버지와 주 예수 그리스도로부터 은혜와 평강이 너희에게 있을지어다","reference":"데살로니가후서 1:2","category":"$undefined"},{"id":"29653","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":3,"text":"형제들아 우리가 너희를 위하여 항상 하나님께 감사할지니 이것이 당연함은 너희 믿음이 더욱 자라고 너희가 다 각기 서로 사랑함이 풍성함이며","reference":"데살로니가후서 1:3","category":"$undefined"},{"id":"29654","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":4,"text":"그리고 너희의 참는 모든 핍박과 환난 중에서 너희 인내와 믿음을 인하여 하나님의 여러 교회에서 우리가 친히 자랑함이라","reference":"데살로니가후서 1:4","category":"$undefined"},{"id":"29655","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":5,"text":"이는 하나님의 공의로운 심판의 표요 너희로 하여금 하나님의 나라에 합당한 자로 여기심을 얻게 하려 함이니 그 나라를 위하여 너희가 또한 고난을 받으리니","reference":"데살로니가후서 1:5","category":"$undefined"},{"id":"29656","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":6,"text":"너희로 환난 받게 하는 자들에게는 환난으로 갚으시고","reference":"데살로니가후서 1:6","category":"$undefined"},{"id":"29657","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":7,"text":"환난 받는 너희에게는 우리와 함께 안식으로 갚으시는 것이 하나님의 공의시니 주 예수께서 저의 능력의 천사들과 함께 하늘로부터 불꽃 중에 나타나실 때에","reference":"데살로니가후서 1:7","category":"$undefined"},{"id":"29658","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":8,"text":"하나님을 모르는 자들과 우리 주 예수의 복음을 복종치 않는 자들에게 형벌을 주시리니","reference":"데살로니가후서 1:8","category":"$undefined"},{"id":"29659","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":9,"text":"이런 자들이 주의 얼굴과 그의 힘의 영광을 떠나 영원한 멸망의 형벌을 받으리로다","reference":"데살로니가후서 1:9","category":"$undefined"},{"id":"29660","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":10,"text":"그 날에 강림하사 그의 성도들에게서 영광을 얻으시고 모든 믿는 자에게서 기이히 여김을 얻으시리라(우리의 증거가 너희에게 믿 어졌음이라)","reference":"데살로니가후서 1:10","category":"$undefined"},{"id":"29661","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":11,"text":"이러므로 우리도 항상 너희를 위하여 기도함은 우리 하나님이 너희를 그 부르심에 합당한 자로 여기시고 모든 선을 기뻐함과 믿 음의 역사를 능력으로 이루게 하시고","reference":"데살로니가후서 1:11","category":"$undefined"},{"id":"29662","book":"데살로니가후서","book_name":"데살로니가후서","chapter":1,"verse":12,"text":"우리 하나님과 주 예수 그리스도의 은혜대로 우리 주 예수의 이름이 너희 가운데서 영광을 얻으시고 너희도 그 안에서 영광을 얻게 하려 함이니라","reference":"데살로니가후서 1:12","category":"$undefined"}],"bookSlug":"2thessalonians"}]
