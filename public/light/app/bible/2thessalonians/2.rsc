2:["$","$L11",null,{"book":{"id":"2thessalonians","name":"데살로니가후서","chapters":3,"testament":"new"},"chapter":2,"verses":[{"id":"29663","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":1,"text":"형제들아 ! 우리가 너희에게 구하는 것은 우리 주 예수 그리스도의 강림하심과 우리가 그 앞에 모임에 관하여","reference":"데살로니가후서 2:1","category":"$undefined"},{"id":"29664","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":2,"text":"혹 영으로나, 혹 말로나, 혹 우리에게서 받았다 하는 편지로나 주의 날이 이르렀다고 쉬 동심하거나 두려워하거나 하지 아니할 그것이라","reference":"데살로니가후서 2:2","category":"$undefined"},{"id":"29665","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":3,"text":"누가 아무렇게 하여도 너희가 미혹하지 말라 먼저 배도하는 일이 있고 저 불법의 사람 곧 멸망의 아들이 나타나기 전에는 이르지 아니하리니","reference":"데살로니가후서 2:3","category":"$undefined"},{"id":"29666","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":4,"text":"저는 대적하는 자라 범사에 일컫는 하나님이나 숭배함을 받는 자 위에 뛰어나 자존하여 하나님 성전에 앉아 자기를 보여 하나님이라 하느니라","reference":"데살로니가후서 2:4","category":"$undefined"},{"id":"29667","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":5,"text":"내가 너희와 함께 있을 때에 이 일을 너희에게 말한 것을 기억하지 못하느냐 ?","reference":"데살로니가후서 2:5","category":"$undefined"},{"id":"29668","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":6,"text":"저로 하여금 저의 때에 나타나게 하려 하여 막는 것을 지금도 너희가 아나니","reference":"데살로니가후서 2:6","category":"$undefined"},{"id":"29669","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":7,"text":"불법의 비밀이 이미 활동하였으나 지금 막는 자가 있어 그 중에서 옮길 때까지 하리라","reference":"데살로니가후서 2:7","category":"$undefined"},{"id":"29670","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":8,"text":"그 때에 불법한 자가 나타나리니 주 예수께서 그 입의 기운으로 저를 죽이시고 강림하여 나타나심으로 폐하시리라","reference":"데살로니가후서 2:8","category":"$undefined"},{"id":"29671","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":9,"text":"악한 자의 임함은 사단의 역사를 따라 모든 능력과 표적과 거짓 기적과","reference":"데살로니가후서 2:9","category":"$undefined"},{"id":"29672","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":10,"text":"불의의 모든 속임으로 멸망하는 자들에게 임하리니 이는 저희가 진리의 사랑을 받지 아니하여 구원함을 얻지 못함이니라","reference":"데살로니가후서 2:10","category":"$undefined"},{"id":"29673","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":11,"text":"이러므로 하나님이 유혹을 저의 가운데 역사하게 하사 거짓 것을 믿게 하심은","reference":"데살로니가후서 2:11","category":"$undefined"},{"id":"29674","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":12,"text":"진리를 믿지 않고 불의를 좋아하는 모든 자로 심판을 받게 하려 하심이니라","reference":"데살로니가후서 2:12","category":"$undefined"},{"id":"29675","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":13,"text":"주의 사랑하시는 형제들아 ! 우리가 항상 너희를 위하여 마땅히 하나님께 감사할 것은 하나님이 처음부터 너희를 택하사 성령의 거룩하게 하심과 진리를 믿음으로 구원을 얻게 하심이니","reference":"데살로니가후서 2:13","category":"$undefined"},{"id":"29676","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":14,"text":"이를 위하여 우리 복음으로 너희를 부르사 우리 주 예수 그리스도의 영광을 얻게 하려 하심이니라","reference":"데살로니가후서 2:14","category":"$undefined"},{"id":"29677","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":15,"text":"이러므로 형제들아 ! 굳게 서서 말로나 우리 편지로 가르침을 받은 유전을 지키라","reference":"데살로니가후서 2:15","category":"$undefined"},{"id":"29678","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":16,"text":"우리 주 예수 그리스도와 우리를 사랑하시고 영원한 위로와 좋은 소망을 은혜로 주신 하나님 우리 아버지께","reference":"데살로니가후서 2:16","category":"$undefined"},{"id":"29679","book":"데살로니가후서","book_name":"데살로니가후서","chapter":2,"verse":17,"text":"너희 마음을 위로하시고 모든 선한 일과 말에 굳게 하시기를 원하노라","reference":"데살로니가후서 2:17","category":"$undefined"}],"bookSlug":"2thessalonians"}]
