2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":1,"verses":[{"id":"26925","book":"사도행전","book_name":"사도행전","chapter":1,"verse":1,"text":"데오빌로여 내가 먼저 쓴 글에는 무릇 예수의 행하시며 가르치시기를 시작하심부터","reference":"사도행전 1:1","category":"$undefined"},{"id":"26926","book":"사도행전","book_name":"사도행전","chapter":1,"verse":2,"text":"그의 택하신 사도들에게 성령으로 명하시고 승천하신 날까지의 일을 기록하였노라","reference":"사도행전 1:2","category":"$undefined"},{"id":"26927","book":"사도행전","book_name":"사도행전","chapter":1,"verse":3,"text":"해 받으신 후에 또한 저희에게 확실한 많은 증거로 친히 사심을 나타내사 사십 일 동안 저희에게 보이시며 하나님 나라의 일을 말씀하시니라","reference":"사도행전 1:3","category":"$undefined"},{"id":"26928","book":"사도행전","book_name":"사도행전","chapter":1,"verse":4,"text":"사도와 같이 모이사 저희에게 분부하여 가라사대 예루살렘을 떠나지 말고 내게 들은 바 아버지의 약속하신 것을 기다리라","reference":"사도행전 1:4","category":"$undefined"},{"id":"26929","book":"사도행전","book_name":"사도행전","chapter":1,"verse":5,"text":"요한은 물로 세례를 베풀었으나 너희는 몇 날이 못 되어 성령으로 세례를 받으리라 하셨느니라","reference":"사도행전 1:5","category":"$undefined"},{"id":"26930","book":"사도행전","book_name":"사도행전","chapter":1,"verse":6,"text":"저희가 모였을때에 예수께 묻자와 가로되 `주께서 이스라엘 나라를 회복하심이 이때니이까 ?' 하니","reference":"사도행전 1:6","category":"$undefined"},{"id":"26931","book":"사도행전","book_name":"사도행전","chapter":1,"verse":7,"text":"가라사대 `때와 기한은 아버지께서 자기의 권한에 두셨으니 너희의 알 바 아니요","reference":"사도행전 1:7","category":"$undefined"},{"id":"26932","book":"사도행전","book_name":"사도행전","chapter":1,"verse":8,"text":"오직 성령이 너희에게 임하시면 너희가 권능을 받고 예루살렘과 온 유대와 사마리아 땅 끝까지 이르러 내 증인이 되리라' 하시니라","reference":"사도행전 1:8","category":"$undefined"},{"id":"26933","book":"사도행전","book_name":"사도행전","chapter":1,"verse":9,"text":"이 말씀을 마치시고 저희 보는데서 올리워 가시니 구름이 저를 가리워 보이지 않게 하더라","reference":"사도행전 1:9","category":"$undefined"},{"id":"26934","book":"사도행전","book_name":"사도행전","chapter":1,"verse":10,"text":"올라가실 때에 제자들이 자세히 하늘을 쳐다보고 있는 데 흰 옷 입은 두사람이 저희 곁에 서서","reference":"사도행전 1:10","category":"$undefined"},{"id":"26935","book":"사도행전","book_name":"사도행전","chapter":1,"verse":11,"text":"가로되 `갈릴리 사람들아 어찌하여 서서 하늘을 쳐다보느냐 ? 너희 가운데서 하늘로 올리우신 이 예수는 하늘로 가심을 본 그대로 오시리라' 하였느니라","reference":"사도행전 1:11","category":"$undefined"},{"id":"26936","book":"사도행전","book_name":"사도행전","chapter":1,"verse":12,"text":"제자들이 감람원이라 하는 산으로부터 예루살렘에 돌아오니 이 산은 예루살렘에서 가까와 안식일에 가기 알맞은 길이라","reference":"사도행전 1:12","category":"$undefined"},{"id":"26937","book":"사도행전","book_name":"사도행전","chapter":1,"verse":13,"text":"들어가 저희 유하는 다락에 올라 가니 베드로, 요한, 야고보, 안드레와 빌립, 도마와 바돌로매, 마태와 및 알패오의 아들 야고보, 셀롯인 시몬, 야고보의 아들 유다가 다 거기 있어","reference":"사도행전 1:13","category":"$undefined"},{"id":"26938","book":"사도행전","book_name":"사도행전","chapter":1,"verse":14,"text":"여자들과 예수의 모친 마리아와 예수의 아우들로 더불어 마음을 같이하여 전혀 기도에 힘쓰니라","reference":"사도행전 1:14","category":"$undefined"},{"id":"26939","book":"사도행전","book_name":"사도행전","chapter":1,"verse":15,"text":"모인 무리의 수가 한 일백 이십 명이나 되더라 그 때에 베드로가 그 형제 가운데 일어서서 가로되","reference":"사도행전 1:15","category":"$undefined"},{"id":"26940","book":"사도행전","book_name":"사도행전","chapter":1,"verse":16,"text":"`형제들아 성령이 다윗의 입을 의탁하사 예수 잡는 자들을 지로한 유다를 가리켜 미리 말씀하신 성경이 응하였으니 마땅하도다","reference":"사도행전 1:16","category":"$undefined"},{"id":"26941","book":"사도행전","book_name":"사도행전","chapter":1,"verse":17,"text":"이 사람이 본래 우리 수 가운데 참예하여 이 직무의 한 부분을 맡았던 자라","reference":"사도행전 1:17","category":"$undefined"},{"id":"26942","book":"사도행전","book_name":"사도행전","chapter":1,"verse":18,"text":"(이 사람이 불의의 삯으로 밭을 사고 후에 몸이 곤두박질하여 배가 터져 창자가 다 흘러 나온지라","reference":"사도행전 1:18","category":"$undefined"},{"id":"26943","book":"사도행전","book_name":"사도행전","chapter":1,"verse":19,"text":"이 일이 예루살렘에 사는 모든 사람에게 알게 되어 본 방언에 그 밭을 이르되 아겔다마라 하니 이는 피밭이라는 뜻이라)","reference":"사도행전 1:19","category":"$undefined"},{"id":"26944","book":"사도행전","book_name":"사도행전","chapter":1,"verse":20,"text":"시편에 기록하였으되 그의 거처로 황폐하게 하시며 거기 거하는 자가 없게 하소서 하였고 또 일렀으되 그 직분을 타인이 취하게 하소서 하였도다","reference":"사도행전 1:20","category":"$undefined"},{"id":"26945","book":"사도행전","book_name":"사도행전","chapter":1,"verse":21,"text":"이러하므로 요한의 세례로부터 우리 가운데서 올리워 가신 날까지 주 예수께서 우리 가운데 출입하실 때에","reference":"사도행전 1:21","category":"$undefined"},{"id":"26946","book":"사도행전","book_name":"사도행전","chapter":1,"verse":22,"text":"항상 우리와 함께 다니던 사람 중에 하나를 세워 우리로 더불어 예수의 부활하심을 증거할 사람이 되게 하여야 하리라' 하거늘","reference":"사도행전 1:22","category":"$undefined"},{"id":"26947","book":"사도행전","book_name":"사도행전","chapter":1,"verse":23,"text":"저희가 두 사람을 천하니 하나는 바사바라고도 하고 별명은 유스도라고 하는 요셉이요 하나는 맛디아라","reference":"사도행전 1:23","category":"$undefined"},{"id":"26948","book":"사도행전","book_name":"사도행전","chapter":1,"verse":24,"text":"저희가 기도하여 가로되 `뭇사람의 마음을 아시는 주여 ! 이 두 사람 중에 누가 주의 택하신 바 되어","reference":"사도행전 1:24","category":"$undefined"},{"id":"26949","book":"사도행전","book_name":"사도행전","chapter":1,"verse":25,"text":"봉사와 및 사도의 직무를 대신 할 자를 보이시옵소서 유다는 이를 버리옵고 제 곳으로 갔나이다' 하고","reference":"사도행전 1:25","category":"$undefined"},{"id":"26950","book":"사도행전","book_name":"사도행전","chapter":1,"verse":26,"text":"제비뽑아 맛디아를 얻으니 저가 열 한 사도의 수에 가입하니라","reference":"사도행전 1:26","category":"$undefined"}],"bookSlug":"acts"}]
