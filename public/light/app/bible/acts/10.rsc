2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":10,"verses":[{"id":"27261","book":"사도행전","book_name":"사도행전","chapter":10,"verse":1,"text":"가이사랴에 고넬료라 하는 사람이 있으니 이달리야대라 하는 군대의 백부장이라","reference":"사도행전 10:1","category":"$undefined"},{"id":"27262","book":"사도행전","book_name":"사도행전","chapter":10,"verse":2,"text":"그가 경건하여 온 집으로 더불어 하나님을 경외하며 백성을 많이 구제하고 하나님께 항상 기도하더니","reference":"사도행전 10:2","category":"$undefined"},{"id":"27263","book":"사도행전","book_name":"사도행전","chapter":10,"verse":3,"text":"하루는 제 구시쯤 되어 환상 중에 밝히 보매 하나님의 사자가 들어와 가로되 `고넬료야' 하니","reference":"사도행전 10:3","category":"$undefined"},{"id":"27264","book":"사도행전","book_name":"사도행전","chapter":10,"verse":4,"text":"고넬료가 주목하여 보고 두려워 가로되 `주여 무슨 일이니이까 ?' 천사가 가로되 `네 기도와 구제가 하나님 앞에 상달하여 기억하신 바가 되었으니","reference":"사도행전 10:4","category":"$undefined"},{"id":"27265","book":"사도행전","book_name":"사도행전","chapter":10,"verse":5,"text":"네가 지금 사람들을 욥바에 보내어 베드로라 하는 시몬을 청하라","reference":"사도행전 10:5","category":"$undefined"},{"id":"27266","book":"사도행전","book_name":"사도행전","chapter":10,"verse":6,"text":"저는 피장 시몬의 집에 우거하니 그 집은 해변에 있느니라' 하더라","reference":"사도행전 10:6","category":"$undefined"},{"id":"27267","book":"사도행전","book_name":"사도행전","chapter":10,"verse":7,"text":"마침 말하던 천사가 떠나매 고넬료가 집안 하인 둘과 종졸 가운데 경건한 사람 하나를 불러","reference":"사도행전 10:7","category":"$undefined"},{"id":"27268","book":"사도행전","book_name":"사도행전","chapter":10,"verse":8,"text":"이 일을 다 고하고 욥바로 보내니라","reference":"사도행전 10:8","category":"$undefined"},{"id":"27269","book":"사도행전","book_name":"사도행전","chapter":10,"verse":9,"text":"이튿날 저희가 행하여 성에 가까이 갔을 그 때에 베드로가 기도하려고 지붕에 올라가니 시간은 제 육시더라","reference":"사도행전 10:9","category":"$undefined"},{"id":"27270","book":"사도행전","book_name":"사도행전","chapter":10,"verse":10,"text":"시장하여 먹고자 하매 사람이 준비할 때에 비몽사몽간에","reference":"사도행전 10:10","category":"$undefined"},{"id":"27271","book":"사도행전","book_name":"사도행전","chapter":10,"verse":11,"text":"하늘이 열리며 한 그릇이 내려 오는 것을 보니 큰 보자기 같고 네 귀를 매어 땅에 드리웠더라","reference":"사도행전 10:11","category":"$undefined"},{"id":"27272","book":"사도행전","book_name":"사도행전","chapter":10,"verse":12,"text":"그 안에는 땅에 있는 각색 네발 가진 짐승과 기는 것과 공중에 나는 것들이 있는데","reference":"사도행전 10:12","category":"$undefined"},{"id":"27273","book":"사도행전","book_name":"사도행전","chapter":10,"verse":13,"text":"또 소리가 있으되 `베드로야, 일어나 잡아 먹으라' 하거늘","reference":"사도행전 10:13","category":"$undefined"},{"id":"27274","book":"사도행전","book_name":"사도행전","chapter":10,"verse":14,"text":"베드로가 가로되 `주여, 그럴 수 없나이다 속되고 깨끗지 아니한 물건을 내가 언제든지 먹지 아니하였삽나이다' 한대","reference":"사도행전 10:14","category":"$undefined"},{"id":"27275","book":"사도행전","book_name":"사도행전","chapter":10,"verse":15,"text":"또 두 번째 소리 있으되 `하나님께서 깨끗케 하신 것을 네가 속되다 하지 말라' 하더라","reference":"사도행전 10:15","category":"$undefined"},{"id":"27276","book":"사도행전","book_name":"사도행전","chapter":10,"verse":16,"text":"이런 일이 세 번 있은 후 그 그릇이 곧 하늘로 올리워 가니라","reference":"사도행전 10:16","category":"$undefined"},{"id":"27277","book":"사도행전","book_name":"사도행전","chapter":10,"verse":17,"text":"베드로가 본 바 환상이 무슨 뜻인지 속으로 의심하더니 마침 고넬료의 보낸 사람들이 시몬의 집을 찾아 문 밖에 서서","reference":"사도행전 10:17","category":"$undefined"},{"id":"27278","book":"사도행전","book_name":"사도행전","chapter":10,"verse":18,"text":"불러 묻되 `베드로라 하는 시몬이 여기 우거하느냐 ?' 하거늘","reference":"사도행전 10:18","category":"$undefined"},{"id":"27279","book":"사도행전","book_name":"사도행전","chapter":10,"verse":19,"text":"베드로가 그 환상에 대하여 생각할 때에 성령께서 저더러 말씀하시되 두 사람이 너를 찾으니","reference":"사도행전 10:19","category":"$undefined"},{"id":"27280","book":"사도행전","book_name":"사도행전","chapter":10,"verse":20,"text":"일어나 내려가 의심치 말고 함께 가라 내가 저희를 보내었느니라 하시니","reference":"사도행전 10:20","category":"$undefined"},{"id":"27281","book":"사도행전","book_name":"사도행전","chapter":10,"verse":21,"text":"베드로가 내려가 그 사람들을 보고 가로되 `내가 곧 너희의 찾는 사람이니 너희가 무슨 일로 왔느냐 ?'","reference":"사도행전 10:21","category":"$undefined"},{"id":"27282","book":"사도행전","book_name":"사도행전","chapter":10,"verse":22,"text":"저희가 대답하되 `백부장 고넬료는 의인이요, 하나님을 경외하는 자라 유대 온 족속이 칭찬하더니 저가 거룩한 천사의 지시를 받아 너를 그 집으로 청하여 말을 들으려 하느니라' 한대","reference":"사도행전 10:22","category":"$undefined"},{"id":"27283","book":"사도행전","book_name":"사도행전","chapter":10,"verse":23,"text":"베드로가 불러 들여 유숙하게 하니라 이튿날 일어나 저희와 함께 갈새 욥바 두어 형제도 함께 가니라","reference":"사도행전 10:23","category":"$undefined"},{"id":"27284","book":"사도행전","book_name":"사도행전","chapter":10,"verse":24,"text":"이튿날 가이사랴에 들어가니 고넬료가 일가와 가까운 친구들을 모아 기다리더니","reference":"사도행전 10:24","category":"$undefined"},{"id":"27285","book":"사도행전","book_name":"사도행전","chapter":10,"verse":25,"text":"마침 베드로가 들어올 때에 고넬료가 맞아 발 앞에 엎드리어 절하니","reference":"사도행전 10:25","category":"$undefined"},{"id":"27286","book":"사도행전","book_name":"사도행전","chapter":10,"verse":26,"text":"베드로가 일으켜 가로되 `일어서라 나도 사람이라' 하고","reference":"사도행전 10:26","category":"$undefined"},{"id":"27287","book":"사도행전","book_name":"사도행전","chapter":10,"verse":27,"text":"더불어 말하며 들어가 여러 사람의 모인 것을 보고","reference":"사도행전 10:27","category":"$undefined"},{"id":"27288","book":"사도행전","book_name":"사도행전","chapter":10,"verse":28,"text":"이르되 `유대인으로서 이방인을 교제하는 것과 가까이 하는 것이 위법인 줄은 너희도 알거니와 하나님께서 내게 지시하사 아무도 속되다 하거나 깨끗지 않다 하지 말라 하시기로","reference":"사도행전 10:28","category":"$undefined"},{"id":"27289","book":"사도행전","book_name":"사도행전","chapter":10,"verse":29,"text":"부름을 사양치 아니하고 왔노라 묻노니 무슨 일로 나를 불렀느뇨 ?'","reference":"사도행전 10:29","category":"$undefined"},{"id":"27290","book":"사도행전","book_name":"사도행전","chapter":10,"verse":30,"text":"고넬료가 가로되 `나흘 전 이맘 때까지 내 집에서 제 구 시 기도를 하는데 홀연히 한 사람이 빛난 옷을 입고 내 앞에 서서","reference":"사도행전 10:30","category":"$undefined"},{"id":"27291","book":"사도행전","book_name":"사도행전","chapter":10,"verse":31,"text":"말하되 고넬료야 하나님이 네 기도를 들으시고 네 구제를 기억하셨으니","reference":"사도행전 10:31","category":"$undefined"},{"id":"27292","book":"사도행전","book_name":"사도행전","chapter":10,"verse":32,"text":"사람을 욥바에 보내어 베드로라 하는 시몬을 청하라 저가 바닷가 피장 시몬의 집에 우거하느니라 하시기로","reference":"사도행전 10:32","category":"$undefined"},{"id":"27293","book":"사도행전","book_name":"사도행전","chapter":10,"verse":33,"text":"내가 곧 당신에게 사람을 보내었더니 오셨으니 잘하였나이다 이제 우리는 주께서 당신에게 명하신 모든 것을 듣고자 하여 다 하나님 앞에 있나이다'","reference":"사도행전 10:33","category":"$undefined"},{"id":"27294","book":"사도행전","book_name":"사도행전","chapter":10,"verse":34,"text":"베드로가 입을 열어 가로되 `내가 참으로 하나님은 사람의 외모를 취하지 아니하시고","reference":"사도행전 10:34","category":"$undefined"},{"id":"27295","book":"사도행전","book_name":"사도행전","chapter":10,"verse":35,"text":"각 나라 중 하나님을 경외하며 의를 행하는 사람은 하나님이 받으시는 줄 깨달았도다","reference":"사도행전 10:35","category":"$undefined"},{"id":"27296","book":"사도행전","book_name":"사도행전","chapter":10,"verse":36,"text":"만유의 주 되신 예수 그리스도로 말미암아 화평의 복음을 전하사 이스라엘 자손들에게 보내신 말씀","reference":"사도행전 10:36","category":"$undefined"},{"id":"27297","book":"사도행전","book_name":"사도행전","chapter":10,"verse":37,"text":"곧 요한이 그 세례를 반포한 후에 갈릴리에서 시작되어 온 유대에 두루 전파된 그것을 너희도 알거니와","reference":"사도행전 10:37","category":"$undefined"},{"id":"27298","book":"사도행전","book_name":"사도행전","chapter":10,"verse":38,"text":"하나님이 나사렛 예수에게 성령과 능력을 기름붓듯 하셨으매 저가 두루 다니시며 착한 일을 행하시고 마귀에게 눌린 모든 자를 고치셨으니 이는 하나님이 함께 하셨음이라","reference":"사도행전 10:38","category":"$undefined"},{"id":"27299","book":"사도행전","book_name":"사도행전","chapter":10,"verse":39,"text":"우리는 유대인의 땅과 예루살렘에서 그의 행하신 모든 일에 증인이라 그를 저희가 나무에 달아 죽였으나","reference":"사도행전 10:39","category":"$undefined"},{"id":"27300","book":"사도행전","book_name":"사도행전","chapter":10,"verse":40,"text":"하나님이 사흘만에 다시 살리사 나타내시되","reference":"사도행전 10:40","category":"$undefined"},{"id":"27301","book":"사도행전","book_name":"사도행전","chapter":10,"verse":41,"text":"모든 백성에게 하신 것이 아니요 오직 미리 택하신 증인 곧 죽은자 가운데서 일어나신 후 모시고 음식을 먹은 우리에게 하신 것이라","reference":"사도행전 10:41","category":"$undefined"},{"id":"27302","book":"사도행전","book_name":"사도행전","chapter":10,"verse":42,"text":"우리를 명하사 백성에게 전도하되 하나님이 산 자와 죽은 자의 재판장으로 정하신 자가 곧 이 사람인 것을 증거하게 하셨고","reference":"사도행전 10:42","category":"$undefined"},{"id":"27303","book":"사도행전","book_name":"사도행전","chapter":10,"verse":43,"text":"저에 대하여 모든 선지자도 증거하되 저를 믿는 사람들이 다 그 이름을 힘입어 죄 사함을 받는다 하였느니라'","reference":"사도행전 10:43","category":"$undefined"},{"id":"27304","book":"사도행전","book_name":"사도행전","chapter":10,"verse":44,"text":"베드로가 이 말 할 때에 성령이 말씀 듣는 모든 사람에게 내려 오시니","reference":"사도행전 10:44","category":"$undefined"},{"id":"27305","book":"사도행전","book_name":"사도행전","chapter":10,"verse":45,"text":"베드로와 함께 온 할례 받은 신자들이 이방인들에게도 성령 부어 주심을 인하여 놀라니","reference":"사도행전 10:45","category":"$undefined"},{"id":"27306","book":"사도행전","book_name":"사도행전","chapter":10,"verse":46,"text":"이는 방언을 말하며 하나님 높임을 들음이러라","reference":"사도행전 10:46","category":"$undefined"},{"id":"27307","book":"사도행전","book_name":"사도행전","chapter":10,"verse":47,"text":"이에 베드로가 가로되 `이 사람들이 우리와 같이 성령을 받았으니 누가 능히 물로 세례 줌을 금하리요' 하고","reference":"사도행전 10:47","category":"$undefined"},{"id":"27308","book":"사도행전","book_name":"사도행전","chapter":10,"verse":48,"text":"명하여 예수 그리스도의 이름으로 세례를 주라 하니라 저희가 베드로에게 수일 더 유하기를 청하니라","reference":"사도행전 10:48","category":"$undefined"}],"bookSlug":"acts"}]
