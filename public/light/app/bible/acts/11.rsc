2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":11,"verses":[{"id":"27309","book":"사도행전","book_name":"사도행전","chapter":11,"verse":1,"text":"유대에 있는 사도들과 형제들이 이방인들도 하나님 말씀을 받았다 함을 들었더니","reference":"사도행전 11:1","category":"$undefined"},{"id":"27310","book":"사도행전","book_name":"사도행전","chapter":11,"verse":2,"text":"베드로가 예루살렘에 올라갔을 때에 할례자들이 힐난하여","reference":"사도행전 11:2","category":"$undefined"},{"id":"27311","book":"사도행전","book_name":"사도행전","chapter":11,"verse":3,"text":"가로되 `네가 무할례자의 집에 들어가 함께 먹었다' 하니","reference":"사도행전 11:3","category":"$undefined"},{"id":"27312","book":"사도행전","book_name":"사도행전","chapter":11,"verse":4,"text":"베드로가 저희에게 이 일을 차례로 설명하여","reference":"사도행전 11:4","category":"$undefined"},{"id":"27313","book":"사도행전","book_name":"사도행전","chapter":11,"verse":5,"text":"가로되 `내가 욥바 성에서 기도 할 때에 비몽사몽간에 환상을 보니 큰 보자기 같은 그릇을 네 귀를 매어 하늘로부터 내리워 내 앞에까지 드리우거늘","reference":"사도행전 11:5","category":"$undefined"},{"id":"27314","book":"사도행전","book_name":"사도행전","chapter":11,"verse":6,"text":"이것을 주목하여 보니 땅에 네 발 가진 것과 들짐승과 기는 것과 공중에 나는 것들이 보이더라","reference":"사도행전 11:6","category":"$undefined"},{"id":"27315","book":"사도행전","book_name":"사도행전","chapter":11,"verse":7,"text":"또 들으니 소리 있어 내게 이르되 베드로야 일어나 잡아 먹으라 하거늘","reference":"사도행전 11:7","category":"$undefined"},{"id":"27316","book":"사도행전","book_name":"사도행전","chapter":11,"verse":8,"text":"내가 가로되 `주여 그럴 수 없나이다 속되거나 깨끗지 아니한 물건은 언제든지 내 입에 들어간 일이 없나이다' 하니","reference":"사도행전 11:8","category":"$undefined"},{"id":"27317","book":"사도행전","book_name":"사도행전","chapter":11,"verse":9,"text":"또 하늘로부터 두 번째 소리 있어 내게 대답하되 하나님이 깨끗하게 하신 것을 네가 속되다 말라 하더라","reference":"사도행전 11:9","category":"$undefined"},{"id":"27318","book":"사도행전","book_name":"사도행전","chapter":11,"verse":10,"text":"이런 일이 세 번 있은 후에 모든 것이 다시 하늘로 끌려 올라가더라","reference":"사도행전 11:10","category":"$undefined"},{"id":"27319","book":"사도행전","book_name":"사도행전","chapter":11,"verse":11,"text":"마침 세 사람이 내 우거한 집 앞에 섰으니 가이사랴에서 내게로 보낸 사람이라","reference":"사도행전 11:11","category":"$undefined"},{"id":"27320","book":"사도행전","book_name":"사도행전","chapter":11,"verse":12,"text":"성령이 내게 명하사 아무 의심 말고 함께 가라 하시매 이 여섯 형제도 나와 함께 가서 그 사람의 집에 들어가니","reference":"사도행전 11:12","category":"$undefined"},{"id":"27321","book":"사도행전","book_name":"사도행전","chapter":11,"verse":13,"text":"그가 우리에게 말하기를 천사가 내 집에 서서 말하되 네가 사람을 욥바에 보내어 베드로라 하는 시몬을 청하라","reference":"사도행전 11:13","category":"$undefined"},{"id":"27322","book":"사도행전","book_name":"사도행전","chapter":11,"verse":14,"text":"그가 너와 네 온 집의 구원 얻을 말씀을 네게 이르리라 함을 보았다 하거늘","reference":"사도행전 11:14","category":"$undefined"},{"id":"27323","book":"사도행전","book_name":"사도행전","chapter":11,"verse":15,"text":"내가 말을 시작할 때에 성령이 저희에게 임하시기를 처음 우리에게 하신 것과 같이 하는지라","reference":"사도행전 11:15","category":"$undefined"},{"id":"27324","book":"사도행전","book_name":"사도행전","chapter":11,"verse":16,"text":"내가 주의 말씀에 요한은 물로 세례를 주었으나 너희는 성령으로 세례 받으리라 하신 것이 생각났노라","reference":"사도행전 11:16","category":"$undefined"},{"id":"27325","book":"사도행전","book_name":"사도행전","chapter":11,"verse":17,"text":"그런즉 하나님이 우리가 주 예수 그리스도를 믿을 때에 주신 것과 같은 선물을 저희에게도 주셨으니 내가 누구관대 하나님을 능히 막겠느냐 !' 하더라","reference":"사도행전 11:17","category":"$undefined"},{"id":"27326","book":"사도행전","book_name":"사도행전","chapter":11,"verse":18,"text":"저희가 이 말을 듣고 잠잠하여 하나님께 영광을 돌려 가로되 `그러면 하나님께서 이방인에게도 생명 얻는 회개를 주셨도다' 하니라","reference":"사도행전 11:18","category":"$undefined"},{"id":"27327","book":"사도행전","book_name":"사도행전","chapter":11,"verse":19,"text":"때에 스데반의 일로 일어난 환난을 인하여 흩어진 자들이 베니게와 구브로와 안디옥까지 이르러 도를 유대인에게만 전하는데","reference":"사도행전 11:19","category":"$undefined"},{"id":"27328","book":"사도행전","book_name":"사도행전","chapter":11,"verse":20,"text":"그 중에 구브로와 구레네 몇 사람이 안디옥에 이르러 헬라인에게도 말하여 주 예수를 전파하니","reference":"사도행전 11:20","category":"$undefined"},{"id":"27329","book":"사도행전","book_name":"사도행전","chapter":11,"verse":21,"text":"주의 손이 그들과 함께 하시매 수다한 사람이 믿고 주께 돌아오더라","reference":"사도행전 11:21","category":"$undefined"},{"id":"27330","book":"사도행전","book_name":"사도행전","chapter":11,"verse":22,"text":"예루살렘 교회가 이 사람들의 소문을 듣고 바나바를 안디옥까지 보내니","reference":"사도행전 11:22","category":"$undefined"},{"id":"27331","book":"사도행전","book_name":"사도행전","chapter":11,"verse":23,"text":"저가 이르러 하나님의 은혜를 보고 기뻐하여 모든 사람에게 굳은 마음으로 주께 붙어 있으라 권하니","reference":"사도행전 11:23","category":"$undefined"},{"id":"27332","book":"사도행전","book_name":"사도행전","chapter":11,"verse":24,"text":"바나바는 착한 사람이요 성령과 믿음이 충만한 자라 이에 큰 무리가 주께 더하더라","reference":"사도행전 11:24","category":"$undefined"},{"id":"27333","book":"사도행전","book_name":"사도행전","chapter":11,"verse":25,"text":"바나바가 사울을 찾으러 다소에 가서","reference":"사도행전 11:25","category":"$undefined"},{"id":"27334","book":"사도행전","book_name":"사도행전","chapter":11,"verse":26,"text":"만나매 안디옥에 데리고 와서 둘이 교회에 일 년간 모여 있어 큰 무리를 가르쳤고 제자들이 안디옥에서 비로소 그리스도인이라 일컫음을 받게 되었더라","reference":"사도행전 11:26","category":"$undefined"},{"id":"27335","book":"사도행전","book_name":"사도행전","chapter":11,"verse":27,"text":"그 때에 선지자들이 예루살렘에서 안디옥에 이르니","reference":"사도행전 11:27","category":"$undefined"},{"id":"27336","book":"사도행전","book_name":"사도행전","chapter":11,"verse":28,"text":"그 중에 아가보라 하는 한 사람이 일어나 성령으로 말하되 `천하가 크게 흉년 들리라' 하더니 글라우디오 때에 그렇게 되니라","reference":"사도행전 11:28","category":"$undefined"},{"id":"27337","book":"사도행전","book_name":"사도행전","chapter":11,"verse":29,"text":"제자들이 각각 그 힘대로 유대에 사는 형제들에게 부조를 보내기로 작정하고","reference":"사도행전 11:29","category":"$undefined"},{"id":"27338","book":"사도행전","book_name":"사도행전","chapter":11,"verse":30,"text":"이를 실행하여 바나바와 사울의 손으로 장로들에게 보내니라","reference":"사도행전 11:30","category":"$undefined"}],"bookSlug":"acts"}]
