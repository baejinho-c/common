2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":12,"verses":[{"id":"27339","book":"사도행전","book_name":"사도행전","chapter":12,"verse":1,"text":"그 때에 헤롯 왕이 손을 들어 교회 중 몇 사람을 해하려 하여","reference":"사도행전 12:1","category":"$undefined"},{"id":"27340","book":"사도행전","book_name":"사도행전","chapter":12,"verse":2,"text":"요한의 형제 야고보를 칼로 죽이니","reference":"사도행전 12:2","category":"$undefined"},{"id":"27341","book":"사도행전","book_name":"사도행전","chapter":12,"verse":3,"text":"유대인들이 이 일을 기뻐하는 것을 보고 베드로도 잡으려 할새 때는 무교절일이라","reference":"사도행전 12:3","category":"$undefined"},{"id":"27342","book":"사도행전","book_name":"사도행전","chapter":12,"verse":4,"text":"잡으매 옥에 가두어 군사 넷씩인 네 패에게 맡겨 지키고 유월절 후에 백성 앞에 끌어 내고자 하더라","reference":"사도행전 12:4","category":"$undefined"},{"id":"27343","book":"사도행전","book_name":"사도행전","chapter":12,"verse":5,"text":"이에 베드로는 옥에 갇혔고 교회는 그를 위하여 간절히 하나님께 빌더라","reference":"사도행전 12:5","category":"$undefined"},{"id":"27344","book":"사도행전","book_name":"사도행전","chapter":12,"verse":6,"text":"헤롯이 잡아 내려고 하는 그 전날 밤에 베드로가 두 군사 틈에서 두 쇠사슬에 매여 누워 자는데 파수군들이 문 밖에서 옥을 지키더니","reference":"사도행전 12:6","category":"$undefined"},{"id":"27345","book":"사도행전","book_name":"사도행전","chapter":12,"verse":7,"text":"홀연히 주의 사자가 곁에 서매 옥중에 광채가 조요하며 또 베드로의 옆구리를 쳐 깨워 가로되 `급히 일어나라' 하니 쇠사슬이 그 손에서 벗어지더라","reference":"사도행전 12:7","category":"$undefined"},{"id":"27346","book":"사도행전","book_name":"사도행전","chapter":12,"verse":8,"text":"천사가 가로되 `띠를 띠고 신을 들메라' 하거늘 베드로가 그대로 하니 천사가 또 가로되 `겉옷을 입고 따라 오라' 한대","reference":"사도행전 12:8","category":"$undefined"},{"id":"27347","book":"사도행전","book_name":"사도행전","chapter":12,"verse":9,"text":"베드로가 나와서 따라갈새 천사의 하는 것이 참인 줄 알지 못하고 환상을 보는가 하니라","reference":"사도행전 12:9","category":"$undefined"},{"id":"27348","book":"사도행전","book_name":"사도행전","chapter":12,"verse":10,"text":"이에 첫째와 둘째 파수를 지나 성으로 통한 쇠문에 이르니 문이 절로 열리는지라 나와 한 거리를 지나매 천사가 곧 떠나더라","reference":"사도행전 12:10","category":"$undefined"},{"id":"27349","book":"사도행전","book_name":"사도행전","chapter":12,"verse":11,"text":"이에 베드로가 정신이 나서 가로되 `내가 이제야 참으로 주께서 그의 천사를 보내어 나를 헤롯의 손과 유대 백성의 모든 기대에서 벗어나게 하신 줄 알겠노라' 하여","reference":"사도행전 12:11","category":"$undefined"},{"id":"27350","book":"사도행전","book_name":"사도행전","chapter":12,"verse":12,"text":"깨닫고 마가라 하는 요한의 어머니 마리아의 집에 가니 여러 사람이 모여 기도하더라","reference":"사도행전 12:12","category":"$undefined"},{"id":"27351","book":"사도행전","book_name":"사도행전","chapter":12,"verse":13,"text":"베드로가 대문을 두드린대 로데라 하는 계집아이가 영접하러 나왔다가","reference":"사도행전 12:13","category":"$undefined"},{"id":"27352","book":"사도행전","book_name":"사도행전","chapter":12,"verse":14,"text":"베드로의 음성인 줄 알고 기뻐하여 문을 미처 열지 못하고 달려 들어가 말하되 `베드로가 대문 밖에 섰더라' 하니","reference":"사도행전 12:14","category":"$undefined"},{"id":"27353","book":"사도행전","book_name":"사도행전","chapter":12,"verse":15,"text":"저희가 말하되 `네가 미쳤다' 하나 계집아이는 힘써 말하되 `참말이라' 하니 저희가 말하되 `그러면 그의 천사라' 하더라","reference":"사도행전 12:15","category":"$undefined"},{"id":"27354","book":"사도행전","book_name":"사도행전","chapter":12,"verse":16,"text":"베드로가 문 두드리기를 그치지 아니하니 저희가 문을 열어 베드로를 보고 놀라는지라","reference":"사도행전 12:16","category":"$undefined"},{"id":"27355","book":"사도행전","book_name":"사도행전","chapter":12,"verse":17,"text":"베드로가 저희에게 손짓하여 종용하게 하고 주께서 자기를 이끌어 옥에서 나오게 하던 일을 말하고 또 야고보와 형제들에게 이 말을 전하라 하고 떠나 다른 곳으로 가니라","reference":"사도행전 12:17","category":"$undefined"},{"id":"27356","book":"사도행전","book_name":"사도행전","chapter":12,"verse":18,"text":"날이 새매 군사들은 베드로가 어떻게 되었는지 알지 못하여 적지 않게 소동하니","reference":"사도행전 12:18","category":"$undefined"},{"id":"27357","book":"사도행전","book_name":"사도행전","chapter":12,"verse":19,"text":"헤롯이 그를 찾아도 보지 못하매 파숫군들을 심문하고 죽이라 명하니라 헤롯이 유대를 떠나 가이사랴로 내려가서 거하니라","reference":"사도행전 12:19","category":"$undefined"},{"id":"27358","book":"사도행전","book_name":"사도행전","chapter":12,"verse":20,"text":"헤롯이 두로와 시돈 사람들을 대단히 노여워하나 저희 지방이 왕국에서 나는 양식을 쓰는고로 일심으로 그에게 나아와 왕의 침소맡은 신하 블라스도를 친하여 화목하기를 청한지라","reference":"사도행전 12:20","category":"$undefined"},{"id":"27359","book":"사도행전","book_name":"사도행전","chapter":12,"verse":21,"text":"헤롯이 날을 택하여 왕복을 입고 위에 앉아 백성을 효유한대","reference":"사도행전 12:21","category":"$undefined"},{"id":"27360","book":"사도행전","book_name":"사도행전","chapter":12,"verse":22,"text":"백성들이 크게 부르되 이것은 신의 소리요 사람의 소리는 아니라 하거늘","reference":"사도행전 12:22","category":"$undefined"},{"id":"27361","book":"사도행전","book_name":"사도행전","chapter":12,"verse":23,"text":"헤롯이 영광을 하나님께로 돌리지 아니하는고로 주의 사자가 곧 치니 충이 먹어 죽으니라","reference":"사도행전 12:23","category":"$undefined"},{"id":"27362","book":"사도행전","book_name":"사도행전","chapter":12,"verse":24,"text":"하나님의 말씀은 흥왕하여 더하더라","reference":"사도행전 12:24","category":"$undefined"},{"id":"27363","book":"사도행전","book_name":"사도행전","chapter":12,"verse":25,"text":"바나바와 사울이 부조의 일을 마치고 마가라 하는 요한을 데리고 예루살렘에서 돌아오니라","reference":"사도행전 12:25","category":"$undefined"}],"bookSlug":"acts"}]
