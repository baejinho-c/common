2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":13,"verses":[{"id":"27364","book":"사도행전","book_name":"사도행전","chapter":13,"verse":1,"text":"안디옥 교회에 선지자들과 교사들이 있으니 곧 바나바와 니게르라하는 시므온과 구레네 사람 루기오와 분봉왕 헤롯의 젖동생 마나엔과 및 사울이라","reference":"사도행전 13:1","category":"$undefined"},{"id":"27365","book":"사도행전","book_name":"사도행전","chapter":13,"verse":2,"text":"주를 섬겨 금식할 때에 성령이 가라사대 `내가 불러 시키는 일을 위하여 바나바와 사울을 따로 세우라' 하시니","reference":"사도행전 13:2","category":"$undefined"},{"id":"27366","book":"사도행전","book_name":"사도행전","chapter":13,"verse":3,"text":"이에 금식하며 기도하고 두 사람에게 안수하여 보내니라","reference":"사도행전 13:3","category":"$undefined"},{"id":"27367","book":"사도행전","book_name":"사도행전","chapter":13,"verse":4,"text":"두 사람이 성령의 보내심을 받아 실루기아에 내려가 거기서 배 타고 구브로에 가서","reference":"사도행전 13:4","category":"$undefined"},{"id":"27368","book":"사도행전","book_name":"사도행전","chapter":13,"verse":5,"text":"살라미에 이르러 하나님의 말씀을 유대인의 여러 회당에서 전할새 요한을 수종자로 두었더라","reference":"사도행전 13:5","category":"$undefined"},{"id":"27369","book":"사도행전","book_name":"사도행전","chapter":13,"verse":6,"text":"온 섬 가운데로 지나서 바보에 이르러 바예수라 하는 유대인 거짓 선지자 박수를 만나니","reference":"사도행전 13:6","category":"$undefined"},{"id":"27370","book":"사도행전","book_name":"사도행전","chapter":13,"verse":7,"text":"그가 총독 서기오 바울과 함께 있으니 서기오 바울은 지혜 있는 사람이라 바나바와 사울을 불러 하나님 말씀을 듣고자 하더라","reference":"사도행전 13:7","category":"$undefined"},{"id":"27371","book":"사도행전","book_name":"사도행전","chapter":13,"verse":8,"text":"이 박수 엘루마는 (이 이름을 번역하면 박수라) 저희를 대적하여 총독으로 믿지 못하게 힘쓰니","reference":"사도행전 13:8","category":"$undefined"},{"id":"27372","book":"사도행전","book_name":"사도행전","chapter":13,"verse":9,"text":"바울이라고 하는 사울이 성령이 충만하여 그를 주목하고","reference":"사도행전 13:9","category":"$undefined"},{"id":"27373","book":"사도행전","book_name":"사도행전","chapter":13,"verse":10,"text":"가로되 `모든 궤계와 악행이 가득한 자요, 마귀의 자식이요, 모든 의의 원수여, 주의 바른 길을 굽게 하기를 그치지 아니하겠느냐 ?","reference":"사도행전 13:10","category":"$undefined"},{"id":"27374","book":"사도행전","book_name":"사도행전","chapter":13,"verse":11,"text":"보라, 이제 주의 손이 네 위에 있으니 네가 소경이 되어 얼마 동안 해를 보지 못하리라' 하니 즉시 안개와 어두움이 그를 덮어 인도할 사람을 두루 구하는지라","reference":"사도행전 13:11","category":"$undefined"},{"id":"27375","book":"사도행전","book_name":"사도행전","chapter":13,"verse":12,"text":"이에 총독이 그렇게 된 것을 보고 믿으며 주의 가르치심을 기이히 여기니라","reference":"사도행전 13:12","category":"$undefined"},{"id":"27376","book":"사도행전","book_name":"사도행전","chapter":13,"verse":13,"text":"바울과 및 동행하는 사람들이 바보에서 배 타고 밤빌리아에 있는 버가에 이르니 요한은 저희에게서 떠나 예루살렘으로 돌아가고","reference":"사도행전 13:13","category":"$undefined"},{"id":"27377","book":"사도행전","book_name":"사도행전","chapter":13,"verse":14,"text":"저희는 버가로부터 지나 비시디아 안디옥에 이르러 안식일에 회당에 들어가 앉으니라","reference":"사도행전 13:14","category":"$undefined"},{"id":"27378","book":"사도행전","book_name":"사도행전","chapter":13,"verse":15,"text":"율법과 선지자의 글을 읽은 후에 회당장들이 사람을 보내어 물어 가로되 `형제들아, 만일 백성을 권할 말이 있거든 말하라' 하니","reference":"사도행전 13:15","category":"$undefined"},{"id":"27379","book":"사도행전","book_name":"사도행전","chapter":13,"verse":16,"text":"바울이 일어나 손짓하며 말하되 `이스라엘 사람들과 및 하나님을 경외하는 사람들아 들으라 !","reference":"사도행전 13:16","category":"$undefined"},{"id":"27380","book":"사도행전","book_name":"사도행전","chapter":13,"verse":17,"text":"이 이스라엘 백성의 하나님이 우리 조상들을 택하시고 애굽 땅에서 나그네 된 그 백성을 높여 큰 권능으로 인도하여 내사","reference":"사도행전 13:17","category":"$undefined"},{"id":"27381","book":"사도행전","book_name":"사도행전","chapter":13,"verse":18,"text":"광야에서 약 사십 년간 저희 소행을 참으시고","reference":"사도행전 13:18","category":"$undefined"},{"id":"27382","book":"사도행전","book_name":"사도행전","chapter":13,"verse":19,"text":"가나안 땅 일곱 족속을 멸하사 그 땅을 기업으로 주시고 (약 사백 오십 년간)","reference":"사도행전 13:19","category":"$undefined"},{"id":"27383","book":"사도행전","book_name":"사도행전","chapter":13,"verse":20,"text":"그 후에 선지자 사무엘 때까지 사사를 주셨더니","reference":"사도행전 13:20","category":"$undefined"},{"id":"27384","book":"사도행전","book_name":"사도행전","chapter":13,"verse":21,"text":"그 후에 저희가 왕을 구하거늘 하나님이 베냐민 지파 사람 기스의 아들 사울을 사십 년간 주셨다가","reference":"사도행전 13:21","category":"$undefined"},{"id":"27385","book":"사도행전","book_name":"사도행전","chapter":13,"verse":22,"text":"폐하시고 다윗을 왕으로 세우시고 증거하여 가라사대 내가 이새의 아들 다윗을 만나니 내 마음에 합한 사람이라 내 뜻을 다 이루게 하리라 하시더니","reference":"사도행전 13:22","category":"$undefined"},{"id":"27386","book":"사도행전","book_name":"사도행전","chapter":13,"verse":23,"text":"하나님이 약속하신 대로 이 사람의 씨에서 이스라엘을 위하여 구주를 세우셨으니 곧 예수라","reference":"사도행전 13:23","category":"$undefined"},{"id":"27387","book":"사도행전","book_name":"사도행전","chapter":13,"verse":24,"text":"그 오시는 앞에 요한이 먼저 회개의 세례를 이스라엘 모든 백성에게 전파하니라","reference":"사도행전 13:24","category":"$undefined"},{"id":"27388","book":"사도행전","book_name":"사도행전","chapter":13,"verse":25,"text":"요한이 그 달려 갈 길을 마칠 때에 말하되 너희가 나를 누구로 생각하느냐 ? 나는 그리스도가 아니라 내 뒤에 오시는 이가 있으니 나는 그 발의 신 풀기도 감당치 못하리라 하였으니","reference":"사도행전 13:25","category":"$undefined"},{"id":"27389","book":"사도행전","book_name":"사도행전","chapter":13,"verse":26,"text":"형제들 아브라함의 후예와 너희 중 하나님을 경외하는 사람들아 ! 이 구원의 말씀을 우리에게 보내셨거늘","reference":"사도행전 13:26","category":"$undefined"},{"id":"27390","book":"사도행전","book_name":"사도행전","chapter":13,"verse":27,"text":"예루살렘에 사는 자들과 저희 관원들이 예수와 및 안식일마다 외우는 바 선지자들의 말을 알지 못하므로 예수를 정죄하여 선지자들의 말을 응하게 하였도다","reference":"사도행전 13:27","category":"$undefined"},{"id":"27391","book":"사도행전","book_name":"사도행전","chapter":13,"verse":28,"text":"죽일 죄를 하나도 찾지 못하였으나 빌라도에게 죽여 달라 하였으니","reference":"사도행전 13:28","category":"$undefined"},{"id":"27392","book":"사도행전","book_name":"사도행전","chapter":13,"verse":29,"text":"성경에 저를 가리켜 기록한 말씀을 다 응하게 한 것이라 후에 나무에서 내려다가 무덤에 두었으나","reference":"사도행전 13:29","category":"$undefined"},{"id":"27393","book":"사도행전","book_name":"사도행전","chapter":13,"verse":30,"text":"하나님이 죽은 자 가운데서 저를 살리신지라","reference":"사도행전 13:30","category":"$undefined"},{"id":"27394","book":"사도행전","book_name":"사도행전","chapter":13,"verse":31,"text":"갈릴리로부터 예루살렘에 함께 올라간 사람들에게 여러 날 보이셨으니 저희가 이제 백성 앞에 그의 증인이라","reference":"사도행전 13:31","category":"$undefined"},{"id":"27395","book":"사도행전","book_name":"사도행전","chapter":13,"verse":32,"text":"우리도 조상들에게 주신 약속을 너희에게 전파하노니","reference":"사도행전 13:32","category":"$undefined"},{"id":"27396","book":"사도행전","book_name":"사도행전","chapter":13,"verse":33,"text":"곧 하나님이 예수를 일으키사 우리 자녀들에게 이 약속을 이루게 하셨다 함이라 시편 둘째 편에 기록한 바와 같이 너는 내 아들이라 오늘 너를 낳았다 하셨고","reference":"사도행전 13:33","category":"$undefined"},{"id":"27397","book":"사도행전","book_name":"사도행전","chapter":13,"verse":34,"text":"또 하나님께서 죽은 자 가운데서 저를 일으키사 다시 썩음을 당하지 않게 하실 것을 가르쳐 가라사대 내가 다윗의 거룩하고 미쁜 은사를 너희에게 주리라 하셨으니","reference":"사도행전 13:34","category":"$undefined"},{"id":"27398","book":"사도행전","book_name":"사도행전","chapter":13,"verse":35,"text":"그러므로 또 다른 편에 일렀으되 주의 거룩한 자로 썩음을 당하지 않게 하시리라 하셨느니라","reference":"사도행전 13:35","category":"$undefined"},{"id":"27399","book":"사도행전","book_name":"사도행전","chapter":13,"verse":36,"text":"다윗은 당시에 하나님의 뜻을 좇아 섬기다가 잠들어 그 조상들과 함께 묻혀 썩음을 당하였으되","reference":"사도행전 13:36","category":"$undefined"},{"id":"27400","book":"사도행전","book_name":"사도행전","chapter":13,"verse":37,"text":"하나님의 살리신 이는 썩음을 당하지 아니하였나니","reference":"사도행전 13:37","category":"$undefined"},{"id":"27401","book":"사도행전","book_name":"사도행전","chapter":13,"verse":38,"text":"그러므로 형제들아 너희가 알것은 이 사람을 힘입어 죄 사함을 너희에게 전하는 이것이며","reference":"사도행전 13:38","category":"$undefined"},{"id":"27402","book":"사도행전","book_name":"사도행전","chapter":13,"verse":39,"text":"또 모세의 율법으로 너희가 의롭다 하심을 얻지 못하던 모든 일에도 이 사람을 힘입어 믿는 자마다 의롭다 하심을 얻는 이것이라","reference":"사도행전 13:39","category":"$undefined"},{"id":"27403","book":"사도행전","book_name":"사도행전","chapter":13,"verse":40,"text":"그런즉 너희는 선지자들로 말씀하신 것이 너희에게 미칠까 삼가라","reference":"사도행전 13:40","category":"$undefined"},{"id":"27404","book":"사도행전","book_name":"사도행전","chapter":13,"verse":41,"text":"일렀으되 보라, 멸시하는 사람들아 너희는 놀라고 망하라 내가 너희 때를 당하여 한 일을 행할 것이니 사람이 너희에게 이를지라도 도무지 믿지 못할 일이라 하였느니라' 하니라","reference":"사도행전 13:41","category":"$undefined"},{"id":"27405","book":"사도행전","book_name":"사도행전","chapter":13,"verse":42,"text":"저희가 나갈새 사람들이 청하되 다음 안식일에도 이 말씀을 하라 하더라","reference":"사도행전 13:42","category":"$undefined"},{"id":"27406","book":"사도행전","book_name":"사도행전","chapter":13,"verse":43,"text":"폐회한 후에 유대인과 유대교에 입교한 경건한 사람들이 많이 바울과 바나바를 좇으니 두 사도가 더불어 말하고 항상 하나님의 은혜 가운데 있으라 권하니라","reference":"사도행전 13:43","category":"$undefined"},{"id":"27407","book":"사도행전","book_name":"사도행전","chapter":13,"verse":44,"text":"그 다음 안식일에는 온 성이 거의 다 하나님 말씀을 듣고자 하여 모이니","reference":"사도행전 13:44","category":"$undefined"},{"id":"27408","book":"사도행전","book_name":"사도행전","chapter":13,"verse":45,"text":"유대인들이 그 무리를 보고 시기가 가득하여 바울의 말한 것을 변박하고 비방하거늘","reference":"사도행전 13:45","category":"$undefined"},{"id":"27409","book":"사도행전","book_name":"사도행전","chapter":13,"verse":46,"text":"바울과 바나바가 담대히 말하여 가로되 `하나님의 말씀을 마땅히 먼저 너희에게 전할 것이로되 너희가 버리고 영생 얻음에 합당치 않은 자로 자처하기로 우리가 이방인에게로 향하노라","reference":"사도행전 13:46","category":"$undefined"},{"id":"27410","book":"사도행전","book_name":"사도행전","chapter":13,"verse":47,"text":"주께서 이같이 우리를 명하시되 내가 너를 이방의 빛을 삼아 너로 땅 끝까지 구원하게 하리라 하셨느니라' 하니","reference":"사도행전 13:47","category":"$undefined"},{"id":"27411","book":"사도행전","book_name":"사도행전","chapter":13,"verse":48,"text":"이방인들이 듣고 기뻐하여 하나님의 말씀을 찬송하며 영생을 주시기로 작정된 자는 다 믿더라","reference":"사도행전 13:48","category":"$undefined"},{"id":"27412","book":"사도행전","book_name":"사도행전","chapter":13,"verse":49,"text":"주의 말씀이 그 지방에 두루 퍼지니라","reference":"사도행전 13:49","category":"$undefined"},{"id":"27413","book":"사도행전","book_name":"사도행전","chapter":13,"verse":50,"text":"이에 유대인들이 경건한 귀부인들과 그 성내 유력자들을 선동하여 바울과 바나바를 핍박케 하여 그 지경에서 쫓아내니","reference":"사도행전 13:50","category":"$undefined"},{"id":"27414","book":"사도행전","book_name":"사도행전","chapter":13,"verse":51,"text":"두 사람이 저희를 향하여 발에 티끌을 떨어 버리고 이고니온으로 가거늘","reference":"사도행전 13:51","category":"$undefined"},{"id":"27415","book":"사도행전","book_name":"사도행전","chapter":13,"verse":52,"text":"제자들은 기쁨과 성령이 충만하니라","reference":"사도행전 13:52","category":"$undefined"}],"bookSlug":"acts"}]
