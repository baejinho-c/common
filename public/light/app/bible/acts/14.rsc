2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":14,"verses":[{"id":"27416","book":"사도행전","book_name":"사도행전","chapter":14,"verse":1,"text":"이에 이고니온에서 두 사도가 함께 유대인의 회당에 들어가 말하니 유대와 헬라의 허다한 무리가 믿더라","reference":"사도행전 14:1","category":"$undefined"},{"id":"27417","book":"사도행전","book_name":"사도행전","chapter":14,"verse":2,"text":"그러나 순종치 아니하는 유대인들이 이방인들의 마음을 선동하여 형제들에게 악감을 품게 하거늘","reference":"사도행전 14:2","category":"$undefined"},{"id":"27418","book":"사도행전","book_name":"사도행전","chapter":14,"verse":3,"text":"두 사도가 오래 있어 주를 힘입어 담대히 말하니 주께서 저희 손으로 표적과 기사를 행하게 하여 주사 자기 은혜의 말씀을 증거하시니","reference":"사도행전 14:3","category":"$undefined"},{"id":"27419","book":"사도행전","book_name":"사도행전","chapter":14,"verse":4,"text":"그 성내 무리가 나뉘어 유대인을 좇는 자도 있고 두 사도를 좇는 자도 있는지라","reference":"사도행전 14:4","category":"$undefined"},{"id":"27420","book":"사도행전","book_name":"사도행전","chapter":14,"verse":5,"text":"이방인과 유대인과 그 관원들이 두 사도를 능욕하며 돌로 치려고 달려드니","reference":"사도행전 14:5","category":"$undefined"},{"id":"27421","book":"사도행전","book_name":"사도행전","chapter":14,"verse":6,"text":"저희가 알고 도망하여 루가오니아의 두 성 루스드라와 더베와 및 그 근방으로 가서","reference":"사도행전 14:6","category":"$undefined"},{"id":"27422","book":"사도행전","book_name":"사도행전","chapter":14,"verse":7,"text":"거기서 복음을 전하니라","reference":"사도행전 14:7","category":"$undefined"},{"id":"27423","book":"사도행전","book_name":"사도행전","chapter":14,"verse":8,"text":"루스드라에 발을 쓰지 못하는 한 사람이 있어 앉았는데 나면서 앉은뱅이 되어 걸어 본 적이 없는 자라","reference":"사도행전 14:8","category":"$undefined"},{"id":"27424","book":"사도행전","book_name":"사도행전","chapter":14,"verse":9,"text":"바울의 말하는 것을 듣거늘 바울이 주목하여 구원 받을 만한 믿음이 그에게 있는 것을 보고","reference":"사도행전 14:9","category":"$undefined"},{"id":"27425","book":"사도행전","book_name":"사도행전","chapter":14,"verse":10,"text":"큰 소리로 가로되 `네 발로 바로 일어서라' 하니 그 사람이 뛰어 걷는지라","reference":"사도행전 14:10","category":"$undefined"},{"id":"27426","book":"사도행전","book_name":"사도행전","chapter":14,"verse":11,"text":"무리가 바울의 행한 일을 보고 루가오니아 방언으로 소리질러 가로되 신들이 사람의 형상으로 우리 가운데 내려오셨다 하여","reference":"사도행전 14:11","category":"$undefined"},{"id":"27427","book":"사도행전","book_name":"사도행전","chapter":14,"verse":12,"text":"바나바는 쓰스라 하고 바울은 그 중에 말하는 자이므로 허메라 하더라","reference":"사도행전 14:12","category":"$undefined"},{"id":"27428","book":"사도행전","book_name":"사도행전","chapter":14,"verse":13,"text":"성 밖 쓰스 신당의 제사장이 소와 화관들을 가지고 대문 앞에 와서 무리와 함께 제사하고자 하니","reference":"사도행전 14:13","category":"$undefined"},{"id":"27429","book":"사도행전","book_name":"사도행전","chapter":14,"verse":14,"text":"두 사도 바나바와 바울이 듣고 옷을 찢고 무리 가운데 뛰어 들어가서 소리질러","reference":"사도행전 14:14","category":"$undefined"},{"id":"27430","book":"사도행전","book_name":"사도행전","chapter":14,"verse":15,"text":"가로되 `여러분이여, 어찌하여 이러한 일을 하느냐 ? 우리도 너희와 같은 성정을 가진 사람이라 너희에게 복음을 전하는 것은 이 헛된 일을 버리고 천지와 바다와 그 가운데 만유를 지으시고 살아 계신 하나님께로 돌아오라 함이라","reference":"사도행전 14:15","category":"$undefined"},{"id":"27431","book":"사도행전","book_name":"사도행전","chapter":14,"verse":16,"text":"하나님이 지나간 세대에는 모든 족속으로 자기의 길들을 다니게 묵인하셨으나","reference":"사도행전 14:16","category":"$undefined"},{"id":"27432","book":"사도행전","book_name":"사도행전","chapter":14,"verse":17,"text":"그러나 자기를 증거하지 아니 하신 것이 아니니 곧 너희에게 하늘로서 비를 내리시며 결실기를 주시는 선한 일을 하사 음식과 기쁨으로 너희 마음에 만족케 하셨느니라' 하고","reference":"사도행전 14:17","category":"$undefined"},{"id":"27433","book":"사도행전","book_name":"사도행전","chapter":14,"verse":18,"text":"이렇게 말하여 겨우 무리를 말려 자기들에게 제사를 못하게 하니라","reference":"사도행전 14:18","category":"$undefined"},{"id":"27434","book":"사도행전","book_name":"사도행전","chapter":14,"verse":19,"text":"유대인들이 안디옥과 이고니온에서 와서 무리를 초인하여 돌로 바울을 쳐서 죽은 줄로 알고 성 밖에 끌어 내치니라","reference":"사도행전 14:19","category":"$undefined"},{"id":"27435","book":"사도행전","book_name":"사도행전","chapter":14,"verse":20,"text":"제자들이 둘러 섰을 때에 바울이 일어나 성에 들어갔다가 이튿날 바나바와 함께 더베로 가서","reference":"사도행전 14:20","category":"$undefined"},{"id":"27436","book":"사도행전","book_name":"사도행전","chapter":14,"verse":21,"text":"복음을 그 성에서 전하여 많은 사람을 제자로 삼고 루스드라와 이고니온과 안디옥으로 돌아가서","reference":"사도행전 14:21","category":"$undefined"},{"id":"27437","book":"사도행전","book_name":"사도행전","chapter":14,"verse":22,"text":"제자들의 마음을 굳게 하여 이 믿음에 거하라 권하고 또 우리가 하나님 나라에 들어가려면 많은 환난을 겪어야 할 것이라 하고","reference":"사도행전 14:22","category":"$undefined"},{"id":"27438","book":"사도행전","book_name":"사도행전","chapter":14,"verse":23,"text":"각 교회에서 장로들을 택하여 금식 기도하며 저희를 그 믿은 바 주께 부탁하고","reference":"사도행전 14:23","category":"$undefined"},{"id":"27439","book":"사도행전","book_name":"사도행전","chapter":14,"verse":24,"text":"비시디아 가운데로 지나가서 밤빌리아에 이르러","reference":"사도행전 14:24","category":"$undefined"},{"id":"27440","book":"사도행전","book_name":"사도행전","chapter":14,"verse":25,"text":"도를 버가에서 전하고 앗달리아로 내려가서","reference":"사도행전 14:25","category":"$undefined"},{"id":"27441","book":"사도행전","book_name":"사도행전","chapter":14,"verse":26,"text":"거기서 배 타고 안디옥에 이르니 이곳은 두 사도의 이룬 그 일을 위하여 전에 하나님의 은혜에 부탁하던 곳이라","reference":"사도행전 14:26","category":"$undefined"},{"id":"27442","book":"사도행전","book_name":"사도행전","chapter":14,"verse":27,"text":"이르러 교회를 모아 하나님이 함께 행하신 모든 일과 이방인들에게 믿음의 문을 여신 것을 고하고","reference":"사도행전 14:27","category":"$undefined"},{"id":"27443","book":"사도행전","book_name":"사도행전","chapter":14,"verse":28,"text":"제자들과 함께 오래 있으니라","reference":"사도행전 14:28","category":"$undefined"}],"bookSlug":"acts"}]
