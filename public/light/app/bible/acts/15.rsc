2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":15,"verses":[{"id":"27444","book":"사도행전","book_name":"사도행전","chapter":15,"verse":1,"text":"어떤 사람들이 유대로부터 내려와서 형제들을 가르치되 `너희가 모세의 법대로 할례를 받지 아니하면 능히 구원을 얻지 못하리라' 하니","reference":"사도행전 15:1","category":"$undefined"},{"id":"27445","book":"사도행전","book_name":"사도행전","chapter":15,"verse":2,"text":"바울과 바나바와 저희 사이에 적지 아니한 다툼과 변론이 일어난지라 형제들이 이 문제에 대하여 바울과 바나바와 및 그 중에 몇사람을 예루살렘에 있는 사도와 장로들에게 보내기로 작정하니","reference":"사도행전 15:2","category":"$undefined"},{"id":"27446","book":"사도행전","book_name":"사도행전","chapter":15,"verse":3,"text":"저희가 교회의 전송을 받고 베니게와 사마리아로 다녀가며 이방인들의 주께 돌아온 일을 말하여 형제들을 다 크게 기쁘게 하더라","reference":"사도행전 15:3","category":"$undefined"},{"id":"27447","book":"사도행전","book_name":"사도행전","chapter":15,"verse":4,"text":"예루살렘에 이르러 교회와 사도와 장로들에게 영접을 받고 하나님이 자기들과 함께 계셔 행하신 모든 일을 말하매","reference":"사도행전 15:4","category":"$undefined"},{"id":"27448","book":"사도행전","book_name":"사도행전","chapter":15,"verse":5,"text":"바리새파 중에 믿는 어떤 사람들이 일어나 말하되 `이방인에게 할례주고 모세의 율법을 지키라 명하는 것이 마땅하다' 하니라","reference":"사도행전 15:5","category":"$undefined"},{"id":"27449","book":"사도행전","book_name":"사도행전","chapter":15,"verse":6,"text":"사도와 장로들이 이 일을 의논하러 모여","reference":"사도행전 15:6","category":"$undefined"},{"id":"27450","book":"사도행전","book_name":"사도행전","chapter":15,"verse":7,"text":"많은 변론이 있은 후에 베드로가 일어나 말하되 `형제들아, 너희도 알거니와 하나님이 이방인들로 내 입에서 복음의 말씀을 들어 믿게 하시려고 오래 전부터 너희 가운데서 나를 택하시고","reference":"사도행전 15:7","category":"$undefined"},{"id":"27451","book":"사도행전","book_name":"사도행전","chapter":15,"verse":8,"text":"또 마음을 아시는 하나님이 우리에게와 같이 저희에게도 성령을 주어 증거하시고","reference":"사도행전 15:8","category":"$undefined"},{"id":"27452","book":"사도행전","book_name":"사도행전","chapter":15,"verse":9,"text":"믿음으로 저희 마음을 깨끗이 하사 저희나 우리나 분간치 아니하셨느니라","reference":"사도행전 15:9","category":"$undefined"},{"id":"27453","book":"사도행전","book_name":"사도행전","chapter":15,"verse":10,"text":"그런데 지금 너희가 어찌하여 하나님을 시험하여 우리 조상과 우리도 능히 메지 못하던 멍에를 제자들의 목에 두려느냐","reference":"사도행전 15:10","category":"$undefined"},{"id":"27454","book":"사도행전","book_name":"사도행전","chapter":15,"verse":11,"text":"우리가 저희와 동일하게 주 예수의 은혜로 구원 받는 줄을 믿노라' 하니라","reference":"사도행전 15:11","category":"$undefined"},{"id":"27455","book":"사도행전","book_name":"사도행전","chapter":15,"verse":12,"text":"온 무리가 가만히 있어 바나바와 바울이 하나님이 자기들로 말미암아 이방인 중에서 행하신 표적과 기사 고하는 것을 듣더니","reference":"사도행전 15:12","category":"$undefined"},{"id":"27456","book":"사도행전","book_name":"사도행전","chapter":15,"verse":13,"text":"말을 마치매 야고보가 대답하여 가로되 `형제들아 내 말을 들으라","reference":"사도행전 15:13","category":"$undefined"},{"id":"27457","book":"사도행전","book_name":"사도행전","chapter":15,"verse":14,"text":"하나님이 처음으로 이방인 중에서 자기 이름을 위할 백성을 취하시려고 저희를 권고하신 것을 시므온이 고하였으니","reference":"사도행전 15:14","category":"$undefined"},{"id":"27458","book":"사도행전","book_name":"사도행전","chapter":15,"verse":15,"text":"선지자들의 말씀이 이와 합하도다 기록된 바","reference":"사도행전 15:15","category":"$undefined"},{"id":"27459","book":"사도행전","book_name":"사도행전","chapter":15,"verse":16,"text":"이 후에 내가 돌아와서 다윗의 무너진 장막을 다시 지으며 또 그 퇴락한 것을 다시 지어 일으키리니","reference":"사도행전 15:16","category":"$undefined"},{"id":"27460","book":"사도행전","book_name":"사도행전","chapter":15,"verse":17,"text":"이는 그 남은 사람들과 내 이름으로 일컬음을 받는 모든 이방인들로 주를 찾게 하려 함이라 하셨으니","reference":"사도행전 15:17","category":"$undefined"},{"id":"27461","book":"사도행전","book_name":"사도행전","chapter":15,"verse":18,"text":"즉 예로부터 이것을 알게 하시는 주의 말씀이라 함과 같으니라","reference":"사도행전 15:18","category":"$undefined"},{"id":"27462","book":"사도행전","book_name":"사도행전","chapter":15,"verse":19,"text":"그러므로 내 의견에는 이방인중에서 하나님께로 돌아 오는 자들을 괴롭게 말고","reference":"사도행전 15:19","category":"$undefined"},{"id":"27463","book":"사도행전","book_name":"사도행전","chapter":15,"verse":20,"text":"다만 우상의 더러운 것과 음행과 목매어 죽인 것과 피를 멀리하라고 편지하는 것이 가하니","reference":"사도행전 15:20","category":"$undefined"},{"id":"27464","book":"사도행전","book_name":"사도행전","chapter":15,"verse":21,"text":"이는 예로부터 각 성에서 모세를 전하는 자가 있어 안식일마다 회당에서 그 글을 읽음이니라' 하더라","reference":"사도행전 15:21","category":"$undefined"},{"id":"27465","book":"사도행전","book_name":"사도행전","chapter":15,"verse":22,"text":"이에 사도와 장로와 온 교회가 그 중에서 사람을 택하여 바울과 바나바와 함께 안디옥으로 보내기를 가결하니 곧 형제 중에 인도자인 바사바라 하는 유다와 실라더라","reference":"사도행전 15:22","category":"$undefined"},{"id":"27466","book":"사도행전","book_name":"사도행전","chapter":15,"verse":23,"text":"그 편에 편지를 부쳐 이르되 `사도와 장로된 형제들은 안디옥과 수리아와 길리기아에 있는 이방인 형제들에게 문안하노라","reference":"사도행전 15:23","category":"$undefined"},{"id":"27467","book":"사도행전","book_name":"사도행전","chapter":15,"verse":24,"text":"들은즉 우리 가운데서 어떤 사람들이 우리의 시킨 것도 없이 나가서 말로 너희를 괴롭게 하고 마음을 혹하게 한다 하기로","reference":"사도행전 15:24","category":"$undefined"},{"id":"27468","book":"사도행전","book_name":"사도행전","chapter":15,"verse":25,"text":"사람을 택하여 우리 주 예수 그리스도의 이름을 위하여 생명을 아끼지 아니하는 자인 우리의 사랑하는 바나바와 바울과 함께 너희에게 보내기를 일치 가결하였노라","reference":"사도행전 15:25","category":"$undefined"},{"id":"27469","book":"사도행전","book_name":"사도행전","chapter":15,"verse":26,"text":"(25 절과 같음)","reference":"사도행전 15:26","category":"$undefined"},{"id":"27470","book":"사도행전","book_name":"사도행전","chapter":15,"verse":27,"text":"그리하여 유다와 실라를 보내니 저희도 이 일을 말로 전하리라","reference":"사도행전 15:27","category":"$undefined"},{"id":"27471","book":"사도행전","book_name":"사도행전","chapter":15,"verse":28,"text":"성령과 우리는 이 요긴한 것들 외에 아무 짐도 너희에게 지우지 아니하는 것이 가한 줄 알았노니","reference":"사도행전 15:28","category":"$undefined"},{"id":"27472","book":"사도행전","book_name":"사도행전","chapter":15,"verse":29,"text":"우상의 제물과 피와 목매어 죽인 것과 음행을 멀리 할지니라 이에 스스로 삼가면 잘되리라 평안함을 원하노라' 하였더라","reference":"사도행전 15:29","category":"$undefined"},{"id":"27473","book":"사도행전","book_name":"사도행전","chapter":15,"verse":30,"text":"저희가 작별하고 안디옥에 내려가 무리를 모은 후에 편지를 전하니","reference":"사도행전 15:30","category":"$undefined"},{"id":"27474","book":"사도행전","book_name":"사도행전","chapter":15,"verse":31,"text":"읽고 그 위로한 말을 기뻐하더라","reference":"사도행전 15:31","category":"$undefined"},{"id":"27475","book":"사도행전","book_name":"사도행전","chapter":15,"verse":32,"text":"유다와 실라도 선지자라 여러말로 형제를 권면하여 굳게 하고","reference":"사도행전 15:32","category":"$undefined"},{"id":"27476","book":"사도행전","book_name":"사도행전","chapter":15,"verse":33,"text":"얼마 있다가 평안히 가라는 전송을 형제들에게 받고 자기를 보내던 사람들에게로 돌아가되","reference":"사도행전 15:33","category":"$undefined"},{"id":"27477","book":"사도행전","book_name":"사도행전","chapter":15,"verse":34,"text":"(없 음)","reference":"사도행전 15:34","category":"$undefined"},{"id":"27478","book":"사도행전","book_name":"사도행전","chapter":15,"verse":35,"text":"바울과 바나바는 안디옥에서 유하여 다수한 다른 사람들과 함께 주의 말씀을 가르치며 전파하니라","reference":"사도행전 15:35","category":"$undefined"},{"id":"27479","book":"사도행전","book_name":"사도행전","chapter":15,"verse":36,"text":"수일 후에 바울이 바나바더러 말하되 `우리가 주의 말씀을 전한 각 성으로 다시 가서 형제들이 어떠한가 방문하자' 하니","reference":"사도행전 15:36","category":"$undefined"},{"id":"27480","book":"사도행전","book_name":"사도행전","chapter":15,"verse":37,"text":"바나바는 마가라 하는 요한도 데리고 가고자 하나","reference":"사도행전 15:37","category":"$undefined"},{"id":"27481","book":"사도행전","book_name":"사도행전","chapter":15,"verse":38,"text":"바울은 밤빌리아에서 자기들을 떠나 한가지로 일하러 가지 아니한 자를 데리고 가는 것이 옳지않다 하여","reference":"사도행전 15:38","category":"$undefined"},{"id":"27482","book":"사도행전","book_name":"사도행전","chapter":15,"verse":39,"text":"서로 심히 다투어 피차 갈라서니 바나바는 마가를 데리고 배 타고 구브로로 가고","reference":"사도행전 15:39","category":"$undefined"},{"id":"27483","book":"사도행전","book_name":"사도행전","chapter":15,"verse":40,"text":"바울은 실라를 택한 후에 형제들에게 주의 은혜에 부탁함을 받고 떠나","reference":"사도행전 15:40","category":"$undefined"},{"id":"27484","book":"사도행전","book_name":"사도행전","chapter":15,"verse":41,"text":"수리아와 길리기아로 다녀가며 교회들을 굳게 하니라","reference":"사도행전 15:41","category":"$undefined"}],"bookSlug":"acts"}]
