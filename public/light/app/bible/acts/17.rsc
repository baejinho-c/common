2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":17,"verses":[{"id":"27525","book":"사도행전","book_name":"사도행전","chapter":17,"verse":1,"text":"저희가 암비볼리와 아볼로니아로 다녀가 데살로니가에 이르니 거기 유대인의 회당이 있는지라","reference":"사도행전 17:1","category":"$undefined"},{"id":"27526","book":"사도행전","book_name":"사도행전","chapter":17,"verse":2,"text":"바울이 자기의 규례대로 저희에게로 들어가서 세 안식일에 성경을 가지고 강론하며","reference":"사도행전 17:2","category":"$undefined"},{"id":"27527","book":"사도행전","book_name":"사도행전","chapter":17,"verse":3,"text":"뜻을 풀어 그리스도가 해를 받고 죽은 자 가운데서 다시 살아야 할 것을 증명하고 이르되 내가 너희에게 전하는 이 예수가 곧 그리스도라 하니","reference":"사도행전 17:3","category":"$undefined"},{"id":"27528","book":"사도행전","book_name":"사도행전","chapter":17,"verse":4,"text":"그 중에 어떤 사람 곧 경건한 헬라인의 큰 무리와 적지 않은 귀부인도 권함을 받고 바울과 실라를 좇으나","reference":"사도행전 17:4","category":"$undefined"},{"id":"27529","book":"사도행전","book_name":"사도행전","chapter":17,"verse":5,"text":"그러나 유대인들은 시기하여 저자의 어떤 괴악한 사람들을 데리고 떼를 지어 성을 소동케 하여 야손의 집에 달려들어 저희를 백성에게 끌어 내려고 찾았으나","reference":"사도행전 17:5","category":"$undefined"},{"id":"27530","book":"사도행전","book_name":"사도행전","chapter":17,"verse":6,"text":"발견치 못하매 야손과 및 형제를 끌고 읍장들 앞에 가서 소리질러 가로되 `천하를 어지럽게 하던 이 사람들이 여기도 이르매","reference":"사도행전 17:6","category":"$undefined"},{"id":"27531","book":"사도행전","book_name":"사도행전","chapter":17,"verse":7,"text":"야손이 들였도다 이 사람들이 다 가이사의 명을 거역하여 말하되 다른 임금 곧 예수라 하는 이가 있다 하더이다' 하니","reference":"사도행전 17:7","category":"$undefined"},{"id":"27532","book":"사도행전","book_name":"사도행전","chapter":17,"verse":8,"text":"무리와 읍장들이 이 말을 듣고 소동하여","reference":"사도행전 17:8","category":"$undefined"},{"id":"27533","book":"사도행전","book_name":"사도행전","chapter":17,"verse":9,"text":"야손과 그 나머지 사람들에게 보를 받고 놓으니라","reference":"사도행전 17:9","category":"$undefined"},{"id":"27534","book":"사도행전","book_name":"사도행전","chapter":17,"verse":10,"text":"밤에 형제들이 곧 바울과 실라를 베뢰아로 보내니 저희가 이르러 유대인의 회당에 들어가니라","reference":"사도행전 17:10","category":"$undefined"},{"id":"27535","book":"사도행전","book_name":"사도행전","chapter":17,"verse":11,"text":"베뢰아 사람은 데살로니가에 있는 사람보다 더 신사적이어서 간절한 마음으로 말씀을 받고 이것이 그러한가 하여 날마다 성경을 상고하므로","reference":"사도행전 17:11","category":"$undefined"},{"id":"27536","book":"사도행전","book_name":"사도행전","chapter":17,"verse":12,"text":"그 중에 믿는 사람이 많고 또 헬라의 귀부인과 남자가 적지 아니하나","reference":"사도행전 17:12","category":"$undefined"},{"id":"27537","book":"사도행전","book_name":"사도행전","chapter":17,"verse":13,"text":"데살로니가에 있는 유대인들이 바울이 하나님 말씀을 베뢰아에서도 전하는 줄을 알고 거기도 가서 무리를 움직여 소동케 하거늘","reference":"사도행전 17:13","category":"$undefined"},{"id":"27538","book":"사도행전","book_name":"사도행전","chapter":17,"verse":14,"text":"형제들이 곧 바울을 내어 보내어 바다까지 가게 하되 실라와 디모데는 아직 거기 유하더라","reference":"사도행전 17:14","category":"$undefined"},{"id":"27539","book":"사도행전","book_name":"사도행전","chapter":17,"verse":15,"text":"바울을 인도하는 사람들이 데리고 아덴까지 이르러 바울에게서 실라와 디모데를 자기에게로 속히 오게 하라는 명을 받고 떠나니라","reference":"사도행전 17:15","category":"$undefined"},{"id":"27540","book":"사도행전","book_name":"사도행전","chapter":17,"verse":16,"text":"바울이 아덴에서 저희를 기다리다가 온 성에 우상이 가득한 것을 보고 마음에 분하여","reference":"사도행전 17:16","category":"$undefined"},{"id":"27541","book":"사도행전","book_name":"사도행전","chapter":17,"verse":17,"text":"회당에서는 유대인과 경건한 사람들과 또 저자에서는 날마다 만나는 사람들과 변론하니","reference":"사도행전 17:17","category":"$undefined"},{"id":"27542","book":"사도행전","book_name":"사도행전","chapter":17,"verse":18,"text":"어떤 에비구레오와 스도이고 철학자들도 바울과 쟁론할새 혹은 이르되 이 말장이가 무슨 말을 하고자 하느뇨 하고 혹은 이르되 이방 신들을 전하는 사람인가보다 하니 이는 바울이 예수와 또 몸의 부활 전함을 인함이러라","reference":"사도행전 17:18","category":"$undefined"},{"id":"27543","book":"사도행전","book_name":"사도행전","chapter":17,"verse":19,"text":"붙들어 가지고 아레오바고로 가며 말하기를 `우리가 너의 말하는 이 새교가 무엇인지 알 수 있겠느냐 ?","reference":"사도행전 17:19","category":"$undefined"},{"id":"27544","book":"사도행전","book_name":"사도행전","chapter":17,"verse":20,"text":"네가 무슨 이상한 것을 우리 귀에 들려 주니 그 무슨 뜻인지 알고자 하노라' 하니","reference":"사도행전 17:20","category":"$undefined"},{"id":"27545","book":"사도행전","book_name":"사도행전","chapter":17,"verse":21,"text":"모든 아덴 사람과 거기서 나그네 된 외국인들이 가장 새로 되는 것을 말하고 듣는 이외에 달리는 시간을 쓰지 않음이더라","reference":"사도행전 17:21","category":"$undefined"},{"id":"27546","book":"사도행전","book_name":"사도행전","chapter":17,"verse":22,"text":"바울이 아레오바고 가운데 서서 말하되 아덴 사람들아 너희를 보니 범사에 종교성이 많도다","reference":"사도행전 17:22","category":"$undefined"},{"id":"27547","book":"사도행전","book_name":"사도행전","chapter":17,"verse":23,"text":"내가 두루 다니며 너희의 위하는 것들을 보다가 알지 못하는 신에게라고 새긴 단도 보았으니 그런즉 너희가 알지 못하고 위하는그것을 내가 너희에게 알게 하리라","reference":"사도행전 17:23","category":"$undefined"},{"id":"27548","book":"사도행전","book_name":"사도행전","chapter":17,"verse":24,"text":"우주와 그 가운데 있는 만유를 지으신 신께서는 천지의 주재시니 손으로 지은 전에 계시지 아니하시고","reference":"사도행전 17:24","category":"$undefined"},{"id":"27549","book":"사도행전","book_name":"사도행전","chapter":17,"verse":25,"text":"또 무엇이 부족한 것처럼 사람의 손으로 섬김을 받으시는 것이 아니니 이는 만민에게 생명과 호흡과 만물을 친히 주시는 자이심이라","reference":"사도행전 17:25","category":"$undefined"},{"id":"27550","book":"사도행전","book_name":"사도행전","chapter":17,"verse":26,"text":"인류의 모든 족속을 한 혈통으로 만드사 온 땅에 거하게 하시고 저희의 연대를 정하시며 거주의 경계를 한하셨으니","reference":"사도행전 17:26","category":"$undefined"},{"id":"27551","book":"사도행전","book_name":"사도행전","chapter":17,"verse":27,"text":"이는 사람으로 하나님을 혹 더듬어 찾아 발견케 하려 하심이로되 그는 우리 각 사람에게서 멀리 떠나 계시지 아니하도다","reference":"사도행전 17:27","category":"$undefined"},{"id":"27552","book":"사도행전","book_name":"사도행전","chapter":17,"verse":28,"text":"우리가 그를 힘입어 살며 기동하며 있느니라 너희 시인 중에도 어떤 사람들의 말과 같이 우리가 그의 소생이라 하니","reference":"사도행전 17:28","category":"$undefined"},{"id":"27553","book":"사도행전","book_name":"사도행전","chapter":17,"verse":29,"text":"이와 같이 신의 소생이 되었은 즉 신을 금이나 은이나 돌에다 사람의 기술과 고안으로 새긴 것들과 같이 여길 것이 아니니라","reference":"사도행전 17:29","category":"$undefined"},{"id":"27554","book":"사도행전","book_name":"사도행전","chapter":17,"verse":30,"text":"알지 못하던 시대에는 하나님이 허물치 아니하셨거니와 이제는 어디든지 사람을 다 명하사 회개하라 하셨으니","reference":"사도행전 17:30","category":"$undefined"},{"id":"27555","book":"사도행전","book_name":"사도행전","chapter":17,"verse":31,"text":"이는 정하신 사람으로 하여금 천하를 공의로 심판할 날을 작정하시고 이에 저를 죽은 자 가운데서 다시 살리신 것으로 모든 사람에게 믿을 만한 증거를 주셨음이니라 하니라","reference":"사도행전 17:31","category":"$undefined"},{"id":"27556","book":"사도행전","book_name":"사도행전","chapter":17,"verse":32,"text":"저희가 죽은 자의 부활을 듣고 혹은 기롱도 하고 혹은 이 일에 대하여 네 말을 다시 듣겠다 하니","reference":"사도행전 17:32","category":"$undefined"},{"id":"27557","book":"사도행전","book_name":"사도행전","chapter":17,"verse":33,"text":"이에 바울이 저희 가운데서 떠나매","reference":"사도행전 17:33","category":"$undefined"},{"id":"27558","book":"사도행전","book_name":"사도행전","chapter":17,"verse":34,"text":"몇 사람이 그를 친하여 믿으니 그 중 아레오바고 관원 디오누시오와 다마리라 하는 여자와 또 다른 사람들도 있었더라","reference":"사도행전 17:34","category":"$undefined"}],"bookSlug":"acts"}]
