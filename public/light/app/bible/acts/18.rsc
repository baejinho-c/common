2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":18,"verses":[{"id":"27559","book":"사도행전","book_name":"사도행전","chapter":18,"verse":1,"text":"이후에 바울이 아덴을 떠나 고린도에 이르러","reference":"사도행전 18:1","category":"$undefined"},{"id":"27560","book":"사도행전","book_name":"사도행전","chapter":18,"verse":2,"text":"아굴라라 하는 본도에서 난 유대인 하나를 만나니 글라우디오가 모든 유대인을 명하여 로마에서 떠나라 한고로 그가 그 아내 브리스길라와 함께 이달리야로부터 새로 온지라 바울이 그들에게 가매","reference":"사도행전 18:2","category":"$undefined"},{"id":"27561","book":"사도행전","book_name":"사도행전","chapter":18,"verse":3,"text":"업이 같으므로 함께 거하여 일을 하니 그 업은 장막을 만드는 것이더라","reference":"사도행전 18:3","category":"$undefined"},{"id":"27562","book":"사도행전","book_name":"사도행전","chapter":18,"verse":4,"text":"안식일마다 바울이 회당에서 강론하고 유대인과 헬라인을 권면하니라","reference":"사도행전 18:4","category":"$undefined"},{"id":"27563","book":"사도행전","book_name":"사도행전","chapter":18,"verse":5,"text":"실라와 디모데가 마게도냐로서 내려오매 바울이 하나님의 말씀에 붙잡혀 유대인들에게 예수는 그리스도라 밝히 증거하니","reference":"사도행전 18:5","category":"$undefined"},{"id":"27564","book":"사도행전","book_name":"사도행전","chapter":18,"verse":6,"text":"저희가 대적하여 훼방하거늘 바울이 옷을 떨어 가로되 `너희 피가 너희 머리로 돌아갈 것이요 나는 깨끗하니라 이 후에는 이방인에게로 가리라' 하고","reference":"사도행전 18:6","category":"$undefined"},{"id":"27565","book":"사도행전","book_name":"사도행전","chapter":18,"verse":7,"text":"거기서 옮겨 하나님을 공경하는 디도 유스도라 하는 사람의 집에 들어가니 그 집이 회당 옆이라","reference":"사도행전 18:7","category":"$undefined"},{"id":"27566","book":"사도행전","book_name":"사도행전","chapter":18,"verse":8,"text":"또 회당장 그리스보가 온 집으로 더불어 주를 믿으며 수다한 고린도 사람도 듣고 믿어 세례를 받더라","reference":"사도행전 18:8","category":"$undefined"},{"id":"27567","book":"사도행전","book_name":"사도행전","chapter":18,"verse":9,"text":"밤에 주께서 환상 가운데 바울에게 말씀하시되 두려워하지 말며 잠잠하지 말고 말하라","reference":"사도행전 18:9","category":"$undefined"},{"id":"27568","book":"사도행전","book_name":"사도행전","chapter":18,"verse":10,"text":"내가 너와 함께 있으매 아무 사람도 너를 대적하여 해롭게 할 자가 없을 것이니 이는 이 성중에 내 백성이 많음이라 하시더라","reference":"사도행전 18:10","category":"$undefined"},{"id":"27569","book":"사도행전","book_name":"사도행전","chapter":18,"verse":11,"text":"일년 육 개월을 유하며 그들 가운데서 하나님의 말씀을 가르치니라","reference":"사도행전 18:11","category":"$undefined"},{"id":"27570","book":"사도행전","book_name":"사도행전","chapter":18,"verse":12,"text":"갈리오가 아가야 총독 되었을 때에 유대인이 일제히 일어나 바울을 대적하여 재판 자리로 데리고 와서","reference":"사도행전 18:12","category":"$undefined"},{"id":"27571","book":"사도행전","book_name":"사도행전","chapter":18,"verse":13,"text":"말하되 `이 사람이 율법을 어기어 하나님을 공경하라고 사람들을 권한다' 하거늘","reference":"사도행전 18:13","category":"$undefined"},{"id":"27572","book":"사도행전","book_name":"사도행전","chapter":18,"verse":14,"text":"바울이 입을 열고자 할 때에 갈리오가 유대인들에게 이르되 `너희 유대인들아 만일 무슨 부정한 일이나 괴악한 행동이었으면 내가 너희 말을 들어주는 것이 가하거니와","reference":"사도행전 18:14","category":"$undefined"},{"id":"27573","book":"사도행전","book_name":"사도행전","chapter":18,"verse":15,"text":"만일 문제가 언어와 명칭과 너희 법에 관한 것이면 너희가 스스로 처리하라 나는 이러한 일에 재판장 되기를 원치 아니하노라' 하고","reference":"사도행전 18:15","category":"$undefined"},{"id":"27574","book":"사도행전","book_name":"사도행전","chapter":18,"verse":16,"text":"저희를 재판 자리에서 쫓아내니","reference":"사도행전 18:16","category":"$undefined"},{"id":"27575","book":"사도행전","book_name":"사도행전","chapter":18,"verse":17,"text":"모든 사람이 회당장 소스데네를 잡아 재판 자리 앞에서 때리되 갈리오가 이 일을 상관치 아니하니라","reference":"사도행전 18:17","category":"$undefined"},{"id":"27576","book":"사도행전","book_name":"사도행전","chapter":18,"verse":18,"text":"바울은 더 여러 날 유하다가 형제들을 작별하고 배 타고 수리아로 떠나갈 새 브리스길라와 아굴라도 함께 하더라 바울이 일찍 서원이 있으므로 겐그레아에서 머리를 깎았더라","reference":"사도행전 18:18","category":"$undefined"},{"id":"27577","book":"사도행전","book_name":"사도행전","chapter":18,"verse":19,"text":"에베소에 와서 저희를 거기 머물러 두고 자기는 회당에 들어가서 유대인들과 변론하니","reference":"사도행전 18:19","category":"$undefined"},{"id":"27578","book":"사도행전","book_name":"사도행전","chapter":18,"verse":20,"text":"여러 사람이 더 오래 있기를 청하되 허락치 아니하고","reference":"사도행전 18:20","category":"$undefined"},{"id":"27579","book":"사도행전","book_name":"사도행전","chapter":18,"verse":21,"text":"작별하여 가로되 `만일 하나님의 뜻이면 너희에게 돌아오리라' 하고 배를 타고 에베소를 떠나","reference":"사도행전 18:21","category":"$undefined"},{"id":"27580","book":"사도행전","book_name":"사도행전","chapter":18,"verse":22,"text":"가이사랴에서 상륙하여 올라가 교회의 안부를 물은 후에 안디옥으로 내려가서","reference":"사도행전 18:22","category":"$undefined"},{"id":"27581","book":"사도행전","book_name":"사도행전","chapter":18,"verse":23,"text":"얼마 있다가 떠나 갈라디아와 브루기아 땅을 차례로 다니며 모든 제자를 굳게 하니라","reference":"사도행전 18:23","category":"$undefined"},{"id":"27582","book":"사도행전","book_name":"사도행전","chapter":18,"verse":24,"text":"알렉산드리아에서 난 아볼로라 하는 유대인이 에베소에 이르니 이 사람은 학문이 많고 성경에 능한 자라","reference":"사도행전 18:24","category":"$undefined"},{"id":"27583","book":"사도행전","book_name":"사도행전","chapter":18,"verse":25,"text":"그가 일찍 주의 도를 배워 열심으로 예수에 관한 것을 자세히 말하며 가르치나 요한의 세례만 알 따름이라","reference":"사도행전 18:25","category":"$undefined"},{"id":"27584","book":"사도행전","book_name":"사도행전","chapter":18,"verse":26,"text":"그가 회당에서 담대히 말하기를 시작하거늘 브리스길라와 아굴라가 듣고 데려다가 하나님의 도를 더 자세히 풀어 이르더라","reference":"사도행전 18:26","category":"$undefined"},{"id":"27585","book":"사도행전","book_name":"사도행전","chapter":18,"verse":27,"text":"아볼로가 아가야로 건너가고자 하니 형제들이 저를 장려하며 제자들에게 편지하여 영접하라 하였더니 저가 가매 은혜로 말미암아 믿은 자들에게 많은 유익을 주니","reference":"사도행전 18:27","category":"$undefined"},{"id":"27586","book":"사도행전","book_name":"사도행전","chapter":18,"verse":28,"text":"이는 성경으로써 예수는 그리스도라고 증거하여 공중 앞에서 유력하게 유대인의 말을 이김일러라","reference":"사도행전 18:28","category":"$undefined"}],"bookSlug":"acts"}]
