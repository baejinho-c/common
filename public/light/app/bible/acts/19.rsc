2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":19,"verses":[{"id":"27587","book":"사도행전","book_name":"사도행전","chapter":19,"verse":1,"text":"아볼로가 고린도에 있을 때에 바울이 윗지방으로 다녀 에베소에 와서 어떤 제자들을 만나","reference":"사도행전 19:1","category":"$undefined"},{"id":"27588","book":"사도행전","book_name":"사도행전","chapter":19,"verse":2,"text":"가로되 `너희가 믿을 때에 성령을 받았느냐 ?' 가로되 `아니라 우리는 성령이 있음도 듣지 못하였노라'","reference":"사도행전 19:2","category":"$undefined"},{"id":"27589","book":"사도행전","book_name":"사도행전","chapter":19,"verse":3,"text":"바울이 가로되 그러면 너희가 무슨 세례를 받았느냐 ? 대답하되 요한의 세례로라","reference":"사도행전 19:3","category":"$undefined"},{"id":"27590","book":"사도행전","book_name":"사도행전","chapter":19,"verse":4,"text":"바울이 가로되 `요한이 회개의 세례를 베풀며 백성에게 말하되 내 뒤에 오시는 이를 믿으라 하였으니 이는 곧 예수라' 하거늘","reference":"사도행전 19:4","category":"$undefined"},{"id":"27591","book":"사도행전","book_name":"사도행전","chapter":19,"verse":5,"text":"저희가 듣고 주 예수의 이름으로 세례를 받으니","reference":"사도행전 19:5","category":"$undefined"},{"id":"27592","book":"사도행전","book_name":"사도행전","chapter":19,"verse":6,"text":"바울이 그들에게 안수하매 성령이 그들에게 임하시므로 방언도 하고 예언도 하니","reference":"사도행전 19:6","category":"$undefined"},{"id":"27593","book":"사도행전","book_name":"사도행전","chapter":19,"verse":7,"text":"모두 열 두 사람쯤 되니라","reference":"사도행전 19:7","category":"$undefined"},{"id":"27594","book":"사도행전","book_name":"사도행전","chapter":19,"verse":8,"text":"바울이 회당에 들어가 석 달 동안을 담대히 하나님 나라에 대하여 강론하며 권면하되","reference":"사도행전 19:8","category":"$undefined"},{"id":"27595","book":"사도행전","book_name":"사도행전","chapter":19,"verse":9,"text":"어떤 사람들은 마음이 굳어 순종치 않고 무리 앞에서 이 도를 비방하거늘 바울이 그들을 떠나 제자들을 따로 세우고 두란노 서원에서 날마다 강론하여","reference":"사도행전 19:9","category":"$undefined"},{"id":"27596","book":"사도행전","book_name":"사도행전","chapter":19,"verse":10,"text":"이같이 두 해 동안을 하매 아시아에 사는 자는 유대인이나 헬라인이나 다 주의 말씀을 듣더라","reference":"사도행전 19:10","category":"$undefined"},{"id":"27597","book":"사도행전","book_name":"사도행전","chapter":19,"verse":11,"text":"하나님이 바울의 손으로 희한한 능을 행하게 하시니","reference":"사도행전 19:11","category":"$undefined"},{"id":"27598","book":"사도행전","book_name":"사도행전","chapter":19,"verse":12,"text":"심지어 사람들이 바울의 몸에서 손수건이나 앞치마를 가져다가 병든 사람에게 얹으면 그 병이 떠나고 악귀도 나가더라","reference":"사도행전 19:12","category":"$undefined"},{"id":"27599","book":"사도행전","book_name":"사도행전","chapter":19,"verse":13,"text":"이에 돌아다니며 마술하는 어떤 유대인들이 시험적으로 악귀 들린 자들에게 대하여 주 예수의 이름을 불러 말하되 `내가 바울의 전파하는 예수를 빙자하여 너희를 명하노라' 하더라","reference":"사도행전 19:13","category":"$undefined"},{"id":"27600","book":"사도행전","book_name":"사도행전","chapter":19,"verse":14,"text":"유대의 한 제사장 스게와의 일곱 아들도 이 일을 행하더니","reference":"사도행전 19:14","category":"$undefined"},{"id":"27601","book":"사도행전","book_name":"사도행전","chapter":19,"verse":15,"text":"악귀가 대답하여 가로되 `예수도 내가 알고 바울도 내가 알거니와 너희는 누구냐 ?' 하며","reference":"사도행전 19:15","category":"$undefined"},{"id":"27602","book":"사도행전","book_name":"사도행전","chapter":19,"verse":16,"text":"악귀 들린 사람이 그 두사람에게 뛰어올라 억제하여 이기니 저희가 상하여 벗은 몸으로 그 집에서 도망하는지라","reference":"사도행전 19:16","category":"$undefined"},{"id":"27603","book":"사도행전","book_name":"사도행전","chapter":19,"verse":17,"text":"에베소에 거하는 유대인과 헬라인들이 다 이 일을 알고 두려워하며 주 예수의 이름을 높이고","reference":"사도행전 19:17","category":"$undefined"},{"id":"27604","book":"사도행전","book_name":"사도행전","chapter":19,"verse":18,"text":"믿은 사람들이 많이 와서 자복하여 행한 일을 고하며","reference":"사도행전 19:18","category":"$undefined"},{"id":"27605","book":"사도행전","book_name":"사도행전","chapter":19,"verse":19,"text":"또 마술을 행하던 많은 사람이 그 책을 모아 가지고 와서 모든 사람 앞에서 불사르니 그 책 값을 계산한 즉 은 오만이나 되더라","reference":"사도행전 19:19","category":"$undefined"},{"id":"27606","book":"사도행전","book_name":"사도행전","chapter":19,"verse":20,"text":"이와 같이 주의 말씀이 힘이 있어 흥왕하여 세력을 얻으니라","reference":"사도행전 19:20","category":"$undefined"},{"id":"27607","book":"사도행전","book_name":"사도행전","chapter":19,"verse":21,"text":"이 일이 다 된 후 바울이 마게도냐와 아가야로 다녀서 예루살렘에 가기를 경영하여 가로되 내가 거기 갔다가 후에 로마도 보아야 하리라 하고","reference":"사도행전 19:21","category":"$undefined"},{"id":"27608","book":"사도행전","book_name":"사도행전","chapter":19,"verse":22,"text":"자기를 돕는 사람 중에서 디모데와 에라스도 두 사람을 마게도냐로 보내고 자기는 아시아에 얼마간 더 있으니라","reference":"사도행전 19:22","category":"$undefined"},{"id":"27609","book":"사도행전","book_name":"사도행전","chapter":19,"verse":23,"text":"그 때쯤 되어 이 도로 인하여 적지 않은 소동이 있었으니","reference":"사도행전 19:23","category":"$undefined"},{"id":"27610","book":"사도행전","book_name":"사도행전","chapter":19,"verse":24,"text":"즉 데메드리오라 하는 어떤 은장색이 아데미의 은감실을 만들어 직공들로 적지 않은 벌이를 하게 하더니","reference":"사도행전 19:24","category":"$undefined"},{"id":"27611","book":"사도행전","book_name":"사도행전","chapter":19,"verse":25,"text":"그가 그 직공들과 이러한 영업하는 자들을 모아 이르되 `여러분도 알거니와 우리의 유족한 생활이 이 업에 있는데","reference":"사도행전 19:25","category":"$undefined"},{"id":"27612","book":"사도행전","book_name":"사도행전","chapter":19,"verse":26,"text":"이 바울이 에베소뿐 아니라 거의 아시아 전부를 통하여 허다한 사람을 권유하여 말하되 사람의 손으로 만든 것들은 신이 아니라하니 이는 그대들도 보고 들은 것이라","reference":"사도행전 19:26","category":"$undefined"},{"id":"27613","book":"사도행전","book_name":"사도행전","chapter":19,"verse":27,"text":"우리의 이 영업만 천하여질 위험이 있을 뿐 아니라 큰 여신 아데미의 전각도 경홀히 여김이 되고 온 아시아와 천하가 위하는 그의 위엄도 떨어질까 하노라' 하더라","reference":"사도행전 19:27","category":"$undefined"},{"id":"27614","book":"사도행전","book_name":"사도행전","chapter":19,"verse":28,"text":"저희가 이 말을 듣고 분이 가득하여 외쳐 가로되 `크다, 에베소 사람의 아데미여' 하니","reference":"사도행전 19:28","category":"$undefined"},{"id":"27615","book":"사도행전","book_name":"사도행전","chapter":19,"verse":29,"text":"온 성이 요란하여 바울과 같이 다니는 마게도냐 사람 가이오와 아리스다고를 잡아가지고 일제히 연극장으로 달려들어 가는지라","reference":"사도행전 19:29","category":"$undefined"},{"id":"27616","book":"사도행전","book_name":"사도행전","chapter":19,"verse":30,"text":"바울이 백성 가운데로 들어가고자 하나 제자들이 말리고","reference":"사도행전 19:30","category":"$undefined"},{"id":"27617","book":"사도행전","book_name":"사도행전","chapter":19,"verse":31,"text":"또 아시아 관원 중에 바울의 친구 된 어떤 이들이 그에게 통지하여 연극장에 들어가지 말라 권하더라","reference":"사도행전 19:31","category":"$undefined"},{"id":"27618","book":"사도행전","book_name":"사도행전","chapter":19,"verse":32,"text":"사람들이 외쳐 혹은 이 말을 혹은 저 말을 하니 모인 무리가 분란하여 태반이나 어찌하여 모였는지 알지 못하더라","reference":"사도행전 19:32","category":"$undefined"},{"id":"27619","book":"사도행전","book_name":"사도행전","chapter":19,"verse":33,"text":"유대인들이 무리 가운데서 알렉산더를 권하여 앞으로 밀어내니 알렉산더가 손짓하며 백성에게 발명하려 하나","reference":"사도행전 19:33","category":"$undefined"},{"id":"27620","book":"사도행전","book_name":"사도행전","chapter":19,"verse":34,"text":"저희는 그가 유대인인 줄 알고 다 한 소리로 외쳐 가로되 `크다 에베소 사람의 아데미여' 하기를 두 시 동안이나 하더니","reference":"사도행전 19:34","category":"$undefined"},{"id":"27621","book":"사도행전","book_name":"사도행전","chapter":19,"verse":35,"text":"서기장이 무리를 안돈시키고 이르되 `에베소 사람들아 에베소 성이 큰 아데미와 및 쓰스에게서 내려온 우상의 전각지기가 된 줄을 누가 알지 못하겠느냐 ?","reference":"사도행전 19:35","category":"$undefined"},{"id":"27622","book":"사도행전","book_name":"사도행전","chapter":19,"verse":36,"text":"이 일이 그렇지 않다 할 수 없으니 너희가 가만히 있어서 무엇이든지 경솔히 아니하여야 하리라","reference":"사도행전 19:36","category":"$undefined"},{"id":"27623","book":"사도행전","book_name":"사도행전","chapter":19,"verse":37,"text":"전각의 물건을 도적질하지도 아니하였고 우리 여신을 훼방하지도 아니한 이 사람들을 너희가 잡아 왔으니","reference":"사도행전 19:37","category":"$undefined"},{"id":"27624","book":"사도행전","book_name":"사도행전","chapter":19,"verse":38,"text":"만일 데메드리오와 및 그와 함께 있는 직공들이 누구에게 송사할 것이 있거든 재판 날도 있고 총독들도 있으니 피차 고소할 것이요","reference":"사도행전 19:38","category":"$undefined"},{"id":"27625","book":"사도행전","book_name":"사도행전","chapter":19,"verse":39,"text":"만일 그 외에 무엇을 원하거든 정식으로 민회에서 결단할지라","reference":"사도행전 19:39","category":"$undefined"},{"id":"27626","book":"사도행전","book_name":"사도행전","chapter":19,"verse":40,"text":"오늘 아무 까닭도 없는 이 일에 우리가 소요의 사건으로 책망 받을 위험이 있고 우리가 이 불법 집회에 관하여 보고할 재료가 없다' 하고","reference":"사도행전 19:40","category":"$undefined"},{"id":"27627","book":"사도행전","book_name":"사도행전","chapter":19,"verse":41,"text":"이에 그 모임을 흩어지게 하니라","reference":"사도행전 19:41","category":"$undefined"}],"bookSlug":"acts"}]
