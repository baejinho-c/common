2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":2,"verses":[{"id":"26951","book":"사도행전","book_name":"사도행전","chapter":2,"verse":1,"text":"오순절날이 이미 이르매 저희가 다 같이 한 곳에 모였더니","reference":"사도행전 2:1","category":"$undefined"},{"id":"26952","book":"사도행전","book_name":"사도행전","chapter":2,"verse":2,"text":"홀연히 하늘로부터 급하고 강한 바람 같은 소리가 있어 저희 앉은 온 집에 가득하며","reference":"사도행전 2:2","category":"$undefined"},{"id":"26953","book":"사도행전","book_name":"사도행전","chapter":2,"verse":3,"text":"불의 혀같이 갈라지는 것이 저희에게 보여 각 사람 위에 임하여 있더니","reference":"사도행전 2:3","category":"$undefined"},{"id":"26954","book":"사도행전","book_name":"사도행전","chapter":2,"verse":4,"text":"저희가 다 성령의 충만함을 받고 성령이 말하게 하심을 따라 다른 방언으로 말하기를 시작하니라","reference":"사도행전 2:4","category":"$undefined"},{"id":"26955","book":"사도행전","book_name":"사도행전","chapter":2,"verse":5,"text":"그 때에 경건한 유대인이 천하 각국으로부터와서 예루살렘에 우거하더니","reference":"사도행전 2:5","category":"$undefined"},{"id":"26956","book":"사도행전","book_name":"사도행전","chapter":2,"verse":6,"text":"이 소리가 나매 큰 무리가 모여 각각 자기의 방언으로 제자들의 말하는 것을 듣고 소동하여","reference":"사도행전 2:6","category":"$undefined"},{"id":"26957","book":"사도행전","book_name":"사도행전","chapter":2,"verse":7,"text":"다 놀라 기이히 여겨 이르되 `보라, 이 말하는 사람이 다 갈릴리 사람이 아니냐 ?","reference":"사도행전 2:7","category":"$undefined"},{"id":"26958","book":"사도행전","book_name":"사도행전","chapter":2,"verse":8,"text":"우리가 우리 각 사람의 난 곳 방언으로 듣게 되는 것이 어찜이뇨 ?","reference":"사도행전 2:8","category":"$undefined"},{"id":"26959","book":"사도행전","book_name":"사도행전","chapter":2,"verse":9,"text":"우리는 바대인과 메대인과 엘람인과 또 메소보다미아 유대와 가바도기아,본도와 아시아,","reference":"사도행전 2:9","category":"$undefined"},{"id":"26960","book":"사도행전","book_name":"사도행전","chapter":2,"verse":10,"text":"브루기아와 밤빌리아, 애굽과 및 구레네에 가까운 리비야 여러 지방에 사는 사람들과 로마로부터 온 나그네 곧 유대인과 유대교에 들어온 사람들과","reference":"사도행전 2:10","category":"$undefined"},{"id":"26961","book":"사도행전","book_name":"사도행전","chapter":2,"verse":11,"text":"그레데인과 아라비아인들이라 우리가 다 우리의 각 방언으로 하나님의 큰 일을 말함을 듣는도다' 하고","reference":"사도행전 2:11","category":"$undefined"},{"id":"26962","book":"사도행전","book_name":"사도행전","chapter":2,"verse":12,"text":"다 놀라며 의혹하여 서로 가로되 `이 어찐 일이냐 ?' 하며","reference":"사도행전 2:12","category":"$undefined"},{"id":"26963","book":"사도행전","book_name":"사도행전","chapter":2,"verse":13,"text":"또 어떤 이들은 조롱하여 가로되 `저희가 새 술이 취하였다' 하더라","reference":"사도행전 2:13","category":"$undefined"},{"id":"26964","book":"사도행전","book_name":"사도행전","chapter":2,"verse":14,"text":"베드로가 열 한 사도와 같이 서서 소리를 높여 가로되 `유대인들과 예루살렘에 사는 모든 사람들아 이 일을 너희로 알게 할 것이니 내 말에 귀를 기울이라","reference":"사도행전 2:14","category":"$undefined"},{"id":"26965","book":"사도행전","book_name":"사도행전","chapter":2,"verse":15,"text":"때가 제 삼시니 너희 생각과 같이 이 사람들이 취한 것이 아니라","reference":"사도행전 2:15","category":"$undefined"},{"id":"26966","book":"사도행전","book_name":"사도행전","chapter":2,"verse":16,"text":"이는 곧 선지자 요엘로 말씀하신 것이니 일렀으되","reference":"사도행전 2:16","category":"$undefined"},{"id":"26967","book":"사도행전","book_name":"사도행전","chapter":2,"verse":17,"text":"하나님이 가라사대 말세에 내가 내 영으로 모든 육체에게 부어 주리니 너희의 자녀들은 예언할 것이요 너희의 젊은이들은 환상을 보고 너희의 늙은이들은 꿈을 꾸리라","reference":"사도행전 2:17","category":"$undefined"},{"id":"26968","book":"사도행전","book_name":"사도행전","chapter":2,"verse":18,"text":"그 때에 내가 내 영으로 내 남종과 여종들에게 부어 주리니 저희가 예언할 것이요","reference":"사도행전 2:18","category":"$undefined"},{"id":"26969","book":"사도행전","book_name":"사도행전","chapter":2,"verse":19,"text":"또 내가 위로 하늘에서는 기사와 아래로 땅에서는 징조를 베풀리니 곧 피와 불과 연기로다","reference":"사도행전 2:19","category":"$undefined"},{"id":"26970","book":"사도행전","book_name":"사도행전","chapter":2,"verse":20,"text":"주의 크고 영화로운 날이 이르기 전에 해가 변하여 어두워지고 달이 변하여 피가 되리라","reference":"사도행전 2:20","category":"$undefined"},{"id":"26971","book":"사도행전","book_name":"사도행전","chapter":2,"verse":21,"text":"누구든지 주의 이름을 부르는 자는 구원을 얻으리라 하였느니라","reference":"사도행전 2:21","category":"$undefined"},{"id":"26972","book":"사도행전","book_name":"사도행전","chapter":2,"verse":22,"text":"이스라엘 사람들아 ! 이 말을 들으라 너희도 아는 바에 하나님께서 나사렛 예수로 큰 권능과 기사와 표적을 너희 가운데서 베푸사 너희 앞에서 그를 증거하셨느니라","reference":"사도행전 2:22","category":"$undefined"},{"id":"26973","book":"사도행전","book_name":"사도행전","chapter":2,"verse":23,"text":"그가 하나님의 정하신 뜻과 미리 아신 대로 내어준 바 되었거늘 너희가 법 없는 자들의 손을 빌어 못 박아 죽였으나","reference":"사도행전 2:23","category":"$undefined"},{"id":"26974","book":"사도행전","book_name":"사도행전","chapter":2,"verse":24,"text":"하나님께서 사망의 고통을 풀어 살리셨으니 이는 그가 사망에게 매여 있을 수 없었음이라","reference":"사도행전 2:24","category":"$undefined"},{"id":"26975","book":"사도행전","book_name":"사도행전","chapter":2,"verse":25,"text":"다윗이 저를 가리켜 가로되 내가 항상 내 앞에 계신 주를 뵈웠음이여 나로 요동치 않게 하기 위하여 그가 내 우편에 계시도다","reference":"사도행전 2:25","category":"$undefined"},{"id":"26976","book":"사도행전","book_name":"사도행전","chapter":2,"verse":26,"text":"이러므로 내 마음이 기뻐하였고 내 입술도 즐거워하였으며 육체는 희망에 거하리니","reference":"사도행전 2:26","category":"$undefined"},{"id":"26977","book":"사도행전","book_name":"사도행전","chapter":2,"verse":27,"text":"이는 내 영혼을 음부에 버리지 아니하시며 주의 거룩한 자로 썩음을 당치 않게 하실 것임이로다","reference":"사도행전 2:27","category":"$undefined"},{"id":"26978","book":"사도행전","book_name":"사도행전","chapter":2,"verse":28,"text":"주께서 생명의 길로 내게 보이셨으니 주의 앞에서 나로 기쁨이 충만하게 하시리로다 하였으니","reference":"사도행전 2:28","category":"$undefined"},{"id":"26979","book":"사도행전","book_name":"사도행전","chapter":2,"verse":29,"text":"형제들아 ! 내가 조상 다윗에 대하여 담대히 말할 수 있노니 다윗이 죽어 장사되어 그 묘가 오늘까지 우리 중에 있도다","reference":"사도행전 2:29","category":"$undefined"},{"id":"26980","book":"사도행전","book_name":"사도행전","chapter":2,"verse":30,"text":"그는 선지자라 하나님이 이미 맹세하사 그 자손 중에서 한 사람을 그 위에 앉게 하리라 하심을 알고","reference":"사도행전 2:30","category":"$undefined"},{"id":"26981","book":"사도행전","book_name":"사도행전","chapter":2,"verse":31,"text":"미리 보는고로 그리스도의 부활하심을 말하되 저가 음부에 버림이 되지 않고 육신이 썩음을 당하지 아니하시리라 하더니","reference":"사도행전 2:31","category":"$undefined"},{"id":"26982","book":"사도행전","book_name":"사도행전","chapter":2,"verse":32,"text":"이 예수를 하나님이 살리신지라 우리가 다 이 일에 증인이로다","reference":"사도행전 2:32","category":"$undefined"},{"id":"26983","book":"사도행전","book_name":"사도행전","chapter":2,"verse":33,"text":"하나님이 오른손으로 예수를 높이시매 그가 약속하신 성령을 아버지께 받아서 너희 보고 듣는 이것을 부어 주셨느니라","reference":"사도행전 2:33","category":"$undefined"},{"id":"26984","book":"사도행전","book_name":"사도행전","chapter":2,"verse":34,"text":"다윗은 하늘에 올라가지 못하였으나 친히 말하여 가로되 주께서 내 주에게 말씀하시기를","reference":"사도행전 2:34","category":"$undefined"},{"id":"26985","book":"사도행전","book_name":"사도행전","chapter":2,"verse":35,"text":"내가 네 원수로 네 발등상 되게 하기까지는 너는 내 우편에 앉았으라 하셨도다 하였으니","reference":"사도행전 2:35","category":"$undefined"},{"id":"26986","book":"사도행전","book_name":"사도행전","chapter":2,"verse":36,"text":"그런즉 이스라엘 온 집이 정녕 알지니 너희가 십자가에 못 박은 이 예수를 하나님이 주와 그리스도가 되게 하셨느니라' 하니라","reference":"사도행전 2:36","category":"$undefined"},{"id":"26987","book":"사도행전","book_name":"사도행전","chapter":2,"verse":37,"text":"저희가 이 말을 듣고 마음에 찔려 베드로와 다른 사도들에게 물어 가로되 `형제들아 우리가 어찌할꼬 ?' 하거늘","reference":"사도행전 2:37","category":"$undefined"},{"id":"26988","book":"사도행전","book_name":"사도행전","chapter":2,"verse":38,"text":"베드로가 가로되 `너희가 회개하여 각각 예수 그리스도의 이름으로 세례를 받고 죄 사함을 얻으라 그리하면 성령을 선물로 받으리니","reference":"사도행전 2:38","category":"$undefined"},{"id":"26989","book":"사도행전","book_name":"사도행전","chapter":2,"verse":39,"text":"이 약속은 너희와 너희 자녀와 모든 먼 데 사람 곧 주 우리 하나님이 얼마든지 부르시는 자들에게 하신 것이라' 하고","reference":"사도행전 2:39","category":"$undefined"},{"id":"26990","book":"사도행전","book_name":"사도행전","chapter":2,"verse":40,"text":"또 여러 말로 확증하며 권하여 가로되 `너희가 이 패역한 세대에서 구원을 받으라 !' 하니","reference":"사도행전 2:40","category":"$undefined"},{"id":"26991","book":"사도행전","book_name":"사도행전","chapter":2,"verse":41,"text":"그 말을 받는 사람들은 세례를 받으매 이 날에 제자의 수가 삼천이나 더하더라","reference":"사도행전 2:41","category":"$undefined"},{"id":"26992","book":"사도행전","book_name":"사도행전","chapter":2,"verse":42,"text":"저희가 사도의 가르침을 받아 서로 교제하며 떡을 떼며 기도하기를 전혀 힘쓰니라","reference":"사도행전 2:42","category":"$undefined"},{"id":"26993","book":"사도행전","book_name":"사도행전","chapter":2,"verse":43,"text":"사람마다 두려워하는데 사도들로 인하여 기사와 표적이 많이 나타나니","reference":"사도행전 2:43","category":"$undefined"},{"id":"26994","book":"사도행전","book_name":"사도행전","chapter":2,"verse":44,"text":"믿는 사람이 다 함께 있어 모든 물건을 서로 통용하고","reference":"사도행전 2:44","category":"$undefined"},{"id":"26995","book":"사도행전","book_name":"사도행전","chapter":2,"verse":45,"text":"또 재산과 소유를 팔아 각 사람의 필요를 따라 나눠 주고","reference":"사도행전 2:45","category":"$undefined"},{"id":"26996","book":"사도행전","book_name":"사도행전","chapter":2,"verse":46,"text":"날마다 마음을 같이 하여 성전에 모이기를 힘쓰고 집에서 떡을 떼며 기쁨과 순전한 마음으로 음식을 먹고","reference":"사도행전 2:46","category":"$undefined"},{"id":"26997","book":"사도행전","book_name":"사도행전","chapter":2,"verse":47,"text":"하나님을 찬미하며 또 온 백성에게 칭송을 받으니 주께서 구원 받는 사람을 날마다 더하게 하시니라","reference":"사도행전 2:47","category":"$undefined"}],"bookSlug":"acts"}]
