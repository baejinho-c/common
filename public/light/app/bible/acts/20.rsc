2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":20,"verses":[{"id":"27628","book":"사도행전","book_name":"사도행전","chapter":20,"verse":1,"text":"소요가 그치매 바울이 제자들을 불러 권한 후에 작별하고 떠나 마게도냐로 가니라","reference":"사도행전 20:1","category":"$undefined"},{"id":"27629","book":"사도행전","book_name":"사도행전","chapter":20,"verse":2,"text":"그 지경으로 다녀가며 여러 말로 제자들에게 권하고 헬라에 이르러","reference":"사도행전 20:2","category":"$undefined"},{"id":"27630","book":"사도행전","book_name":"사도행전","chapter":20,"verse":3,"text":"거기 석 달을 있다가 배 타고 수리아로 가고자 할 그 때에 유대인들이 자기를 해하려고 공모하므로 마게도냐로 다녀 돌아가기를 작정하니","reference":"사도행전 20:3","category":"$undefined"},{"id":"27631","book":"사도행전","book_name":"사도행전","chapter":20,"verse":4,"text":"아시아까지 함께 가는 자는 베뢰아 사람 부로의 아들 소바더와 데살로니가 사람 아리스다고와 세군도와 더베 사람 가이오와 및 디모데와 아시아 사람 두기오와 드로비모라","reference":"사도행전 20:4","category":"$undefined"},{"id":"27632","book":"사도행전","book_name":"사도행전","chapter":20,"verse":5,"text":"그들은 먼저 가서 드로아에서 우리를 기다리더라","reference":"사도행전 20:5","category":"$undefined"},{"id":"27633","book":"사도행전","book_name":"사도행전","chapter":20,"verse":6,"text":"우리는 무교절 후에 빌립보에서 배로 떠나 닷새 만에 드로아에 있는 그들에게 가서 이레를 머무니라","reference":"사도행전 20:6","category":"$undefined"},{"id":"27634","book":"사도행전","book_name":"사도행전","chapter":20,"verse":7,"text":"안식 후 첫날에 우리가 떡을 떼려 하여 모였더니 바울이 이튿날 떠나고자 하여 저희에게 강론할 새 말을 밤중까지 계속하매","reference":"사도행전 20:7","category":"$undefined"},{"id":"27635","book":"사도행전","book_name":"사도행전","chapter":20,"verse":8,"text":"우리의 모인 윗 다락에 등불을 많이 켰는데","reference":"사도행전 20:8","category":"$undefined"},{"id":"27636","book":"사도행전","book_name":"사도행전","chapter":20,"verse":9,"text":"유두고라 하는 청년이 창에 걸터 앉았다가 깊이 졸더니 바울이 강론하기를 더 오래 하매 졸음을 이기지 못하여 삼층 누에서 떨어지거늘 일으켜 보니 죽었는지라","reference":"사도행전 20:9","category":"$undefined"},{"id":"27637","book":"사도행전","book_name":"사도행전","chapter":20,"verse":10,"text":"바울이 내려가서 그 위에 엎드려 그 몸을 안고 말하되 `떠들지 말라 생명이 저에게 있다' 하고","reference":"사도행전 20:10","category":"$undefined"},{"id":"27638","book":"사도행전","book_name":"사도행전","chapter":20,"verse":11,"text":"올라가 떡을 떼어 먹고 오래 동안 곧 날이 새기까지 이야기하고 떠나니라","reference":"사도행전 20:11","category":"$undefined"},{"id":"27639","book":"사도행전","book_name":"사도행전","chapter":20,"verse":12,"text":"사람들이 살아난 아이를 데리고 와서 위로를 적지 않게 받았더라","reference":"사도행전 20:12","category":"$undefined"},{"id":"27640","book":"사도행전","book_name":"사도행전","chapter":20,"verse":13,"text":"우리는 앞서 배를 타고 앗소에서 바울을 태우려고 그리로 행선하니 이는 자기가 도보로 가고자 하여 이렇게 정하여 준 것이라","reference":"사도행전 20:13","category":"$undefined"},{"id":"27641","book":"사도행전","book_name":"사도행전","chapter":20,"verse":14,"text":"바울이 앗소에서 우리를 만나니 우리가 배에 올리고 미둘레네에 가서","reference":"사도행전 20:14","category":"$undefined"},{"id":"27642","book":"사도행전","book_name":"사도행전","chapter":20,"verse":15,"text":"거기서 떠나 이튿날 기오 앞에 오고 그 이튿날 사모에 들리고 또 그 다음날 밀레도에 이르니라","reference":"사도행전 20:15","category":"$undefined"},{"id":"27643","book":"사도행전","book_name":"사도행전","chapter":20,"verse":16,"text":"바울이 아시아에서 지체치 않기 위하여 에베소를 지나 행선하기로 작정하였으니 이는 될 수 있는 대로 오순절 안에 예루살렘에 이르려고 급히 감이러라","reference":"사도행전 20:16","category":"$undefined"},{"id":"27644","book":"사도행전","book_name":"사도행전","chapter":20,"verse":17,"text":"바울이 밀레도에서 사람을 에베소로 보내어 교회 장로들을 청하니","reference":"사도행전 20:17","category":"$undefined"},{"id":"27645","book":"사도행전","book_name":"사도행전","chapter":20,"verse":18,"text":"오매 저희에게 말하되 `아시아에 들어온 첫날부터 지금까지 내가 항상 너희 가운데서 어떻게 행한 것을 너희도 아는 바니","reference":"사도행전 20:18","category":"$undefined"},{"id":"27646","book":"사도행전","book_name":"사도행전","chapter":20,"verse":19,"text":"곧 모든 겸손과 눈물이며 유대인의 간계를 인하여 당한 시험을 참고 주를 섬긴 것과","reference":"사도행전 20:19","category":"$undefined"},{"id":"27647","book":"사도행전","book_name":"사도행전","chapter":20,"verse":20,"text":"유익한 것은 무엇이든지 공중 앞에서나 각 집에서나 꺼림이 없이 너희에게 전하여 가르치고","reference":"사도행전 20:20","category":"$undefined"},{"id":"27648","book":"사도행전","book_name":"사도행전","chapter":20,"verse":21,"text":"유대인과 헬라인들에게 하나님께 대한 회개와 우리 주 예수 그리스도께 대한 믿음을 증거한 것이라","reference":"사도행전 20:21","category":"$undefined"},{"id":"27649","book":"사도행전","book_name":"사도행전","chapter":20,"verse":22,"text":"보라, 이제 나는 심령에 매임을 받아 예루살렘으로 가는데 저기서 무슨 일을 만날는지 알지 못하노라","reference":"사도행전 20:22","category":"$undefined"},{"id":"27650","book":"사도행전","book_name":"사도행전","chapter":20,"verse":23,"text":"오직 성령이 각 성에서 내게 증거하여 결박과 환난이 나를 기다린다 하시나","reference":"사도행전 20:23","category":"$undefined"},{"id":"27651","book":"사도행전","book_name":"사도행전","chapter":20,"verse":24,"text":"나의 달려갈 길과 주 예수께 받은 사명 곧 하나님의 은혜의 복음 증거하는 일을 마치려 함에는 나의 생명을 조금도 귀한 것으로 여기지 아니하노라","reference":"사도행전 20:24","category":"$undefined"},{"id":"27652","book":"사도행전","book_name":"사도행전","chapter":20,"verse":25,"text":"보라, 내가 너희 중에 왕래하며 하나님 나라를 전파하였으나 지금은 너희가 다 내 얼굴을 다시 보지 못할 줄 아노라","reference":"사도행전 20:25","category":"$undefined"},{"id":"27653","book":"사도행전","book_name":"사도행전","chapter":20,"verse":26,"text":"그러므로 오늘 너희에게 증거하노니 모든 사람의 피에 대하여 내가 깨끗하니","reference":"사도행전 20:26","category":"$undefined"},{"id":"27654","book":"사도행전","book_name":"사도행전","chapter":20,"verse":27,"text":"이는 내가 꺼리지 않고 하나님의 뜻을 다 너희에게 전하였음이라","reference":"사도행전 20:27","category":"$undefined"},{"id":"27655","book":"사도행전","book_name":"사도행전","chapter":20,"verse":28,"text":"너희는 자기를 위하여 또는 온 양떼를 위하여 삼가라 성령이 저들 가운데 너희로 감독자를 삼고 하나님이 자기 피로 사신 교회를 치게 하셨느니라","reference":"사도행전 20:28","category":"$undefined"},{"id":"27656","book":"사도행전","book_name":"사도행전","chapter":20,"verse":29,"text":"내가 떠난 후에 흉악한 이리가 너희에게 들어와서 그 양떼를 아끼지 아니하며","reference":"사도행전 20:29","category":"$undefined"},{"id":"27657","book":"사도행전","book_name":"사도행전","chapter":20,"verse":30,"text":"또한 너희 중에서도 제자들을 끌어 자기를 좇게 하려고 어그러진 말을 하는 사람들이 일어날 줄을 내가 아노니","reference":"사도행전 20:30","category":"$undefined"},{"id":"27658","book":"사도행전","book_name":"사도행전","chapter":20,"verse":31,"text":"그러므로 너희가 일깨어 내가 삼 년이나 밤낮 쉬지 않고 눈물로 각 사람을 훈계하던 것을 기억하라","reference":"사도행전 20:31","category":"$undefined"},{"id":"27659","book":"사도행전","book_name":"사도행전","chapter":20,"verse":32,"text":"지금 내가 너희를 주와 및 그 은혜의 말씀께 부탁하노니 그 말씀이 너희를 능히 든든히 세우사 거룩케 하심을 입은 모든 자 가운데 기업이 있게 하시리라","reference":"사도행전 20:32","category":"$undefined"},{"id":"27660","book":"사도행전","book_name":"사도행전","chapter":20,"verse":33,"text":"내가 아무의 은이나 금이나 의복을 탐하지 아니하였고","reference":"사도행전 20:33","category":"$undefined"},{"id":"27661","book":"사도행전","book_name":"사도행전","chapter":20,"verse":34,"text":"너희 아는 바에 이 손으로 나와 내 동행들의 쓰는 것을 당하여","reference":"사도행전 20:34","category":"$undefined"},{"id":"27662","book":"사도행전","book_name":"사도행전","chapter":20,"verse":35,"text":"범사에 너희에게 모본을 보였노니 곧 이같이 수고하여 약한 사람들을 돕고 또 주 예수의 친히 말씀하신 바 주는 것이 받는 것보다 복이 있다 하심을 기억하여야 할지니라'","reference":"사도행전 20:35","category":"$undefined"},{"id":"27663","book":"사도행전","book_name":"사도행전","chapter":20,"verse":36,"text":"이 말을 한 후 무릎을 꿇고 저희 모든 사람과 함께 기도하니","reference":"사도행전 20:36","category":"$undefined"},{"id":"27664","book":"사도행전","book_name":"사도행전","chapter":20,"verse":37,"text":"다 크게 울며 바울의 목을 안고 입을 맞추고","reference":"사도행전 20:37","category":"$undefined"},{"id":"27665","book":"사도행전","book_name":"사도행전","chapter":20,"verse":38,"text":"다시 그 얼굴을 보지 못하리라 한 말을 인하여 더욱 근심하고 배에까지 그를 전송하니라","reference":"사도행전 20:38","category":"$undefined"}],"bookSlug":"acts"}]
