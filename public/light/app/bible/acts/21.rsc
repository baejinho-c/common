2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":21,"verses":[{"id":"27666","book":"사도행전","book_name":"사도행전","chapter":21,"verse":1,"text":"우리가 저희를 작별하고 행선하여 바로 고스로 가서 이튿날 로도에 이르러 거기서부터 바다라로 가서","reference":"사도행전 21:1","category":"$undefined"},{"id":"27667","book":"사도행전","book_name":"사도행전","chapter":21,"verse":2,"text":"베니게로 건너가는 배를 만나서 타고 가다가","reference":"사도행전 21:2","category":"$undefined"},{"id":"27668","book":"사도행전","book_name":"사도행전","chapter":21,"verse":3,"text":"구브로를 바라보고 이를 왼편에 두고 수리아로 행선하여 두로에서 상륙하니 거기서 배가 짐을 풀려 함이러라","reference":"사도행전 21:3","category":"$undefined"},{"id":"27669","book":"사도행전","book_name":"사도행전","chapter":21,"verse":4,"text":"제자들을 찾아 거기서 이레를 머물더니 그 제자들이 성령의 감동으로 바울더러 예루살렘에 들어가지 말라 하더라","reference":"사도행전 21:4","category":"$undefined"},{"id":"27670","book":"사도행전","book_name":"사도행전","chapter":21,"verse":5,"text":"이 여러 날을 지난 후 우리가 떠나갈새 저희가 다 그 처자와 함께 성문 밖까지 전송하거늘 우리가 바닷가에서 무릎을 꿇어 기도하고","reference":"사도행전 21:5","category":"$undefined"},{"id":"27671","book":"사도행전","book_name":"사도행전","chapter":21,"verse":6,"text":"서로 작별한 후 우리는 배에 오르고 저희는 집으로 돌아가니라","reference":"사도행전 21:6","category":"$undefined"},{"id":"27672","book":"사도행전","book_name":"사도행전","chapter":21,"verse":7,"text":"두로로부터 수로를 다 행하여 돌레마이에 이르러 형제들에게 안부를 묻고 그들과 함께 하루를 있다가","reference":"사도행전 21:7","category":"$undefined"},{"id":"27673","book":"사도행전","book_name":"사도행전","chapter":21,"verse":8,"text":"이튿날 떠나 가이사랴에 이르러 일곱 집사 중 하나인 전도자 빌립의 집에 들어가서 유하니라","reference":"사도행전 21:8","category":"$undefined"},{"id":"27674","book":"사도행전","book_name":"사도행전","chapter":21,"verse":9,"text":"그에게 딸 넷이 있으니 처녀로 예언하는 자라","reference":"사도행전 21:9","category":"$undefined"},{"id":"27675","book":"사도행전","book_name":"사도행전","chapter":21,"verse":10,"text":"여러 날 있더니 한 선지자 아가보라 하는 이가 유대로부터 내려와","reference":"사도행전 21:10","category":"$undefined"},{"id":"27676","book":"사도행전","book_name":"사도행전","chapter":21,"verse":11,"text":"우리에게 와서 바울의 띠를 가져다가 자기 수족을 잡아매고 말하기를 성령이 말씀하시되 예루살렘에서 유대인들이 이같이 이 띠 임자를 결박하여 이방인의 손에 넘겨 주리라 하거늘","reference":"사도행전 21:11","category":"$undefined"},{"id":"27677","book":"사도행전","book_name":"사도행전","chapter":21,"verse":12,"text":"우리가 그 말을 듣고 그 곳 사람들로 더불어 바울에게 예루살렘으로 올라가지 말라 권하니","reference":"사도행전 21:12","category":"$undefined"},{"id":"27678","book":"사도행전","book_name":"사도행전","chapter":21,"verse":13,"text":"바울이 대답하되 `너희가 어찌하여 울어 내 마음을 상하게 하느냐 ? 나는 주 예수의 이름을 위하여 결박 받을 뿐 아니라 예루살렘에서 죽을 것도 각오하였노라' 하니","reference":"사도행전 21:13","category":"$undefined"},{"id":"27679","book":"사도행전","book_name":"사도행전","chapter":21,"verse":14,"text":"저가 권함을 받지 아니하므로 우리가 주의 뜻대로 이루어지이다 하고 그쳤노라","reference":"사도행전 21:14","category":"$undefined"},{"id":"27680","book":"사도행전","book_name":"사도행전","chapter":21,"verse":15,"text":"이 여러 날 후에 행장을 준비하여 예루살렘으로 올라갈새","reference":"사도행전 21:15","category":"$undefined"},{"id":"27681","book":"사도행전","book_name":"사도행전","chapter":21,"verse":16,"text":"가이사랴의 몇 제자가 함께 가며 한 오랜 제자 구브로 사람 나손을 데리고 가니 이는 우리가 그의 집에 유하려 함이라","reference":"사도행전 21:16","category":"$undefined"},{"id":"27682","book":"사도행전","book_name":"사도행전","chapter":21,"verse":17,"text":"예루살렘에 이르니 형제들이 우리를 기꺼이 영접하거늘","reference":"사도행전 21:17","category":"$undefined"},{"id":"27683","book":"사도행전","book_name":"사도행전","chapter":21,"verse":18,"text":"그 이튿날 바울이 우리와 함께 야고보에게로 들어가니 장로들도다 있더라","reference":"사도행전 21:18","category":"$undefined"},{"id":"27684","book":"사도행전","book_name":"사도행전","chapter":21,"verse":19,"text":"바울이 문안하고 하나님이 자기의 봉사로 말미암아 이방 가운데서 하신 일을 낱낱이 고하니","reference":"사도행전 21:19","category":"$undefined"},{"id":"27685","book":"사도행전","book_name":"사도행전","chapter":21,"verse":20,"text":"저희가 듣고 하나님께 영광을 돌리고 바울더러 이르되 `형제여 그대도 보는 바에 유대인 중에 믿는 자 수만 명이 있으니 다 율법에 열심 있는 자라","reference":"사도행전 21:20","category":"$undefined"},{"id":"27686","book":"사도행전","book_name":"사도행전","chapter":21,"verse":21,"text":"네가 이방에 있는 모든 유대인을 가르치되 모세가 배반하고 아들들에게 할례를 하지 말고 또 규모를 지키지 말라 한다 함을 저희가 들었도다","reference":"사도행전 21:21","category":"$undefined"},{"id":"27687","book":"사도행전","book_name":"사도행전","chapter":21,"verse":22,"text":"그러면 어찌할꼬 저희가 필연 그대의 온 것을 들으리니","reference":"사도행전 21:22","category":"$undefined"},{"id":"27688","book":"사도행전","book_name":"사도행전","chapter":21,"verse":23,"text":"우리의 말하는 이대로 하라 서원한 네 사람이 우리에게 있으니","reference":"사도행전 21:23","category":"$undefined"},{"id":"27689","book":"사도행전","book_name":"사도행전","chapter":21,"verse":24,"text":"저희를 데리고 함께 결례를 행하고 저희를 위하여 비용을 내어 머리를 깎게 하라 그러면 모든 사람이 그대에게 대하여 들은 것 이 헛된 것이고 그대로 율법을 지켜 행하는 줄로 알 것이라","reference":"사도행전 21:24","category":"$undefined"},{"id":"27690","book":"사도행전","book_name":"사도행전","chapter":21,"verse":25,"text":"주를 믿는 이방인에게는 우리가 우상의 제물과 피와 목매어 죽인 것과 음행을 피할 것을 결의하고 편지하였느니라' 하니","reference":"사도행전 21:25","category":"$undefined"},{"id":"27691","book":"사도행전","book_name":"사도행전","chapter":21,"verse":26,"text":"바울이 이 사람들을 데리고 이튿날 저희와 함께 결례를 행하고 성전에 들어가서 각 사람을 위하여 제사 드릴 때까지의 결례의 만기 된 것을 고하니라","reference":"사도행전 21:26","category":"$undefined"},{"id":"27692","book":"사도행전","book_name":"사도행전","chapter":21,"verse":27,"text":"그 이레가 거의 차매 아시아로부터 온 유대인들이 성전에서 바울을 보고 모든 무리를 충동하여 그를 붙들고","reference":"사도행전 21:27","category":"$undefined"},{"id":"27693","book":"사도행전","book_name":"사도행전","chapter":21,"verse":28,"text":"외치되 `이스라엘 사람들아 도우라 이 사람은 각처에서 우리 백성과 율법과 이 곳을 훼방하여 모든 사람을 가르치는 그 자인데 또 헬라인을 데리고 성전에 들어가서 이 거룩한 곳을 더럽게 하였다'하니","reference":"사도행전 21:28","category":"$undefined"},{"id":"27694","book":"사도행전","book_name":"사도행전","chapter":21,"verse":29,"text":"이는 저희가 전에 에베소 사람 드로비모가 바울과 함께 성내에 있음을 보고 바울이 저를 성전에 데리고 들어간 줄로 생각함일러라","reference":"사도행전 21:29","category":"$undefined"},{"id":"27695","book":"사도행전","book_name":"사도행전","chapter":21,"verse":30,"text":"온 성이 소동하여 백성이 달려와 모여 바울을 잡아 성전 밖으로 끌고 나가니 문들이 곧 닫히더라","reference":"사도행전 21:30","category":"$undefined"},{"id":"27696","book":"사도행전","book_name":"사도행전","chapter":21,"verse":31,"text":"저희가 그를 죽이려 할 때에 온 예루살렘의 요란하다는 소문이 군대의 천부장에게 들리매","reference":"사도행전 21:31","category":"$undefined"},{"id":"27697","book":"사도행전","book_name":"사도행전","chapter":21,"verse":32,"text":"저가 급히 군사들과 백부장들을 거느리고 달려 내려가니 저희가 천부장과 군사들을 보고 바울 치기를 그치는지라","reference":"사도행전 21:32","category":"$undefined"},{"id":"27698","book":"사도행전","book_name":"사도행전","chapter":21,"verse":33,"text":"이에 천부장이 가까이 가서 바울을 잡아 `두 쇠사슬로 결박하라' 명하고 `누구며 무슨 일을 하였느냐 ?' 물으니","reference":"사도행전 21:33","category":"$undefined"},{"id":"27699","book":"사도행전","book_name":"사도행전","chapter":21,"verse":34,"text":"무리 가운데서 어떤 이는 이 말로 어떤 이는 저 말로 부르짖거늘 천부장이 소동을 인하여 그 실상을 알수 없어 그를 영문 안으로 데려가라 명하니라","reference":"사도행전 21:34","category":"$undefined"},{"id":"27700","book":"사도행전","book_name":"사도행전","chapter":21,"verse":35,"text":"바울이 층대에 이를 때에 무리의 포행을 인하여 군사들에게 들려가니","reference":"사도행전 21:35","category":"$undefined"},{"id":"27701","book":"사도행전","book_name":"사도행전","chapter":21,"verse":36,"text":"이는 백성의 무리가 그를 없이 하자고 외치며 따라 감이러라","reference":"사도행전 21:36","category":"$undefined"},{"id":"27702","book":"사도행전","book_name":"사도행전","chapter":21,"verse":37,"text":"바울을 데리고 영문으로 들어가려 할 그때에 바울이 천부장더러 이르되 `내가 당신에게 말할수 있느뇨 ?' 가로되 `네가 헬라말을 아느냐 ?","reference":"사도행전 21:37","category":"$undefined"},{"id":"27703","book":"사도행전","book_name":"사도행전","chapter":21,"verse":38,"text":"그러면 네가 이전에 난을 일으켜 사천의 자객을 거느리고 광야로 가던 애굽인이 아니냐 ?'","reference":"사도행전 21:38","category":"$undefined"},{"id":"27704","book":"사도행전","book_name":"사도행전","chapter":21,"verse":39,"text":"바울이 가로되 `나는 유대인이라 소읍이 아닌 길리기아 다소 성의 시민이니 청컨대 백성에게 말하기를 허락하라' 하니","reference":"사도행전 21:39","category":"$undefined"},{"id":"27705","book":"사도행전","book_name":"사도행전","chapter":21,"verse":40,"text":"천부장이 허락하거늘 바울이 층대 위에 서서 백성에게 손짓하여 크게 종용히 한 후에 히브리 방언으로 말하여 가로되","reference":"사도행전 21:40","category":"$undefined"}],"bookSlug":"acts"}]
