2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":22,"verses":[{"id":"27706","book":"사도행전","book_name":"사도행전","chapter":22,"verse":1,"text":"부형들아 내가 지금 너희 앞에서 변명하는 말을 들으라 하더라","reference":"사도행전 22:1","category":"$undefined"},{"id":"27707","book":"사도행전","book_name":"사도행전","chapter":22,"verse":2,"text":"저희가 그 히브리 방언으로 말함을 듣고 더욱 종용한지라 이어 가로되","reference":"사도행전 22:2","category":"$undefined"},{"id":"27708","book":"사도행전","book_name":"사도행전","chapter":22,"verse":3,"text":"나는 유대인으로 길리기아 다소에서 났고 이 성에서 자라 가말리엘의 문하에서 우리 조상들의 율법의 엄한 교훈을 받았고 오늘 너희 모든 사람처럼 하나님께 대하여 열심하는 자라","reference":"사도행전 22:3","category":"$undefined"},{"id":"27709","book":"사도행전","book_name":"사도행전","chapter":22,"verse":4,"text":"내가 이 도를 핍박하여 사람을 죽이기까지 하고 남녀를 결박하여 옥에 넘겼노니","reference":"사도행전 22:4","category":"$undefined"},{"id":"27710","book":"사도행전","book_name":"사도행전","chapter":22,"verse":5,"text":"이에 대제사장과 모든 장로들이 내 증인이라 또 내가 저희에게서 다메섹 형제들에게 가는 공문을 받아 가지고 거기 있는 자들도 결박하여 예루살렘으로 끌어다가 형벌 받게 하려고 가더니","reference":"사도행전 22:5","category":"$undefined"},{"id":"27711","book":"사도행전","book_name":"사도행전","chapter":22,"verse":6,"text":"가는데 다메섹에 가까왔을 때에 오정쯤 되어 홀연히 하늘로서 큰 빛이 나를 둘러 비취매","reference":"사도행전 22:6","category":"$undefined"},{"id":"27712","book":"사도행전","book_name":"사도행전","chapter":22,"verse":7,"text":"내가 땅에 엎드러져 들으니 소리 있어 가로되 사울아 사울아 네가 왜 나를 핍박하느냐 하시거늘","reference":"사도행전 22:7","category":"$undefined"},{"id":"27713","book":"사도행전","book_name":"사도행전","chapter":22,"verse":8,"text":"내가 대답하되 주여 뉘시니이까 ? 하니 가라사대 나는 네가 핍박하는 나사렛 예수라 하시더라","reference":"사도행전 22:8","category":"$undefined"},{"id":"27714","book":"사도행전","book_name":"사도행전","chapter":22,"verse":9,"text":"나와 함께 있는 사람들이 빛은 보면서도 나더러 말하시는 이의 소리는 듣지 못하더라","reference":"사도행전 22:9","category":"$undefined"},{"id":"27715","book":"사도행전","book_name":"사도행전","chapter":22,"verse":10,"text":"내가 가로되 주여 무엇을 하리이까 ? 주께서 가라사대 일어나 다메섹으로 들어가라 정한 바 너희 모든 행할 것을 거기서 누가 이르리라 하시거늘","reference":"사도행전 22:10","category":"$undefined"},{"id":"27716","book":"사도행전","book_name":"사도행전","chapter":22,"verse":11,"text":"나는 그 빛의 광채를 인하여 볼 수 없게 되었으므로 나와 함께 있는 사람들의 손에 끌려 다메섹에 들어갔노라","reference":"사도행전 22:11","category":"$undefined"},{"id":"27717","book":"사도행전","book_name":"사도행전","chapter":22,"verse":12,"text":"율법에 의하면 경건한 사람으로 거기 사는 모든 유대인들에게 칭찬을 듣는 아나니아라 하는 이가","reference":"사도행전 22:12","category":"$undefined"},{"id":"27718","book":"사도행전","book_name":"사도행전","chapter":22,"verse":13,"text":"내게 와 곁에 서서 말하되 형제 사울아 다시 보라 하거늘 즉시 그를 쳐다보았노라","reference":"사도행전 22:13","category":"$undefined"},{"id":"27719","book":"사도행전","book_name":"사도행전","chapter":22,"verse":14,"text":"그가 또 가로되 우리 조상들의 하나님이 너를 택하여 너로 하여금 자기 뜻을 알게 하시며 저 의인을 보게 하시고 그 입에서 나오는 음성을 듣게 하셨으니","reference":"사도행전 22:14","category":"$undefined"},{"id":"27720","book":"사도행전","book_name":"사도행전","chapter":22,"verse":15,"text":"네가 그를 위하여 모든 사람 앞에서 너의 보고 들은 것에 증인이 되리라","reference":"사도행전 22:15","category":"$undefined"},{"id":"27721","book":"사도행전","book_name":"사도행전","chapter":22,"verse":16,"text":"이제는 왜 주저하느뇨 일어나 주의 이름을 불러 세례를 받고 너의 죄를 씻으라 하더라","reference":"사도행전 22:16","category":"$undefined"},{"id":"27722","book":"사도행전","book_name":"사도행전","chapter":22,"verse":17,"text":"후에 내가 예루살렘으로 돌아와서 성전에서 기도할 때에 비몽사몽간에","reference":"사도행전 22:17","category":"$undefined"},{"id":"27723","book":"사도행전","book_name":"사도행전","chapter":22,"verse":18,"text":"바울이 한 백부장을 청하여 가로되 `이 청년을 천부장에게로 인도하라 그에게 무슨 할 말이 있다' 하니","reference":"사도행전 22:18","category":"$undefined"},{"id":"27724","book":"사도행전","book_name":"사도행전","chapter":22,"verse":19,"text":"후에 내가 예루살렘으로 돌아와서 성전에서 기도할 때에 비몽사몽간에","reference":"사도행전 22:19","category":"$undefined"},{"id":"27725","book":"사도행전","book_name":"사도행전","chapter":22,"verse":20,"text":"바울이 한 백부장을 청하여 가로되 `이 청년을 천부장에게로 인도하라 그에게 무슨 할 말이 있다' 하니","reference":"사도행전 22:20","category":"$undefined"},{"id":"27726","book":"사도행전","book_name":"사도행전","chapter":22,"verse":21,"text":"보매 주께서 내게 말씀하시되 속히 예루살렘에서 나가라 저희는 네가 내게 대하여 증거하는 말을 듣지 아니하리라 하시거늘","reference":"사도행전 22:21","category":"$undefined"},{"id":"27727","book":"사도행전","book_name":"사도행전","chapter":22,"verse":22,"text":"내가 말하기를 주여 내가 주 믿는 사람들을 가두고 또 각 회당에서 때리고","reference":"사도행전 22:22","category":"$undefined"},{"id":"27728","book":"사도행전","book_name":"사도행전","chapter":22,"verse":23,"text":"또 주의 증인 스데반의 피를 흘릴 적에 내가 곁에 서서 찬성하고 그 죽이는 사람들의 옷을 지킨 줄 저희도 아나이다","reference":"사도행전 22:23","category":"$undefined"},{"id":"27729","book":"사도행전","book_name":"사도행전","chapter":22,"verse":24,"text":"나더러 또 이르시되 떠나가라 내가 너를 멀리 이방인에게로 보내리라 하셨느니라","reference":"사도행전 22:24","category":"$undefined"},{"id":"27730","book":"사도행전","book_name":"사도행전","chapter":22,"verse":25,"text":"이 말 하는 것까지 저희가 듣다가 소리질러 가로되 이러한 놈은 세상에서 없이 하자 살려 둘 자가 아니라 하여","reference":"사도행전 22:25","category":"$undefined"},{"id":"27731","book":"사도행전","book_name":"사도행전","chapter":22,"verse":26,"text":"떠들며 옷을 벗어 던지고 티끌을 공중에 날리니","reference":"사도행전 22:26","category":"$undefined"},{"id":"27732","book":"사도행전","book_name":"사도행전","chapter":22,"verse":27,"text":"천부장이 바울을 영문 안으로 데려가라 명하고 저희가 무슨 일로 그를 대하여 떠드나 알고자 하여 채찍질하며 신문하라 한대","reference":"사도행전 22:27","category":"$undefined"},{"id":"27733","book":"사도행전","book_name":"사도행전","chapter":22,"verse":28,"text":"가죽줄로 바울을 매니 바울이 곁에 섰는 백부장더러 이르되 `너희가 로마 사람 된 자를 죄도 정치 아니하고 채찍질할 수 있느냐 ? 하니","reference":"사도행전 22:28","category":"$undefined"},{"id":"27734","book":"사도행전","book_name":"사도행전","chapter":22,"verse":29,"text":"백부장이 듣고 가서 천부장에게 전하여 가로되 `어찌하려 하느뇨 이는 로마 사람이라' 하니","reference":"사도행전 22:29","category":"$undefined"},{"id":"27735","book":"사도행전","book_name":"사도행전","chapter":22,"verse":30,"text":"천부장이 와서 바울에게 말하되 `네가 로마 사람이냐 ? 내게 말하라' 가로되 `그러하다' [ (Acts 22:31) 천부장이 대답하되 `나는 돈을 많이 들여 이 시민권을 얻었노라' 바울이 가로되 `나는 나면서부터로라' 하니 ] [ (Acts 22:32) 신문하려던 사람들이 곧 그에게서 물러가고 천부장도 그가 로마 사람인줄 알고 또는 그 결박한 것을 인하여 두려워하니라 ] [ (Acts 22:33) 이튿날 천부장이 무슨 일로 유대인들이 그를 송사하는지 실상을 알고자 하여 그 결박을 풀고 명하여 제사장들과 온 공회를 모으고 바울을 데리고 내려가서 저희 앞에 세우니라 ]","reference":"사도행전 22:30","category":"$undefined"}],"bookSlug":"acts"}]
