2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":23,"verses":[{"id":"27736","book":"사도행전","book_name":"사도행전","chapter":23,"verse":1,"text":"바울이 공회를 주목하여 가로되 `여러분 형제들아 오늘날까지 내가 범사에 양심을 따라 하나님을 섬겼노라' 하거늘","reference":"사도행전 23:1","category":"$undefined"},{"id":"27737","book":"사도행전","book_name":"사도행전","chapter":23,"verse":2,"text":"대제사장 아나니아가 바울 곁에 섰는 사람들에게 `그 입을 치라' 명하니","reference":"사도행전 23:2","category":"$undefined"},{"id":"27738","book":"사도행전","book_name":"사도행전","chapter":23,"verse":3,"text":"바울이 가로되 `회 칠한 담이여 ! 하나님이 너를 치시리로다 네가 나를 율법대로 판단한다고 앉아서 율법을 어기고 나를 치라 하느냐 ?' 하니","reference":"사도행전 23:3","category":"$undefined"},{"id":"27739","book":"사도행전","book_name":"사도행전","chapter":23,"verse":4,"text":"곁에 선 사람들이 말하되 `하나님의 대제사장을 네가 욕하느냐 ?'","reference":"사도행전 23:4","category":"$undefined"},{"id":"27740","book":"사도행전","book_name":"사도행전","chapter":23,"verse":5,"text":"바울이 가로되 `형제들아 나는 그가 대제사장인 줄 알지 못하였노라 기록하였으되 너희 백성의 관원을 비방치 말라 하였느니라' 하더라","reference":"사도행전 23:5","category":"$undefined"},{"id":"27741","book":"사도행전","book_name":"사도행전","chapter":23,"verse":6,"text":"바울이 그 한 부분은 사두개인이요 한 부분은 바리새인인 줄 알고 공회에서 외쳐 가로되 여러분 형제들아 나는 바리새인이요 또바리새인의 아들이라 죽은 자의 소망 곧 부활을 인하여 내가 심문을 받노라","reference":"사도행전 23:6","category":"$undefined"},{"id":"27742","book":"사도행전","book_name":"사도행전","chapter":23,"verse":7,"text":"그 말을 한즉 바리새인과 사두개인 사이에 다툼이 생겨 무리가 나누이니","reference":"사도행전 23:7","category":"$undefined"},{"id":"27743","book":"사도행전","book_name":"사도행전","chapter":23,"verse":8,"text":"이는 사두개인은 부활도 없고 천사도 없고 영도 없다 하고 바리새인은 다 있다 함이라","reference":"사도행전 23:8","category":"$undefined"},{"id":"27744","book":"사도행전","book_name":"사도행전","chapter":23,"verse":9,"text":"크게 훤화가 일어날새 바리새인 편에서 몇 서기관이 일어나 다투어 가로되 `우리가 이 사람을 보매 악한 것이 없도다 혹 영이나 혹 천사가 저더러 말하였으면 어찌 하겠느뇨' 하여","reference":"사도행전 23:9","category":"$undefined"},{"id":"27745","book":"사도행전","book_name":"사도행전","chapter":23,"verse":10,"text":"큰 분쟁이 생기니 천부장이 바울이 저희에게 찢겨질까 하여 군사를 명하여 내려가 무리 가운데서 빼앗아 가지고 영문으로 들어가라 하니라","reference":"사도행전 23:10","category":"$undefined"},{"id":"27746","book":"사도행전","book_name":"사도행전","chapter":23,"verse":11,"text":"그날 밤에 주께서 바울 곁에 서서 이르시되 `담대하라 네가 예루살렘에서 나의 일을 증거한 것같이 로마에서도 증거하여야 하리라' 하시니라","reference":"사도행전 23:11","category":"$undefined"},{"id":"27747","book":"사도행전","book_name":"사도행전","chapter":23,"verse":12,"text":"날이 새매 유대인들이 당을 지어 맹세하되 `바울을 죽이기 전에는 먹지도 아니하고 마시지도 아니하겠다' 하고","reference":"사도행전 23:12","category":"$undefined"},{"id":"27748","book":"사도행전","book_name":"사도행전","chapter":23,"verse":13,"text":"이같이 동맹한 자가 사십여 명이더라","reference":"사도행전 23:13","category":"$undefined"},{"id":"27749","book":"사도행전","book_name":"사도행전","chapter":23,"verse":14,"text":"대제사장들과 장로들에게 가서 말하되 `우리가 바울을 죽이기 전에는 아무 것도 먹지 않기로 굳게 맹세하였으니","reference":"사도행전 23:14","category":"$undefined"},{"id":"27750","book":"사도행전","book_name":"사도행전","chapter":23,"verse":15,"text":"이제 너희는 그의 사실을 더 자세히 알아볼 양으로 공회와 함께 천부장에게 청하여 바울을 너희에게로 데리고 내려오게 하라 우리는 그가 가까이 오기 전에 죽이기로 준비하였노라' 하더니","reference":"사도행전 23:15","category":"$undefined"},{"id":"27751","book":"사도행전","book_name":"사도행전","chapter":23,"verse":16,"text":"바울의 생질이 그들이 매복하여 있다 함을 듣고 와서 영문에 들어가 바울에게 고한지라","reference":"사도행전 23:16","category":"$undefined"},{"id":"27752","book":"사도행전","book_name":"사도행전","chapter":23,"verse":17,"text":"천부장에게로 데리고 가서 가로되 `죄수 바울이 나를 불러 이 청년이 당신께 할 말이 있다 하여 데리고 가기를 청하더이다' 하매","reference":"사도행전 23:17","category":"$undefined"},{"id":"27753","book":"사도행전","book_name":"사도행전","chapter":23,"verse":18,"text":"천부장이 그 손을 잡고 물러가서 종용히 묻되 `내게 할 말이 무엇이냐 ?'","reference":"사도행전 23:18","category":"$undefined"},{"id":"27754","book":"사도행전","book_name":"사도행전","chapter":23,"verse":19,"text":"대답하되 `유대인들이 공모하기를 저희들이 바울에 대하여 더 자세한 것을 묻기 위함이라 하고 내일 그를 데리고 공회로 내려오기를 당신께 청하자 하였으니","reference":"사도행전 23:19","category":"$undefined"},{"id":"27755","book":"사도행전","book_name":"사도행전","chapter":23,"verse":20,"text":"당신은 저희 청함을 좇지 마옵소서 저희 중에서 바울을 죽이기 전에는 먹지도 않고 마시지도 않기로 맹세한 자 사십여 명이 그를 죽이려고 숨어서 지금 다 준비하고 당신의 허락만 기다리나이다' 하매","reference":"사도행전 23:20","category":"$undefined"},{"id":"27756","book":"사도행전","book_name":"사도행전","chapter":23,"verse":21,"text":"이에 천부장이 청년을 보내며 경계하되 `이 일을 내게 고하였다고 아무에게도 이르지 말라' 하고","reference":"사도행전 23:21","category":"$undefined"},{"id":"27757","book":"사도행전","book_name":"사도행전","chapter":23,"verse":22,"text":"백부장 둘을 불러 이르되 `밤 제 삼시에 가이사랴까지 갈 보병 이백 명과 마병 칠십 명과 창군 이백 명을 준비하라' 하고","reference":"사도행전 23:22","category":"$undefined"},{"id":"27758","book":"사도행전","book_name":"사도행전","chapter":23,"verse":23,"text":"또 바울을 태워 총독 벨릭스에게로 무사히 보내기 위하여 짐승을 준비하라 명하며","reference":"사도행전 23:23","category":"$undefined"},{"id":"27759","book":"사도행전","book_name":"사도행전","chapter":23,"verse":24,"text":"또 이 아래와 같이 편지하니 일렀으되","reference":"사도행전 23:24","category":"$undefined"},{"id":"27760","book":"사도행전","book_name":"사도행전","chapter":23,"verse":25,"text":"글라우디오 루시아는 총독 벨릭스 각하에게 문안하노이다","reference":"사도행전 23:25","category":"$undefined"},{"id":"27761","book":"사도행전","book_name":"사도행전","chapter":23,"verse":26,"text":"이 사람이 유대인들에게 잡혀 죽게 된 것을 내가 로마 사람인줄 들어 알고 군사를 거느리고 가서 구원하여다가","reference":"사도행전 23:26","category":"$undefined"},{"id":"27762","book":"사도행전","book_name":"사도행전","chapter":23,"verse":27,"text":"유대인들이 무슨 일로 그를 송사하는지 알고자 하여 저희 공회로 데리고 내려갔더니","reference":"사도행전 23:27","category":"$undefined"},{"id":"27763","book":"사도행전","book_name":"사도행전","chapter":23,"verse":28,"text":"송사하는 것이 저희 율법 문제에 관한 것뿐이요 한 가지도 죽이거나 결박할 사건이 없음을 발견하였나이다","reference":"사도행전 23:28","category":"$undefined"},{"id":"27764","book":"사도행전","book_name":"사도행전","chapter":23,"verse":29,"text":"그러나 이 사람을 해하려는 간계가 있다고 누가 내게 알게 하기로 곧 당신께로 보내며 또 송사하는 사람들도 당신 앞에서 그를 대하여 말하라 하였나이다 하였더라","reference":"사도행전 23:29","category":"$undefined"},{"id":"27765","book":"사도행전","book_name":"사도행전","chapter":23,"verse":30,"text":"보병이 명을 받은 대로 밤에 바울을 데리고 안디바드리에 이르러","reference":"사도행전 23:30","category":"$undefined"},{"id":"27766","book":"사도행전","book_name":"사도행전","chapter":23,"verse":31,"text":"이튿날 마병으로 바울을 호송하게 하고 영문으로 돌아가니라","reference":"사도행전 23:31","category":"$undefined"},{"id":"27767","book":"사도행전","book_name":"사도행전","chapter":23,"verse":32,"text":"저희가 가이사랴에 들어가서 편지를 총독에게 드리고 바울을 그 앞에 세우니","reference":"사도행전 23:32","category":"$undefined"},{"id":"27768","book":"사도행전","book_name":"사도행전","chapter":23,"verse":33,"text":"총독이 읽고 바울더러 `어느 영지 사람이냐 ?' 물어 갈리기아 사람인줄 알고","reference":"사도행전 23:33","category":"$undefined"},{"id":"27769","book":"사도행전","book_name":"사도행전","chapter":23,"verse":34,"text":"가로되 `너를 송사하는 사람들이 오거든 네 말을 들으리라' 하고 헤롯궁에 그를 지키라 명하니라","reference":"사도행전 23:34","category":"$undefined"},{"id":"27770","book":"사도행전","book_name":"사도행전","chapter":23,"verse":35,"text":"","reference":"사도행전 23:35","category":"$undefined"}],"bookSlug":"acts"}]
