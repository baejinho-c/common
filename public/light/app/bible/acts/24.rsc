2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":24,"verses":[{"id":"27771","book":"사도행전","book_name":"사도행전","chapter":24,"verse":1,"text":"닷새 후에 대제사장 아나니아가 어떤 장로들과 한 변사 더둘로와 함께 내려와서 총독 앞에서 바울을 고소하니라","reference":"사도행전 24:1","category":"$undefined"},{"id":"27772","book":"사도행전","book_name":"사도행전","chapter":24,"verse":2,"text":"바울을 부르매 더둘로가 송사하여 가로되","reference":"사도행전 24:2","category":"$undefined"},{"id":"27773","book":"사도행전","book_name":"사도행전","chapter":24,"verse":3,"text":"`벨릭스 각하여 우리가 당신을 힘입어 태평을 누리고 또 이 민족이 당신의 선견을 인하여 여러 가지로 개량된 것을 우리가 어느 모양으로나 어느 곳에서나 감사 무지 하옵나이다","reference":"사도행전 24:3","category":"$undefined"},{"id":"27774","book":"사도행전","book_name":"사도행전","chapter":24,"verse":4,"text":"당신을 더 괴롭게 아니하려 하여 우리가 대강 여짜옵나니 관용하여 들으시기를 원하나이다","reference":"사도행전 24:4","category":"$undefined"},{"id":"27775","book":"사도행전","book_name":"사도행전","chapter":24,"verse":5,"text":"우리가 보니 이 사람은 염병이라 천하에 퍼진 유대인을 다 소요케 하는 자요 나사렛 이단의 괴수라","reference":"사도행전 24:5","category":"$undefined"},{"id":"27776","book":"사도행전","book_name":"사도행전","chapter":24,"verse":6,"text":"저가 또 성전을 더럽게 하려 하므로 우리가 잡았사오니","reference":"사도행전 24:6","category":"$undefined"},{"id":"27777","book":"사도행전","book_name":"사도행전","chapter":24,"verse":7,"text":"당신이 친히 그를 심문하시면","reference":"사도행전 24:7","category":"$undefined"},{"id":"27778","book":"사도행전","book_name":"사도행전","chapter":24,"verse":8,"text":"우리의 송사하는 이 모든 일을 아실 수 있나이다' 하니","reference":"사도행전 24:8","category":"$undefined"},{"id":"27779","book":"사도행전","book_name":"사도행전","chapter":24,"verse":9,"text":"유대인들도 이에 참가하여 이 말이 옳다 주장하니라","reference":"사도행전 24:9","category":"$undefined"},{"id":"27780","book":"사도행전","book_name":"사도행전","chapter":24,"verse":10,"text":"총독이 바울에게 머리로 표시하여 말하라 하니 그가 대답하되 `당신이 여러 해 전부터 이 민족의 재판장 된 것을 내가 알고 내 사건에 대하여 기쁘게 변명하나이다","reference":"사도행전 24:10","category":"$undefined"},{"id":"27781","book":"사도행전","book_name":"사도행전","chapter":24,"verse":11,"text":"당신이 아실 수 있는 바와 같이 내가 예루살렘에 예배하러 올라간 지 열 이틀 밖에 못되었고","reference":"사도행전 24:11","category":"$undefined"},{"id":"27782","book":"사도행전","book_name":"사도행전","chapter":24,"verse":12,"text":"저희는 내가 성전에서 아무와 변론하는 것이나 회당과 또는 성중에서 무리를 소동케 하는 것을 보지 못하였으니","reference":"사도행전 24:12","category":"$undefined"},{"id":"27783","book":"사도행전","book_name":"사도행전","chapter":24,"verse":13,"text":"이제 나를 송사하는 모든 일에 대하여 저희가 능히 당신 앞에 내세울 것이 없나이다","reference":"사도행전 24:13","category":"$undefined"},{"id":"27784","book":"사도행전","book_name":"사도행전","chapter":24,"verse":14,"text":"그러나 이것을 당신께 고백하리이다 나는 저희가 이단이라 하는 도를 좇아 조상의 하나님을 섬기고 율법과 및 선지자들의 글에 기록된 것을 다 믿으며","reference":"사도행전 24:14","category":"$undefined"},{"id":"27785","book":"사도행전","book_name":"사도행전","chapter":24,"verse":15,"text":"저희의 기다리는 바 하나님께 향한 소망을 나도 가졌으니 곧 의인과 악인의 부활이 있으리라 함이라","reference":"사도행전 24:15","category":"$undefined"},{"id":"27786","book":"사도행전","book_name":"사도행전","chapter":24,"verse":16,"text":"이것을 인하여 나도 하나님과 사람을 대하여 항상 양심에 거리낌이 없기를 힘쓰노라","reference":"사도행전 24:16","category":"$undefined"},{"id":"27787","book":"사도행전","book_name":"사도행전","chapter":24,"verse":17,"text":"여러 해만에 내가 내 민족을 구제할 것과 제물을 가지고 와서","reference":"사도행전 24:17","category":"$undefined"},{"id":"27788","book":"사도행전","book_name":"사도행전","chapter":24,"verse":18,"text":"드리는 중에 내가 결례를 행하였고 모임도 없고 소동도 없이 성전에 있는 것을 저희가 보았나이다 그러나 아시아로부터 온 어떤 유대인들이 있었으니","reference":"사도행전 24:18","category":"$undefined"},{"id":"27789","book":"사도행전","book_name":"사도행전","chapter":24,"verse":19,"text":"저희가 만일 나를 반대할 사건이 있으면 마땅히 당신 앞에 와서 송사하였을 것이요","reference":"사도행전 24:19","category":"$undefined"},{"id":"27790","book":"사도행전","book_name":"사도행전","chapter":24,"verse":20,"text":"그렇지 않으면 이 사람들이 내가 공회 앞에 섰을 때에 무슨 옳지 않은 것을 보았는가 말하라 하소서","reference":"사도행전 24:20","category":"$undefined"},{"id":"27791","book":"사도행전","book_name":"사도행전","chapter":24,"verse":21,"text":"오직 내가 저희 가운데 서서 외치기를 내가 죽은 자의 부활에 대하여 오늘 너희 앞에 심문을 받는다고 한 이 한 소리가 있을 따름이니이다' 하니","reference":"사도행전 24:21","category":"$undefined"},{"id":"27792","book":"사도행전","book_name":"사도행전","chapter":24,"verse":22,"text":"벨릭스가 이 도에 관한 것을 더 자세히 아는고로 연기하여 가로되 천부장 루시아가 내려오거든 너희 일을 처결하리라 하고","reference":"사도행전 24:22","category":"$undefined"},{"id":"27793","book":"사도행전","book_name":"사도행전","chapter":24,"verse":23,"text":"백부장을 명하여 `바울을 지키되 자유를 주며 친구 중 아무나 수종하는 것을 금치 말라' 하니라","reference":"사도행전 24:23","category":"$undefined"},{"id":"27794","book":"사도행전","book_name":"사도행전","chapter":24,"verse":24,"text":"수일 후에 벨릭스가 그 아내 유대 여자 드루실라와 함께 와서 바울을 불러 그리스도 예수 믿는 도를 듣거늘","reference":"사도행전 24:24","category":"$undefined"},{"id":"27795","book":"사도행전","book_name":"사도행전","chapter":24,"verse":25,"text":"바울이 의와 절제와 장차 오는 심판을 강론하니 벨릭스가 두려워하여 대답하되 `시방은 가라 내가 틈이 있으면 너를 부르리라' 하고","reference":"사도행전 24:25","category":"$undefined"},{"id":"27796","book":"사도행전","book_name":"사도행전","chapter":24,"verse":26,"text":"동시에 또 바울에게서 돈을 받을까 바라는고로 더 자주 불러 같이 이야기하더라","reference":"사도행전 24:26","category":"$undefined"},{"id":"27797","book":"사도행전","book_name":"사도행전","chapter":24,"verse":27,"text":"이태를 지내서 보르기오 베스도가 벨릭스의 소임을 대신하니 벨릭스가 유대인의 마음을 얻고자 하여 바울을 구류하여 두니라","reference":"사도행전 24:27","category":"$undefined"}],"bookSlug":"acts"}]
