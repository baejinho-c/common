2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":25,"verses":[{"id":"27798","book":"사도행전","book_name":"사도행전","chapter":25,"verse":1,"text":"베스도가 도임한 지 삼일 후에 가이사랴에서 예루살렘으로 올라가니","reference":"사도행전 25:1","category":"$undefined"},{"id":"27799","book":"사도행전","book_name":"사도행전","chapter":25,"verse":2,"text":"대제사장들과 유대인 중 높은 사람들이 바울을 고소할새","reference":"사도행전 25:2","category":"$undefined"},{"id":"27800","book":"사도행전","book_name":"사도행전","chapter":25,"verse":3,"text":"베스도의 호의로 바울을 예루살렘으로 옮겨 보내기를 청하니 이는 길에 매복하였다가 그를 죽이고자 함이러라","reference":"사도행전 25:3","category":"$undefined"},{"id":"27801","book":"사도행전","book_name":"사도행전","chapter":25,"verse":4,"text":"베스도가 대답하여 바울이 가이사랴에 구류된 것과 자기도 미구에 떠나갈 것을 말하고","reference":"사도행전 25:4","category":"$undefined"},{"id":"27802","book":"사도행전","book_name":"사도행전","chapter":25,"verse":5,"text":"또 가로되 `너희 중 유력한 자들은 나아 함께 내려가서 그 사람에게 만일 옳지 아니한 일이 있거든 송사하라' 하니라","reference":"사도행전 25:5","category":"$undefined"},{"id":"27803","book":"사도행전","book_name":"사도행전","chapter":25,"verse":6,"text":"베스도가 그들 가운데서 팔 일 혹 십 일을 지낸 후 가이사랴로 내려가서 이튿날 재판 자리에 앉고 바울을 데려오라 명하니","reference":"사도행전 25:6","category":"$undefined"},{"id":"27804","book":"사도행전","book_name":"사도행전","chapter":25,"verse":7,"text":"그가 나오매 예루살렘에서 내려온 유대인들이 둘러 서서 여러가지 중대한 사건으로 송사하되 능히 증명하지 못한지라","reference":"사도행전 25:7","category":"$undefined"},{"id":"27805","book":"사도행전","book_name":"사도행전","chapter":25,"verse":8,"text":"바울이 변명하여 가로되 `유대인의 율법이나 성전이나 가이사에게나 내가 도무지 죄를 범하지 아니하였노라' 하니","reference":"사도행전 25:8","category":"$undefined"},{"id":"27806","book":"사도행전","book_name":"사도행전","chapter":25,"verse":9,"text":"베스도가 유대인의 마음을 얻고자 하여 바울더러 묻되 `네가 예루살렘에 올라가서 이 사건에 대하여 내 앞에서 심문을 받으려느냐 ?'","reference":"사도행전 25:9","category":"$undefined"},{"id":"27807","book":"사도행전","book_name":"사도행전","chapter":25,"verse":10,"text":"바울이 가로되 `내가 가이사의 재판 자리 앞에 섰으니 마땅히 거기서 심문을 받을 것이라 당신도 잘 아시는 바에 내가 유대인들에게 불의를 행한 일이 없나이다","reference":"사도행전 25:10","category":"$undefined"},{"id":"27808","book":"사도행전","book_name":"사도행전","chapter":25,"verse":11,"text":"만일 내가 불의를 행하여 무슨 사죄를 범하였으면 죽기를 사양치 아니할 것이나 만일 이 사람들의 나를 송사하는 것이 다 사실이 아니면 누구든지 나를 그들에게 내어 줄 수 없삽나이다 내가 가이사께 호소하노라' 한대","reference":"사도행전 25:11","category":"$undefined"},{"id":"27809","book":"사도행전","book_name":"사도행전","chapter":25,"verse":12,"text":"베스도가 배석자들과 상의하고 가로되 `네가 가이사에게 호소하였으니 가이사에게 갈 것이라' 하니라","reference":"사도행전 25:12","category":"$undefined"},{"id":"27810","book":"사도행전","book_name":"사도행전","chapter":25,"verse":13,"text":"수일 후에 아그립바 왕과 버니게가 베스도에게 문안하러 가이사랴에 와서","reference":"사도행전 25:13","category":"$undefined"},{"id":"27811","book":"사도행전","book_name":"사도행전","chapter":25,"verse":14,"text":"여러 날을 있더니 베스도가 바울의 일로 왕에게 고하여 가로되 벨릭스가 한 사람을 구류하여 두었는데","reference":"사도행전 25:14","category":"$undefined"},{"id":"27812","book":"사도행전","book_name":"사도행전","chapter":25,"verse":15,"text":"내가 예루살렘에 있을 때에 유대인의 대제사장들과 장로들이 그를 고소하여 정죄하기를 청하기에","reference":"사도행전 25:15","category":"$undefined"},{"id":"27813","book":"사도행전","book_name":"사도행전","chapter":25,"verse":16,"text":"내가 대답하되 무릇 피고가 원고들 앞에서 고소 사건에 대하여 변명할 기회가 있기 전에 내어주는 것이 로마 사람의 법이 아니라 하였노라","reference":"사도행전 25:16","category":"$undefined"},{"id":"27814","book":"사도행전","book_name":"사도행전","chapter":25,"verse":17,"text":"그러므로 저희가 나와 함께 여기 오매 내가 지체하지 아니하고 이튿날 재판 자리에 앉아 명하여 그 사람을 데려왔으나","reference":"사도행전 25:17","category":"$undefined"},{"id":"27815","book":"사도행전","book_name":"사도행전","chapter":25,"verse":18,"text":"원고들이 서서 나의 짐작하던것 같은 악행의 사건은 하나도 제출치 아니하고","reference":"사도행전 25:18","category":"$undefined"},{"id":"27816","book":"사도행전","book_name":"사도행전","chapter":25,"verse":19,"text":"오직 자기들의 종교와 또는 예수라 하는 이의 죽은 것을 살았다고 바울이 주장하는 그 일에 관한 문제로 송사하는 것뿐이라","reference":"사도행전 25:19","category":"$undefined"},{"id":"27817","book":"사도행전","book_name":"사도행전","chapter":25,"verse":20,"text":"내가 이 일을 어떻게 사실할는지 의심이 있어서 바울에게 묻되 예루살렘에 올라가서 이 일에 심문을 받으려느냐 한즉","reference":"사도행전 25:20","category":"$undefined"},{"id":"27818","book":"사도행전","book_name":"사도행전","chapter":25,"verse":21,"text":"바울은 황제의 판결을 받도록 자기를 지켜 주기를 호소하므로 내가 그를 가이사에게 보내기까지 지켜 두라 명하였노라' 하니","reference":"사도행전 25:21","category":"$undefined"},{"id":"27819","book":"사도행전","book_name":"사도행전","chapter":25,"verse":22,"text":"아그립바가 베스도더러 이르되 `나도 이 사람의 말을 듣고자 하노라' 베스도가 가로되 `내일 들으시리이다' 하더라","reference":"사도행전 25:22","category":"$undefined"},{"id":"27820","book":"사도행전","book_name":"사도행전","chapter":25,"verse":23,"text":"이튿날 아그립바와 버니게가 크게 위의를 베풀고 와서 천부장들과 성중의 높은 사람들과 함께 신문소에 들어오고 베스도의 명으로 바울을 데려오니","reference":"사도행전 25:23","category":"$undefined"},{"id":"27821","book":"사도행전","book_name":"사도행전","chapter":25,"verse":24,"text":"베스도가 말하되 `아그립바 왕과 여기 같이 있는 여러분이여 당신들의 보는 이 사람은 유대의 모든 무리가 크게 외치되 살려 두지 못할 사람이라고 하여 예루살렘에서와 여기서도 내게 청원하였으나","reference":"사도행전 25:24","category":"$undefined"},{"id":"27822","book":"사도행전","book_name":"사도행전","chapter":25,"verse":25,"text":"나는 살피건대 죽일 죄를 범한 일이 없더이다 그러나 저가 황제에게 호소한 고로 보내기를 작정하였나이다","reference":"사도행전 25:25","category":"$undefined"},{"id":"27823","book":"사도행전","book_name":"사도행전","chapter":25,"verse":26,"text":"그에게 대하여 황제께 확실한 사실을 아뢸 것이 없으므로 심문한 후 상소할 재료가 있을까 하여 당신들 앞 특히 아그립바 왕 당신 앞에 그를 내어 세웠나이다","reference":"사도행전 25:26","category":"$undefined"},{"id":"27824","book":"사도행전","book_name":"사도행전","chapter":25,"verse":27,"text":"그 죄목을 베풀지 아니하고 죄수를 보내는 것이 무리한 일인줄 아나이다' 하였더라","reference":"사도행전 25:27","category":"$undefined"}],"bookSlug":"acts"}]
