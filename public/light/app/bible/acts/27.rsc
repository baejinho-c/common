2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":27,"verses":[{"id":"27857","book":"사도행전","book_name":"사도행전","chapter":27,"verse":1,"text":"우리의 배 타고 이달리야로 갈 일이 작정되매 바울과 다른 죄수 몇 사람을 아구사도대의 백부장 율리오란 사람에게 맡기니","reference":"사도행전 27:1","category":"$undefined"},{"id":"27858","book":"사도행전","book_name":"사도행전","chapter":27,"verse":2,"text":"아시아 해변 각처로 가려 하는 아드라뭇데노 배에 우리가 올라 행선할새 마게도냐의 데살로니가 사람 아리스다고도 함께 하니라","reference":"사도행전 27:2","category":"$undefined"},{"id":"27859","book":"사도행전","book_name":"사도행전","chapter":27,"verse":3,"text":"이튿날 시돈에 대니 율리오가 바울을 친절히 하여 친구들에게 가서 대접받음을 허락하더니","reference":"사도행전 27:3","category":"$undefined"},{"id":"27860","book":"사도행전","book_name":"사도행전","chapter":27,"verse":4,"text":"또 거기서 우리가 떠나가다가 바람의 거스림을 피하여 구브로 해안을 의지하고 행선하여","reference":"사도행전 27:4","category":"$undefined"},{"id":"27861","book":"사도행전","book_name":"사도행전","chapter":27,"verse":5,"text":"길리기아와 밤빌리아 바다를 건너 루기아의 무라성에 이르러","reference":"사도행전 27:5","category":"$undefined"},{"id":"27862","book":"사도행전","book_name":"사도행전","chapter":27,"verse":6,"text":"거기서 백부장이 이달리야로 가려 하는 알렉산드리아 배를 만나 우리를 오르게 하니","reference":"사도행전 27:6","category":"$undefined"},{"id":"27863","book":"사도행전","book_name":"사도행전","chapter":27,"verse":7,"text":"배가 더디 가 여러 날만에 간신히 니도 맞은 편에 이르러 풍세가 더 허락지 아니하므로 살모네 앞을 지나 그레데 해안을 의지하고 행선하여","reference":"사도행전 27:7","category":"$undefined"},{"id":"27864","book":"사도행전","book_name":"사도행전","chapter":27,"verse":8,"text":"간신히 그 연안을 지나 미항이라는 곳에 이르니 라새아성에서 가깝더라","reference":"사도행전 27:8","category":"$undefined"},{"id":"27865","book":"사도행전","book_name":"사도행전","chapter":27,"verse":9,"text":"여러 날이 걸려 금식하는 절기가 이미 지났으므로 행선하기가 위태한지라 바울이 저희를 권하여","reference":"사도행전 27:9","category":"$undefined"},{"id":"27866","book":"사도행전","book_name":"사도행전","chapter":27,"verse":10,"text":"말하되 `여러분이여, 내가 보니 이번 행선이 하물과 배만 아니라 우리 생명에도 타격과 많은 손해가 있으리라' 하되","reference":"사도행전 27:10","category":"$undefined"},{"id":"27867","book":"사도행전","book_name":"사도행전","chapter":27,"verse":11,"text":"백부장이 선장과 선주의 말을 바울의 말보다 더 믿더라","reference":"사도행전 27:11","category":"$undefined"},{"id":"27868","book":"사도행전","book_name":"사도행전","chapter":27,"verse":12,"text":"그 항구가 과동하기에 불편하므로 거기서 떠나 아무쪼록 뵈닉스에 가서 과동하자 하는 자가 더 많으니 뵈닉스는 그레데 항구라 한 편은 동북을,한 편은 동남을 향하였더라","reference":"사도행전 27:12","category":"$undefined"},{"id":"27869","book":"사도행전","book_name":"사도행전","chapter":27,"verse":13,"text":"남풍이 순하게 불매 저희가 득의한 줄 알고 닻을 감아 그레데 해변을 가까이 하고 행선하더니","reference":"사도행전 27:13","category":"$undefined"},{"id":"27870","book":"사도행전","book_name":"사도행전","chapter":27,"verse":14,"text":"얼마 못되어 섬 가운데로서 유라굴로라는 광풍이 대작하니","reference":"사도행전 27:14","category":"$undefined"},{"id":"27871","book":"사도행전","book_name":"사도행전","chapter":27,"verse":15,"text":"배가 밀려 바람을 맞추어 갈 수 없어 가는 대로 두고 쫓겨가다가","reference":"사도행전 27:15","category":"$undefined"},{"id":"27872","book":"사도행전","book_name":"사도행전","chapter":27,"verse":16,"text":"가우다라는 작은 섬 아래로 지나 간신히 거루를 잡아","reference":"사도행전 27:16","category":"$undefined"},{"id":"27873","book":"사도행전","book_name":"사도행전","chapter":27,"verse":17,"text":"끌어 올리고 줄을 가지고 선체를 둘러 감고 스르디스에 걸릴까 두려워 연장을 내리고 그냥 쫓겨가더니","reference":"사도행전 27:17","category":"$undefined"},{"id":"27874","book":"사도행전","book_name":"사도행전","chapter":27,"verse":18,"text":"우리가 풍랑으로 심히 애쓰다가 이튿날 사공들이 짐을 바다에 풀어 버리고","reference":"사도행전 27:18","category":"$undefined"},{"id":"27875","book":"사도행전","book_name":"사도행전","chapter":27,"verse":19,"text":"사흘째 되는 날에 배의 기구를 저희 손으로 내어 버리니라","reference":"사도행전 27:19","category":"$undefined"},{"id":"27876","book":"사도행전","book_name":"사도행전","chapter":27,"verse":20,"text":"여러 날 동안 해와 별이 보이지 아니하고 큰 풍랑이 그대로 있으매 구원의 여망이 다 없어졌더라","reference":"사도행전 27:20","category":"$undefined"},{"id":"27877","book":"사도행전","book_name":"사도행전","chapter":27,"verse":21,"text":"여러 사람이 오래 먹지 못하였으매 바울이 가운데 서서 말하되 여러분이여 내 말을 듣고 그레데에서 떠나지 아니하여 이 타격과 손상을 면하였더면 좋을 뻔하였느니라","reference":"사도행전 27:21","category":"$undefined"},{"id":"27878","book":"사도행전","book_name":"사도행전","chapter":27,"verse":22,"text":"내가 너희를 권하노니 이제는 안심하라 너희 중 생명에는 아무 손상이 없겠고 오직 배뿐이리라","reference":"사도행전 27:22","category":"$undefined"},{"id":"27879","book":"사도행전","book_name":"사도행전","chapter":27,"verse":23,"text":"나의 속한 바 곧 나의 섬기는 하나님의 사자가 어제 밤에 내 곁에 서서 말하되","reference":"사도행전 27:23","category":"$undefined"},{"id":"27880","book":"사도행전","book_name":"사도행전","chapter":27,"verse":24,"text":"바울아 두려워 말라 네가 가이사 앞에 서야 하겠고 또 하나님께서 너와 함께 행선하는 자를 다 네게 주셨다 하였으니","reference":"사도행전 27:24","category":"$undefined"},{"id":"27881","book":"사도행전","book_name":"사도행전","chapter":27,"verse":25,"text":"그러므로 여러분이여 안심하라 나는 내게 말씀하신 그대로 되리라 !고 하나님을 믿노라","reference":"사도행전 27:25","category":"$undefined"},{"id":"27882","book":"사도행전","book_name":"사도행전","chapter":27,"verse":26,"text":"그러나 우리가 한 섬에 걸리리라 하더라","reference":"사도행전 27:26","category":"$undefined"},{"id":"27883","book":"사도행전","book_name":"사도행전","chapter":27,"verse":27,"text":"열 나흘째 되는 날 밤에 우리가 아드리아 바다에 이리저리 쫓겨 가더니 밤중쯤 되어 사공들이 어느 육지에 가까와지는 줄을 짐작하고","reference":"사도행전 27:27","category":"$undefined"},{"id":"27884","book":"사도행전","book_name":"사도행전","chapter":27,"verse":28,"text":"물을 재어보니 이십 길이 되고 조금 가다가 다시 재니 열 다섯 길이라","reference":"사도행전 27:28","category":"$undefined"},{"id":"27885","book":"사도행전","book_name":"사도행전","chapter":27,"verse":29,"text":"암초에 걸릴까 하여 고물로 닻 넷을 주고 날이 새기를 고대하더니","reference":"사도행전 27:29","category":"$undefined"},{"id":"27886","book":"사도행전","book_name":"사도행전","chapter":27,"verse":30,"text":"사공들이 도망하고자 하여 이물에서 닻을 주려는 체하고 거루를 바다에 내려놓거늘","reference":"사도행전 27:30","category":"$undefined"},{"id":"27887","book":"사도행전","book_name":"사도행전","chapter":27,"verse":31,"text":"바울이 백부장과 군사들에게 이르되 `이 사람들이 배에 있지 아니하면 너희가 구원을 얻지 못하리라' 하니","reference":"사도행전 27:31","category":"$undefined"},{"id":"27888","book":"사도행전","book_name":"사도행전","chapter":27,"verse":32,"text":"이에 군사들이 거룻 줄을 끊어 떼어 버리니라","reference":"사도행전 27:32","category":"$undefined"},{"id":"27889","book":"사도행전","book_name":"사도행전","chapter":27,"verse":33,"text":"날이 새어 가매 바울이 여러 사람을 음식 먹으라 권하여 가로되 너희가 기다리고 기다리며 먹지 못하고 주린 지가 오늘까지 열 나흘인즉","reference":"사도행전 27:33","category":"$undefined"},{"id":"27890","book":"사도행전","book_name":"사도행전","chapter":27,"verse":34,"text":"음식 먹으라 권하노니 이것이 너희 구원을 위하는 것이요 너희 중 머리터럭 하나라도 잃을 자가 없느니라 하고","reference":"사도행전 27:34","category":"$undefined"},{"id":"27891","book":"사도행전","book_name":"사도행전","chapter":27,"verse":35,"text":"떡을 가져다가 모든 사람 앞에서 하나님께 축사하고 떼어 먹기를 시작하매","reference":"사도행전 27:35","category":"$undefined"},{"id":"27892","book":"사도행전","book_name":"사도행전","chapter":27,"verse":36,"text":"저희도 다 안심하고 받아 먹으니","reference":"사도행전 27:36","category":"$undefined"},{"id":"27893","book":"사도행전","book_name":"사도행전","chapter":27,"verse":37,"text":"배에 있는 우리의 수는 전부 이백 칠십 륙 인이러라","reference":"사도행전 27:37","category":"$undefined"},{"id":"27894","book":"사도행전","book_name":"사도행전","chapter":27,"verse":38,"text":"배부르게 먹고 밀을 바다에 버려 배를 가볍게 하였더니","reference":"사도행전 27:38","category":"$undefined"},{"id":"27895","book":"사도행전","book_name":"사도행전","chapter":27,"verse":39,"text":"날이 새매 어느 땅인지 알지 못하나 경사 진 해안으로 된 항만이 눈에 띄거늘 배를 거기에 들여다 댈 수 있는가 의논한 후","reference":"사도행전 27:39","category":"$undefined"},{"id":"27896","book":"사도행전","book_name":"사도행전","chapter":27,"verse":40,"text":"닻을 끊어 바다에 버리는 동시에 킷줄을 늦추고 돛을 달고 바람을 맞추어 해안을 향하여 들어가다가","reference":"사도행전 27:40","category":"$undefined"},{"id":"27897","book":"사도행전","book_name":"사도행전","chapter":27,"verse":41,"text":"두 물이 합하여 흐르는 곳을 당하여 배를 걸매 이물은 부딪혀 움직일 수 없이 붙고 고물은 큰 물결에 깨어져 가니","reference":"사도행전 27:41","category":"$undefined"},{"id":"27898","book":"사도행전","book_name":"사도행전","chapter":27,"verse":42,"text":"군사들은 죄수가 헤엄쳐서 도망할까 하여 저희를 죽이는 것이 좋다 하였으나","reference":"사도행전 27:42","category":"$undefined"},{"id":"27899","book":"사도행전","book_name":"사도행전","chapter":27,"verse":43,"text":"백부장이 바울을 구원하려 하여 저희의 뜻을 막고 헤엄칠 줄 아는 사람들을 명하여 물에 뛰어 내려 먼저 육지에 나가게 하고","reference":"사도행전 27:43","category":"$undefined"},{"id":"27900","book":"사도행전","book_name":"사도행전","chapter":27,"verse":44,"text":"그 남은 사람들은 널조각 혹은 배 물건에 의지하여 나가게 하니 마침내 사람들이 다 상륙하여 구원을 얻으니라","reference":"사도행전 27:44","category":"$undefined"}],"bookSlug":"acts"}]
