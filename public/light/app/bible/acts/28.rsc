2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":28,"verses":[{"id":"27901","book":"사도행전","book_name":"사도행전","chapter":28,"verse":1,"text":"우리가 구원을 얻은 후에 안즉 그 섬은 멜리데라 하더라","reference":"사도행전 28:1","category":"$undefined"},{"id":"27902","book":"사도행전","book_name":"사도행전","chapter":28,"verse":2,"text":"토인들이 우리에게 특별한 동정을 하여 비가 오고 날이 차매 불을 피워 우리를 다 영접하더라","reference":"사도행전 28:2","category":"$undefined"},{"id":"27903","book":"사도행전","book_name":"사도행전","chapter":28,"verse":3,"text":"바울이 한뭇 나무를 거두어 불에 넣으니 뜨거움을 인하여 독사가 나와 그 손을 물고 있는지라","reference":"사도행전 28:3","category":"$undefined"},{"id":"27904","book":"사도행전","book_name":"사도행전","chapter":28,"verse":4,"text":"토인들이 이 짐승이 그 손에 달림을 보고 서로 말하되 `진실로 이 사람은 살인한 자로다 바다에서는 구원을 얻었으나 공의가 살지 못하게 하심이로다' 하더니","reference":"사도행전 28:4","category":"$undefined"},{"id":"27905","book":"사도행전","book_name":"사도행전","chapter":28,"verse":5,"text":"바울이 그 짐승을 불에 떨어 버리매 조금도 상함이 없더라","reference":"사도행전 28:5","category":"$undefined"},{"id":"27906","book":"사도행전","book_name":"사도행전","chapter":28,"verse":6,"text":"그가 붓든지 혹 갑자기 엎드러져 죽을 줄로 저희가 기다렸더니 오래 기다려도 그에게 아무 이상이 없음을 보고 돌려 생각하여 말하되 신이라 하더라","reference":"사도행전 28:6","category":"$undefined"},{"id":"27907","book":"사도행전","book_name":"사도행전","chapter":28,"verse":7,"text":"이 섬에 제일 높은 사람 보블리오라 하는 이가 그 근처에 토지가 있는지라 그가 우리를 영접하여 사흘이나 친절히 유숙하게 하더니","reference":"사도행전 28:7","category":"$undefined"},{"id":"27908","book":"사도행전","book_name":"사도행전","chapter":28,"verse":8,"text":"보블리오의 부친이 열병과 이질에 걸려 누웠거늘 바울이 들어가서 기도하고 그에게 안수하여 낫게 하매","reference":"사도행전 28:8","category":"$undefined"},{"id":"27909","book":"사도행전","book_name":"사도행전","chapter":28,"verse":9,"text":"이러므로 섬 가운데 다른 병든 사람들이 와서 고침을 받고","reference":"사도행전 28:9","category":"$undefined"},{"id":"27910","book":"사도행전","book_name":"사도행전","chapter":28,"verse":10,"text":"후한 예로 우리를 대접하고 떠날 때에 우리 쓸 것을 배에 올리더라","reference":"사도행전 28:10","category":"$undefined"},{"id":"27911","book":"사도행전","book_name":"사도행전","chapter":28,"verse":11,"text":"석 달 후에 그 섬에서 과동한 알렉산드리아 배를 우리가 타고 떠나니 그 배 기호는 디오스구로라","reference":"사도행전 28:11","category":"$undefined"},{"id":"27912","book":"사도행전","book_name":"사도행전","chapter":28,"verse":12,"text":"수라구사에 대고 사흘을 있다가","reference":"사도행전 28:12","category":"$undefined"},{"id":"27913","book":"사도행전","book_name":"사도행전","chapter":28,"verse":13,"text":"거기서 둘러가서 레기온에 이르러 하루를 지난 후 남풍이 일어나므로 이튿날 보디올에 이르러","reference":"사도행전 28:13","category":"$undefined"},{"id":"27914","book":"사도행전","book_name":"사도행전","chapter":28,"verse":14,"text":"거기서 형제를 만나 저희의 청함을 받아 이레를 함께 유하다가 로마로 가니라","reference":"사도행전 28:14","category":"$undefined"},{"id":"27915","book":"사도행전","book_name":"사도행전","chapter":28,"verse":15,"text":"거기 형제들이 우리 소식을 듣고 압비오 저자와 삼관까지 맞으러 오니 바울이 저희를 보고 하나님께 사례하고 담대한 마음을 얻으니라","reference":"사도행전 28:15","category":"$undefined"},{"id":"27916","book":"사도행전","book_name":"사도행전","chapter":28,"verse":16,"text":"우리가 로마에 들어가니 바울은 자기를 지키는 한 군사와 함께 따로 있게 허락하더라","reference":"사도행전 28:16","category":"$undefined"},{"id":"27917","book":"사도행전","book_name":"사도행전","chapter":28,"verse":17,"text":"사흘 후에 바울이 유대인 중 높은 사람들을 청하여 모인 후에 이르되 여러분 형제들아 내가 이스라엘 백성이나 우리 조상의 규모를 배척한 일이 없는데 예루살렘에서 로마인의 손에 죄수로 내어준 바 되었으니","reference":"사도행전 28:17","category":"$undefined"},{"id":"27918","book":"사도행전","book_name":"사도행전","chapter":28,"verse":18,"text":"로마인은 나를 심문하여 죽일 죄목이 없으므로 놓으려 하였으나","reference":"사도행전 28:18","category":"$undefined"},{"id":"27919","book":"사도행전","book_name":"사도행전","chapter":28,"verse":19,"text":"유대인들이 반대하기로 내가 마지 못하여 가이사에게 호소함이요 내 민족을 송사하려는 것이 아니로라","reference":"사도행전 28:19","category":"$undefined"},{"id":"27920","book":"사도행전","book_name":"사도행전","chapter":28,"verse":20,"text":"이러하므로 너희를 보고 함께 이야기하려고 청하였노니 이스라엘의 소망을 인하여 내가 이 쇠사슬에 매인 바 되었노라","reference":"사도행전 28:20","category":"$undefined"},{"id":"27921","book":"사도행전","book_name":"사도행전","chapter":28,"verse":21,"text":"저희가 가로되 우리가 유대에서 네게 대한 편지도 받은 일이 없고 또 형제 중 누가 와서 네게 대하여 좋지 못한 것을 고하든지 이야기한 일도 없느니라","reference":"사도행전 28:21","category":"$undefined"},{"id":"27922","book":"사도행전","book_name":"사도행전","chapter":28,"verse":22,"text":"이에 우리가 너의 사상이 어떠한가 듣고자 하노니 이 파에 대하여는 어디서든지 반대를 받는 줄 우리가 앎이라 하더라","reference":"사도행전 28:22","category":"$undefined"},{"id":"27923","book":"사도행전","book_name":"사도행전","chapter":28,"verse":23,"text":"저희가 일자를 정하고 그의 우거하는 집에 많이 오니 바울이 아침부터 저녁까지 강론하여 하나님 나라를 증거하고 모세의 율법과 선지자의 말을 가지고 예수의 일로 권하더라","reference":"사도행전 28:23","category":"$undefined"},{"id":"27924","book":"사도행전","book_name":"사도행전","chapter":28,"verse":24,"text":"그말을 믿는 사람도 있고 믿지 아니하는 사람도 있어","reference":"사도행전 28:24","category":"$undefined"},{"id":"27925","book":"사도행전","book_name":"사도행전","chapter":28,"verse":25,"text":"서로 맞지 아니하여 흩어질 때에 바울이 한 말로 일러 가로되 성령이 선지자 이사야로 너희 조상들에게 말씀하신 것이 옳도다","reference":"사도행전 28:25","category":"$undefined"},{"id":"27926","book":"사도행전","book_name":"사도행전","chapter":28,"verse":26,"text":"일렀으되 이 백성에게 가서 말하기를 너희가 듣기는 들어도 도무지 깨닫지 못하며 보기는 보아도 도무지 알지 못하는도다","reference":"사도행전 28:26","category":"$undefined"},{"id":"27927","book":"사도행전","book_name":"사도행전","chapter":28,"verse":27,"text":"이 백성들의 마음이 완악하여져서 그 귀로는 둔하게 듣고 그 눈을 감았으니 이는 눈으로 보고 귀로 듣고 마음으로 깨달아 돌아와 나의 고침을 받을까 함이라 하였으니","reference":"사도행전 28:27","category":"$undefined"},{"id":"27928","book":"사도행전","book_name":"사도행전","chapter":28,"verse":28,"text":"그런즉 하나님의 이 구원을 이방인에게로 보내신 줄 알라 저희는 또한 들으리라 하더라","reference":"사도행전 28:28","category":"$undefined"},{"id":"27929","book":"사도행전","book_name":"사도행전","chapter":28,"verse":29,"text":"(없 음)","reference":"사도행전 28:29","category":"$undefined"},{"id":"27930","book":"사도행전","book_name":"사도행전","chapter":28,"verse":30,"text":"바울이 온 이태를 자기 셋집에 유하며 자기에게 오는 사람을 다 영접하고","reference":"사도행전 28:30","category":"$undefined"},{"id":"27931","book":"사도행전","book_name":"사도행전","chapter":28,"verse":31,"text":"담대히 하나님 나라를 전파하며 주 예수 그리스도께 관한 것을 가르치되 금하는 사람이 없었더라","reference":"사도행전 28:31","category":"$undefined"}],"bookSlug":"acts"}]
