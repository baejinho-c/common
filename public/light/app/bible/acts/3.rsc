2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":3,"verses":[{"id":"26998","book":"사도행전","book_name":"사도행전","chapter":3,"verse":1,"text":"제 구 시 기도 시간에 베드로와 요한이 성전에 올라갈새","reference":"사도행전 3:1","category":"$undefined"},{"id":"26999","book":"사도행전","book_name":"사도행전","chapter":3,"verse":2,"text":"나면서 앉은뱅이 된 자를 사람들이 메고 오니 이는 성전에 들어가는 사람들에게 구걸하기 위하여 날마다 미문이라는 성전 문에 두는 지라","reference":"사도행전 3:2","category":"$undefined"},{"id":"27000","book":"사도행전","book_name":"사도행전","chapter":3,"verse":3,"text":"그가 베드로와 요한이 성전에 들어가려 함을 보고 구걸하거늘","reference":"사도행전 3:3","category":"$undefined"},{"id":"27001","book":"사도행전","book_name":"사도행전","chapter":3,"verse":4,"text":"베드로가 요한으로 더불어 주목하여 가로되 `우리를 보라' 하니","reference":"사도행전 3:4","category":"$undefined"},{"id":"27002","book":"사도행전","book_name":"사도행전","chapter":3,"verse":5,"text":"그가 저희에게 무엇을 얻을까 하여 바라보거늘","reference":"사도행전 3:5","category":"$undefined"},{"id":"27003","book":"사도행전","book_name":"사도행전","chapter":3,"verse":6,"text":"베드로가 가로되 `은과 금은 내게 없거니와 내게 있는 것으로 네게 주노니 곧 나사렛 예수 그리스도의 이름으로 걸으라 !' 하고","reference":"사도행전 3:6","category":"$undefined"},{"id":"27004","book":"사도행전","book_name":"사도행전","chapter":3,"verse":7,"text":"오른손을 잡아 일으키니 발과 발목이 곧 힘을 얻고","reference":"사도행전 3:7","category":"$undefined"},{"id":"27005","book":"사도행전","book_name":"사도행전","chapter":3,"verse":8,"text":"뛰어 서서 걸으며 그들과 함께 성전으로 들어가면서 걷기도 하고 뛰기도 하며 하나님을 찬미하니","reference":"사도행전 3:8","category":"$undefined"},{"id":"27006","book":"사도행전","book_name":"사도행전","chapter":3,"verse":9,"text":"모든 백성이 그 걷는 것과 및 하나님을 찬미함을 보고","reference":"사도행전 3:9","category":"$undefined"},{"id":"27007","book":"사도행전","book_name":"사도행전","chapter":3,"verse":10,"text":"그 본래 성전 미문에 앉아 구걸하던 사람인 줄 알고 그의 당한 일을 인하여 심히 기이히 여기며 놀라니라","reference":"사도행전 3:10","category":"$undefined"},{"id":"27008","book":"사도행전","book_name":"사도행전","chapter":3,"verse":11,"text":"나은 사람이 베드로와 요한을 붙잡으니 모든 백성이 크게 놀라며 달려 나아가 솔로몬의 행각이라 칭하는 행각에 모이거늘","reference":"사도행전 3:11","category":"$undefined"},{"id":"27009","book":"사도행전","book_name":"사도행전","chapter":3,"verse":12,"text":"베드로가 이것을 보고 백성에게 말하되 `이스라엘 사람들아 ! 이 일을 왜 기이히 여기느냐 우리 개인의 권능과 경건으로 이 사람을 걷게 한 것처럼 왜 우리를 주목하느냐","reference":"사도행전 3:12","category":"$undefined"},{"id":"27010","book":"사도행전","book_name":"사도행전","chapter":3,"verse":13,"text":"아브라함과 이삭과 야곱의 하나님 곧 우리 조상의 하나님이 그 종 예수를 영화롭게 하셨느니라 너희가 저를 넘겨 주고 빌라도가 놓아 주기로 결안한 것을 너희가 그 앞에서 부인하였으니","reference":"사도행전 3:13","category":"$undefined"},{"id":"27011","book":"사도행전","book_name":"사도행전","chapter":3,"verse":14,"text":"너희가 거룩하고 의로운 자를 부인하고 도리어 살인한 사람을 놓아주기를 구하여","reference":"사도행전 3:14","category":"$undefined"},{"id":"27012","book":"사도행전","book_name":"사도행전","chapter":3,"verse":15,"text":"생명의 주를 죽였도다 그러나 하나님이 죽은 자 가운데서 살리셨으니 우리가 이 일에 증인이로라","reference":"사도행전 3:15","category":"$undefined"},{"id":"27013","book":"사도행전","book_name":"사도행전","chapter":3,"verse":16,"text":"그 이름을 믿으므로 그 이름이 너희 보고 아는 이 사람을 성하게 하였나니 예수로 말미암아 난 믿음이 너희 모든 사람 앞에서 이같이 완전히 낫게 하였느니라","reference":"사도행전 3:16","category":"$undefined"},{"id":"27014","book":"사도행전","book_name":"사도행전","chapter":3,"verse":17,"text":"형제들아 너희가 알지 못하여서 그리하였으며 너희 관원들도 그리한 줄 아노라","reference":"사도행전 3:17","category":"$undefined"},{"id":"27015","book":"사도행전","book_name":"사도행전","chapter":3,"verse":18,"text":"그러나 하나님이 모든 선지자의 입을 의탁하사 자기의 그리스도의 해 받으실 일을 미리 알게 하신 것을 이와 같이 이루셨느니라","reference":"사도행전 3:18","category":"$undefined"},{"id":"27016","book":"사도행전","book_name":"사도행전","chapter":3,"verse":19,"text":"그러므로 너희가 회개하고 돌이켜 너희 죄 없이 함을 받으라 이같이 하면 유쾌하게 되는 날이 주 앞으로부터 이를 것이요","reference":"사도행전 3:19","category":"$undefined"},{"id":"27017","book":"사도행전","book_name":"사도행전","chapter":3,"verse":20,"text":"또 주께서 너희를 위하여 예정하신 그리스도 곧 예수를 보내시리니","reference":"사도행전 3:20","category":"$undefined"},{"id":"27018","book":"사도행전","book_name":"사도행전","chapter":3,"verse":21,"text":"하나님이 영원 전부터 거룩한 선지자의 입을 의탁하여 말씀하신 바 만유를 회복하실 때까지는 하늘이 마땅히 그를 받아두리라","reference":"사도행전 3:21","category":"$undefined"},{"id":"27019","book":"사도행전","book_name":"사도행전","chapter":3,"verse":22,"text":"모세가 말하되 주 하나님이 너희를 위하여 너희 형제 가운데서 나같은 선지자 하나를 세울 것이니 너희가 무엇이든지 그 모든 말씀을 들을 것이라","reference":"사도행전 3:22","category":"$undefined"},{"id":"27020","book":"사도행전","book_name":"사도행전","chapter":3,"verse":23,"text":"누구든지 그 선지자의 말을 듣지 아니하는 자는 백성 중에서 멸망 받으리라 하였고","reference":"사도행전 3:23","category":"$undefined"},{"id":"27021","book":"사도행전","book_name":"사도행전","chapter":3,"verse":24,"text":"또한 사무엘 때부터 옴으로 말한 모든 선지자도 이 때를 가리켜 말하였느니라","reference":"사도행전 3:24","category":"$undefined"},{"id":"27022","book":"사도행전","book_name":"사도행전","chapter":3,"verse":25,"text":"너희는 선지자들의 자손이요 또 하나님이 너희 조상으로 더불어 세우신 언약의 자손이라 아브라함에게 이르시기를 땅 위의 모든 족속이 너의 씨를 인하여 복을 받으리라 하셨으니","reference":"사도행전 3:25","category":"$undefined"},{"id":"27023","book":"사도행전","book_name":"사도행전","chapter":3,"verse":26,"text":"하나님이 그 종을 세워 복 주시려고 너희에게 먼저 보내사 너희로 하여금 돌이켜 각각 그 악함을 버리게 하셨느니라'","reference":"사도행전 3:26","category":"$undefined"}],"bookSlug":"acts"}]
