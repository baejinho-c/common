2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":4,"verses":[{"id":"27024","book":"사도행전","book_name":"사도행전","chapter":4,"verse":1,"text":"사도들이 백성에게 말할 때에 제사장들과 성전 맡은 자와 사두개인들이 이르러","reference":"사도행전 4:1","category":"$undefined"},{"id":"27025","book":"사도행전","book_name":"사도행전","chapter":4,"verse":2,"text":"백성을 가르침과 예수를 들어 죽은 자 가운데서 부활하는 도(道) 전함을 싫어하여","reference":"사도행전 4:2","category":"$undefined"},{"id":"27026","book":"사도행전","book_name":"사도행전","chapter":4,"verse":3,"text":"저희를 잡으매 날이 이미 저문 고로 이튿날까지 가두었으나","reference":"사도행전 4:3","category":"$undefined"},{"id":"27027","book":"사도행전","book_name":"사도행전","chapter":4,"verse":4,"text":"말씀을 들은 사람 중에 믿는 자가 많으니 남자의 수가 약 오천이나 되었더라","reference":"사도행전 4:4","category":"$undefined"},{"id":"27028","book":"사도행전","book_name":"사도행전","chapter":4,"verse":5,"text":"이튿날에 관원과 장로와 서기관들이 예루살렘에 모였는데","reference":"사도행전 4:5","category":"$undefined"},{"id":"27029","book":"사도행전","book_name":"사도행전","chapter":4,"verse":6,"text":"대제사장 안나스와 가야바와 요한과 알렉산더와 및 대제사장의 문중이 다 참여하여","reference":"사도행전 4:6","category":"$undefined"},{"id":"27030","book":"사도행전","book_name":"사도행전","chapter":4,"verse":7,"text":"사도들을 가운데 세우고 묻되 `너희가 무슨 권세와 뉘 이름으로 이 일을 행하였느냐 ?'","reference":"사도행전 4:7","category":"$undefined"},{"id":"27031","book":"사도행전","book_name":"사도행전","chapter":4,"verse":8,"text":"이에 베드로가 성령이 충만하여 가로되 `백성의 관원과 장로들아","reference":"사도행전 4:8","category":"$undefined"},{"id":"27032","book":"사도행전","book_name":"사도행전","chapter":4,"verse":9,"text":"만일 병인에게 행한 착한 일에 대하여 이 사람이 어떻게 구원을 얻었느냐고 오늘 우리에게 질문하면","reference":"사도행전 4:9","category":"$undefined"},{"id":"27033","book":"사도행전","book_name":"사도행전","chapter":4,"verse":10,"text":"너희와 모든 이스라엘 백성들은 알라 너희가 십자가에 못 박고 하나님이 죽은 자 가운데서 살리신 나사렛 예수 그리스도의 이름으로 이 사람이 건강하게 되어 너희 앞에 섰느니라","reference":"사도행전 4:10","category":"$undefined"},{"id":"27034","book":"사도행전","book_name":"사도행전","chapter":4,"verse":11,"text":"이 예수는 너희 건축자들의 버린 돌로서 집 모퉁이의 머릿돌이 되었느니라","reference":"사도행전 4:11","category":"$undefined"},{"id":"27035","book":"사도행전","book_name":"사도행전","chapter":4,"verse":12,"text":"다른 이로서는 구원을 얻을 수 없나니 천하 인간에 구원을 얻을 만한 다른 이름을 우리에게 주신 일이 없음이니라' 하였더라","reference":"사도행전 4:12","category":"$undefined"},{"id":"27036","book":"사도행전","book_name":"사도행전","chapter":4,"verse":13,"text":"저희가 베드로와 요한이 기탄없이 말함을 보고 그 본래 학문 없는 범인으로 알았다가 이상히 여기며 또 그 전에 예수와 함께 있던 줄도 알고","reference":"사도행전 4:13","category":"$undefined"},{"id":"27037","book":"사도행전","book_name":"사도행전","chapter":4,"verse":14,"text":"또 병 나은 사람이 그들과 함께 섰는 것을 보고 힐난할 말이 없는지라","reference":"사도행전 4:14","category":"$undefined"},{"id":"27038","book":"사도행전","book_name":"사도행전","chapter":4,"verse":15,"text":"명하여 공회에서 나가라 하고 서로 의논하여 가로되","reference":"사도행전 4:15","category":"$undefined"},{"id":"27039","book":"사도행전","book_name":"사도행전","chapter":4,"verse":16,"text":"`이 사람들을 어떻게 할꼬 ? 저희로 인하여 유명한 표적 나타난 것이 예루살렘에 사는 모든 사람에게 알려졌으니 우리도 부인할 수 없는지라","reference":"사도행전 4:16","category":"$undefined"},{"id":"27040","book":"사도행전","book_name":"사도행전","chapter":4,"verse":17,"text":"이것이 민간에 더 퍼지지 못하게 저희를 위협하여 이 후에는 이 이름으로 아무 사람에게도 말하지 말게 하자' 하고","reference":"사도행전 4:17","category":"$undefined"},{"id":"27041","book":"사도행전","book_name":"사도행전","chapter":4,"verse":18,"text":"그들을 불러 경계하여 `도무지 예수의 이름으로 말하지도 말고 가르치지도 말라' 하니","reference":"사도행전 4:18","category":"$undefined"},{"id":"27042","book":"사도행전","book_name":"사도행전","chapter":4,"verse":19,"text":"베드로와 요한이 대답하여 가로되 `하나님 앞에서 너희 말 듣는 것이 하나님 말씀 듣는 것보다 옳은가 판단하라","reference":"사도행전 4:19","category":"$undefined"},{"id":"27043","book":"사도행전","book_name":"사도행전","chapter":4,"verse":20,"text":"우리는 보고 들은 것을 말하지 아니할 수 없다' 하니","reference":"사도행전 4:20","category":"$undefined"},{"id":"27044","book":"사도행전","book_name":"사도행전","chapter":4,"verse":21,"text":"관원들이 백성을 인하여 저희를 어떻게 벌할 도리를 찾지 못하고 다시 위협하여 놓아 주었으니 이는 모든 사람이 그 된 일을 보고 하나님께 영광을 돌림이러라","reference":"사도행전 4:21","category":"$undefined"},{"id":"27045","book":"사도행전","book_name":"사도행전","chapter":4,"verse":22,"text":"이 표적으로 병 나은 사람은 사십여 세나 되었더라","reference":"사도행전 4:22","category":"$undefined"},{"id":"27046","book":"사도행전","book_name":"사도행전","chapter":4,"verse":23,"text":"사도들이 놓이매 그 동류에게 가서 제사장들과 장로들의 말을 다 고하니","reference":"사도행전 4:23","category":"$undefined"},{"id":"27047","book":"사도행전","book_name":"사도행전","chapter":4,"verse":24,"text":"저희가 듣고 일심으로 하나님께 소리를 높여 가로되 `대주재여 ! 천지와 바다와 그 가운데 만유를 지은 이시요","reference":"사도행전 4:24","category":"$undefined"},{"id":"27048","book":"사도행전","book_name":"사도행전","chapter":4,"verse":25,"text":"또 주의 종 우리 조상 다윗의 입을 의탁하사 성령으로 말씀하시기를 어찌하여 열방이 분노하며 족속들이 허사를 경영하였는고","reference":"사도행전 4:25","category":"$undefined"},{"id":"27049","book":"사도행전","book_name":"사도행전","chapter":4,"verse":26,"text":"세상의 군왕들이 나서며 관원들이 함께 모여 주와 그 그리스도를 대적하도다 하신 이로소이다","reference":"사도행전 4:26","category":"$undefined"},{"id":"27050","book":"사도행전","book_name":"사도행전","chapter":4,"verse":27,"text":"과연 헤롯과 본디오 빌라도는 이방인과 이스라엘 백성과 합동하여 하나님의 기름부으신 거룩한 종 예수를 거스려","reference":"사도행전 4:27","category":"$undefined"},{"id":"27051","book":"사도행전","book_name":"사도행전","chapter":4,"verse":28,"text":"하나님의 권능과 뜻대로 이루려고 예정하신 그것을 행하려고 이 성에 모였나이다","reference":"사도행전 4:28","category":"$undefined"},{"id":"27052","book":"사도행전","book_name":"사도행전","chapter":4,"verse":29,"text":"주여 ! 이제도 저희의 위협함을 하감하옵시고 또 종들로 하여금 담대히 하나님의 말씀을 전하게 하여 주옵시며","reference":"사도행전 4:29","category":"$undefined"},{"id":"27053","book":"사도행전","book_name":"사도행전","chapter":4,"verse":30,"text":"손을 내밀어 병을 낫게 하옵시고 표적과 기사가 거룩한 종 예수의 이름으로 이루어지게 하옵소서' 하더라","reference":"사도행전 4:30","category":"$undefined"},{"id":"27054","book":"사도행전","book_name":"사도행전","chapter":4,"verse":31,"text":"빌기를 다하매 모인 곳이 진동하더니 무리가 다 성령이 충만하여 담대히 하나님의 말씀을 전하니라","reference":"사도행전 4:31","category":"$undefined"},{"id":"27055","book":"사도행전","book_name":"사도행전","chapter":4,"verse":32,"text":"믿는 무리가 한 마음과 한 뜻이 되어 모든 물건을 서로 통용하고 제 재물을 조금이라도 제 것이라 하는 이가 하나도 없더라","reference":"사도행전 4:32","category":"$undefined"},{"id":"27056","book":"사도행전","book_name":"사도행전","chapter":4,"verse":33,"text":"사도들이 큰 권능으로 주 예수의 부활을 증거하니 무리가 큰 은혜를 얻어","reference":"사도행전 4:33","category":"$undefined"},{"id":"27057","book":"사도행전","book_name":"사도행전","chapter":4,"verse":34,"text":"그 중에 핍절한 사람이 없으니 이는 밭과 집 있는 자는 팔아 그 판것의 값을 가져다가","reference":"사도행전 4:34","category":"$undefined"},{"id":"27058","book":"사도행전","book_name":"사도행전","chapter":4,"verse":35,"text":"사도들의 발 앞에 두매 저희가 각 사람의 필요를 따라 나눠 줌이러라","reference":"사도행전 4:35","category":"$undefined"},{"id":"27059","book":"사도행전","book_name":"사도행전","chapter":4,"verse":36,"text":"구브로에서 난 레위족인이 있으니 이름은 요셉이라 사도들이 일컬어 바나바 (번역하면 권위자)라 하니","reference":"사도행전 4:36","category":"$undefined"},{"id":"27060","book":"사도행전","book_name":"사도행전","chapter":4,"verse":37,"text":"그가 밭이 있으매 팔아 값을 가지고 사도들의 발 앞에 두니라","reference":"사도행전 4:37","category":"$undefined"}],"bookSlug":"acts"}]
