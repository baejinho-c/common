2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":5,"verses":[{"id":"27061","book":"사도행전","book_name":"사도행전","chapter":5,"verse":1,"text":"아나니아라 하는 사람이 그 아내 삽비라로 더불어 소유를 팔아","reference":"사도행전 5:1","category":"$undefined"},{"id":"27062","book":"사도행전","book_name":"사도행전","chapter":5,"verse":2,"text":"그 값에서 얼마를 감추매 그 아내도 알더라 얼마를 가져다가 사도들의 발 앞에 두니","reference":"사도행전 5:2","category":"$undefined"},{"id":"27063","book":"사도행전","book_name":"사도행전","chapter":5,"verse":3,"text":"베드로가 가로되 `아나니아야, 어찌하여 사단이 네 마음에 가득하여 네가 성령을 속이고 땅 값 얼마를 감추었느냐 ?","reference":"사도행전 5:3","category":"$undefined"},{"id":"27064","book":"사도행전","book_name":"사도행전","chapter":5,"verse":4,"text":"땅이 그대로 있을 때에는 네 땅이 아니며 판 후에도 네 임의로 할 수가 없더냐 어찌하여 이 일을 네 마음에 두었느냐 ? 사람에게 거짓말 한것이 아니요 하나님께로다'","reference":"사도행전 5:4","category":"$undefined"},{"id":"27065","book":"사도행전","book_name":"사도행전","chapter":5,"verse":5,"text":"아나니아가 이 말을 듣고 엎드러져 혼이 떠나니 이 일을 듣는 사람이 다 크게 두려워하더라","reference":"사도행전 5:5","category":"$undefined"},{"id":"27066","book":"사도행전","book_name":"사도행전","chapter":5,"verse":6,"text":"젊은 사람들이 일어나 시신을 싸서 메고 나가 장사하니라","reference":"사도행전 5:6","category":"$undefined"},{"id":"27067","book":"사도행전","book_name":"사도행전","chapter":5,"verse":7,"text":"세 시간쯤 지나 그 아내가 그 생긴 일을 알지 못하고 들어오니","reference":"사도행전 5:7","category":"$undefined"},{"id":"27068","book":"사도행전","book_name":"사도행전","chapter":5,"verse":8,"text":"베드로가 가로되 `그 땅 판 값이 이것뿐이냐 ? 내게 말하라' 하니 가로되 `예, 이뿐이로라'","reference":"사도행전 5:8","category":"$undefined"},{"id":"27069","book":"사도행전","book_name":"사도행전","chapter":5,"verse":9,"text":"베드로가 가로되 `너희가 어찌 함께 꾀하여 주의 영을 시험하려 하느냐 ? 보라, 네 남편을 장사하고 오는 사람들의 발이 문앞에 이르렀으니 또 너를 메어 내가리라' 한대","reference":"사도행전 5:9","category":"$undefined"},{"id":"27070","book":"사도행전","book_name":"사도행전","chapter":5,"verse":10,"text":"곧 베드로의 발 앞에 엎드러져 혼이 떠나는지라 젊은 사람들이 들어와 죽은 것을 보고 메어다가 그 남편곁에 장사하니","reference":"사도행전 5:10","category":"$undefined"},{"id":"27071","book":"사도행전","book_name":"사도행전","chapter":5,"verse":11,"text":"온 교회와 이 일을 듣는 사람들이 다 크게 두려워하니라","reference":"사도행전 5:11","category":"$undefined"},{"id":"27072","book":"사도행전","book_name":"사도행전","chapter":5,"verse":12,"text":"사도들의 손으로 민간에 표적과 기사가 많이 되매 믿는 사람이 다 마음을 같이하여 솔로몬 행각에 모이고","reference":"사도행전 5:12","category":"$undefined"},{"id":"27073","book":"사도행전","book_name":"사도행전","chapter":5,"verse":13,"text":"그 나머지는 감히 그들과 상종하는 사람이 없으나 백성이 칭송하더라","reference":"사도행전 5:13","category":"$undefined"},{"id":"27074","book":"사도행전","book_name":"사도행전","chapter":5,"verse":14,"text":"믿고 주께로 나오는 자가 더 많으니 남녀의 큰 무리더라","reference":"사도행전 5:14","category":"$undefined"},{"id":"27075","book":"사도행전","book_name":"사도행전","chapter":5,"verse":15,"text":"심지어 병든 사람을 메고 거리에 나가 침대와 요 위에 뉘우고 베드로가 지날 때에 혹 그 그림자라도 뉘게 덮일까 바라고","reference":"사도행전 5:15","category":"$undefined"},{"id":"27076","book":"사도행전","book_name":"사도행전","chapter":5,"verse":16,"text":"예루살렘 근읍 허다한 사람들도 모여 병든 사람과 더러운 귀신에게 괴로움 받는 사람을 데리고 와서 다 나음을 얻으니라","reference":"사도행전 5:16","category":"$undefined"},{"id":"27077","book":"사도행전","book_name":"사도행전","chapter":5,"verse":17,"text":"대제사장과 그와 함께 있는 사람 즉 사두개인의 당파가 다 마음에 시기가 가득하여 일어나서","reference":"사도행전 5:17","category":"$undefined"},{"id":"27078","book":"사도행전","book_name":"사도행전","chapter":5,"verse":18,"text":"사도들을 잡아다가 옥에 가두었더니","reference":"사도행전 5:18","category":"$undefined"},{"id":"27079","book":"사도행전","book_name":"사도행전","chapter":5,"verse":19,"text":"주의 사자가 밤에 옥문을 열고 끌어내어 가로되","reference":"사도행전 5:19","category":"$undefined"},{"id":"27080","book":"사도행전","book_name":"사도행전","chapter":5,"verse":20,"text":"`가서 성전에 서서 이 생명의 말씀을 다 백성에게 말하라' 하매","reference":"사도행전 5:20","category":"$undefined"},{"id":"27081","book":"사도행전","book_name":"사도행전","chapter":5,"verse":21,"text":"저희가 듣고 새벽에 성전에 들어가서 가르치더니 대제사장과 그와 함께 있는 사람들이 와서 공회와 이스라엘 족속의 원로들을 다 모으고 사람을 옥에 보내어 사도들을 잡아오라 하니","reference":"사도행전 5:21","category":"$undefined"},{"id":"27082","book":"사도행전","book_name":"사도행전","chapter":5,"verse":22,"text":"관속들이 가서 옥에서 사도들을 보지 못하고 돌아와 말하여","reference":"사도행전 5:22","category":"$undefined"},{"id":"27083","book":"사도행전","book_name":"사도행전","chapter":5,"verse":23,"text":"가로되 `우리가 보니 옥은 든든하게 잠기고 지킨 사람들이 문에 섰으되 문을 열고 본즉 그 안에는 한 사람도 없더이다' 하니","reference":"사도행전 5:23","category":"$undefined"},{"id":"27084","book":"사도행전","book_name":"사도행전","chapter":5,"verse":24,"text":"성전 맡은 자와 제사장들이 이 말을 듣고 의혹하여 이 일이 어찌 될까 하더니","reference":"사도행전 5:24","category":"$undefined"},{"id":"27085","book":"사도행전","book_name":"사도행전","chapter":5,"verse":25,"text":"사람이 와서 고하되 `보소서, 옥에 가두었던 사람들이 성전에 서서 백성을 가르치더이다' 하니","reference":"사도행전 5:25","category":"$undefined"},{"id":"27086","book":"사도행전","book_name":"사도행전","chapter":5,"verse":26,"text":"성전 맡은 자가 관속들과 같이 서서 저희를 잡아 왔으나 강제로 못함은 백성들이 돌로 칠까 두려워 함이러라","reference":"사도행전 5:26","category":"$undefined"},{"id":"27087","book":"사도행전","book_name":"사도행전","chapter":5,"verse":27,"text":"저희를 끌어다가 공회 앞에 세우니 대제사장이 물어","reference":"사도행전 5:27","category":"$undefined"},{"id":"27088","book":"사도행전","book_name":"사도행전","chapter":5,"verse":28,"text":"가로되 `우리가 이 이름으로 사람을 가르치지 말라고 엄금하였으되 너희가 너희 교(敎)를 예루살렘에 가득하게 하니 이 사람의 피를 우리에게로 돌리고자 함이로다'","reference":"사도행전 5:28","category":"$undefined"},{"id":"27089","book":"사도행전","book_name":"사도행전","chapter":5,"verse":29,"text":"베드로와 사도들이 대답하여 가로되 `사람보다 하나님을 순종하는 것이 마땅하니라","reference":"사도행전 5:29","category":"$undefined"},{"id":"27090","book":"사도행전","book_name":"사도행전","chapter":5,"verse":30,"text":"너희가 나무에 달아 죽인 예수를 우리 조상의 하나님이 살리시고","reference":"사도행전 5:30","category":"$undefined"},{"id":"27091","book":"사도행전","book_name":"사도행전","chapter":5,"verse":31,"text":"이스라엘로 회개케 하사 죄사함을 얻게 하시려고 그를 오른손으로 높이사 임금과 구주를 삼으셨느니라","reference":"사도행전 5:31","category":"$undefined"},{"id":"27092","book":"사도행전","book_name":"사도행전","chapter":5,"verse":32,"text":"우리는 이 일에 증인이요 하나님이 자기를 순종하는 사람들에게 주신 성령도 그러하니라' 하더라","reference":"사도행전 5:32","category":"$undefined"},{"id":"27093","book":"사도행전","book_name":"사도행전","chapter":5,"verse":33,"text":"저희가 듣고 크게 노하여 사도들을 없이하고자 할새","reference":"사도행전 5:33","category":"$undefined"},{"id":"27094","book":"사도행전","book_name":"사도행전","chapter":5,"verse":34,"text":"바리새인 가말리엘은 교법사로 모든 백성에게 존경을 받는 자라 공회 중에 일어나 명하사 사도들을 잠간 밖에 나가게 하고","reference":"사도행전 5:34","category":"$undefined"},{"id":"27095","book":"사도행전","book_name":"사도행전","chapter":5,"verse":35,"text":"말하되 `이스라엘 사람들아, 너희가 이 사람들에게 대하여 어떻게 하려는 것을 조심하라","reference":"사도행전 5:35","category":"$undefined"},{"id":"27096","book":"사도행전","book_name":"사도행전","chapter":5,"verse":36,"text":"이전에 드다가 일어나 스스로 자랑하매 사람이 약 사백이나 따르더니 그가 죽임을 당하매 좇던 사람이 다 흩어져 없어졌고","reference":"사도행전 5:36","category":"$undefined"},{"id":"27097","book":"사도행전","book_name":"사도행전","chapter":5,"verse":37,"text":"그 후 호적할 때에 갈릴리 유다가 일어나 백성을 꾀어 좇게 하다가 그도 망한즉 좇던 사람이 다 흩어졌느니라","reference":"사도행전 5:37","category":"$undefined"},{"id":"27098","book":"사도행전","book_name":"사도행전","chapter":5,"verse":38,"text":"이제 내가 너희에게 말하노니 이 사람들을 상관 말고 버려두라 이 사상과 소행이 사람에게로서 났으면 무너질 것이요","reference":"사도행전 5:38","category":"$undefined"},{"id":"27099","book":"사도행전","book_name":"사도행전","chapter":5,"verse":39,"text":"만일 하나님께로서 났으면 너희가 저희를 무너뜨릴 수 없겠고 도리어 하나님을 대적하는 자가 될까 하노라' 하니","reference":"사도행전 5:39","category":"$undefined"},{"id":"27100","book":"사도행전","book_name":"사도행전","chapter":5,"verse":40,"text":"저희가 옳게 여겨 사도들을 불러들여 채찍질하며 예수의 이름으로 말하는 것을 금하고 놓으니","reference":"사도행전 5:40","category":"$undefined"},{"id":"27101","book":"사도행전","book_name":"사도행전","chapter":5,"verse":41,"text":"사도들은 그 이름을 위하여 능욕 받는 일에 합당한 자로 여기심을 기뻐하면서 공회 앞을 떠나니라","reference":"사도행전 5:41","category":"$undefined"},{"id":"27102","book":"사도행전","book_name":"사도행전","chapter":5,"verse":42,"text":"저희가 날마다 성전에 있든지 집에 있든지 예수는 그리스도라 가르치기와 전도하기를 쉬지 아니하니라","reference":"사도행전 5:42","category":"$undefined"}],"bookSlug":"acts"}]
