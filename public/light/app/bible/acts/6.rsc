2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":6,"verses":[{"id":"27103","book":"사도행전","book_name":"사도행전","chapter":6,"verse":1,"text":"그때에 제자가 더 많아졌는데 헬라파 유대인들이 자기의 과부들이 그 매일 구제에 빠지므로 히브리파 사람을 원망한대","reference":"사도행전 6:1","category":"$undefined"},{"id":"27104","book":"사도행전","book_name":"사도행전","chapter":6,"verse":2,"text":"열 두 사도가 모든 제자를 불러 이르되 `우리가 하나님의 말씀을 제쳐놓고 공궤를 일삼는 것이 마땅치 아니하니","reference":"사도행전 6:2","category":"$undefined"},{"id":"27105","book":"사도행전","book_name":"사도행전","chapter":6,"verse":3,"text":"형제들아 너희 가운데서 성령과 지혜가 충만하여 칭찬 듣는 사람 일곱을 택하라 우리가 이 일을 저희에게 맡기고","reference":"사도행전 6:3","category":"$undefined"},{"id":"27106","book":"사도행전","book_name":"사도행전","chapter":6,"verse":4,"text":"우리는 기도하는 것과 말씀 전하는 것을 전무하리라' 하니","reference":"사도행전 6:4","category":"$undefined"},{"id":"27107","book":"사도행전","book_name":"사도행전","chapter":6,"verse":5,"text":"온 무리가 이 말을 기뻐하여 믿음과 성령이 충만한 사람 스데반과, 또 빌립과, 브로고로와, 니가노르와, 디몬과, 바메나와, 유대교에 입교한 안디옥 사람 니골라를 택하여","reference":"사도행전 6:5","category":"$undefined"},{"id":"27108","book":"사도행전","book_name":"사도행전","chapter":6,"verse":6,"text":"사도들 앞에 세우니 사도들이 기도하고 그들에게 안수하니라","reference":"사도행전 6:6","category":"$undefined"},{"id":"27109","book":"사도행전","book_name":"사도행전","chapter":6,"verse":7,"text":"하나님의 말씀이 점점 왕성하여 예루살렘에 있는 제자의 수가 더 심히 많아지고 허다한 제사장의 무리도 이 도에 복종하니라","reference":"사도행전 6:7","category":"$undefined"},{"id":"27110","book":"사도행전","book_name":"사도행전","chapter":6,"verse":8,"text":"스데반이 은혜와 권능이 충만하여 큰 기사와 표적을 민간에 행하니","reference":"사도행전 6:8","category":"$undefined"},{"id":"27111","book":"사도행전","book_name":"사도행전","chapter":6,"verse":9,"text":"리버디노, 구레네인, 알렉산드리아인, 길리기아와 아시아에서 온 사람들의 회당이라는 각 회당에서 어떤 자들이 일어나 스데반으로 더불어 변론할새","reference":"사도행전 6:9","category":"$undefined"},{"id":"27112","book":"사도행전","book_name":"사도행전","chapter":6,"verse":10,"text":"스데반이 지혜와 성령으로 말함을 저희가 능히 당치 못하여","reference":"사도행전 6:10","category":"$undefined"},{"id":"27113","book":"사도행전","book_name":"사도행전","chapter":6,"verse":11,"text":"사람들을 가르쳐 말시키되 이 사람이 모세와 및 하나님을 모독하는 말하는 것을 우리가 들었노라 하게 하고","reference":"사도행전 6:11","category":"$undefined"},{"id":"27114","book":"사도행전","book_name":"사도행전","chapter":6,"verse":12,"text":"백성과 장로와 서기관들을 충동시켜 와서 잡아 가지고 공회에 이르러","reference":"사도행전 6:12","category":"$undefined"},{"id":"27115","book":"사도행전","book_name":"사도행전","chapter":6,"verse":13,"text":"거짓 증인들을 세우니 가로되 `이 사람이 이 거룩한 곳과 율법을 거스려 말하기를 마지 아니하는도다","reference":"사도행전 6:13","category":"$undefined"},{"id":"27116","book":"사도행전","book_name":"사도행전","chapter":6,"verse":14,"text":"그의 말에 이 나사렛 예수가 이 곳을 헐고 또 모세가 우리에게 전하여 준 규례를 고치겠다 함을 우리가 들었노라' 하거늘","reference":"사도행전 6:14","category":"$undefined"},{"id":"27117","book":"사도행전","book_name":"사도행전","chapter":6,"verse":15,"text":"공회 중에 앉은 사람들이 다 스데반을 주목하여 보니 그 얼굴이 천사의 얼굴과 같더라","reference":"사도행전 6:15","category":"$undefined"}],"bookSlug":"acts"}]
