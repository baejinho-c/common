2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":7,"verses":[{"id":"27118","book":"사도행전","book_name":"사도행전","chapter":7,"verse":1,"text":"대제사장이 가로되 `이것이 사실이냐 ?'","reference":"사도행전 7:1","category":"$undefined"},{"id":"27119","book":"사도행전","book_name":"사도행전","chapter":7,"verse":2,"text":"스데반이 가로되 `여러분 부형들이여, 들으소서 우리 조상 아브라함이 하란에 있기 전 메소보다미아에 있을 때에 영광의 하나님이 그에게 보여","reference":"사도행전 7:2","category":"$undefined"},{"id":"27120","book":"사도행전","book_name":"사도행전","chapter":7,"verse":3,"text":"가라사대 네 고향과 친척을 떠나 내가 네게 보일 땅으로 가라 하시니","reference":"사도행전 7:3","category":"$undefined"},{"id":"27121","book":"사도행전","book_name":"사도행전","chapter":7,"verse":4,"text":"아브라함이 갈대아 사람의 땅을 떠나 하란에 거하다가 그 아비가 죽으매 하나님이 그를 거기서 너희 시방 거하는 이 땅으로 옮기셨느니라","reference":"사도행전 7:4","category":"$undefined"},{"id":"27122","book":"사도행전","book_name":"사도행전","chapter":7,"verse":5,"text":"그러나 여기서 발 붙일 만큼도 유업을 주지 아니하시고 다만 이 땅을 아직 자식도 없는 저와 저의 씨에게 소유로 주신다고 약속하셨으며","reference":"사도행전 7:5","category":"$undefined"},{"id":"27123","book":"사도행전","book_name":"사도행전","chapter":7,"verse":6,"text":"하나님이 또 이같이 말씀하시되 그 씨가 다른 땅에 나그네 되리니 그 땅 사람이 종을 삼아 사백 년 동안을 괴롭게 하리라 하시고","reference":"사도행전 7:6","category":"$undefined"},{"id":"27124","book":"사도행전","book_name":"사도행전","chapter":7,"verse":7,"text":"또 가라사대 종 삼는 나라를 내가 심판하리니 그 후에 저희가 나와서 이곳에서 나를 섬기리라 하시고","reference":"사도행전 7:7","category":"$undefined"},{"id":"27125","book":"사도행전","book_name":"사도행전","chapter":7,"verse":8,"text":"할례의 언약을 아브라함에게 주셨더니 그가 이삭을 낳아 여드레만에 할례를 행하고 이삭이 야곱을,야곱이 우리 열 두 조상을 낳으니","reference":"사도행전 7:8","category":"$undefined"},{"id":"27126","book":"사도행전","book_name":"사도행전","chapter":7,"verse":9,"text":"여러 조상이 요셉을 시기하여 애굽에 팔았더니 하나님이 저와 함께 계셔","reference":"사도행전 7:9","category":"$undefined"},{"id":"27127","book":"사도행전","book_name":"사도행전","chapter":7,"verse":10,"text":"그 모든 환난에서 건져내사 애굽 왕 바로앞에서 은총과 지혜를 주시매 바로가 저를 애굽과 자기 온 집의 치리자로 세웠느니라","reference":"사도행전 7:10","category":"$undefined"},{"id":"27128","book":"사도행전","book_name":"사도행전","chapter":7,"verse":11,"text":"그 때에 애굽과 가나안 온 땅에 흉년 들어 큰 환난이 있을새 우리 조상들이 양식이 없는지라","reference":"사도행전 7:11","category":"$undefined"},{"id":"27129","book":"사도행전","book_name":"사도행전","chapter":7,"verse":12,"text":"야곱이 애굽에 곡식 있다는 말을 듣고 먼저 우리 조상들을 보내고","reference":"사도행전 7:12","category":"$undefined"},{"id":"27130","book":"사도행전","book_name":"사도행전","chapter":7,"verse":13,"text":"또 재차 보내매 요셉이 자기 형제들에게 알게 되고 또 요셉의 친족이 바로에게 드러나게 되니라","reference":"사도행전 7:13","category":"$undefined"},{"id":"27131","book":"사도행전","book_name":"사도행전","chapter":7,"verse":14,"text":"요셉이 보내어 그 부친 야곱과 온 친족 일흔 다섯 사람을 청하였더니","reference":"사도행전 7:14","category":"$undefined"},{"id":"27132","book":"사도행전","book_name":"사도행전","chapter":7,"verse":15,"text":"야곱이 애굽으로 내려가 자기와 우리 조상들이 거기서 죽고","reference":"사도행전 7:15","category":"$undefined"},{"id":"27133","book":"사도행전","book_name":"사도행전","chapter":7,"verse":16,"text":"세겜으로 옮기워 아브라함이 세겜 하몰의 자손에게서 은으로 값주고 산 무덤에 장사되니라","reference":"사도행전 7:16","category":"$undefined"},{"id":"27134","book":"사도행전","book_name":"사도행전","chapter":7,"verse":17,"text":"하나님이 아브라함에게 약속하신 때가 가까우매 이스라엘 백성이 애굽에서 번성하여 많아졌더니","reference":"사도행전 7:17","category":"$undefined"},{"id":"27135","book":"사도행전","book_name":"사도행전","chapter":7,"verse":18,"text":"요셉을 알지 못하는 새 임금이 애굽 왕위에 오르매","reference":"사도행전 7:18","category":"$undefined"},{"id":"27136","book":"사도행전","book_name":"사도행전","chapter":7,"verse":19,"text":"그가 우리 족속에게 궤계를 써서 조상들을 괴롭게 하여 그 어린 아이들을 내어버려 살지 못하게 하려 할새","reference":"사도행전 7:19","category":"$undefined"},{"id":"27137","book":"사도행전","book_name":"사도행전","chapter":7,"verse":20,"text":"그 때에 모세가 났는데 하나님 보시기에 아름다운지라 그 부친의 집에서 석 달을 길리우더니","reference":"사도행전 7:20","category":"$undefined"},{"id":"27138","book":"사도행전","book_name":"사도행전","chapter":7,"verse":21,"text":"버리운 후에 바로의 딸이 가져다가 자기 아들로 기르매","reference":"사도행전 7:21","category":"$undefined"},{"id":"27139","book":"사도행전","book_name":"사도행전","chapter":7,"verse":22,"text":"모세가 애굽 사람의 학술을 다 배워 그 말과 행사가 능하더라","reference":"사도행전 7:22","category":"$undefined"},{"id":"27140","book":"사도행전","book_name":"사도행전","chapter":7,"verse":23,"text":"나이 사십이 되매 그 형제 이스라엘 자손을 돌아볼 생각이 나더니","reference":"사도행전 7:23","category":"$undefined"},{"id":"27141","book":"사도행전","book_name":"사도행전","chapter":7,"verse":24,"text":"한 사람의 원통한 일 당함을 보고 보호하여 압제 받는 자를 위하여 원수를 갚아 애굽 사람을 쳐 죽이니라","reference":"사도행전 7:24","category":"$undefined"},{"id":"27142","book":"사도행전","book_name":"사도행전","chapter":7,"verse":25,"text":"저는 그 형제들이 하나님께서 자기의 손을 빌어 구원하여 주시는 것을 깨달으리라고 생각하였으나 저희가 깨닫지 못하였더라","reference":"사도행전 7:25","category":"$undefined"},{"id":"27143","book":"사도행전","book_name":"사도행전","chapter":7,"verse":26,"text":"이튿날 이스라엘 사람이 싸울 때에 모세가 와서 화목시키려 하여 가로되 너희는 형제라 어찌 서로 해하느냐 하니","reference":"사도행전 7:26","category":"$undefined"},{"id":"27144","book":"사도행전","book_name":"사도행전","chapter":7,"verse":27,"text":"그 동무를 해하는 사람이 모세를 밀뜨려 가로되 누가 너를 관원과 재판장으로 우리 위에 세웠느냐","reference":"사도행전 7:27","category":"$undefined"},{"id":"27145","book":"사도행전","book_name":"사도행전","chapter":7,"verse":28,"text":"네가 어제 애굽 사람을 죽임과 같이 또 나를 죽이려느냐 ? 하니","reference":"사도행전 7:28","category":"$undefined"},{"id":"27146","book":"사도행전","book_name":"사도행전","chapter":7,"verse":29,"text":"모세가 이 말을 인하여 도주하여 미디안 땅에서 나그네 되어 거기서 아들 둘을 낳으니라","reference":"사도행전 7:29","category":"$undefined"},{"id":"27147","book":"사도행전","book_name":"사도행전","chapter":7,"verse":30,"text":"사십 년이 차매 천사가 시내 산 광야 가시나무 떨기 불꽃 가운데서 그에게 보이거늘","reference":"사도행전 7:30","category":"$undefined"},{"id":"27148","book":"사도행전","book_name":"사도행전","chapter":7,"verse":31,"text":"모세가 이 광경을 보고 기이히 여겨 알아보려고 가까이 가니 주의 소리 있어","reference":"사도행전 7:31","category":"$undefined"},{"id":"27149","book":"사도행전","book_name":"사도행전","chapter":7,"verse":32,"text":"나는 네 조상의 하나님 즉 아브라함과 이삭과 야곱의 하나님이로라 하신대 모세가 무서워 감히 알아 보지 못하더라","reference":"사도행전 7:32","category":"$undefined"},{"id":"27150","book":"사도행전","book_name":"사도행전","chapter":7,"verse":33,"text":"주께서 가라사대 네 발에 신을 벗으라 ! 너 섰는 곳은 거룩한 땅이니라","reference":"사도행전 7:33","category":"$undefined"},{"id":"27151","book":"사도행전","book_name":"사도행전","chapter":7,"verse":34,"text":"내 백성이 애굽에서 괴로움 받음을 내가 정녕히 보고 그 탄식하는 소리를 듣고 저희를 구원하려고 내려 왔노니 시방 내가 너를 애굽으로 보내리라 하시니라","reference":"사도행전 7:34","category":"$undefined"},{"id":"27152","book":"사도행전","book_name":"사도행전","chapter":7,"verse":35,"text":"저희 말이 누가 너를 관원과 재판장으로 세웠느냐 하며 거절하던 그 모세를 하나님은 가시나무 떨기 가운데서 보이던 천사의 손을 의탁하여 관원과 속량하는 자로 보내셨으니","reference":"사도행전 7:35","category":"$undefined"},{"id":"27153","book":"사도행전","book_name":"사도행전","chapter":7,"verse":36,"text":"이 사람이 백성을 인도하여 나오게 하고 애굽과 홍해와 광야에서 사십 년간 기사와 표적을 행하였느니라","reference":"사도행전 7:36","category":"$undefined"},{"id":"27154","book":"사도행전","book_name":"사도행전","chapter":7,"verse":37,"text":"이스라엘 자손을 대하여 하나님이 너희 형제 가운데서 나와 같은 선지자를 세우리라 하던 자가 곧 이 모세라","reference":"사도행전 7:37","category":"$undefined"},{"id":"27155","book":"사도행전","book_name":"사도행전","chapter":7,"verse":38,"text":"시내산에서 말하던 그 천사와 및 우리 조상들과 함께 광야 교회에 있었고 또 생명의 도를 받아 우리에게 주던 자가 이 사람이라","reference":"사도행전 7:38","category":"$undefined"},{"id":"27156","book":"사도행전","book_name":"사도행전","chapter":7,"verse":39,"text":"우리 조상들이 모세에게 복종치 아니하고자 하여 거절하며 그 마음이 도리어 애굽으로 행하여","reference":"사도행전 7:39","category":"$undefined"},{"id":"27157","book":"사도행전","book_name":"사도행전","chapter":7,"verse":40,"text":"아론더러 이르되 우리를 인도할 신들을 우리를 위하여 만들라 애굽 땅에서 우리를 인도하던 이 모세는 어떻게 되었는지 알지 못하노라 하고","reference":"사도행전 7:40","category":"$undefined"},{"id":"27158","book":"사도행전","book_name":"사도행전","chapter":7,"verse":41,"text":"그 때에 저희가 송아지를 만들어 그 우상 앞에 제사하며 자기 손으로 만든 것을 기뻐하더니","reference":"사도행전 7:41","category":"$undefined"},{"id":"27159","book":"사도행전","book_name":"사도행전","chapter":7,"verse":42,"text":"하나님이 돌이키사 저희를 그 하늘의 군대 섬기는 일에 버려 두셨으니 이는 선지자의 책에 기록된 바 이스라엘의 집이여 사십년을 광야에서 너희가 희생과 제물을 내게 드린 일이 있었느냐","reference":"사도행전 7:42","category":"$undefined"},{"id":"27160","book":"사도행전","book_name":"사도행전","chapter":7,"verse":43,"text":"몰록의 장막과 신(神) 레판의 별을 받들었음이여 이것은 너희가 절하고자 하여 만든 형상이로다 내가 너희를 바벨론 밖에 옮기리라함과 같으니라","reference":"사도행전 7:43","category":"$undefined"},{"id":"27161","book":"사도행전","book_name":"사도행전","chapter":7,"verse":44,"text":"광야에서 우리 조상들에게 증거의 장막이 있었으니 이것은 모세에게 말씀하신 이가 명하사 저가 본 그식대로 만들게 하신 것이라","reference":"사도행전 7:44","category":"$undefined"},{"id":"27162","book":"사도행전","book_name":"사도행전","chapter":7,"verse":45,"text":"우리 조상들이 그것을 받아 하나님이 저희 앞에서 쫓아내신 이방인의 땅을 점령할 때에 여호수아와 함께 가지고 들어가사 다윗 때까지 이르니라","reference":"사도행전 7:45","category":"$undefined"},{"id":"27163","book":"사도행전","book_name":"사도행전","chapter":7,"verse":46,"text":"다윗이 하나님 앞에서 은혜를 받아 야곱의 집을 위하여 하나님의 처소를 준비케 하여 달라 하더니","reference":"사도행전 7:46","category":"$undefined"},{"id":"27164","book":"사도행전","book_name":"사도행전","chapter":7,"verse":47,"text":"솔로몬이 그를 위하여 집을 지었느니라","reference":"사도행전 7:47","category":"$undefined"},{"id":"27165","book":"사도행전","book_name":"사도행전","chapter":7,"verse":48,"text":"그러나 지극히 높으신 이는 손으로 지은 곳에 계시지 아니하시나니 선지자의 말한 바","reference":"사도행전 7:48","category":"$undefined"},{"id":"27166","book":"사도행전","book_name":"사도행전","chapter":7,"verse":49,"text":"주께서 가라사대 하늘은 나의 보좌요 땅은 나의 발등상이니 너희가 나를 위하여 무슨 집을 짓겠으며 나의 안식할 처소가 어디뇨","reference":"사도행전 7:49","category":"$undefined"},{"id":"27167","book":"사도행전","book_name":"사도행전","chapter":7,"verse":50,"text":"이 모든 것이 다 내 손으로 지은 것이 아니냐 함과 같으니라","reference":"사도행전 7:50","category":"$undefined"},{"id":"27168","book":"사도행전","book_name":"사도행전","chapter":7,"verse":51,"text":"목이 곧고 마음과 귀에 할례를 받지 못한 사람들아 ! 너희가 항상 성령을 거스려 너희 조상과 같이 너희도 하는도다","reference":"사도행전 7:51","category":"$undefined"},{"id":"27169","book":"사도행전","book_name":"사도행전","chapter":7,"verse":52,"text":"너희 조상들은 선지자 중에 누구를 핍박지 아니하였느냐 ? 의인이 오시리라 예고한 자들을 저희가 죽였고 이제 너희는 그 의인을 잡아준 자요 살인한 자가 되나니","reference":"사도행전 7:52","category":"$undefined"},{"id":"27170","book":"사도행전","book_name":"사도행전","chapter":7,"verse":53,"text":"너희가 천사의 전한 율법을 받고도 지키지 아니하였도다' 하니라","reference":"사도행전 7:53","category":"$undefined"},{"id":"27171","book":"사도행전","book_name":"사도행전","chapter":7,"verse":54,"text":"저희가 이 말을 듣고 마음에 찔려 저를 향하여 이를 갈거늘","reference":"사도행전 7:54","category":"$undefined"},{"id":"27172","book":"사도행전","book_name":"사도행전","chapter":7,"verse":55,"text":"스데반이 성령이 충만하여 하늘을 우러러 주목하여 하나님의 영광과 및 예수께서 하나님 우편에 서신 것을 보고","reference":"사도행전 7:55","category":"$undefined"},{"id":"27173","book":"사도행전","book_name":"사도행전","chapter":7,"verse":56,"text":"말하되 `보라, 하늘이 열리고 인자가 하나님 우편에 서신 것을 보노라' 한대","reference":"사도행전 7:56","category":"$undefined"},{"id":"27174","book":"사도행전","book_name":"사도행전","chapter":7,"verse":57,"text":"저희가 큰 소리를 지르며 귀를 막고 일심으로 그에게 달려들어","reference":"사도행전 7:57","category":"$undefined"},{"id":"27175","book":"사도행전","book_name":"사도행전","chapter":7,"verse":58,"text":"성 밖에 내치고 돌로 칠새 증인들이 옷을 벗어 사울이라 하는 청년의 발 앞에 두니라","reference":"사도행전 7:58","category":"$undefined"},{"id":"27176","book":"사도행전","book_name":"사도행전","chapter":7,"verse":59,"text":"저희가 돌로 스데반을 치니 스데반이 부르짖어 가로되 `주 예수여, 내 영혼을 받으시옵소서' 하고","reference":"사도행전 7:59","category":"$undefined"},{"id":"27177","book":"사도행전","book_name":"사도행전","chapter":7,"verse":60,"text":"무릎을 꿇고 크게 불러 가로되 `주여, 이 죄를 저들에게 돌리지 마옵소서' 이 말을 하고 자니라","reference":"사도행전 7:60","category":"$undefined"}],"bookSlug":"acts"}]
