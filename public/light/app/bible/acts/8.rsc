2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":8,"verses":[{"id":"27178","book":"사도행전","book_name":"사도행전","chapter":8,"verse":1,"text":"사울이 그의 죽임 당함을 마땅히 여기더라 그 날에 예루살렘에 있는 교회에 큰 핍박이 나서 사도 외에는 다 유대와 사마리아 모든 땅으로 흩어지니라","reference":"사도행전 8:1","category":"$undefined"},{"id":"27179","book":"사도행전","book_name":"사도행전","chapter":8,"verse":2,"text":"경건한 사람들이 스데반을 장사하고 위하여 크게 울더라","reference":"사도행전 8:2","category":"$undefined"},{"id":"27180","book":"사도행전","book_name":"사도행전","chapter":8,"verse":3,"text":"사울이 교회를 잔멸할새 각 집에 들어가 남녀를 끌어다가 옥에 넘기니라","reference":"사도행전 8:3","category":"$undefined"},{"id":"27181","book":"사도행전","book_name":"사도행전","chapter":8,"verse":4,"text":"그 흩어진 사람들이 두루 다니며 복음의 말씀을 전할새","reference":"사도행전 8:4","category":"$undefined"},{"id":"27182","book":"사도행전","book_name":"사도행전","chapter":8,"verse":5,"text":"빌립이 사마리아 성에 내려가 그리스도를 백성에게 전파하니","reference":"사도행전 8:5","category":"$undefined"},{"id":"27183","book":"사도행전","book_name":"사도행전","chapter":8,"verse":6,"text":"무리가 빌립의 말도 듣고 행하는 표적도 보고 일심으로 그의 말하는 것을 좇더라","reference":"사도행전 8:6","category":"$undefined"},{"id":"27184","book":"사도행전","book_name":"사도행전","chapter":8,"verse":7,"text":"많은 사람에게 붙었던 더러운 귀신들이 크게 소리를 지르며 나가고 또 많은 중풍병자와 앉은뱅이가 나으니","reference":"사도행전 8:7","category":"$undefined"},{"id":"27185","book":"사도행전","book_name":"사도행전","chapter":8,"verse":8,"text":"그 성에 큰 기쁨이 있더라","reference":"사도행전 8:8","category":"$undefined"},{"id":"27186","book":"사도행전","book_name":"사도행전","chapter":8,"verse":9,"text":"그 성에 시몬이라 하는 사람이 전부터 있어 마술을 행하여 사마리아 백성을 놀라게 하며 자칭 큰 자라 하니","reference":"사도행전 8:9","category":"$undefined"},{"id":"27187","book":"사도행전","book_name":"사도행전","chapter":8,"verse":10,"text":"낮은 사람부터 높은 사람까지 다 청종하여 가로되 `이 사람은 크다 일컫는 하나님의 능력이라' 하더라","reference":"사도행전 8:10","category":"$undefined"},{"id":"27188","book":"사도행전","book_name":"사도행전","chapter":8,"verse":11,"text":"오래 동안 그 마술에 놀랐으므로 저희가 청종하더니","reference":"사도행전 8:11","category":"$undefined"},{"id":"27189","book":"사도행전","book_name":"사도행전","chapter":8,"verse":12,"text":"빌립이 하나님 나라와 및 예수 그리스도의 이름에 관하여 전도함을 저희가 믿고 남녀가 다 세례를 받으니","reference":"사도행전 8:12","category":"$undefined"},{"id":"27190","book":"사도행전","book_name":"사도행전","chapter":8,"verse":13,"text":"시몬도 믿고 세례를 받은 후에 전심으로 빌립을 따라 다니며 그 나타나는 표적과 큰 능력을 보고 놀라니라","reference":"사도행전 8:13","category":"$undefined"},{"id":"27191","book":"사도행전","book_name":"사도행전","chapter":8,"verse":14,"text":"예루살렘에 있는 사도들이 사마리아도 하나님의 말씀을 받았다 함을 듣고 베드로와 요한을 보내매","reference":"사도행전 8:14","category":"$undefined"},{"id":"27192","book":"사도행전","book_name":"사도행전","chapter":8,"verse":15,"text":"그들이 내려가서 저희를 위하여 성령 받기를 기도하니","reference":"사도행전 8:15","category":"$undefined"},{"id":"27193","book":"사도행전","book_name":"사도행전","chapter":8,"verse":16,"text":"이는 아직 한 사람에게도 성령 내리신 일이 없고 오직 주 예수의 이름으로 세례만 받을 뿐이러라","reference":"사도행전 8:16","category":"$undefined"},{"id":"27194","book":"사도행전","book_name":"사도행전","chapter":8,"verse":17,"text":"이에 두 사도가 저희에게 안수하매 성령을 받는지라","reference":"사도행전 8:17","category":"$undefined"},{"id":"27195","book":"사도행전","book_name":"사도행전","chapter":8,"verse":18,"text":"시몬이 사도들의 안수함으로 성령 받는 것을 보고 돈을 드려","reference":"사도행전 8:18","category":"$undefined"},{"id":"27196","book":"사도행전","book_name":"사도행전","chapter":8,"verse":19,"text":"가로되 `이 권능을 내게도 주어 누구든지 내가 안수하는 사람은 성령을 받게 하여 주소서' 하니","reference":"사도행전 8:19","category":"$undefined"},{"id":"27197","book":"사도행전","book_name":"사도행전","chapter":8,"verse":20,"text":"베드로가 가로되 `네가 하나님의 선물을 돈 주고 살 줄로 생각하였으니 네 은과 네가 함께 망할지어다","reference":"사도행전 8:20","category":"$undefined"},{"id":"27198","book":"사도행전","book_name":"사도행전","chapter":8,"verse":21,"text":"하나님 앞에서 네 마음이 바르지 못하니 이 도에는 네가 관계도 없고 분깃 될 것도 없느니라","reference":"사도행전 8:21","category":"$undefined"},{"id":"27199","book":"사도행전","book_name":"사도행전","chapter":8,"verse":22,"text":"그러므로 너의 이 악함을 회개하고 주께 기도하라 혹 마음에 품은 것을 사하여 주시리라","reference":"사도행전 8:22","category":"$undefined"},{"id":"27200","book":"사도행전","book_name":"사도행전","chapter":8,"verse":23,"text":"내가 보니 너는 악독이 가득하며 불의에 매인 바 되었도다'","reference":"사도행전 8:23","category":"$undefined"},{"id":"27201","book":"사도행전","book_name":"사도행전","chapter":8,"verse":24,"text":"시몬이 대답하여 가로되 `나를 위하여 주께 기도하여 말한 것이 하나도 내게 임하지 말게 하소서' 하니라","reference":"사도행전 8:24","category":"$undefined"},{"id":"27202","book":"사도행전","book_name":"사도행전","chapter":8,"verse":25,"text":"두 사도가 주의 말씀을 증거하여 말한 후 예루살렘으로 돌아 갈새 사마리아인의 여러 촌에서 복음을 전하니라","reference":"사도행전 8:25","category":"$undefined"},{"id":"27203","book":"사도행전","book_name":"사도행전","chapter":8,"verse":26,"text":"주의 사자가 빌립더러 일러 가로되 `일어나서 남으로 향하여 예루살렘에서 가사로 내려가는 길까지 가라'하니 그 길은 광야라","reference":"사도행전 8:26","category":"$undefined"},{"id":"27204","book":"사도행전","book_name":"사도행전","chapter":8,"verse":27,"text":"일어나 가서 보니 에디오피아 사람 곧 에디오피아 여왕 간다게의 모든 국고를 맡은 큰 권세가 있는 내시가 예배하러 예루살렘에 왔다가","reference":"사도행전 8:27","category":"$undefined"},{"id":"27205","book":"사도행전","book_name":"사도행전","chapter":8,"verse":28,"text":"돌아가는데 병거를 타고 선지자 이사야의 글을 읽더라","reference":"사도행전 8:28","category":"$undefined"},{"id":"27206","book":"사도행전","book_name":"사도행전","chapter":8,"verse":29,"text":"성령이 빌립더러 이르시되 `이 병거로 가까이 나아가라' 하시거늘","reference":"사도행전 8:29","category":"$undefined"},{"id":"27207","book":"사도행전","book_name":"사도행전","chapter":8,"verse":30,"text":"빌립이 달려가서 `선지자 이사야의 글 읽는 것을 듣고 말하되 읽는 것을 깨닫느뇨 ?'","reference":"사도행전 8:30","category":"$undefined"},{"id":"27208","book":"사도행전","book_name":"사도행전","chapter":8,"verse":31,"text":"대답하되 `지도하는 사람이 없으니 어찌 깨달을 수 있느뇨 ?' 하고 빌립을 청하여 `병거에 올라 같이 앉으라' 하니라","reference":"사도행전 8:31","category":"$undefined"},{"id":"27209","book":"사도행전","book_name":"사도행전","chapter":8,"verse":32,"text":"읽는 성경 귀절은 이것이니 일렀으되 저가 사지로 가는 양과 같이 끌리었고 털 깎는 자 앞에 있는 어린 양의 잠잠함과 같이 그 입을 열지 아니하였도다","reference":"사도행전 8:32","category":"$undefined"},{"id":"27210","book":"사도행전","book_name":"사도행전","chapter":8,"verse":33,"text":"낮을 때에 공변된 판단을 받지 못하였으니 누가 가히 그 세대를 말하리요 그 생명이 땅에서 빼앗김이로다 하였거늘","reference":"사도행전 8:33","category":"$undefined"},{"id":"27211","book":"사도행전","book_name":"사도행전","chapter":8,"verse":34,"text":"내시가 빌립더러 말하되 청컨대 `묻노니 선지자가 이 말 한 것이 누구를 가리킴이뇨 ? 자기를 가리킴이뇨 ? 타인을 가리킴이뇨 ?'","reference":"사도행전 8:34","category":"$undefined"},{"id":"27212","book":"사도행전","book_name":"사도행전","chapter":8,"verse":35,"text":"빌립이 입을 열어 이 글에서 시작하여 예수를 가르쳐 복음을 전하니","reference":"사도행전 8:35","category":"$undefined"},{"id":"27213","book":"사도행전","book_name":"사도행전","chapter":8,"verse":36,"text":"길 가다가 물 있는 곳에 이르러 내시가 말하되 `보라, 물이 있으니 내가 세례를 받음에 무슨 거리낌이 있느뇨'","reference":"사도행전 8:36","category":"$undefined"},{"id":"27214","book":"사도행전","book_name":"사도행전","chapter":8,"verse":37,"text":"(없 음)","reference":"사도행전 8:37","category":"$undefined"},{"id":"27215","book":"사도행전","book_name":"사도행전","chapter":8,"verse":38,"text":"이에 명하여 병거를 머물고 빌립과 내시가 둘 다 물에 내려가 빌립이 세례를 주고","reference":"사도행전 8:38","category":"$undefined"},{"id":"27216","book":"사도행전","book_name":"사도행전","chapter":8,"verse":39,"text":"둘이 물에서 올라갈새 주의 영이 빌립을 이끌어 간지라 내시는 흔연히 길을 가므로 그를 다시 보지 못하니라","reference":"사도행전 8:39","category":"$undefined"},{"id":"27217","book":"사도행전","book_name":"사도행전","chapter":8,"verse":40,"text":"빌립은 아소도에 나타나 여러성을 지나 다니며 복음을 전하고 가이사랴에 이르니라","reference":"사도행전 8:40","category":"$undefined"}],"bookSlug":"acts"}]
