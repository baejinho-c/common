2:["$","$L11",null,{"book":{"id":"acts","name":"사도행전","chapters":28,"testament":"new"},"chapter":9,"verses":[{"id":"27218","book":"사도행전","book_name":"사도행전","chapter":9,"verse":1,"text":"사울이 주의 제자들을 대하여 여전히 위협과 살기가 등등하여 대제사장에게 가서","reference":"사도행전 9:1","category":"$undefined"},{"id":"27219","book":"사도행전","book_name":"사도행전","chapter":9,"verse":2,"text":"다메섹 여러 회당에 갈 공문을 청하니 이는 만일 그 도를 좇는 사람을 만나면 무론 남녀하고 결박하여 예루살렘으로 잡아오려 함이라","reference":"사도행전 9:2","category":"$undefined"},{"id":"27220","book":"사도행전","book_name":"사도행전","chapter":9,"verse":3,"text":"사울이 행하여 다메섹에 가까이 가더니 홀연히 하늘로서 빛이 저를 둘러 비추는지라","reference":"사도행전 9:3","category":"$undefined"},{"id":"27221","book":"사도행전","book_name":"사도행전","chapter":9,"verse":4,"text":"땅에 엎드러져 들으매 소리 있어 가라사대 `사울아 ! 사울아 ! 네가 어찌하여 나를 핍박하느냐 ?' 하시거늘","reference":"사도행전 9:4","category":"$undefined"},{"id":"27222","book":"사도행전","book_name":"사도행전","chapter":9,"verse":5,"text":"대답하되 `주여 뉘시오니이까 ?' 가라사대 `나는 네가 핍박하는 예수라","reference":"사도행전 9:5","category":"$undefined"},{"id":"27223","book":"사도행전","book_name":"사도행전","chapter":9,"verse":6,"text":"네가 일어나 성으로 들어가라 행할 것을 네게 이를 자가 있느니라' 하시니","reference":"사도행전 9:6","category":"$undefined"},{"id":"27224","book":"사도행전","book_name":"사도행전","chapter":9,"verse":7,"text":"같이 가던 사람들은 소리만 듣고 아무도 보지 못하여 말을 못하고 섰더라","reference":"사도행전 9:7","category":"$undefined"},{"id":"27225","book":"사도행전","book_name":"사도행전","chapter":9,"verse":8,"text":"사울이 땅에서 일어나 눈은 떴으나 아무 것도 보지 못하고 사람의 손에 끌려 다메섹으로 들어가서","reference":"사도행전 9:8","category":"$undefined"},{"id":"27226","book":"사도행전","book_name":"사도행전","chapter":9,"verse":9,"text":"사흘 동안을 보지 못하고 식음을 전폐하니라","reference":"사도행전 9:9","category":"$undefined"},{"id":"27227","book":"사도행전","book_name":"사도행전","chapter":9,"verse":10,"text":"그 때에 다메섹에 아나니아라 하는 제자가 있더니 주께서 환상 중에 불러 가라사대 `아나니아야' 하시거늘 대답하되 `주여, 내가 여기 있나이다' 하니","reference":"사도행전 9:10","category":"$undefined"},{"id":"27228","book":"사도행전","book_name":"사도행전","chapter":9,"verse":11,"text":"주께서 가라사대 `일어나 직가라 하는 거리로 가서 유다 집에서 다소 사람 사울이라 하는 자를 찾으라 저가 기도하는 중이다","reference":"사도행전 9:11","category":"$undefined"},{"id":"27229","book":"사도행전","book_name":"사도행전","chapter":9,"verse":12,"text":"저가 아나니아라 하는 사람이 들어와서 자기에게 안수하여 다시 보게 하는 것을 보았느니라' 하시거늘","reference":"사도행전 9:12","category":"$undefined"},{"id":"27230","book":"사도행전","book_name":"사도행전","chapter":9,"verse":13,"text":"아나니아가 대답하되 `주여, 이 사람에 대하여 내가 여러 사람에게 듣사온즉 그가 예루살렘에서 주의 성도에게 적지 않은 해를 끼쳤다 하더니","reference":"사도행전 9:13","category":"$undefined"},{"id":"27231","book":"사도행전","book_name":"사도행전","chapter":9,"verse":14,"text":"여기서도 주의 이름을 부르는 모든 자를 결박할 권세를 대제사장들에게 받았나이다' 하거늘","reference":"사도행전 9:14","category":"$undefined"},{"id":"27232","book":"사도행전","book_name":"사도행전","chapter":9,"verse":15,"text":"주께서 가라사대 `가라, 이 사람은 내 이름을 이방인과 임금들과 이스라엘 자손들 앞에 전하기 위하여 택한 나의 그릇이라 !","reference":"사도행전 9:15","category":"$undefined"},{"id":"27233","book":"사도행전","book_name":"사도행전","chapter":9,"verse":16,"text":"그가 내 이름을 위하여 해를 얼마나 받아야 할 것을 내가 그에게 보이리라' 하시니","reference":"사도행전 9:16","category":"$undefined"},{"id":"27234","book":"사도행전","book_name":"사도행전","chapter":9,"verse":17,"text":"아나니아가 떠나 그 집에 들어가서 그에게 안수하여 가로되 `형제 사울아 ! 주 곧 네가 오는 길에서 나타나시던 예수께서 나를 보내어 너로 다시 보게 하시고 성령으로 충만하게 하신다' 하니","reference":"사도행전 9:17","category":"$undefined"},{"id":"27235","book":"사도행전","book_name":"사도행전","chapter":9,"verse":18,"text":"즉시 사울의 눈에서 비늘 같은 것이 벗어져 다시 보게 된지라 일어나 세례를 받고","reference":"사도행전 9:18","category":"$undefined"},{"id":"27236","book":"사도행전","book_name":"사도행전","chapter":9,"verse":19,"text":"음식을 먹으매 강건하여지니라 사울이 다메섹에 있는 제자들과 함께 며칠 있을새","reference":"사도행전 9:19","category":"$undefined"},{"id":"27237","book":"사도행전","book_name":"사도행전","chapter":9,"verse":20,"text":"즉시로 각 회당에서 예수의 하나님의 아들이심을 전파하니","reference":"사도행전 9:20","category":"$undefined"},{"id":"27238","book":"사도행전","book_name":"사도행전","chapter":9,"verse":21,"text":"듣는 사람이 다 놀라 말하되 `이사람이 예루살렘에서 이 이름 부르는 사람을 잔해하던 자가 아니냐 ? 여기 온것도 저희를 결박하여 대제사장들에게 끌어 가고자 함이 아니냐 ?' 하더라","reference":"사도행전 9:21","category":"$undefined"},{"id":"27239","book":"사도행전","book_name":"사도행전","chapter":9,"verse":22,"text":"사울은 힘을 더 얻어 예수를 그리스도라 증명하여 다메섹에 사는 유대인들을 굴복시키니라","reference":"사도행전 9:22","category":"$undefined"},{"id":"27240","book":"사도행전","book_name":"사도행전","chapter":9,"verse":23,"text":"여러 날이 지나매 유대인들이 사울 죽이기를 공모하더니","reference":"사도행전 9:23","category":"$undefined"},{"id":"27241","book":"사도행전","book_name":"사도행전","chapter":9,"verse":24,"text":"그 계교가 사울에게 알려지니라 저희가 그를 죽이려고 밤낮으로 성문까지 지키거늘","reference":"사도행전 9:24","category":"$undefined"},{"id":"27242","book":"사도행전","book_name":"사도행전","chapter":9,"verse":25,"text":"그의 제자들이 밤에 광주리에 사울을 담아 성에서 달아 내리니라","reference":"사도행전 9:25","category":"$undefined"},{"id":"27243","book":"사도행전","book_name":"사도행전","chapter":9,"verse":26,"text":"사울이 예루살렘에 가서 제자들을 사귀고자 하나 다 두려워하여 그의 제자 됨을 믿지 아니하니","reference":"사도행전 9:26","category":"$undefined"},{"id":"27244","book":"사도행전","book_name":"사도행전","chapter":9,"verse":27,"text":"바나바가 데리고 사도들에게 가서 그가 길에서 어떻게 주를 본 것과 주께서 그에게 말씀하신 일과 다메섹에서 그가 어떻게 예수의 이름으로 담대히 말하던 것을 말하니라","reference":"사도행전 9:27","category":"$undefined"},{"id":"27245","book":"사도행전","book_name":"사도행전","chapter":9,"verse":28,"text":"사울이 제자들과 함께 있어 예루살렘에 출입하며","reference":"사도행전 9:28","category":"$undefined"},{"id":"27246","book":"사도행전","book_name":"사도행전","chapter":9,"verse":29,"text":"또 주 예수의 이름으로 담대히 말하고 헬라파 유대인들과 함께 말하며 변론하니 그 사람들이 죽이려고 힘쓰거늘","reference":"사도행전 9:29","category":"$undefined"},{"id":"27247","book":"사도행전","book_name":"사도행전","chapter":9,"verse":30,"text":"형제들이 알고 가이사랴로 데리고 내려가서 다소로 보내니라","reference":"사도행전 9:30","category":"$undefined"},{"id":"27248","book":"사도행전","book_name":"사도행전","chapter":9,"verse":31,"text":"그리하여 온 유대와 갈릴리와 사마리아 교회가 평안하여 든든히 서가고 주를 경외함과 성령의 위로로 진행하여 수가 더 많아지니라","reference":"사도행전 9:31","category":"$undefined"},{"id":"27249","book":"사도행전","book_name":"사도행전","chapter":9,"verse":32,"text":"때에 베드로가 사방으로 두루 행하다가 룻다에 사는 성도들에게도 내려갔더니","reference":"사도행전 9:32","category":"$undefined"},{"id":"27250","book":"사도행전","book_name":"사도행전","chapter":9,"verse":33,"text":"거기서 애니아라 하는 사람을 만나매 그가 중풍병으로 상 위에 누운지 팔 년이라","reference":"사도행전 9:33","category":"$undefined"},{"id":"27251","book":"사도행전","book_name":"사도행전","chapter":9,"verse":34,"text":"베드로가 가로되 `애니아야, 예수 그리스도께서 너를 낫게 하시니 일어나 네 자리를 정돈하라' 한대 곧 일어나니","reference":"사도행전 9:34","category":"$undefined"},{"id":"27252","book":"사도행전","book_name":"사도행전","chapter":9,"verse":35,"text":"룻다와 사론에 사는 사람들이 다 그를 보고 주께로 돌아가니라","reference":"사도행전 9:35","category":"$undefined"},{"id":"27253","book":"사도행전","book_name":"사도행전","chapter":9,"verse":36,"text":"욥바에 다비다라 하는 여제자가 있으니 그 이름을 번역하면 도르가라 선행과 구제하는 일이 심히 많더니","reference":"사도행전 9:36","category":"$undefined"},{"id":"27254","book":"사도행전","book_name":"사도행전","chapter":9,"verse":37,"text":"그 때에 병들어 죽으매 시체를 씻어 다락에 뉘우니라","reference":"사도행전 9:37","category":"$undefined"},{"id":"27255","book":"사도행전","book_name":"사도행전","chapter":9,"verse":38,"text":"룻다가 욥바에 가까운지라 제자들이 베드로가 거기 있음을 듣고 두 사람을 보내어 지체 말고 오라고 간청하니","reference":"사도행전 9:38","category":"$undefined"},{"id":"27256","book":"사도행전","book_name":"사도행전","chapter":9,"verse":39,"text":"베드로가 일어나 저희와 함께 가서 이르매 저희가 데리고 다락에 올라가니 모든 과부가 베드로의 곁에 서서 울며 도르가가 저희와 함께 있을 때에 지은 속옷과 겉옷을 다 내어 보이거늘","reference":"사도행전 9:39","category":"$undefined"},{"id":"27257","book":"사도행전","book_name":"사도행전","chapter":9,"verse":40,"text":"베드로가 사람을 다 내어 보내고 무릎을 꿇고 기도하고 돌이켜 시체를 향하여 가로되 `다비다야, 일어나라' 하니 그가 눈을 떠 베드로를 보고 일어나 앉는지라","reference":"사도행전 9:40","category":"$undefined"},{"id":"27258","book":"사도행전","book_name":"사도행전","chapter":9,"verse":41,"text":"베드로가 손을 내밀어 일으키고 성도들과 과부들을 불러들여 그의 산 것을 보이니","reference":"사도행전 9:41","category":"$undefined"},{"id":"27259","book":"사도행전","book_name":"사도행전","chapter":9,"verse":42,"text":"온 욥바 사람이 알고 많이 주를 믿더라","reference":"사도행전 9:42","category":"$undefined"},{"id":"27260","book":"사도행전","book_name":"사도행전","chapter":9,"verse":43,"text":"베드로가 욥바에 여러 날 있어 시몬이라 하는 피장의 집에서 유하니라","reference":"사도행전 9:43","category":"$undefined"}],"bookSlug":"acts"}]
