2:["$","$L11",null,{"book":{"id":"amos","name":"아모스","chapters":9,"testament":"old"},"chapter":4,"verses":[{"id":"22412","book":"아모스","book_name":"아모스","chapter":4,"verse":1,"text":"사마리아 산에 거하는 바산 암소들아 이 말을 들으라 너희는 가난한 자를 학대하며 궁핍한 자를 압제하며 가장에게 이르기를 술을 가져다가 우리로 마시게 하라 하는도다","reference":"아모스 4:1","category":"$undefined"},{"id":"22413","book":"아모스","book_name":"아모스","chapter":4,"verse":2,"text":"주 여호와께서 자기의 거룩함을 가리켜 맹세하시되 때가 너희에게 임할지라 사람이 갈고리로 너희를 끌어 가며 낚시로 너희의 남은 자들을 그리하리라","reference":"아모스 4:2","category":"$undefined"},{"id":"22414","book":"아모스","book_name":"아모스","chapter":4,"verse":3,"text":"너희가 성 무너진 데로 말미암아 각기 앞으로 바로 나가서 하르몬에 던지우리라 이는 여호와의 말씀이니라","reference":"아모스 4:3","category":"$undefined"},{"id":"22415","book":"아모스","book_name":"아모스","chapter":4,"verse":4,"text":"너희는 벧엘에 가서 범죄하며 길갈에 가서 죄를 더하며 아침마다 너희 희생을, 삼일 마다 너희 십일조를 드리며","reference":"아모스 4:4","category":"$undefined"},{"id":"22416","book":"아모스","book_name":"아모스","chapter":4,"verse":5,"text":"누룩 넣은 것을 불살라 수은제로 드리며 낙헌제를 소리내어 광포하려무나 이스라엘 자손들아 이것이 너희의 기뻐하는 바니라 이는 주 여호와의 말씀이니라","reference":"아모스 4:5","category":"$undefined"},{"id":"22417","book":"아모스","book_name":"아모스","chapter":4,"verse":6,"text":"또 내가 너희 모든 성읍에서 너희 이를 한가하게 하며 너희 각처에서 양식이 떨어지게 하였으나 너희가 내게로 돌아 오지 아니하였느니라 이는 여호와의 말씀이니라","reference":"아모스 4:6","category":"$undefined"},{"id":"22418","book":"아모스","book_name":"아모스","chapter":4,"verse":7,"text":"또 추수하기 석달 전에 내가 너희에게 비를 멈추어 어떤 성읍에는 내리고 어떤 성읍에는 내리지 않게 하였더니 땅 한 부분은 비를 얻고 한 부분은 비를 얻지 못하여 말랐으매","reference":"아모스 4:7","category":"$undefined"},{"id":"22419","book":"아모스","book_name":"아모스","chapter":4,"verse":8,"text":"두 세 성읍 사람이 어떤 성읍으로 비틀거리며 물을 마시러 가서 만족히 마시지 못하였으나 너희가 내게로 돌아 오지 아니하였느니라 이는 여호와의 말씀이니라","reference":"아모스 4:8","category":"$undefined"},{"id":"22420","book":"아모스","book_name":"아모스","chapter":4,"verse":9,"text":"내가 풍재와 깜부기 재앙으로 너희를 쳤으며 팟종이로 너희의 많은 동산과 포도원과 무화과나무와 감람나무를 다 먹게 하였으나 너희가 내게로 돌아오지 아니하였느니라 이는 여호와의 말씀이니라","reference":"아모스 4:9","category":"$undefined"},{"id":"22421","book":"아모스","book_name":"아모스","chapter":4,"verse":10,"text":"내가 너희 중에 염병이 임하게 하기를 애굽에서 한 것처럼 하였으며 칼로 너희 청년들을 죽였으며 너희 말들을 노략하게 하며 너희 진의 악취로 코를 찌르게 하였으나 너희가 내게로 돌아 오지 아니하였느니라 이는 여호와의 말씀이니라","reference":"아모스 4:10","category":"$undefined"},{"id":"22422","book":"아모스","book_name":"아모스","chapter":4,"verse":11,"text":"내가 너희 중의 성읍 무너뜨리기를 하나님 내가 소돔과 고모라를 무너뜨림 같이 하였으므로 너희가 불 붙는 가운데서 빼낸 나무 조각 같이 되었으나 너희가 내게로 돌아오지 아니하였느니라 이는 여호와의 말씀이니라","reference":"아모스 4:11","category":"$undefined"},{"id":"22423","book":"아모스","book_name":"아모스","chapter":4,"verse":12,"text":"그러므로 이스라엘아 내가 이와 같이 네게 행하리라 내가 이것을 네게 행하리니 이스라엘아 네 하나님 만나기를 예비하라","reference":"아모스 4:12","category":"$undefined"},{"id":"22424","book":"아모스","book_name":"아모스","chapter":4,"verse":13,"text":"대저 산들을 지으며 바람을 창조하며 자기 뜻을 사람에게 보이며 아침을 어둡게 하며 땅의 높은데를 밟는 자는 그 이름이 만군의 하나님 여호와니라","reference":"아모스 4:13","category":"$undefined"}],"bookSlug":"amos"}]
