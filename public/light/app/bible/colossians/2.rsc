2:["$","$L11",null,{"book":{"id":"colossians","name":"골로새서","chapters":4,"testament":"new"},"chapter":2,"verses":[{"id":"29496","book":"골로새서","book_name":"골로새서","chapter":2,"verse":1,"text":"내가 너희와 라오디게아에 있는 자들과 무릇 내 육신의 얼굴을 보지 못한 자들을 위하여 어떻게 힘쓰는 것을 너희가 알기를 원하노니","reference":"골로새서 2:1","category":"$undefined"},{"id":"29497","book":"골로새서","book_name":"골로새서","chapter":2,"verse":2,"text":"이는 저희로 마음에 위안을 받고 사랑 안에서 연합하여 원만한 이해의 모든 부요에 이르러 하나님의 비밀인 그리스도를 깨닫게 하려 함이라","reference":"골로새서 2:2","category":"$undefined"},{"id":"29498","book":"골로새서","book_name":"골로새서","chapter":2,"verse":3,"text":"그 안에는 지혜와 지식의 모든 보화가 감취어 있느니라","reference":"골로새서 2:3","category":"$undefined"},{"id":"29499","book":"골로새서","book_name":"골로새서","chapter":2,"verse":4,"text":"내가 이것을 말함은 아무도 공교한 말로 너희를 속이지 못하게 하려 함이니","reference":"골로새서 2:4","category":"$undefined"},{"id":"29500","book":"골로새서","book_name":"골로새서","chapter":2,"verse":5,"text":"이는 내가 육신으로는 떠나 있으나 심령으로는 너희와 함께 있어 너희의 규모와 그리스도를 믿는 너희 믿음의 굳은 것을 기쁘게 봄이라","reference":"골로새서 2:5","category":"$undefined"},{"id":"29501","book":"골로새서","book_name":"골로새서","chapter":2,"verse":6,"text":"그러므로 너희가 그리스도 예수를 주로 받았으니 그 안에서 행하되","reference":"골로새서 2:6","category":"$undefined"},{"id":"29502","book":"골로새서","book_name":"골로새서","chapter":2,"verse":7,"text":"그 안에 뿌리를 박으며 세움을 입어 교훈을 받은대로 믿음에 굳게 서서 감사함을 넘치게 하라","reference":"골로새서 2:7","category":"$undefined"},{"id":"29503","book":"골로새서","book_name":"골로새서","chapter":2,"verse":8,"text":"누가 철학과 헛된 속임수로 너희를 노략할까 주의하라 이것이 사람의 유전과 세상의 초등 학문을 좇음이요 그리스도를 좇음이 아니니라","reference":"골로새서 2:8","category":"$undefined"},{"id":"29504","book":"골로새서","book_name":"골로새서","chapter":2,"verse":9,"text":"그 안에는 신성의 모든 충만이 육체로 거하시고","reference":"골로새서 2:9","category":"$undefined"},{"id":"29505","book":"골로새서","book_name":"골로새서","chapter":2,"verse":10,"text":"너희도 그 안에서 충만하여졌으니 그는 모든 정사와 권세의 머리시라","reference":"골로새서 2:10","category":"$undefined"},{"id":"29506","book":"골로새서","book_name":"골로새서","chapter":2,"verse":11,"text":"또 그 안에서 너희가 손으로 하지 아니한 할례를 받았으니 곧 육적 몸을 벗는 것이요 그리스도의 할례니라","reference":"골로새서 2:11","category":"$undefined"},{"id":"29507","book":"골로새서","book_name":"골로새서","chapter":2,"verse":12,"text":"너희가 세례로 그리스도와 함께 장사한 바 되고 또 죽은 자들 가운데서 그를 일으키신 하나님의 역사를 믿음으로 말미암아 그 안에서 함께 일으키심을 받았느니라","reference":"골로새서 2:12","category":"$undefined"},{"id":"29508","book":"골로새서","book_name":"골로새서","chapter":2,"verse":13,"text":"또 너희의 범죄와 육체의 무할례로 죽었던 너희를 하나님이 그와 함께 살리시고 우리에게 모든 죄를 사하시고","reference":"골로새서 2:13","category":"$undefined"},{"id":"29509","book":"골로새서","book_name":"골로새서","chapter":2,"verse":14,"text":"우리를 거스리고 우리를 대적하는 의문에 쓴 증서를 도말하시고 제하여 버리사 십자가에 못 박으시고","reference":"골로새서 2:14","category":"$undefined"},{"id":"29510","book":"골로새서","book_name":"골로새서","chapter":2,"verse":15,"text":"정사와 권세를 벗어버려 밝히 드러내시고 십자가로 승리하셨느니라","reference":"골로새서 2:15","category":"$undefined"},{"id":"29511","book":"골로새서","book_name":"골로새서","chapter":2,"verse":16,"text":"그러므로 먹고 마시는 것과 절기나 월삭이나 안식일을 인하여 누구든지 너희를 평론하지 못하게 하라","reference":"골로새서 2:16","category":"$undefined"},{"id":"29512","book":"골로새서","book_name":"골로새서","chapter":2,"verse":17,"text":"이것들은 장래 일의 그림자이나 몸은 그리스도의 것이니라","reference":"골로새서 2:17","category":"$undefined"},{"id":"29513","book":"골로새서","book_name":"골로새서","chapter":2,"verse":18,"text":"누구든지 일부러 겸손함과 천사 숭배함을 인하여 너희 상을 빼앗지 못하게 하라 저가 그 본 것을 의지하여 그 육체의 마음을 좇아 헛되이 과장하고","reference":"골로새서 2:18","category":"$undefined"},{"id":"29514","book":"골로새서","book_name":"골로새서","chapter":2,"verse":19,"text":"머리를 붙들지 아니하는지라 온 몸이 머리로 말미암아 마디와 힘줄로 공급함을 얻고 연합하여 하나님이 자라게 하심으로 자라느니라","reference":"골로새서 2:19","category":"$undefined"},{"id":"29515","book":"골로새서","book_name":"골로새서","chapter":2,"verse":20,"text":"너희가 세상의 초등 학문에서 그리스도와 함께 죽었거든 어찌하여 세상에 사는 것과 같이 의문에 순종하느냐 ?","reference":"골로새서 2:20","category":"$undefined"},{"id":"29516","book":"골로새서","book_name":"골로새서","chapter":2,"verse":21,"text":"곧 붙잡지도 말고 맛보지도 말고 만지지도 말라 하는 것이니","reference":"골로새서 2:21","category":"$undefined"},{"id":"29517","book":"골로새서","book_name":"골로새서","chapter":2,"verse":22,"text":"(이 모든 것은 쓰는 대로 부패에 돌아가리라) 사람의 명과 가르침을 좇느냐","reference":"골로새서 2:22","category":"$undefined"},{"id":"29518","book":"골로새서","book_name":"골로새서","chapter":2,"verse":23,"text":"이런 것들은 자의적 숭배와 겸손과 몸을 괴롭게 하는 데 지혜 있는 모양이나 오직 육체 좇는 것을 금하는 데는 유익이 조금도 없느니라","reference":"골로새서 2:23","category":"$undefined"}],"bookSlug":"colossians"}]
