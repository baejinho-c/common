2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":10,"verses":[{"id":"22017","book":"다니엘","book_name":"다니엘","chapter":10,"verse":1,"text":"바사 왕 고레스 삼년에 한 일이 벨드사살이라 이름한 다니엘에게 나타났는데 그 일이 참되니 곧 큰 전쟁에 관한 것이라 다니엘이 그 일을 분명히 알았고 그 이상을 깨달으니라","reference":"다니엘 10:1","category":"$undefined"},{"id":"22018","book":"다니엘","book_name":"다니엘","chapter":10,"verse":2,"text":"그 때에 나 다니엘이 세 이레 동안을 슬퍼하며","reference":"다니엘 10:2","category":"$undefined"},{"id":"22019","book":"다니엘","book_name":"다니엘","chapter":10,"verse":3,"text":"세 이레가 차기까지 좋은 떡을 먹지 아니하며 고기와 포도주를 입에 넣지 아니하며 또 기름을 바르지 아니하니라","reference":"다니엘 10:3","category":"$undefined"},{"id":"22020","book":"다니엘","book_name":"다니엘","chapter":10,"verse":4,"text":"정월 이십 사 일에 내가 힛데겔이라 하는 큰 강가에 있었는데","reference":"다니엘 10:4","category":"$undefined"},{"id":"22021","book":"다니엘","book_name":"다니엘","chapter":10,"verse":5,"text":"그 때에 내가 눈을 들어 바라본즉 한 사람이 세마포 옷을 입었고 허리에는 우바스 정금 띠를 띠었고","reference":"다니엘 10:5","category":"$undefined"},{"id":"22022","book":"다니엘","book_name":"다니엘","chapter":10,"verse":6,"text":"그 몸은 황옥 같고 그 얼굴은 번갯빛 같고 그 눈은 횃불 같고 그 팔과 발은 빛난 놋과 같고 그 말소리는 무리의 소리와 같더라","reference":"다니엘 10:6","category":"$undefined"},{"id":"22023","book":"다니엘","book_name":"다니엘","chapter":10,"verse":7,"text":"이 이상은 나 다니엘이 홀로 보았고 나와 함께한 사람들은 이 이상은 보지 못하였어도 그들이 크게 떨며 도망하여 숨었었느니라","reference":"다니엘 10:7","category":"$undefined"},{"id":"22024","book":"다니엘","book_name":"다니엘","chapter":10,"verse":8,"text":"그러므로 나만 홀로 있어서 이 큰 이상을 볼 때에 내 몸에 힘이 빠졌고 나의 아름다운 빛이 변하여 썩은 듯하였고 나의 힘이 다 없어졌으나","reference":"다니엘 10:8","category":"$undefined"},{"id":"22025","book":"다니엘","book_name":"다니엘","chapter":10,"verse":9,"text":"내가 그 말소리를 들었는데 그 말소리를 들을 때에 내가 얼굴을 땅에 대고 깊이 잠들었었느니라","reference":"다니엘 10:9","category":"$undefined"},{"id":"22026","book":"다니엘","book_name":"다니엘","chapter":10,"verse":10,"text":"한 손이 있어 나를 어루만지기로 내가 떨더니 그가 내 무릎과 손 바닥이 땅에 닿게 일으키고","reference":"다니엘 10:10","category":"$undefined"},{"id":"22027","book":"다니엘","book_name":"다니엘","chapter":10,"verse":11,"text":"내게 이르되 은총을 크게 받은 사람 다니엘아 내가 네게 이르는 말을 깨닫고 일어서라 내가 네게 보내심을 받았느니라 그가 내게 이 말을 한 후에 내가 떨며 일어서매","reference":"다니엘 10:11","category":"$undefined"},{"id":"22028","book":"다니엘","book_name":"다니엘","chapter":10,"verse":12,"text":"그가 이르되 다니엘아 두려워하지 말라 네가 깨달으려 하여 네 하나님 앞에 스스로 겸비케 하기로 결심하던 첫 날부터 네 말이 들으신 바 되었으므로 내가 네 말로 인하여 왔느니라","reference":"다니엘 10:12","category":"$undefined"},{"id":"22029","book":"다니엘","book_name":"다니엘","chapter":10,"verse":13,"text":"그런데 바사국 군이 이십 일일 동안 나를 막았으므로 내가 거기 바사국 왕들과 함께 머물러 있더니 군장 중 하나 미가엘이 와서 나를 도와주므로","reference":"다니엘 10:13","category":"$undefined"},{"id":"22030","book":"다니엘","book_name":"다니엘","chapter":10,"verse":14,"text":"이제 내가 말일에 네 백성의 당할 일을 네게 깨닫게 하러 왔노라 대저 이 이상은 오래 후의 일이니라","reference":"다니엘 10:14","category":"$undefined"},{"id":"22031","book":"다니엘","book_name":"다니엘","chapter":10,"verse":15,"text":"그가 이런 말로 내게 이를 때에 내가 곧 얼굴을 땅에 향하고 벙벙하였더니","reference":"다니엘 10:15","category":"$undefined"},{"id":"22032","book":"다니엘","book_name":"다니엘","chapter":10,"verse":16,"text":"인자와 같은 이가 있어 내 입술을 만진지라 내가 곧 입을 열어 내 앞에 섰는 자에게 말하여 가로되 `내 주여 이 이상을 인하여 근심이 내게 더하므로 내가 힘이 없어졌나이다","reference":"다니엘 10:16","category":"$undefined"},{"id":"22033","book":"다니엘","book_name":"다니엘","chapter":10,"verse":17,"text":"내 몸에 힘이 없어졌고 호흡이 남지 아니하였사오니 내 주의 이 종이 어찌 능히 내 주로 더불어 말씀할 수 있으리이까","reference":"다니엘 10:17","category":"$undefined"},{"id":"22034","book":"다니엘","book_name":"다니엘","chapter":10,"verse":18,"text":"또 사람의 모양 같은 것 하나가 나를 만지며 나로 강건케 하여","reference":"다니엘 10:18","category":"$undefined"},{"id":"22035","book":"다니엘","book_name":"다니엘","chapter":10,"verse":19,"text":"가로되 은총을 크게 받은 사람이여 두려워하지 말라 평안하라 강건하라 강건하라 그가 이같이 내게 말하매 내가 곧 힘이 나서 가로되 내 주께서 나로 힘이 나게 하셨사오니 말씀하옵소서","reference":"다니엘 10:19","category":"$undefined"},{"id":"22036","book":"다니엘","book_name":"다니엘","chapter":10,"verse":20,"text":"그가 이르되 내가 어찌하여 네게 나아온 것을 네가 아느냐 이제 내가 돌아가서 바사 군과 싸우려니와 내가 나간 후에는 헬라 군이 이를 것이라","reference":"다니엘 10:20","category":"$undefined"},{"id":"22037","book":"다니엘","book_name":"다니엘","chapter":10,"verse":21,"text":"오직 내가 먼저 진리의 글에 기록된 것으로 네게 보이리라 나를 도와서 그들을 대적하는 자는 너희 군 미가엘 뿐이니라","reference":"다니엘 10:21","category":"$undefined"}],"bookSlug":"daniel"}]
