2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":11,"verses":[{"id":"22038","book":"다니엘","book_name":"다니엘","chapter":11,"verse":1,"text":"내가 또 메대 사람 다리오 원년에 일어나 그를 돕고 강하게 한 일이 있었느니라","reference":"다니엘 11:1","category":"$undefined"},{"id":"22039","book":"다니엘","book_name":"다니엘","chapter":11,"verse":2,"text":"이제 내가 참된 것을 네게 보이리라 보라 바사에서 또 세 왕이 일어날 것이요 그 후의 네째는 그들보다 심히 부요할 것이며 그가 그 부요함으로 강하여진 후에는 모든 사람을 격동시켜 헬라국을 칠 것이며","reference":"다니엘 11:2","category":"$undefined"},{"id":"22040","book":"다니엘","book_name":"다니엘","chapter":11,"verse":3,"text":"장차 한 능력 있는 왕이 일어나서 큰 권세로 다스리며 임의로 행하리라","reference":"다니엘 11:3","category":"$undefined"},{"id":"22041","book":"다니엘","book_name":"다니엘","chapter":11,"verse":4,"text":"그러나 그가 강성할 때에 그 나라가 갈라져 천하 사방에 나누일 것이나 그 자손에게로 돌아가지도 아니할 것이요 또 자기가 주장하던 권세대로도 되지 아니하리니 이는 그 나라가 뽑혀서 이 외의 사람들에게로 돌아갈 것임이니라","reference":"다니엘 11:4","category":"$undefined"},{"id":"22042","book":"다니엘","book_name":"다니엘","chapter":11,"verse":5,"text":"남방의 왕은 강할 것이나 그 군들 중에 하나는 그보다 강하여 권세를 떨치리니 그 권세가 심히 클 것이요","reference":"다니엘 11:5","category":"$undefined"},{"id":"22043","book":"다니엘","book_name":"다니엘","chapter":11,"verse":6,"text":"몇 해 후에 그들이 서로 맹약하리니 곧 남방 왕의 딸이 북방 왕에게 나아가서 화친하리라 그러나 이 공주의 힘이 쇠하고 그 왕은 서지도 못하며 권세가 없어질 뿐 아니라 이 공주와 그를 데리고 온 자와 그를 낳은 자와 그 때에 도와주던 자가 다 버림을 당하리라","reference":"다니엘 11:6","category":"$undefined"},{"id":"22044","book":"다니엘","book_name":"다니엘","chapter":11,"verse":7,"text":"그러나 이 공주의 본족에서 난 자 중에 하나가 그의 위를 이어 북방 왕의 군대를 치러 와서 그의 성에 들어가서 그들을 이기고","reference":"다니엘 11:7","category":"$undefined"},{"id":"22045","book":"다니엘","book_name":"다니엘","chapter":11,"verse":8,"text":"그 신들과 부어만든 우상들과 그 은과 금의 아름다운 기구를 다 노략하여 애굽으로 가져갈 것이요 몇 해 동안은 그가 북방 왕을 치지 아니하리라","reference":"다니엘 11:8","category":"$undefined"},{"id":"22046","book":"다니엘","book_name":"다니엘","chapter":11,"verse":9,"text":"북방 왕이 남방 왕의 나라로 쳐 들어갈 것이나 자기 본국으로 물러 가리라","reference":"다니엘 11:9","category":"$undefined"},{"id":"22047","book":"다니엘","book_name":"다니엘","chapter":11,"verse":10,"text":"그 아들들이 전쟁을 준비하고 심히 많은 군대를 모아서 물의 넘침 같이 나아올 것이며 그가 또 와서 남방 왕의 견고한 성까지 칠 것이요","reference":"다니엘 11:10","category":"$undefined"},{"id":"22048","book":"다니엘","book_name":"다니엘","chapter":11,"verse":11,"text":"남방 왕은 크게 노하여 나와서 북방 왕과 싸울 것이라 북방 왕이 큰 무리를 일으킬 것이나 그 무리가 그의 손에 붙인바 되리라","reference":"다니엘 11:11","category":"$undefined"},{"id":"22049","book":"다니엘","book_name":"다니엘","chapter":11,"verse":12,"text":"그가 큰 무리를 사로잡은 후에 그 마음이 스스로 높아져서 수만명을 엎드러뜨릴 것이나 그 세력은 더하지 못할 것이요","reference":"다니엘 11:12","category":"$undefined"},{"id":"22050","book":"다니엘","book_name":"다니엘","chapter":11,"verse":13,"text":"북방 왕은 돌아가서 다시 대군을 전보다 더 많이 준비하였다가 몇 때 곧 몇 해 후에 대군과 많은 물건을 거느리고 오리라","reference":"다니엘 11:13","category":"$undefined"},{"id":"22051","book":"다니엘","book_name":"다니엘","chapter":11,"verse":14,"text":"그 때에 여러 사람이 일어나서 남방 왕을 칠 것이요 네 백성 중에서도 강포한 자가 스스로 높아져서 이상을 이루려 할 것이나 그들이 도리어 넘어지리라","reference":"다니엘 11:14","category":"$undefined"},{"id":"22052","book":"다니엘","book_name":"다니엘","chapter":11,"verse":15,"text":"이에 북방 왕은 와서 토성을 쌓고 견고한 성읍을 취할 것이요 남방 군대는 그를 당할 힘이 없을 것이므로","reference":"다니엘 11:15","category":"$undefined"},{"id":"22053","book":"다니엘","book_name":"다니엘","chapter":11,"verse":16,"text":"오직 와서 치는 자가 임의로 행하리니 능히 그 앞에 설 사람이 없겠고 그가 영화로운 땅에 설 것이요 그 손에 멸망이 있으리라","reference":"다니엘 11:16","category":"$undefined"},{"id":"22054","book":"다니엘","book_name":"다니엘","chapter":11,"verse":17,"text":"그가 결심하고 전국의 힘을 다하여 이르렀다가 그와 화친할 것이요 또 여자의 딸을 그에게 주어 그 나라를 패망케 하려 할 것이나 이루지 못하리니 그에게 무익하리라","reference":"다니엘 11:17","category":"$undefined"},{"id":"22055","book":"다니엘","book_name":"다니엘","chapter":11,"verse":18,"text":"그 후에 그가 얼굴을 섬들로 돌이켜 많이 취할 것이나 한 대장이 있어서 그의 보이는 수욕을 씻고 그 수욕을 그에게로 돌릴 것이므로","reference":"다니엘 11:18","category":"$undefined"},{"id":"22056","book":"다니엘","book_name":"다니엘","chapter":11,"verse":19,"text":"그가 드디어 그 얼굴을 돌이켜 자기 땅 산성들로 향할 것이나 거쳐 넘어지고 다시는 보이지 아니하리라","reference":"다니엘 11:19","category":"$undefined"},{"id":"22057","book":"다니엘","book_name":"다니엘","chapter":11,"verse":20,"text":"그 위를 이을 자가 토색하는 자로 그 나라의 아름다운 곳으로 두루 다니게 할 것이나 그는 분노함이나 싸움이 없이 몇 날이 못되어 망할 것이요","reference":"다니엘 11:20","category":"$undefined"},{"id":"22058","book":"다니엘","book_name":"다니엘","chapter":11,"verse":21,"text":"또 그 위를 이을 자는 한 비천한 사람이라 나라 영광을 그에게 주지 아니할 것이나 그가 평안한 때를 타서 궤휼로 그 나라를 얻을 것이며","reference":"다니엘 11:21","category":"$undefined"},{"id":"22059","book":"다니엘","book_name":"다니엘","chapter":11,"verse":22,"text":"넘치는 물 같은 군대가 그에게 넘침을 입어 패할 것이요 동맹한 왕도 그렇게 될 것이며","reference":"다니엘 11:22","category":"$undefined"},{"id":"22060","book":"다니엘","book_name":"다니엘","chapter":11,"verse":23,"text":"그와 약조한 후에 그는 거짓을 행하여 올라올 것이요 적은 백성을 거느리고 강하게 될 것이며","reference":"다니엘 11:23","category":"$undefined"},{"id":"22061","book":"다니엘","book_name":"다니엘","chapter":11,"verse":24,"text":"그가 평안한 때에 그 도의 가장 기름진 곳에 들어와서 그 열조와 열조의 조상이 행하지 못하던 것을 행할 것이요 그는 노략하며 탈취한 재물을 무리에게 흩어주며 모략을 베풀어 얼마 동안 산성들을 칠 것인데 때가 이르기까지 그리하리라","reference":"다니엘 11:24","category":"$undefined"},{"id":"22062","book":"다니엘","book_name":"다니엘","chapter":11,"verse":25,"text":"그가 그 힘을 떨치며 용맹을 발하여 큰 군대를 거느리고 남방 왕도 심히 크고 강한 군대를 거느리고 맞아 싸울 것이나 능히 당하지 못하리니 이는 그들이 모략을 베풀어 그를 침이니라","reference":"다니엘 11:25","category":"$undefined"},{"id":"22063","book":"다니엘","book_name":"다니엘","chapter":11,"verse":26,"text":"자기의 진미를 먹는 자가 그를 멸하리니 그 군대가 흩어질 것이요 많은 자가 엎드러져 죽으리라","reference":"다니엘 11:26","category":"$undefined"},{"id":"22064","book":"다니엘","book_name":"다니엘","chapter":11,"verse":27,"text":"이 두 왕이 마음에 서로 해코자 하여 한 밥상에 앉았을 때에 거짓말을 할 것이라 일이 형통하지 못하리니 이는 작정된 기한에 미쳐서 그 일이 끝날 것임이니라","reference":"다니엘 11:27","category":"$undefined"},{"id":"22065","book":"다니엘","book_name":"다니엘","chapter":11,"verse":28,"text":"북방 왕은 많은 재물을 가지고 본국으로 돌아가리니 그는 마음으로 거룩한 언약을 거스리며 임의로 행하고 본토로 돌아갈 것이며","reference":"다니엘 11:28","category":"$undefined"},{"id":"22066","book":"다니엘","book_name":"다니엘","chapter":11,"verse":29,"text":"작정된 기한에 그가 다시 나와서 남방에 이를 것이나 이번이 그 전번만 못하리니","reference":"다니엘 11:29","category":"$undefined"},{"id":"22067","book":"다니엘","book_name":"다니엘","chapter":11,"verse":30,"text":"이는 깃딤의 배들이 이르러 그를 칠 것임이라 그가 낙심하고 돌아가며 거룩한 언약을 한하고 임의로 행하며 돌아가서는 거룩한 언약을 배반하는 자를 중히 여길 것이며","reference":"다니엘 11:30","category":"$undefined"},{"id":"22068","book":"다니엘","book_name":"다니엘","chapter":11,"verse":31,"text":"군대는 그의 편에 서서 성소 곧 견고한 곳을 더럽히며 매일 드리는 제사를 폐하며 멸망케 하는 미운 물건을 세울 것이며","reference":"다니엘 11:31","category":"$undefined"},{"id":"22069","book":"다니엘","book_name":"다니엘","chapter":11,"verse":32,"text":"그가 또 언약을 배반하고 악행하는 자를 궤휼로 타락시킬 것이나 오직 자기의 하나님을 아는 백성은 강하여 용맹을 발하리라","reference":"다니엘 11:32","category":"$undefined"},{"id":"22070","book":"다니엘","book_name":"다니엘","chapter":11,"verse":33,"text":"백성 중에 지혜로운 자가 많은 사람을 가르칠 것이나 그들이 칼날과 불꽃과 사로잡힘과 약탈을 당하여 여러 날 동안 쇠패하리라","reference":"다니엘 11:33","category":"$undefined"},{"id":"22071","book":"다니엘","book_name":"다니엘","chapter":11,"verse":34,"text":"그들이 쇠패할 때에 도움을 조금 얻을 것이나 많은 사람은 궤휼로 그들과 친합할 것이며","reference":"다니엘 11:34","category":"$undefined"},{"id":"22072","book":"다니엘","book_name":"다니엘","chapter":11,"verse":35,"text":"또 그들 중 지혜로운 자 몇 사람이 쇠패하여 무리로 연단되며 정결케 되며 희게 되어 마지막 때까지 이르게 하리니 이는 작정된 기한이 있음이니라","reference":"다니엘 11:35","category":"$undefined"},{"id":"22073","book":"다니엘","book_name":"다니엘","chapter":11,"verse":36,"text":"이 왕이 자기 뜻대로 행하며 스스로 높여 모든 신보다 크다 하며 비상한 말로 신들의 신을 대적하며 형통하기를 분노하심이 쉴 때까지 하리니 이는 그 작정된 일이 반드시 이룰 것임이니라","reference":"다니엘 11:36","category":"$undefined"},{"id":"22074","book":"다니엘","book_name":"다니엘","chapter":11,"verse":37,"text":"그가 모든 것보다 스스로 크다 하고 그 열조의 신들과 여자의 사모하는 것을 돌아보지 아니하며 아무 신이든지 돌아보지 아니할 것이나","reference":"다니엘 11:37","category":"$undefined"},{"id":"22075","book":"다니엘","book_name":"다니엘","chapter":11,"verse":38,"text":"그 대신에 세력의 신을 공경할 것이요 또 그 열조가 알지 못하던 신에게 금,은 보석과 보물을 드려 공경할 것이며","reference":"다니엘 11:38","category":"$undefined"},{"id":"22076","book":"다니엘","book_name":"다니엘","chapter":11,"verse":39,"text":"그는 이방 신을 힘입어 크게 견고한 산성들을 취할 것이요 무릇 그를 안다 하는 자에게는 영광을 더하여 여러 백성을 다스리게도 하며 그에게서 뇌물을 받고 땅을 나눠주기도 하리라","reference":"다니엘 11:39","category":"$undefined"},{"id":"22077","book":"다니엘","book_name":"다니엘","chapter":11,"verse":40,"text":"마지막 때에 남방 왕이 그를 찌르리니 북방 왕이 병거와 마병과 많은 배로 회리바람처럼 그에게로 마주 와서 그 여러 나라에 들어가며 물이 넘침 같이 지나갈 것이요","reference":"다니엘 11:40","category":"$undefined"},{"id":"22078","book":"다니엘","book_name":"다니엘","chapter":11,"verse":41,"text":"그가 또 영화로운 땅에 들어갈 것이요 많은 나라를 패망케 할 것이나 오직 에돔과 모압과 암몬 자손의 존귀한 자들은 그 손에서 벗어나리라","reference":"다니엘 11:41","category":"$undefined"},{"id":"22079","book":"다니엘","book_name":"다니엘","chapter":11,"verse":42,"text":"그가 열국에 그 손을 펴리니 애굽 땅도 면치 못할 것이므로","reference":"다니엘 11:42","category":"$undefined"},{"id":"22080","book":"다니엘","book_name":"다니엘","chapter":11,"verse":43,"text":"그가 권세로 애굽의 금 은과 모든 보물을 잡을 것이요 리비아 사람과 구스 사람이 그의 시종이 되리라","reference":"다니엘 11:43","category":"$undefined"},{"id":"22081","book":"다니엘","book_name":"다니엘","chapter":11,"verse":44,"text":"그러나 동북에서부터 소문이 이르러 그로 번민케 하므로 그가 분노하여 나가서 많은 무리를 다 도륙하며 진멸코자 할 것이요","reference":"다니엘 11:44","category":"$undefined"},{"id":"22082","book":"다니엘","book_name":"다니엘","chapter":11,"verse":45,"text":"그가 장막 궁전을 바다와 영화롭고 거룩한 산 사이에 베풀 것이나 그의 끝이 이르리니 도와줄 자가 없으리라","reference":"다니엘 11:45","category":"$undefined"}],"bookSlug":"daniel"}]
