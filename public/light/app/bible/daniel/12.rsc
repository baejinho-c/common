2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":12,"verses":[{"id":"22083","book":"다니엘","book_name":"다니엘","chapter":12,"verse":1,"text":"그 때에 네 민족을 호위하는 대군 미가엘이 일어날 것이요 또 환난이 있으리니 이는 개국 이래로 그 때까지 없던 환난일 것이며 그 때에 네 백성 중 무릇 책에 기록된 모든 자가 구원을 얻을 것이라","reference":"다니엘 12:1","category":"$undefined"},{"id":"22084","book":"다니엘","book_name":"다니엘","chapter":12,"verse":2,"text":"땅의 티끌 가운데서 자는 자 중에 많이 깨어 영생을 얻는 자도 있겠고 수욕을 받아서 무궁히 부끄러움을 입을 자도 있을 것이며","reference":"다니엘 12:2","category":"$undefined"},{"id":"22085","book":"다니엘","book_name":"다니엘","chapter":12,"verse":3,"text":"지혜 있는 자는 궁창의 빛과 같이 빛날 것이요 많은 사람을 옳은데로 돌아오게 한 자는 별과 같이 영원토록 비취리라","reference":"다니엘 12:3","category":"$undefined"},{"id":"22086","book":"다니엘","book_name":"다니엘","chapter":12,"verse":4,"text":"다니엘아 마지막 때까지 이 말을 간수하고 이 글을 봉함하라 많은 사람이 빨리 왕래하며 지식이 더하리라","reference":"다니엘 12:4","category":"$undefined"},{"id":"22087","book":"다니엘","book_name":"다니엘","chapter":12,"verse":5,"text":"나 다니엘이 본즉 다른 두 사람이 있어 하나는 강 이편 언덕에 섰고 하나는 강 저편 언덕에 섰더니","reference":"다니엘 12:5","category":"$undefined"},{"id":"22088","book":"다니엘","book_name":"다니엘","chapter":12,"verse":6,"text":"그 중에 하나가 세마포 옷을 입은 자 곧 강물 위에 있는 자에게 이르되 이 기사의 끝이 어느 때까지냐 하기로","reference":"다니엘 12:6","category":"$undefined"},{"id":"22089","book":"다니엘","book_name":"다니엘","chapter":12,"verse":7,"text":"내가 들은즉 그 세마포 옷을 입고 강물 위에 있는 자가 그 좌우 손을 들어 하늘을 향하여 영생하시는 자를 가리켜 맹세하여 가로되 반드시 한 때, 두 때, 반 때를 지나서 성도의 권세가 다 깨어지기까지니 그렇게 되면 이 모든 일이 다 끝나리라 하더라","reference":"다니엘 12:7","category":"$undefined"},{"id":"22090","book":"다니엘","book_name":"다니엘","chapter":12,"verse":8,"text":"내가 듣고도 깨닫지 못한지라 내가 가로되 내 주여 이 모든 일의 결국이 어떠하겠삽나이까 ?","reference":"다니엘 12:8","category":"$undefined"},{"id":"22091","book":"다니엘","book_name":"다니엘","chapter":12,"verse":9,"text":"그가 가로되 다니엘아 갈지어다 대저 이 말은 마지막 때까지 간수하고 봉함할 것임이니라","reference":"다니엘 12:9","category":"$undefined"},{"id":"22092","book":"다니엘","book_name":"다니엘","chapter":12,"verse":10,"text":"많은 사람이 연단을 받아 스스로 정결케 하며 희게 할 것이나 악한 사람은 악을 행하리니 악한 자는 아무도 깨닫지 못하되 오직 지혜있는 자는 깨달으리라","reference":"다니엘 12:10","category":"$undefined"},{"id":"22093","book":"다니엘","book_name":"다니엘","chapter":12,"verse":11,"text":"매일 드리는 제사를 폐하며 멸망케 할 미운 물건을 세울 때부터 일천 이백구십 일을 지낼 것이요","reference":"다니엘 12:11","category":"$undefined"},{"id":"22094","book":"다니엘","book_name":"다니엘","chapter":12,"verse":12,"text":"기다려서 일천 삼백 삼십 오일까지 이르는 그 사람은 복이 있으리라","reference":"다니엘 12:12","category":"$undefined"},{"id":"22095","book":"다니엘","book_name":"다니엘","chapter":12,"verse":13,"text":"너는 가서 마지막을 기다리라 이는 네가 평안히 쉬다가 끝날에는 네 업을 누릴 것임이니라","reference":"다니엘 12:13","category":"$undefined"}],"bookSlug":"daniel"}]
