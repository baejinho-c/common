2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":3,"verses":[{"id":"21809","book":"다니엘","book_name":"다니엘","chapter":3,"verse":1,"text":"느부갓네살 왕이 금으로 신상을 만들었으니 고는 육십 규빗이요 광은 여섯 규빗이라 그것을 바벨론 도의 두라 평지에 세웠더라","reference":"다니엘 3:1","category":"$undefined"},{"id":"21810","book":"다니엘","book_name":"다니엘","chapter":3,"verse":2,"text":"느부갓네살 왕이 보내어 방백과 수령과 도백과 재판관과 재무관과 모사와 법률사와 각 도 모든 관원을 자기 느부갓네살 왕의 세운 신상의 낙성 예식에 참집하게 하매","reference":"다니엘 3:2","category":"$undefined"},{"id":"21811","book":"다니엘","book_name":"다니엘","chapter":3,"verse":3,"text":"이에 방백과 수령과 도백과 재판관과 재무관과 모사와 법률사와 각 도 모든 관원이 느부갓네살 왕의 세운 신상의 낙성 예식에 참집하여 느부갓네살의 세운 신상 앞에 서니라","reference":"다니엘 3:3","category":"$undefined"},{"id":"21812","book":"다니엘","book_name":"다니엘","chapter":3,"verse":4,"text":"반포하는 자가 크게 외쳐 가로되 백성들과 나라들과 각 방언하는 자들아 왕이 너희 무리에게 명하시나니","reference":"다니엘 3:4","category":"$undefined"},{"id":"21813","book":"다니엘","book_name":"다니엘","chapter":3,"verse":5,"text":"너희는 나팔과 피리와 수금과 삼현금과 양금과 생황과 및 모든 악기 소리를 들을 때에 엎드리어 느부갓네살 왕의 세운 금신상에게 절하라","reference":"다니엘 3:5","category":"$undefined"},{"id":"21814","book":"다니엘","book_name":"다니엘","chapter":3,"verse":6,"text":"누구든지 엎드리어 절하지 아니하는 자는 즉시 극렬히 타는 풀무에 던져 넣으리라 하매","reference":"다니엘 3:6","category":"$undefined"},{"id":"21815","book":"다니엘","book_name":"다니엘","chapter":3,"verse":7,"text":"모든 백성과 나라들과 각 방언하는 자들이 나팔과, 피리와, 수금과, 삼현금과, 양금과, 및 모든 악기 소리를 듣자 곧 느부갓네살 왕의 세운 금신상에게 엎드리어 절하니라","reference":"다니엘 3:7","category":"$undefined"},{"id":"21816","book":"다니엘","book_name":"다니엘","chapter":3,"verse":8,"text":"그 때에 어떤 갈대아 사람들이 나아와 유다 사람들을 참소하니라","reference":"다니엘 3:8","category":"$undefined"},{"id":"21817","book":"다니엘","book_name":"다니엘","chapter":3,"verse":9,"text":"그들이 느부갓네살 왕에게 고하여 가로되 왕이여 만세수를 하옵소서","reference":"다니엘 3:9","category":"$undefined"},{"id":"21818","book":"다니엘","book_name":"다니엘","chapter":3,"verse":10,"text":"왕이여 왕이 명령을 내리사 무릇 사람마다 나팔과, 피리와, 수금과, 삼현금과, 양금과, 생황과, 및 모든 악기 소리를 듣거든 엎드리어 금 신상에게 절할 것이라","reference":"다니엘 3:10","category":"$undefined"},{"id":"21819","book":"다니엘","book_name":"다니엘","chapter":3,"verse":11,"text":"누구든지 엎드리어 절하지 아니하는 자는 극렬히 타는 풀무 가운데 던져 넣음을 당하리라 하지 아니하셨나이까 ?","reference":"다니엘 3:11","category":"$undefined"},{"id":"21820","book":"다니엘","book_name":"다니엘","chapter":3,"verse":12,"text":"이제 몇 유다 사람 사드락과 메삭과 아벳느고는 왕이 세워 바벨론 도를 다스리게 하신 자이어늘 왕이여 이 사람들이 왕을 높이지 아니하며 왕의 신들을 섬기지 아니하며 왕이 세우신 금 신상에게 절하지 아니하나이다","reference":"다니엘 3:12","category":"$undefined"},{"id":"21821","book":"다니엘","book_name":"다니엘","chapter":3,"verse":13,"text":"느부갓네살 왕이 노하고 분하여 사드락과 메삭과 아벳느고를 끌어 오라 명하매 드디어 그 사람들을 왕의 앞으로 끌어온지라","reference":"다니엘 3:13","category":"$undefined"},{"id":"21822","book":"다니엘","book_name":"다니엘","chapter":3,"verse":14,"text":"느부갓네살이 그들에게 물어 가로되 사드락,메삭,아벳느고야 너희가 내 신을 섬기지 아니하며 내가 세운 그 신상에게 절하지 아니하니 짐짓 그리하였느냐 ?","reference":"다니엘 3:14","category":"$undefined"},{"id":"21823","book":"다니엘","book_name":"다니엘","chapter":3,"verse":15,"text":"이제라도 너희가 예비하였다가 언제든지 나팔과, 피리와, 수금과, 삼현금과, 양금과, 생황과, 및 모든 악기 소리를 듣거든 내가 만든 신상 앞에 엎드리어 절하면 좋거니와 너희가 만일 절하지 아니하면 즉시 너희를 극렬히 타는 풀무 가운데 던져 넣을 것이니 능히 너희를 내 손에서 건져 낼 신이 어떤 신이겠느냐","reference":"다니엘 3:15","category":"$undefined"},{"id":"21824","book":"다니엘","book_name":"다니엘","chapter":3,"verse":16,"text":"사드락과 메삭과 아벳느고가 왕에게 대답하여 가로되 느부갓네살이여 우리가 이 일에 대하여 왕에게 대답할 필요가 없나이다","reference":"다니엘 3:16","category":"$undefined"},{"id":"21825","book":"다니엘","book_name":"다니엘","chapter":3,"verse":17,"text":"만일 그럴 것이면 왕이여 우리가 섬기는 우리 하나님이 우리를 극렬히 타는 풀무 가운데서 능히 건져 내시겠고 왕의 손에서도 건져내시리이다","reference":"다니엘 3:17","category":"$undefined"},{"id":"21826","book":"다니엘","book_name":"다니엘","chapter":3,"verse":18,"text":"그리 아니하실지라도 ! 왕이여 우리가 왕의 신들을 섬기지도 아니하고 왕의 세우신 금신상에게 절하지도 아니할 줄을 아옵소서","reference":"다니엘 3:18","category":"$undefined"},{"id":"21827","book":"다니엘","book_name":"다니엘","chapter":3,"verse":19,"text":"느부갓네살이 분이 가득하여 사드락과 메삭과 아벳느고를 향하여 낯빛을 변하고 명하여 이르되 그 풀무를 뜨겁게 하기를 평일보다 칠 배나 뜨겁게 하라 하고","reference":"다니엘 3:19","category":"$undefined"},{"id":"21828","book":"다니엘","book_name":"다니엘","chapter":3,"verse":20,"text":"군대 중 용사 몇 사람을 명하여 사드락과 메삭과 아벳느고를 결박하여 극렬히 타는 풀무 가운데 던지라 하니","reference":"다니엘 3:20","category":"$undefined"},{"id":"21829","book":"다니엘","book_name":"다니엘","chapter":3,"verse":21,"text":"이 사람들을 고의와 속옷과 겉옷과 별다른 옷을 입은 채 결박하여 극렬히 타는 풀무 가운데 던질 때에","reference":"다니엘 3:21","category":"$undefined"},{"id":"21830","book":"다니엘","book_name":"다니엘","chapter":3,"verse":22,"text":"왕의 명령이 엄하고 풀무가 심히 뜨거우므로 불꽃이 사드락과 메삭과 아벳느고를 붙든 사람을 태워 죽였고","reference":"다니엘 3:22","category":"$undefined"},{"id":"21831","book":"다니엘","book_name":"다니엘","chapter":3,"verse":23,"text":"이 세 사람 사드락과 메삭과 아벳느고는 결박된 채 극렬히 타는 풀무 가운데 떨어졌더라","reference":"다니엘 3:23","category":"$undefined"},{"id":"21832","book":"다니엘","book_name":"다니엘","chapter":3,"verse":24,"text":"때에 느부갓네살 왕이 놀라 급히 일어나서 모사들에게 물어 가로되 우리가 결박하여 불가운데 던진 자는 세 사람이 아니었느냐 그들이 왕에게 대답하여 가로되 왕이여 옳소이다","reference":"다니엘 3:24","category":"$undefined"},{"id":"21833","book":"다니엘","book_name":"다니엘","chapter":3,"verse":25,"text":"왕이 또 말하여 가로되 내가 보니 결박되지 아니한 네 사람이 불 가운데로 다니는데 상하지도 아니하였고 그 네째의 모양은 신들의 아들과 같도다 하고","reference":"다니엘 3:25","category":"$undefined"},{"id":"21834","book":"다니엘","book_name":"다니엘","chapter":3,"verse":26,"text":"느부갓네살이 극렬히 타는 풀무 아구 가까이 가서 불러 가로되 지극히 높으신 하나님의 종 사드락, 메삭, 아벳느고야 나와서 이리로 오라 하매 사드락과 메삭과 아벳느고가 불 가운데서 나온지라","reference":"다니엘 3:26","category":"$undefined"},{"id":"21835","book":"다니엘","book_name":"다니엘","chapter":3,"verse":27,"text":"방백과 수령과 도백과 왕의 모사들이 모여 이 사람들을 본즉 불이 능히 그 몸을 해하지 못하였고 머리털도 그슬리지 아니하였고 고의 빛도 변하지 아니하였고 불 탄 냄새도 없었더라","reference":"다니엘 3:27","category":"$undefined"},{"id":"21836","book":"다니엘","book_name":"다니엘","chapter":3,"verse":28,"text":"느부갓네살이 말하여 가로되 사드락과 메삭과 아벳느고의 하나님을 찬송할지로다 그가 그 사자를 보내사 자기를 의뢰하고 그 몸을 버려서 왕의 명을 거역하고 그 하나님 밖에는 다른 신을 섬기지 아니하며 그에게 절하지 아니한 종들을 구원하셨도다","reference":"다니엘 3:28","category":"$undefined"},{"id":"21837","book":"다니엘","book_name":"다니엘","chapter":3,"verse":29,"text":"그러므로 내가 이제 조서를 내리노니 각 백성과 각 나라와 각 방언하는 자가 무릇 사드락과 메삭과 아벳느고의 하나님께 설만히 말하거든 그 몸을 쪼개고 그 집으로 거름터를 삼을지니 이는 이 같이 사람을 구원할 다른 신이 없음이니라 하고","reference":"다니엘 3:29","category":"$undefined"},{"id":"21838","book":"다니엘","book_name":"다니엘","chapter":3,"verse":30,"text":"왕이 드디어 사드락과 메삭과 아벳느고를 바벨론 도에서 더욱 높이니라","reference":"다니엘 3:30","category":"$undefined"}],"bookSlug":"daniel"}]
