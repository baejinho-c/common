2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":4,"verses":[{"id":"21839","book":"다니엘","book_name":"다니엘","chapter":4,"verse":1,"text":"느부갓네살 왕은 천하에 거하는 백성들과 나라들과 각 방언하는 자에게 조서하노라 원하노니 너희에게 많은 평강이 있을지어다","reference":"다니엘 4:1","category":"$undefined"},{"id":"21840","book":"다니엘","book_name":"다니엘","chapter":4,"verse":2,"text":"지극히 높으신 하나님이 내게 행하신 이적과 기사를 내가 알게 하기를 즐겨하노라","reference":"다니엘 4:2","category":"$undefined"},{"id":"21841","book":"다니엘","book_name":"다니엘","chapter":4,"verse":3,"text":"크도다, 그 이적이여 능하도다 그 기사여, 그 나라는 영원한 나라요 그 권병은 대대에 이르리로다","reference":"다니엘 4:3","category":"$undefined"},{"id":"21842","book":"다니엘","book_name":"다니엘","chapter":4,"verse":4,"text":"나 느부갓네살이 내 집에 편히 있으며 내 궁에서 평강할 때에","reference":"다니엘 4:4","category":"$undefined"},{"id":"21843","book":"다니엘","book_name":"다니엘","chapter":4,"verse":5,"text":"한 꿈을 꾸고 그로 인하여 두려워하였으되 곧 내 침상에서 생각하는 것과 뇌 속으로 받은 이상을 인하여 번민하였었노라","reference":"다니엘 4:5","category":"$undefined"},{"id":"21844","book":"다니엘","book_name":"다니엘","chapter":4,"verse":6,"text":"이러므로 내가 명을 내려 바벨론 모든 박사를 내 앞으로 불러다가 그 꿈의 해석을 내게 알게 하라 하매","reference":"다니엘 4:6","category":"$undefined"},{"id":"21845","book":"다니엘","book_name":"다니엘","chapter":4,"verse":7,"text":"박수와 술객과 갈대아 술사와 점장이가 들어왔기로 내가 그 꿈을 그들에게 고하였으나 그들이 그 해석을 내게 알게 하지 못하였느니라","reference":"다니엘 4:7","category":"$undefined"},{"id":"21846","book":"다니엘","book_name":"다니엘","chapter":4,"verse":8,"text":"그 후에 다니엘이 내 앞에 들어왔으니 그는 내 신의 이름을 좇아 벨드사살이라 이름한 자요 그의 안에는 거룩한 신들의 영이 있는자라 내가 그에게 꿈을 고하여 가로되","reference":"다니엘 4:8","category":"$undefined"},{"id":"21847","book":"다니엘","book_name":"다니엘","chapter":4,"verse":9,"text":"박수장 벨드사살아 네 안에는 거룩한 신들의 영이 있은즉 아무 은밀한 것이라도 네게는 어려울 것이 없는 줄을 내가 아노니 내 꿈에 본 이상의 해석을 내게 고하라","reference":"다니엘 4:9","category":"$undefined"},{"id":"21848","book":"다니엘","book_name":"다니엘","chapter":4,"verse":10,"text":"내가 침상에서 나의 뇌 속으로 받은 이상이 이러하니라 내가 본즉 땅의 중앙에 한 나무가 있는데 고가 높더니","reference":"다니엘 4:10","category":"$undefined"},{"id":"21849","book":"다니엘","book_name":"다니엘","chapter":4,"verse":11,"text":"그 나무가 자라서 견고하여지고 그 고는 하늘에 닿았으니 땅 끝에서도 보이겠고","reference":"다니엘 4:11","category":"$undefined"},{"id":"21850","book":"다니엘","book_name":"다니엘","chapter":4,"verse":12,"text":"그 잎사귀는 아름답고 그 열매는 많아서 만민의 식물이 될 만하고 들짐승이 그 그늘에 있으며 공중에 나는 새는 그 가지에 깃들이고 무릇 혈기 있는 자가 거기서 식물을 얻더라","reference":"다니엘 4:12","category":"$undefined"},{"id":"21851","book":"다니엘","book_name":"다니엘","chapter":4,"verse":13,"text":"내가 침상에서 뇌 속으로 받은 이상 가운데 또 본즉 한 순찰자 한 거룩한 자가 하늘에서 내려왔는데","reference":"다니엘 4:13","category":"$undefined"},{"id":"21852","book":"다니엘","book_name":"다니엘","chapter":4,"verse":14,"text":"그가 소리 질러 외쳐서 이처럼 이르기를 그 나무를 베고 그 가지를 찍고 그 잎사귀를 떨고 그 열매를 헤치고 짐승들로 그 아래서 떠나게 하고 새들을 그 가지에서 쫓아내라","reference":"다니엘 4:14","category":"$undefined"},{"id":"21853","book":"다니엘","book_name":"다니엘","chapter":4,"verse":15,"text":"그러나 그 뿌리의 그루터기를 땅에 남겨두고 철과 놋줄로 동이고 그것으로 들 청초 가운데 있게 하라 그것이 하늘 이슬에 젖고 땅의 풀 가운데서 짐승으로 더불어 그 분량을 같이 하리라","reference":"다니엘 4:15","category":"$undefined"},{"id":"21854","book":"다니엘","book_name":"다니엘","chapter":4,"verse":16,"text":"또 그 마음은 변하여 인생의 마음 같지 아니하고 짐승의 마음을 받아 일곱 때를 지나리라","reference":"다니엘 4:16","category":"$undefined"},{"id":"21855","book":"다니엘","book_name":"다니엘","chapter":4,"verse":17,"text":"이는 순찰자들의 명령대로요 거룩한 자들의 말대로니 곧 인생으로 지극히 높으신 자가 인간 나라를 다스리시며 자기의 뜻대로 그것을 누구에게든지 주시며 또 지극히 천한 자로 그 위에 세우시는 줄을 알게 하려 함이니라 하였느니라","reference":"다니엘 4:17","category":"$undefined"},{"id":"21856","book":"다니엘","book_name":"다니엘","chapter":4,"verse":18,"text":"나 느부갓네살 왕이 이 꿈을 꾸었나니 너 벨드사살아 그 해석을 밝히 말하라 내 나라 모든 박사가 능히 그 해석을 내게 알게 하지 못하였으나 오직 너는 능히 하리니 이는 거룩한 신들의 영이 네 안에 있음이니라","reference":"다니엘 4:18","category":"$undefined"},{"id":"21857","book":"다니엘","book_name":"다니엘","chapter":4,"verse":19,"text":"벨드사살이라 이름한 다니엘이 얼마 동안 놀라 벙벙하며 마음이 번민하여 하는지라 왕이 그에게 말하여 이르기를 벨드사살아 너는 이 꿈과 그 해석을 인하여 번민할 것이 아니니라 벨드사살이 대답하여 가로되 내 주여 그 꿈은 왕을 미워하는 자에게 응하기를 원하며 그 해석은 왕의 대적에게 응하기를 원하나이다","reference":"다니엘 4:19","category":"$undefined"},{"id":"21858","book":"다니엘","book_name":"다니엘","chapter":4,"verse":20,"text":"왕의 보신 그 나무가 자라서 견고하여지고 그 고는 하늘에 닿았으니 땅 끝에서도 보이겠고","reference":"다니엘 4:20","category":"$undefined"},{"id":"21859","book":"다니엘","book_name":"다니엘","chapter":4,"verse":21,"text":"그 잎사귀는 아름답고 그 열매는 많아서 만민의 식물이 될만하고 들짐승은 그 아래 거하며 공중에 나는 새는 그 가지에 깃들이더라 하시오니","reference":"다니엘 4:21","category":"$undefined"},{"id":"21860","book":"다니엘","book_name":"다니엘","chapter":4,"verse":22,"text":"왕이여 이 나무는 곧 왕이시라 이는 왕이 자라서 견고하여지고 창대하사 하늘에 닿으시며 권세는 땅 끝까지 미치심이니이다","reference":"다니엘 4:22","category":"$undefined"},{"id":"21861","book":"다니엘","book_name":"다니엘","chapter":4,"verse":23,"text":"왕이 보신즉 한 순찰자, 한 거룩한 자가 하늘에서 내려와서 이르기를 그 나무를 베고 멸하라 그러나 그 뿌리의 그루터기는 땅에 남겨두고 철과 놋줄로 동이고 그것을 들 청초 가운데 있게 하라 그것이 하늘 이슬에 젖고 또 들짐승으로 더불어 그 분량을 같이 하며 일곱 때를 지내리라 하더라 하시오니","reference":"다니엘 4:23","category":"$undefined"},{"id":"21862","book":"다니엘","book_name":"다니엘","chapter":4,"verse":24,"text":"왕이여 그 해석은 이러하니이다 곧 지극히 높으신 자의 명정하신 것이 내 주 왕에게 미칠 것이라","reference":"다니엘 4:24","category":"$undefined"},{"id":"21863","book":"다니엘","book_name":"다니엘","chapter":4,"verse":25,"text":"왕이 사람에게서 쫓겨나서 들짐승과 함께 거하며 소처럼 풀을 먹으며 하늘 이슬에 젖을 것이요 이와 같이 일곱 때를 지낼 것이라 그 때에 지극히 높으신 자가 인간 나라를 다스리시며 자기의 뜻대로 그것을 누구에게든지 주시는 줄을 아시리이다","reference":"다니엘 4:25","category":"$undefined"},{"id":"21864","book":"다니엘","book_name":"다니엘","chapter":4,"verse":26,"text":"또 그들이 그 나무 뿌리의 그루터기를 남겨 두라 하였은즉 하나님이 다스리시는 줄을 왕이 깨달은 후에야 왕의 나라가 견고하리이다","reference":"다니엘 4:26","category":"$undefined"},{"id":"21865","book":"다니엘","book_name":"다니엘","chapter":4,"verse":27,"text":"그런즉 왕이여 나의 간하는 것을 받으시고 공의를 행함으로 죄를 속하고 가난한 자를 긍휼히 여김으로 죄악을 속하소서 그리하시면 왕의 평안함이 혹시 장구하리이다 하였느니라","reference":"다니엘 4:27","category":"$undefined"},{"id":"21866","book":"다니엘","book_name":"다니엘","chapter":4,"verse":28,"text":"이 모든 일이 다 나 느부갓네살 왕에게 임하였느니라","reference":"다니엘 4:28","category":"$undefined"},{"id":"21867","book":"다니엘","book_name":"다니엘","chapter":4,"verse":29,"text":"열 두 달이 지난 후에 내가 바벨론 궁 지붕에서 거닐새","reference":"다니엘 4:29","category":"$undefined"},{"id":"21868","book":"다니엘","book_name":"다니엘","chapter":4,"verse":30,"text":"나 왕이 말하여 가로되 이 큰 바벨론은 내가 능력과 권세로 건설하여 나의 도성을 삼고 이것으로 내 위엄의 영광을 나타낸 것이 아니냐 하였더니","reference":"다니엘 4:30","category":"$undefined"},{"id":"21869","book":"다니엘","book_name":"다니엘","chapter":4,"verse":31,"text":"이 말이 오히려 나 왕의 입에 있을 때에 하늘에서 소리가 내려 가로되 느부갓네살 왕아 네게 말하노니 나라의 위가 네게서 떠났느니라","reference":"다니엘 4:31","category":"$undefined"},{"id":"21870","book":"다니엘","book_name":"다니엘","chapter":4,"verse":32,"text":"네가 사람에게서 쫓겨나서 들짐승과 함께 거하며 소처럼 풀을 먹을 것이요 이와 같이 일곱 때를 지내서 지극히 높으신 자가 인간나라를 다스리시며 자기의 뜻대로 그것을 누구에게든지 주시는 줄을 알기까지 이르리라 하더니","reference":"다니엘 4:32","category":"$undefined"},{"id":"21871","book":"다니엘","book_name":"다니엘","chapter":4,"verse":33,"text":"그 동시에 이 일이 나 느부갓네살에게 응하므로 내가 사람에게 쫓겨나서 소처럼 풀을 먹으며 몸이 하늘 이슬에 젖고 머리털이 독수리 털과 같았고 손톱은 새 발톱과 같았었느니라","reference":"다니엘 4:33","category":"$undefined"},{"id":"21872","book":"다니엘","book_name":"다니엘","chapter":4,"verse":34,"text":"그 기한이 차매 나 느부갓네살이 하늘을 우러러 보았더니 내 총명이 다시 내게로 돌아온지라 이에 내가 지극히 높으신 자에게 감사하며 영생하시는 자를 찬양하고 존경하였노니 그 권세는 영원한 권세요 그 나라는 대대로 이르리로다","reference":"다니엘 4:34","category":"$undefined"},{"id":"21873","book":"다니엘","book_name":"다니엘","chapter":4,"verse":35,"text":"땅의 모든 거민을 없는 것 같이 여기시며 하늘의 군사에게든지,땅의 거민에게든지 그는 자기 뜻대로 행하시나니 누가 그의 손을 금하든지 혹시 이르기를 네가 무엇을 하느냐 할 자가 없도다","reference":"다니엘 4:35","category":"$undefined"},{"id":"21874","book":"다니엘","book_name":"다니엘","chapter":4,"verse":36,"text":"그 동시에 내 총명이 내게로 돌아왔고 또 나라 영광에 대하여도 내 위엄과 광명이 내게로 돌아왔고 또 나의 모사들과 관원들이 내게 조회하니 내가 내 나라에서 다시 세움을 입고 또 지극한 위세가 내게 더하였느니라","reference":"다니엘 4:36","category":"$undefined"},{"id":"21875","book":"다니엘","book_name":"다니엘","chapter":4,"verse":37,"text":"그러므로 지금 나 느부갓네살이 하늘의 왕을 찬양하며 칭송하며 존경하노니 그의 일이 다 진실하고 그의 행하심이 의로우시므로 무릇 교만하게 행하는 자를 그가 능히 낮추심이니라","reference":"다니엘 4:37","category":"$undefined"}],"bookSlug":"daniel"}]
