2:["$","$L11",null,{"book":{"id":"daniel","name":"다니엘","chapters":12,"testament":"old"},"chapter":8,"verses":[{"id":"21963","book":"다니엘","book_name":"다니엘","chapter":8,"verse":1,"text":"나 다니엘에게 처음에 나타난 이상 후 벨사살 왕 삼년에 다시 이상이 나타나니라","reference":"다니엘 8:1","category":"$undefined"},{"id":"21964","book":"다니엘","book_name":"다니엘","chapter":8,"verse":2,"text":"내가 이상을 보았는데 내가 그것을 볼 때에 내 몸은 엘람도 수산성에 있었고 내가 이상을 보기는 을래 강변에서니라","reference":"다니엘 8:2","category":"$undefined"},{"id":"21965","book":"다니엘","book_name":"다니엘","chapter":8,"verse":3,"text":"내가 눈을 들어본즉 강 가에 두 뿔 가진 수양이 섰는데 그 두 뿔이 다 길어도 한 뿔은 다른 뿔보다도 길었고 그 긴 것은 나중에 난 것이더라","reference":"다니엘 8:3","category":"$undefined"},{"id":"21966","book":"다니엘","book_name":"다니엘","chapter":8,"verse":4,"text":"내가 본즉 그 수양이 서와 북과 남을 향하여 받으나 그것을 당할 짐승이 하나도 없고 그 손에서 능히 구할 이가 절대로 없으므로 그것이 임의로 행하고 스스로 강대하더라","reference":"다니엘 8:4","category":"$undefined"},{"id":"21967","book":"다니엘","book_name":"다니엘","chapter":8,"verse":5,"text":"내가 생각할 때에 한 수염소가 서편에서부터 와서 온 지면에 두루 다니되 땅에 닿지 아니하며 그 염소 두 눈 사이에는 현저한 뿔이 있더라","reference":"다니엘 8:5","category":"$undefined"},{"id":"21968","book":"다니엘","book_name":"다니엘","chapter":8,"verse":6,"text":"그것이 두 뿔 가진 수양 곧 내가 본바 강가에 섰던 양에게로 나아가되 분노한 힘으로 그것에게로 달려가더니","reference":"다니엘 8:6","category":"$undefined"},{"id":"21969","book":"다니엘","book_name":"다니엘","chapter":8,"verse":7,"text":"내가 본즉 그것이 수양에게로 가까이 나아가서는 더욱 성내어 그 수양을 땅에 엎드러뜨리고 짓밟았으나 능히 수양을 그 손에서 벗어나게 할 이가 없었더라","reference":"다니엘 8:7","category":"$undefined"},{"id":"21970","book":"다니엘","book_name":"다니엘","chapter":8,"verse":8,"text":"수염소가 스스로 심히 강대하여 가더니 강성할 때에 그 큰 뿔이 꺾이고 그 대신에 현저한 뿔 넷이 하늘 사방을 향하여 났더라","reference":"다니엘 8:8","category":"$undefined"},{"id":"21971","book":"다니엘","book_name":"다니엘","chapter":8,"verse":9,"text":"그 중 한 뿔에서 또 작은 뿔 하나가 나서 남편과 동편과 또 영화로운 땅을 향하여 심히 커지더니","reference":"다니엘 8:9","category":"$undefined"},{"id":"21972","book":"다니엘","book_name":"다니엘","chapter":8,"verse":10,"text":"그것이 하늘 군대에 미칠만큼 커져서 그 군대와 별 중에 몇을 땅에 떨어뜨리고 그것을 짓밞고","reference":"다니엘 8:10","category":"$undefined"},{"id":"21973","book":"다니엘","book_name":"다니엘","chapter":8,"verse":11,"text":"또 스스로 높아져서 군대의 주재를 대적하며 그에게 매일 드리는 제사를 제하여 버렸고 그의 성소를 헐었으며","reference":"다니엘 8:11","category":"$undefined"},{"id":"21974","book":"다니엘","book_name":"다니엘","chapter":8,"verse":12,"text":"범죄함을 인하여 백성과 매일 드리는 제사가 그것에게 붙인 바 되었고 그것이 또 진리를 땅에 던지며 자의로 행하여 형통하였더라","reference":"다니엘 8:12","category":"$undefined"},{"id":"21975","book":"다니엘","book_name":"다니엘","chapter":8,"verse":13,"text":"내가 들은즉 거룩한 자가 말하더니 다른 거룩한 자가 그 말하는 자에게 묻되 이상에 나타난바 매일 드리는 제사와 망하게 하는 죄악에 대한 일과 성소와 백성이 내어준바 되며 짓밟힐 일이 어느 때까지 이를꼬 하매","reference":"다니엘 8:13","category":"$undefined"},{"id":"21976","book":"다니엘","book_name":"다니엘","chapter":8,"verse":14,"text":"그가 내게 이르되 이천 삼백 주야까지니 그 때에 성소가 정결하게 함을 입으리라 하였느니라","reference":"다니엘 8:14","category":"$undefined"},{"id":"21977","book":"다니엘","book_name":"다니엘","chapter":8,"verse":15,"text":"나 다니엘이 이 이상을 보고 그 뜻을 알고자 할 때에 사람 모양 같은 것이 내 앞에 섰고","reference":"다니엘 8:15","category":"$undefined"},{"id":"21978","book":"다니엘","book_name":"다니엘","chapter":8,"verse":16,"text":"내가 들은즉 을래 강 두 언덕 사이에서 사람의 목소리가 있어 외쳐 이르되 가브리엘아 이 이상을 이 사람에게 깨닫게 하라 하더니","reference":"다니엘 8:16","category":"$undefined"},{"id":"21979","book":"다니엘","book_name":"다니엘","chapter":8,"verse":17,"text":"그가 나의 선 곳으로 나아왔는데 그 나아올 때에 내가 두려워서 얼굴을 땅에 대고 엎드리매 그가 내게 이르되 인자야 깨달아 알라 이 이상은 정한 때 끝에 관한 것이니라","reference":"다니엘 8:17","category":"$undefined"},{"id":"21980","book":"다니엘","book_name":"다니엘","chapter":8,"verse":18,"text":"그가 내게 말할 때에 내가 얼굴을 땅에 대고 엎드리어 깊이 잠들매 그가 나를 어루만져서 일으켜 세우며","reference":"다니엘 8:18","category":"$undefined"},{"id":"21981","book":"다니엘","book_name":"다니엘","chapter":8,"verse":19,"text":"가로되 진노하시는 때가 마친 후에 될 일을 내가 네게 알게 하리니 이 이상은 정한 때 끝에 관한 일임이니라","reference":"다니엘 8:19","category":"$undefined"},{"id":"21982","book":"다니엘","book_name":"다니엘","chapter":8,"verse":20,"text":"네가 본바 두 뿔 가진 수양은 곧 메대와 바사 왕들이요","reference":"다니엘 8:20","category":"$undefined"},{"id":"21983","book":"다니엘","book_name":"다니엘","chapter":8,"verse":21,"text":"털이 많은 수염소는 곧 헬라 왕이요 두 눈 사이에 있는 큰 뿔은 곧 그 첫째 왕이요","reference":"다니엘 8:21","category":"$undefined"},{"id":"21984","book":"다니엘","book_name":"다니엘","chapter":8,"verse":22,"text":"이 뿔이 꺾이고 그 대신에 네 뿔이 났은즉 그 나라 가운데서 네 나라가 일어나되 그 권세만 못하리라","reference":"다니엘 8:22","category":"$undefined"},{"id":"21985","book":"다니엘","book_name":"다니엘","chapter":8,"verse":23,"text":"이 네 나라 마지막 때에 패역자들이 가득할 즈음에 한 왕이 일어나리니 그 얼굴은 엄장하며 궤휼에 능하며","reference":"다니엘 8:23","category":"$undefined"},{"id":"21986","book":"다니엘","book_name":"다니엘","chapter":8,"verse":24,"text":"그 권세가 강할 것이나 자기의 힘으로 말미암은 것이 아니며 그가 장차 비상하게 파괴를 행하고 자의로 행하여 형통하며 강한 자들과 거룩한 백성을 멸하리라","reference":"다니엘 8:24","category":"$undefined"},{"id":"21987","book":"다니엘","book_name":"다니엘","chapter":8,"verse":25,"text":"그가 꾀를 베풀어 제 손으로 궤휼을 이루고 마음에 스스로 큰 체하며 또 평화한 때에 많은 무리를 멸하며 또 스스로 서서 만왕의 왕을 대적할 것이나 그가 사람의 손을 말미암지 않고 깨어지리라","reference":"다니엘 8:25","category":"$undefined"},{"id":"21988","book":"다니엘","book_name":"다니엘","chapter":8,"verse":26,"text":"이미 말한바 주야에 대한 이상이 확실하니 너는 그 이상을 간수하라 이는 여러 날 후의 일임이니라","reference":"다니엘 8:26","category":"$undefined"},{"id":"21989","book":"다니엘","book_name":"다니엘","chapter":8,"verse":27,"text":"이에 나 다니엘이 혼절하여 수일을 앓다가 일어나서 왕의 일을 보았느니라 내가 그 이상을 인하여 놀랐고 그 뜻을 깨닫는 사람도 없었느니라","reference":"다니엘 8:27","category":"$undefined"}],"bookSlug":"daniel"}]
