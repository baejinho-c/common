2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":1,"verses":[{"id":"4894","book":"신명기","book_name":"신명기","chapter":1,"verse":1,"text":"이는 모세가 요단 저편 숩 맞은편의 아라바 광야 곧 바란과, 도벨과, 라반과, 하세롯과, 디사합 사이에서 이스라엘 무리에게 선포한 말씀이니라","reference":"신명기 1:1","category":"$undefined"},{"id":"4895","book":"신명기","book_name":"신명기","chapter":1,"verse":2,"text":"호렙산에서 세일산을 지나 가데스 바네아에까지 열 하룻 길이었더라","reference":"신명기 1:2","category":"$undefined"},{"id":"4896","book":"신명기","book_name":"신명기","chapter":1,"verse":3,"text":"제 사십년 십일월 그 달 초일일에 모세가 이스라엘 자손에게 여호와께서 그들을 위하여 자기에게 주신 명령을 다 고하였으니","reference":"신명기 1:3","category":"$undefined"},{"id":"4897","book":"신명기","book_name":"신명기","chapter":1,"verse":4,"text":"때는 모세가 헤스본에 거하는 아모리 왕 시혼을 쳐 죽이고 에드레이에서 아스다롯에 거하는 바산 왕 옥을 쳐 죽인 후라","reference":"신명기 1:4","category":"$undefined"},{"id":"4898","book":"신명기","book_name":"신명기","chapter":1,"verse":5,"text":"모세가 요단 저편 모압 땅에서 이 율법 설명하기를 시작하였더라 일렀으되","reference":"신명기 1:5","category":"$undefined"},{"id":"4899","book":"신명기","book_name":"신명기","chapter":1,"verse":6,"text":"우리 하나님 여호와께서 호렙산에서 우리에게 말씀하여 이르시기를 너희가 이 산에서 거한지 오래니","reference":"신명기 1:6","category":"$undefined"},{"id":"4900","book":"신명기","book_name":"신명기","chapter":1,"verse":7,"text":"방향을 돌려 진행하여 아모리 족속의 산지로 가고 그 근지 곳곳으로 가고 아라바와 산지와 평지와 남방과 해변과 가나안 족속의 땅과 레바논과 큰 강 유브라데까지 가라 하셨나니","reference":"신명기 1:7","category":"$undefined"},{"id":"4901","book":"신명기","book_name":"신명기","chapter":1,"verse":8,"text":"여호와께서 너희의 열조 아브라함과 이삭과 야곱에게 맹세하사 그들과 그 후손에게 주리라 하신 땅이 너희 앞에 있으니 들어가서 얻을지니라","reference":"신명기 1:8","category":"$undefined"},{"id":"4902","book":"신명기","book_name":"신명기","chapter":1,"verse":9,"text":"그 때에 내가 너희에게 말하여 이르기를 나는 홀로 너희 짐을 질 수 없도다","reference":"신명기 1:9","category":"$undefined"},{"id":"4903","book":"신명기","book_name":"신명기","chapter":1,"verse":10,"text":"너희 하나님 여호와께서 너희를 번성케 하셨으므로 너희가 오늘날 하늘의 별 같이 많거니와","reference":"신명기 1:10","category":"$undefined"},{"id":"4904","book":"신명기","book_name":"신명기","chapter":1,"verse":11,"text":"너희 열조의 하나님 여호와께서 너희를 현재보다 천배나 많게 하시며 너희에게 허락하신 것과 같이 너희에게 복 주시기를 원하노라 !","reference":"신명기 1:11","category":"$undefined"},{"id":"4905","book":"신명기","book_name":"신명기","chapter":1,"verse":12,"text":"그런즉 나 홀로 어찌 능히 너희의 괴로운 것과 너희의 무거운 짐과 너희의 다툼을 담당할 수 있으랴","reference":"신명기 1:12","category":"$undefined"},{"id":"4906","book":"신명기","book_name":"신명기","chapter":1,"verse":13,"text":"너희의 각 지파에서 지혜와 지식이 있는 유명한 자를 택하라 내가 그들을 세워 너희 두령을 삼으리라 한즉","reference":"신명기 1:13","category":"$undefined"},{"id":"4907","book":"신명기","book_name":"신명기","chapter":1,"verse":14,"text":"너희가 대답하여 이르기를 당신의 말씀대로 하는 것이 좋다 하기에","reference":"신명기 1:14","category":"$undefined"},{"id":"4908","book":"신명기","book_name":"신명기","chapter":1,"verse":15,"text":"내가 너희 지파의 두령으로 지혜가 있는 유명한 자를 취하여 너희의 어른을 삼되 곧 각 지파를 따라 천부장과, 백부장과, 오십부장과, 십부장과, 패장을 삼고","reference":"신명기 1:15","category":"$undefined"},{"id":"4909","book":"신명기","book_name":"신명기","chapter":1,"verse":16,"text":"내가 그 때에 너희 재판장들에게 명하여 이르기를 너희가 너희 형제 중에 송사를 들을 때에 양방간에 공정히 판결 할 것이며 그들 중의 타국인에게도 그리할 것이라","reference":"신명기 1:16","category":"$undefined"},{"id":"4910","book":"신명기","book_name":"신명기","chapter":1,"verse":17,"text":"재판은 하나님께 속한 것인즉 너희는 재판에 외모를 보지 말고 귀천을 일반으로 듣고 사람의 낯을 두려워 말 것이며 스스로 결단하기 어려운 일이거든 내게로 돌리라 내가 들으리라 하였고","reference":"신명기 1:17","category":"$undefined"},{"id":"4911","book":"신명기","book_name":"신명기","chapter":1,"verse":18,"text":"내가 너희의 행할 모든 일을 그 때에 너희에게 다 명하였느니라","reference":"신명기 1:18","category":"$undefined"},{"id":"4912","book":"신명기","book_name":"신명기","chapter":1,"verse":19,"text":"우리 하나님 여호와께서 우리에게 명하신 대로 우리가 호렙산에서 발행하여 너희의 본바 크고 두려운 광야를 지나 아모리 족속 산지 길로 가데스 바네아에 이른 때에","reference":"신명기 1:19","category":"$undefined"},{"id":"4913","book":"신명기","book_name":"신명기","chapter":1,"verse":20,"text":"내가 너희에게 이르기를 우리 하나님 여호와께서 우리에게 주신 아모리 족속의 산지에 너희가 이르렀나니","reference":"신명기 1:20","category":"$undefined"},{"id":"4914","book":"신명기","book_name":"신명기","chapter":1,"verse":21,"text":"너희 하나님 여호와께서 이 땅을 너희 앞에 두셨은즉 너희 열조의 하나님 여호와께서 너희에게 이르신 대로 올라가서 얻으라 두려워 말라 ! 주저하지 말라 ! 한즉","reference":"신명기 1:21","category":"$undefined"},{"id":"4915","book":"신명기","book_name":"신명기","chapter":1,"verse":22,"text":"너희가 다 내 앞으로 나아와 말하기를 우리가 사람을 우리 앞서 보내어 우리를 위하여 그 땅을 정탐하고 어느 길로 올라가야 할 것과 어느 성읍으로 들어가야 할 것을 우리에게 회보케 하자 하기에","reference":"신명기 1:22","category":"$undefined"},{"id":"4916","book":"신명기","book_name":"신명기","chapter":1,"verse":23,"text":"내가 그 말을 선히 여겨 너희 중에서 매 지파에 한 사람씩 열 둘을 택하매","reference":"신명기 1:23","category":"$undefined"},{"id":"4917","book":"신명기","book_name":"신명기","chapter":1,"verse":24,"text":"그들이 앞으로 가서 산지에 올라 에스골 골짜기에 이르러 그 곳을 정탐하고","reference":"신명기 1:24","category":"$undefined"},{"id":"4918","book":"신명기","book_name":"신명기","chapter":1,"verse":25,"text":"그 땅의 과실을 손에 가지고 우리에게로 돌아와서 우리에게 회보하여 이르되 우리의 하나님 여호와께서 우리에게 주시는 땅이 좋더라 하였느니라","reference":"신명기 1:25","category":"$undefined"},{"id":"4919","book":"신명기","book_name":"신명기","chapter":1,"verse":26,"text":"그러나 너희가 올라 가기를 즐겨 아니하고 너희 하나님 여호와의 명을 거역하여","reference":"신명기 1:26","category":"$undefined"},{"id":"4920","book":"신명기","book_name":"신명기","chapter":1,"verse":27,"text":"장막 중에서 원망하여 이르기를 `여호와께서 우리를 미워하시는 고로 아모리 족속의 손에 붙여 멸하시려고 우리를 애굽 땅에서 인도하여 내셨도다","reference":"신명기 1:27","category":"$undefined"},{"id":"4921","book":"신명기","book_name":"신명기","chapter":1,"verse":28,"text":"우리가 어디로 갈꼬 ?' 우리의 형제들이 우리로 낙심케 하여 말하기를 `그 백성은 우리보다 장대하며 그 성읍은 크고 성곽은 하늘에 닿았으며 우리가 또 거기서 아낙 자손을 보았노라 하는도다' 하기로","reference":"신명기 1:28","category":"$undefined"},{"id":"4922","book":"신명기","book_name":"신명기","chapter":1,"verse":29,"text":"내가 너희에게 말하기를 `그들을 무서워 말라 ! 두려워 하지 말라 !","reference":"신명기 1:29","category":"$undefined"},{"id":"4923","book":"신명기","book_name":"신명기","chapter":1,"verse":30,"text":"너희 앞서 행하시는 너희 하나님 여호와께서 애굽에서 너희를 위하여 너희 목전에서 모든 일을 행하신 것 같이 이제도 너희를 위하여 싸우실 것이며","reference":"신명기 1:30","category":"$undefined"},{"id":"4924","book":"신명기","book_name":"신명기","chapter":1,"verse":31,"text":"광야에서도 너희가 당하였거니와 사람이 자기 아들을 안음 같이 너희 하나님 여호와께서 너희의 행로 중에 너희를 안으사 이곳까지 이르게 하셨느니라' 하나","reference":"신명기 1:31","category":"$undefined"},{"id":"4925","book":"신명기","book_name":"신명기","chapter":1,"verse":32,"text":"이 일에 너희가 너희 하나님 여호와를 믿지 아니하였도다","reference":"신명기 1:32","category":"$undefined"},{"id":"4926","book":"신명기","book_name":"신명기","chapter":1,"verse":33,"text":"그는 너희 앞서 행하시며 장막 칠 곳을 찾으시고 밤에는 불로, 낮에는 구름으로 너희의 행할 길을 지시하신 자니라","reference":"신명기 1:33","category":"$undefined"},{"id":"4927","book":"신명기","book_name":"신명기","chapter":1,"verse":34,"text":"여호와께서 너희의 말소리를 들으시고 노하사 맹세하여 가라사대","reference":"신명기 1:34","category":"$undefined"},{"id":"4928","book":"신명기","book_name":"신명기","chapter":1,"verse":35,"text":"이 악한 세대 사람들 중에는 내가 그들의 열조에게 주기로 맹세 한 좋은 땅을 볼 자가 하나도 없으리라","reference":"신명기 1:35","category":"$undefined"},{"id":"4929","book":"신명기","book_name":"신명기","chapter":1,"verse":36,"text":"오직 ! 여분네의 아들 갈렙은 온전히 여호와를 순종하였은즉 그는 그것을 볼것이요 그가 밟은 땅을 내가 그와 그의 자손에게 주리라 하시고","reference":"신명기 1:36","category":"$undefined"},{"id":"4930","book":"신명기","book_name":"신명기","chapter":1,"verse":37,"text":"여호와께서 너희의 연고로 내게도 진노하사 가라사대 너도 그리로 들어가지 못하리라","reference":"신명기 1:37","category":"$undefined"},{"id":"4931","book":"신명기","book_name":"신명기","chapter":1,"verse":38,"text":"너의 종자 눈의 아들 여호수아는 그리로 들어갈 것이니 너는 그를 담대케 하라 그가 이스라엘에게 그 땅을 기업으로 얻게하리라","reference":"신명기 1:38","category":"$undefined"},{"id":"4932","book":"신명기","book_name":"신명기","chapter":1,"verse":39,"text":"또 너희가 사로 잡히리라 하던 너희의 아이들과 당일에 선악을 분변치 못하던 너희 자녀들 그들은 그리로 들어갈 것이라 내가 그 땅을 그들에게 주어 산업이 되게 하리라","reference":"신명기 1:39","category":"$undefined"},{"id":"4933","book":"신명기","book_name":"신명기","chapter":1,"verse":40,"text":"너희는 회정하여 홍해 길로 하여 광야로 들어갈지니라 하시매","reference":"신명기 1:40","category":"$undefined"},{"id":"4934","book":"신명기","book_name":"신명기","chapter":1,"verse":41,"text":"너희가 대답하여 내게 이르기를 `우리가 여호와께 범죄하였사오니 우리 하나님께서 우리에게 명하신 대로 우리가 올라 가서 싸우리이다' 하고 너희가 각각 병기를 띠고 경솔히 산지로 올라가려 할 때에","reference":"신명기 1:41","category":"$undefined"},{"id":"4935","book":"신명기","book_name":"신명기","chapter":1,"verse":42,"text":"여호와께서 내게 이르시되 너는 그들에게 이르기를 너희는 올라가지 말라 싸우지도 말라 내가 너희 중에 있지 아니하니 너희가 대적에게 패할까 하노라 하셨다 하라 하시기로","reference":"신명기 1:42","category":"$undefined"},{"id":"4936","book":"신명기","book_name":"신명기","chapter":1,"verse":43,"text":"내가 너희에게 고하였으나 너희가 듣지 아니하고 여호와의 명을 거역하고 천자히 산지로 올라가매","reference":"신명기 1:43","category":"$undefined"},{"id":"4937","book":"신명기","book_name":"신명기","chapter":1,"verse":44,"text":"그 산지에 거하는 아모리 족속이 너희를 마주 나와서 벌떼같이 너희를 쫓아 세일산에서 쳐서 호르마까지 미친지라","reference":"신명기 1:44","category":"$undefined"},{"id":"4938","book":"신명기","book_name":"신명기","chapter":1,"verse":45,"text":"너희가 돌아와서 여호와 앞에서 통곡하나 여호와께서 너희의 소리를 듣지 아니하시며 너희에게 귀를 기울이지 아니하셨으므로","reference":"신명기 1:45","category":"$undefined"},{"id":"4939","book":"신명기","book_name":"신명기","chapter":1,"verse":46,"text":"너희가 가데스에 여러날동안 거하였었나니 곧 너희가 그 곳에 거하던 날 수대로니라","reference":"신명기 1:46","category":"$undefined"}],"bookSlug":"deuteronomy"}]
