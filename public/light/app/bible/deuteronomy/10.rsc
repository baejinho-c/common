2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":10,"verses":[{"id":"5188","book":"신명기","book_name":"신명기","chapter":10,"verse":1,"text":"그 때에 여호와께서 내게 이르시기를 너는 처음과 같은 두 돌판을 다듬어 가지고 산에 올라 내게로 나아오고 또 나무궤 하나를 만들라","reference":"신명기 10:1","category":"$undefined"},{"id":"5189","book":"신명기","book_name":"신명기","chapter":10,"verse":2,"text":"네가 깨뜨린 처음 판에 쓴 말을 내가 그 판에 쓰리니 너는 그것을 그 궤에 넣으라 하시기로","reference":"신명기 10:2","category":"$undefined"},{"id":"5190","book":"신명기","book_name":"신명기","chapter":10,"verse":3,"text":"내가 싯딤나무로 궤를 만들고 처음 것과 같은 돌판 둘을 다듬어 손에 들고 산에 오르매","reference":"신명기 10:3","category":"$undefined"},{"id":"5191","book":"신명기","book_name":"신명기","chapter":10,"verse":4,"text":"여호와께서 그 총회 날에 산 위 불 가운데서 너희에게 이르신 십계명을 처음과 같이 그 판에 쓰시고 그것을 내게 주시기로","reference":"신명기 10:4","category":"$undefined"},{"id":"5192","book":"신명기","book_name":"신명기","chapter":10,"verse":5,"text":"내가 돌이켜 산에서 내려와서 여호와께서 내게 명하신 대로 그 판을 내가 만든 궤에 넣었더니 지금까지 있느니라","reference":"신명기 10:5","category":"$undefined"},{"id":"5193","book":"신명기","book_name":"신명기","chapter":10,"verse":6,"text":"이스라엘 자손이 브에롯 브네야아간에서 발행하여 모세라에 이르러서는 아론이 거기서 죽고 거기 장사되었고 그 아들 엘르아살이 그를 이어 제사장의 직임을 행하였으며","reference":"신명기 10:6","category":"$undefined"},{"id":"5194","book":"신명기","book_name":"신명기","chapter":10,"verse":7,"text":"또 거기서 발행하여 굿고다에 이르고 굿고다에서 발행하여 욧바다에 이른즉 그 땅에는 시내가 많았었으며","reference":"신명기 10:7","category":"$undefined"},{"id":"5195","book":"신명기","book_name":"신명기","chapter":10,"verse":8,"text":"그 때에 여호와께서 레위 지파를 구별하여 여호와의 언약 궤를 메이며 여호와 앞에 서서 그를 섬기며 또 여호와의 이름으로 축복하게 하셨고 그 일은 오늘날까지 이르느니라","reference":"신명기 10:8","category":"$undefined"},{"id":"5196","book":"신명기","book_name":"신명기","chapter":10,"verse":9,"text":"그러므로 레위는 그 형제 중에 분깃이 없으며 기업이 없고 네 하나님 여호와께서 그에게 말씀하심 같이 여호와가 그의 기업이시니라","reference":"신명기 10:9","category":"$undefined"},{"id":"5197","book":"신명기","book_name":"신명기","chapter":10,"verse":10,"text":"내가 처음과 같이 사십 주야를 산에서 유하였고 그 때에도 여호와께서 내 말을 들으사 너를 참아 멸하지 아니하시고","reference":"신명기 10:10","category":"$undefined"},{"id":"5198","book":"신명기","book_name":"신명기","chapter":10,"verse":11,"text":"여호와께서 내게 이르시되 일어나서 백성 앞서 진행하라 내가 그들에게 주리라고 그 열조에게 맹세한 땅에 그들이 들어가서 그것을 얻으리라 하셨느니라","reference":"신명기 10:11","category":"$undefined"},{"id":"5199","book":"신명기","book_name":"신명기","chapter":10,"verse":12,"text":"이스라엘아 ! 네 하나님 여호와께서 네게 요구하시는 것이 무엇이냐 ? 곧 네 하나님 여호와를 경외하여 그 모든 도를 행하고 그를 사랑하며 마음을 다하고 성품을 다하여 네 하나님 여호와를 섬기고","reference":"신명기 10:12","category":"$undefined"},{"id":"5200","book":"신명기","book_name":"신명기","chapter":10,"verse":13,"text":"내가 오늘날 네 행복을 위하여 네게 명하는 여호와의 명령과 규례를 지킬 것이 아니냐 ?","reference":"신명기 10:13","category":"$undefined"},{"id":"5201","book":"신명기","book_name":"신명기","chapter":10,"verse":14,"text":"하늘과 모든 하늘의 하늘과 땅과 그 위의 만물은 본래 네 하나님 여호와께 속한 것이로되","reference":"신명기 10:14","category":"$undefined"},{"id":"5202","book":"신명기","book_name":"신명기","chapter":10,"verse":15,"text":"여호와께서 오직 네 열조를 기뻐하시고 그들을 사랑하사 그 후손 너희를 만민 중에서 택하셨음이 오늘날과 같으니라","reference":"신명기 10:15","category":"$undefined"},{"id":"5203","book":"신명기","book_name":"신명기","chapter":10,"verse":16,"text":"그러므로 너희는 마음에 할례를 행하고 다시는 목을 곧게 하지 말라","reference":"신명기 10:16","category":"$undefined"},{"id":"5204","book":"신명기","book_name":"신명기","chapter":10,"verse":17,"text":"너희의 하나님 여호와는 신의 신이시요, 주의 주시요, 크고 능하시며 두려우신 하나님이시라 사람을 외모로 보지 아니하시며 뇌물을 받지 아니하시고","reference":"신명기 10:17","category":"$undefined"},{"id":"5205","book":"신명기","book_name":"신명기","chapter":10,"verse":18,"text":"고아와 과부를 위하여 신원하시며 나그네를 사랑하사 그에게 식물과 의복을 주시나니","reference":"신명기 10:18","category":"$undefined"},{"id":"5206","book":"신명기","book_name":"신명기","chapter":10,"verse":19,"text":"너희는 나그네를 사랑하라 ! 전에 너희도 애굽 땅에서 나그네 되었었음이니라","reference":"신명기 10:19","category":"$undefined"},{"id":"5207","book":"신명기","book_name":"신명기","chapter":10,"verse":20,"text":"네 하나님 여호와를 경외하여 그를 섬기며 그에게 친근히 하고 그 이름으로 맹세하라","reference":"신명기 10:20","category":"$undefined"},{"id":"5208","book":"신명기","book_name":"신명기","chapter":10,"verse":21,"text":"그는 네 찬송이시요 ! 네 하나님이시라 ! 네가 목도한 바 이같이 크고 두려운 일을 너를 위하여 행하셨느니라","reference":"신명기 10:21","category":"$undefined"},{"id":"5209","book":"신명기","book_name":"신명기","chapter":10,"verse":22,"text":"애굽에 내려간 네 열조가 겨우 칠십인이었으나 이제는 네 하나님 여호와께서 너를 하늘의 별같이 많게 하셨느니라","reference":"신명기 10:22","category":"$undefined"}],"bookSlug":"deuteronomy"}]
