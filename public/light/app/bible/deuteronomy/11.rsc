2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":11,"verses":[{"id":"5210","book":"신명기","book_name":"신명기","chapter":11,"verse":1,"text":"그런즉 네 하나님 여호와를 사랑하여 그 직임과 법도와 규례와 명령을 항상 지키라 !","reference":"신명기 11:1","category":"$undefined"},{"id":"5211","book":"신명기","book_name":"신명기","chapter":11,"verse":2,"text":"너희의 자녀는 알지도 못하고 보지도 못하였으나 너희가 오늘날 기억할 것은 너희 하나님 여호와의 징계와 그 위엄과 그 강한 손과 펴신 팔과","reference":"신명기 11:2","category":"$undefined"},{"id":"5212","book":"신명기","book_name":"신명기","chapter":11,"verse":3,"text":"애굽에서 그 왕 바로와 그 전국에 행하신 이적과 기사와","reference":"신명기 11:3","category":"$undefined"},{"id":"5213","book":"신명기","book_name":"신명기","chapter":11,"verse":4,"text":"또 여호와께서 애굽 군대와 그 말과 그 병거에 행하신 일 곧 그들이 너희를 따를 때에 홍해 물로 그들을 덮어 멸하사 오늘까지 이른 것과","reference":"신명기 11:4","category":"$undefined"},{"id":"5214","book":"신명기","book_name":"신명기","chapter":11,"verse":5,"text":"또 너희가 이곳에 이르기까지 광야에서 너희에게 행하신 일과","reference":"신명기 11:5","category":"$undefined"},{"id":"5215","book":"신명기","book_name":"신명기","chapter":11,"verse":6,"text":"르우벤 자손 엘리압의 아들 다답과 아비람에게 하신 일 곧 온 이스라엘의 한가운데서 땅으로 입을 열어서 그들과 그 가족과 그 장막과 그를 따르는 모든 샘물을 삼키게 하신 일이라","reference":"신명기 11:6","category":"$undefined"},{"id":"5216","book":"신명기","book_name":"신명기","chapter":11,"verse":7,"text":"너희가 여호와의 행하신 이 모든 큰 일을 목도하였느니라","reference":"신명기 11:7","category":"$undefined"},{"id":"5217","book":"신명기","book_name":"신명기","chapter":11,"verse":8,"text":"그러므로 너희는 내가 오늘날 너희에게 명하는 모든 명령을 지키라 ! 그리하면 너희가 강성할 것이요 너희가 건너가서 얻을 땅에 들어가서 그것을 얻을 것이며","reference":"신명기 11:8","category":"$undefined"},{"id":"5218","book":"신명기","book_name":"신명기","chapter":11,"verse":9,"text":"또 여호와께서 너희의 열조에게 맹세하사 그와 그 후손에게 주리라고 하신 땅 곧 젖과 꿀이 흐르는 땅에서 너희의 날이 장구하리라","reference":"신명기 11:9","category":"$undefined"},{"id":"5219","book":"신명기","book_name":"신명기","chapter":11,"verse":10,"text":"네가 들어가 얻으려 하는 땅은 네가 나온 애굽 땅과 같지 아니하니 거기서는 너희가 파종한 후에 발로 물대기를 채소 밭에 댐과 같이 하였거니와","reference":"신명기 11:10","category":"$undefined"},{"id":"5220","book":"신명기","book_name":"신명기","chapter":11,"verse":11,"text":"너희가 건너가서 얻을 땅은 산과 골짜기가 있어서 하늘에서 내리는 비를 흡수하는 땅이요","reference":"신명기 11:11","category":"$undefined"},{"id":"5221","book":"신명기","book_name":"신명기","chapter":11,"verse":12,"text":"네 하나님 여호와께서 권고하시는 땅이라 세초부터 세말까지 네 하나님 여호와의 눈이 항상 그 위에 있느니라","reference":"신명기 11:12","category":"$undefined"},{"id":"5222","book":"신명기","book_name":"신명기","chapter":11,"verse":13,"text":"내가 오늘날 너희에게 명하는 나의 명령을 너희가 만일 청종하고 너희의 하나님 여호와를 사랑하여 마음을 다하고 성품을 다하여 섬기면","reference":"신명기 11:13","category":"$undefined"},{"id":"5223","book":"신명기","book_name":"신명기","chapter":11,"verse":14,"text":"여호와께서 너희 땅에 이른비, 늦은비를 적당한 때에 내리시리니 너희가 곡식과 포도주와 기름을 얻을 것이요","reference":"신명기 11:14","category":"$undefined"},{"id":"5224","book":"신명기","book_name":"신명기","chapter":11,"verse":15,"text":"또 육축을 위하여 들에 풀이 나게 하시리니 네가 먹고 배부를 것이라","reference":"신명기 11:15","category":"$undefined"},{"id":"5225","book":"신명기","book_name":"신명기","chapter":11,"verse":16,"text":"너희는 스스로 삼가라 두렵건대 마음에 미혹하여 돌이켜 다른 신들을 섬기며 그것에 절하므로","reference":"신명기 11:16","category":"$undefined"},{"id":"5226","book":"신명기","book_name":"신명기","chapter":11,"verse":17,"text":"여호와께서 너희에게 진노하사 하늘을 닫아 비를 내리지 아니하여 땅으로 소산을 내지 않게 하시므로 너희가 여호와의 주신 아름다운 땅에서 속히 멸망할까 하노라","reference":"신명기 11:17","category":"$undefined"},{"id":"5227","book":"신명기","book_name":"신명기","chapter":11,"verse":18,"text":"이러므로 너희는 나의 이 말을 너희 마음과 뜻에 두고 또 그것으로 너희 손목에 매어 기호를 삼고 너희 미간에 붙여 표를 삼으며","reference":"신명기 11:18","category":"$undefined"},{"id":"5228","book":"신명기","book_name":"신명기","chapter":11,"verse":19,"text":"또 그것을 너희의 자녀에게 가르치며 집에 앉았을 때에든지,길에 행할 때에든지, 누웠을 때에든지,일어날 때에든지 이 말씀을 강론하고","reference":"신명기 11:19","category":"$undefined"},{"id":"5229","book":"신명기","book_name":"신명기","chapter":11,"verse":20,"text":"또 네 집 문설주와 바깥 문에 기록하라","reference":"신명기 11:20","category":"$undefined"},{"id":"5230","book":"신명기","book_name":"신명기","chapter":11,"verse":21,"text":"그리하면 여호와께서 너희 열조에게 주리라고 맹세하신 땅에서 너희의 날과 너희 자녀의 날이 많아서 하늘이 땅을 덮는 날의 장구함 같으리라","reference":"신명기 11:21","category":"$undefined"},{"id":"5231","book":"신명기","book_name":"신명기","chapter":11,"verse":22,"text":"너희가 만일 내가 너희에게 명하는 이 모든 명령을 잘 지켜 행하여 너희 하나님 여호와를 사랑하고 그 모든 도를 행하여 그에게 부종하면","reference":"신명기 11:22","category":"$undefined"},{"id":"5232","book":"신명기","book_name":"신명기","chapter":11,"verse":23,"text":"여호와께서 그 모든 나라 백성을 너희 앞에서 다 쫓아내실 것이라 너희가 너희보다 강대한 나라들을 얻을 것인즉","reference":"신명기 11:23","category":"$undefined"},{"id":"5233","book":"신명기","book_name":"신명기","chapter":11,"verse":24,"text":"너희의 발바닥으로 밟는 곳은 다 너희 소유가 되리니 너희의 경계는 곧 광야에서부터 레바논까지와 유브라데 하수라 하는 하수에서 서해까지라","reference":"신명기 11:24","category":"$undefined"},{"id":"5234","book":"신명기","book_name":"신명기","chapter":11,"verse":25,"text":"너희 하나님 여호와께서 너희에게 말씀하신 대로 너희 밟는 모든땅 사람들로 너희를 두려워하고 무서워하게 하시리니 너희를 능히 당할 사람이 없으리라","reference":"신명기 11:25","category":"$undefined"},{"id":"5235","book":"신명기","book_name":"신명기","chapter":11,"verse":26,"text":"내가 오늘날 복과 저주를 너희 앞에 두나니","reference":"신명기 11:26","category":"$undefined"},{"id":"5236","book":"신명기","book_name":"신명기","chapter":11,"verse":27,"text":"너희가 만일 내가 오늘날 너희에게 명하는 너희 하나님 여호와의 명령을 들으면 복이 될 것이요","reference":"신명기 11:27","category":"$undefined"},{"id":"5237","book":"신명기","book_name":"신명기","chapter":11,"verse":28,"text":"너희가 만일 내가 오늘날 너희에게 명하는 도에서 돌이켜 떠나 너희 하나님 여호와의 명령을 듣지 아니하고 본래 알지 못하던 다른 신들을 좇으면 저주를 받으리라 !","reference":"신명기 11:28","category":"$undefined"},{"id":"5238","book":"신명기","book_name":"신명기","chapter":11,"verse":29,"text":"네 하나님 여호와께서 네가 가서 얻을 땅으로 너를 인도하여 들이실 때에 너는 그리심산에서 축복을 선포하고 에발산에서 저주를 선포하라","reference":"신명기 11:29","category":"$undefined"},{"id":"5239","book":"신명기","book_name":"신명기","chapter":11,"verse":30,"text":"이 두 산은 요단강 저편 곧 해 지는 편으로 가는 길 뒤 길갈 맞은편 모레 상수리나무 곁의 아라바에 거하는 가나안 족속의 땅에 있지 아니하냐 ?","reference":"신명기 11:30","category":"$undefined"},{"id":"5240","book":"신명기","book_name":"신명기","chapter":11,"verse":31,"text":"너희가 요단을 건너 너희 하나님 여호와께서 너희에게 주시는 땅에 들어가서 얻으려 하나니 반드시 그것을 얻어 거기 거할지라","reference":"신명기 11:31","category":"$undefined"},{"id":"5241","book":"신명기","book_name":"신명기","chapter":11,"verse":32,"text":"내가 오늘날 너희 앞에 베푸는 모든 규례와 법도를 너희는 지켜 행할지니라 !","reference":"신명기 11:32","category":"$undefined"}],"bookSlug":"deuteronomy"}]
