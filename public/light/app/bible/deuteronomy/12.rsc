2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":12,"verses":[{"id":"5242","book":"신명기","book_name":"신명기","chapter":12,"verse":1,"text":"네 열조의 하나님 여호와께서 네게 주셔서 얻게 하신 땅에서 너희가 평생에 지켜 행할 규례와 법도는 이러하니라","reference":"신명기 12:1","category":"$undefined"},{"id":"5243","book":"신명기","book_name":"신명기","chapter":12,"verse":2,"text":"너희가 쫓아 낼 민족들이 그 신들을 섬기는 곳은 높은 산이든지 작은 산이든지 푸른 나무 아래든지 무론하고 그 모든 곳을 너희가 마땅히 파멸하며","reference":"신명기 12:2","category":"$undefined"},{"id":"5244","book":"신명기","book_name":"신명기","chapter":12,"verse":3,"text":"그 단을 헐며 주상을 깨뜨리며 아세라 상을 불사르고 또 그 조각한 신상들을 찍어서 그 이름을 그곳에서 멸하라","reference":"신명기 12:3","category":"$undefined"},{"id":"5245","book":"신명기","book_name":"신명기","chapter":12,"verse":4,"text":"너희 하나님 여호와에게는 너희가 그처럼 행하지 말고","reference":"신명기 12:4","category":"$undefined"},{"id":"5246","book":"신명기","book_name":"신명기","chapter":12,"verse":5,"text":"오직 너희 하나님 여호와께서 자기 이름을 두시려고 너희 모든 지파 중에서 택하신 곳인 그 거하실 곳으로 찾아 나아가서","reference":"신명기 12:5","category":"$undefined"},{"id":"5247","book":"신명기","book_name":"신명기","chapter":12,"verse":6,"text":"너희 번제와 너희 희생과 너희의 십일조와 너희 손의 거제와 너희 서원제와 낙헌 예물과 너희 우양의 처음 낳은 것들을 너희는 그리로 가져다가 드리고","reference":"신명기 12:6","category":"$undefined"},{"id":"5248","book":"신명기","book_name":"신명기","chapter":12,"verse":7,"text":"거기 곧 너희 하나님 여호와 앞에서 먹고 너희 하나님 여호와께서 너희 손으로 수고한 일에 복 주심을 인하여 너희와 너희 가족이 즐거워할지니라","reference":"신명기 12:7","category":"$undefined"},{"id":"5249","book":"신명기","book_name":"신명기","chapter":12,"verse":8,"text":"우리가 오늘날 여기서는 각기 소견대로 하였거니와 너희가 거기서는 하지 말지니라","reference":"신명기 12:8","category":"$undefined"},{"id":"5250","book":"신명기","book_name":"신명기","chapter":12,"verse":9,"text":"너희가 너희 하나님 여호와의 주시는 안식과 기업에 아직은 이르지 못하였거니와","reference":"신명기 12:9","category":"$undefined"},{"id":"5251","book":"신명기","book_name":"신명기","chapter":12,"verse":10,"text":"너희가 요단을 건너 너희 하나님 여호와께서 너희에게 기업으로 주시는 땅에 거하게 될 때 또는 여호와께서 너희로 너희 사방의 모든 대적을 이기게 하시고 너희에게 안식을 주사 너희로 평안히 거하게 하실 때에","reference":"신명기 12:10","category":"$undefined"},{"id":"5252","book":"신명기","book_name":"신명기","chapter":12,"verse":11,"text":"너희는 너희 하나님 여호와께서 자기 이름을 두시려고 한 곳을 택하실 그 곳으로 나의 명하는 것을 모두 가지고 갈지니 곧 너희 번제와, 너희 희생과, 너희 십일조와, 너희 손의 거제와, 너희가 여호와께 서원하는 모든 아름다운 서원물을 가져가고","reference":"신명기 12:11","category":"$undefined"},{"id":"5253","book":"신명기","book_name":"신명기","chapter":12,"verse":12,"text":"너희와 너희 자녀와 노비와 함께 너희 하나님 여호와 앞에서 즐거워할 것이요 네 성중에 거하는 레위인과도 그리할지니 레위인 은 너희 중에 분깃이나 기업이 없음이니라","reference":"신명기 12:12","category":"$undefined"},{"id":"5254","book":"신명기","book_name":"신명기","chapter":12,"verse":13,"text":"너는 삼가서 네게 보이는 아무 곳에서든지 번제를 드리지 말고","reference":"신명기 12:13","category":"$undefined"},{"id":"5255","book":"신명기","book_name":"신명기","chapter":12,"verse":14,"text":"오직 너희의 한 지파 중에 여호와의 택하실 그 곳에서 너는 번제를 드리고 또 내가 네게 명하는 모든 것을 거기서 행할지니라","reference":"신명기 12:14","category":"$undefined"},{"id":"5256","book":"신명기","book_name":"신명기","chapter":12,"verse":15,"text":"그러나 네 하나님 여호와께서 네게 주신 복을 따라 각 성에서 네 마음에 즐기는 대로 생축을 잡아 그 고기를 먹을 수 있나니 곧 정한 자나 부정한 자를 무론하고 노루나 사슴을 먹음과 같이 먹으려니와","reference":"신명기 12:15","category":"$undefined"},{"id":"5257","book":"신명기","book_name":"신명기","chapter":12,"verse":16,"text":"오직 그 피는 먹지 말고 물 같이 땅에 쏟을 것이며","reference":"신명기 12:16","category":"$undefined"},{"id":"5258","book":"신명기","book_name":"신명기","chapter":12,"verse":17,"text":"너는 곡식과 포도주와 기름의 십일조와 네 우양의 처음 낳은 것과 너의 서원을 갚는 예물과 너의 낙헌 예물과 네 손의 거제물은 너의 각 성에서 먹지 말고","reference":"신명기 12:17","category":"$undefined"},{"id":"5259","book":"신명기","book_name":"신명기","chapter":12,"verse":18,"text":"오직 네 하나님 여호와께서 택하실 곳에서 네 하나님 여호와 앞에서 너는 네 자녀와 노비와 성중에 거하는 레위인과 함께 그것을 먹고 또 네 손으로 수고한 모든 일을 인하여 네 하나님 여호와 앞에서 즐거워하되","reference":"신명기 12:18","category":"$undefined"},{"id":"5260","book":"신명기","book_name":"신명기","chapter":12,"verse":19,"text":"너는 삼가서 네 땅에 거하는 동안에 레위인을 저버리지 말지니라 !","reference":"신명기 12:19","category":"$undefined"},{"id":"5261","book":"신명기","book_name":"신명기","chapter":12,"verse":20,"text":"네 하나님 여호와께서 네게 허락하신 대로 네 지경을 넓히신 후에 네 마음에 고기를 먹고자 하여 이르기를 내가 고기를 먹으리라 하면 네가 무릇 마음에 좋아하는 대로 고기를 먹을 수 있으리니","reference":"신명기 12:20","category":"$undefined"},{"id":"5262","book":"신명기","book_name":"신명기","chapter":12,"verse":21,"text":"만일 네 하나님 여호와께서 자기 이름을 두시려고 택하신 곳이 네게서 멀거든 내가 네게 명한 대로 너는 여호와의 주신 우양을 잡아 너의 각 성에서 네가 무릇 마음에 좋아하는 것을 먹되","reference":"신명기 12:21","category":"$undefined"},{"id":"5263","book":"신명기","book_name":"신명기","chapter":12,"verse":22,"text":"정한 자나 부정한 자를 무론하고 노루나 사슴을 먹음같이 먹을 수 있거니와","reference":"신명기 12:22","category":"$undefined"},{"id":"5264","book":"신명기","book_name":"신명기","chapter":12,"verse":23,"text":"오직 크게 삼가서 그 피는 먹지 말라 ! 피는 그 생명인즉 네가 그 생명을 고기와 아울러 먹지 못하리니","reference":"신명기 12:23","category":"$undefined"},{"id":"5265","book":"신명기","book_name":"신명기","chapter":12,"verse":24,"text":"너는 그것을 먹지 말고 물 같이 땅에 쏟으라 !","reference":"신명기 12:24","category":"$undefined"},{"id":"5266","book":"신명기","book_name":"신명기","chapter":12,"verse":25,"text":"너는 피를 먹지 말라 ! 네가 이같이 여호와께서 의롭게 여기시는 일을 행하면 너와 네 후손이 복을 누리리라 !","reference":"신명기 12:25","category":"$undefined"},{"id":"5267","book":"신명기","book_name":"신명기","chapter":12,"verse":26,"text":"오직 네 성물과 서원물을 여호와께서 택하신 곳으로 가지고 가라","reference":"신명기 12:26","category":"$undefined"},{"id":"5268","book":"신명기","book_name":"신명기","chapter":12,"verse":27,"text":"네가 번제를 드릴 때에는 그 고기와 피를 네 하나님 여호와의 단에 드릴 것이요 다른 제 희생을 드릴 때에는 그 피를 네 하나님 여호와의 단 위에 붓고 그 고기는 먹을지니라","reference":"신명기 12:27","category":"$undefined"},{"id":"5269","book":"신명기","book_name":"신명기","chapter":12,"verse":28,"text":"내가 네게 명하는 이 모든 말을 너는 듣고 지키라 ! 네 하나님 여호와의 목전에 선과 의를 행하면 너와 네 후손에게 영원히 복이 있으리라 !","reference":"신명기 12:28","category":"$undefined"},{"id":"5270","book":"신명기","book_name":"신명기","chapter":12,"verse":29,"text":"네 하나님 여호와께서 네가 들어가서 쫓아낼 그 민족들을 네 앞에서 멸절하시고 너로 그 땅을 얻어 거기 거하게 하실 때에","reference":"신명기 12:29","category":"$undefined"},{"id":"5271","book":"신명기","book_name":"신명기","chapter":12,"verse":30,"text":"너는 스스로 삼가서 네 앞에서 멸망한 그들의 자취를 밟아 올무에 들지 말라 또 그들의 신을 탐구하여 이르기를 이 민족들은 그 신들을 어떻게 위하였는고 나도 그와 같이 하겠다 하지 말라","reference":"신명기 12:30","category":"$undefined"},{"id":"5272","book":"신명기","book_name":"신명기","chapter":12,"verse":31,"text":"네 하나님 여호와께는 네가 그와 같이 행하지 못할 것이라 그들은 여호와의 꺼리시며 가증히 여기시는 일을 그 신들에게 행하여 심지어 그 자녀를 불살라 그 신들에게 드렸느니라","reference":"신명기 12:31","category":"$undefined"},{"id":"5273","book":"신명기","book_name":"신명기","chapter":12,"verse":32,"text":"내가 너희에게 명하는 이 모든 말을 너희는 지켜 행하고 그것에 가감하지 말지니라 !","reference":"신명기 12:32","category":"$undefined"}],"bookSlug":"deuteronomy"}]
