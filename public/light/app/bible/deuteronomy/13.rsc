2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":13,"verses":[{"id":"5274","book":"신명기","book_name":"신명기","chapter":13,"verse":1,"text":"너희 중에 선지자나 꿈 꾸는 자가 일어나서 이적과 기사를 네게 보이고","reference":"신명기 13:1","category":"$undefined"},{"id":"5275","book":"신명기","book_name":"신명기","chapter":13,"verse":2,"text":"네게 말하기를 네가 본래 알지 못하던 다른 신들을 우리가 좇아 섬기자 하며 이적과 기사가 그 말대로 이룰지라도","reference":"신명기 13:2","category":"$undefined"},{"id":"5276","book":"신명기","book_name":"신명기","chapter":13,"verse":3,"text":"너는 그 선지자나 꿈꾸는 자의 말을 청종하지 말라 이는 너희 하나님 여호와께서 너희가 마음을 다하고 성품을 다하여 너희 하나님 여호와를 사랑하는 여부를 알려 하사 너희를 시험하심이니라","reference":"신명기 13:3","category":"$undefined"},{"id":"5277","book":"신명기","book_name":"신명기","chapter":13,"verse":4,"text":"너희는 너희 하나님 여호와를 순종하며 그를 경외하며 그 명령을 지키며 그 목소리를 청종하며 그를 섬기며 그에게 부종하고","reference":"신명기 13:4","category":"$undefined"},{"id":"5278","book":"신명기","book_name":"신명기","chapter":13,"verse":5,"text":"그 선지자나 꿈 꾸는 자는 죽이라 ! 이는 그가 너희로 너희를 애굽 땅에서 인도하여 내시며 종 되었던 집에서 속량하여 취하신 너희 하나님 여호와를 배반케 하려 하며 너희 하나님 여호와께서 네게 행하라 명하신 도에서 너를 꾀어 내려고 말하였음이라 너는 이같이 하여 너희 중에서 악을 제할지니라","reference":"신명기 13:5","category":"$undefined"},{"id":"5279","book":"신명기","book_name":"신명기","chapter":13,"verse":6,"text":"네 동복 형제나 네 자녀나 네 품의 아내나 너와 생명을 함께 하는 친구가 가만히 너를 꾀어 이르기를 너와 네 열조가 알지 못하던 다른 신들","reference":"신명기 13:6","category":"$undefined"},{"id":"5280","book":"신명기","book_name":"신명기","chapter":13,"verse":7,"text":"곧 네 사방에 둘러 있는 민족 혹 네게서 가깝든지 네게서 멀든지 땅 이 끝에서 저 끝까지 있는 민족의 신들을 우리가 가서 섬기자 할지라도","reference":"신명기 13:7","category":"$undefined"},{"id":"5281","book":"신명기","book_name":"신명기","chapter":13,"verse":8,"text":"너는 그를 좇지 말며 듣지 말며 긍휼히 보지 말며 애석히 여기지 말며 덮어 숨기지 말고","reference":"신명기 13:8","category":"$undefined"},{"id":"5282","book":"신명기","book_name":"신명기","chapter":13,"verse":9,"text":"너는 용서없이 그를 죽이되 죽일 때에 네가 먼저 그에게 손을 대고 후에 뭇 백성이 손을 대라","reference":"신명기 13:9","category":"$undefined"},{"id":"5283","book":"신명기","book_name":"신명기","chapter":13,"verse":10,"text":"그는 애굽 땅 종 되었던 집에서 너를 인도하여 내신 네 하나님 여호와에게서 너를 꾀어 떠나게 하려한 자니 너는 돌로 쳐 죽이라 !","reference":"신명기 13:10","category":"$undefined"},{"id":"5284","book":"신명기","book_name":"신명기","chapter":13,"verse":11,"text":"그리하면 온 이스라엘이 듣고 두려워하여 이같은 악을 다시는 너희 중에서 행하지 못하리라","reference":"신명기 13:11","category":"$undefined"},{"id":"5285","book":"신명기","book_name":"신명기","chapter":13,"verse":12,"text":"네 하나님 여호와께서 네게 주어 거하게 하시는 한 성읍에 대하여 네게 소문이 들리기를","reference":"신명기 13:12","category":"$undefined"},{"id":"5286","book":"신명기","book_name":"신명기","chapter":13,"verse":13,"text":"너희 중 어떤 잡류가 일어나서 그 성읍 거민을 유혹하여 이르기를 너희가 알지 못하던 다른 신들을 우리가 가서 섬기자 한다 하거든","reference":"신명기 13:13","category":"$undefined"},{"id":"5287","book":"신명기","book_name":"신명기","chapter":13,"verse":14,"text":"너는 자세히 묻고 살펴보아서 이런 가증한 일이 참 사실로 너희 중에 있으면","reference":"신명기 13:14","category":"$undefined"},{"id":"5288","book":"신명기","book_name":"신명기","chapter":13,"verse":15,"text":"너는 마땅히 그 성읍 거민을 칼날로 죽이고 그 성읍과 그 중에 거하는 모든 것과 그 생축을 칼날로 진멸하고","reference":"신명기 13:15","category":"$undefined"},{"id":"5289","book":"신명기","book_name":"신명기","chapter":13,"verse":16,"text":"또 그 속에서 빼앗아 얻은 물건을 다 거리에 모아 놓고 그 성읍과 그 탈취물 전부를 불살라 네 하나님 여호와께 드릴지니 그 성읍은 영영히 무더기가 되어 다시는 건축됨이 없을 것이니라","reference":"신명기 13:16","category":"$undefined"},{"id":"5290","book":"신명기","book_name":"신명기","chapter":13,"verse":17,"text":"너는 이 진멸할 물건을 조금도 네 손에 대지 말라 그리하면 여호와께서 그 진노를 그치시고 너를 긍휼히 여기시고 자비를 더하사 너의 열조에게 맹세하심 같이 네 수효를 번성케 하실 것이라","reference":"신명기 13:17","category":"$undefined"},{"id":"5291","book":"신명기","book_name":"신명기","chapter":13,"verse":18,"text":"네가 만일 네 하나님 여호와의 말씀을 듣고 오늘날 내가 네게 명하는 그 모든 명령을 지켜 네 하나님 여호와의 목전에 정직을 행하면 이같이 되리라","reference":"신명기 13:18","category":"$undefined"}],"bookSlug":"deuteronomy"}]
