2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":14,"verses":[{"id":"5292","book":"신명기","book_name":"신명기","chapter":14,"verse":1,"text":"너희는 너희 하나님 여호와의 자녀니 죽은 자를 위하여 자기 몸을 베지 말며 눈썹 사이 이마 위의 털을 밀지 말라","reference":"신명기 14:1","category":"$undefined"},{"id":"5293","book":"신명기","book_name":"신명기","chapter":14,"verse":2,"text":"너는 너의 하나님 여호와의 성민이라 여호와께서 지상 만민 중에서 너를 택하여 자기의 기업의 백성을 삼으셨느니라","reference":"신명기 14:2","category":"$undefined"},{"id":"5294","book":"신명기","book_name":"신명기","chapter":14,"verse":3,"text":"너는 가증한 물건은 무엇이든지 먹지 말라 !","reference":"신명기 14:3","category":"$undefined"},{"id":"5295","book":"신명기","book_name":"신명기","chapter":14,"verse":4,"text":"너희의 먹을 만한 짐승은 이러하니 곧 소와, 양과, 염소와,","reference":"신명기 14:4","category":"$undefined"},{"id":"5296","book":"신명기","book_name":"신명기","chapter":14,"verse":5,"text":"사슴과, 노루와, 불그스럼한 사슴과, 산 염소와, 볼기 흰 노루와, 뿔 긴 사슴과, 산양들,","reference":"신명기 14:5","category":"$undefined"},{"id":"5297","book":"신명기","book_name":"신명기","chapter":14,"verse":6,"text":"무릇 짐승 중에 굽이 갈라져 쪽발도 되고 새김질도 하는 것은 너희가 먹을 것이니라","reference":"신명기 14:6","category":"$undefined"},{"id":"5298","book":"신명기","book_name":"신명기","chapter":14,"verse":7,"text":"다만 새김질을 하거나 굽이 갈라진 짐승 중에도 너희가 먹지 못할 것은 이것이니 곧 약대와, 토끼와, 사반 그것들은 새김질을 하나 굽이 갈라지지 아니하였으니 너희에게 부정하고","reference":"신명기 14:7","category":"$undefined"},{"id":"5299","book":"신명기","book_name":"신명기","chapter":14,"verse":8,"text":"돼지는 굽은 갈라졌으나 새김질을 못하므로 너희에게 부정하니 너희는 이런 것의 고기를 먹지 말 것이며 그 사체도 만지지 말 것이니라","reference":"신명기 14:8","category":"$undefined"},{"id":"5300","book":"신명기","book_name":"신명기","chapter":14,"verse":9,"text":"물에 있는 어족 중에 이런 것은 너희가 먹을 것이니 무릇 지느러미와 비늘 있는 것은 너희가 먹을 것이요","reference":"신명기 14:9","category":"$undefined"},{"id":"5301","book":"신명기","book_name":"신명기","chapter":14,"verse":10,"text":"무릇 지느러미와 비늘이 없는 것은 너희가 먹지 말지니 이는 너희에게 부정하니라","reference":"신명기 14:10","category":"$undefined"},{"id":"5302","book":"신명기","book_name":"신명기","chapter":14,"verse":11,"text":"무릇 정한 새는 너희가 먹으려니와","reference":"신명기 14:11","category":"$undefined"},{"id":"5303","book":"신명기","book_name":"신명기","chapter":14,"verse":12,"text":"이런 것은 너희가 먹지 못할지니 곧 독수리와, 솔개와, 어응과,","reference":"신명기 14:12","category":"$undefined"},{"id":"5304","book":"신명기","book_name":"신명기","chapter":14,"verse":13,"text":"매와, 새매와, 매의 종류와,","reference":"신명기 14:13","category":"$undefined"},{"id":"5305","book":"신명기","book_name":"신명기","chapter":14,"verse":14,"text":"까마귀 종류와,","reference":"신명기 14:14","category":"$undefined"},{"id":"5306","book":"신명기","book_name":"신명기","chapter":14,"verse":15,"text":"타조와, 다호마스와, 갈매기와, 새매 종류와,","reference":"신명기 14:15","category":"$undefined"},{"id":"5307","book":"신명기","book_name":"신명기","chapter":14,"verse":16,"text":"올빼미와, 부엉이와, 따오기와,","reference":"신명기 14:16","category":"$undefined"},{"id":"5308","book":"신명기","book_name":"신명기","chapter":14,"verse":17,"text":"당아와, 올응과, 노자와,","reference":"신명기 14:17","category":"$undefined"},{"id":"5309","book":"신명기","book_name":"신명기","chapter":14,"verse":18,"text":"학과, 황새 종류와, 대승과, 박쥐며,","reference":"신명기 14:18","category":"$undefined"},{"id":"5310","book":"신명기","book_name":"신명기","chapter":14,"verse":19,"text":"또 무릇 날기도 하고 기어 다니기도 하는 것은 너희에게 부정하니 너희는 먹지 말 것이나","reference":"신명기 14:19","category":"$undefined"},{"id":"5311","book":"신명기","book_name":"신명기","chapter":14,"verse":20,"text":"무릇 정한 새는 너희가 먹을지니라","reference":"신명기 14:20","category":"$undefined"},{"id":"5312","book":"신명기","book_name":"신명기","chapter":14,"verse":21,"text":"너희는 너희 하나님 여호와의 성민이라 무릇 스스로 죽은 것은 먹지 말 것이니 그것을 성 중에 우거하는 객에게 주어 먹게 하거나 이방인에게 팔아도 가하니라 너는 염소 새끼를 그 어미의 젖에 삶지 말지니라","reference":"신명기 14:21","category":"$undefined"},{"id":"5313","book":"신명기","book_name":"신명기","chapter":14,"verse":22,"text":"너는 마땅히 매년에 토지 소산의 십일조를 드릴 것이며","reference":"신명기 14:22","category":"$undefined"},{"id":"5314","book":"신명기","book_name":"신명기","chapter":14,"verse":23,"text":"네 하나님 여호와 앞 곧 여호와께서 그 이름을 두시려고 택하신 곳에서 네 곡식과 포도주와 기름의 십일조를 먹으며 또 네 우양의 처음 난 것을 먹고 네 하나님 여호와 경외하기를 항상 배울 것이니라","reference":"신명기 14:23","category":"$undefined"},{"id":"5315","book":"신명기","book_name":"신명기","chapter":14,"verse":24,"text":"그러나 네 하나님 여호와께서 그 이름을 두시려고 택하신 곳이 네게서 너무 멀고 행로가 어려워서 그 풍부히 주신 것을 가지고 갈 수 없거든","reference":"신명기 14:24","category":"$undefined"},{"id":"5316","book":"신명기","book_name":"신명기","chapter":14,"verse":25,"text":"그것을 돈으로 바꾸어 그 돈을 싸서 가지고 네 하나님 여호와의 택하신 곳으로 가서","reference":"신명기 14:25","category":"$undefined"},{"id":"5317","book":"신명기","book_name":"신명기","chapter":14,"verse":26,"text":"무릇 네 마음에 좋아하는 것을 그 돈으로 사되 우양이나 포도주나 독주 등 무릇 네 마음에 원하는 것을 구하고 거기 네 하나님 여호와의 앞에서 너와 네 권속이 함께 먹고 즐거워할 것이며","reference":"신명기 14:26","category":"$undefined"},{"id":"5318","book":"신명기","book_name":"신명기","chapter":14,"verse":27,"text":"네 성읍에 거하는 레위인은 너희 중에 분깃이나 기업이 없는 자니 또한 저버리지 말지니라 !","reference":"신명기 14:27","category":"$undefined"},{"id":"5319","book":"신명기","book_name":"신명기","chapter":14,"verse":28,"text":"매 삼년 끝에 그 해 소산의 십분 일을 다 내어 네 성읍에 저축하여","reference":"신명기 14:28","category":"$undefined"},{"id":"5320","book":"신명기","book_name":"신명기","chapter":14,"verse":29,"text":"너희 중에 분깃이나 기업이 없는 레위인과 네 성중에 우거하는 객과 및 고아와 과부들로 와서 먹어 배부르게 하라 그리하면 네 하나님 여호와께서 너의 손으로 하는 범사에 네게 축복을 주시리라 !","reference":"신명기 14:29","category":"$undefined"}],"bookSlug":"deuteronomy"}]
