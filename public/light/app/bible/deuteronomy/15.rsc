2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":15,"verses":[{"id":"5321","book":"신명기","book_name":"신명기","chapter":15,"verse":1,"text":"매 칠년 끝에 면제하라","reference":"신명기 15:1","category":"$undefined"},{"id":"5322","book":"신명기","book_name":"신명기","chapter":15,"verse":2,"text":"면제의 규례는 이러하니라 무릇 그 이웃에게 꾸어준 채주는 그것을 면제하고 그 이웃에게나 그 형제에게 독촉하지 말지니 이 해는 여호와의 면제년이라 칭함이니라","reference":"신명기 15:2","category":"$undefined"},{"id":"5323","book":"신명기","book_name":"신명기","chapter":15,"verse":3,"text":"이방인에게는 네가 독촉하려니와 네 형제에게 꾸인 것은 네 손에서 면제하라","reference":"신명기 15:3","category":"$undefined"},{"id":"5324","book":"신명기","book_name":"신명기","chapter":15,"verse":4,"text":"네가 만일 네 하나님 여호와의 말씀만 듣고 내가 오늘날 네게 명하는 그 명령을 다 지켜 행하면 네 하나님 여호와께서 네게 유업으로 주신 땅에서 네가 정녕 복을 받으리니 너희 중에 가난한 자가 없으리라","reference":"신명기 15:4","category":"$undefined"},{"id":"5325","book":"신명기","book_name":"신명기","chapter":15,"verse":5,"text":"(4절과 같음)","reference":"신명기 15:5","category":"$undefined"},{"id":"5326","book":"신명기","book_name":"신명기","chapter":15,"verse":6,"text":"네 하나님 여호와께서 네게 허락하신 대로 네게 복을 주시리니 네가 여러 나라에 꾸어 줄지라도 너는 꾸지 아니하겠고 네가 여러 나라를 치리할지라도 너는 치리함을 받지 아니하리라","reference":"신명기 15:6","category":"$undefined"},{"id":"5327","book":"신명기","book_name":"신명기","chapter":15,"verse":7,"text":"네 하나님 여호와께서 네게 주신 땅 어느 성읍에서든지 가난한 형제가 너와 함께 거하거든 그 가난한 형제에게 네 마음을 강퍅히 하지 말며 네 손을 움켜 쥐지 말고","reference":"신명기 15:7","category":"$undefined"},{"id":"5328","book":"신명기","book_name":"신명기","chapter":15,"verse":8,"text":"반드시 네 손을 그에게 펴서 그 요구하는 대로 쓸 것을 넉넉히 꾸어주라","reference":"신명기 15:8","category":"$undefined"},{"id":"5329","book":"신명기","book_name":"신명기","chapter":15,"verse":9,"text":"삼가 너는 마음에 악념을 품지 말라 곧 이르기를 제 칠년 면제년이 가까왔다 하고 네 궁핍한 형제에게 악한 눈을 들고 아무 것도 주지 아니하면 그가 너를 여호와께 호소하리니 네가 죄를 얻을 것이라","reference":"신명기 15:9","category":"$undefined"},{"id":"5330","book":"신명기","book_name":"신명기","chapter":15,"verse":10,"text":"너는 반드시 그에게 구제할 것이요 구제할 때에는 아끼는 마음을 품지 말 것이니라 이로 인하여 네 하나님 여호와께서 네 범사와 네 손으로 하는바에 네게 복을 주시리라 !","reference":"신명기 15:10","category":"$undefined"},{"id":"5331","book":"신명기","book_name":"신명기","chapter":15,"verse":11,"text":"땅에는 언제든지 가난한 자가 그치지 아니하겠는고로 내가 네게 명하여 이르노니 너는 반드시 네 경내 네 형제의 곤란한 자와 궁핍한 자에게 네 손을 펼지니라 !","reference":"신명기 15:11","category":"$undefined"},{"id":"5332","book":"신명기","book_name":"신명기","chapter":15,"verse":12,"text":"네 동족 히브리 남자나 히브리 여자가 네게 팔렸다 하자 만일 육년을 너를 섬겼거든 제 칠년에 너는 그를 놓아 자유하게 할 것이요","reference":"신명기 15:12","category":"$undefined"},{"id":"5333","book":"신명기","book_name":"신명기","chapter":15,"verse":13,"text":"그를 놓아 자유하게 할 때에는 공수로 가게 하지 말고","reference":"신명기 15:13","category":"$undefined"},{"id":"5334","book":"신명기","book_name":"신명기","chapter":15,"verse":14,"text":"네 양 무리 중에서와 타작 마당에서와 포도주 틀에서 그에게 후히 줄지니 곧 네 하나님 여호와께서 네게 복을 주신대로 그에게 줄지니라","reference":"신명기 15:14","category":"$undefined"},{"id":"5335","book":"신명기","book_name":"신명기","chapter":15,"verse":15,"text":"너는 애굽 땅 종 되었던 것과 네 하나님 여호와께서 너를 속하셨음을 기억하라 ! 그를 인하여 내가 오늘날 이같이 네게 명하노라","reference":"신명기 15:15","category":"$undefined"},{"id":"5336","book":"신명기","book_name":"신명기","chapter":15,"verse":16,"text":"종이 만일 너와 네 집을 사랑하므로 너와 동거하기를 좋게 여겨 네게 향하여 내가 주인을 떠나지 아니하겠노라 하거든","reference":"신명기 15:16","category":"$undefined"},{"id":"5337","book":"신명기","book_name":"신명기","chapter":15,"verse":17,"text":"송곳을 취하여 그의 귀를 문에 대고 뚫으라 그리하면 그가 영영히 네 종이 되리라 네 여종에게도 일례로 할지니라","reference":"신명기 15:17","category":"$undefined"},{"id":"5338","book":"신명기","book_name":"신명기","chapter":15,"verse":18,"text":"그가 육년 동안에 품군의 삯의 배나 받을 만큼 너를 섬겼은즉 너는 그를 놓아 자유하게 하기를 어렵게 여기지 말라 그리하면 네 하나님 여호와께서 너의 범사에 네게 복을 주시리라 !","reference":"신명기 15:18","category":"$undefined"},{"id":"5339","book":"신명기","book_name":"신명기","chapter":15,"verse":19,"text":"너는 우양의 처음 난 수컷은 구별하여 네 하나님 여호와께 드릴 것이니 네 소의 첫 새끼는 부리지 말고 네 양의 첫 새끼의 털은 깍지 말고","reference":"신명기 15:19","category":"$undefined"},{"id":"5340","book":"신명기","book_name":"신명기","chapter":15,"verse":20,"text":"너와 네 가족이 매년에 여호와의 택하신 곳 네 하나님 여호와 앞에서 먹을지니라","reference":"신명기 15:20","category":"$undefined"},{"id":"5341","book":"신명기","book_name":"신명기","chapter":15,"verse":21,"text":"그러나 그 짐승이 흠이 있어서 절거나 눈이 멀었거나 무슨 흠이 있든지 네 하나님 여호와께 잡아 드리지 못할지니","reference":"신명기 15:21","category":"$undefined"},{"id":"5342","book":"신명기","book_name":"신명기","chapter":15,"verse":22,"text":"네 성 중에서 먹되 부정한 자나 정한 자가 다 같이 먹기를 노루와 사슴을 먹음같이 할 것이요","reference":"신명기 15:22","category":"$undefined"},{"id":"5343","book":"신명기","book_name":"신명기","chapter":15,"verse":23,"text":"오직 피는 먹지 말고 물 같이 땅에 쏟을 지니라","reference":"신명기 15:23","category":"$undefined"}],"bookSlug":"deuteronomy"}]
