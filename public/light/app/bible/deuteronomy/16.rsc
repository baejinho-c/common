2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":16,"verses":[{"id":"5344","book":"신명기","book_name":"신명기","chapter":16,"verse":1,"text":"아빕월을 지켜 네 하나님 여호와의 유월절 예식을 행하라 ! 이는 아빕월에 네 하나님 여호와께서 밤에 너를 애굽에서 인도하여 내셨음이라","reference":"신명기 16:1","category":"$undefined"},{"id":"5345","book":"신명기","book_name":"신명기","chapter":16,"verse":2,"text":"여호와께서 그 이름을 두시려고 택하신 곳에서 우양으로 네 하나님 여호와께 유월절 제사를 드리되","reference":"신명기 16:2","category":"$undefined"},{"id":"5346","book":"신명기","book_name":"신명기","chapter":16,"verse":3,"text":"유교병을 그것과 아울러 먹지 말고 칠일 동안은 무교병 곧 고난의 떡을 그것과 아울러 먹으라 이는 네가 애굽 땅에서 급속히 나왔음이니 이같이 행하여 너의 평생에 항상 네가 애굽 땅에서 나온 날을 기억할 것이니라","reference":"신명기 16:3","category":"$undefined"},{"id":"5347","book":"신명기","book_name":"신명기","chapter":16,"verse":4,"text":"그 칠일 동안에는 네 사경내에 누룩이 보이지 않게 할 것이요 또 네가 첫날 해 질 때에 제사드린 고기를 밤을 지내어 아침까지 두지 말 것이며","reference":"신명기 16:4","category":"$undefined"},{"id":"5348","book":"신명기","book_name":"신명기","chapter":16,"verse":5,"text":"유월절 제사를 네 하나님 여호와께서 네게 주신 각 성에서 드리지 말고","reference":"신명기 16:5","category":"$undefined"},{"id":"5349","book":"신명기","book_name":"신명기","chapter":16,"verse":6,"text":"오직 네 하나님 여호와께서 그 이름을 두시려고 택하신 곳에서 네가 애굽에서 나오던 시각 곧 초저녁 해 질 때에 드리고","reference":"신명기 16:6","category":"$undefined"},{"id":"5350","book":"신명기","book_name":"신명기","chapter":16,"verse":7,"text":"네 하나님 여호와께서 택하신 곳에서 그 고기를 구워먹고 아침에 네 장막으로 돌아갈 것이니라","reference":"신명기 16:7","category":"$undefined"},{"id":"5351","book":"신명기","book_name":"신명기","chapter":16,"verse":8,"text":"너는 육일 동안은 무교병을 먹고 제 칠일에 네 하나님 여호와 앞에 성회로 모이고 아무 노동도 하지 말지니라","reference":"신명기 16:8","category":"$undefined"},{"id":"5352","book":"신명기","book_name":"신명기","chapter":16,"verse":9,"text":"칠주를 계속할지니 곡식에 낫을 대는 첫날부터 칠주를 계수하여","reference":"신명기 16:9","category":"$undefined"},{"id":"5353","book":"신명기","book_name":"신명기","chapter":16,"verse":10,"text":"네 하나님 여호와 앞에 칠칠절을 지키되 네 하나님 여호와께서 네게 복을 주신 대로 네 힘을 헤아려 자원하는 예물을 드리고","reference":"신명기 16:10","category":"$undefined"},{"id":"5354","book":"신명기","book_name":"신명기","chapter":16,"verse":11,"text":"너와 네 자녀와 노비와 네 성중에 거하는 레위인과 및 너희 중에 있는 객과 고아와 과부가 함께 네 하나님 여호와께서 그 이름을 두시려고 택하신 곳에서 네 하나님 여호와 앞에서 즐거워할지니라","reference":"신명기 16:11","category":"$undefined"},{"id":"5355","book":"신명기","book_name":"신명기","chapter":16,"verse":12,"text":"너는 애굽에서 종 되었던 것을 기억하고 이 규례를 지켜 행할지니라 !","reference":"신명기 16:12","category":"$undefined"},{"id":"5356","book":"신명기","book_name":"신명기","chapter":16,"verse":13,"text":"너희 타작 마당과 포도주 틀의 소출을 수장한 후에 칠일동안 초막절을 지킬 것이요","reference":"신명기 16:13","category":"$undefined"},{"id":"5357","book":"신명기","book_name":"신명기","chapter":16,"verse":14,"text":"절기를 지킬 때에는 너와 네 자녀와 노비와 네 성중에 거하는 레위인과 객과 고아와 과부가 함께 연락하되","reference":"신명기 16:14","category":"$undefined"},{"id":"5358","book":"신명기","book_name":"신명기","chapter":16,"verse":15,"text":"네 하나님 여호와께서 택하신 곳에서 너는 칠일 동안 네 하나님 여호와 앞에서 절기를 지키고 네 하나님 여호와께서 네 모든 물산과 네 손을 댄 모든 일에 복 주실 것을 인하여 너는 온전히 즐거워할지니라 !","reference":"신명기 16:15","category":"$undefined"},{"id":"5359","book":"신명기","book_name":"신명기","chapter":16,"verse":16,"text":"너의 중 모든 남자는 일년 삼차 곧 무교절과, 칠칠절과, 초막절에 네 하나님 여호와의 택하신 곳에서 여호와께 보이되 공수로 여호와께 보이지 말고","reference":"신명기 16:16","category":"$undefined"},{"id":"5360","book":"신명기","book_name":"신명기","chapter":16,"verse":17,"text":"각 사람이 네 하나님 여호와의 주신 복을 따라 그 힘대로 물건을 드릴지니라 !","reference":"신명기 16:17","category":"$undefined"},{"id":"5361","book":"신명기","book_name":"신명기","chapter":16,"verse":18,"text":"네 하나님 여호와께서 네게 주시는 각 성에서 네 지파를 따라 재판장과 유사를 둘 것이요 그들은 공의로 백성을 재판할 것이니라","reference":"신명기 16:18","category":"$undefined"},{"id":"5362","book":"신명기","book_name":"신명기","chapter":16,"verse":19,"text":"너는 굽게 판단하지 말며 사람을 외모로 보지 말며 또 뇌물을 받지 말라 뇌물은 지혜자의 눈을 어둡게 하고 의인의 말을 굽게 하느니라","reference":"신명기 16:19","category":"$undefined"},{"id":"5363","book":"신명기","book_name":"신명기","chapter":16,"verse":20,"text":"너는 마땅히 공의만 좇으라 ! 그리하면 네가 살겠고 네 하나님 여호와께서 네게 주시는 땅을 얻으리라","reference":"신명기 16:20","category":"$undefined"},{"id":"5364","book":"신명기","book_name":"신명기","chapter":16,"verse":21,"text":"네 하나님 여호와를 위하여 쌓은 단 곁에 아무 나무로든지 아세라 상을 세우지 말며","reference":"신명기 16:21","category":"$undefined"},{"id":"5365","book":"신명기","book_name":"신명기","chapter":16,"verse":22,"text":"자기를 위하여 주상을 세우지 말라 ! 네 하나님 여호와께서 미워하시느니라 !","reference":"신명기 16:22","category":"$undefined"}],"bookSlug":"deuteronomy"}]
