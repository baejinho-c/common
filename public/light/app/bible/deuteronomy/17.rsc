2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":17,"verses":[{"id":"5366","book":"신명기","book_name":"신명기","chapter":17,"verse":1,"text":"무릇 흠이나 악질이 있는 우양은 네 하나님 여호와께 드리지 말지니 이는 네 하나님 여호와께 가증한 것이 됨이니라","reference":"신명기 17:1","category":"$undefined"},{"id":"5367","book":"신명기","book_name":"신명기","chapter":17,"verse":2,"text":"네 하나님 여호와께서 네게 주시는 어느 성중에서든지 너의 가운데 혹시 어떤 남자나 여자가 네 하나님 여호와의 목전에 악을 행하여 그 언약을 어기고","reference":"신명기 17:2","category":"$undefined"},{"id":"5368","book":"신명기","book_name":"신명기","chapter":17,"verse":3,"text":"가서 다른 신들을 섬겨 그것에게 절하며 내가 명하지 아니한 일월성신에게 절한다 하자","reference":"신명기 17:3","category":"$undefined"},{"id":"5369","book":"신명기","book_name":"신명기","chapter":17,"verse":4,"text":"혹이 그 일을 네게 고하므로 네가 듣거든 자세히 사실하여 볼지니 만일 그 일과 말이 확실하여 이스라엘 중에 이런 가증한 일을 행함이 있으면","reference":"신명기 17:4","category":"$undefined"},{"id":"5370","book":"신명기","book_name":"신명기","chapter":17,"verse":5,"text":"너는 그 악을 행한 남자나 여자를 네 성문으로 끌어내고 돌로 그 남자나 여자를 쳐 죽이되","reference":"신명기 17:5","category":"$undefined"},{"id":"5371","book":"신명기","book_name":"신명기","chapter":17,"verse":6,"text":"죽일 자를 두 사람이나 세 사람의 증거로 죽일 것이요 한 사람의 증거로는 죽이지 말 것이며","reference":"신명기 17:6","category":"$undefined"},{"id":"5372","book":"신명기","book_name":"신명기","chapter":17,"verse":7,"text":"이런 자를 죽임에는 증인이 먼저 그에게 손을 댄 후에 뭇 백성이 손을 댈지니라 너는 이와 같이 하여 너의 중에 악을 제할지니라","reference":"신명기 17:7","category":"$undefined"},{"id":"5373","book":"신명기","book_name":"신명기","chapter":17,"verse":8,"text":"네 성중에서 송사로 다투는 일이 있으되 서로 피를 흘렸거나 다투었거나 구타하였거나 하여 네가 판결하기 어려운 일이 생기거든 너는 일어나 네 하나님 여호와의 택하실 곳으로 올라가서","reference":"신명기 17:8","category":"$undefined"},{"id":"5374","book":"신명기","book_name":"신명기","chapter":17,"verse":9,"text":"레위 사람 제사장과 당시 재판장에게로 나아가서 물으라 그리하면 그들이 어떻게 판결할 것을 네게 가르치리니","reference":"신명기 17:9","category":"$undefined"},{"id":"5375","book":"신명기","book_name":"신명기","chapter":17,"verse":10,"text":"여호와께서 택하신 곳에서 그들이 네게 보이는 판결의 뜻대로 네가 행하되 무릇 그들이 네게 가르치는 대로 삼가 행할 것이니","reference":"신명기 17:10","category":"$undefined"},{"id":"5376","book":"신명기","book_name":"신명기","chapter":17,"verse":11,"text":"곧 그들이 네게 가르치는 법률의 뜻대로 그들이 네게 고하는 판결대로 행할 것이요 그들이 네게 보이는 판결을 어기어서 좌로나 우로나 치우치지 말 것이니라","reference":"신명기 17:11","category":"$undefined"},{"id":"5377","book":"신명기","book_name":"신명기","chapter":17,"verse":12,"text":"사람이 만일 천자히 하고 네 하나님 여호와 앞에 서서 섬기는 제사장이나 재판장을 듣지 아니하거든 그 사람을 죽여 이스라엘 중에서 악을 제하여 버리라","reference":"신명기 17:12","category":"$undefined"},{"id":"5378","book":"신명기","book_name":"신명기","chapter":17,"verse":13,"text":"그리하면 온 백성이 듣고 두려워하여 다시는 천자히 행치 아니하리라","reference":"신명기 17:13","category":"$undefined"},{"id":"5379","book":"신명기","book_name":"신명기","chapter":17,"verse":14,"text":"네가 네 하나님 여호와께서 네게 주시는 땅에 이르러서 그 땅을 얻어 거할 때에 만일 우리도 우리 주위의 열국 같이 우리 위에 왕을 세우리라는 뜻이 나거든","reference":"신명기 17:14","category":"$undefined"},{"id":"5380","book":"신명기","book_name":"신명기","chapter":17,"verse":15,"text":"반드시 네 하나님 여호와의 택하신 자를 네 위에 왕으로 세울 것이며 네 위에 왕을 세우려면 네 형제 중에서 한 사람으로 할 것이요 네 형제 아닌 타국인을 네 위에 세우지 말 것이며","reference":"신명기 17:15","category":"$undefined"},{"id":"5381","book":"신명기","book_name":"신명기","chapter":17,"verse":16,"text":"왕 된 자는 말을 많이 두지 말 것이요 말을 많이 얻으려고 그 백성을 애굽으로 돌아가게 말 것이니 이는 여호와께서 너희에게 이르시기를 너희가 이 후에는 그 길로 다시 돌아가지 말 것이라 하셨음이며","reference":"신명기 17:16","category":"$undefined"},{"id":"5382","book":"신명기","book_name":"신명기","chapter":17,"verse":17,"text":"아내를 많이 두어서 그 마음이 미혹되게 말것이며 은,금을 자기를 위하여 많이 쌓지 말 것이니라","reference":"신명기 17:17","category":"$undefined"},{"id":"5383","book":"신명기","book_name":"신명기","chapter":17,"verse":18,"text":"그가 왕위에 오르거든 레위 사람 제사장 앞에 보관한 이 율법서를 등사하여","reference":"신명기 17:18","category":"$undefined"},{"id":"5384","book":"신명기","book_name":"신명기","chapter":17,"verse":19,"text":"평생에 자기 옆에 두고 읽어서 그 하나님 여호와 경외하기를 배우며 이 율법의 모든 말과 이 규례를 지켜 행할 것이라","reference":"신명기 17:19","category":"$undefined"},{"id":"5385","book":"신명기","book_name":"신명기","chapter":17,"verse":20,"text":"그리하면 그의 마음이 그 형제 위에 교만하지 아니하고 이 명령에서 떠나 좌로나 우로나 치우치지 아니하리니 이스라엘 중에서 그와 그의 자손의 왕위에 있는 날이 장구하리라","reference":"신명기 17:20","category":"$undefined"}],"bookSlug":"deuteronomy"}]
