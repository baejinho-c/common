2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":18,"verses":[{"id":"5386","book":"신명기","book_name":"신명기","chapter":18,"verse":1,"text":"레위 사람 제사장과 레위의 온 지파는 이스라엘 중에 분깃도 없고 기업도 없을지니 그들은 여호와의 화제물과 그 기업을 먹을 것이라","reference":"신명기 18:1","category":"$undefined"},{"id":"5387","book":"신명기","book_name":"신명기","chapter":18,"verse":2,"text":"그들이 그 형제 중에 기업이 없을 것은 그들에게 대하여 말씀하심 같이 여호와께서 그들의 기업이 되심이니라","reference":"신명기 18:2","category":"$undefined"},{"id":"5388","book":"신명기","book_name":"신명기","chapter":18,"verse":3,"text":"제사장이 백성에게서 받을 응식은 이러하니 곧 그 드리는 제물의 우양을 물론하고 그 앞 넓적다리와 두 볼과 위라 이것을 제사장에게 줄 것이요","reference":"신명기 18:3","category":"$undefined"},{"id":"5389","book":"신명기","book_name":"신명기","chapter":18,"verse":4,"text":"또 너의 처음 된 곡식과 포도주와 기름과 너의 처음 깍은 양털을 네가 그에게 줄 것이니","reference":"신명기 18:4","category":"$undefined"},{"id":"5390","book":"신명기","book_name":"신명기","chapter":18,"verse":5,"text":"이는 네 하나님 여호와께서 네 모든 지파 중에서 그를 택하여 내시고 그와 그의 자손으로 영영히 여호와의 이름으로 서서 섬기게 하셨음이니라","reference":"신명기 18:5","category":"$undefined"},{"id":"5391","book":"신명기","book_name":"신명기","chapter":18,"verse":6,"text":"이스라엘 온 땅 어느 성읍에든지 거하는 레위인이 간절한 소원이 있어 그 거한 곳을 떠나 여호와의 택하신 곳에 이르면","reference":"신명기 18:6","category":"$undefined"},{"id":"5392","book":"신명기","book_name":"신명기","chapter":18,"verse":7,"text":"여호와 앞에 선 그 형제 모든 레위인과 일반으로 그 하나님 여호와의 이름으로 섬길 수 있나니","reference":"신명기 18:7","category":"$undefined"},{"id":"5393","book":"신명기","book_name":"신명기","chapter":18,"verse":8,"text":"그 사람의 응식은 그들과 같을 것이요 그 상속 산업을 판 돈은 이 외에 그에게 속할 것이니라","reference":"신명기 18:8","category":"$undefined"},{"id":"5394","book":"신명기","book_name":"신명기","chapter":18,"verse":9,"text":"네 하나님 여호와께서 네게 주시는 땅에 들어가거든 너는 그 민족들의 가증한 행위를 본받지 말 것이니","reference":"신명기 18:9","category":"$undefined"},{"id":"5395","book":"신명기","book_name":"신명기","chapter":18,"verse":10,"text":"그 아들이나 딸을 불 가운데로 지나게 하는 자나 복술자나, 길흉을 말하는 자나, 요술을 하는 자나, 무당이나,","reference":"신명기 18:10","category":"$undefined"},{"id":"5396","book":"신명기","book_name":"신명기","chapter":18,"verse":11,"text":"진언자나, 신접자나, 박수나, 초혼자를 너의 중에 용납하지 말라","reference":"신명기 18:11","category":"$undefined"},{"id":"5397","book":"신명기","book_name":"신명기","chapter":18,"verse":12,"text":"무릇 이런 일을 행하는 자는 여호와께서 가증히 여기시나니 이런 가증한 일로 인하여 네 하나님 여호와께서 그들을 네 앞에서 쫓아 내시느니라","reference":"신명기 18:12","category":"$undefined"},{"id":"5398","book":"신명기","book_name":"신명기","chapter":18,"verse":13,"text":"너는 네 하나님 여호와 앞에 완전하라 !","reference":"신명기 18:13","category":"$undefined"},{"id":"5399","book":"신명기","book_name":"신명기","chapter":18,"verse":14,"text":"네가 쫓아낼 이 민족들은 길흉을 말하는 자나 복술자의 말을 듣거니와 네게는 네 하나님 여호와께서 이런 일을 용납지 아니하시느니라","reference":"신명기 18:14","category":"$undefined"},{"id":"5400","book":"신명기","book_name":"신명기","chapter":18,"verse":15,"text":"네 하나님 여호와께서 너의 중 네 형제 중에서 나와 같은 선지자 하나를 너를 위하여 일으키시리니 너희는 그를 들을지니라","reference":"신명기 18:15","category":"$undefined"},{"id":"5401","book":"신명기","book_name":"신명기","chapter":18,"verse":16,"text":"이것이 곧 네가 총회의 날에 호렙산에서 너의 하나님 여호와께 구한 것이라 곧 네가 말하기를 나로 다시는 나의 하나님 여호와의 음성을 듣지 않게 하시고 다시는 이 큰 불을 보지 않게 하소서 두렵건대 내가 죽을까 하나이다 하매","reference":"신명기 18:16","category":"$undefined"},{"id":"5402","book":"신명기","book_name":"신명기","chapter":18,"verse":17,"text":"여호와께서 이르시되 그들의 말이 옳도다","reference":"신명기 18:17","category":"$undefined"},{"id":"5403","book":"신명기","book_name":"신명기","chapter":18,"verse":18,"text":"내가 그들의 형제 중에 너와 같은 선지자 하나를 그들을 위하여 일으키고 내 말을 그 입에 두리니 내가 그에게 명하는 것을 그가 우리에게 다 고하리라","reference":"신명기 18:18","category":"$undefined"},{"id":"5404","book":"신명기","book_name":"신명기","chapter":18,"verse":19,"text":"무릇 그가 내 이름으로 고하는 내 말을 듣지 아니하는 자는 내게 벌을 받을 것이요","reference":"신명기 18:19","category":"$undefined"},{"id":"5405","book":"신명기","book_name":"신명기","chapter":18,"verse":20,"text":"내가 고하라고 명하지 아니한 말을 어떤 선지자가 만일 방자히 내 이름으로 고하든지 다른 신들의 이름으로 말하면 그 선지자는 죽임을 당하리라 하셨느니라","reference":"신명기 18:20","category":"$undefined"},{"id":"5406","book":"신명기","book_name":"신명기","chapter":18,"verse":21,"text":"네가 혹시 심중에 이르기를 그 말이 여호와의 이르신 말씀인지 우리가 어떻게 알리요 하리라","reference":"신명기 18:21","category":"$undefined"},{"id":"5407","book":"신명기","book_name":"신명기","chapter":18,"verse":22,"text":"만일 선지자가 있어서 여호와의 이름으로 말한 일에 증험도 없고 성취함도 없으면 이는 여호와의 말씀하신 것이 아니요 그 선지자가 방자히 한 말이니 너는 그를 두려워 말지니라","reference":"신명기 18:22","category":"$undefined"}],"bookSlug":"deuteronomy"}]
