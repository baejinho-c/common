2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":19,"verses":[{"id":"5408","book":"신명기","book_name":"신명기","chapter":19,"verse":1,"text":"네 하나님 여호와께서 이 열국을 멸절하시고 네 하나님 여호와께서 그 땅을 네게 주시므로 네가 필경 그것을 얻고 그들의 각 성읍과 각 가옥에 거할 때에","reference":"신명기 19:1","category":"$undefined"},{"id":"5409","book":"신명기","book_name":"신명기","chapter":19,"verse":2,"text":"네 하나님 여호와께서 네게 기업으로 주신 땅 가운데서 세 성읍을 너를 위하여 구별하고","reference":"신명기 19:2","category":"$undefined"},{"id":"5410","book":"신명기","book_name":"신명기","chapter":19,"verse":3,"text":"네 하나님 여호와께서 네게 유업으로 주시는 땅의 전체를 삼구로 분하여 그 도로를 닦고 무릇 살인자를 그 성읍으로 도피케 하라","reference":"신명기 19:3","category":"$undefined"},{"id":"5411","book":"신명기","book_name":"신명기","chapter":19,"verse":4,"text":"살인자가 그리로 도피하여 살 만한 경위는 이러하니 곧 누구든지 본래 혐원이 없이 부지중에 그 이웃을 죽인 일,","reference":"신명기 19:4","category":"$undefined"},{"id":"5412","book":"신명기","book_name":"신명기","chapter":19,"verse":5,"text":"가령 사람이 그 이웃과 함께 벌목하러 삼림에 들어가서 손에 도끼를 들고 벌목하려고 찍을 때에 도끼가 자루에서 빠져 그 이웃을 맞춰 그로 죽게함 같은 것이라 이런 사람은 그 성읍 중 하나로 도피하여 생명을 보존할 것이니라","reference":"신명기 19:5","category":"$undefined"},{"id":"5413","book":"신명기","book_name":"신명기","chapter":19,"verse":6,"text":"그 사람이 그에게 본래 혐원이 없으니 죽이기에 합당치 아니하나 두렵건대 보수자의 마음이 뜨거워서 살인자를 따르는데 그 가는 길이 멀면 그를 따라 미쳐서 죽일까 하노라","reference":"신명기 19:6","category":"$undefined"},{"id":"5414","book":"신명기","book_name":"신명기","chapter":19,"verse":7,"text":"그러므로 내가 네게 명하기를 세 성읍을 너를 위하여 구별하라 하노라","reference":"신명기 19:7","category":"$undefined"},{"id":"5415","book":"신명기","book_name":"신명기","chapter":19,"verse":8,"text":"네 하나님 여호와께서 네 열조에게 맹세하신 대로 네 지경을 넓혀 네 열조에게 주리라고 말씀하신 땅을 다 네게 주실 때","reference":"신명기 19:8","category":"$undefined"},{"id":"5416","book":"신명기","book_name":"신명기","chapter":19,"verse":9,"text":"또 네가 나의 오늘날 네게 명하는 이 모든 명령을 지켜 행하여 네 하나님 여호와를 사랑하고 항상 그 길로 행할 때에는 이 셋 외에 세 성읍을 더하여","reference":"신명기 19:9","category":"$undefined"},{"id":"5417","book":"신명기","book_name":"신명기","chapter":19,"verse":10,"text":"네 하나님 여호와께서 네게 기업으로 주시는 땅에서 무죄한 피를 흘림이 없게 하라 이같이 하면 그 피가 네게로 돌아가지 아니하리라","reference":"신명기 19:10","category":"$undefined"},{"id":"5418","book":"신명기","book_name":"신명기","chapter":19,"verse":11,"text":"그러나 만일 사람이 그 이웃을 미워하여 엎드려 그를 기다리다가 일어나 쳐서 그 생명을 상하여 죽게 하고 이 한 성읍으로 도피하거든","reference":"신명기 19:11","category":"$undefined"},{"id":"5419","book":"신명기","book_name":"신명기","chapter":19,"verse":12,"text":"그 본 성읍 장로들이 사람을 보내어 그를 거기서 잡아다가 보수자의 손에 넘겨 죽이게 할 것이라","reference":"신명기 19:12","category":"$undefined"},{"id":"5420","book":"신명기","book_name":"신명기","chapter":19,"verse":13,"text":"네 눈이 그를 긍휼히 보지 말고 무죄한 피 흘린 죄를 이스라엘에서 제하라 ! 그리하면 네게 복이 있으리라 !","reference":"신명기 19:13","category":"$undefined"},{"id":"5421","book":"신명기","book_name":"신명기","chapter":19,"verse":14,"text":"네 하나님 여호와께서 네게 주어 얻게 하시는 땅 곧 네 기업된 소유의 땅에서 선인(先人)의 정한 네 이웃의 경계표를 이동하지 말지니라","reference":"신명기 19:14","category":"$undefined"},{"id":"5422","book":"신명기","book_name":"신명기","chapter":19,"verse":15,"text":"사람이 아무 악이든지 무릇 범한 죄는 한 증인으로만 정할 것이 아니요 두 증인의 입으로나 세 증인의 입으로 그 사건을 확정할 것이며","reference":"신명기 19:15","category":"$undefined"},{"id":"5423","book":"신명기","book_name":"신명기","chapter":19,"verse":16,"text":"만일 위증하는 자가 있어 아무 사람이 악을 행하였다 말함이 있으면","reference":"신명기 19:16","category":"$undefined"},{"id":"5424","book":"신명기","book_name":"신명기","chapter":19,"verse":17,"text":"그 논쟁하는 양방이 같이 하나님 앞에 나아가 당시 제사장과 재판장 앞에 설 것이요","reference":"신명기 19:17","category":"$undefined"},{"id":"5425","book":"신명기","book_name":"신명기","chapter":19,"verse":18,"text":"재판장은 자세히 사실하여 그 증인이 위증인이라 그 형제를 거짓으로 무함한 것이 판명되거든","reference":"신명기 19:18","category":"$undefined"},{"id":"5426","book":"신명기","book_name":"신명기","chapter":19,"verse":19,"text":"그가 그 형제에게 행하려고 꾀 한대로 그에게 행하여 너희 중에서 악을 제하라 !","reference":"신명기 19:19","category":"$undefined"},{"id":"5427","book":"신명기","book_name":"신명기","chapter":19,"verse":20,"text":"그리하면 그 남은 자들이 듣고 두려워하여 이후부터는 이런 악을 너희 중에서 다시 행하지 아니하리라","reference":"신명기 19:20","category":"$undefined"},{"id":"5428","book":"신명기","book_name":"신명기","chapter":19,"verse":21,"text":"네 눈이 긍휼히 보지 말라 생명은 생명으로, 눈은 눈으로, 이는 이로, 손은 손으로, 발은 발로니라","reference":"신명기 19:21","category":"$undefined"}],"bookSlug":"deuteronomy"}]
