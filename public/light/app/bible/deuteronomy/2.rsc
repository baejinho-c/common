2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":2,"verses":[{"id":"4940","book":"신명기","book_name":"신명기","chapter":2,"verse":1,"text":"우리가 회정하여 여호와께서 내게 명하신 대로 홍해 길로 광야에 들어가서 여러날 동안 세일 산을 두루 행하더니","reference":"신명기 2:1","category":"$undefined"},{"id":"4941","book":"신명기","book_name":"신명기","chapter":2,"verse":2,"text":"여호와께서 내게 고하여 이르시되","reference":"신명기 2:2","category":"$undefined"},{"id":"4942","book":"신명기","book_name":"신명기","chapter":2,"verse":3,"text":"너희가 이 산을 두루 행한지 오래니 돌이켜 북으로 나아가라","reference":"신명기 2:3","category":"$undefined"},{"id":"4943","book":"신명기","book_name":"신명기","chapter":2,"verse":4,"text":"너는 또 백성에게 명하여 이르기를 너희는 세일에 거하는 너희 동족 에서의 자손의 지경으로 지날진대 그들이 너희를 두려워하리니 너희는 깊이 스스로 삼가고","reference":"신명기 2:4","category":"$undefined"},{"id":"4944","book":"신명기","book_name":"신명기","chapter":2,"verse":5,"text":"그들과 다투지 말라 그들의 땅은 한 발자국도 너희에게 주지 아니하리니 이는 내가 세일산을 에서에게 기업으로 주었음이로라","reference":"신명기 2:5","category":"$undefined"},{"id":"4945","book":"신명기","book_name":"신명기","chapter":2,"verse":6,"text":"너희는 돈으로 그들에게서 양식을 사서 먹으며 돈으로 그들에게서 물을 사서 마시라","reference":"신명기 2:6","category":"$undefined"},{"id":"4946","book":"신명기","book_name":"신명기","chapter":2,"verse":7,"text":"네 하나님 여호와가 너의 하는 모든 일에 네게 복을 주고 네가 이 큰 광야에 두루 행함을 알고 네 하나님 여호와가 이 사십년 동안을 너와 함께 하였으므로 네게 부족함이 없었느니라 하셨다 하라 하시기로","reference":"신명기 2:7","category":"$undefined"},{"id":"4947","book":"신명기","book_name":"신명기","chapter":2,"verse":8,"text":"우리가 세일 산에 거하는 우리 동족 에서의 자손을 떠나서 아라바를 지나며 엘랏과 에시온 게벨 곁으로 지나 행하고 돌이켜 모압 광야 길로 진행할 때에","reference":"신명기 2:8","category":"$undefined"},{"id":"4948","book":"신명기","book_name":"신명기","chapter":2,"verse":9,"text":"여호와께서 내게 이르시되 모압을 괴롭게 말라 그와 싸우지도 말라 그 땅을 내가 네게 기업으로 주지 아니하리니 이는 내가 롯 자손에게 아르를 기업으로 주었음이로라","reference":"신명기 2:9","category":"$undefined"},{"id":"4949","book":"신명기","book_name":"신명기","chapter":2,"verse":10,"text":"옛적에 엠 사람이 거기 거하여 강하고 많고 아낙 족속과 같이 키가 크므로","reference":"신명기 2:10","category":"$undefined"},{"id":"4950","book":"신명기","book_name":"신명기","chapter":2,"verse":11,"text":"그들을 아낙 족속과 같이 르바임이라 칭하였으나 모압 사람은 그들을 에밈이라 칭하였으며","reference":"신명기 2:11","category":"$undefined"},{"id":"4951","book":"신명기","book_name":"신명기","chapter":2,"verse":12,"text":"호리 사람도 세일에 거하였더니 에서의 자손이 그들을 멸하고 대신하여 그 땅에 거하였으니 이스라엘이 여호와의 주신 기업의 땅에서 행한 것과 일반이었느니라","reference":"신명기 2:12","category":"$undefined"},{"id":"4952","book":"신명기","book_name":"신명기","chapter":2,"verse":13,"text":"이제 너희는 일어나서 세렛 시내를 건너가라 하시기로 우리가 세렛 시내를 건넜으니","reference":"신명기 2:13","category":"$undefined"},{"id":"4953","book":"신명기","book_name":"신명기","chapter":2,"verse":14,"text":"이제 너희는 일어나서 세렛 시내를 건너가라 하시기로 우리가 세렛 시내를 건넜으니","reference":"신명기 2:14","category":"$undefined"},{"id":"4954","book":"신명기","book_name":"신명기","chapter":2,"verse":15,"text":"가데스 바네아에서 떠나 세렛 시내를 건너기까지 삼십 팔년 동안이라 이 때에는 그 시대의 모든 군인들이 여호와께서 그들에게 맹세하신대로 진 중에서 다 멸절되었나니","reference":"신명기 2:15","category":"$undefined"},{"id":"4955","book":"신명기","book_name":"신명기","chapter":2,"verse":16,"text":"여호와께서 손으로 그들을 치사 진 중에서 멸하신 고로 필경은 다 멸절되었느니라","reference":"신명기 2:16","category":"$undefined"},{"id":"4956","book":"신명기","book_name":"신명기","chapter":2,"verse":17,"text":"모든 군인이 사망하여 백성 중에서 진멸된 후에","reference":"신명기 2:17","category":"$undefined"},{"id":"4957","book":"신명기","book_name":"신명기","chapter":2,"verse":18,"text":"여호와께서 내게 일러 가라사대","reference":"신명기 2:18","category":"$undefined"},{"id":"4958","book":"신명기","book_name":"신명기","chapter":2,"verse":19,"text":"내가 오늘 모압 변경 아르를 지나리니","reference":"신명기 2:19","category":"$undefined"},{"id":"4959","book":"신명기","book_name":"신명기","chapter":2,"verse":20,"text":"암몬 족속에게 가까이 이르거든 그들을 괴롭게 말라 그들과 다투지도 말라 암몬 족속의 땅은 내가 네게 기업으로 주지 아니하리니 이는 내가 그것을 롯 자손에게 기업으로 주었음이로라","reference":"신명기 2:20","category":"$undefined"},{"id":"4960","book":"신명기","book_name":"신명기","chapter":2,"verse":21,"text":"(이곳도 르바임의 땅이라 하였었나니 전에 르바임이 거기 거하였었음이요 암몬 족속은 그들을 삼숨밈이라 일컬었었으며","reference":"신명기 2:21","category":"$undefined"},{"id":"4961","book":"신명기","book_name":"신명기","chapter":2,"verse":22,"text":"그 백성은 강하고 많고 아낙 족속과 같이 키가 크나 여호와께서 암몬 족속 앞에서 그들을 멸하셨으므로 암몬 족속이 대신하여 그 땅에 거하였으니","reference":"신명기 2:22","category":"$undefined"},{"id":"4962","book":"신명기","book_name":"신명기","chapter":2,"verse":23,"text":"마치 세일에 거한에서 자손 앞에 호리 사람을 멸하심과 일반이라 그들이 호리 사람을 쫓아 내고 대신하여 오늘까지 거기 거하였으며","reference":"신명기 2:23","category":"$undefined"},{"id":"4963","book":"신명기","book_name":"신명기","chapter":2,"verse":24,"text":"또 갑돌에서 나온 갑돌 사람이 가사까지 각 촌에 거하는 아위 사람을 멸하고 그들을 대신하여 거기 거하였었느니라)","reference":"신명기 2:24","category":"$undefined"},{"id":"4964","book":"신명기","book_name":"신명기","chapter":2,"verse":25,"text":"너희는 일어나 진행하여 아르논 골짜기를 건너라 내가 헤스본 왕 아모리 사람 시혼과 그 땅을 네 손에 붙였은즉 비로소 더불어 싸워서 그 땅을 얻으라","reference":"신명기 2:25","category":"$undefined"},{"id":"4965","book":"신명기","book_name":"신명기","chapter":2,"verse":26,"text":"오늘부터 내가 천하 만민으로 너를 무서워하며 너를 두려워하게 하리니 그들이 네 명성을 듣고 떨며 너로 인하여 근심하리라 하셨느니라","reference":"신명기 2:26","category":"$undefined"},{"id":"4966","book":"신명기","book_name":"신명기","chapter":2,"verse":27,"text":"내가 그데못 광야에서 헤스본 왕 시혼에게 사자를 보내어 평화의 말로 이르기를","reference":"신명기 2:27","category":"$undefined"},{"id":"4967","book":"신명기","book_name":"신명기","chapter":2,"verse":28,"text":"나를 네 땅으로 통과하게 하라 내가 대로로만 행하고 좌로나 우로나 치우치지 아니하리라","reference":"신명기 2:28","category":"$undefined"},{"id":"4968","book":"신명기","book_name":"신명기","chapter":2,"verse":29,"text":"너는 돈을 받고 양식을 팔아 나로 먹게 하고 돈을 받고 물을 주어 나로 마시게 하라 나는 도보로 지날 뿐인즉","reference":"신명기 2:29","category":"$undefined"},{"id":"4969","book":"신명기","book_name":"신명기","chapter":2,"verse":30,"text":"세일에 거하는 에서 자손과 아르에 거하는 모압 사람이 내게 행한 것 같이 하라 그리하면 내가 요단을 건너서 우리 하나님 여호와께서 우리에게 주시는 땅에 이르리라 하나","reference":"신명기 2:30","category":"$undefined"},{"id":"4970","book":"신명기","book_name":"신명기","chapter":2,"verse":31,"text":"헤스본 왕 시혼이 우리의 통과하기를 허락지 아니하였으니 이는 너의 하나님 여호와께서 그를 네 손에 붙이시려고 그 성품을 완강케 하셨고 그 마음을 강퍅케 하셨음이라 오늘날과 같으니라","reference":"신명기 2:31","category":"$undefined"},{"id":"4971","book":"신명기","book_name":"신명기","chapter":2,"verse":32,"text":"때에 여호와께서 내게 이르시되 내가 비로소 시혼과 그 땅을 네게 붙이노니 너는 이제부터 그 땅을 얻어서 기업으로 삼으라 하시더니","reference":"신명기 2:32","category":"$undefined"},{"id":"4972","book":"신명기","book_name":"신명기","chapter":2,"verse":33,"text":"시혼이 그 모든 백성을 거느리고 나와서 우리를 대적하여 야하스에서 싸울 때에","reference":"신명기 2:33","category":"$undefined"},{"id":"4973","book":"신명기","book_name":"신명기","chapter":2,"verse":34,"text":"우리 하나님 여호와께서 그를 우리에게 붙이시매 우리가 그와 그 아들들과 그 모든 백성을 쳤고","reference":"신명기 2:34","category":"$undefined"},{"id":"4974","book":"신명기","book_name":"신명기","chapter":2,"verse":35,"text":"그 때에 우리가 그 모든 성읍을 취하고 그 각 성읍을 그 남녀와 유아와 함께 하나도 남기지 아니하고 진멸하였고","reference":"신명기 2:35","category":"$undefined"},{"id":"4975","book":"신명기","book_name":"신명기","chapter":2,"verse":36,"text":"오직 그 육축과 성읍에서 탈취한 것은 우리의 소유로 삼았으며","reference":"신명기 2:36","category":"$undefined"},{"id":"4976","book":"신명기","book_name":"신명기","chapter":2,"verse":37,"text":"우리 하나님 여호와께서 그 모든 땅을 우리에게 붙이심으로 아르논 골짜기 가에 있는 아로엘과 골짜기 가운데 있는 성읍으로부터 길르앗에까지 우리가 모든 높은 성읍을 취하지 못한 것이 하나도 없었으나 [ (Deuteronomy 2:38) 오직 암몬 족속의 땅 얍복강 가와 산지에 있는 성읍들과 무릇 우리 하나님 여호와께서 우리의 가기를 금하신 곳은 네가 가까이 하지 못하였느니라 ]","reference":"신명기 2:37","category":"$undefined"}],"bookSlug":"deuteronomy"}]
