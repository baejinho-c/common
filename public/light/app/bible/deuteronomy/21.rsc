2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":21,"verses":[{"id":"5449","book":"신명기","book_name":"신명기","chapter":21,"verse":1,"text":"네 하나님 여호와께서 네게 주어 얻게 하시는 땅에서 혹시 피살한 시체가 들에 엎드러진 것을 발견하고 그 쳐 죽인 자가 누구인지 알지 못하거든","reference":"신명기 21:1","category":"$undefined"},{"id":"5450","book":"신명기","book_name":"신명기","chapter":21,"verse":2,"text":"너의 장로들과 재판장들이 나가서 그 피살한 곳에서 사면에 있는 각 성읍의 원근을 잴 것이요","reference":"신명기 21:2","category":"$undefined"},{"id":"5451","book":"신명기","book_name":"신명기","chapter":21,"verse":3,"text":"그 피살한 곳에서 제일 가까운 성읍 곧 그 성읍의 장로들이 아직 부리우지 아니하고 멍에를 메지 아니한 암송아지를 취하고","reference":"신명기 21:3","category":"$undefined"},{"id":"5452","book":"신명기","book_name":"신명기","chapter":21,"verse":4,"text":"성읍의 장로들이 물이 항상 흐르고 갈지도 심지도 못하는 골짜기로 그 송아지를 끌고 가서 그 골짜기에서 그 송아지의 목을 꺾을 것이요","reference":"신명기 21:4","category":"$undefined"},{"id":"5453","book":"신명기","book_name":"신명기","chapter":21,"verse":5,"text":"레위 자손 제사장들도 그리로 올지니 그들은 네 하나님 여호와께서 택하사 자기를 섬기게 하시며 또 여호와의 이름으로 축복하게 하신 자라 모든 소송과 모든 투쟁이 그들의 말대로 판결될 것이니라","reference":"신명기 21:5","category":"$undefined"},{"id":"5454","book":"신명기","book_name":"신명기","chapter":21,"verse":6,"text":"그 피살된 곳에서 제일 가까운 성읍의 모든 장로들은 그 골짜기에서 목을 꺾은 암송아지 위에 손을 씻으며","reference":"신명기 21:6","category":"$undefined"},{"id":"5455","book":"신명기","book_name":"신명기","chapter":21,"verse":7,"text":"말하기를 우리의 손이 이 피를 흘리지 아니하였고 우리의 눈이 이것을 보지도 못하였나이다","reference":"신명기 21:7","category":"$undefined"},{"id":"5456","book":"신명기","book_name":"신명기","chapter":21,"verse":8,"text":"여호와여 ! 주께서 속량하신 주의 백성 이스라엘을 사하시고 무죄한 피를 주의 백성 이스라엘 중에 머물러 두지 마옵소서 하면 그 피 흘린 죄가 사함을 받으리니","reference":"신명기 21:8","category":"$undefined"},{"id":"5457","book":"신명기","book_name":"신명기","chapter":21,"verse":9,"text":"너는 이와 같이 여호와의 보시기에 정직한 일을 행하여 무죄자의 피 흘린 죄를 너희 중에서 제할지니라 !","reference":"신명기 21:9","category":"$undefined"},{"id":"5458","book":"신명기","book_name":"신명기","chapter":21,"verse":10,"text":"네가 나가서 대적과 싸움함을 당하여 네 하나님 여호와께서 그들을 네 손에 붙이시므로 네가 그들을 사로잡은 후에","reference":"신명기 21:10","category":"$undefined"},{"id":"5459","book":"신명기","book_name":"신명기","chapter":21,"verse":11,"text":"네가 만일 그 포로 중의 아리따운 여자를 보고 연련하여 아내를 삼고자 하거든","reference":"신명기 21:11","category":"$undefined"},{"id":"5460","book":"신명기","book_name":"신명기","chapter":21,"verse":12,"text":"그를 네 집으로 데려갈 것이요 그는 그 머리를 밀고 손톱을 베고","reference":"신명기 21:12","category":"$undefined"},{"id":"5461","book":"신명기","book_name":"신명기","chapter":21,"verse":13,"text":"또 포로의 의복을 벗고 네 집에 거하며 그 부모를 위하여 일개월동안 애곡한 후에 네가 그에게로 들어가서 그 남편이 되고 그는 네 아내가 될것이요","reference":"신명기 21:13","category":"$undefined"},{"id":"5462","book":"신명기","book_name":"신명기","chapter":21,"verse":14,"text":"그 후에 네가 그를 기뻐하지 아니하거든 그 마음대로 가게 하고 결코 돈을 받고 팔지 말지라 네가 그를 욕보였은즉 종으로 여기지 말지니라","reference":"신명기 21:14","category":"$undefined"},{"id":"5463","book":"신명기","book_name":"신명기","chapter":21,"verse":15,"text":"어떤 사람이 두 아내를 두었는데 하나는 사랑을 받고 하나는 미움을 받다가 그 사랑을 받는 자와 미움을 받는 자가 둘 다 아들을 낳았다 하자 그 미움을 받는 자의 소생이 장자여든","reference":"신명기 21:15","category":"$undefined"},{"id":"5464","book":"신명기","book_name":"신명기","chapter":21,"verse":16,"text":"자기의 소유를 그 아들들에게 기업으로 나누는 날에 그 사랑을 받는 자의 아들로 장자를 삼아 참 장자 곧 미움을 받는 자의 아들보다 앞세우지 말고","reference":"신명기 21:16","category":"$undefined"},{"id":"5465","book":"신명기","book_name":"신명기","chapter":21,"verse":17,"text":"반드시 그 미움을 받는 자의 아들을 장자로 인정하여 자기의 소유에서 그에게는 두 몫을 줄 것이니 그는 자기의 기력의 시작이라 장자의 권리가 그에게 있음이니라","reference":"신명기 21:17","category":"$undefined"},{"id":"5466","book":"신명기","book_name":"신명기","chapter":21,"verse":18,"text":"사람에게 완악하고 패역한 아들이 있어 그 아비의 말이나 그 어미의 말을 순종치 아니하고 부모가 징책하여도 듣지 아니하거든","reference":"신명기 21:18","category":"$undefined"},{"id":"5467","book":"신명기","book_name":"신명기","chapter":21,"verse":19,"text":"부모가 그를 잡아가지고 성문에 이르러 그 성읍 장로들에게 나아가서","reference":"신명기 21:19","category":"$undefined"},{"id":"5468","book":"신명기","book_name":"신명기","chapter":21,"verse":20,"text":"그 성읍 장로들에게 말하기를 `우리의 이 자식은 완악하고 패역하여 우리 말을 순종치 아니하고 방탕하며 술에 잠긴 자라' 하거든","reference":"신명기 21:20","category":"$undefined"},{"id":"5469","book":"신명기","book_name":"신명기","chapter":21,"verse":21,"text":"그 성읍의 모든 사람들이 그를 돌로 쳐 죽일지니 이같이 네가 너의 중에 악을 제하라 그리하면 온 이스라엘이 듣고 두려워하리라","reference":"신명기 21:21","category":"$undefined"},{"id":"5470","book":"신명기","book_name":"신명기","chapter":21,"verse":22,"text":"사람이 만일 죽을 죄를 범하므로 네가 그를 죽여 나무 위에 달거든","reference":"신명기 21:22","category":"$undefined"},{"id":"5471","book":"신명기","book_name":"신명기","chapter":21,"verse":23,"text":"그 시체를 나무 위에 밤새도록 두지 말고 당일에 장사하여 네 하나님 여호와께서 네게 기업으로 주시는 땅을 더럽히지 말라 나무에 달린 자는 하나님께 저주를 받았음이니라","reference":"신명기 21:23","category":"$undefined"}],"bookSlug":"deuteronomy"}]
