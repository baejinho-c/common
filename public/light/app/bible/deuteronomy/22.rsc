2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":22,"verses":[{"id":"5472","book":"신명기","book_name":"신명기","chapter":22,"verse":1,"text":"네 형제의 우양의 길 잃은 것을 보거든 못 본 체 하지 말고 너는 반드시 끌어다가 네 형제에게 돌릴 것이요","reference":"신명기 22:1","category":"$undefined"},{"id":"5473","book":"신명기","book_name":"신명기","chapter":22,"verse":2,"text":"네 형제가 네게서 멀거나 네가 혹 그를 알지 못하거든 그 짐승을 네 집으로 끌고 와서 네 형제가 찾기까지 네게 두었다가 그에게 돌릴지니","reference":"신명기 22:2","category":"$undefined"},{"id":"5474","book":"신명기","book_name":"신명기","chapter":22,"verse":3,"text":"나귀라도 그리하고 의복이라도 그리하고 무릇 형제의 잃은 아무것이든지 네가 얻거든 다 그리하고 못 본 체 하지 말 것이며","reference":"신명기 22:3","category":"$undefined"},{"id":"5475","book":"신명기","book_name":"신명기","chapter":22,"verse":4,"text":"네 형제의 나귀나 소가 길에 넘어진 것을 보거든 못 본 체 하지말고 너는 반드시 형제를 도와서 그것을 일으킬지니라","reference":"신명기 22:4","category":"$undefined"},{"id":"5476","book":"신명기","book_name":"신명기","chapter":22,"verse":5,"text":"여자는 남자의 의복을 입지 말 것이요 남자는 여자의 의복을 입지 말 것이라 이같이 하는 자는 네 하나님 여호와께 가증한 자니라","reference":"신명기 22:5","category":"$undefined"},{"id":"5477","book":"신명기","book_name":"신명기","chapter":22,"verse":6,"text":"노중에서 나무에나 땅에 있는 새의 보금자리에 새 새끼나 알이 있고 어미새가 그 새끼나 알을 품은 것을 만나거든 그 어미새와 새끼를 아울러 취하지 말고","reference":"신명기 22:6","category":"$undefined"},{"id":"5478","book":"신명기","book_name":"신명기","chapter":22,"verse":7,"text":"어미는 반드시 놓아 줄 것이요 새끼는 취하여도 가하니 그리하면 네가 복을 누리고 장수하리라","reference":"신명기 22:7","category":"$undefined"},{"id":"5479","book":"신명기","book_name":"신명기","chapter":22,"verse":8,"text":"네가 새 집을 건축할 때에 지붕에 난간을 만들어 사람으로 떨어지지 않게 하라 그 피 흐른 죄가 네 집에 돌아갈까 하노라","reference":"신명기 22:8","category":"$undefined"},{"id":"5480","book":"신명기","book_name":"신명기","chapter":22,"verse":9,"text":"네 포도원에 두 종자를 섞어 뿌리지 말라 ! 그리하면 네가 뿌린 씨의 열매와 포도원의 소산이 다 빼앗김이 될까 하노라","reference":"신명기 22:9","category":"$undefined"},{"id":"5481","book":"신명기","book_name":"신명기","chapter":22,"verse":10,"text":"너는 소와 나귀를 겨리하여 갈지 말며","reference":"신명기 22:10","category":"$undefined"},{"id":"5482","book":"신명기","book_name":"신명기","chapter":22,"verse":11,"text":"양털과 베실로 섞어 짠 것을 입지 말지니라 !","reference":"신명기 22:11","category":"$undefined"},{"id":"5483","book":"신명기","book_name":"신명기","chapter":22,"verse":12,"text":"입는 겉옷 네 귀에 술을 만들지니라 !","reference":"신명기 22:12","category":"$undefined"},{"id":"5484","book":"신명기","book_name":"신명기","chapter":22,"verse":13,"text":"비방거리를 만들어 그에게 누명을 씌워 가로되 `내가 이 여자를 취하였더니 그와 동침할 때에 그의 처녀인 표적을 보지 못하였노라' 하면","reference":"신명기 22:13","category":"$undefined"},{"id":"5485","book":"신명기","book_name":"신명기","chapter":22,"verse":14,"text":"그 처녀의 부모가 처녀의 처녀인 표를 얻어 가지고 그 성읍문 장로들에게로 가서","reference":"신명기 22:14","category":"$undefined"},{"id":"5486","book":"신명기","book_name":"신명기","chapter":22,"verse":15,"text":"처녀의 아비가 장로들에게 말하기를 `내 딸을 이 사람에게 아내로 주었더니 그가 미워하여","reference":"신명기 22:15","category":"$undefined"},{"id":"5487","book":"신명기","book_name":"신명기","chapter":22,"verse":16,"text":"비방거리를 만들어 말하기를 내가 네 딸의 처녀인 표적을 보지 못하였노라 하나 보라 ! 내 딸의 처녀인 표적이 이것이라' 하고 그 부모가 그 자리옷을 그 성읍 장로들 앞에 펼 것이요","reference":"신명기 22:16","category":"$undefined"},{"id":"5488","book":"신명기","book_name":"신명기","chapter":22,"verse":17,"text":"그 성읍 장로들은 그 사람을 잡아 때리고","reference":"신명기 22:17","category":"$undefined"},{"id":"5489","book":"신명기","book_name":"신명기","chapter":22,"verse":18,"text":"이스라엘 처녀에게 누명 씌움을 인하여 그에게서 은 일백 세겔을 벌금으로 받아 여자의 아비에게 주고 그 여자로 그 남자의 평생에 버리지 못할 아내가 되게 하려니와","reference":"신명기 22:18","category":"$undefined"},{"id":"5490","book":"신명기","book_name":"신명기","chapter":22,"verse":19,"text":"그 일이 참되어 그 처녀에게 처녀인 표적이 없거든","reference":"신명기 22:19","category":"$undefined"},{"id":"5491","book":"신명기","book_name":"신명기","chapter":22,"verse":20,"text":"처녀를 그 아비 집 문에서 끌어내고 그 성읍 사람들이 그를 돌로 쳐 죽일지니 이는 그가 그 아비 집에서 창기의 행동을 하여 이스라엘 중에서 악을 행하였음이라 너는 이와 같이 하여 너의 중에 악을 제할지니라 !","reference":"신명기 22:20","category":"$undefined"},{"id":"5492","book":"신명기","book_name":"신명기","chapter":22,"verse":21,"text":"남자가 유부녀와 통간함을 보거든 그 통간한 남자와 그 여자를 둘 다 죽여 이스라엘 중에 악을 제할지니라","reference":"신명기 22:21","category":"$undefined"},{"id":"5493","book":"신명기","book_name":"신명기","chapter":22,"verse":22,"text":"처녀인 여자가 남자와 약혼한 후에 어떤 남자가 그를 성읍중에서 만나 통간하면","reference":"신명기 22:22","category":"$undefined"},{"id":"5494","book":"신명기","book_name":"신명기","chapter":22,"verse":23,"text":"너희는 그들을 둘 다 성읍 문으로 끌어내고 그들을 돌로 쳐 죽일 것이니 그 처녀는 성읍 중에 있어서도 소리 지르지 아니하였음이요 그 남자는 그 이웃의 아내를 욕보였음이라 너는 이같이 하여 너의 중에 악을 제할지니라 !","reference":"신명기 22:23","category":"$undefined"},{"id":"5495","book":"신명기","book_name":"신명기","chapter":22,"verse":24,"text":"만일 남자가 어떤 약혼한 처녀를 들에서 만나서 강간하였거든 그 강간한 남자만 죽일 것이요","reference":"신명기 22:24","category":"$undefined"},{"id":"5496","book":"신명기","book_name":"신명기","chapter":22,"verse":25,"text":"처녀에게는 아무 것도 행치 말 것은 처녀에게는 죽일 죄가 없음이라 이 일은 사람이 일어나 그 이웃을 쳐 죽인 것과 일반이라","reference":"신명기 22:25","category":"$undefined"},{"id":"5497","book":"신명기","book_name":"신명기","chapter":22,"verse":26,"text":"남자가 처녀를 들에서 만난 까닭에 그 약혼한 처녀가 소리질러도 구원할 자가 없었음이니라","reference":"신명기 22:26","category":"$undefined"},{"id":"5498","book":"신명기","book_name":"신명기","chapter":22,"verse":27,"text":"만일 남자가 어떤 약혼하지 아니한 처녀를 만나 그를 붙들고 통간하는 중 그 두 사람이 발견되거든","reference":"신명기 22:27","category":"$undefined"},{"id":"5499","book":"신명기","book_name":"신명기","chapter":22,"verse":28,"text":"그 통간한 남자는 그 처녀의 아비에게 은 오십 세겔을 주고 그 처녀로 아내를 삼을 것이라 그가 그 처녀를 욕보였은즉 평생에 그를 버리지 못하리라","reference":"신명기 22:28","category":"$undefined"},{"id":"5500","book":"신명기","book_name":"신명기","chapter":22,"verse":29,"text":"사람이 그 아비의 후실을 취하여 아비의 하체를 드러내지 말지니라","reference":"신명기 22:29","category":"$undefined"},{"id":"5501","book":"신명기","book_name":"신명기","chapter":22,"verse":30,"text":"","reference":"신명기 22:30","category":"$undefined"}],"bookSlug":"deuteronomy"}]
