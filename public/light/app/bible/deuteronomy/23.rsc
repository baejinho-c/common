2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":23,"verses":[{"id":"5502","book":"신명기","book_name":"신명기","chapter":23,"verse":1,"text":"신낭이 상한 자나 신을 베인 자는 여호와의 총회에 들어오지 못하리라","reference":"신명기 23:1","category":"$undefined"},{"id":"5503","book":"신명기","book_name":"신명기","chapter":23,"verse":2,"text":"사생자는 여호와의 총회에 들어오지 못하리니 십대까지라도 여호와의 총회에 들어오지 못하리라","reference":"신명기 23:2","category":"$undefined"},{"id":"5504","book":"신명기","book_name":"신명기","chapter":23,"verse":3,"text":"암몬 사람과 모압 사람은 여호와의 총회에 들어오지 못하리니 그들에게 속한 자는 십대 뿐아니라 영원히 여호와의 총회에 들어오지 못하리라","reference":"신명기 23:3","category":"$undefined"},{"id":"5505","book":"신명기","book_name":"신명기","chapter":23,"verse":4,"text":"그들은 너희가 애굽에서 나올 때에 떡과 물로 너희를 길에서 영접하지 아니하고 메소보다미아의 브돌 사람 브올의 아들 발람에게 뇌물을 주어 너희를 저주케 하려 하였으나","reference":"신명기 23:4","category":"$undefined"},{"id":"5506","book":"신명기","book_name":"신명기","chapter":23,"verse":5,"text":"네 하나님 여호와께서 너를 사랑하시므로 발람의 말을 듣지 아니하시고 그 저주를 변하여 복이 되게 하셨나니","reference":"신명기 23:5","category":"$undefined"},{"id":"5507","book":"신명기","book_name":"신명기","chapter":23,"verse":6,"text":"너의 평생에 그들의 평안과 형통을 영영히 구하지 말지니라","reference":"신명기 23:6","category":"$undefined"},{"id":"5508","book":"신명기","book_name":"신명기","chapter":23,"verse":7,"text":"너는 에돔 사람을 미워하지 말라 ! 그는 너의 형제니라 애굽 사람을 미워하지 말라 ! 네가 그의 땅에서 객이 되었음이니라","reference":"신명기 23:7","category":"$undefined"},{"id":"5509","book":"신명기","book_name":"신명기","chapter":23,"verse":8,"text":"그들의 삼대 후 자손은 여호와의 총회에 들어올 수 있느리라","reference":"신명기 23:8","category":"$undefined"},{"id":"5510","book":"신명기","book_name":"신명기","chapter":23,"verse":9,"text":"네가 대적을 치러 출진할 때에 모든 악한 일을 스스로 삼갈지니","reference":"신명기 23:9","category":"$undefined"},{"id":"5511","book":"신명기","book_name":"신명기","chapter":23,"verse":10,"text":"너희 중에 누가 밤에 몽설함으로 부정하거든 진 밖으로 나가고 진 안에 들어오지 아니하다가","reference":"신명기 23:10","category":"$undefined"},{"id":"5512","book":"신명기","book_name":"신명기","chapter":23,"verse":11,"text":"해질 때에 목욕하고 해진 후에 진에 들어올 것이요","reference":"신명기 23:11","category":"$undefined"},{"id":"5513","book":"신명기","book_name":"신명기","chapter":23,"verse":12,"text":"너의 진 밖에 변소를 베풀고 그리로 나가되","reference":"신명기 23:12","category":"$undefined"},{"id":"5514","book":"신명기","book_name":"신명기","chapter":23,"verse":13,"text":"너의 기구에 작은 삽을 더하여 밖에 나가서 대변을 통할 때에 그것으로 땅을 팔 것이요 몸을 돌이켜 그 배설물을 덮을지니","reference":"신명기 23:13","category":"$undefined"},{"id":"5515","book":"신명기","book_name":"신명기","chapter":23,"verse":14,"text":"이는 네 하나님 여호와께서 너를 구원하시고 적군을 네게 붙이시려고 네 진중에 행하심이라 그러므로 네 진을 거룩히 하라 그리하면 네게서 불합한 것을 보시지 않으므로 너를 떠나지 아니하시리라","reference":"신명기 23:14","category":"$undefined"},{"id":"5516","book":"신명기","book_name":"신명기","chapter":23,"verse":15,"text":"종이 그 주인을 피하여 네게로 도망하거든 너는 그 주인에게로 돌리지 말고","reference":"신명기 23:15","category":"$undefined"},{"id":"5517","book":"신명기","book_name":"신명기","chapter":23,"verse":16,"text":"그가 너의 성읍 중에서 기뻐하는 곳을 택하는 대로 너와 함께 네 가운데 거하게 하고 그를 압제하지 말지니라","reference":"신명기 23:16","category":"$undefined"},{"id":"5518","book":"신명기","book_name":"신명기","chapter":23,"verse":17,"text":"이스라엘 여자 중에 창기가 있지 못할 것이요 이스라엘 남자 중에 미동이 있지 못할지니","reference":"신명기 23:17","category":"$undefined"},{"id":"5519","book":"신명기","book_name":"신명기","chapter":23,"verse":18,"text":"창기의 번 돈과 개 같은 자의 소득은 아무 서원하는 일로든지 네 하나님 여호와의 전에 가져오지 말라 이 둘은 다 네 하나님 여호와께 가증한 것임이니라","reference":"신명기 23:18","category":"$undefined"},{"id":"5520","book":"신명기","book_name":"신명기","chapter":23,"verse":19,"text":"네가 형제에게 꾸이거든 이식을 취하지 말지니 곧 돈의 이식, 식물의 이식, 무릇 이식을 낼 만한 것의 이식을 취하지 말 것이라","reference":"신명기 23:19","category":"$undefined"},{"id":"5521","book":"신명기","book_name":"신명기","chapter":23,"verse":20,"text":"타국인에게 네가 꾸이면 이식을 취하여도 가하거니와 너의 형제에게 꾸이거든 이식을 취하지 말라 그리하면 네 하나님 여호와께서 네가 들어가서 얻을 땅에서 네 손으로 하는 범사에 복을 내리시리라","reference":"신명기 23:20","category":"$undefined"},{"id":"5522","book":"신명기","book_name":"신명기","chapter":23,"verse":21,"text":"네 하나님 여호와께 서원하거든 갚기를 더디 하지 말라 ! 네 하나님 여호와께서 반드시 그것을 네게 요구하시리니 더디면 네게 죄라","reference":"신명기 23:21","category":"$undefined"},{"id":"5523","book":"신명기","book_name":"신명기","chapter":23,"verse":22,"text":"네가 서원치 아니하였으면 무죄하니라마는","reference":"신명기 23:22","category":"$undefined"},{"id":"5524","book":"신명기","book_name":"신명기","chapter":23,"verse":23,"text":"네 입에서 낸 것은 그대로 실행하기를 주의하라 무릇 자원한 예물은 네 하나님 여호와께 네가 서원하여 입으로 언약한 대로 행할지니라","reference":"신명기 23:23","category":"$undefined"},{"id":"5525","book":"신명기","book_name":"신명기","chapter":23,"verse":24,"text":"네 이웃의 포도원에 들어갈 때에 마음대로 그 포도를 배불리 먹어도 가하니라 그러나 그릇에 담지 말 것이요","reference":"신명기 23:24","category":"$undefined"},{"id":"5526","book":"신명기","book_name":"신명기","chapter":23,"verse":25,"text":"네 이웃의 곡식 밭에 들어갈 때에 네가 손으로 그 이삭을 따도 가하니라 그러나 이웃의 곡식 밭에 낫을 대지 말지니라","reference":"신명기 23:25","category":"$undefined"}],"bookSlug":"deuteronomy"}]
