2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":24,"verses":[{"id":"5527","book":"신명기","book_name":"신명기","chapter":24,"verse":1,"text":"사람이 아내를 취하여 데려온 후에 수치되는 일이 그에게 있음을 발견하고 그를 기뻐하지 아니하거든 이혼 증서를 써서 그 손에 주고 그를 자기 집에서 내어보낼 것이요","reference":"신명기 24:1","category":"$undefined"},{"id":"5528","book":"신명기","book_name":"신명기","chapter":24,"verse":2,"text":"그 여자는 그 집에서 나가서 다른 사람의 아내가 되려니와","reference":"신명기 24:2","category":"$undefined"},{"id":"5529","book":"신명기","book_name":"신명기","chapter":24,"verse":3,"text":"그 후부도 그를 미워하여 이혼 증서를 써서 그 손에 주고 그를 자기 집에서 내어 보내었거나 혹시 그를 아내로 취한 후부가 죽었다 하자","reference":"신명기 24:3","category":"$undefined"},{"id":"5530","book":"신명기","book_name":"신명기","chapter":24,"verse":4,"text":"그 여자가 이미 몸을 더럽혔은즉 그를 내어 보낸 전부가 그를 다시 아내로 취하지 말지니 이 일은 여호와 앞에 가증한 것이라 네 하나님 여호와께서 네게 기업으로 주시는 땅으로 너는 범죄케 하지 말지니라","reference":"신명기 24:4","category":"$undefined"},{"id":"5531","book":"신명기","book_name":"신명기","chapter":24,"verse":5,"text":"사람이 새로이 아내를 취하였거든 그를 군대로 내어 보내지 말 것이요 무슨 직무든지 그에게 맡기지 말 것이며 그는 일년 동안 집에 한가히 거하여 그 취한 아내를 즐겁게 할지니라","reference":"신명기 24:5","category":"$undefined"},{"id":"5532","book":"신명기","book_name":"신명기","chapter":24,"verse":6,"text":"사람이 맷돌의 전부나 그 윗짝만이나 전집하지 말지니 이는 그 생명을 전집함이니라","reference":"신명기 24:6","category":"$undefined"},{"id":"5533","book":"신명기","book_name":"신명기","chapter":24,"verse":7,"text":"사람이 자기 형제 곧 이스라엘 자손 중 한 사람을 후려다가 그를 부리거나 판 것이 발견되거든 그 후린 자를 죽일지니 이같이 하여 너의 중에 악을 제할지니라 !","reference":"신명기 24:7","category":"$undefined"},{"id":"5534","book":"신명기","book_name":"신명기","chapter":24,"verse":8,"text":"너는 문둥병에 대하여 삼가서 레위 사람 제사장들이 너희에게 가르치는 대로 네가 힘써 다 행하되 곧 네가 그들에게 명한 대로 너희는 주의하여 행하라 !","reference":"신명기 24:8","category":"$undefined"},{"id":"5535","book":"신명기","book_name":"신명기","chapter":24,"verse":9,"text":"너희가 애굽에서 나오는 길에서 네 하나님 여호와께서 미리암에게 행하신 일을 기억할지니라 !","reference":"신명기 24:9","category":"$undefined"},{"id":"5536","book":"신명기","book_name":"신명기","chapter":24,"verse":10,"text":"무릇 네 이웃에게 꾸어줄 때에 네가 그 집에 들어가서 전집물을 취하지 말고","reference":"신명기 24:10","category":"$undefined"},{"id":"5537","book":"신명기","book_name":"신명기","chapter":24,"verse":11,"text":"너는 밖에 섰고 네게 꾸는 자가 전집물을 가지고 나와서 네게 줄것이며","reference":"신명기 24:11","category":"$undefined"},{"id":"5538","book":"신명기","book_name":"신명기","chapter":24,"verse":12,"text":"그가 가난한 자여든 너는 그의 전집물을 가지고 자지 말고","reference":"신명기 24:12","category":"$undefined"},{"id":"5539","book":"신명기","book_name":"신명기","chapter":24,"verse":13,"text":"해질 때에 전집물을 반드시 그에게 돌릴 것이라 그리하면 그가 그 옷을 입고 자며 너를 위하여 축복하리니 그 일이 네 하나님 여호와 앞에서 네 의로움이 되리라","reference":"신명기 24:13","category":"$undefined"},{"id":"5540","book":"신명기","book_name":"신명기","chapter":24,"verse":14,"text":"곤궁하고 빈한한 품군은 너의 형제든지 네 땅 성문안에 우거하는 객이든지 그를 학대하지 말며","reference":"신명기 24:14","category":"$undefined"},{"id":"5541","book":"신명기","book_name":"신명기","chapter":24,"verse":15,"text":"그 품삯을 당일에 주고 해진 후까지 끌지 말라 이는 그가 빈궁하므로 마음에 품삯을 사모함이라 두렵건대 그가 너를 여호와께 호소하면 죄가 네게로 돌아갈까 하노라","reference":"신명기 24:15","category":"$undefined"},{"id":"5542","book":"신명기","book_name":"신명기","chapter":24,"verse":16,"text":"아비는 그 자식들을 인하여 죽임을 당치 않을 것이요 자식들은 그 아비를 인하여 죽임을 당치 않을 것이라 각 사람은 자기 죄에 죽임을 당할 것이니라","reference":"신명기 24:16","category":"$undefined"},{"id":"5543","book":"신명기","book_name":"신명기","chapter":24,"verse":17,"text":"너는 객이나 고아의 송사를 억울하게 말며 과부의 옷을 전집하지말라","reference":"신명기 24:17","category":"$undefined"},{"id":"5544","book":"신명기","book_name":"신명기","chapter":24,"verse":18,"text":"너는 애굽에서 종이 되었던 일과 네 하나님 여호와께서 너를 거기서 속량하신 것을 기억하라 ! 이러므로 내가 네게 이 일을 행하라 명하노라","reference":"신명기 24:18","category":"$undefined"},{"id":"5545","book":"신명기","book_name":"신명기","chapter":24,"verse":19,"text":"네가 밭에서 곡식을 벨 때에 그 한 뭇을 밭에 잊어버렸거든 다시 가서 취하지 말고 객과 고아와 과부를 위하여 버려두라 그리하면 네 하나님 여호와께서 네 손으로 하는 범사에 복을 내리시리라","reference":"신명기 24:19","category":"$undefined"},{"id":"5546","book":"신명기","book_name":"신명기","chapter":24,"verse":20,"text":"네가 네 감람나무를 떤 후에 그 가지를 다시 살피지 말고 그 남은 것은 객과 고아와 과부를 위하여 버려두며","reference":"신명기 24:20","category":"$undefined"},{"id":"5547","book":"신명기","book_name":"신명기","chapter":24,"verse":21,"text":"네가 네 포도원의 포도를 딴 후에 그 남은 것을 다시 따지 말고 객과 고아와 과부를 위하여 버려두라","reference":"신명기 24:21","category":"$undefined"},{"id":"5548","book":"신명기","book_name":"신명기","chapter":24,"verse":22,"text":"너는 애굽 땅에서 종 되었던 것을 기억하라 ! 이러므로 내가 네게 이 일을 행하라 명하노라","reference":"신명기 24:22","category":"$undefined"}],"bookSlug":"deuteronomy"}]
