2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":25,"verses":[{"id":"5549","book":"신명기","book_name":"신명기","chapter":25,"verse":1,"text":"사람과 사람 사이에 시비가 생겨서 재판을 청하거든 재판장은 그들을 재판하여 의인은 의롭다 하고 악인은 정죄할 것이며","reference":"신명기 25:1","category":"$undefined"},{"id":"5550","book":"신명기","book_name":"신명기","chapter":25,"verse":2,"text":"악인에게 태형이 합당하거든 재판장은 그를 엎드리게 하고 그 죄의 경중대로 여수이 자기 앞에서 때리게 하라","reference":"신명기 25:2","category":"$undefined"},{"id":"5551","book":"신명기","book_name":"신명기","chapter":25,"verse":3,"text":"사십까지는 때리려니와 그것을 넘기지는 못할지니 만일 그것을 넘겨 과다히 때리면 네가 네 형제로 천히 여김을 받게 할까 하노라","reference":"신명기 25:3","category":"$undefined"},{"id":"5552","book":"신명기","book_name":"신명기","chapter":25,"verse":4,"text":"곡식 떠는 소의 입에 망을 씌우지 말지니라 !","reference":"신명기 25:4","category":"$undefined"},{"id":"5553","book":"신명기","book_name":"신명기","chapter":25,"verse":5,"text":"형제가 동거하는데 그 중 하나가 죽고 아들이 없거든 그 죽은 자의 아내는 나가서 타인에게 시집가지 말 것이요 그 남편의 형제가 그에게로 들어가서 그를 취하여 아내를 삼아 그의 남편의 형제 된 의무를 그에게 다 행할 것이요","reference":"신명기 25:5","category":"$undefined"},{"id":"5554","book":"신명기","book_name":"신명기","chapter":25,"verse":6,"text":"그 여인의 낳은 첫 아들로 그 죽은 형제의 후사를 잇게 하여 그 이름을 이스라엘 중에서 끊어지지 않게 할 것이니라","reference":"신명기 25:6","category":"$undefined"},{"id":"5555","book":"신명기","book_name":"신명기","chapter":25,"verse":7,"text":"그러나 그 사람이 만일 그 형제의 아내 취하기를 즐겨하지 아니하거든 그 형제의 아내는 그 성문 장로들에게로 나아가서 말하기를 내 남편의 형제가 그 형제의 이름을 이스라엘 중에 잇기를 싫어하여 남편의 형제된 의무를 내게 행치 아니하나이다 할 것이요","reference":"신명기 25:7","category":"$undefined"},{"id":"5556","book":"신명기","book_name":"신명기","chapter":25,"verse":8,"text":"그 성읍 장로들은 그를 불러다가 이를 것이며 그가 이미 정한 뜻대로 말하기를 내가 그 여자 취하기를 즐겨 아니하노라 하거든","reference":"신명기 25:8","category":"$undefined"},{"id":"5557","book":"신명기","book_name":"신명기","chapter":25,"verse":9,"text":"그 형제의 아내가 장로들 앞에서 그에게 나아가서 그의 발에서 신을 벗기고 그 얼굴에 침을 뱉으며 이르기를 그 형제의 집 세우기를 즐겨 아니하는 자에게는 이같이 할 것이라 할 것이며","reference":"신명기 25:9","category":"$undefined"},{"id":"5558","book":"신명기","book_name":"신명기","chapter":25,"verse":10,"text":"이스라엘 중에서 그의 이름을 신 벗기운 자의 집이라 칭할 것이니라","reference":"신명기 25:10","category":"$undefined"},{"id":"5559","book":"신명기","book_name":"신명기","chapter":25,"verse":11,"text":"두 사람이 서로 싸울 때에 한 사람의 아내가 그 남편을 그 치는 자의 손에서 구하려 하여 가까이 가서 손을 벌려 그 사람의 음낭을 잡거든","reference":"신명기 25:11","category":"$undefined"},{"id":"5560","book":"신명기","book_name":"신명기","chapter":25,"verse":12,"text":"너는 그 여인의 손을 찍어 버릴 것이고 네 눈이 그를 불쌍히 보지 말지니라","reference":"신명기 25:12","category":"$undefined"},{"id":"5561","book":"신명기","book_name":"신명기","chapter":25,"verse":13,"text":"너는 주머니에 같지 않은 저울추 곧 큰 것과 작은 것을 넣지 말것이며","reference":"신명기 25:13","category":"$undefined"},{"id":"5562","book":"신명기","book_name":"신명기","chapter":25,"verse":14,"text":"네 집에 같지 않은 되 곧 큰 것과 작은 것을 두지 말 것이요","reference":"신명기 25:14","category":"$undefined"},{"id":"5563","book":"신명기","book_name":"신명기","chapter":25,"verse":15,"text":"오직 십분 공정한 저울추를 두며 십분 공정한 되를 둘 것이라 그리하면 네 하나님 여호와께서 네게 주시는 땅에서 네 날이 장구하리라","reference":"신명기 25:15","category":"$undefined"},{"id":"5564","book":"신명기","book_name":"신명기","chapter":25,"verse":16,"text":"무릇 이같이 하는자, 무릇 부정당히 행하는 자는 네 하나님 여호와께 가증하니라","reference":"신명기 25:16","category":"$undefined"},{"id":"5565","book":"신명기","book_name":"신명기","chapter":25,"verse":17,"text":"너희가 애굽에서 나오는 길에 아말렉이 네게 행한 일을 기억하라 !","reference":"신명기 25:17","category":"$undefined"},{"id":"5566","book":"신명기","book_name":"신명기","chapter":25,"verse":18,"text":"곧 그들이 하나님을 두려워하지 아니하고 너를 길에서 만나 너의 피곤함을 타서 네 뒤에 떨어진 약한 자들을 쳤느니라","reference":"신명기 25:18","category":"$undefined"},{"id":"5567","book":"신명기","book_name":"신명기","chapter":25,"verse":19,"text":"그러므로 네 하나님 여호와께서 네게 주어 기업으로 얻게 하시는 땅에서 네 하나님 여호와께서 너로 사면에 있는 모든 대적을 벗어나게 하시고 네게 안식을 주실 때에 너는 아말렉의 이름을 천하에서 도말할지니라 너는 잊지 말지니라 !","reference":"신명기 25:19","category":"$undefined"}],"bookSlug":"deuteronomy"}]
