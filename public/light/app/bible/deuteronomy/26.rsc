2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":26,"verses":[{"id":"5568","book":"신명기","book_name":"신명기","chapter":26,"verse":1,"text":"네 하나님 여호와께서 네게 기업으로 주사 얻게 하시는 땅에 네가 들어가서 거기 거할 때에","reference":"신명기 26:1","category":"$undefined"},{"id":"5569","book":"신명기","book_name":"신명기","chapter":26,"verse":2,"text":"네 하나님 여호와께서 네게 주시는 땅에서 그 토지 모든 소산의 맏물을 거둔 후에 그것을 취하여 광주리에 담고 네 하나님 여호와께서 그 이름을 두시려고 택하신 곳으로 그것을 가지고 가서","reference":"신명기 26:2","category":"$undefined"},{"id":"5570","book":"신명기","book_name":"신명기","chapter":26,"verse":3,"text":"당시 제사장에게 나아가서 그에게 이르기를 `내가 오늘날 당신의 하나님 여호와께 고하나이다 내가 여호와께서 우리에게 주리라고 우리 열조에게 맹세하신 땅에 이르렀나이다' 할 것이요","reference":"신명기 26:3","category":"$undefined"},{"id":"5571","book":"신명기","book_name":"신명기","chapter":26,"verse":4,"text":"제사장은 네 손에서 그 광주리를 취하여다가 네 하나님 여호와의 단 앞에 놓을 것이며","reference":"신명기 26:4","category":"$undefined"},{"id":"5572","book":"신명기","book_name":"신명기","chapter":26,"verse":5,"text":"너는 또 네 하나님 여호와 앞에 아뢰기를 내 조상은 유리하는 아람 사람으로서 소수의 사람을 거느리고 애굽에 내려가서 거기 우거하여 필경은 거기서 크고 강하고 번성한 민족이 되었더니","reference":"신명기 26:5","category":"$undefined"},{"id":"5573","book":"신명기","book_name":"신명기","chapter":26,"verse":6,"text":"애굽 사람이 우리를 학대하며 우리를 괴롭게 하며 우리에게 중역을 시키므로","reference":"신명기 26:6","category":"$undefined"},{"id":"5574","book":"신명기","book_name":"신명기","chapter":26,"verse":7,"text":"우리가 우리 조상의 하나님 여호와께 부르짖었더니 여호와께서 우리 음성을 들으시고 우리의 고통과 신고와 압제를 하감하시고","reference":"신명기 26:7","category":"$undefined"},{"id":"5575","book":"신명기","book_name":"신명기","chapter":26,"verse":8,"text":"여호와께서 강한 손과 편 팔과 큰 위엄과 이적과 기사로 우리를 애굽에서 인도하여 내시고","reference":"신명기 26:8","category":"$undefined"},{"id":"5576","book":"신명기","book_name":"신명기","chapter":26,"verse":9,"text":"이 곳으로 인도하사 이 땅 곧 젖과 꿀이 흐르는 땅을 주셨나이다","reference":"신명기 26:9","category":"$undefined"},{"id":"5577","book":"신명기","book_name":"신명기","chapter":26,"verse":10,"text":"여호와여 이제 내가 주께서 내게 주신 토지 소산의 맏물을 가져 왔나이다 하고 너는 그것을 네 하나님 여호와 앞에 두고 네 하나님 여호와 앞에 경배할 것이며","reference":"신명기 26:10","category":"$undefined"},{"id":"5578","book":"신명기","book_name":"신명기","chapter":26,"verse":11,"text":"네 하나님 여호와께서 너와 네 집에 주신 모든 복을 인하여 너는 레위인과 너의 중에 우거하는 객과 함께 즐거워할지니라","reference":"신명기 26:11","category":"$undefined"},{"id":"5579","book":"신명기","book_name":"신명기","chapter":26,"verse":12,"text":"제 삼년 곧 십일조를 드리는 해에 네 모든 소산의 십일조 다 내기를 마친 후에 그것을 레위인과 객과 고아와 과부에게 주어서 네 성문 안에서 먹어 배부르게 하라","reference":"신명기 26:12","category":"$undefined"},{"id":"5580","book":"신명기","book_name":"신명기","chapter":26,"verse":13,"text":"그리할 때에 네 하나님 여호와 앞에 고하기를 내가 성물을 내 집에서 내어 레위인과 객과 고아와 과부에게 주기를 주께서 내게 명하신 명령대로 하였사오니 내가 주의 명령을 범치도 아니하였고 잊지도 아니하였나이다","reference":"신명기 26:13","category":"$undefined"},{"id":"5581","book":"신명기","book_name":"신명기","chapter":26,"verse":14,"text":"내가 애곡하는 날에 이 성물을 먹지 아니하였고 부정한 몸으로 이를 떼어두지 아니하였고 죽은 자를 위하여 이를 쓰지 아니하였고 내 하나님 여호와의 말씀을 청종하여 주께서 내게 명령하신 대로 다 행하였사오니","reference":"신명기 26:14","category":"$undefined"},{"id":"5582","book":"신명기","book_name":"신명기","chapter":26,"verse":15,"text":"원컨대 주의 거룩한 처소 하늘에서 하감하시고 주의 백성 이스라엘에게 복을 주시며 우리 열조에게 맹세하여 우리에게 주신 바 젖과 꿀이 흐르는 땅에 복을 내리소서 할지니라","reference":"신명기 26:15","category":"$undefined"},{"id":"5583","book":"신명기","book_name":"신명기","chapter":26,"verse":16,"text":"오늘날 네 하나님 여호와께서 이 규례와 법도를 행하라고 네게 명하시나니 그런즉 너는 마음을 다하고 성품을 다하여 지켜 행하라","reference":"신명기 26:16","category":"$undefined"},{"id":"5584","book":"신명기","book_name":"신명기","chapter":26,"verse":17,"text":"네가 오늘날 여호와를 네 하나님으로 인정하고 또 그 도를 행하고 그 규례와 명령과 법도를 지키며 그 소리를 들으리라 확언하였고","reference":"신명기 26:17","category":"$undefined"},{"id":"5585","book":"신명기","book_name":"신명기","chapter":26,"verse":18,"text":"여호와께서도 네게 말씀하신 대로 오늘날 너를 자기의 보배로운 백성으로 인정하시고 또 그 모든 명령을 지키게 하리라 확언하셨은즉","reference":"신명기 26:18","category":"$undefined"},{"id":"5586","book":"신명기","book_name":"신명기","chapter":26,"verse":19,"text":"여호와께서 너의 칭찬과 명예와 영광으로 그 지으신 모든 민족 위에 뛰어나게 하시고 그 말씀하신 대로 너로 네 하나님 여호와의 성민이 되게 하시리라","reference":"신명기 26:19","category":"$undefined"}],"bookSlug":"deuteronomy"}]
