2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":27,"verses":[{"id":"5587","book":"신명기","book_name":"신명기","chapter":27,"verse":1,"text":"모세가 이스라엘 장로들로 더불어 백성에게 명하여 가로되 `내가 오늘날 너희에게 명하는 이 명령을 너희는 다 지킬지니라'","reference":"신명기 27:1","category":"$undefined"},{"id":"5588","book":"신명기","book_name":"신명기","chapter":27,"verse":2,"text":"너희가 요단을 건너 네 하나님 여호와께서 네게 주시는 땅에 들어가는 날에 큰 돌들을 세우고 석회를 바르라","reference":"신명기 27:2","category":"$undefined"},{"id":"5589","book":"신명기","book_name":"신명기","chapter":27,"verse":3,"text":"이미 건넌 후에 이 율법의 모든 말씀을 그 위에 기록하라 그리하면 네 하나님 여호와께서 네게 주시는 땅 곧 젖과 꿀이 흐르는 땅에 네가 들어가기를 네 열조의 하나님 여호와께서 네게 말씀하신 대로 하리니","reference":"신명기 27:3","category":"$undefined"},{"id":"5590","book":"신명기","book_name":"신명기","chapter":27,"verse":4,"text":"너희가 요단을 건너거든 내가 오늘날 너희에게 명하는 이 돌들을 에발산에 세우고 그 위에 석회를 바를 것이며","reference":"신명기 27:4","category":"$undefined"},{"id":"5591","book":"신명기","book_name":"신명기","chapter":27,"verse":5,"text":"또 거기서 네 하나님 여호와를 위하여 단 곧 돌단을 쌓되 그것에 철기를 대지 말지니라","reference":"신명기 27:5","category":"$undefined"},{"id":"5592","book":"신명기","book_name":"신명기","chapter":27,"verse":6,"text":"너는 다듬지 않은 돌로 네 하나님 여호와의 단을 쌓고 그 위에 하나님 여호와께 번제를 드릴 것이며","reference":"신명기 27:6","category":"$undefined"},{"id":"5593","book":"신명기","book_name":"신명기","chapter":27,"verse":7,"text":"또 화목제를 드리고 거기서 먹으며 네 하나님 여호와 앞에서 즐거워하라 !","reference":"신명기 27:7","category":"$undefined"},{"id":"5594","book":"신명기","book_name":"신명기","chapter":27,"verse":8,"text":"너는 이 율법의 모든 말씀을 그 돌들 위에 명백히 기록할지니라 !","reference":"신명기 27:8","category":"$undefined"},{"id":"5595","book":"신명기","book_name":"신명기","chapter":27,"verse":9,"text":"모세가 레위 제사장들로 더불어 온 이스라엘에게 고하여 가로되 이스라엘아 잠잠히 들으라 ! 오늘날 네가 네 하나님 여호와의 백성이 되었으니","reference":"신명기 27:9","category":"$undefined"},{"id":"5596","book":"신명기","book_name":"신명기","chapter":27,"verse":10,"text":"그런즉 네 하나님 여호와의 말씀을 복종하여 내가 오늘날 네게 명하는 그 명령과 규례를 행할지니라'","reference":"신명기 27:10","category":"$undefined"},{"id":"5597","book":"신명기","book_name":"신명기","chapter":27,"verse":11,"text":"모세가 당일에 백성에게 명하여 가로되","reference":"신명기 27:11","category":"$undefined"},{"id":"5598","book":"신명기","book_name":"신명기","chapter":27,"verse":12,"text":"너희가 요단을 건넌 후에 시므온과 레위와 유다와 잇사갈과 요셉과 베냐민은 백성을 축복하기 위하여 그리심산에 서고","reference":"신명기 27:12","category":"$undefined"},{"id":"5599","book":"신명기","book_name":"신명기","chapter":27,"verse":13,"text":"르우벤과 갓과 아셀과 스불론과 단과 납달리는 저주하기 위하여 에발산에 서고","reference":"신명기 27:13","category":"$undefined"},{"id":"5600","book":"신명기","book_name":"신명기","chapter":27,"verse":14,"text":"레위 사람은 큰 소리로 이스라엘 모든 사람에게 말하여 이르기를","reference":"신명기 27:14","category":"$undefined"},{"id":"5601","book":"신명기","book_name":"신명기","chapter":27,"verse":15,"text":"장색의 손으로 조각하였거나 부어 만든 우상은 여호와께 가증하니 그것을 만들어 은밀히 세우는 자는 저주를 받을 것이라 할 것이요 모든 백성은 응답하여 아멘 할지니라","reference":"신명기 27:15","category":"$undefined"},{"id":"5602","book":"신명기","book_name":"신명기","chapter":27,"verse":16,"text":"그 부모를 경홀히 여기는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:16","category":"$undefined"},{"id":"5603","book":"신명기","book_name":"신명기","chapter":27,"verse":17,"text":"그 이웃의 지계표를 옮기는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:17","category":"$undefined"},{"id":"5604","book":"신명기","book_name":"신명기","chapter":27,"verse":18,"text":"소경으로 길을 잃게 하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:18","category":"$undefined"},{"id":"5605","book":"신명기","book_name":"신명기","chapter":27,"verse":19,"text":"객이나 고아나 과부의 송사를 억울케 하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:19","category":"$undefined"},{"id":"5606","book":"신명기","book_name":"신명기","chapter":27,"verse":20,"text":"계모와 구합하는 자는 그 아비의 하체를 드러내었으니 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:20","category":"$undefined"},{"id":"5607","book":"신명기","book_name":"신명기","chapter":27,"verse":21,"text":"무릇 짐승과 교합하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:21","category":"$undefined"},{"id":"5608","book":"신명기","book_name":"신명기","chapter":27,"verse":22,"text":"그 자매 곧 그 아비의 딸이나 어미의 딸과 구합하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:22","category":"$undefined"},{"id":"5609","book":"신명기","book_name":"신명기","chapter":27,"verse":23,"text":"장모와 구합하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:23","category":"$undefined"},{"id":"5610","book":"신명기","book_name":"신명기","chapter":27,"verse":24,"text":"그 이웃을 암살하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:24","category":"$undefined"},{"id":"5611","book":"신명기","book_name":"신명기","chapter":27,"verse":25,"text":"무죄자를 죽이려고 뇌물을 받는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:25","category":"$undefined"},{"id":"5612","book":"신명기","book_name":"신명기","chapter":27,"verse":26,"text":"이 율법의 모든 말씀을 실행치 아니하는 자는 저주를 받을 것이라 할 것이요 모든 백성은 아멘 할지니라","reference":"신명기 27:26","category":"$undefined"}],"bookSlug":"deuteronomy"}]
