2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":28,"verses":[{"id":"5613","book":"신명기","book_name":"신명기","chapter":28,"verse":1,"text":"네가 네 하나님 여호와의 말씀을 삼가 듣고 내가 오늘날 네게 명하는 그 모든 명령을 지켜 행하면 네 하나님 여호와께서 너를 세계 모든 민족 위에 뛰어나게 하실 것이라","reference":"신명기 28:1","category":"$undefined"},{"id":"5614","book":"신명기","book_name":"신명기","chapter":28,"verse":2,"text":"네가 네 하나님 여호와의 말씀을 순종하면 이 모든 복이 네게 임하며 네게 미치리니","reference":"신명기 28:2","category":"$undefined"},{"id":"5615","book":"신명기","book_name":"신명기","chapter":28,"verse":3,"text":"성읍에서도 복을 받고, 들에서도 복을 받을 것이며","reference":"신명기 28:3","category":"$undefined"},{"id":"5616","book":"신명기","book_name":"신명기","chapter":28,"verse":4,"text":"네 몸의 소생과, 네 토지의 소산과, 네 짐승의 새끼와, 우양의 새끼가 복을 받을 것이며","reference":"신명기 28:4","category":"$undefined"},{"id":"5617","book":"신명기","book_name":"신명기","chapter":28,"verse":5,"text":"네 광주리와, 떡반죽 그릇이 복을 받을 것이며","reference":"신명기 28:5","category":"$undefined"},{"id":"5618","book":"신명기","book_name":"신명기","chapter":28,"verse":6,"text":"네가 들어와도 복을 받고, 나가도 복을 받을 것이니라","reference":"신명기 28:6","category":"$undefined"},{"id":"5619","book":"신명기","book_name":"신명기","chapter":28,"verse":7,"text":"네 대적들이 일어나 너를 치려하면 여호와께서 그들을 네 앞에서 패하게 하시리니 그들이 한 길로 너를 치러 들어왔으나 네 앞에서 일곱 길로 도망하리라","reference":"신명기 28:7","category":"$undefined"},{"id":"5620","book":"신명기","book_name":"신명기","chapter":28,"verse":8,"text":"여호와께서 명하사 네 창고와 네 손으로 하는 모든 일에 복을 내리시고 네 하나님 여호와께서 네게 주시는 땅에서 네게 복을 주실 것이며","reference":"신명기 28:8","category":"$undefined"},{"id":"5621","book":"신명기","book_name":"신명기","chapter":28,"verse":9,"text":"네가 네 하나님 여호와의 명령을 지켜 그 길로 행하면 여호와께서 네게 맹세하신 대로 너를 세워 자기의 성민이 되게 하시리니","reference":"신명기 28:9","category":"$undefined"},{"id":"5622","book":"신명기","book_name":"신명기","chapter":28,"verse":10,"text":"너를 여호와의 이름으로 일컬음을 세계 만민이 보고 너를 두려워하리라","reference":"신명기 28:10","category":"$undefined"},{"id":"5623","book":"신명기","book_name":"신명기","chapter":28,"verse":11,"text":"여호와께서 네게 주리라고 네 열조에게 맹세하신 땅에서 네게 복을 주사 네 몸의 소생과, 육축의 새끼와, 토지의 소산으로 많게 하시며","reference":"신명기 28:11","category":"$undefined"},{"id":"5624","book":"신명기","book_name":"신명기","chapter":28,"verse":12,"text":"여호와께서 너를 위하여 하늘의 아름다운 보고를 열으사 네 땅에 때를 따라 비를 내리시고 네 손으로 하는 모든 일에 복을 주시리니 네가 많은 민족에게 꾸어줄지라도 너는 꾸지 아니할 것이요","reference":"신명기 28:12","category":"$undefined"},{"id":"5625","book":"신명기","book_name":"신명기","chapter":28,"verse":13,"text":"여호와께서 너로 머리가 되고 꼬리가 되지 않게 하시며 위에만 있고 아래에 있지 않게 하시리니 오직 너는 내가 오늘날 네게 명하는 네 하나님 여호와의 명령을 듣고 지켜 행하며","reference":"신명기 28:13","category":"$undefined"},{"id":"5626","book":"신명기","book_name":"신명기","chapter":28,"verse":14,"text":"내가 오늘날 너희에게 명하는 그 말씀을 떠나 좌로나 우로나 치우치지 아니하고 다른 신을 따라 섬기지 아니하면 이와 같으리라","reference":"신명기 28:14","category":"$undefined"},{"id":"5627","book":"신명기","book_name":"신명기","chapter":28,"verse":15,"text":"네가 만일 네 하나님 여호와의 말씀을 순종하지 아니하여 내가 오늘날 네게 명하는 그 모든 명령과 규례를 지켜 행하지 아니하면 이 모든 저주가 네게 임하고 네게 미칠 것이니","reference":"신명기 28:15","category":"$undefined"},{"id":"5628","book":"신명기","book_name":"신명기","chapter":28,"verse":16,"text":"네가 성읍에서도 저주를 받으며, 들에서도 저주를 받을 것이요","reference":"신명기 28:16","category":"$undefined"},{"id":"5629","book":"신명기","book_name":"신명기","chapter":28,"verse":17,"text":"또 네 광주리와, 떡반죽 그릇이 저주를 받을 것이요","reference":"신명기 28:17","category":"$undefined"},{"id":"5630","book":"신명기","book_name":"신명기","chapter":28,"verse":18,"text":"네 몸의 소생과, 네 토지의 소산과, 네 우양의 새끼가 저주를 받을것이며","reference":"신명기 28:18","category":"$undefined"},{"id":"5631","book":"신명기","book_name":"신명기","chapter":28,"verse":19,"text":"네가 들어와도 저주를 받고, 나가도 저주를 받으리라","reference":"신명기 28:19","category":"$undefined"},{"id":"5632","book":"신명기","book_name":"신명기","chapter":28,"verse":20,"text":"네가 악을 행하여 그를 잊으므로 네 손으로 하는 모든 일에 여호와께서 저주와 공구와 견책을 내리사 망하여 속히 파멸케 하실 것이며","reference":"신명기 28:20","category":"$undefined"},{"id":"5633","book":"신명기","book_name":"신명기","chapter":28,"verse":21,"text":"여호와께서 네 몸에 염병이 들게 하사 네가 들어가 얻을 땅에서 필경 너를 멸하실 것이며","reference":"신명기 28:21","category":"$undefined"},{"id":"5634","book":"신명기","book_name":"신명기","chapter":28,"verse":22,"text":"여호와께서 폐병과, 열병과, 상한과, 학질과, 한재와, 풍재와, 썩는 재앙으로 너를 치시리니 이 재앙들이 너를 따라서 너를 진멸케 할 것이라","reference":"신명기 28:22","category":"$undefined"},{"id":"5635","book":"신명기","book_name":"신명기","chapter":28,"verse":23,"text":"네 머리 위의 하늘은 놋이 되고 네 아래의 땅은 철이 될 것이며","reference":"신명기 28:23","category":"$undefined"},{"id":"5636","book":"신명기","book_name":"신명기","chapter":28,"verse":24,"text":"여호와께서 비 대신에 티끌과 모래를 네 땅에 내리시리니 그것들이 하늘에서 네 위에 내려서 필경 너를 멸하리라","reference":"신명기 28:24","category":"$undefined"},{"id":"5637","book":"신명기","book_name":"신명기","chapter":28,"verse":25,"text":"여호와께서 너로 네 대적 앞에 패하게 하시리니 네가 한 길로 그들을 치러 나가서는 그들의 앞에서 일곱 길로 도망할 것이며 네가 또 세계 만국 중에 흩음을 당하고","reference":"신명기 28:25","category":"$undefined"},{"id":"5638","book":"신명기","book_name":"신명기","chapter":28,"verse":26,"text":"네 시체가 공중의 모든 새와 땅 짐승들의 밥이 될 것이나 그것들을 쫓아 줄 자가 없을 것이며","reference":"신명기 28:26","category":"$undefined"},{"id":"5639","book":"신명기","book_name":"신명기","chapter":28,"verse":27,"text":"여호와께서 애굽의 종기와, 치질과, 괴혈병과, 개창으로 너를 치시리니 네가 치료함을 얻지 못할 것이며","reference":"신명기 28:27","category":"$undefined"},{"id":"5640","book":"신명기","book_name":"신명기","chapter":28,"verse":28,"text":"여호와께서 또 너를 미침과, 눈멂과, 경심증으로 치시리니","reference":"신명기 28:28","category":"$undefined"},{"id":"5641","book":"신명기","book_name":"신명기","chapter":28,"verse":29,"text":"소경이 어두운데서 더듬는 것과 같이 네가 백주에도 더듬고 네 길이 형통치 못하여 항상 압제와 노략을 당할 뿐이니 너를 구원할 자가 없을 것이며","reference":"신명기 28:29","category":"$undefined"},{"id":"5642","book":"신명기","book_name":"신명기","chapter":28,"verse":30,"text":"네가 여자와 약혼하였으나 다른 사람이 그와 같이 잘 것이요 집을 건축하였으나 거기 거하지 못할 것이요 포도원을 심었으나 네가 그 과실을 쓰지 못할 것이며","reference":"신명기 28:30","category":"$undefined"},{"id":"5643","book":"신명기","book_name":"신명기","chapter":28,"verse":31,"text":"네 소를 네 목전에서 잡았으나 네가 먹지 못할 것이며 네 나귀를 네 목전에서 빼앗아감을 당하여도 도로 찾지 못할 것이며 네 양을 대적에게 빼앗길 것이나 너를 도와 줄 자가 없을 것이며","reference":"신명기 28:31","category":"$undefined"},{"id":"5644","book":"신명기","book_name":"신명기","chapter":28,"verse":32,"text":"네 자녀를 다른 민족에게 빼앗기고 종일 생각하고 알아봄으로 눈이 쇠하여지나 네 손에 능이 없을 것이며","reference":"신명기 28:32","category":"$undefined"},{"id":"5645","book":"신명기","book_name":"신명기","chapter":28,"verse":33,"text":"네 토지 소산과 네 수고로 얻은 것을 네가 알지 못하는 민족이 먹겠고 너는 항상 압제와 학대를 받을 뿐이리니","reference":"신명기 28:33","category":"$undefined"},{"id":"5646","book":"신명기","book_name":"신명기","chapter":28,"verse":34,"text":"이러므로 네 눈에 보이는 일로 인하여 네가 미치리라","reference":"신명기 28:34","category":"$undefined"},{"id":"5647","book":"신명기","book_name":"신명기","chapter":28,"verse":35,"text":"여호와께서 네 무릎과 다리를 쳐서 고치지 못할 심한 종기로 발하게 하여 발바닥으로 정수리까지 이르게 하시리라","reference":"신명기 28:35","category":"$undefined"},{"id":"5648","book":"신명기","book_name":"신명기","chapter":28,"verse":36,"text":"여호와께서 너와 네가 세울 네 임금을 너와 네 열조가 알지 못하던 나라로 끌어가시리니 네가 거기서 목석으로 만든 다른 신들을 섬길 것이며","reference":"신명기 28:36","category":"$undefined"},{"id":"5649","book":"신명기","book_name":"신명기","chapter":28,"verse":37,"text":"여호와께서 너를 끌어 가시는 모든 민족 중에서 네가 놀램과, 속담과, 비방거리가 될 것이라","reference":"신명기 28:37","category":"$undefined"},{"id":"5650","book":"신명기","book_name":"신명기","chapter":28,"verse":38,"text":"네가 많은 종자를 들에 심을지라도 메뚜기가 먹으므로 거둘 것이 적을 것이며","reference":"신명기 28:38","category":"$undefined"},{"id":"5651","book":"신명기","book_name":"신명기","chapter":28,"verse":39,"text":"네가 포도원을 심고 다스릴지라도 벌레가 먹으므로 포도를 따지 못하고 포도주를 마시지 못할 것이며","reference":"신명기 28:39","category":"$undefined"},{"id":"5652","book":"신명기","book_name":"신명기","chapter":28,"verse":40,"text":"네 모든 경내에 감람나무가 있을지라도 그 열매가 떨어지므로 그 기름을 네 몸에 바르지 못할 것이며","reference":"신명기 28:40","category":"$undefined"},{"id":"5653","book":"신명기","book_name":"신명기","chapter":28,"verse":41,"text":"네가 자녀를 낳을지라도 그들이 포로가 되므로 네게 있지 못할 것이며","reference":"신명기 28:41","category":"$undefined"},{"id":"5654","book":"신명기","book_name":"신명기","chapter":28,"verse":42,"text":"네 모든 나무와 토지 소산은 메뚜기가 먹을 것이며","reference":"신명기 28:42","category":"$undefined"},{"id":"5655","book":"신명기","book_name":"신명기","chapter":28,"verse":43,"text":"너의 중에 우거하는 이방인은 점점 높아져서 네 위에 뛰어나고 너는 점점 낮아질 것이며","reference":"신명기 28:43","category":"$undefined"},{"id":"5656","book":"신명기","book_name":"신명기","chapter":28,"verse":44,"text":"그는 네게 꾸일지라도 너는 그에게 뀌지 못하리니 그는 머리가 되고 너는 꼬리가 될 것이라","reference":"신명기 28:44","category":"$undefined"},{"id":"5657","book":"신명기","book_name":"신명기","chapter":28,"verse":45,"text":"네가 네 하나님 여호와의 말씀을 순종치 아니하고 네게 명하신 그 명령과 규례를 지키지 아니하므로 이 모든 저주가 네게 임하고 너를 따르고 네게 미쳐서 필경 너를 멸하리니","reference":"신명기 28:45","category":"$undefined"},{"id":"5658","book":"신명기","book_name":"신명기","chapter":28,"verse":46,"text":"이 모든 저주가 너와 네 자손에게 영원히 있어서 표적과 감계가 되리라","reference":"신명기 28:46","category":"$undefined"},{"id":"5659","book":"신명기","book_name":"신명기","chapter":28,"verse":47,"text":"네가 모든 것이 풍족하여도 기쁨과 즐거운 마음으로 네 하나님 여호와를 섬기지 아니함을 인하여","reference":"신명기 28:47","category":"$undefined"},{"id":"5660","book":"신명기","book_name":"신명기","chapter":28,"verse":48,"text":"네가 주리고 목마르고 헐벗고 모든 것이 핍절한 중에서 여호와께서 보내사 너를 치게 하실 대적을 섬기게 될 것이니 그가 철 멍에를 네 목에 메워서 필경 너를 멸할 것이라","reference":"신명기 28:48","category":"$undefined"},{"id":"5661","book":"신명기","book_name":"신명기","chapter":28,"verse":49,"text":"곧 여호와께서 원방에서 땅 끝에서 한 민족을 독수리의 날음 같이 너를 치러 오게 하시리니 이는 네가 그 언어를 알지 못하는 민족이요","reference":"신명기 28:49","category":"$undefined"},{"id":"5662","book":"신명기","book_name":"신명기","chapter":28,"verse":50,"text":"그 용모가 흉악한 민족이라 노인을 돌아보지 아니하며 유치를 긍휼히 여기지 아니하며","reference":"신명기 28:50","category":"$undefined"},{"id":"5663","book":"신명기","book_name":"신명기","chapter":28,"verse":51,"text":"네 육축의 새끼와 네 토지의 소산을 먹어서 필경은 너를 멸망시키며 또 곡식이나 포도주나 기름이나 소의 새끼나 양의 새끼를 위하여 남기지 아니하고 필경은 너를 멸절시키리라","reference":"신명기 28:51","category":"$undefined"},{"id":"5664","book":"신명기","book_name":"신명기","chapter":28,"verse":52,"text":"그들이 전국에서 네 모든 성읍을 에워싸고 네가 의뢰하는 바 높고 견고한 성벽을 다 헐며 네 하나님 여호와께서 네게 주시는 땅의 모든 성읍에서 너를 에워싸리니","reference":"신명기 28:52","category":"$undefined"},{"id":"5665","book":"신명기","book_name":"신명기","chapter":28,"verse":53,"text":"네가 대적에게 에워싸이고 맹렬히 쳐서 곤란케 함을 당하므로 네 하나님 여호와께서 네게 주신 자녀 곧 네 몸의 소생의 고기를 먹을 것이라","reference":"신명기 28:53","category":"$undefined"},{"id":"5666","book":"신명기","book_name":"신명기","chapter":28,"verse":54,"text":"너희 중에 유순하고 연약한 남자라도 그 형제와 그 품의 아내와 그 남은 자녀를 질시하여","reference":"신명기 28:54","category":"$undefined"},{"id":"5667","book":"신명기","book_name":"신명기","chapter":28,"verse":55,"text":"자기의 먹는 그 자녀의 고기를 그 중 누구에게든지 주지 아니하리니 이는 네 대적이 네 모든 성읍을 에워싸고 맹렬히 너를 쳐서 곤란케 하므로 아무 것도 그에게 남음이 없는 연고일 것이며","reference":"신명기 28:55","category":"$undefined"},{"id":"5668","book":"신명기","book_name":"신명기","chapter":28,"verse":56,"text":"또 너희 중에 유순하고 연약한 부녀 곧 유순하고 연약하여 그 발바닥으로 땅을 밟아 보지도 아니하던 자라도 그 품의 남편과 그 자녀를 질시하여","reference":"신명기 28:56","category":"$undefined"},{"id":"5669","book":"신명기","book_name":"신명기","chapter":28,"verse":57,"text":"그 다리 사이에서 나온 태와 자기의 낳은 어린 자식을 가만히 먹으리니 이는 네 대적이 네 생명을 에워싸고 맹렬히 쳐서 곤란케 하므로 아무 것도 얻지 못함이리라","reference":"신명기 28:57","category":"$undefined"},{"id":"5670","book":"신명기","book_name":"신명기","chapter":28,"verse":58,"text":"네가 만일 이 책에 기록한 이 율법의 모든 말씀을 지켜 행하지 아니하고 네 하나님 여호와라 하는 영화롭고 두려운 이름을 경외하지 아니하면","reference":"신명기 28:58","category":"$undefined"},{"id":"5671","book":"신명기","book_name":"신명기","chapter":28,"verse":59,"text":"여호와께서 너의 재앙과 네 자손의 재앙을 극렬하게 하시리니 그 재앙이 크고 오래고 질병이 중하고 오랠 것이라","reference":"신명기 28:59","category":"$undefined"},{"id":"5672","book":"신명기","book_name":"신명기","chapter":28,"verse":60,"text":"여호와께서 네가 두려워하던 애굽의 모든 질병을 네게로 가져다가 네 몸에 들어붓게 하실 것이며","reference":"신명기 28:60","category":"$undefined"},{"id":"5673","book":"신명기","book_name":"신명기","chapter":28,"verse":61,"text":"또 이 율법 책에 기록지 아니한 모든 질병과 모든 재앙을 너의 멸망하기까지 여호와께서 네게 내리실 것이니","reference":"신명기 28:61","category":"$undefined"},{"id":"5674","book":"신명기","book_name":"신명기","chapter":28,"verse":62,"text":"너희가 하늘의 별같이 많았을지라도 네 하나님 여호와의 말씀을 순종치 아니하므로 남는 자가 얼마되지 못할 것이라","reference":"신명기 28:62","category":"$undefined"},{"id":"5675","book":"신명기","book_name":"신명기","chapter":28,"verse":63,"text":"이왕에 여호와께서 너희에게 선을 행하시고 너희로 번성케 하시기를 기뻐하시던 것 같이 이제는 여호와께서 너희를 망하게 하시며 멸하시기를 기뻐하시리니 너희가 들어가 얻는 땅에서 뽑힐 것이요","reference":"신명기 28:63","category":"$undefined"},{"id":"5676","book":"신명기","book_name":"신명기","chapter":28,"verse":64,"text":"여호와께서 너를 땅 이 끝에서, 저 끝까지 만민 중에 흩으시리니 네가 그 곳에서 너와 네 열조의 알지 못하던 목석 우상을 섬길 것이라","reference":"신명기 28:64","category":"$undefined"},{"id":"5677","book":"신명기","book_name":"신명기","chapter":28,"verse":65,"text":"그 열국 중에서 네가 평안함을 얻지 못하며 네 발바닥을 쉴 곳도 얻지 못하고 오직 여호와께서 거기서 너의 마음으로 떨고 눈으로 쇠하고 정신으로 산란케 하시리니","reference":"신명기 28:65","category":"$undefined"},{"id":"5678","book":"신명기","book_name":"신명기","chapter":28,"verse":66,"text":"네 생명이 의심나는 곳에 달린 것 같아서 주야로 두려워하며 네 생명을 확신할수 없을 것이라","reference":"신명기 28:66","category":"$undefined"},{"id":"5679","book":"신명기","book_name":"신명기","chapter":28,"verse":67,"text":"네 마음의 두려움과 눈의 보는 것으로 인하여 아침에는 이르기를 아하, 저녁이 되었으면 좋겠다 할 것이요 저녁에는 이르기를 아하, 아침이 되었으면 좋겠다 하리라","reference":"신명기 28:67","category":"$undefined"},{"id":"5680","book":"신명기","book_name":"신명기","chapter":28,"verse":68,"text":"여호와께서 너를 배에 실으시고 전에 네게 고하여 이르시기를 네가 다시는 그 길을 보지 아니하리라 하시던 그 길로 너를 애굽으로 끌어가실 것이라 거기서 너희가 너희 몸을 대적에게 노비로 팔려하나 너희를 살 자가 없으리라","reference":"신명기 28:68","category":"$undefined"}],"bookSlug":"deuteronomy"}]
