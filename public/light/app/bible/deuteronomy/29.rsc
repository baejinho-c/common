2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":29,"verses":[{"id":"5681","book":"신명기","book_name":"신명기","chapter":29,"verse":1,"text":"호렙에서 이스라엘 자손과 세우신 언약 외에 여호와께서 모세에게 명하사 모압 땅에서 또 그들과 세우신 언약의 말씀이 이러하 니라","reference":"신명기 29:1","category":"$undefined"},{"id":"5682","book":"신명기","book_name":"신명기","chapter":29,"verse":2,"text":"모세가 온 이스라엘을 소집하고 그들에게 이르되 여호와께서 애굽 땅에서 너희 목전에 바로와 그 모든 신하와 그 온 땅에 행하신 모든 일을 너희가 보았나니","reference":"신명기 29:2","category":"$undefined"},{"id":"5683","book":"신명기","book_name":"신명기","chapter":29,"verse":3,"text":"곧 그 큰 시험과 이적과 큰 기사를 네가 목도하였느니라","reference":"신명기 29:3","category":"$undefined"},{"id":"5684","book":"신명기","book_name":"신명기","chapter":29,"verse":4,"text":"그러나 깨닫는 마음과 보는 눈과 듣는 귀는 오늘날까지 여호와께서 너희에게 주지 아니하셨느니라","reference":"신명기 29:4","category":"$undefined"},{"id":"5685","book":"신명기","book_name":"신명기","chapter":29,"verse":5,"text":"주께서 사십년 동안 너희를 인도하여 광야를 통행케 하셨거니와 너희 몸의 옷이 낡지 아니하였고 너희 발의 신이 해어지지 아니하였으며","reference":"신명기 29:5","category":"$undefined"},{"id":"5686","book":"신명기","book_name":"신명기","chapter":29,"verse":6,"text":"너희로 떡도 먹지 못하며 포도주나 독주를 마시지 못하게 하셨음은 주는 너희 하나님 여호와이신 줄을 알게 하려 하심이니라","reference":"신명기 29:6","category":"$undefined"},{"id":"5687","book":"신명기","book_name":"신명기","chapter":29,"verse":7,"text":"너희가 이곳에 올 때에 헤스본 왕 시혼과 바산 왕 옥이 우리와 싸우러 나왔으므로 우리가 그들을 치고","reference":"신명기 29:7","category":"$undefined"},{"id":"5688","book":"신명기","book_name":"신명기","chapter":29,"verse":8,"text":"그 땅을 취하여 르우벤과 갓과 므낫세 반 지파에게 기업으로 주었나니","reference":"신명기 29:8","category":"$undefined"},{"id":"5689","book":"신명기","book_name":"신명기","chapter":29,"verse":9,"text":"그런즉 너희는 이 언약의 말씀을 지켜 행하라 ! 그리하면 너희의 하는 모든 일이 형통하리라","reference":"신명기 29:9","category":"$undefined"},{"id":"5690","book":"신명기","book_name":"신명기","chapter":29,"verse":10,"text":"오늘날 너희 곧 너희 두령과 너희 지파와 너희 장로들과 너희 유사와 이스라엘 모든 남자와","reference":"신명기 29:10","category":"$undefined"},{"id":"5691","book":"신명기","book_name":"신명기","chapter":29,"verse":11,"text":"너희 유아들과 너희 아내와 및 네 진중에 있는 객과 무릇 너를 위하여 나무를 패는 자로부터 물 긷는 자까지 다 너희 하나님 여호와 앞에 선 것은","reference":"신명기 29:11","category":"$undefined"},{"id":"5692","book":"신명기","book_name":"신명기","chapter":29,"verse":12,"text":"너의 하나님 여호와의 언약에 참예하며 또 너의 하나님 여호와께서 오늘날 네게 향하여 하시는 맹세에 참예하여","reference":"신명기 29:12","category":"$undefined"},{"id":"5693","book":"신명기","book_name":"신명기","chapter":29,"verse":13,"text":"여호와께서 이왕에 네게 말씀하신 대로 또 네 열조 아브라함과 이삭과 야곱에게 맹세하신 대로 오늘날 너를 세워 자기 백성을 삼으시고 자기는 친히 네 하나님이 되시려 함이니라","reference":"신명기 29:13","category":"$undefined"},{"id":"5694","book":"신명기","book_name":"신명기","chapter":29,"verse":14,"text":"내가 이 언약과 맹세를 너희에게만 세우는 것이 아니라","reference":"신명기 29:14","category":"$undefined"},{"id":"5695","book":"신명기","book_name":"신명기","chapter":29,"verse":15,"text":"오늘날 우리 하나님 여호와 앞에서 우리와 함께 여기 선 자와 오늘날 우리와 함께 여기 있지 아니한 자에게까지니","reference":"신명기 29:15","category":"$undefined"},{"id":"5696","book":"신명기","book_name":"신명기","chapter":29,"verse":16,"text":"(우리가 애굽 땅에 어떻게 거하였었는지 너희가 여러 나라를 어떻게 통과하여 왔었는지 너희가 알며","reference":"신명기 29:16","category":"$undefined"},{"id":"5697","book":"신명기","book_name":"신명기","chapter":29,"verse":17,"text":"너희가 또 그들 중에 있는 가증한 것과 목석과 은금의 우상을 보았느니라)","reference":"신명기 29:17","category":"$undefined"},{"id":"5698","book":"신명기","book_name":"신명기","chapter":29,"verse":18,"text":"너희 중에 남자나 여자나 가족이나 지파나 오늘날 그 마음이 우리 하나님 여호와를 떠나서 그 모든 민족의 신들에게 가서 섬길까 염려하며 독초와 쑥의 뿌리가 너희 중에 생겨서","reference":"신명기 29:18","category":"$undefined"},{"id":"5699","book":"신명기","book_name":"신명기","chapter":29,"verse":19,"text":"이 저주의 말을 듣고도 심중에 스스로 위로하여 이르기를 내가 내 마음을 강퍅케 하여 젖은 것과 마른 것을 멸할지라도 평안하리라 할까 염려함이라","reference":"신명기 29:19","category":"$undefined"},{"id":"5700","book":"신명기","book_name":"신명기","chapter":29,"verse":20,"text":"여호와는 이런 자를 사하지 않으실 뿐 아니라 여호와의 분노와 질투의 불로 그의 위에 붓게 하시며 또 이 책에 기록된 모든 저주로 그에게 더하실 것이라 여호와께서 필경은 그의 이름을 천하에서 도말하시되","reference":"신명기 29:20","category":"$undefined"},{"id":"5701","book":"신명기","book_name":"신명기","chapter":29,"verse":21,"text":"여호와께서 곧 이스라엘 모든 지파 중에서 그를 구별하시고 이 율법 책에 기록된 언약의 모든 저주대로 그에게 화를 더하시리라","reference":"신명기 29:21","category":"$undefined"},{"id":"5702","book":"신명기","book_name":"신명기","chapter":29,"verse":22,"text":"너희 뒤에 일어나는 너희 자손과 원방에서 오는 객이 그 땅의 재앙과 여호와께서 그 땅에 유행시키시는 질병을 보며","reference":"신명기 29:22","category":"$undefined"},{"id":"5703","book":"신명기","book_name":"신명기","chapter":29,"verse":23,"text":"그 온 땅이 유황이 되며 소금이 되며 또 불에 타서 심지도 못하며 결실함도 없으며 거기 아무 풀도 나지 아니함이 옛적에 여호와께서 진노와 분한으로 훼멸하신 소돔과 고모라와 아드마와 스보임의 무너짐과 같음을 보고 말할 것이요","reference":"신명기 29:23","category":"$undefined"},{"id":"5704","book":"신명기","book_name":"신명기","chapter":29,"verse":24,"text":"열방 사람들도 말하기를 여호와께서 어찌하여 이 땅에 이같이 행하셨느뇨 ? 이같이 크고 열렬하게 노하심은 무슨 뜻이뇨 ? 하면","reference":"신명기 29:24","category":"$undefined"},{"id":"5705","book":"신명기","book_name":"신명기","chapter":29,"verse":25,"text":"그 때에 사람이 대답하기를 그 무리가 자기의 조상의 하나님 여호와께서 그 조상을 애굽에서 인도하여 내실 때에 더불어 세우신 언약을 버리고","reference":"신명기 29:25","category":"$undefined"},{"id":"5706","book":"신명기","book_name":"신명기","chapter":29,"verse":26,"text":"가서 자기들이 알지도 못하고 여호와께서 그들에게 주시지도 아니한 다른 신들을 섬겨 그에게 절한 까닭이라","reference":"신명기 29:26","category":"$undefined"},{"id":"5707","book":"신명기","book_name":"신명기","chapter":29,"verse":27,"text":"이러므로 여호와께서 이 땅을 향하여 진노하사 이 책에 기록된 모든 저주대로 재앙을 내리시고","reference":"신명기 29:27","category":"$undefined"},{"id":"5708","book":"신명기","book_name":"신명기","chapter":29,"verse":28,"text":"여호와께서 또 진노와 분한과 크게 통한하심으로 그들을 이 땅에서 뽑아내사 다른 나라에 던져 보내심이 오늘날과 같다 하리라","reference":"신명기 29:28","category":"$undefined"},{"id":"5709","book":"신명기","book_name":"신명기","chapter":29,"verse":29,"text":"오묘한 일은 우리 하나님 여호와께 속하였거니와 나타난 일은 영구히 우리와 우리 자손에게 속하였나니 이는 우리로 이 율법의 모든 말씀을 행하게 하심이니라","reference":"신명기 29:29","category":"$undefined"}],"bookSlug":"deuteronomy"}]
