2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":3,"verses":[{"id":"4977","book":"신명기","book_name":"신명기","chapter":3,"verse":1,"text":"우리가 돌이켜 바산으로 올라가매 바산 왕 옥이 그 모든 백성을 거느리고 나와서 우리를 대적하여 에드레이에서 싸우는지라","reference":"신명기 3:1","category":"$undefined"},{"id":"4978","book":"신명기","book_name":"신명기","chapter":3,"verse":2,"text":"여호와께서 내게 이르시되 그를 두려워 말라 ! 내가 그와 그 모든 백성과 그 땅을 네 손에 붙였으니 네가 헤스본에 거하던 아모리 족속의 왕 시혼에게 행한 것과 같이 그에게 행할 것이니라 하시고","reference":"신명기 3:2","category":"$undefined"},{"id":"4979","book":"신명기","book_name":"신명기","chapter":3,"verse":3,"text":"우리 하나님 여호와께서 바산 왕 옥과 그 모든 백성을 우리 손에 붙이시매 우리가 그들을 쳐서 한 사람도 남기지 아니하였느니라","reference":"신명기 3:3","category":"$undefined"},{"id":"4980","book":"신명기","book_name":"신명기","chapter":3,"verse":4,"text":"그 때에 우리가 그들에게서 빼앗지 아니한 성읍이 하나도 없이 다 빼앗았는데 그 성읍이 육십이니 곧 아르곱 온 지방이요 바산에 있는 옥의 나라이라","reference":"신명기 3:4","category":"$undefined"},{"id":"4981","book":"신명기","book_name":"신명기","chapter":3,"verse":5,"text":"그 모든 성읍에 높은 성벽이 둘려 있고 문과 빗장이 있어 견고하며 그 외에 성벽 없는 고을이 심히 많았느니라","reference":"신명기 3:5","category":"$undefined"},{"id":"4982","book":"신명기","book_name":"신명기","chapter":3,"verse":6,"text":"우리가 헤스본 왕 시혼에게 행한 것과 같이 그 성읍들을 진멸하되 각 성읍의 남녀와 유아를 진멸하였으나","reference":"신명기 3:6","category":"$undefined"},{"id":"4983","book":"신명기","book_name":"신명기","chapter":3,"verse":7,"text":"오직 모든 육축과 그 성읍들에서 탈취한 것은 우리의 소유로 삼았으며","reference":"신명기 3:7","category":"$undefined"},{"id":"4984","book":"신명기","book_name":"신명기","chapter":3,"verse":8,"text":"그 때에 우리가 요단강 이편 땅을 아르논 골짜기에서부터 헤르몬 산에까지 아모리 족속의 두 왕에게서 취하였으니","reference":"신명기 3:8","category":"$undefined"},{"id":"4985","book":"신명기","book_name":"신명기","chapter":3,"verse":9,"text":"(헤르몬 산을 시돈 사람은 [시룐]이라 칭하고 아모리 족속은 [스닐]이라 칭하였느니라)","reference":"신명기 3:9","category":"$undefined"},{"id":"4986","book":"신명기","book_name":"신명기","chapter":3,"verse":10,"text":"우리의 취한 것은 평원의 모든 성읍과 길르앗 온 땅과 바산의 온 땅 곧 옥의 나라 바산의 성읍 살르가와 에드레이까지니라","reference":"신명기 3:10","category":"$undefined"},{"id":"4987","book":"신명기","book_name":"신명기","chapter":3,"verse":11,"text":"(르바임 족속의 남은 자는 바산 왕 옥 뿐이었으며 그의 침상은 철 침상이라 지금 오히려 암몬 족속의 랍바에 있지 아니하냐 ? 그것을 사람의 보통 규빗으로 재면 그 장이 아홉 규빗이요, 광이 네 규빗이니라)","reference":"신명기 3:11","category":"$undefined"},{"id":"4988","book":"신명기","book_name":"신명기","chapter":3,"verse":12,"text":"그 때에 우리가 이 땅을 얻으매 아르논 골짜기 곁에 아로엘에서부터 길르앗 산지 절반과 그 성읍들을 내가 르우벤 자손과 갓 자손에게 주었고","reference":"신명기 3:12","category":"$undefined"},{"id":"4989","book":"신명기","book_name":"신명기","chapter":3,"verse":13,"text":"길르앗의 남은 땅과 옥의 나라이었던 아르곱 온 지방 곧 온 바산으로는 내가 므낫세 반 지파에게 주었노라 (바산을 옛적에는 [르바임]의 땅이라 칭하더니","reference":"신명기 3:13","category":"$undefined"},{"id":"4990","book":"신명기","book_name":"신명기","chapter":3,"verse":14,"text":"므낫세의 아들 야일이 그술 족속과, 마아갓 족속의 경계까지의 아르곱 온 지방을 취하고 자기의 이름으로 이 바산을 [하봇야일]이라 칭하여 오늘까지 이르느니라)","reference":"신명기 3:14","category":"$undefined"},{"id":"4991","book":"신명기","book_name":"신명기","chapter":3,"verse":15,"text":"내가 마길에게 길르앗을 주었고","reference":"신명기 3:15","category":"$undefined"},{"id":"4992","book":"신명기","book_name":"신명기","chapter":3,"verse":16,"text":"르우벤 자손과, 갓 자손에게는 길르앗에서부터 아르논 골짜기까지 주었으되 그 골짜기의 중앙으로 지경을 정하였으니 곧 암몬 자손의 지경 얍복강까지며","reference":"신명기 3:16","category":"$undefined"},{"id":"4993","book":"신명기","book_name":"신명기","chapter":3,"verse":17,"text":"또는 아라바와 요단과 그 가요 긴네렛에서 아라바 바다 곧 염해와 비스가 산록에 이르기까지의 동편 지경이니라","reference":"신명기 3:17","category":"$undefined"},{"id":"4994","book":"신명기","book_name":"신명기","chapter":3,"verse":18,"text":"그 때에 내가 이 땅을 받은 너희에게 명하여 이르기를 너희의 하나님 여호와께서 이 땅을 너희에게 주어 기업이 되게 하셨은즉 너희 군인들은 무장하고 너희의 형제 이스라엘 자손의 선봉이 되어 건너가되","reference":"신명기 3:18","category":"$undefined"},{"id":"4995","book":"신명기","book_name":"신명기","chapter":3,"verse":19,"text":"너희에게 육축이 많은 줄 내가 아노니 너희의 처자와 육축은 내가 너희에게 준 성읍에 머무르라","reference":"신명기 3:19","category":"$undefined"},{"id":"4996","book":"신명기","book_name":"신명기","chapter":3,"verse":20,"text":"여호와께서 너희에게 주신 것 같이 너희 형제에게 안식을 주시리니 그들도 요단 저편에서 너희 하나님 여호와의 주시는 땅을 얻어 기업을 삼기에 이르거든 너희는 각기 내가 준 기업으로 돌아 갈 것이니라 하고","reference":"신명기 3:20","category":"$undefined"},{"id":"4997","book":"신명기","book_name":"신명기","chapter":3,"verse":21,"text":"그 때에 내가 여호수아에게 명하여 이르기를 너희 하나님 여호와께서 이 두 왕에게 행하신 모든 일을 네가 목도하였거니와 네가 가는 모든 나라에도 여호와께서 이와 같이 행하시리니","reference":"신명기 3:21","category":"$undefined"},{"id":"4998","book":"신명기","book_name":"신명기","chapter":3,"verse":22,"text":"너희는 그들을 두려워하지 말라 ! 너희 하나님 여호와 그가 너희를 위하여 싸우시리라 ! 하였노라","reference":"신명기 3:22","category":"$undefined"},{"id":"4999","book":"신명기","book_name":"신명기","chapter":3,"verse":23,"text":"그 때에 내가 여호와께 간구하기를","reference":"신명기 3:23","category":"$undefined"},{"id":"5000","book":"신명기","book_name":"신명기","chapter":3,"verse":24,"text":"`주 여호와여 ! 주께서 주의 크심과 주의 권능을 주의 종에게 나타내시기를 시작하였사오니 천지간에 무슨 신이 능히 주의 행하신 일 곧 주의 큰 능력으로 행하신 일같이 행할 수 있으리이까 ?","reference":"신명기 3:24","category":"$undefined"},{"id":"5001","book":"신명기","book_name":"신명기","chapter":3,"verse":25,"text":"구하옵나니 나로 건너가게 하사 요단 저편에 있는 아름다운 땅 아름다운 산과 레바논을 보게 하옵소서' 하되","reference":"신명기 3:25","category":"$undefined"},{"id":"5002","book":"신명기","book_name":"신명기","chapter":3,"verse":26,"text":"여호와께서 너희의 연고로 내게 진노하사 내 말을 듣지 아니하시고 내게 이르시기를 그만해도 족하니 이 일로 다시 내게 말하지 말라","reference":"신명기 3:26","category":"$undefined"},{"id":"5003","book":"신명기","book_name":"신명기","chapter":3,"verse":27,"text":"너는 비스가산 꼭대기에 올라가서 눈을 들어 동서 남북을 바라고 네 눈으로 그 땅을 보라 네가 이 요단을 건너지 못할 것임이니라","reference":"신명기 3:27","category":"$undefined"},{"id":"5004","book":"신명기","book_name":"신명기","chapter":3,"verse":28,"text":"너는 여호수아에게 명하고 그를 담대케 하며 그를 강경케 하라 그는 이 백성을 거느리고 건너가서 네가 볼 땅을 그들로 기업으로 얻게 하리라 하셨느니라","reference":"신명기 3:28","category":"$undefined"},{"id":"5005","book":"신명기","book_name":"신명기","chapter":3,"verse":29,"text":"그때에 우리가 벨브올 맞은편 골짜기에 거하였었느니라","reference":"신명기 3:29","category":"$undefined"}],"bookSlug":"deuteronomy"}]
