2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":32,"verses":[{"id":"5760","book":"신명기","book_name":"신명기","chapter":32,"verse":1,"text":"하늘이여 귀를 기울이라 내가 말하리라 땅은 내 입의 말을 들을지어다","reference":"신명기 32:1","category":"$undefined"},{"id":"5761","book":"신명기","book_name":"신명기","chapter":32,"verse":2,"text":"나의 교훈은 내리는 비요, 나의 말은 맺히는 이슬이요, 연한 풀 위에 가는 비요, 채소 위에 단 비로다","reference":"신명기 32:2","category":"$undefined"},{"id":"5762","book":"신명기","book_name":"신명기","chapter":32,"verse":3,"text":"내가 여호와의 이름을 전파하리니 너희는 위엄을 우리 하나님께 돌릴지어다 !","reference":"신명기 32:3","category":"$undefined"},{"id":"5763","book":"신명기","book_name":"신명기","chapter":32,"verse":4,"text":"그는 반석이시니 그 공덕이 완전하고 그 모든 길이 공평하며 진실무망하신 하나님이시니 공의로우시고 정직하시도다","reference":"신명기 32:4","category":"$undefined"},{"id":"5764","book":"신명기","book_name":"신명기","chapter":32,"verse":5,"text":"그들이 여호와를 향하여 악을 행하니 하나님의 자녀가 아니요 흠이 있는 사곡한 종류로다","reference":"신명기 32:5","category":"$undefined"},{"id":"5765","book":"신명기","book_name":"신명기","chapter":32,"verse":6,"text":"우매무지한 백성아 여호와께 이같이 보답하느냐 ? 그는 너를 얻으신 너의 아버지가 아니시냐 ? 너를 지으시고 세우셨도다","reference":"신명기 32:6","category":"$undefined"},{"id":"5766","book":"신명기","book_name":"신명기","chapter":32,"verse":7,"text":"옛날을 기억하라 역대의 연대를 생각하라 네 아비에게 물으라 그가 네게 설명할 것이요 네 어른들에게 물으라 그들이 네게 이르리로다","reference":"신명기 32:7","category":"$undefined"},{"id":"5767","book":"신명기","book_name":"신명기","chapter":32,"verse":8,"text":"지극히 높으신 자가 열국의 기업을 주실 때 인종을 분정하실 때에 이스라엘 자손의 수효대로 민족들의 경계를 정하셨도다","reference":"신명기 32:8","category":"$undefined"},{"id":"5768","book":"신명기","book_name":"신명기","chapter":32,"verse":9,"text":"여호와의 분깃은 자기 백성이라 야곱은 그 택하신 기업이로다","reference":"신명기 32:9","category":"$undefined"},{"id":"5769","book":"신명기","book_name":"신명기","chapter":32,"verse":10,"text":"여호와께서 그를 황무지에서, 짐승의 부르짖는 광야에서 만나시고 호위하시며 보호하시며 자기 눈동자같이 지키셨도다","reference":"신명기 32:10","category":"$undefined"},{"id":"5770","book":"신명기","book_name":"신명기","chapter":32,"verse":11,"text":"마치 독수리가 그 보금자리를 어지럽게 하며 그 새끼 위에 너풀 거리며 그 날개를 펴서 새끼를 받으며 그 날개 위에 그것을 업는것 같이","reference":"신명기 32:11","category":"$undefined"},{"id":"5771","book":"신명기","book_name":"신명기","chapter":32,"verse":12,"text":"여호와께서 홀로 그들을 인도하셨고 함께 한 다른 신이 없었도다","reference":"신명기 32:12","category":"$undefined"},{"id":"5772","book":"신명기","book_name":"신명기","chapter":32,"verse":13,"text":"여호와께서 그로 땅의 높은 곳을 타고 다니게 하시며 밭의 소산을 먹게 하시며 반석에서 꿀을,굳은 반석에서 기름을 빨게 하시며","reference":"신명기 32:13","category":"$undefined"},{"id":"5773","book":"신명기","book_name":"신명기","chapter":32,"verse":14,"text":"소의 젖 기름과 양의 젖과 어린 양의 기름과 바산 소산의 수양과 염소와 지극히 아름다운 밀을 먹이시며 또 포도즙의 붉은 술을 마시우셨도다","reference":"신명기 32:14","category":"$undefined"},{"id":"5774","book":"신명기","book_name":"신명기","chapter":32,"verse":15,"text":"그러한데 여수룬이 살지매 발로 찼도다 네가 살지고 부대하고 윤택하매 자기를 지으신 하나님을 버리며 자기를 구원하신 반석을 경홀히 여겼도다","reference":"신명기 32:15","category":"$undefined"},{"id":"5775","book":"신명기","book_name":"신명기","chapter":32,"verse":16,"text":"그들이 다른 신으로 그의 질투를 일으키며 가증한 것으로 그의 진노를 격발하였도다","reference":"신명기 32:16","category":"$undefined"},{"id":"5776","book":"신명기","book_name":"신명기","chapter":32,"verse":17,"text":"그들은 하나님께 제사하지 아니하고 마귀에게 하였으니 곧 그들의 알지 못하던 신,근래에 일어난 새 신,너희 열조의 두려워하지 않던 것들이로다","reference":"신명기 32:17","category":"$undefined"},{"id":"5777","book":"신명기","book_name":"신명기","chapter":32,"verse":18,"text":"너를 낳은 반석은 네가 상관치 아니하고 너를 내신 하나님은 네가 잊었도다","reference":"신명기 32:18","category":"$undefined"},{"id":"5778","book":"신명기","book_name":"신명기","chapter":32,"verse":19,"text":"여호와께서 보시고 미워하셨으니 그 자녀가 그를 격노케한 연고로다","reference":"신명기 32:19","category":"$undefined"},{"id":"5779","book":"신명기","book_name":"신명기","chapter":32,"verse":20,"text":"여호와의 말씀에 내가 내 얼굴을 숨겨 그들에게 보이지 않게 하고 그들의 종말의 어떠함을 보리니 그들은 심히 패역한 종류요 무신한 자녀임이로다","reference":"신명기 32:20","category":"$undefined"},{"id":"5780","book":"신명기","book_name":"신명기","chapter":32,"verse":21,"text":"그들이 하나님이 아닌 자로 나의 질투를 일으키며 그들의 허무한 것으로 나의 진노를 격발하였으니 나도 백성이 되지 아니한 자로 그들의 시기가 나게 하며 우준한 민족으로 그들의 분노를 격발하리로다","reference":"신명기 32:21","category":"$undefined"},{"id":"5781","book":"신명기","book_name":"신명기","chapter":32,"verse":22,"text":"내 분노의 불이 일어나서 음부 깊은 곳까지 사르며 땅의 그 소산을 삼키며 산들의 터도 붙게 하는도다","reference":"신명기 32:22","category":"$undefined"},{"id":"5782","book":"신명기","book_name":"신명기","chapter":32,"verse":23,"text":"내가 재앙을 그들의 위에 쌓으며 나의 살을 다하여 그들을 쏘리로다","reference":"신명기 32:23","category":"$undefined"},{"id":"5783","book":"신명기","book_name":"신명기","chapter":32,"verse":24,"text":"그들이 주리므로 파리하며 불 같은 더위와 독한 파멸에게 삼키울 것이라 내가 들짐승의 이와 티끌에 기는 것의 독을 그들에게 보내리로다","reference":"신명기 32:24","category":"$undefined"},{"id":"5784","book":"신명기","book_name":"신명기","chapter":32,"verse":25,"text":"밖으로는 칼에 방안에서는 놀람에 멸망하리니 청년 남자와 처녀와 젖 먹는 아이와 백발 노인까지리로다","reference":"신명기 32:25","category":"$undefined"},{"id":"5785","book":"신명기","book_name":"신명기","chapter":32,"verse":26,"text":"내가 그들을 흩어서 인간에서 그 기억이 끊어지게 하리라 하였다 마는","reference":"신명기 32:26","category":"$undefined"},{"id":"5786","book":"신명기","book_name":"신명기","chapter":32,"verse":27,"text":"대적을 격동할까 염려라 원수가 오해하고 말하기를 우리 수단이 높음이요 여호와의 행함이 아니라 할까 염려라 하시도다","reference":"신명기 32:27","category":"$undefined"},{"id":"5787","book":"신명기","book_name":"신명기","chapter":32,"verse":28,"text":"그들은 모략이 없는 국민이라 그 중에 지식이 없도다","reference":"신명기 32:28","category":"$undefined"},{"id":"5788","book":"신명기","book_name":"신명기","chapter":32,"verse":29,"text":"그들이 지혜가 있어서 이것을 깨닫고 자기의 종말을 생각하였으면","reference":"신명기 32:29","category":"$undefined"},{"id":"5789","book":"신명기","book_name":"신명기","chapter":32,"verse":30,"text":"그들의 반석이 그들을 팔지 아니하였고 여호와께서 그들을 내어 주지 아니하셨더면 어찌 한 사람이 천을 쫓으며 두 사람이 만을 도망케 하였을까","reference":"신명기 32:30","category":"$undefined"},{"id":"5790","book":"신명기","book_name":"신명기","chapter":32,"verse":31,"text":"대적의 반석이 우리의 반석과 같지 못하니 대적도 스스로 판단하도다","reference":"신명기 32:31","category":"$undefined"},{"id":"5791","book":"신명기","book_name":"신명기","chapter":32,"verse":32,"text":"그들의 포도나무는 소돔의 포도나무요 고모라의 밭의 소산이라 그들의 포도는 쓸개포도니 그 송이는 쓰며","reference":"신명기 32:32","category":"$undefined"},{"id":"5792","book":"신명기","book_name":"신명기","chapter":32,"verse":33,"text":"그들의 포도주는 뱀의 독이요 독사의 악독이라","reference":"신명기 32:33","category":"$undefined"},{"id":"5793","book":"신명기","book_name":"신명기","chapter":32,"verse":34,"text":"이것이 내게 쌓이고 내 곳간에 봉하여 있지 아니한가","reference":"신명기 32:34","category":"$undefined"},{"id":"5794","book":"신명기","book_name":"신명기","chapter":32,"verse":35,"text":"보수는 내 것이라 그들의 실족할 그 때에 갚으리로다 그들의 환난의 날이 가까우니 당할 그 일이 속히 임하리로다","reference":"신명기 32:35","category":"$undefined"},{"id":"5795","book":"신명기","book_name":"신명기","chapter":32,"verse":36,"text":"여호와께서 자기 백성을 판단하시고 그 종들을 인하여 후회하시리니 곧 그들의 무력함과 갇힌 자나 놓인 자가 없음을 보시는 때에로다","reference":"신명기 32:36","category":"$undefined"},{"id":"5796","book":"신명기","book_name":"신명기","chapter":32,"verse":37,"text":"여호와의 말씀에 그들의 신들이 어디 있으며 그들의 피하던 반석이 어디 있느냐 ?","reference":"신명기 32:37","category":"$undefined"},{"id":"5797","book":"신명기","book_name":"신명기","chapter":32,"verse":38,"text":"그들의 희생의 고기를 먹던 것들, 전제의 술을 마시던 것들로 일어나서 너희를 돕게 하라 너희의 보장이 되게 하라","reference":"신명기 32:38","category":"$undefined"},{"id":"5798","book":"신명기","book_name":"신명기","chapter":32,"verse":39,"text":"이제는 나 곧 내가 그인 줄 알라 나와 함께 하는 신이 없도다 내가 죽이기도 하며 살리기도 하며 상하게도 하며 낫게도 하나니 내 손에서 능히 건질 자 없도다","reference":"신명기 32:39","category":"$undefined"},{"id":"5799","book":"신명기","book_name":"신명기","chapter":32,"verse":40,"text":"내가 하늘을 향하여 내 손을 들고 말하노라 나의 영원히 삶을 두고 맹세하노니","reference":"신명기 32:40","category":"$undefined"},{"id":"5800","book":"신명기","book_name":"신명기","chapter":32,"verse":41,"text":"나의 번쩍이는 칼을 갈며 내 손에 심판을 잡고 나의 대적에게 보수하며 나를 미워하는 자에게 보응할 것이라","reference":"신명기 32:41","category":"$undefined"},{"id":"5801","book":"신명기","book_name":"신명기","chapter":32,"verse":42,"text":"나의 화살로 피에 취하게 하고 나의 칼로 그 고기를 삼키게 하리니 곧 피살자와 포로된 자의 피요 대적의 장관의 머리로다 하시도다","reference":"신명기 32:42","category":"$undefined"},{"id":"5802","book":"신명기","book_name":"신명기","chapter":32,"verse":43,"text":"너희 열방은 주의 백성과 즐거워 하라 ! 주께서 그 종들의 피를 갚으사 그 대적에게 보수하시고 자기 땅과 백성을 위하여 속죄하시리로다","reference":"신명기 32:43","category":"$undefined"},{"id":"5803","book":"신명기","book_name":"신명기","chapter":32,"verse":44,"text":"모세와 눈의 아들 호세아가 와서 이 노래의 모든 말씀을 백성에게 말하여 들리니라","reference":"신명기 32:44","category":"$undefined"},{"id":"5804","book":"신명기","book_name":"신명기","chapter":32,"verse":45,"text":"모세가 이 모든 말씀을 온 이스라엘에게 말하기를 마치고","reference":"신명기 32:45","category":"$undefined"},{"id":"5805","book":"신명기","book_name":"신명기","chapter":32,"verse":46,"text":"그들에게 이르되 `내가 오늘날 너희에게 증거한 모든 말을 너희 마음에 두고 너희 자녀에게 명하여 이 율법의 모든 말씀을 지켜 행하게 하라","reference":"신명기 32:46","category":"$undefined"},{"id":"5806","book":"신명기","book_name":"신명기","chapter":32,"verse":47,"text":"이는 너희에게 허사가 아니라 너희의 생명이니 이 일로 인하여 너희가 요단을 건너 얻을 땅에서 너희의 날이 장구하리라'","reference":"신명기 32:47","category":"$undefined"},{"id":"5807","book":"신명기","book_name":"신명기","chapter":32,"verse":48,"text":"당일에 여호와께서 모세에게 일러 가라사대","reference":"신명기 32:48","category":"$undefined"},{"id":"5808","book":"신명기","book_name":"신명기","chapter":32,"verse":49,"text":"너는 여리고 맞은편 모압 땅에 있는 아바림산에 올라 느보산에 이르러 내가 이스라엘 자손에게 기업으로 주는 가나안 땅을 바라보라","reference":"신명기 32:49","category":"$undefined"},{"id":"5809","book":"신명기","book_name":"신명기","chapter":32,"verse":50,"text":"네 형 아론이 호르산에서 죽어 그 조상에게로 돌아간 것 같이 너도 올라가는 이 산에서 죽어 네 조상에게로 돌아가리니","reference":"신명기 32:50","category":"$undefined"},{"id":"5810","book":"신명기","book_name":"신명기","chapter":32,"verse":51,"text":"이는 너희가 신 광야 가데스의 므리바 물 가에서 이스라엘 자손중 내게 범죄하여 나의 거룩함을 이스라엘 자손 중에서 나타내지 아니한 연고라","reference":"신명기 32:51","category":"$undefined"},{"id":"5811","book":"신명기","book_name":"신명기","chapter":32,"verse":52,"text":"내가 이스라엘 자손에게 주는 땅을 네가 바라보기는 하려니와 그리로 들어가지는 못하리라 하시니라","reference":"신명기 32:52","category":"$undefined"}],"bookSlug":"deuteronomy"}]
