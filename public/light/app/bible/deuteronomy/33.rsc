2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":33,"verses":[{"id":"5812","book":"신명기","book_name":"신명기","chapter":33,"verse":1,"text":"하나님의 사람 모세가 죽기 전에 이스라엘 자손을 위하여 축복함이 이러하니라","reference":"신명기 33:1","category":"$undefined"},{"id":"5813","book":"신명기","book_name":"신명기","chapter":33,"verse":2,"text":"일렀으되 여호와께서 시내에서 오시고 세일산에서 일어나시고 바란산에서 비취시고 일만 성도 가운데서 강림하셨고 그 오른손에는 불 같은 율법이 있도다","reference":"신명기 33:2","category":"$undefined"},{"id":"5814","book":"신명기","book_name":"신명기","chapter":33,"verse":3,"text":"여호와께서 백성을 사랑하시나니 모든 성도가 그 수중에 있으며 주의 발 아래에 앉아서 주의 말씀을 받는도다","reference":"신명기 33:3","category":"$undefined"},{"id":"5815","book":"신명기","book_name":"신명기","chapter":33,"verse":4,"text":"모세가 우리에게 율법을 명하였으니 곧 야곱의 총회의 기업이로다","reference":"신명기 33:4","category":"$undefined"},{"id":"5816","book":"신명기","book_name":"신명기","chapter":33,"verse":5,"text":"여수룬에 왕이 있었으니 곧 백성의 두령이 모이고 이스라엘 모든 지파가 함께 한 때에로다","reference":"신명기 33:5","category":"$undefined"},{"id":"5817","book":"신명기","book_name":"신명기","chapter":33,"verse":6,"text":"르우벤은 살고 죽지 아니하고 그 인수가 적지 않기를 원하도다","reference":"신명기 33:6","category":"$undefined"},{"id":"5818","book":"신명기","book_name":"신명기","chapter":33,"verse":7,"text":"유다에 대한 축복은 이러하니라 일렀으되 여호와여 ! 유다의 음성을 들으시고 그 백성에게로 인도하시오며 그 손으로 자기를 위하여 싸우게 하시고 주께서 도우사 그로 그 대적을 치게 하시기를 원하나이다","reference":"신명기 33:7","category":"$undefined"},{"id":"5819","book":"신명기","book_name":"신명기","chapter":33,"verse":8,"text":"레위에 대하여는 일렀으되 주의 둠밈과 우림이 주의 경건한 자에게 있도다 주께서 그를 맛사에서 시험하시고 므리바 물 가에서 그와 다투셨도다","reference":"신명기 33:8","category":"$undefined"},{"id":"5820","book":"신명기","book_name":"신명기","chapter":33,"verse":9,"text":"그는 그 부모에게 대하여 이르기를 내가 그들을 보지 못하였다 하며 그 형제들을 인정치 아니하며 그 자녀를 알지 아니한 것은 주의 말씀을 준행하고 주의 언약을 지킴을 인함이로다","reference":"신명기 33:9","category":"$undefined"},{"id":"5821","book":"신명기","book_name":"신명기","chapter":33,"verse":10,"text":"주의 법도를 야곱에게, 주의 율법을 이스라엘에게 가르치며 주 앞에 분향하고 온전한 번제를 주의 단 위에 드리리로다","reference":"신명기 33:10","category":"$undefined"},{"id":"5822","book":"신명기","book_name":"신명기","chapter":33,"verse":11,"text":"여호와여 ! 그 재산을 풍족케 하시고 그 손의 일을 받으소서 ! 그를 대적하여 일어나는 자와 미워하는 자의 허리를 꺽으사 다시 일어나지 못하게 하옵소서 !","reference":"신명기 33:11","category":"$undefined"},{"id":"5823","book":"신명기","book_name":"신명기","chapter":33,"verse":12,"text":"베냐민에 대하여는 일렀으되 여호와의 사랑을 입은 자는 그 곁에 안전히 거하리로다 여호와께서 그를 날이 맞도록 보호하시고 그로 자기 어깨 사이에 처하게 하시리로다","reference":"신명기 33:12","category":"$undefined"},{"id":"5824","book":"신명기","book_name":"신명기","chapter":33,"verse":13,"text":"요셉에 대하여는 일렀으되 원컨대 그 땅이 여호와께 복을 받아 하늘의 보물인 이슬과 땅 아래 저장한 물과","reference":"신명기 33:13","category":"$undefined"},{"id":"5825","book":"신명기","book_name":"신명기","chapter":33,"verse":14,"text":"태양이 결실케 하는 보물과 태음이 자라게 하는 보물과","reference":"신명기 33:14","category":"$undefined"},{"id":"5826","book":"신명기","book_name":"신명기","chapter":33,"verse":15,"text":"옛 산의 상품물과 영원한 작은 산의 보물과","reference":"신명기 33:15","category":"$undefined"},{"id":"5827","book":"신명기","book_name":"신명기","chapter":33,"verse":16,"text":"땅의 보물과 거기 충만한 것과 가시떨기 나무 가운데 거하시던 자의 은혜로 인하여 복이 요셉의 머리에, 그 형제 중 구별한 자의 정수리에 임할지로다","reference":"신명기 33:16","category":"$undefined"},{"id":"5828","book":"신명기","book_name":"신명기","chapter":33,"verse":17,"text":"그는 첫 수송아지 같이 위엄이 있으니 그 뿔이 들소의 뿔 같도다 이것으로 열방을 받아 땅 끝까지 이르리니 곧 에브라임의 만민이요 므낫세의 천천이리로다","reference":"신명기 33:17","category":"$undefined"},{"id":"5829","book":"신명기","book_name":"신명기","chapter":33,"verse":18,"text":"스불론에 대하여는 일렀으되 스불론이여 너는 나감을 기뻐하라 잇사갈이여 ! 너는 장막에 있음을 즐거워하라 !","reference":"신명기 33:18","category":"$undefined"},{"id":"5830","book":"신명기","book_name":"신명기","chapter":33,"verse":19,"text":"그들이 열국 백성을 불러 산에 이르게 하고 거기서 의로운 제사를 드릴 것이며 바다의 풍부한 것,모래에 감추인 보배를 흡수하리로다","reference":"신명기 33:19","category":"$undefined"},{"id":"5831","book":"신명기","book_name":"신명기","chapter":33,"verse":20,"text":"갓에 대하여는 일렀으되 갓을 광대케 하시는 자에게 찬송을 부를지어다 ! 갓이 암사자같이 엎드리고 팔과 정수리를 찢는도다","reference":"신명기 33:20","category":"$undefined"},{"id":"5832","book":"신명기","book_name":"신명기","chapter":33,"verse":21,"text":"그가 자기를 위하여 먼저 기업을 택하였으니 곧 법 세운 자의 분깃으로 예비된 것이로다 그가 백성의 두령들과 함께 와서 여호와의 공의와 이스라엘과 세우신 법도를 행하도다","reference":"신명기 33:21","category":"$undefined"},{"id":"5833","book":"신명기","book_name":"신명기","chapter":33,"verse":22,"text":"단에 대하여는 일렀으되 단은 바산에서 뛰어 나오는 사자의 새끼로다","reference":"신명기 33:22","category":"$undefined"},{"id":"5834","book":"신명기","book_name":"신명기","chapter":33,"verse":23,"text":"납달리에 대하여는 일렀으되 은혜가 족하고 여호와의 복이 가득한 납달리여 ! 너는 서방과 남방을 얻을지로다","reference":"신명기 33:23","category":"$undefined"},{"id":"5835","book":"신명기","book_name":"신명기","chapter":33,"verse":24,"text":"아셀에 대하여는 일렀으되 아셀은 다자한 복을 받으며 그 형제에게 기쁨이 되며 그 발이 기름에 잠길지로다","reference":"신명기 33:24","category":"$undefined"},{"id":"5836","book":"신명기","book_name":"신명기","chapter":33,"verse":25,"text":"네 문빗장은 철과 놋이 될 것이니 네 사는 날을 따라서 능력이 있으리로다","reference":"신명기 33:25","category":"$undefined"},{"id":"5837","book":"신명기","book_name":"신명기","chapter":33,"verse":26,"text":"여수룬이여 ! 하나님 같은 자 없도다 그가 너를 도우시려고 하늘을 타시고 궁창에서 위엄을 나타내시는도다","reference":"신명기 33:26","category":"$undefined"},{"id":"5838","book":"신명기","book_name":"신명기","chapter":33,"verse":27,"text":"영원하신 하나님이 너의 처소가 되시니 그 영원하신 팔이 네 아래 있도다 그가 네 앞에서 대적을 쫓으시며 멸하라 하시도다","reference":"신명기 33:27","category":"$undefined"},{"id":"5839","book":"신명기","book_name":"신명기","chapter":33,"verse":28,"text":"이스라엘이 안전히 거하며 야곱의 샘은 곡식과 새 포도주의 땅에 홀로 있나니 곧 그의 하늘이 이슬을 내리는 곳에로다","reference":"신명기 33:28","category":"$undefined"},{"id":"5840","book":"신명기","book_name":"신명기","chapter":33,"verse":29,"text":"이스라엘이여 ! 너는 행복자로다 ! 여호와의 구원을 너같이 얻은 백성이 누구뇨 그는 너를 돕는 방패시요 너의 영광의 칼이시로다 네 대적이 네게 복종하리니 네가 그들의 높은 곳을 밟으리로다","reference":"신명기 33:29","category":"$undefined"}],"bookSlug":"deuteronomy"}]
