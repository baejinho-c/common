2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":34,"verses":[{"id":"5841","book":"신명기","book_name":"신명기","chapter":34,"verse":1,"text":"모세가 모압 평지에서 느보산에 올라 여리고 맞은편 비스가산 꼭대기에 이르매 여호와께서 길르앗 온 땅을 단까지 보이시고","reference":"신명기 34:1","category":"$undefined"},{"id":"5842","book":"신명기","book_name":"신명기","chapter":34,"verse":2,"text":"또 온 납달리와 에브라임과 므낫세의 땅과 서해까지의 유다 온 땅과","reference":"신명기 34:2","category":"$undefined"},{"id":"5843","book":"신명기","book_name":"신명기","chapter":34,"verse":3,"text":"남방과 종려의 성읍 여리고 골짜기 평지를 소알까지 보이시고","reference":"신명기 34:3","category":"$undefined"},{"id":"5844","book":"신명기","book_name":"신명기","chapter":34,"verse":4,"text":"여호와께서 그에게 이르시되 이는 내가 아브라함과 이삭과 야곱에게 맹세하여 그 후손에게 주리라 한 땅이라 내가 네 눈으로 보게 하였거니와 너는 그리로 건너가지 못하리라 하시매","reference":"신명기 34:4","category":"$undefined"},{"id":"5845","book":"신명기","book_name":"신명기","chapter":34,"verse":5,"text":"이에 여호와의 종 모세가 여호와의 말씀대로 모압 땅에서 죽어","reference":"신명기 34:5","category":"$undefined"},{"id":"5846","book":"신명기","book_name":"신명기","chapter":34,"verse":6,"text":"벧브올 맞은편 모압 땅에 있는 골짜기에 장사되었고 오늘까지 그 묘를 아는 자 없으니라","reference":"신명기 34:6","category":"$undefined"},{"id":"5847","book":"신명기","book_name":"신명기","chapter":34,"verse":7,"text":"모세의 죽을 때 나이 일백 이십세나 그 눈이 흐리지 아니하였고 기력이 쇠하지 아니하였더라","reference":"신명기 34:7","category":"$undefined"},{"id":"5848","book":"신명기","book_name":"신명기","chapter":34,"verse":8,"text":"이스라엘 자손이 모압 평지에서 애곡하는 기한이 맞도록 모세를 위하여 삼십일을 애곡하니라","reference":"신명기 34:8","category":"$undefined"},{"id":"5849","book":"신명기","book_name":"신명기","chapter":34,"verse":9,"text":"모세가 눈의 아들 여호수아에게 안수하였으므로 그에게 지혜의 신이 충만하니 이스라엘 자손이 여호와께서 모세에게 명하신 대로 여호수아의 말을 순종하였더라","reference":"신명기 34:9","category":"$undefined"},{"id":"5850","book":"신명기","book_name":"신명기","chapter":34,"verse":10,"text":"그 후에는 이스라엘에 모세와 같은 선지자가 일어나지 못하였나니 모세는 여호와께서 대면하여 아시던 자요","reference":"신명기 34:10","category":"$undefined"},{"id":"5851","book":"신명기","book_name":"신명기","chapter":34,"verse":11,"text":"여호와께서 그를 애굽 땅에 보내사 바로와 그 모든 신하와 그 온 땅에 모든 이적과 기사와","reference":"신명기 34:11","category":"$undefined"},{"id":"5852","book":"신명기","book_name":"신명기","chapter":34,"verse":12,"text":"모든 큰 권능과 위엄을 행하게 하시매 온 이스라엘 목전에서 그것을 행한 자더라","reference":"신명기 34:12","category":"$undefined"}],"bookSlug":"deuteronomy"}]
