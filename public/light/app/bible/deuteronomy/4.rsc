2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":4,"verses":[{"id":"5006","book":"신명기","book_name":"신명기","chapter":4,"verse":1,"text":"이스라엘아 ! 이제 내가 너희에게 가르치는 규례와 법도를 듣고 준행하라 ! 그리하면 너희가 살 것이요 너희의 열조의 하나님 여호와께서 너희에게 주시는 땅에 들어가서 그것을 얻게 되리라","reference":"신명기 4:1","category":"$undefined"},{"id":"5007","book":"신명기","book_name":"신명기","chapter":4,"verse":2,"text":"내가 너희에게 명하는 말을 너희는 가감하지 말고 내가 너희에게 명하는 너희 하나님 여호와의 명령을 지키라 !","reference":"신명기 4:2","category":"$undefined"},{"id":"5008","book":"신명기","book_name":"신명기","chapter":4,"verse":3,"text":"여호와께서 바알브올의 일을 인하여 행하신 바를 너희가 목도하였거니와 바알브올을 좇은 모든 사람을 너의 하나님 여호와께서 너의 중에서 진멸하셨으되","reference":"신명기 4:3","category":"$undefined"},{"id":"5009","book":"신명기","book_name":"신명기","chapter":4,"verse":4,"text":"오직 ! 너희의 하나님 여호와께 붙어 떠나지 않은 너희는 오늘까지 다 생존하였느니라","reference":"신명기 4:4","category":"$undefined"},{"id":"5010","book":"신명기","book_name":"신명기","chapter":4,"verse":5,"text":"내가 나의 하나님 여호와의 명하신 대로 규례와 법도를 너희에게 가르쳤나니 이는 너희로 들어가서 기업으로 얻을 땅에서 그대로 행하게 하려 함인즉","reference":"신명기 4:5","category":"$undefined"},{"id":"5011","book":"신명기","book_name":"신명기","chapter":4,"verse":6,"text":"너희는 지켜 행하라 ! 그리함은 열국 앞에 너희의 지혜요 너희의 지식이라 그들이 이 모든 규례를 듣고 이르기를 이 큰 나라 사람은 과연 지혜와 지식이 있는 백성이로다 하리라","reference":"신명기 4:6","category":"$undefined"},{"id":"5012","book":"신명기","book_name":"신명기","chapter":4,"verse":7,"text":"우리 하나님 여호와께서 우리가 그에게 기도할 때마다 우리에게 가까이 하심과 같이 그 신의 가까이 함을 얻은 나라가 어디 있느냐 ?","reference":"신명기 4:7","category":"$undefined"},{"id":"5013","book":"신명기","book_name":"신명기","chapter":4,"verse":8,"text":"오늘 내가 너희에게 선포하는 이 율법과 같이 그 규례와 법도가 공의로운 큰 나라가 어디 있느냐 ?","reference":"신명기 4:8","category":"$undefined"},{"id":"5014","book":"신명기","book_name":"신명기","chapter":4,"verse":9,"text":"오직 너는 스스로 삼가며 네 마음을 힘써 지키라 두렵건대 네가 그 목도한 일을 잊어버릴까 하노라 두렵건대 네 생존하는 날 동안에 그 일들이 네 마음 속에서 떠날까 하노라 너는 그 일들을 네 아들들과 네 손자들에게 알게 하라","reference":"신명기 4:9","category":"$undefined"},{"id":"5015","book":"신명기","book_name":"신명기","chapter":4,"verse":10,"text":"네가 호렙산에서 네 하나님 여호와 앞에 섰던 날에 여호와께서 내게 이르시기를 나를 위하여 백성을 모으라 내가 그들에게 내 말을 들려서 그들로 세상에 사는 날 동안 나 경외함을 배우게 하며 그 자녀에게 가르치게 하려 하노라 하시매","reference":"신명기 4:10","category":"$undefined"},{"id":"5016","book":"신명기","book_name":"신명기","chapter":4,"verse":11,"text":"너희가 가까이 나아와서 산 아래 서니 그 산에 불이 붙어 화염이 충천하고 유암과 구름과 흑암이 덮였는데","reference":"신명기 4:11","category":"$undefined"},{"id":"5017","book":"신명기","book_name":"신명기","chapter":4,"verse":12,"text":"여호와께서 화염 중에서 너희에게 말씀하시되 음성 뿐이므로 너희가 그 말소리만 듣고 형상은 보지 못하였느니라","reference":"신명기 4:12","category":"$undefined"},{"id":"5018","book":"신명기","book_name":"신명기","chapter":4,"verse":13,"text":"여호와께서 그 언약을 너희에게 반포하시고 너희로 지키라 명하셨으니 곧 십계명이며 두 돌판에 친히 쓰신 것이라","reference":"신명기 4:13","category":"$undefined"},{"id":"5019","book":"신명기","book_name":"신명기","chapter":4,"verse":14,"text":"그 때에 여호와께서 내게 명하사 너희에게 규례와 법도를 교훈하게 하셨나니 이는 너희로 건너가서 얻을 땅에서 행하게 하심이니라","reference":"신명기 4:14","category":"$undefined"},{"id":"5020","book":"신명기","book_name":"신명기","chapter":4,"verse":15,"text":"여호와께서 호렙산 화염 중에서 너희에게 말씀하시던 날에 너희가 아무 형상도 보지 못하였은즉 너희는 깊이 삼가라 !","reference":"신명기 4:15","category":"$undefined"},{"id":"5021","book":"신명기","book_name":"신명기","chapter":4,"verse":16,"text":"두렵건대 스스로 부패하여 자기를 위하여 아무 형상대로든지 우상을 새겨 만들되 남자의 형상이라든지, 여자의 형상이라든지,","reference":"신명기 4:16","category":"$undefined"},{"id":"5022","book":"신명기","book_name":"신명기","chapter":4,"verse":17,"text":"땅 위에 있는 아무 짐승의 형상이라든지, 하늘에 나는 아무 새의 형상이라든지,","reference":"신명기 4:17","category":"$undefined"},{"id":"5023","book":"신명기","book_name":"신명기","chapter":4,"verse":18,"text":"땅 위에 기는 아무 곤충의 형상이라든지, 땅 아래 물 속에 있는 아무 어족(魚族)의 형상이라든지 만들까 하노라","reference":"신명기 4:18","category":"$undefined"},{"id":"5024","book":"신명기","book_name":"신명기","chapter":4,"verse":19,"text":"땅 위에 기는 아무 곤충의 형상이라든지, 땅 아래 물 속에 있는 아무 어족(魚族)의 형상이라든지 만들까 하노라","reference":"신명기 4:19","category":"$undefined"},{"id":"5025","book":"신명기","book_name":"신명기","chapter":4,"verse":20,"text":"또 두렵건대 네가 하늘을 향하여 눈을 들어 일월 성신 하늘 위의 군중 곧 너희 하나님 여호와께서 천하 만민을 위하여 분정하신 것을 보고 미혹하여 그것에 경배하며 섬길까 하노라","reference":"신명기 4:20","category":"$undefined"},{"id":"5026","book":"신명기","book_name":"신명기","chapter":4,"verse":21,"text":"여호와께서 너희를 택하시고 너희를 쇠풀무 곧 애굽에서 인도하여 내사 자기 기업의 백성을 삼으신 것이 오늘과 같아도","reference":"신명기 4:21","category":"$undefined"},{"id":"5027","book":"신명기","book_name":"신명기","chapter":4,"verse":22,"text":"여호와께서 너희로 인하여 내게 진노하사 나로 요단을 건너지 못하며 네 하나님 여호와께서 네게 기업으로 주신 그 아름다운 땅에 들어가지 못하게 하리라고 맹세하셨은즉","reference":"신명기 4:22","category":"$undefined"},{"id":"5028","book":"신명기","book_name":"신명기","chapter":4,"verse":23,"text":"나는 이 땅에서 죽고 요단을 건너지 못하려니와 너희는 건너가서 그 아름다운 땅을 얻으리니","reference":"신명기 4:23","category":"$undefined"},{"id":"5029","book":"신명기","book_name":"신명기","chapter":4,"verse":24,"text":"너희는 스스로 삼가서 너희 하나님 여호와께서 너희와 세우신 언약을 잊어버려서 네 하나님 여호와께서 금하신 아무 형상의 우상이든지 조각하지 말라","reference":"신명기 4:24","category":"$undefined"},{"id":"5030","book":"신명기","book_name":"신명기","chapter":4,"verse":25,"text":"네 하나님 여호와는 소멸하는 불이시요 ! 질투하는 하나님이시니라 !","reference":"신명기 4:25","category":"$undefined"},{"id":"5031","book":"신명기","book_name":"신명기","chapter":4,"verse":26,"text":"네가 그 땅에서 아들을 낳고 손자를 얻으며 오래 살 때에 만일 스스로 부패하여 무슨 형상의 우상이든지 조각하여 네 하나님 여호와 앞에 악을 행함으로 그의 노를 격발하면","reference":"신명기 4:26","category":"$undefined"},{"id":"5032","book":"신명기","book_name":"신명기","chapter":4,"verse":27,"text":"내가 오늘날 천지를 불러 증거를 삼노니 너희가 요단을 건너가서 얻는 땅에서 속히 망할 것이라 너희가 거기서 너희 날이 길지 못하고 전멸될 것이니라","reference":"신명기 4:27","category":"$undefined"},{"id":"5033","book":"신명기","book_name":"신명기","chapter":4,"verse":28,"text":"여호와께서 너희를 열국 중에 흩으실 것이요 여호와께서 너희를 쫓아 보내실 그 열국 중에 너희의 남은 수가 많지 못할 것이며","reference":"신명기 4:28","category":"$undefined"},{"id":"5034","book":"신명기","book_name":"신명기","chapter":4,"verse":29,"text":"너희는 거기서 사람의 손으로 만든바 보지도 못하며 듣지도 못하며 먹지도 못하며 냄새도 맡지 못하는 목석의 신들을 섬기리라","reference":"신명기 4:29","category":"$undefined"},{"id":"5035","book":"신명기","book_name":"신명기","chapter":4,"verse":30,"text":"그러나 네가 거기서 네 하나님 여호와를 구하게 되리니 만일 마음을 다하고 성품을 다하여 그를 구하면 만나리라 !","reference":"신명기 4:30","category":"$undefined"},{"id":"5036","book":"신명기","book_name":"신명기","chapter":4,"verse":31,"text":"이 모든 일이 네게 임하여 환난을 당하다가 끝날에 네가 네 하나님 여호와께로 돌아와서 그 말씀을 청종하리니","reference":"신명기 4:31","category":"$undefined"},{"id":"5037","book":"신명기","book_name":"신명기","chapter":4,"verse":32,"text":"네 하나님 여호와는 자비하신 하나님이심이라 ! 그가 너를 버리지 아니하시며 너를 멸하지 아니하시며 네 열조에게 맹세하신 언약을 잊지 아니하시리라","reference":"신명기 4:32","category":"$undefined"},{"id":"5038","book":"신명기","book_name":"신명기","chapter":4,"verse":33,"text":"네가 있기 전 하나님이 사람을 세상에 창조하신 날부터 지금까지 지나간 날을 상고하여 보라 ! 하늘 이 끝에서 저 끝까지 이런 큰 일이 있었느냐 ? 이런 일을 들은 적이 있었느냐 ?","reference":"신명기 4:33","category":"$undefined"},{"id":"5039","book":"신명기","book_name":"신명기","chapter":4,"verse":34,"text":"어떤 국민이 불 가운데서 말씀하시는 하나님의 음성을 너처럼 듣고 생존하였었느냐 ?","reference":"신명기 4:34","category":"$undefined"},{"id":"5040","book":"신명기","book_name":"신명기","chapter":4,"verse":35,"text":"어떤 신이 와서 시험과 이적과 기사와 전쟁과 강한 손과 편 팔과 크게 두려운 일로 한 민족을 다른 민족에게서 인도하여 낸 일이 있느냐 ? 이는 다 너희 하나님 여호와께서 애굽에서 너희를 위하여 너희의 목전에서 행하신 일이라","reference":"신명기 4:35","category":"$undefined"},{"id":"5041","book":"신명기","book_name":"신명기","chapter":4,"verse":36,"text":"이것을 네게 나타내심은 여호와는 하나님이시요 그 외에는 다른 신이 없음을 네게 알게 하려 하심이니라","reference":"신명기 4:36","category":"$undefined"},{"id":"5042","book":"신명기","book_name":"신명기","chapter":4,"verse":37,"text":"여호와께서 너를 교훈하시려고 하늘에서부터 그 음성을 너로 듣게 하시며 땅에서는 그 큰 불을 네게 보이시고 너로 불가운데서 나오는 그 말씀을 듣게 하셨느니라","reference":"신명기 4:37","category":"$undefined"},{"id":"5043","book":"신명기","book_name":"신명기","chapter":4,"verse":38,"text":"여호와께서 네 열조를 사랑 하신고로 그 후손 너를 택하시고 큰 권능으로 친히 인도하여 애굽에서 나오게 하시며","reference":"신명기 4:38","category":"$undefined"},{"id":"5044","book":"신명기","book_name":"신명기","chapter":4,"verse":39,"text":"너보다 강대한 열국을 네 앞에서 쫓아내고 너를 그들의 땅으로 인도하여 들여서 그것을 네게 기업으로 주려 하심이 오늘과 같으니라","reference":"신명기 4:39","category":"$undefined"},{"id":"5045","book":"신명기","book_name":"신명기","chapter":4,"verse":40,"text":"그런즉 너는 오늘날 상천 하지에 오직 여호와는 하나님이시요 ! 다른 신이 없는 줄을 알아 명심하고","reference":"신명기 4:40","category":"$undefined"},{"id":"5046","book":"신명기","book_name":"신명기","chapter":4,"verse":41,"text":"오늘 내가 네게 명하는 여호와의 규례와 명령을 지키라 ! 너와 네 후손이 복을 받아 네 하나님 여호와께서 네게 주시는 땅에서 한 없이 오래 살리라","reference":"신명기 4:41","category":"$undefined"},{"id":"5047","book":"신명기","book_name":"신명기","chapter":4,"verse":42,"text":"때에 모세가 요단 이편 해 돋는 편에서 세 성읍을 구별하였으니","reference":"신명기 4:42","category":"$undefined"},{"id":"5048","book":"신명기","book_name":"신명기","chapter":4,"verse":43,"text":"이는 과거에 원혐이 없이 부지중에 오살한 자로 그곳으로 도피케 하기 위함이며 그 한 성읍으로 도피한 자로 그 생명을 보존케 하기 위함이라","reference":"신명기 4:43","category":"$undefined"},{"id":"5049","book":"신명기","book_name":"신명기","chapter":4,"verse":44,"text":"하나는 광야 평원에 있는 베셀이라 르우벤 지파를 위한 것이요 하나는 길르앗 라못이라 갓 지파를 위한 것이요 하나는 바산 골란이라 므낫세 지파를 위한 것이었더라","reference":"신명기 4:44","category":"$undefined"},{"id":"5050","book":"신명기","book_name":"신명기","chapter":4,"verse":45,"text":"모세가 이스라엘 자손에게 선포한 율법이 이러하니라","reference":"신명기 4:45","category":"$undefined"},{"id":"5051","book":"신명기","book_name":"신명기","chapter":4,"verse":46,"text":"이스라엘 자손이 애굽에서 나온 후에 증거하신 것과 규례와 법도를 모세가 선포하였으니","reference":"신명기 4:46","category":"$undefined"},{"id":"5052","book":"신명기","book_name":"신명기","chapter":4,"verse":47,"text":"요단 동편 벳브올 맞은편 골짜기에서라 이 땅은 헤스본에 거하는 아모리 족속의 왕 시혼에게 속하였더니 모세와 이스라엘 자손이 애굽에서 나온 후에 그를 쳐서 멸하고","reference":"신명기 4:47","category":"$undefined"},{"id":"5053","book":"신명기","book_name":"신명기","chapter":4,"verse":48,"text":"그 땅을 기업으로 얻었고 또 바산 왕 옥의 땅을 얻었으니 그 두 사람은 아모리 족속의 왕으로서 요단 이편 해 돋는 편에 거하였었으며","reference":"신명기 4:48","category":"$undefined"},{"id":"5054","book":"신명기","book_name":"신명기","chapter":4,"verse":49,"text":"그 얻은 땅은 아르논 골짜기 가의 아로엘에서부터 시온산 곧 헤르몬산까지요 [ (Deuteronomy 4:50) 요단 이편 곧 그 동편 온 아라바니 비스가 산록 아래 아라바의 바다까지니라 ]","reference":"신명기 4:49","category":"$undefined"}],"bookSlug":"deuteronomy"}]
