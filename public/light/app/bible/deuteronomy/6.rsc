2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":6,"verses":[{"id":"5088","book":"신명기","book_name":"신명기","chapter":6,"verse":1,"text":"이는 곧 너희 하나님 여호와께서 너희에게 가르치라 명하신 바 명령과 규례와 법도라 너희가 건너가서 얻을 땅에서 행할 것이니","reference":"신명기 6:1","category":"$undefined"},{"id":"5089","book":"신명기","book_name":"신명기","chapter":6,"verse":2,"text":"곧 너와 네 아들과 네 손자로 평생에 네 하나님 여호와를 경외하며 내가 너희에게 명한 그 모든 규례와 명령을 지키게 하기 위한 것이며 또 네 날을 장구케 하기 위한 것이라","reference":"신명기 6:2","category":"$undefined"},{"id":"5090","book":"신명기","book_name":"신명기","chapter":6,"verse":3,"text":"이스라엘아 듣고 삼가 그것을 행하라 ! 그리하면 네가 복을 얻고 네 열조의 하나님 여호와께서 네게 허락하심 같이 젖과 꿀이 흐르는 땅에서 너의 수효가 심히 번성하리라","reference":"신명기 6:3","category":"$undefined"},{"id":"5091","book":"신명기","book_name":"신명기","chapter":6,"verse":4,"text":"이스라엘아 들으라 ! 우리 하나님 여호와는 오직 하나인 여호와시니","reference":"신명기 6:4","category":"$undefined"},{"id":"5092","book":"신명기","book_name":"신명기","chapter":6,"verse":5,"text":"너는 마음을 다하고, 성품을 다하고, 힘을 다하여 네 하나님 여호와를 사랑하라 !","reference":"신명기 6:5","category":"$undefined"},{"id":"5093","book":"신명기","book_name":"신명기","chapter":6,"verse":6,"text":"오늘날 내가 네게 명하는 이 말씀을 너는 마음에 새기고","reference":"신명기 6:6","category":"$undefined"},{"id":"5094","book":"신명기","book_name":"신명기","chapter":6,"verse":7,"text":"네 자녀에게 부지런히 가르치며 집에 앉았을 때에든지, 길에 행할때에든지, 누웠을 때에든지, 일어날 때에든지, 이 말씀을 강론할 것이며","reference":"신명기 6:7","category":"$undefined"},{"id":"5095","book":"신명기","book_name":"신명기","chapter":6,"verse":8,"text":"너는 또 그것을 네 손목에 매어 기호를 삼으며 네 미간에 붙여 표를 삼고","reference":"신명기 6:8","category":"$undefined"},{"id":"5096","book":"신명기","book_name":"신명기","chapter":6,"verse":9,"text":"또 네 집 문설주와 바깥 문에 기록할지니라","reference":"신명기 6:9","category":"$undefined"},{"id":"5097","book":"신명기","book_name":"신명기","chapter":6,"verse":10,"text":"네 하나님 여호와께서 네 열조 아브라함과 이삭과 야곱을 향하여 네게 주리라 맹세하신 땅으로 너로 들어가게 하시고 네가 건축하지 아니한 크고 아름다운 성읍을 얻게 하시며","reference":"신명기 6:10","category":"$undefined"},{"id":"5098","book":"신명기","book_name":"신명기","chapter":6,"verse":11,"text":"네가 채우지 아니한 아름다운 물건이 가득한 집을 얻게 하시며 네가 파지 아니한 우물을 얻게 하시며 네가 심지 아니한 포도원과 감람 나무를 얻게 하사 너로 배불리 먹게 하실 때에","reference":"신명기 6:11","category":"$undefined"},{"id":"5099","book":"신명기","book_name":"신명기","chapter":6,"verse":12,"text":"너는 조심하여 너를 애굽 땅 종 되었던 집에서 인도하여 내신 여호와를 잊지 말고","reference":"신명기 6:12","category":"$undefined"},{"id":"5100","book":"신명기","book_name":"신명기","chapter":6,"verse":13,"text":"네 하나님 여호와를 경외하며 섬기며 그 이름으로 맹세할 것이니라","reference":"신명기 6:13","category":"$undefined"},{"id":"5101","book":"신명기","book_name":"신명기","chapter":6,"verse":14,"text":"너희는 다른 신들 곧 네 사면에 있는 백성의 신들을 좇지 말라","reference":"신명기 6:14","category":"$undefined"},{"id":"5102","book":"신명기","book_name":"신명기","chapter":6,"verse":15,"text":"너희 중에 계신 너희 하나님 여호와는 질투하시는 하나님이신즉 너희 하나님 여호와께서 네게 진노하사 너를 지면에서 멸절시키실까 두려워하노라","reference":"신명기 6:15","category":"$undefined"},{"id":"5103","book":"신명기","book_name":"신명기","chapter":6,"verse":16,"text":"너희가 맛사에서 시험한 것 같이 너희의 하나님 여호와를 시험하지 말고","reference":"신명기 6:16","category":"$undefined"},{"id":"5104","book":"신명기","book_name":"신명기","chapter":6,"verse":17,"text":"너희의 하나님 여호와께서 너희에게 명하신 명령과 증거하신 것과 규례를 삼가 지키며","reference":"신명기 6:17","category":"$undefined"},{"id":"5105","book":"신명기","book_name":"신명기","chapter":6,"verse":18,"text":"여호와의 보시기에 정직하고 선량한 일을 행하라 그리하면 네가 복을 얻고 여호와께서 네 열조에게 맹세하사 네 대적을 몰수히 네 앞에서 쫓아내리라 하신 아름다운 땅을 들어가서 얻으리니 여호와의 말씀과 같으리라","reference":"신명기 6:18","category":"$undefined"},{"id":"5106","book":"신명기","book_name":"신명기","chapter":6,"verse":19,"text":"(18절과 같음)","reference":"신명기 6:19","category":"$undefined"},{"id":"5107","book":"신명기","book_name":"신명기","chapter":6,"verse":20,"text":"후일에 네 아들이 네게 묻기를 우리 하나님 여호와의 명하신 증거와 말씀과 규례와 법도가 무슨 뜻이뇨 ? 하거든","reference":"신명기 6:20","category":"$undefined"},{"id":"5108","book":"신명기","book_name":"신명기","chapter":6,"verse":21,"text":"너는 네 아들에게 이르기를 우리가 옛적에 애굽에서 바로의 종이 되었더니 여호와께서 권능의 손으로 우리를 애굽에서 인도하여 내셨나니","reference":"신명기 6:21","category":"$undefined"},{"id":"5109","book":"신명기","book_name":"신명기","chapter":6,"verse":22,"text":"곧 여호와께서 우리의 목전에서 크고 두려운 이적과 기사를 애굽과 바로와 그 온 집에 베푸시고","reference":"신명기 6:22","category":"$undefined"},{"id":"5110","book":"신명기","book_name":"신명기","chapter":6,"verse":23,"text":"우리 열조에게 맹세하신 땅으로 우리에게 주어 들어가게 하시려고 우리를 거기서 인도하여 내시고","reference":"신명기 6:23","category":"$undefined"},{"id":"5111","book":"신명기","book_name":"신명기","chapter":6,"verse":24,"text":"여호와께서 우리에게 이 모든 규례를 지키라 명하셨으니 이는 우리로 우리 하나님 여호와를 경외하여 항상 복을 누리게 하기 위하심이며 또 여호와께서 우리로 오늘날과 같이 생활하게 하려 하심이라","reference":"신명기 6:24","category":"$undefined"},{"id":"5112","book":"신명기","book_name":"신명기","chapter":6,"verse":25,"text":"우리가 그 명하신대로 이 모든 명령을 우리 하나님 여호와 앞에서 삼가 지키면 그것이 곧 우리의 의로움이니라 ! 할지니라","reference":"신명기 6:25","category":"$undefined"}],"bookSlug":"deuteronomy"}]
