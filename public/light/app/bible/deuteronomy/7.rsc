2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":7,"verses":[{"id":"5113","book":"신명기","book_name":"신명기","chapter":7,"verse":1,"text":"네 하나님 여호와께서 너를 인도하사 네가 가서 얻을 땅으로 들이시고 네 앞에서 여러 민족 헷 족속과, 기르가스 족속과, 아모리 족속과, 가나안 족속과, 브리스 족속과, 히위 족속과, 여부스 족속 곧 너보다 많고 힘이 있는 일곱 족속을 쫓아내실 때에","reference":"신명기 7:1","category":"$undefined"},{"id":"5114","book":"신명기","book_name":"신명기","chapter":7,"verse":2,"text":"네 하나님 여호와께서 그들을 네게 붙여 너로 치게 하시리니 그 때에 너는 그들을 진멸할 것이라 그들과 무슨 언약도 말것이요 그들을 불쌍히 여기지도 말 것이며","reference":"신명기 7:2","category":"$undefined"},{"id":"5115","book":"신명기","book_name":"신명기","chapter":7,"verse":3,"text":"또 그들과 혼인하지 말지니 네 딸을 그 아들에게 주지 말 것이요 그 딸로 네 며느리를 삼지 말 것은","reference":"신명기 7:3","category":"$undefined"},{"id":"5116","book":"신명기","book_name":"신명기","chapter":7,"verse":4,"text":"그가 네 아들을 유혹하여 그로 여호와를 떠나고 다른 신들을 섬기게 하므로 여호와께서 너희에게 진노하사 갑자기 너희를 멸하실 것임이니라","reference":"신명기 7:4","category":"$undefined"},{"id":"5117","book":"신명기","book_name":"신명기","chapter":7,"verse":5,"text":"오직 너희가 그들에게 행할 것은 이러하니 그들의 단을 헐며 주상을 깨뜨리며 아세라 목상을 찍으며 조각한 우상들을 불사를 것이니라","reference":"신명기 7:5","category":"$undefined"},{"id":"5118","book":"신명기","book_name":"신명기","chapter":7,"verse":6,"text":"너는 여호와 네 하나님의 성민이라 네 하나님 여호와께서 지상 만민 중에서 너를 자기 기업의 백성으로 택하셨나니","reference":"신명기 7:6","category":"$undefined"},{"id":"5119","book":"신명기","book_name":"신명기","chapter":7,"verse":7,"text":"여호와께서 너희를 기뻐하시고 너희를 택하심은 너희가 다른 민족보다 수효가 많은 연고가 아니라 너희는 모든 민족 중에 가장 적으니라","reference":"신명기 7:7","category":"$undefined"},{"id":"5120","book":"신명기","book_name":"신명기","chapter":7,"verse":8,"text":"여호와께서 다만 너희를 사랑하심을 인하여 또는 너희 열조에게 하신 맹세를 지키려 하심을 인하여 자기의 권능의 손으로 너희를 인도하여 내시되 너희를 그 종 되었던 집에서 애굽 왕 바로의 손에서 속량하셨나니","reference":"신명기 7:8","category":"$undefined"},{"id":"5121","book":"신명기","book_name":"신명기","chapter":7,"verse":9,"text":"그런즉 너는 알라 ! 오직 네 하나님 여호와는 하나님이시요 신실하신 하나님이시라 그를 사랑하고 그 계명을 지키는 자에게는 천대까지 그 언약을 이행하시며 인애를 베푸시되","reference":"신명기 7:9","category":"$undefined"},{"id":"5122","book":"신명기","book_name":"신명기","chapter":7,"verse":10,"text":"그를 미워하는 자에게는 당장에 보응하여 멸하시나니 여호와는 자기를 미워하는 자에게 지체하지 아니하시고 당장에 그에게 보응하시느니라","reference":"신명기 7:10","category":"$undefined"},{"id":"5123","book":"신명기","book_name":"신명기","chapter":7,"verse":11,"text":"그런즉 너는 오늘날 내가 네게 명하는 명령과 규례와 법도를 지켜 행할지니라 !","reference":"신명기 7:11","category":"$undefined"},{"id":"5124","book":"신명기","book_name":"신명기","chapter":7,"verse":12,"text":"너희가 이 모든 법도를 듣고 지켜 행하면 네 하나님 여호와께서 네 열조에게 맹세하신 언약을 지켜 네게 인애를 베푸실 것이라","reference":"신명기 7:12","category":"$undefined"},{"id":"5125","book":"신명기","book_name":"신명기","chapter":7,"verse":13,"text":"곧 너를 사랑하시고 복을 주사 너로 번성케 하시되 네게 주리라고 네 열조에게 맹세하신 땅에서 네 소생에게 은혜를 베푸시며 네 토지 소산과 곡식과 포도주와 기름을 풍성케 하시고 네 소와 양을 번식케 하시리니","reference":"신명기 7:13","category":"$undefined"},{"id":"5126","book":"신명기","book_name":"신명기","chapter":7,"verse":14,"text":"네가 복을 받음이 만민보다 우승하여 너희 중의 남녀와 너희 짐승의 암수에 생육하지 못함이 없을 것이며","reference":"신명기 7:14","category":"$undefined"},{"id":"5127","book":"신명기","book_name":"신명기","chapter":7,"verse":15,"text":"여호와께서 또 모든 질병을 네게서 멀리하사 너희가 아는 바 그 애굽의 악질이 네게 임하지 않게 하시고 너를 미워하는 모든 자에게 임하게 하실 것이라","reference":"신명기 7:15","category":"$undefined"},{"id":"5128","book":"신명기","book_name":"신명기","chapter":7,"verse":16,"text":"네 하나님 여호와께서 네게 붙이신 모든 민족을 네 눈이 긍휼히 보지 말고 진멸하고 그 신을 섬기지 말라 그것이 네게 올무가 되리라","reference":"신명기 7:16","category":"$undefined"},{"id":"5129","book":"신명기","book_name":"신명기","chapter":7,"verse":17,"text":"네가 혹시 심중에 이르기를 이 민족들이 나보다 많으니 내가 어찌 그를 쫓아 낼 수 있으리요 하리라마는","reference":"신명기 7:17","category":"$undefined"},{"id":"5130","book":"신명기","book_name":"신명기","chapter":7,"verse":18,"text":"그들을 두려워 말고 네 하나님 여호와께서 바로와 온 애굽에 행하신 것을 잘 기억하되","reference":"신명기 7:18","category":"$undefined"},{"id":"5131","book":"신명기","book_name":"신명기","chapter":7,"verse":19,"text":"네 하나님 여호와께서 너를 인도하여 내실 때에 네가 목도한 큰 시험과 이적과 기사와 강한 손과 편 팔을 기억하라 ! 그와 같이 네 하나님 여호와께서 네가 두려워하는 모든 민족에게 행하실 것이요","reference":"신명기 7:19","category":"$undefined"},{"id":"5132","book":"신명기","book_name":"신명기","chapter":7,"verse":20,"text":"네 하나님 여호와께서 또 왕벌을 그들 중에 보내어 그들의 남은 자와 너를 피하여 숨은 자를 멸하시리니","reference":"신명기 7:20","category":"$undefined"},{"id":"5133","book":"신명기","book_name":"신명기","chapter":7,"verse":21,"text":"너는 그들을 두려워 말라 ! 너희 하나님 여호와 곧 크고 두려운 하나님이 너희 중에 계심이니라","reference":"신명기 7:21","category":"$undefined"},{"id":"5134","book":"신명기","book_name":"신명기","chapter":7,"verse":22,"text":"네 하나님 여호와께서 이 민족들을 네 앞에서 점점 쫓아내시리니 너는 그들을 급히 멸하지 말라 두렵건대 들짐승이 번성하여 너를 해할까 하노라","reference":"신명기 7:22","category":"$undefined"},{"id":"5135","book":"신명기","book_name":"신명기","chapter":7,"verse":23,"text":"네 하나님 여호와께서 그들을 네게 붙이시고 그들을 크게 요란케하여 필경은 진멸하시고","reference":"신명기 7:23","category":"$undefined"},{"id":"5136","book":"신명기","book_name":"신명기","chapter":7,"verse":24,"text":"너는 그들의 조각한 신상들을 불사르고 그것에 입힌 은이나 금을 탐내지 말며 취하지 말라 두렵건대 네가 그것으로 인하여 올무에 들까 하노니 이는 네 하나님 여호와의 가증히 여기시는 것임이니라","reference":"신명기 7:24","category":"$undefined"},{"id":"5137","book":"신명기","book_name":"신명기","chapter":7,"verse":25,"text":"그들의 왕들을 네 손에 붙이시리니 너는 그 이름을 천하에서 제하여 버리라 너를 당할 자가 없이 네가 필경은 그들을 진멸하리라","reference":"신명기 7:25","category":"$undefined"},{"id":"5138","book":"신명기","book_name":"신명기","chapter":7,"verse":26,"text":"너는 그들의 조각한 신상들을 불사르고 그것에 입힌 은이나 금을 탐내지 말며 취하지 말라 두렵건대 네가 그것으로 인하여 올무에 들까 하노니 이는 네 하나님 여호와의 가증히 여기시는 것임이니라 [ (Deuteronomy 7:27) 그들의 왕들을 네 손에 붙이시리니 너는 그 이름을 천하에서 제하여 버리라 너를 당할 자가 없이 네가 필경은 그들을 진멸하리라 ] [ (Deuteronomy 7:28) 너는 가증한 것을 네 집에 들이지 말라 너도 그와 같이 진멸당할 것이 될까 하노라 너는 그것을 극히 꺼리며 심히 미워하라 ! 그것은 진멸당할 것임이니라 ]","reference":"신명기 7:26","category":"$undefined"}],"bookSlug":"deuteronomy"}]
