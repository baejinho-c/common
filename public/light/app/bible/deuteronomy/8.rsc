2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":8,"verses":[{"id":"5139","book":"신명기","book_name":"신명기","chapter":8,"verse":1,"text":"내가 오늘날 명하는 모든 명령을 너희는 지켜 행하라 ! 그리하면 너희가 살고 번성하고 여호와께서 너희의 열조에게 맹세하신 땅에 들어가서 그것을 얻으리라","reference":"신명기 8:1","category":"$undefined"},{"id":"5140","book":"신명기","book_name":"신명기","chapter":8,"verse":2,"text":"네 하나님 여호와께서 이 사십년 동안에 너로 광야의 길을 걷게 하신 것을 기억하라 ! 이는 너를 낮추시며 너를 시험하사 네 마음이 어떠한지 그 명령을 지키는지 아니 지키는지 알려 하심이라","reference":"신명기 8:2","category":"$undefined"},{"id":"5141","book":"신명기","book_name":"신명기","chapter":8,"verse":3,"text":"너를 낮추시며 너로 주리게 하시며 또 너도 알지 못하며 네 열조도 알지 못하던 만나를 네게 먹이신 것은 사람이 떡으로만 사는 것이 아니요 여호와의 입에서 나오는 모든 말씀으로 사는 줄을 너로 알게 하려 하심이니라","reference":"신명기 8:3","category":"$undefined"},{"id":"5142","book":"신명기","book_name":"신명기","chapter":8,"verse":4,"text":"이 사십년 동안에 네 의복이 해어지지 아니하였고 네 발이 부릍지 아니하였느니라","reference":"신명기 8:4","category":"$undefined"},{"id":"5143","book":"신명기","book_name":"신명기","chapter":8,"verse":5,"text":"너는 사람이 그 아들을 징계함 같이 네 하나님 여호와께서 너를 징계하시는 줄 마음에 생각하고","reference":"신명기 8:5","category":"$undefined"},{"id":"5144","book":"신명기","book_name":"신명기","chapter":8,"verse":6,"text":"네 하나님 여호와의 명령을 지켜 그 도를 행하며 그를 경외할지니라 !","reference":"신명기 8:6","category":"$undefined"},{"id":"5145","book":"신명기","book_name":"신명기","chapter":8,"verse":7,"text":"네 하나님 여호와께서 너를 아름다운 땅에 이르게 하시나니 그곳은 골짜기에든지 산지에든지 시내와 분천과 샘이 흐르고","reference":"신명기 8:7","category":"$undefined"},{"id":"5146","book":"신명기","book_name":"신명기","chapter":8,"verse":8,"text":"밀과, 보리의 소산지요, 포도와, 무화과와, 석류와, 감람들의 나무와, 꿀의 소산지라","reference":"신명기 8:8","category":"$undefined"},{"id":"5147","book":"신명기","book_name":"신명기","chapter":8,"verse":9,"text":"너의 먹는 식물의 결핍함이 없고 네게 아무 부족함이 없는 땅이며 그 땅의 돌은 철이요 산에서는 동을 캘 것이라","reference":"신명기 8:9","category":"$undefined"},{"id":"5148","book":"신명기","book_name":"신명기","chapter":8,"verse":10,"text":"네가 먹어서 배불리고 네 하나님 여호와께서 옥토로 네게 주셨음을 인하여 그를 찬송하리라","reference":"신명기 8:10","category":"$undefined"},{"id":"5149","book":"신명기","book_name":"신명기","chapter":8,"verse":11,"text":"내가 오늘날 네게 명하는 여호와의 명령과 법도와 규례를 지키지 아니하고 네 하나님 여호와를 잊어버리게 되지 않도록 삼갈지어다 !","reference":"신명기 8:11","category":"$undefined"},{"id":"5150","book":"신명기","book_name":"신명기","chapter":8,"verse":12,"text":"네가 먹어서 배불리고 아름다운 집을 짓고 거하게 되며","reference":"신명기 8:12","category":"$undefined"},{"id":"5151","book":"신명기","book_name":"신명기","chapter":8,"verse":13,"text":"또 네 우양이 번성하며 네 은,금이 증식되며 네 소유가 다 풍부하게 될 때에","reference":"신명기 8:13","category":"$undefined"},{"id":"5152","book":"신명기","book_name":"신명기","chapter":8,"verse":14,"text":"두렵건대 네 마음이 교만하여 네 하나님 여호와를 잊어버릴까 하노라 여호와는 너를 애굽 땅 종 되었던 집에서 이끌어 내시고","reference":"신명기 8:14","category":"$undefined"},{"id":"5153","book":"신명기","book_name":"신명기","chapter":8,"verse":15,"text":"너를 인도하여 그 광대하고 위험한 광야 곧 불뱀과 전갈이 있고 물이 없는 간조한 땅을 지나게 하셨으며 또 너를 위하여 물을 굳은 반석에서 내셨으며","reference":"신명기 8:15","category":"$undefined"},{"id":"5154","book":"신명기","book_name":"신명기","chapter":8,"verse":16,"text":"네 열조도 알지 못하던 만나를 광야에서 네게 먹이셨나니 이는 다 너를 낮추시며 너를 시험하사 마침내 네게 복을 주려 하심이었느니라","reference":"신명기 8:16","category":"$undefined"},{"id":"5155","book":"신명기","book_name":"신명기","chapter":8,"verse":17,"text":"또 두렵건대 네가 마음에 이르기를 내 능과 내 손의 힘으로 내가 이 재물을 얻었다 할까 하노라","reference":"신명기 8:17","category":"$undefined"},{"id":"5156","book":"신명기","book_name":"신명기","chapter":8,"verse":18,"text":"네 하나님 여호와를 기억하라 ! 그가 네게 재물 얻을 능을 주셨음이라 이같이 하심은 네 열조에게 맹세하신 언약을 오늘과 같이 이루려 하심이니라","reference":"신명기 8:18","category":"$undefined"},{"id":"5157","book":"신명기","book_name":"신명기","chapter":8,"verse":19,"text":"네가 만일 네 하나님 여호와를 잊어버리고 다른 신들을 좇아 그들을 섬기며 그들에게 절하면 내가 너희에게 증거하노니 너희가 정녕히 멸망할 것이라","reference":"신명기 8:19","category":"$undefined"},{"id":"5158","book":"신명기","book_name":"신명기","chapter":8,"verse":20,"text":"여호와께서 너희의 앞에서 멸망시키신 민족들 같이 너희도 멸망하리니 이는 너희가 너희 하나님 여호와의 소리를 청종치 아니함이니라","reference":"신명기 8:20","category":"$undefined"}],"bookSlug":"deuteronomy"}]
