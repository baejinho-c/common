11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"deuteronomy","name":"신명기","chapters":34,"testament":"old"},"chapter":9,"verses":[{"id":"5159","book":"신명기","book_name":"신명기","chapter":9,"verse":1,"text":"이스라엘아 들으라 ! 네가 오늘 요단을 건너 너보다 강대한 나라들로 들어가서 그것을 얻으리니 그 성읍들은 크고 성벽은 하늘에 닿았으며","reference":"신명기 9:1","category":"$undefined"},{"id":"5160","book":"신명기","book_name":"신명기","chapter":9,"verse":2,"text":"그 백성은 네가 아는 바 장대한 아낙 자손이라 그에게 대한 말을 네가 들었나니 이르기를 누가 아낙 자손을 능히 당하리요 하거니와","reference":"신명기 9:2","category":"$undefined"},{"id":"5161","book":"신명기","book_name":"신명기","chapter":9,"verse":3,"text":"오늘날 너는 알라 ! 네 하나님 여호와께서 맹렬한 불과 같이 네 앞에 나아가신즉 여호와께서 그들을 파하사 네 앞에 엎드러지게 하시리니 여호와께서 네게 말씀하신 것 같이 너는 그들을 쫓아내며 속히 그들을 멸할 것이라","reference":"신명기 9:3","category":"$undefined"},{"id":"5162","book":"신명기","book_name":"신명기","chapter":9,"verse":4,"text":"네 하나님 여호와께서 그들을 네 앞에서 쫓아내신 후에 네가 심중에 이르기를 나의 의로움을 인하여 여호와께서 나를 이 땅으로 인도하여 들여서 그것을 얻게 하셨다 하지 말라 실상은 이 민족들이 악함을 인하여 여호와께서 그들을 네 앞에서 쫓아내심이니라","reference":"신명기 9:4","category":"$undefined"},{"id":"5163","book":"신명기","book_name":"신명기","chapter":9,"verse":5,"text":"네가 가서 그 땅을 얻음은 너의 의로움을 인함도 아니며 네 마음이 정직함을 인함도 아니요 이 민족들의 악함을 인하여 네 하나님 여호와께서 그들을 네 앞에서 쫓아내심이라 여호와께서 이같이 하심은 네 열조 아브라함과 이삭과 야곱에게 하신 맹세를 이루려 하심이니라","reference":"신명기 9:5","category":"$undefined"},{"id":"5164","book":"신명기","book_name":"신명기","chapter":9,"verse":6,"text":"그러므로 네가 알 것은 네 하나님 여호와께서 네게 이 아름다운 땅을 기업으로 주신 것이 네 의로움을 인함이 아니니라 너는 목이 곧은 백성이니라","reference":"신명기 9:6","category":"$undefined"},{"id":"5165","book":"신명기","book_name":"신명기","chapter":9,"verse":7,"text":"너는 광야에서 네 하나님 여호와를 격노케 하던 일을 잊지 말고 기억하라 네가 애굽 땅에서 나오던 날부터 이곳에 이르기까지 늘 여호와를 거역하였으되","reference":"신명기 9:7","category":"$undefined"},{"id":"5166","book":"신명기","book_name":"신명기","chapter":9,"verse":8,"text":"호렙산에서 너희가 여호와를 격노케 하였으므로 여호와께서 진노하사 너희를 멸하려 하셨느니라","reference":"신명기 9:8","category":"$undefined"},{"id":"5167","book":"신명기","book_name":"신명기","chapter":9,"verse":9,"text":"그 때에 내가 돌판들 곧 여호와께서 너희와 세우신 언약의 돌판들을 받으려고 산에 올라가서 사십 주야를 산에 거하며 떡도 먹지 아니하고 물도 마시지 아니하였더니","reference":"신명기 9:9","category":"$undefined"},{"id":"5168","book":"신명기","book_name":"신명기","chapter":9,"verse":10,"text":"여호와께서 두 돌판을 네게 주셨나니 그 판의 글은 하나님이 친수로 기록하신 것이요 너희 총회 날에 여호와께서 산상 불 가운데서 너희에게 이르신 모든 말씀이니라","reference":"신명기 9:10","category":"$undefined"},{"id":"5169","book":"신명기","book_name":"신명기","chapter":9,"verse":11,"text":"사십 주야가 지난 후에 여호와께서 내게 돌판 곧 언약의 두 돌판을 주시고","reference":"신명기 9:11","category":"$undefined"},{"id":"5170","book":"신명기","book_name":"신명기","chapter":9,"verse":12,"text":"내게 이르시되 일어나 여기서 속히 내려가라 네가 애굽에서 인도하여 낸 내 백성이 스스로 부패하여 내가 그들에게 명한 도를 속히 떠나 자기를 위하여 우상을 부어 만들었느니라","reference":"신명기 9:12","category":"$undefined"},{"id":"5171","book":"신명기","book_name":"신명기","chapter":9,"verse":13,"text":"여호와께서 또 내게 일러 가라사대 내가 이 백성을 보았노라 보라 ! 이는 목이 곧은 백성이니라","reference":"신명기 9:13","category":"$undefined"},{"id":"5172","book":"신명기","book_name":"신명기","chapter":9,"verse":14,"text":"나를 막지 말라 내가 그들을 멸하여 그 이름을 천하에서 도말하고 너로 그들보다 강대한 나라가 되게 하리라 하시기로","reference":"신명기 9:14","category":"$undefined"},{"id":"5173","book":"신명기","book_name":"신명기","chapter":9,"verse":15,"text":"내가 돌이켜 산에서 내려 오는데 산에는 불이 붙었고 언약의 두 돌판은 내 손에 있었느니라","reference":"신명기 9:15","category":"$undefined"},{"id":"5174","book":"신명기","book_name":"신명기","chapter":9,"verse":16,"text":"내가 본즉 너희가 너희 하나님 여호와께 범죄하여 자기를 위하여 송아지를 부어 만들어서 급속히 여호와의 명하신 도를 떠났기로","reference":"신명기 9:16","category":"$undefined"},{"id":"5175","book":"신명기","book_name":"신명기","chapter":9,"verse":17,"text":"내가 그 두 돌판을 내 두 손에서 들어 던져 너희의 목전에서 깨뜨렸었노라","reference":"신명기 9:17","category":"$undefined"},{"id":"5176","book":"신명기","book_name":"신명기","chapter":9,"verse":18,"text":"그리고 내가 전과 같이 사십 주야를 여호와 앞에 엎드려서 떡도 먹지 아니하고 물도 마시지 아니하였으니 이는 너희가 여호와의 목전에 악을 행하여 그를 격노케 하여 크게 죄를 얻었음이라","reference":"신명기 9:18","category":"$undefined"},{"id":"5177","book":"신명기","book_name":"신명기","chapter":9,"verse":19,"text":"여호와께서 심히 분노하사 너희를 멸하려 하셨으므로 내가 두려워 하였었노라 그러나 여호와께서 그 때에도 내 말을 들으셨고","reference":"신명기 9:19","category":"$undefined"},{"id":"5178","book":"신명기","book_name":"신명기","chapter":9,"verse":20,"text":"여호와께서 또 아론에게 진노하사 그를 멸하려 하셨으므로 내가 그 때에도 아론을 위하여 기도하고","reference":"신명기 9:20","category":"$undefined"},{"id":"5179","book":"신명기","book_name":"신명기","chapter":9,"verse":21,"text":"너희의 죄 곧 너희의 만든 송아지를 취하여 불살라 찧고 티끌같이 가늘게 갈아 그 가루를 산에서 흘러 내리는 시내에 뿌렸었느니라","reference":"신명기 9:21","category":"$undefined"},{"id":"5180","book":"신명기","book_name":"신명기","chapter":9,"verse":22,"text":"너희가 다베라와, 맛사와, 기브롯 핫다아와에서도 여호와를 격노케 하였느니라","reference":"신명기 9:22","category":"$undefined"},{"id":"5181","book":"신명기","book_name":"신명기","chapter":9,"verse":23,"text":"여호와께서 너희를 가데스 바네아에서 떠나게 하실 때에 이르시기를 너희는 올라가서 내가 너희에게 준 땅을 얻으라 하시되 너희가 너희 하나님 여호와의 명령을 거역하여 믿지 아니하고 그 말씀을 듣지 아니하였나니","reference":"신명기 9:23","category":"$undefined"},{"id":"5182","book":"신명기","book_name":"신명기","chapter":9,"verse":24,"text":"내가 너희를 알던 날부터 옴으로 너희가 항상 여호와를 거역하였느니라","reference":"신명기 9:24","category":"$undefined"},{"id":"5183","book":"신명기","book_name":"신명기","chapter":9,"verse":25,"text":"그 때에 여호와께서 너희를 멸하겠다 하셨으므로 내가 여전히 사십 주야를 여호와 앞에 엎드리고","reference":"신명기 9:25","category":"$undefined"},{"id":"5184","book":"신명기","book_name":"신명기","chapter":9,"verse":26,"text":"여호와께 간구하여 가로되 `주 여호와여 ! 주께서 큰 위엄으로 속하시고 강한 손으로 애굽에서 인도하여 내신 주의 백성 곧 주의 기업을 멸하지 마옵소서","reference":"신명기 9:26","category":"$undefined"},{"id":"5185","book":"신명기","book_name":"신명기","chapter":9,"verse":27,"text":"주의 종 아브라함과 이삭과 야곱을 생각하사 이 백성의 강퍅과 악과 죄를 보지 마옵소서","reference":"신명기 9:27","category":"$undefined"},{"id":"5186","book":"신명기","book_name":"신명기","chapter":9,"verse":28,"text":"주께서 우리를 인도하여 내신 그 땅 백성이 말하기를 여호와께서 그들에게 허락하신 땅으로 그들을 인도하여 들일 능력도 없고 그들을 미워도 하사 광야에서 죽이려고 인도하여 내셨다 할까 두려워하나이다","reference":"신명기 9:28","category":"$undefined"},{"id":"5187","book":"신명기","book_name":"신명기","chapter":9,"verse":29,"text":"그들은 주의 큰 능력과 펴신 팔로 인도하여 내신 주의 백성 곧 주의 기업이로소이다' 하였었노라","reference":"신명기 9:29","category":"$undefined"}],"bookSlug":"deuteronomy"}]
