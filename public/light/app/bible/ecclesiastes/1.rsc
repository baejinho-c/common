2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":1,"verses":[{"id":"17317","book":"전도서","book_name":"전도서","chapter":1,"verse":1,"text":"다윗의 아들 예루살렘 왕 전도자의 말씀이라","reference":"전도서 1:1","category":"$undefined"},{"id":"17318","book":"전도서","book_name":"전도서","chapter":1,"verse":2,"text":"전도자가 가로되 헛되고 헛되며 헛되고 헛되니 모든 것이 헛되도다","reference":"전도서 1:2","category":"$undefined"},{"id":"17319","book":"전도서","book_name":"전도서","chapter":1,"verse":3,"text":"사람이 해 아래서 수고하는 모든 수고가 자기에게 무엇이 유익한고","reference":"전도서 1:3","category":"$undefined"},{"id":"17320","book":"전도서","book_name":"전도서","chapter":1,"verse":4,"text":"한 세대는 가고 한 세대는 오되 땅은 영원히 있도다","reference":"전도서 1:4","category":"$undefined"},{"id":"17321","book":"전도서","book_name":"전도서","chapter":1,"verse":5,"text":"해는 떴다가 지며 그 떴던 곳으로 빨리 돌아가고","reference":"전도서 1:5","category":"$undefined"},{"id":"17322","book":"전도서","book_name":"전도서","chapter":1,"verse":6,"text":"바람은 남으로 불다가 북으로 돌이키며 이리 돌며 저리 돌아 불던 곳으로 돌아가고","reference":"전도서 1:6","category":"$undefined"},{"id":"17323","book":"전도서","book_name":"전도서","chapter":1,"verse":7,"text":"모든 강물은 다 바다로 흐르되 바다를 채우지 못하며 어느 곳으로 흐르든지 그리로 연하여 흐르느니라","reference":"전도서 1:7","category":"$undefined"},{"id":"17324","book":"전도서","book_name":"전도서","chapter":1,"verse":8,"text":"만물의 피곤함을 사람이 말로 다 할 수 없나니 눈은 보아도 족함이 없고 귀는 들어도 차지 아니하는도다","reference":"전도서 1:8","category":"$undefined"},{"id":"17325","book":"전도서","book_name":"전도서","chapter":1,"verse":9,"text":"이미 있던 것이 후에 다시 있겠고 이미 한 일을 후에 다시 할지라 해 아래는 새 것이 없나니","reference":"전도서 1:9","category":"$undefined"},{"id":"17326","book":"전도서","book_name":"전도서","chapter":1,"verse":10,"text":"무엇을 가리켜 이르기를 보라 이것이 새 것이라 할 것이 있으랴 오래 전 세대에도 이미 있었느니라","reference":"전도서 1:10","category":"$undefined"},{"id":"17327","book":"전도서","book_name":"전도서","chapter":1,"verse":11,"text":"이전 세대를 기억함이 없으니 장래 세대도 그 후 세대가 기억함이 없으리라","reference":"전도서 1:11","category":"$undefined"},{"id":"17328","book":"전도서","book_name":"전도서","chapter":1,"verse":12,"text":"나 전도자는 예루살렘에서 이스라엘 왕이 되어","reference":"전도서 1:12","category":"$undefined"},{"id":"17329","book":"전도서","book_name":"전도서","chapter":1,"verse":13,"text":"마음을 다하며 지혜를 써서 하늘 아래서 행하는 모든 일을 궁구하며 살핀즉 이는 괴로운 것이니 하나님이 인생들에게 주사 수고하게 하신 것이라","reference":"전도서 1:13","category":"$undefined"},{"id":"17330","book":"전도서","book_name":"전도서","chapter":1,"verse":14,"text":"내가 해 아래서 행하는 모든 일을 본즉 다 헛되어 바람을 잡으려는 것이로다","reference":"전도서 1:14","category":"$undefined"},{"id":"17331","book":"전도서","book_name":"전도서","chapter":1,"verse":15,"text":"구부러진 것을 곧게 할 수 없고 이지러진 것을 셀 수 없도다","reference":"전도서 1:15","category":"$undefined"},{"id":"17332","book":"전도서","book_name":"전도서","chapter":1,"verse":16,"text":"내가 마음 가운데 말하여 이르기를 내가 큰 지혜를 많이 얻었으므로 나보다 먼저 예루살렘에 있던 자보다 낫다 하였나니 곧 내 마음이 지혜와 지식을 많이 만나 보았음이로다","reference":"전도서 1:16","category":"$undefined"},{"id":"17333","book":"전도서","book_name":"전도서","chapter":1,"verse":17,"text":"내가 다시 지혜를 알고자 하며 미친 것과 미련한 것을 알고자 하여 마음을 썼으나 이것도 바람을 잡으려는 것인 줄을 깨달았도다","reference":"전도서 1:17","category":"$undefined"},{"id":"17334","book":"전도서","book_name":"전도서","chapter":1,"verse":18,"text":"지혜가 많으면 번뇌도 많으니 지식을 더하는 자는 근심을 더하느니라","reference":"전도서 1:18","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
