2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":10,"verses":[{"id":"17495","book":"전도서","book_name":"전도서","chapter":10,"verse":1,"text":"죽은 파리가 향기름으로 악취가 나게 하는 것 같이 적은 우매가 지혜와 존귀로 패하게 하느니라","reference":"전도서 10:1","category":"$undefined"},{"id":"17496","book":"전도서","book_name":"전도서","chapter":10,"verse":2,"text":"지혜자의 마음은 오른편에 있고 우매자의 마음은 왼편에 있느니라","reference":"전도서 10:2","category":"$undefined"},{"id":"17497","book":"전도서","book_name":"전도서","chapter":10,"verse":3,"text":"우매자는 길에 행할 때에도 지혜가 결핍하여 각 사람에게 자기의 우매한 것을 말하느니라","reference":"전도서 10:3","category":"$undefined"},{"id":"17498","book":"전도서","book_name":"전도서","chapter":10,"verse":4,"text":"주권자가 네게 분을 일으키거든 너는 네 자리를 떠나지 말라 공순이 큰 허물을 경하게 하느니라","reference":"전도서 10:4","category":"$undefined"},{"id":"17499","book":"전도서","book_name":"전도서","chapter":10,"verse":5,"text":"내가 해 아래서 한 가지 폐단 곧 주권자에게서 나는 허물인 듯한것을 보았노니","reference":"전도서 10:5","category":"$undefined"},{"id":"17500","book":"전도서","book_name":"전도서","chapter":10,"verse":6,"text":"우매자가 크게 높은 지위를 얻고 부자가 낮은 지위에 앉는도다","reference":"전도서 10:6","category":"$undefined"},{"id":"17501","book":"전도서","book_name":"전도서","chapter":10,"verse":7,"text":"또 보았노니 종들은 말을 타고 방백들은 종처럼 땅에 걸어 다니는도다","reference":"전도서 10:7","category":"$undefined"},{"id":"17502","book":"전도서","book_name":"전도서","chapter":10,"verse":8,"text":"함정을 파는 자는 거기 빠질 것이요 담을 허는 자는 뱀에게 물리리라","reference":"전도서 10:8","category":"$undefined"},{"id":"17503","book":"전도서","book_name":"전도서","chapter":10,"verse":9,"text":"돌을 떠내는 자는 그로 인하여 상할 것이요 나무를 쪼개는 자는 그로 인하여 위험을 당하리라","reference":"전도서 10:9","category":"$undefined"},{"id":"17504","book":"전도서","book_name":"전도서","chapter":10,"verse":10,"text":"무딘 철 연장 날을 갈지 아니하면 힘이 더 드느니라 오직 지혜는 성공하기에 유익하니라","reference":"전도서 10:10","category":"$undefined"},{"id":"17505","book":"전도서","book_name":"전도서","chapter":10,"verse":11,"text":"방술을 베풀기 전에 뱀에게 물렸으면 술객은 무용하니라","reference":"전도서 10:11","category":"$undefined"},{"id":"17506","book":"전도서","book_name":"전도서","chapter":10,"verse":12,"text":"지혜자의 입의 말은 은혜로우나 우매자의 입술은 자기를 삼키나니","reference":"전도서 10:12","category":"$undefined"},{"id":"17507","book":"전도서","book_name":"전도서","chapter":10,"verse":13,"text":"그 입의 말의 시작은 우매요 끝은 광패니라","reference":"전도서 10:13","category":"$undefined"},{"id":"17508","book":"전도서","book_name":"전도서","chapter":10,"verse":14,"text":"우매자는 말을 많이 하거니와 사람이 장래 일을 알지 못하나니 신후사를 알게 할 자가 누구이냐","reference":"전도서 10:14","category":"$undefined"},{"id":"17509","book":"전도서","book_name":"전도서","chapter":10,"verse":15,"text":"우매자들의 수고는 제각기 곤하게 할 뿐이라 저희는 성읍에 들어갈 줄도 알지 못함이니라","reference":"전도서 10:15","category":"$undefined"},{"id":"17510","book":"전도서","book_name":"전도서","chapter":10,"verse":16,"text":"왕은 어리고 대신들은 아침에 연락하는 이 나라여 화가 있도다","reference":"전도서 10:16","category":"$undefined"},{"id":"17511","book":"전도서","book_name":"전도서","chapter":10,"verse":17,"text":"왕은 귀족의 아들이요 대신들은 취하려 함이 아니라 기력을 보하려고 마땅한 때에 먹는 이 나라여 복이 있도다","reference":"전도서 10:17","category":"$undefined"},{"id":"17512","book":"전도서","book_name":"전도서","chapter":10,"verse":18,"text":"게으른즉 석가래가 퇴락하고 손이 풀어진즉 집이 새느니라","reference":"전도서 10:18","category":"$undefined"},{"id":"17513","book":"전도서","book_name":"전도서","chapter":10,"verse":19,"text":"잔치는 희락을 위하여 베푸는 것이요 포도주는 생명을 기쁘게 하는 것이나 돈은 범사에 응용되느니라","reference":"전도서 10:19","category":"$undefined"},{"id":"17514","book":"전도서","book_name":"전도서","chapter":10,"verse":20,"text":"심중에라도 왕을 저주하지 말며 침방에서라도 부자를 저주하지 말라 공중의 새가 그 소리를 전하고 날짐승이 그 일을 전파할 것임이니라","reference":"전도서 10:20","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
