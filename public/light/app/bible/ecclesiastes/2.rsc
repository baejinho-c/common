2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":2,"verses":[{"id":"17335","book":"전도서","book_name":"전도서","chapter":2,"verse":1,"text":"나는 내 마음에 이르기를 자, 내가 시험적으로 너를 즐겁게 하리니 너는 낙을 누리라 하였으나 본즉 이것도 헛되도다","reference":"전도서 2:1","category":"$undefined"},{"id":"17336","book":"전도서","book_name":"전도서","chapter":2,"verse":2,"text":"내가 웃음을 논하여 이르기를 미친 것이라 하였고 희락을 논하여 이르기를 저가 무엇을 하는가 하였노라","reference":"전도서 2:2","category":"$undefined"},{"id":"17337","book":"전도서","book_name":"전도서","chapter":2,"verse":3,"text":"내 마음이 궁구하기를 내가 어떻게 하여야 내 마음에 지혜로 다스림을 받으면서 술로 내 육신을 즐겁게 할까 또 어떻게 하여야 어리석음을 취하여서 천하 인생의 종신토록 생활함에 어떤 것이 쾌락인지 알까 하여","reference":"전도서 2:3","category":"$undefined"},{"id":"17338","book":"전도서","book_name":"전도서","chapter":2,"verse":4,"text":"나의 사업을 크게 하였노라 내가 나를 위하여 집들을 지으며 포도원을 심으며","reference":"전도서 2:4","category":"$undefined"},{"id":"17339","book":"전도서","book_name":"전도서","chapter":2,"verse":5,"text":"여러 동산과 과원을 만들고 그 가운데 각종 과목을 심었으며","reference":"전도서 2:5","category":"$undefined"},{"id":"17340","book":"전도서","book_name":"전도서","chapter":2,"verse":6,"text":"수목을 기르는 삼림에 물주기 위하여 못을 팠으며","reference":"전도서 2:6","category":"$undefined"},{"id":"17341","book":"전도서","book_name":"전도서","chapter":2,"verse":7,"text":"노비는 사기도 하였고 집에서 나게도 하였으며 나보다 먼저 예루살렘에 있던 모든 자보다도 소와 양떼의 소유를 많게 하였으며","reference":"전도서 2:7","category":"$undefined"},{"id":"17342","book":"전도서","book_name":"전도서","chapter":2,"verse":8,"text":"은금과 왕들의 보배와 여러 도의 보배를 쌓고 또 노래하는 남녀와 인생들의 기뻐하는 처와 첩들을 많이 두었노라","reference":"전도서 2:8","category":"$undefined"},{"id":"17343","book":"전도서","book_name":"전도서","chapter":2,"verse":9,"text":"내가 이같이 창성하여 나보다 먼저 예루살렘에 있던 모든 자보다 지나고 내 지혜도 내게 여전하여","reference":"전도서 2:9","category":"$undefined"},{"id":"17344","book":"전도서","book_name":"전도서","chapter":2,"verse":10,"text":"무엇이든지 내 마음이 즐거워하는 것을 내가 막지 아니하였으니 이는 나의 모든 수고를 내 마음이 기뻐하였음이라 이것이 나의 모든 수고로 말미암아 얻은 분복이로다","reference":"전도서 2:10","category":"$undefined"},{"id":"17345","book":"전도서","book_name":"전도서","chapter":2,"verse":11,"text":"그 후에 본즉 내 손으로 한 모든 일과 수고한 모든 수고가 다 헛되어 바람을 잡으려는 것이며 해 아래서 무익한 것이로다","reference":"전도서 2:11","category":"$undefined"},{"id":"17346","book":"전도서","book_name":"전도서","chapter":2,"verse":12,"text":"내가 돌이켜 지혜와 망령됨과 어리석음을 보았나니 왕의 뒤에 오는 자는 무슨 일을 행할꼬 행한지 오랜 일일 뿐이리라","reference":"전도서 2:12","category":"$undefined"},{"id":"17347","book":"전도서","book_name":"전도서","chapter":2,"verse":13,"text":"내가 보건대 지혜가 우매보다 뛰어남이 빛이 어두움보다 뛰어남 같도다","reference":"전도서 2:13","category":"$undefined"},{"id":"17348","book":"전도서","book_name":"전도서","chapter":2,"verse":14,"text":"지혜자는 눈이 밝고 우매자는 어두움에 다니거니와 이들의 당하는 일이 일반인 줄을 내가 깨닫고","reference":"전도서 2:14","category":"$undefined"},{"id":"17349","book":"전도서","book_name":"전도서","chapter":2,"verse":15,"text":"심중에 이르기를 우매자의 당한 것을 나도 당하리니 내가 심중에 이르기를 이것도 헛되도다","reference":"전도서 2:15","category":"$undefined"},{"id":"17350","book":"전도서","book_name":"전도서","chapter":2,"verse":16,"text":"지혜자나 우매자나 영원토록 기억함을 얻지 못하나니 후일에는 다 잊어버린지 오랠 것임이라 오호라, 지혜자의 죽음이 우매자의 죽음과 일반이로다","reference":"전도서 2:16","category":"$undefined"},{"id":"17351","book":"전도서","book_name":"전도서","chapter":2,"verse":17,"text":"이러므로 내가 사는 것을 한하였노니 이는 해 아래서 하는 일이 내게 괴로움이요 다 헛되어 바람을 잡으려는 것임이로다","reference":"전도서 2:17","category":"$undefined"},{"id":"17352","book":"전도서","book_name":"전도서","chapter":2,"verse":18,"text":"내가 해 아래서 나의 수고한 모든 수고를 한하였노니 이는 내 뒤를 이을 자에게 끼치게 됨이라","reference":"전도서 2:18","category":"$undefined"},{"id":"17353","book":"전도서","book_name":"전도서","chapter":2,"verse":19,"text":"그 사람이 지혜자일지,우매자일지야 누가 알랴마는 내가 해 아래서 내 지혜를 나타내어 수고한 모든 결과를 저가 다 관리하리니 이것도 헛되도다","reference":"전도서 2:19","category":"$undefined"},{"id":"17354","book":"전도서","book_name":"전도서","chapter":2,"verse":20,"text":"이러므로 내가 해 아래서 수고한 모든 수고에 대하여 도리어 마음으로 실망케 하였도다","reference":"전도서 2:20","category":"$undefined"},{"id":"17355","book":"전도서","book_name":"전도서","chapter":2,"verse":21,"text":"어떤 사람은 그 지혜와 지식과 재주를 써서 수고하였어도 그 얻은 것을 수고하지 아니한 자에게 업으로 끼치리니 이것도 헛된 것이라 큰 해로다","reference":"전도서 2:21","category":"$undefined"},{"id":"17356","book":"전도서","book_name":"전도서","chapter":2,"verse":22,"text":"사람이 해 아래서 수고하는 모든 수고와 마음에 애쓰는 것으로 소득이 무엇이랴","reference":"전도서 2:22","category":"$undefined"},{"id":"17357","book":"전도서","book_name":"전도서","chapter":2,"verse":23,"text":"일평생에 근심하며 수고하는 것이 슬픔뿐이라 그 마음이 밤에도 쉬지 못하나니 이것도 헛되도다","reference":"전도서 2:23","category":"$undefined"},{"id":"17358","book":"전도서","book_name":"전도서","chapter":2,"verse":24,"text":"사람이 먹고 마시며 수고하는 가운데서 심령으로 낙을 누리게 하는 것보다 나은 것이 없나니 내가 이것도 본즉 하나님의 손에서 나는 것이로다","reference":"전도서 2:24","category":"$undefined"},{"id":"17359","book":"전도서","book_name":"전도서","chapter":2,"verse":25,"text":"먹고 즐거워하는 일에 누가 나보다 승하랴","reference":"전도서 2:25","category":"$undefined"},{"id":"17360","book":"전도서","book_name":"전도서","chapter":2,"verse":26,"text":"하나님이 그 기뻐하시는 자에게는 지혜와 지식과 희락을 주시나 죄인에게는 노고를 주시고 저로 모아 쌓게 하사 하나님을 기뻐하는 자에게 주게 하시나니 이것도 헛되어 바람을 잡으려는 것이로다","reference":"전도서 2:26","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
