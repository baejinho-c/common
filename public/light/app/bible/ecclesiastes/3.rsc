2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":3,"verses":[{"id":"17361","book":"전도서","book_name":"전도서","chapter":3,"verse":1,"text":"천하에 범사가 기한이 있고 모든 목적이 이룰 때가 있나니","reference":"전도서 3:1","category":"$undefined"},{"id":"17362","book":"전도서","book_name":"전도서","chapter":3,"verse":2,"text":"날 때가 있고, 죽을 때가 있으며, 심을 때가 있고, 심은 것을 뽑을 때가 있으며,","reference":"전도서 3:2","category":"$undefined"},{"id":"17363","book":"전도서","book_name":"전도서","chapter":3,"verse":3,"text":"죽일 때가 있고, 치료시킬 때가 있으며, 헐 때가 있고, 세울 때가 있으며,","reference":"전도서 3:3","category":"$undefined"},{"id":"17364","book":"전도서","book_name":"전도서","chapter":3,"verse":4,"text":"울 때가 있고, 웃을 때가 있으며, 슬퍼할 때가 있고, 춤출 때가 있으며,","reference":"전도서 3:4","category":"$undefined"},{"id":"17365","book":"전도서","book_name":"전도서","chapter":3,"verse":5,"text":"돌을 던져 버릴 때가 있고, 돌을 거둘 때가 있으며, 안을 때가 있고, 안는 일을 멀리 할 때가 있으며,","reference":"전도서 3:5","category":"$undefined"},{"id":"17366","book":"전도서","book_name":"전도서","chapter":3,"verse":6,"text":"찾을 때가 있고, 잃을 때가 있으며, 지킬 때가 있고, 버릴 때가 있으며,","reference":"전도서 3:6","category":"$undefined"},{"id":"17367","book":"전도서","book_name":"전도서","chapter":3,"verse":7,"text":"찢을 때가 있고, 꿰멜 때가 있으며, 잠잠할 때가 있고, 말할 때가 있으며,","reference":"전도서 3:7","category":"$undefined"},{"id":"17368","book":"전도서","book_name":"전도서","chapter":3,"verse":8,"text":"사랑할 때가 있고, 미워할 때가 있으며, 전쟁할 때가 있고, 평화할때가 있느니라","reference":"전도서 3:8","category":"$undefined"},{"id":"17369","book":"전도서","book_name":"전도서","chapter":3,"verse":9,"text":"일하는 자가 그 수고로 말미암아 무슨 이익이 있으랴","reference":"전도서 3:9","category":"$undefined"},{"id":"17370","book":"전도서","book_name":"전도서","chapter":3,"verse":10,"text":"하나님이 인생들에게 노고를 주사 애쓰게 하신 것을 내가 보았노라","reference":"전도서 3:10","category":"$undefined"},{"id":"17371","book":"전도서","book_name":"전도서","chapter":3,"verse":11,"text":"하나님이 모든 것을 지으시되 때를 따라 아름답게 하셨고 또 사람에게 영원을 사모하는 마음을 주셨느니라 그러나 하나님의 하시는 일의 시종을 사람으로 측량할 수 없게 하셨도다","reference":"전도서 3:11","category":"$undefined"},{"id":"17372","book":"전도서","book_name":"전도서","chapter":3,"verse":12,"text":"사람이 사는 동안에 기뻐하며 선을 행하는 것보다 나은 것이 없는 줄을 내가 알았고","reference":"전도서 3:12","category":"$undefined"},{"id":"17373","book":"전도서","book_name":"전도서","chapter":3,"verse":13,"text":"사람마다 먹고 마시는 것과 수고함으로 낙을 누리는 것이 하나님의 선물인 줄을 또한 알았도다","reference":"전도서 3:13","category":"$undefined"},{"id":"17374","book":"전도서","book_name":"전도서","chapter":3,"verse":14,"text":"무릇 하나님의 행하시는 것은 영원히 있을 것이라 더 할 수도 없고 덜 할 수도 없나니 하나님이 이같이 행하심은 사람으로 그 앞에서 경외하게 하려 하심인 줄을 내가 알았도다","reference":"전도서 3:14","category":"$undefined"},{"id":"17375","book":"전도서","book_name":"전도서","chapter":3,"verse":15,"text":"이제 있는 것이 옛적에 있었고 장래에 있을 것도 옛적에 있었나니 하나님은 이미 지난 것을 다시 찾으시느니라","reference":"전도서 3:15","category":"$undefined"},{"id":"17376","book":"전도서","book_name":"전도서","chapter":3,"verse":16,"text":"내가 해 아래서 또 보건대 재판하는 곳에 악이 있고 공의를 행하는 곳에도 악이 있도다","reference":"전도서 3:16","category":"$undefined"},{"id":"17377","book":"전도서","book_name":"전도서","chapter":3,"verse":17,"text":"내가 심중에 이르기를 의인과 악인을 하나님이 심판하시리니 이는 모든 목적과 모든 일이 이룰 때가 있음이라 하였으며","reference":"전도서 3:17","category":"$undefined"},{"id":"17378","book":"전도서","book_name":"전도서","chapter":3,"verse":18,"text":"내가 심중에 이르기를 인생의 일에 대하여 하나님이 저희를 시험하시리니 저희로 자기가 짐승보다 다름이 없는 줄을 깨닫게 하려하심이라 하였노라","reference":"전도서 3:18","category":"$undefined"},{"id":"17379","book":"전도서","book_name":"전도서","chapter":3,"verse":19,"text":"인생에게 임하는 일이 일반이라 다 동일한 호흡이 있어서 이의 죽음같이 저도 죽으니 사람이 짐승보다 뛰어남이 없음은 모든 것이 헛됨이로다","reference":"전도서 3:19","category":"$undefined"},{"id":"17380","book":"전도서","book_name":"전도서","chapter":3,"verse":20,"text":"다 흙으로 말미암았으므로 다 흙으로 돌아가나니 다 한 곳으로 가거니와","reference":"전도서 3:20","category":"$undefined"},{"id":"17381","book":"전도서","book_name":"전도서","chapter":3,"verse":21,"text":"인생의 혼은 위로 올라가고 짐승의 혼은 아래 곧 땅으로 내려가는 줄을 누가 알랴","reference":"전도서 3:21","category":"$undefined"},{"id":"17382","book":"전도서","book_name":"전도서","chapter":3,"verse":22,"text":"그러므로 내 소견에는 사람이 자기 일에 즐거워하는 것보다 나은것이 없나니 이는 그의 분복이라 그 신후사를 보게 하려고 저를 도로 데리고 올 자가 누구이랴","reference":"전도서 3:22","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
