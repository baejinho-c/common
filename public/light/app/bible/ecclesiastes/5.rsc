2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":5,"verses":[{"id":"17399","book":"전도서","book_name":"전도서","chapter":5,"verse":1,"text":"너는 하나님의 전에 들어갈 때에 네 발을 삼갈지어다 가까이 하여 말씀을 듣는 것이 우매자의 제사 드리는 것보다 나으니 저희는 악을 행하면서도 깨닫지 못함이니라","reference":"전도서 5:1","category":"$undefined"},{"id":"17400","book":"전도서","book_name":"전도서","chapter":5,"verse":2,"text":"너는 하나님 앞에서 함부로 입을 열지 말며 급한 마음으로 말을 내지 말라 하나님은 하늘에 계시고 너는 땅에 있음이니라 그런즉 마땅히 말을 적게 할 것이라","reference":"전도서 5:2","category":"$undefined"},{"id":"17401","book":"전도서","book_name":"전도서","chapter":5,"verse":3,"text":"일이 많으면 꿈이 생기고 말이 많으면 우매자의 소리가 나타나느니라","reference":"전도서 5:3","category":"$undefined"},{"id":"17402","book":"전도서","book_name":"전도서","chapter":5,"verse":4,"text":"네가 하나님께 서원하였거든 갚기를 더디게 말라 하나님은 우매자를 기뻐하지 아니하시나니 서원한 것을 갚으라","reference":"전도서 5:4","category":"$undefined"},{"id":"17403","book":"전도서","book_name":"전도서","chapter":5,"verse":5,"text":"서원하고 갚지 아니하는 것보다 서원하지 아니하는 것이 나으니","reference":"전도서 5:5","category":"$undefined"},{"id":"17404","book":"전도서","book_name":"전도서","chapter":5,"verse":6,"text":"네 입으로 네 육체를 범죄케 말라 사자 앞에서 내가 서원한 것이 실수라고 말하지 말라 어찌 하나님으로 네 말소리를 진노하사 네 손으로 한 것을 멸하시게 하랴","reference":"전도서 5:6","category":"$undefined"},{"id":"17405","book":"전도서","book_name":"전도서","chapter":5,"verse":7,"text":"꿈이 많으면 헛된 것이 많고 말이 많아도 그러하니 오직 너는 하나님을 경외할지니라","reference":"전도서 5:7","category":"$undefined"},{"id":"17406","book":"전도서","book_name":"전도서","chapter":5,"verse":8,"text":"너는 어느 도에서든지 빈민을 학대하는 것과 공의를 박멸하는 것을 볼지라도 그것을 이상히 여기지 말라 높은 자보다 더 높은 자가 감찰하고 그들보다 더 높은 자들이 있음이니라","reference":"전도서 5:8","category":"$undefined"},{"id":"17407","book":"전도서","book_name":"전도서","chapter":5,"verse":9,"text":"땅의 이익은 뭇 사람을 위하여 있나니 왕도 밭의 소산을 받느니라","reference":"전도서 5:9","category":"$undefined"},{"id":"17408","book":"전도서","book_name":"전도서","chapter":5,"verse":10,"text":"은을 사랑하는 자는 은으로 만족함이 없고 풍부를 사랑하는 자는 소득으로 만족함이 없나니 이것도 헛되도다","reference":"전도서 5:10","category":"$undefined"},{"id":"17409","book":"전도서","book_name":"전도서","chapter":5,"verse":11,"text":"노동자는 먹는 것이 많든지 적든지 잠을 달게 자거니와 부자는 배부름으로 자지 못하느니라","reference":"전도서 5:11","category":"$undefined"},{"id":"17410","book":"전도서","book_name":"전도서","chapter":5,"verse":12,"text":"내가 해 아래서 큰 폐단되는 것을 보았나니 곧 소유주가 재물을 자기에게 해 되도록 지키는 것이라","reference":"전도서 5:12","category":"$undefined"},{"id":"17411","book":"전도서","book_name":"전도서","chapter":5,"verse":13,"text":"그 재물이 재난을 인하여 패하나니 비록 아들은 낳았으나 그 손에 아무 것도 없느니라","reference":"전도서 5:13","category":"$undefined"},{"id":"17412","book":"전도서","book_name":"전도서","chapter":5,"verse":14,"text":"저가 모태에서 벌거벗고 나왔은즉 그 나온 대로 돌아가고 수고하여 얻은 것을 아무 것도 손에 가지고 가지 못하리니","reference":"전도서 5:14","category":"$undefined"},{"id":"17413","book":"전도서","book_name":"전도서","chapter":5,"verse":15,"text":"이것도 폐단이라 어떻게 왔든지 그대로 가리니 바람을 잡으려는 수고가 저에게 무엇이 유익하랴","reference":"전도서 5:15","category":"$undefined"},{"id":"17414","book":"전도서","book_name":"전도서","chapter":5,"verse":16,"text":"일평생을 어두운 데서 먹으며 번뇌와 병과 분노가 저에게 있느니라","reference":"전도서 5:16","category":"$undefined"},{"id":"17415","book":"전도서","book_name":"전도서","chapter":5,"verse":17,"text":"사람이 하나님의 주신 바 그 일평생에 먹고 마시며 해 아래서 수고하는 모든 수고 중에서 낙을 누리는 것이 선하고 아름다움을 내가 보았나니 이것이 그의 분복이로다","reference":"전도서 5:17","category":"$undefined"},{"id":"17416","book":"전도서","book_name":"전도서","chapter":5,"verse":18,"text":"어떤 사람에게든지 하나님이 재물과 부요를 주사 능히 누리게 하시며 분복을 받아 수고함으로 즐거워하게 하신 것은 하나님의 선물이라","reference":"전도서 5:18","category":"$undefined"},{"id":"17417","book":"전도서","book_name":"전도서","chapter":5,"verse":19,"text":"저는 그 생명의 날을 깊이 관념치 아니하리니 이는 하나님이 저의 마음의 기뻐하는 것으로 응하심이라","reference":"전도서 5:19","category":"$undefined"},{"id":"17418","book":"전도서","book_name":"전도서","chapter":5,"verse":20,"text":"","reference":"전도서 5:20","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
