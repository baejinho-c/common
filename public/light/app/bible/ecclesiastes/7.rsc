2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":7,"verses":[{"id":"17431","book":"전도서","book_name":"전도서","chapter":7,"verse":1,"text":"아름다운 이름이 보배로운 기름보다 낫고 죽는 날이 출생하는 날보다 나으며","reference":"전도서 7:1","category":"$undefined"},{"id":"17432","book":"전도서","book_name":"전도서","chapter":7,"verse":2,"text":"초상집에 가는 것이 잔치집에 가는 것보다 나으니 모든 사람의 결국이 이와 같이 됨이라 산 자가 이것에 유심하리로다","reference":"전도서 7:2","category":"$undefined"},{"id":"17433","book":"전도서","book_name":"전도서","chapter":7,"verse":3,"text":"슬픔이 웃음보다 나음은 얼굴에 근심함으로 마음이 좋게 됨이니라","reference":"전도서 7:3","category":"$undefined"},{"id":"17434","book":"전도서","book_name":"전도서","chapter":7,"verse":4,"text":"지혜자의 마음은 초상집에 있으되 우매자의 마음은 연락하는 집에 있느니라","reference":"전도서 7:4","category":"$undefined"},{"id":"17435","book":"전도서","book_name":"전도서","chapter":7,"verse":5,"text":"사람이 지혜자의 책망을 듣는 것이 우매자의 노래를 듣는 것보다 나으니라","reference":"전도서 7:5","category":"$undefined"},{"id":"17436","book":"전도서","book_name":"전도서","chapter":7,"verse":6,"text":"우매자의 웃음 소리는 솥 밑에서 가시나무의 타는 소리 같으니 이것도 헛되니라","reference":"전도서 7:6","category":"$undefined"},{"id":"17437","book":"전도서","book_name":"전도서","chapter":7,"verse":7,"text":"탐학이 지혜자를 우매하게 하고 뇌물이 사람의 명철을 망케 하느니라","reference":"전도서 7:7","category":"$undefined"},{"id":"17438","book":"전도서","book_name":"전도서","chapter":7,"verse":8,"text":"일의 끝이 시작보다 낫고 참는 마음이 교만한 마음보다 나으니","reference":"전도서 7:8","category":"$undefined"},{"id":"17439","book":"전도서","book_name":"전도서","chapter":7,"verse":9,"text":"급한 마음으로 노를 발하지 말라 노는 우매자의 품에 머무름이니라","reference":"전도서 7:9","category":"$undefined"},{"id":"17440","book":"전도서","book_name":"전도서","chapter":7,"verse":10,"text":"옛날이 오늘보다 나은 것이 어찜이냐 하지 말라 이렇게 묻는 것이 지혜가 아니니라","reference":"전도서 7:10","category":"$undefined"},{"id":"17441","book":"전도서","book_name":"전도서","chapter":7,"verse":11,"text":"지혜는 유업같이 아름답고 햇빛을 보는 자에게 유익하도다","reference":"전도서 7:11","category":"$undefined"},{"id":"17442","book":"전도서","book_name":"전도서","chapter":7,"verse":12,"text":"지혜도 보호하는 것이 되고 돈도 보호하는 것이 되나 지식이 더욱 아름다움은 지혜는 지혜 얻은 자의 생명을 보존함이니라","reference":"전도서 7:12","category":"$undefined"},{"id":"17443","book":"전도서","book_name":"전도서","chapter":7,"verse":13,"text":"하나님의 행하시는 일을 보라 하나님이 굽게 하신 것을 누가 능히 곧게 하겠느냐","reference":"전도서 7:13","category":"$undefined"},{"id":"17444","book":"전도서","book_name":"전도서","chapter":7,"verse":14,"text":"형통한 날에는 기뻐하고 곤고한 날에는 생각하라 하나님이 이 두가지를 병행하게 하사 사람으로 그 장래 일을 능히 헤아려 알지 못하게 하셨느니라","reference":"전도서 7:14","category":"$undefined"},{"id":"17445","book":"전도서","book_name":"전도서","chapter":7,"verse":15,"text":"내가 내 헛된 날에 이 모든 일을 본즉 자기의 의로운 중에서 멸망하는 의인이 있고 자기의 악행 중에서 장수하는 악인이 있으니","reference":"전도서 7:15","category":"$undefined"},{"id":"17446","book":"전도서","book_name":"전도서","chapter":7,"verse":16,"text":"지나치게 의인이 되지 말며 지나치게 지혜자도 되지 말라 어찌하여 스스로 패망케 하겠느냐","reference":"전도서 7:16","category":"$undefined"},{"id":"17447","book":"전도서","book_name":"전도서","chapter":7,"verse":17,"text":"지나치게 악인이 되지 말며 우매자도 되지 말라 어찌하여 기한 전에 죽으려느냐","reference":"전도서 7:17","category":"$undefined"},{"id":"17448","book":"전도서","book_name":"전도서","chapter":7,"verse":18,"text":"너는 이것을 잡으며 저것을 놓지 마는 것이 좋으니 하나님을 경외하는 자는 이 모든 일에서 벗어날 것임이니라","reference":"전도서 7:18","category":"$undefined"},{"id":"17449","book":"전도서","book_name":"전도서","chapter":7,"verse":19,"text":"지혜가 지혜자로 성읍 가운데 열 유사보다 능력이 있게 하느니라","reference":"전도서 7:19","category":"$undefined"},{"id":"17450","book":"전도서","book_name":"전도서","chapter":7,"verse":20,"text":"선을 행하고 죄를 범치 아니하는 의인은 세상에 아주 없느니라","reference":"전도서 7:20","category":"$undefined"},{"id":"17451","book":"전도서","book_name":"전도서","chapter":7,"verse":21,"text":"무릇 사람의 말을 들으려고 마음을 두지 말라 염려컨대 네 종이 너를 저주하는 것을 들으리라","reference":"전도서 7:21","category":"$undefined"},{"id":"17452","book":"전도서","book_name":"전도서","chapter":7,"verse":22,"text":"너도 가끔 사람을 저주한 것을 네 마음이 아느니라","reference":"전도서 7:22","category":"$undefined"},{"id":"17453","book":"전도서","book_name":"전도서","chapter":7,"verse":23,"text":"내가 이 모든 것을 지혜로 시험하며 스스로 이르기를 내가 지혜자가 되리라 하였으나 지혜가 나를 멀리하였도다","reference":"전도서 7:23","category":"$undefined"},{"id":"17454","book":"전도서","book_name":"전도서","chapter":7,"verse":24,"text":"무릇 된 것이 멀고 깊고 깊도다 누가 능히 통달하랴","reference":"전도서 7:24","category":"$undefined"},{"id":"17455","book":"전도서","book_name":"전도서","chapter":7,"verse":25,"text":"내가 돌이켜 전심으로 지혜와 명철을 살피고 궁구하여 악한 것이 어리석은 것이요 어리석은 것이 미친 것인 줄을 알고자 하였더니","reference":"전도서 7:25","category":"$undefined"},{"id":"17456","book":"전도서","book_name":"전도서","chapter":7,"verse":26,"text":"내가 깨달은즉 마음이 올무와 그물같고 손이 포승같은 여인은 사망보다 독한 자라 하나님을 기뻐하는 자는 저를 피하려니와 죄인은 저에게 잡히리로다","reference":"전도서 7:26","category":"$undefined"},{"id":"17457","book":"전도서","book_name":"전도서","chapter":7,"verse":27,"text":"전도자가 가로되 내가 낱낱이 살펴 그 이치를 궁구하여 이것을 깨달았노라","reference":"전도서 7:27","category":"$undefined"},{"id":"17458","book":"전도서","book_name":"전도서","chapter":7,"verse":28,"text":"내 마음에 찾아도 아직 얻지 못한 것이 이것이라 일천 남자 중에서 하나를 얻었거니와 일천 여인 중에서는 하나도 얻지 못하였느니라","reference":"전도서 7:28","category":"$undefined"},{"id":"17459","book":"전도서","book_name":"전도서","chapter":7,"verse":29,"text":"나의 깨달은 것이 이것이라 곧 하나님이 사람을 정직하게 지으셨으나 사람은 많은 꾀를 낸 것이니라","reference":"전도서 7:29","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
