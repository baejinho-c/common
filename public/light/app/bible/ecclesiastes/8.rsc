2:["$","$L11",null,{"book":{"id":"ecclesiastes","name":"전도서","chapters":12,"testament":"old"},"chapter":8,"verses":[{"id":"17460","book":"전도서","book_name":"전도서","chapter":8,"verse":1,"text":"지혜자와 같은 자 누구며 사리의 해석을 아는 자 누구냐 사람의 지혜는 그 사람의 얼굴에 광채가 나게 하나니 그 얼굴의 사나운 것이 변하느니라","reference":"전도서 8:1","category":"$undefined"},{"id":"17461","book":"전도서","book_name":"전도서","chapter":8,"verse":2,"text":"내가 권하노니 왕의 명령을 지키라 이미 하나님을 가리켜 맹세하였음이니라","reference":"전도서 8:2","category":"$undefined"},{"id":"17462","book":"전도서","book_name":"전도서","chapter":8,"verse":3,"text":"왕 앞에서 물러가기를 급거히 말며 악한 것을 일삼지 말라 왕은 그 하고자 하는 것을 다 행함이니라","reference":"전도서 8:3","category":"$undefined"},{"id":"17463","book":"전도서","book_name":"전도서","chapter":8,"verse":4,"text":"왕의 말은 권능이 있나니 누가 이르기를 왕께서 무엇을 하시나이까 할 수 있으랴","reference":"전도서 8:4","category":"$undefined"},{"id":"17464","book":"전도서","book_name":"전도서","chapter":8,"verse":5,"text":"무릇 명령을 지키는 자는 화를 모르리라 지혜자의 마음은 시기와 판단을 분변하나니","reference":"전도서 8:5","category":"$undefined"},{"id":"17465","book":"전도서","book_name":"전도서","chapter":8,"verse":6,"text":"무론 무슨 일에든지 시기와 판단이 있으므로 사람에게 임하는 화가 심함이니라","reference":"전도서 8:6","category":"$undefined"},{"id":"17466","book":"전도서","book_name":"전도서","chapter":8,"verse":7,"text":"사람이 장래 일을 알지 못하나니 장래 일을 가르칠 자가 누구이랴","reference":"전도서 8:7","category":"$undefined"},{"id":"17467","book":"전도서","book_name":"전도서","chapter":8,"verse":8,"text":"생기를 주장하여 생기로 머무르게할 사람도 없고 죽는 날을 주장할 자도 없고 전쟁할 때에 모면할 자도 없으며 악이 행악자를 건져낼 수도 없느니라","reference":"전도서 8:8","category":"$undefined"},{"id":"17468","book":"전도서","book_name":"전도서","chapter":8,"verse":9,"text":"내가 이런 것들을 다 보고 마음을 다하여 해 아래서 행하는 모든 일을 살핀즉 사람이 사람을 주장하여 해롭게 하는 때가 있으며","reference":"전도서 8:9","category":"$undefined"},{"id":"17469","book":"전도서","book_name":"전도서","chapter":8,"verse":10,"text":"내가 본즉 악인은 장사 지낸 바 되어 무덤에 들어 갔고 선을 행한 자는 거룩한 곳에서 떠나 성읍 사람의 잊어버린 바 되었으니 이것도 헛되도다","reference":"전도서 8:10","category":"$undefined"},{"id":"17470","book":"전도서","book_name":"전도서","chapter":8,"verse":11,"text":"악한 일에 징벌이 속히 실행되지 않으므로 인생들이 악을 행하기에 마음이 담대하도다","reference":"전도서 8:11","category":"$undefined"},{"id":"17471","book":"전도서","book_name":"전도서","chapter":8,"verse":12,"text":"죄인이 백번 악을 행하고도 장수하거니와 내가 정녕히 아노니 하나님을 경외하여 그 앞에서 경외하는 자가 잘 될 것이요","reference":"전도서 8:12","category":"$undefined"},{"id":"17472","book":"전도서","book_name":"전도서","chapter":8,"verse":13,"text":"악인은 잘 되지 못하며 장수하지 못하고 그 날이 그림자와 같으리니 이는 하나님 앞에 경외하지 아니함이니라","reference":"전도서 8:13","category":"$undefined"},{"id":"17473","book":"전도서","book_name":"전도서","chapter":8,"verse":14,"text":"세상에 행하는 헛된 일이 있나니 곧 악인의 행위대로 받는 의인도 있고 의인의 행위대로 받는 악인도 있는 것이라 내가 이르노 니 이것도 헛되도다","reference":"전도서 8:14","category":"$undefined"},{"id":"17474","book":"전도서","book_name":"전도서","chapter":8,"verse":15,"text":"이에 내가 희락을 칭찬하노니 이는 사람이 먹고 마시고 즐거워하는 것보다 해 아래서 나은 것이 없음이라 하나님이 사람으로 해 아래서 살게 하신 날 동안 수고하는 중에 이것이 항상 함께 있을것이니라","reference":"전도서 8:15","category":"$undefined"},{"id":"17475","book":"전도서","book_name":"전도서","chapter":8,"verse":16,"text":"내가 마음을 다하여 지혜를 알고자 하며 세상에서 하는 노고를 보고자 하는 동시에 (밤낮으로 자지 못하는 자도 있도다)","reference":"전도서 8:16","category":"$undefined"},{"id":"17476","book":"전도서","book_name":"전도서","chapter":8,"verse":17,"text":"하나님의 모든 행사를 살펴보니 해 아래서 하시는 일을 사람이 능히 깨달을 수 없도다 사람이 아무리 애써 궁구할지라도 능히 깨닫지 못하나니 비록 지혜자가 아노라 할지라도 능히 깨닫지 못하리로다","reference":"전도서 8:17","category":"$undefined"}],"bookSlug":"ecclesiastes"}]
