2:["$","$L11",null,{"book":{"id":"ephesians","name":"에베소서","chapters":6,"testament":"new"},"chapter":1,"verses":[{"id":"29208","book":"에베소서","book_name":"에베소서","chapter":1,"verse":1,"text":"하나님의 뜻으로 말미암아 그리스도 예수의 사도 된 바울은 에베소에 있는 성도들과 그리스도 예수 안에 신실한 자들에게 편지하노니","reference":"에베소서 1:1","category":"$undefined"},{"id":"29209","book":"에베소서","book_name":"에베소서","chapter":1,"verse":2,"text":"하나님 우리 아버지와 주 예수 그리스도로 좇아 은혜와 평강이 너희에게 있을지어다 !","reference":"에베소서 1:2","category":"$undefined"},{"id":"29210","book":"에베소서","book_name":"에베소서","chapter":1,"verse":3,"text":"찬송하리로다 ! 하나님 곧 우리 주 예수 그리스도의 아버지께서 그리스도 안에서 하늘에 속한 모든 신령한 복으로 우리에게 복 주시되","reference":"에베소서 1:3","category":"$undefined"},{"id":"29211","book":"에베소서","book_name":"에베소서","chapter":1,"verse":4,"text":"곧 창세 전에 그리스도 안에서 우리를 택하사 우리로 사랑 안에서 그 앞에 거룩하고 흠이 없게 하시려고","reference":"에베소서 1:4","category":"$undefined"},{"id":"29212","book":"에베소서","book_name":"에베소서","chapter":1,"verse":5,"text":"그 기쁘신 뜻대로 우리를 예정하사 예수 그리스도로 말미암아 자기의 아들들이 되게 하셨으니","reference":"에베소서 1:5","category":"$undefined"},{"id":"29213","book":"에베소서","book_name":"에베소서","chapter":1,"verse":6,"text":"이는 그의 사랑하시는 자 안에서 우리에게 거저 주시는 바 그의 은혜의 영광을 찬미하게 하려는 것이라","reference":"에베소서 1:6","category":"$undefined"},{"id":"29214","book":"에베소서","book_name":"에베소서","chapter":1,"verse":7,"text":"우리가 그리스도 안에서 그의 은혜의 풍성함을 따라 그의 피로 말미암아 구속 곧 죄 사함을 받았으니","reference":"에베소서 1:7","category":"$undefined"},{"id":"29215","book":"에베소서","book_name":"에베소서","chapter":1,"verse":8,"text":"이는 그가 모든 지혜와 총명으로 우리에게 넘치게 하사","reference":"에베소서 1:8","category":"$undefined"},{"id":"29216","book":"에베소서","book_name":"에베소서","chapter":1,"verse":9,"text":"그 뜻의 비밀을 우리에게 알리셨으니 곧 그 기쁘심을 따라 그리스도 안에서 때가 찬 경륜(經綸)을 위하여 예정하신 것이니","reference":"에베소서 1:9","category":"$undefined"},{"id":"29217","book":"에베소서","book_name":"에베소서","chapter":1,"verse":10,"text":"하늘에 있는 것이나 땅에 있는 것이 다 그리스도 안에서 통일되게 하려 하심이라","reference":"에베소서 1:10","category":"$undefined"},{"id":"29218","book":"에베소서","book_name":"에베소서","chapter":1,"verse":11,"text":"모든 일을 그 마음의 원대로 역사하시는 자의 뜻을 따라 우리가 예정을 입어 그 안에서 기업이 되었으니","reference":"에베소서 1:11","category":"$undefined"},{"id":"29219","book":"에베소서","book_name":"에베소서","chapter":1,"verse":12,"text":"이는 그리스도 안에서 전부터 바라던 우리로 그의 영광의 찬송이 되게 하려 하심이라","reference":"에베소서 1:12","category":"$undefined"},{"id":"29220","book":"에베소서","book_name":"에베소서","chapter":1,"verse":13,"text":"그 안에서 너희도 진리의 말씀 곧 너희의 구원의 복음을 듣고 그 안에서 또한 믿어 약속의 성령으로 인치심을 받았으니","reference":"에베소서 1:13","category":"$undefined"},{"id":"29221","book":"에베소서","book_name":"에베소서","chapter":1,"verse":14,"text":"이는 우리의 기업에 보증이 되사 그 얻으신 것을 구속하시고 그의 영광을 찬미하게 하려 하심이라","reference":"에베소서 1:14","category":"$undefined"},{"id":"29222","book":"에베소서","book_name":"에베소서","chapter":1,"verse":15,"text":"이를 인하여 주 예수 안에서 너희 믿음과 모든 성도를 향한 사랑을 나도 듣고","reference":"에베소서 1:15","category":"$undefined"},{"id":"29223","book":"에베소서","book_name":"에베소서","chapter":1,"verse":16,"text":"너희를 인하여 감사하기를 마지 아니하고 내가 기도할 때에 너희를 말하노라","reference":"에베소서 1:16","category":"$undefined"},{"id":"29224","book":"에베소서","book_name":"에베소서","chapter":1,"verse":17,"text":"우리 주 예수 그리스도의 하나님, 영광의 아버지께서 지혜와 계시의 정신을 너희에게 주사 하나님을 알게 하시고","reference":"에베소서 1:17","category":"$undefined"},{"id":"29225","book":"에베소서","book_name":"에베소서","chapter":1,"verse":18,"text":"너희 마음 눈을 밝히사 그의 부르심의 소망이 무엇이며 성도 안에서 그 기업의 영광의 풍성이 무엇이며","reference":"에베소서 1:18","category":"$undefined"},{"id":"29226","book":"에베소서","book_name":"에베소서","chapter":1,"verse":19,"text":"그의 힘의 강력으로 역사하심을 따라 믿는 우리에게 베푸신 능력의 지극히 크심이 어떤 것을 너희로 알게 하시기를 구하노라","reference":"에베소서 1:19","category":"$undefined"},{"id":"29227","book":"에베소서","book_name":"에베소서","chapter":1,"verse":20,"text":"그 능력이 그리스도 안에서 역사하사 죽은 자들 가운데서 다시 살리시고 하늘에서 자기의 오른 편에 앉히사","reference":"에베소서 1:20","category":"$undefined"},{"id":"29228","book":"에베소서","book_name":"에베소서","chapter":1,"verse":21,"text":"모든 정사(政事)와 권세와 능력과 주관하는 자와 이 세상 뿐 아니라 오는 세상에 일컫는 모든 이름 위에 뛰어나게 하시고","reference":"에베소서 1:21","category":"$undefined"},{"id":"29229","book":"에베소서","book_name":"에베소서","chapter":1,"verse":22,"text":"또 만물을 그 발 아래 복종하게 하시고 그를 만물 위에 교회의 머리로 주셨느니라","reference":"에베소서 1:22","category":"$undefined"},{"id":"29230","book":"에베소서","book_name":"에베소서","chapter":1,"verse":23,"text":"교회는 그의 몸이니 만물 안에서 만물을 충만케 하시는 자의 충만이니라","reference":"에베소서 1:23","category":"$undefined"}],"bookSlug":"ephesians"}]
