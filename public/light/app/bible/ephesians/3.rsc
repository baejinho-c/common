2:["$","$L11",null,{"book":{"id":"ephesians","name":"에베소서","chapters":6,"testament":"new"},"chapter":3,"verses":[{"id":"29253","book":"에베소서","book_name":"에베소서","chapter":3,"verse":1,"text":"이러므로 그리스도 예수의 일로 너희 이방을 위하여 갇힌 자 된 나 바울은","reference":"에베소서 3:1","category":"$undefined"},{"id":"29254","book":"에베소서","book_name":"에베소서","chapter":3,"verse":2,"text":"너희를 위하여 내게 주신 하나님의 그 은혜의 경륜을 너희가 들었을 터이라","reference":"에베소서 3:2","category":"$undefined"},{"id":"29255","book":"에베소서","book_name":"에베소서","chapter":3,"verse":3,"text":"곧 계시로 내게 비밀을 알게 하신 것은 내가 이미 대강 기록함과 같으니","reference":"에베소서 3:3","category":"$undefined"},{"id":"29256","book":"에베소서","book_name":"에베소서","chapter":3,"verse":4,"text":"이것을 읽으면 그리스도의 비밀을 내가 깨달은 것을 너희가 알 수 있으리라","reference":"에베소서 3:4","category":"$undefined"},{"id":"29257","book":"에베소서","book_name":"에베소서","chapter":3,"verse":5,"text":"이제 그의 거룩한 사도들과 선지자들에게 성령으로 나타내신 것같이 다른 세대에서는 사람의 아들들에게 알게 하지 아니하셨으니","reference":"에베소서 3:5","category":"$undefined"},{"id":"29258","book":"에베소서","book_name":"에베소서","chapter":3,"verse":6,"text":"이는 이방인들이 복음으로 말미암아 그리스도 예수 안에서 함께 후사가 되고 함께 지체가 되고 함께 약속에 참예하는 자가 됨이라","reference":"에베소서 3:6","category":"$undefined"},{"id":"29259","book":"에베소서","book_name":"에베소서","chapter":3,"verse":7,"text":"이 복음을 위하여 그의 능력이 역사하시는 대로 내게 주신 하나님의 은혜의 선물을 따라 내가 일군이 되었노라","reference":"에베소서 3:7","category":"$undefined"},{"id":"29260","book":"에베소서","book_name":"에베소서","chapter":3,"verse":8,"text":"모든 성도 중에 지극히 작은 자보다 더 작은 나에게 이 은혜를 주신 것은 측량할 수 없는 그리스도의 풍성을 이방인에게 전하게 하시고","reference":"에베소서 3:8","category":"$undefined"},{"id":"29261","book":"에베소서","book_name":"에베소서","chapter":3,"verse":9,"text":"영원부터 만물을 창조하신 하나님 속에 감취었던 비밀의 경륜이 어떠한 것을 드러내게 하려 하심이라","reference":"에베소서 3:9","category":"$undefined"},{"id":"29262","book":"에베소서","book_name":"에베소서","chapter":3,"verse":10,"text":"이는 이제 교회로 말미암아 하늘에서 정사와 권세들에게 하나님의 각종 지혜를 알게 하려 하심이니","reference":"에베소서 3:10","category":"$undefined"},{"id":"29263","book":"에베소서","book_name":"에베소서","chapter":3,"verse":11,"text":"곧 영원부터 우리 주 그리스도 예수 안에서 예정하신 뜻대로 하신 것이라","reference":"에베소서 3:11","category":"$undefined"},{"id":"29264","book":"에베소서","book_name":"에베소서","chapter":3,"verse":12,"text":"우리가 그 안에서 그를 믿음으로 말미암아 담대함과 하나님께 당당히 나아감을 얻느니라","reference":"에베소서 3:12","category":"$undefined"},{"id":"29265","book":"에베소서","book_name":"에베소서","chapter":3,"verse":13,"text":"그러므로 너희에게 구하노니 너희를 위한 나의 여러 환난에 대하여 낙심치 말라 이는 너희의 영광이니라","reference":"에베소서 3:13","category":"$undefined"},{"id":"29266","book":"에베소서","book_name":"에베소서","chapter":3,"verse":14,"text":"이러하므로 내가 하늘과 땅에 있는 각 족속에게","reference":"에베소서 3:14","category":"$undefined"},{"id":"29267","book":"에베소서","book_name":"에베소서","chapter":3,"verse":15,"text":"이름을 주신 아버지 앞에 무릎을 꿇고 비노니","reference":"에베소서 3:15","category":"$undefined"},{"id":"29268","book":"에베소서","book_name":"에베소서","chapter":3,"verse":16,"text":"그 영광의 풍성을 따라 그의 성령으로 말미암아 너희 속 사람을 능력으로 강건하게 하옵시며","reference":"에베소서 3:16","category":"$undefined"},{"id":"29269","book":"에베소서","book_name":"에베소서","chapter":3,"verse":17,"text":"믿음으로 말미암아 그리스도께서 너희 마음에 계시게 하옵시고 너희가 사랑 가운데서 뿌리가 박히고 터가 굳어져서","reference":"에베소서 3:17","category":"$undefined"},{"id":"29270","book":"에베소서","book_name":"에베소서","chapter":3,"verse":18,"text":"능히 모든 성도와 함께 지식에 넘치는 그리스도의 사랑을 알아","reference":"에베소서 3:18","category":"$undefined"},{"id":"29271","book":"에베소서","book_name":"에베소서","chapter":3,"verse":19,"text":"그 넓이와 길이와 높이와 깊이가 어떠함을 깨달아 하나님의 모든 충만하신 것으로 너희에게 충만하게 하시기를 구하노라","reference":"에베소서 3:19","category":"$undefined"},{"id":"29272","book":"에베소서","book_name":"에베소서","chapter":3,"verse":20,"text":"우리 가운데서 역사하시는 능력대로 우리의 온갖 구하는 것이나 생각하는 것에 더 넘치도록 능히 하실 이에게","reference":"에베소서 3:20","category":"$undefined"},{"id":"29273","book":"에베소서","book_name":"에베소서","chapter":3,"verse":21,"text":"교회 안에서와 그리스도 예수 안에서 영광이 대대로 영원 무궁하기를 원하노라 아멘","reference":"에베소서 3:21","category":"$undefined"}],"bookSlug":"ephesians"}]
