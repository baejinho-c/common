2:["$","$L11",null,{"book":{"id":"ephesians","name":"에베소서","chapters":6,"testament":"new"},"chapter":4,"verses":[{"id":"29274","book":"에베소서","book_name":"에베소서","chapter":4,"verse":1,"text":"그러므로 주 안에서 갇힌 내가 너희를 권하노니 너희가 부르심을 입은 부름에 합당하게 행하여","reference":"에베소서 4:1","category":"$undefined"},{"id":"29275","book":"에베소서","book_name":"에베소서","chapter":4,"verse":2,"text":"모든 겸손과 온유로 하고 오래 참음으로 사랑 가운데서 서로 용납하고","reference":"에베소서 4:2","category":"$undefined"},{"id":"29276","book":"에베소서","book_name":"에베소서","chapter":4,"verse":3,"text":"평안의 매는 줄로 성령의 하나되게 하신 것을 힘써 지키라","reference":"에베소서 4:3","category":"$undefined"},{"id":"29277","book":"에베소서","book_name":"에베소서","chapter":4,"verse":4,"text":"몸이 하나이요, 성령이 하나이니 이와 같이 너희가 부르심의 한 소망 안에서 부르심을 입었느니라","reference":"에베소서 4:4","category":"$undefined"},{"id":"29278","book":"에베소서","book_name":"에베소서","chapter":4,"verse":5,"text":"주도 하나이요, 믿음도 하나이요, 세례도 하나이요,","reference":"에베소서 4:5","category":"$undefined"},{"id":"29279","book":"에베소서","book_name":"에베소서","chapter":4,"verse":6,"text":"하나님도 하나이시니 곧 만유의 아버지시라 만유 위에 계시고 만유를 통일하시고 만유 가운데 계시도다","reference":"에베소서 4:6","category":"$undefined"},{"id":"29280","book":"에베소서","book_name":"에베소서","chapter":4,"verse":7,"text":"우리 각 사람에게 그리스도의 선물의 분량대로 은혜를 주셨나니","reference":"에베소서 4:7","category":"$undefined"},{"id":"29281","book":"에베소서","book_name":"에베소서","chapter":4,"verse":8,"text":"그러므로 이르기를 그가 위로 올라가실 때에 사로잡힌 자를 사로 잡고 사람들에게 선물을 주셨다 하였도다","reference":"에베소서 4:8","category":"$undefined"},{"id":"29282","book":"에베소서","book_name":"에베소서","chapter":4,"verse":9,"text":"올라가셨다 하였은즉 땅 아랫 곳으로 내리셨던 것이 아니면 무엇이냐","reference":"에베소서 4:9","category":"$undefined"},{"id":"29283","book":"에베소서","book_name":"에베소서","chapter":4,"verse":10,"text":"내리셨던 그가 곧 모든 하늘 위에 오르신 자니 이는 만물을 충만케 하려 하심이니라","reference":"에베소서 4:10","category":"$undefined"},{"id":"29284","book":"에베소서","book_name":"에베소서","chapter":4,"verse":11,"text":"그가 혹은 사도로, 혹은 선지자로, 혹은 복음 전하는 자로, 혹은 목사와 교사로 주셨으니","reference":"에베소서 4:11","category":"$undefined"},{"id":"29285","book":"에베소서","book_name":"에베소서","chapter":4,"verse":12,"text":"이는 성도를 온전케 하며 봉사의 일을 하게 하며 그리스도의 몸을 세우려 하심이라","reference":"에베소서 4:12","category":"$undefined"},{"id":"29286","book":"에베소서","book_name":"에베소서","chapter":4,"verse":13,"text":"우리가 다 하나님의 아들을 믿는 것과 아는 일에 하나가 되어 온전한 사람을 이루어 그리스도의 장성한 분량이 충만한 데까지 이르리니","reference":"에베소서 4:13","category":"$undefined"},{"id":"29287","book":"에베소서","book_name":"에베소서","chapter":4,"verse":14,"text":"이는 우리가 이제부터 어린 아이가 되지 아니하여 사람의 궤술과 간사한 유혹에 빠져 모든 교훈의 풍조에 밀려 요동치 않게 하려 함이라","reference":"에베소서 4:14","category":"$undefined"},{"id":"29288","book":"에베소서","book_name":"에베소서","chapter":4,"verse":15,"text":"오직 사랑 안에서 참된 것을 하여 범사에 그에게까지 자랄지라 그는 머리니 곧 그리스도라","reference":"에베소서 4:15","category":"$undefined"},{"id":"29289","book":"에베소서","book_name":"에베소서","chapter":4,"verse":16,"text":"그에게서 온 몸이 각 마디를 통하여 도움을 입음으로 연락하고 상합하여 각 지체의 분량대로 역사하여 그 몸을 자라게 하며 사랑 안에서 스스로 세우느니라","reference":"에베소서 4:16","category":"$undefined"},{"id":"29290","book":"에베소서","book_name":"에베소서","chapter":4,"verse":17,"text":"그러므로 내가 이것을 말하며 주 안에서 증거하노니 이제부터는 이방인이 그 마음의 허망한 것으로 행함같이 너희는 행하지 말라","reference":"에베소서 4:17","category":"$undefined"},{"id":"29291","book":"에베소서","book_name":"에베소서","chapter":4,"verse":18,"text":"저희 총명이 어두워지고 저희 가운데 있는 무지함과 저희 마음이 굳어짐으로 말미암아 하나님의 생명에서 떠나 있도다","reference":"에베소서 4:18","category":"$undefined"},{"id":"29292","book":"에베소서","book_name":"에베소서","chapter":4,"verse":19,"text":"저희가 감각 없는 자 되어 자신을 방탕에 방임하여 모든 더러운 것을 욕심으로 행하되","reference":"에베소서 4:19","category":"$undefined"},{"id":"29293","book":"에베소서","book_name":"에베소서","chapter":4,"verse":20,"text":"오직 너희는 그리스도를 이같이 배우지 아니하였느니라","reference":"에베소서 4:20","category":"$undefined"},{"id":"29294","book":"에베소서","book_name":"에베소서","chapter":4,"verse":21,"text":"진리가 예수 안에 있는 것같이 너희가 과연 그에게서 듣고 또한 그 안에서 가르침을 받았을진대","reference":"에베소서 4:21","category":"$undefined"},{"id":"29295","book":"에베소서","book_name":"에베소서","chapter":4,"verse":22,"text":"너희는 유혹의 욕심을 따라 썩어져 가는 구습을 좇는 옛 사람을 벗어버리고","reference":"에베소서 4:22","category":"$undefined"},{"id":"29296","book":"에베소서","book_name":"에베소서","chapter":4,"verse":23,"text":"오직 심령으로 새롭게 되어","reference":"에베소서 4:23","category":"$undefined"},{"id":"29297","book":"에베소서","book_name":"에베소서","chapter":4,"verse":24,"text":"하나님을 따라 의와 진리의 거룩함으로 지으심을 받은 새 사람을 입으라","reference":"에베소서 4:24","category":"$undefined"},{"id":"29298","book":"에베소서","book_name":"에베소서","chapter":4,"verse":25,"text":"그런즉 거짓을 버리고 각각 그 이웃으로 더불어 참된 것을 말하라 이는 우리가 서로 지체가 됨이니라","reference":"에베소서 4:25","category":"$undefined"},{"id":"29299","book":"에베소서","book_name":"에베소서","chapter":4,"verse":26,"text":"분을 내어도 죄를 짓지 말며 해가 지도록 분을 품지 말고","reference":"에베소서 4:26","category":"$undefined"},{"id":"29300","book":"에베소서","book_name":"에베소서","chapter":4,"verse":27,"text":"마귀로 틈을 타지 못하게 하라 !","reference":"에베소서 4:27","category":"$undefined"},{"id":"29301","book":"에베소서","book_name":"에베소서","chapter":4,"verse":28,"text":"도적질하는 자는 다시 도적질 하지 말고 돌이켜 빈궁한 자에게 구제할 것이 있기 위하여 제 손으로 수고하여 선한 일을 하라","reference":"에베소서 4:28","category":"$undefined"},{"id":"29302","book":"에베소서","book_name":"에베소서","chapter":4,"verse":29,"text":"무릇 더러운 말은 너희 입 밖에도 내지 말고 오직 덕을 세우는 데 소용되는 대로 선한 말을 하여 듣는 자들에게 은혜를 끼치게 하라","reference":"에베소서 4:29","category":"$undefined"},{"id":"29303","book":"에베소서","book_name":"에베소서","chapter":4,"verse":30,"text":"하나님의 성령을 근심하게 하지 말라 그 안에서 너희가 구속의 날까지 인치심을 받았느니라","reference":"에베소서 4:30","category":"$undefined"},{"id":"29304","book":"에베소서","book_name":"에베소서","chapter":4,"verse":31,"text":"너희는 모든 악독과, 노함과, 분냄과, 떠드는 것과, 훼방하는 것을 모든 악의와 함께 버리고","reference":"에베소서 4:31","category":"$undefined"},{"id":"29305","book":"에베소서","book_name":"에베소서","chapter":4,"verse":32,"text":"서로 인자하게 하며 불쌍히 여기며 서로 용서하기를 하나님이 그리스도 안에서 너희를 용서하심과 같이 하라","reference":"에베소서 4:32","category":"$undefined"}],"bookSlug":"ephesians"}]
