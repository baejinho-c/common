2:["$","$L11",null,{"book":{"id":"ephesians","name":"에베소서","chapters":6,"testament":"new"},"chapter":5,"verses":[{"id":"29306","book":"에베소서","book_name":"에베소서","chapter":5,"verse":1,"text":"그러므로 사랑을 입은 자녀같이 너희는 하나님을 본받는 자가 되고","reference":"에베소서 5:1","category":"$undefined"},{"id":"29307","book":"에베소서","book_name":"에베소서","chapter":5,"verse":2,"text":"그리스도께서 너희를 사랑하신 것같이 너희도 사랑 가운데서 행하라 그는 우리를 위하여 자신을 버리사 향기로운 제물과 생축으로 하나님께 드리셨느니라","reference":"에베소서 5:2","category":"$undefined"},{"id":"29308","book":"에베소서","book_name":"에베소서","chapter":5,"verse":3,"text":"음행과 온갖 더러운 것과 탐욕은 너희 중에서 그 이름이라도 부르지 말라 이는 성도의 마땅한 바니라","reference":"에베소서 5:3","category":"$undefined"},{"id":"29309","book":"에베소서","book_name":"에베소서","chapter":5,"verse":4,"text":"누추함과 어리석은 말이나 희롱의 말이 마땅치 아니하니 돌이켜 감사하는 말을 하라","reference":"에베소서 5:4","category":"$undefined"},{"id":"29310","book":"에베소서","book_name":"에베소서","chapter":5,"verse":5,"text":"너희도 이것을 정녕히 알거니와 음행하는 자나 더러운 자나 탐하는 자 곧 우상 숭배자는 다 그리스도와 하나님 나라에서 기업을 얻지 못하리니","reference":"에베소서 5:5","category":"$undefined"},{"id":"29311","book":"에베소서","book_name":"에베소서","chapter":5,"verse":6,"text":"누구든지 헛된 말로 너희를 속이지 못하게 하라 이를 인하여 하나님의 진노가 불순종의 아들들에게 임하나니","reference":"에베소서 5:6","category":"$undefined"},{"id":"29312","book":"에베소서","book_name":"에베소서","chapter":5,"verse":7,"text":"그러므로 저희와 함께 참예하는 자 되지 말라","reference":"에베소서 5:7","category":"$undefined"},{"id":"29313","book":"에베소서","book_name":"에베소서","chapter":5,"verse":8,"text":"너희가 전에는 어두움이더니 이제는 주 안에서 빛이라 빛의 자녀들처럼 행하라","reference":"에베소서 5:8","category":"$undefined"},{"id":"29314","book":"에베소서","book_name":"에베소서","chapter":5,"verse":9,"text":"빛의 열매는 모든 착함과, 의로움과, 진실함에 있느니라","reference":"에베소서 5:9","category":"$undefined"},{"id":"29315","book":"에베소서","book_name":"에베소서","chapter":5,"verse":10,"text":"주께 기쁘시게 할 것이 무엇인가 시험하여 보라","reference":"에베소서 5:10","category":"$undefined"},{"id":"29316","book":"에베소서","book_name":"에베소서","chapter":5,"verse":11,"text":"너희는 열매 없는 어두움의 일에 참예하지 말고 도리어 책망하라","reference":"에베소서 5:11","category":"$undefined"},{"id":"29317","book":"에베소서","book_name":"에베소서","chapter":5,"verse":12,"text":"저희의 은밀히 행하는 것들은 말하기도 부끄러움이라","reference":"에베소서 5:12","category":"$undefined"},{"id":"29318","book":"에베소서","book_name":"에베소서","chapter":5,"verse":13,"text":"그러나 책망을 받는 모든 것이 빛으로 나타나나니 나타나지는 것마다 빛이니라","reference":"에베소서 5:13","category":"$undefined"},{"id":"29319","book":"에베소서","book_name":"에베소서","chapter":5,"verse":14,"text":"그러므로 이르시기를 잠 자는 자여 ! 깨어서 죽은 자들 가운데서 일어나라 그리스도께서 네게 비취시리라 하셨느니라","reference":"에베소서 5:14","category":"$undefined"},{"id":"29320","book":"에베소서","book_name":"에베소서","chapter":5,"verse":15,"text":"그런즉 너희가 어떻게 행할 것을 자세히 주의하여 지혜 없는 자같이 말고 오직 지혜 있는 자같이 하여","reference":"에베소서 5:15","category":"$undefined"},{"id":"29321","book":"에베소서","book_name":"에베소서","chapter":5,"verse":16,"text":"세월을 아끼라 ! 때가 악하니라 !","reference":"에베소서 5:16","category":"$undefined"},{"id":"29322","book":"에베소서","book_name":"에베소서","chapter":5,"verse":17,"text":"그러므로 어리석은 자가 되지 말고 오직 주의 뜻이 무엇인가 이해하라","reference":"에베소서 5:17","category":"$undefined"},{"id":"29323","book":"에베소서","book_name":"에베소서","chapter":5,"verse":18,"text":"술 취하지 말라 이는 방탕한 것이니 오직 성령의 충만을 받으라 !","reference":"에베소서 5:18","category":"$undefined"},{"id":"29324","book":"에베소서","book_name":"에베소서","chapter":5,"verse":19,"text":"시와 찬미와 신령한 노래들로 서로 화답하며 너희의 마음으로 주께 노래하며 찬송하며","reference":"에베소서 5:19","category":"$undefined"},{"id":"29325","book":"에베소서","book_name":"에베소서","chapter":5,"verse":20,"text":"범사에 우리 주 예수 그리스도의 이름으로 항상 아버지 하나님께 감사하며","reference":"에베소서 5:20","category":"$undefined"},{"id":"29326","book":"에베소서","book_name":"에베소서","chapter":5,"verse":21,"text":"그리스도를 경외함으로 피차 복종하라","reference":"에베소서 5:21","category":"$undefined"},{"id":"29327","book":"에베소서","book_name":"에베소서","chapter":5,"verse":22,"text":"아내들이여 ! 자기 남편에게 복종하기를 주께 하듯 하라","reference":"에베소서 5:22","category":"$undefined"},{"id":"29328","book":"에베소서","book_name":"에베소서","chapter":5,"verse":23,"text":"이는 남편이 아내의 머리 됨이 그리스도께서 교회의 머리 됨과 같음이니 그가 친히 몸의 구주시니라","reference":"에베소서 5:23","category":"$undefined"},{"id":"29329","book":"에베소서","book_name":"에베소서","chapter":5,"verse":24,"text":"그러나 교회가 그리스도에게 하듯 아내들도 범사에 그 남편에게 복종할지니라","reference":"에베소서 5:24","category":"$undefined"},{"id":"29330","book":"에베소서","book_name":"에베소서","chapter":5,"verse":25,"text":"남편들아 ! 아내 사랑하기를 그리스도께서 교회를 사랑하시고 위하여 자신을 주심같이 하라","reference":"에베소서 5:25","category":"$undefined"},{"id":"29331","book":"에베소서","book_name":"에베소서","chapter":5,"verse":26,"text":"이는 곧 물로 씻어 말씀으로 깨끗하게 하사 거룩하게 하시고","reference":"에베소서 5:26","category":"$undefined"},{"id":"29332","book":"에베소서","book_name":"에베소서","chapter":5,"verse":27,"text":"자기 앞에 영광스러운 교회로 세우사 티나 주름잡힌 것이나 이런 것들이 없이 거룩하고 흠이 없게 하려 하심이니라","reference":"에베소서 5:27","category":"$undefined"},{"id":"29333","book":"에베소서","book_name":"에베소서","chapter":5,"verse":28,"text":"이와 같이 남편들도 자기 아내 사랑하기를 제 몸같이 할지니 자기 아내를 사랑하는 자는 자기를 사랑하는 것이라","reference":"에베소서 5:28","category":"$undefined"},{"id":"29334","book":"에베소서","book_name":"에베소서","chapter":5,"verse":29,"text":"누구든지 언제든지 제 육체를 미워하지 않고 오직 양육하여 보호하기를 그리스도께서 교회를 보양(保養)함과 같이 하나니","reference":"에베소서 5:29","category":"$undefined"},{"id":"29335","book":"에베소서","book_name":"에베소서","chapter":5,"verse":30,"text":"우리는 그 몸의 지체임이니라","reference":"에베소서 5:30","category":"$undefined"},{"id":"29336","book":"에베소서","book_name":"에베소서","chapter":5,"verse":31,"text":"이러므로 사람이 부모를 떠나 그 아내와 합하여 그 둘이 한 육체가 될지니","reference":"에베소서 5:31","category":"$undefined"},{"id":"29337","book":"에베소서","book_name":"에베소서","chapter":5,"verse":32,"text":"이 비밀이 크도다 ! 내가 그리스도와 교회에 대하여 말하노라","reference":"에베소서 5:32","category":"$undefined"},{"id":"29338","book":"에베소서","book_name":"에베소서","chapter":5,"verse":33,"text":"그러나 너희도 각각 자기의 아내 사랑하기를 자기같이 하고 아내도 그 남편을 경외하라","reference":"에베소서 5:33","category":"$undefined"}],"bookSlug":"ephesians"}]
