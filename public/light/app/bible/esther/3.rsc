2:["$","$L11",null,{"book":{"id":"esther","name":"에스더","chapters":10,"testament":"old"},"chapter":3,"verses":[{"id":"12749","book":"에스더","book_name":"에스더","chapter":3,"verse":1,"text":"그 후에 아하수에로왕이 아각 사람 함므다다의 아들 하만의 지위를 높이 올려 모든 함께 있는 대신 위에 두니","reference":"에스더 3:1","category":"$undefined"},{"id":"12750","book":"에스더","book_name":"에스더","chapter":3,"verse":2,"text":"대궐 문에 있는 왕의 모든 신복이 다 왕의 명대로 하만에게 꿇어 절하되 모르드개는 꿇지도 아니하고 절하지도 아니하니","reference":"에스더 3:2","category":"$undefined"},{"id":"12751","book":"에스더","book_name":"에스더","chapter":3,"verse":3,"text":"대궐 문에 있는 왕의 신복이 모르드개에게 이르되 `너는 어찌하여 왕의 명령을 거역하느냐 ?' 하고","reference":"에스더 3:3","category":"$undefined"},{"id":"12752","book":"에스더","book_name":"에스더","chapter":3,"verse":4,"text":"날마다 권하되 모르드개가 듣지 아니하고 자기는 유다인임을 고하였더니 저희가 모르드개의 일이 어찌되나 보고자 하여 하만에게 고하였더라","reference":"에스더 3:4","category":"$undefined"},{"id":"12753","book":"에스더","book_name":"에스더","chapter":3,"verse":5,"text":"하만이 모르드개가 꿇지도 아니하고 절하지도 아니함을 보고 심히 노하더니","reference":"에스더 3:5","category":"$undefined"},{"id":"12754","book":"에스더","book_name":"에스더","chapter":3,"verse":6,"text":"저희가 모르드개의 민족을 하만에게 고한고로 하만이 `모르드개만 죽이는 것이 경하다' 하고 아하수에로의 온 나라에 있는 유다인 곧 모르드개의 민족을 다 멸하고자 하더라","reference":"에스더 3:6","category":"$undefined"},{"id":"12755","book":"에스더","book_name":"에스더","chapter":3,"verse":7,"text":"아하수에로왕 십 이년 정월 곧 니산월에 무리가 하만 앞에서 날과 달에 대하여 부르 곧 제비를 뽑아 십이월 곧 아달월을 얻은지라","reference":"에스더 3:7","category":"$undefined"},{"id":"12756","book":"에스더","book_name":"에스더","chapter":3,"verse":8,"text":"하만이 아하수에로 왕에게 아뢰되 `한 민족이 왕의 나라 각 도 백성 중에 흩어져 거하는데 그 법률이 만민보다 달라서 왕의 법률을 지키지 아니하오니 용납하는 것이 왕에게 무익하나이다","reference":"에스더 3:8","category":"$undefined"},{"id":"12757","book":"에스더","book_name":"에스더","chapter":3,"verse":9,"text":"왕이 옳게 여기시거든 조서를 내려 저희를 진멸하소서 내가 은 일만 달란트를 왕의 일을 맡은 자의 손에 붙여 왕의 부고에 드리리이다'","reference":"에스더 3:9","category":"$undefined"},{"id":"12758","book":"에스더","book_name":"에스더","chapter":3,"verse":10,"text":"왕이 반지를 손에서 빼어 유다인의 대적 곧 아각 사람 함므다다의 아들 하만에게 주며","reference":"에스더 3:10","category":"$undefined"},{"id":"12759","book":"에스더","book_name":"에스더","chapter":3,"verse":11,"text":"이르되 `그 은을 네게 주고 그 백성도 그리하노니 너는 소견에 좋을대로 행하라' 하더라","reference":"에스더 3:11","category":"$undefined"},{"id":"12760","book":"에스더","book_name":"에스더","chapter":3,"verse":12,"text":"정월 십 삼일에 왕의 서기관이 소집되어 하만의 명을 따라 왕의 대신과 각 도 방백과 각 민족의 관원에게 아하수에로 왕의 이름으로 조서를 쓰되 곧 각 도의 문자와 각 민족의 방언대로 쓰고 왕의 반지로 인치니라","reference":"에스더 3:12","category":"$undefined"},{"id":"12761","book":"에스더","book_name":"에스더","chapter":3,"verse":13,"text":"이에 그 조서를 역졸에게 부쳐 왕의 각 도에 보내니 십이월 곧 아달월 십 삼일 하루 동안에 모든 유다인을 노소나 어린 아이나 부녀를 무론하고 죽이고 도륙하고 진멸하고 또 그 재산을 탈취하라 하였고","reference":"에스더 3:13","category":"$undefined"},{"id":"12762","book":"에스더","book_name":"에스더","chapter":3,"verse":14,"text":"이 명령을 각 도에 전하기 위하여 조서의 초본을 모든 민족에게 선포하여 그 날을 위하여 준비하게 하라 하였더라","reference":"에스더 3:14","category":"$undefined"},{"id":"12763","book":"에스더","book_name":"에스더","chapter":3,"verse":15,"text":"역졸이 왕의 명을 받들어 급히 나가매 그 조서가 도성 수산에도 반포되니 왕은 하만과 함께 앉아 마시되 수산성은 어지럽더라","reference":"에스더 3:15","category":"$undefined"}],"bookSlug":"esther"}]
