2:["$","$L11",null,{"book":{"id":"esther","name":"에스더","chapters":10,"testament":"old"},"chapter":9,"verses":[{"id":"12836","book":"에스더","book_name":"에스더","chapter":9,"verse":1,"text":"아달월 곧 십이월 십 삼일은 왕의 조명을 행하게 된 날이라 유다인의 대적이 저희를 제어하기를 바랐더니 유다인이 도리어 자기를 미워하는 자를 제어하게 된 그 날에","reference":"에스더 9:1","category":"$undefined"},{"id":"12837","book":"에스더","book_name":"에스더","chapter":9,"verse":2,"text":"유다인들이 아하수에로왕의 각 도, 각 읍에 모여 자기를 해하고자 하는 자를 죽이려 하니 모든 민족이 저희를 두려워 하여 능히 막을 자가 없고","reference":"에스더 9:2","category":"$undefined"},{"id":"12838","book":"에스더","book_name":"에스더","chapter":9,"verse":3,"text":"각 도 모든 관원과 대신과 방백과 왕의 사무를 보는 자들이 모르드개를 두려워하므로 다 유다인을 도우니","reference":"에스더 9:3","category":"$undefined"},{"id":"12839","book":"에스더","book_name":"에스더","chapter":9,"verse":4,"text":"모르드개가 왕궁에서 존귀하여 점점 창대하매 이 사람 모르드개의 명성이 각 도에 퍼지더라","reference":"에스더 9:4","category":"$undefined"},{"id":"12840","book":"에스더","book_name":"에스더","chapter":9,"verse":5,"text":"유다인이 칼로 그 모든 대적을 쳐서 도륙하고 진멸하고 자기를 미워하는 자에게 마음대로 행하고","reference":"에스더 9:5","category":"$undefined"},{"id":"12841","book":"에스더","book_name":"에스더","chapter":9,"verse":6,"text":"유다인이 또 도성 수산에서 오백인을 죽이고 멸하고","reference":"에스더 9:6","category":"$undefined"},{"id":"12842","book":"에스더","book_name":"에스더","chapter":9,"verse":7,"text":"또 바산다다와, 달본과, 아스바다와","reference":"에스더 9:7","category":"$undefined"},{"id":"12843","book":"에스더","book_name":"에스더","chapter":9,"verse":8,"text":"보라다와, 아달리야와, 아리다다와","reference":"에스더 9:8","category":"$undefined"},{"id":"12844","book":"에스더","book_name":"에스더","chapter":9,"verse":9,"text":"바마스다와, 아리새와, 아리대와, 왜사다","reference":"에스더 9:9","category":"$undefined"},{"id":"12845","book":"에스더","book_name":"에스더","chapter":9,"verse":10,"text":"곧 함므다다의 손자요, 유다인의 대적 하만의 열 아들을 죽였으나 그 재산에는 손을 대지 아니하였더라","reference":"에스더 9:10","category":"$undefined"},{"id":"12846","book":"에스더","book_name":"에스더","chapter":9,"verse":11,"text":"그 날에 도성 수산에서 도륙한자의 수효를 왕께 고하니","reference":"에스더 9:11","category":"$undefined"},{"id":"12847","book":"에스더","book_name":"에스더","chapter":9,"verse":12,"text":"왕이 왕후 에스더에게 이르되 `유다인이 도성 수산에서 이미 오백인을 죽이고 멸하고 또 하만의 열 아들을 죽였으니 왕의 다른 도에서는 어떠하였겠느뇨 이제 그대의 소청이 무엇이뇨 곧 허락하겠노라 그대의 요구가 무엇이뇨 또한 시행하겠노라'","reference":"에스더 9:12","category":"$undefined"},{"id":"12848","book":"에스더","book_name":"에스더","chapter":9,"verse":13,"text":"에스더가 가로되 `왕이 만일 선히 여기시거든 수산에 거하는 유다인으로 내일도 오늘날 조서대로 행하게 하시고 하만의 열 아들의 시체를 나무에 달게 하소서'","reference":"에스더 9:13","category":"$undefined"},{"id":"12849","book":"에스더","book_name":"에스더","chapter":9,"verse":14,"text":"왕이 그대로 행하기를 허락하고 조서를 내리니 하만의 열 아들의 시체가 달리니라","reference":"에스더 9:14","category":"$undefined"},{"id":"12850","book":"에스더","book_name":"에스더","chapter":9,"verse":15,"text":"아달월 십 사일에도 수산에 있는 유다인이 모여 또 삼백인을 수산에서 도륙하되 그 재산에는 손을 대지 아니하였고","reference":"에스더 9:15","category":"$undefined"},{"id":"12851","book":"에스더","book_name":"에스더","chapter":9,"verse":16,"text":"왕의 각 도에 있는 다른 유다인들이 모여 스스로 생명을 보호하여 대적들에게서 벗어나며 자기를 미워하는 자 칠만 오천인을 도륙하되 그 재산에는 손을 대지 아니하였더라","reference":"에스더 9:16","category":"$undefined"},{"id":"12852","book":"에스더","book_name":"에스더","chapter":9,"verse":17,"text":"아달월 십 삼일에 그 일을 행하였고 십 사일에 쉬며 그 날에 잔치를 베풀어 즐겼고","reference":"에스더 9:17","category":"$undefined"},{"id":"12853","book":"에스더","book_name":"에스더","chapter":9,"verse":18,"text":"수산에 거한 유다인은 십 삼일과 십 사일에 모였고 십 오일에 쉬며 이 날에 잔치를 베풀어 즐긴지라","reference":"에스더 9:18","category":"$undefined"},{"id":"12854","book":"에스더","book_name":"에스더","chapter":9,"verse":19,"text":"그러므로 촌촌의 유다인 곧 성이 없는 고을 고을에 거하는 자들이 아달월 십사일로 경절을 삼아 잔치를 베풀고 즐기며 서로 예물을 주더라","reference":"에스더 9:19","category":"$undefined"},{"id":"12855","book":"에스더","book_name":"에스더","chapter":9,"verse":20,"text":"모르드개가 이 일을 기록하고 아하수에로왕의 각 도에 있는 모든 유다인에게 무론 원근하고 글을 보내어 이르기를","reference":"에스더 9:20","category":"$undefined"},{"id":"12856","book":"에스더","book_name":"에스더","chapter":9,"verse":21,"text":"`한 규례를 세워 해마다 아달월 십 사일과 십 오일을 지키라","reference":"에스더 9:21","category":"$undefined"},{"id":"12857","book":"에스더","book_name":"에스더","chapter":9,"verse":22,"text":"이 달 이 날에 유다인이 대적에게서 벗어나서 평안함을 얻어 슬픔이 변하여 기쁨이 되고 애통이 변하여 길한 날이 되었으니 이 두 날을 지켜 잔치를 베풀고 즐기며 서로 예물을 주며 가난한 자를 구제하라' 하매","reference":"에스더 9:22","category":"$undefined"},{"id":"12858","book":"에스더","book_name":"에스더","chapter":9,"verse":23,"text":"유다인이 자기들의 이미 시작한대로 또는 모르드개의 보낸 글대로 계속하여 행하였으니","reference":"에스더 9:23","category":"$undefined"},{"id":"12859","book":"에스더","book_name":"에스더","chapter":9,"verse":24,"text":"곧 아각 사람 함므다다의 아들 모든 유다인의 대적 하만이 유다인을 진멸하기를 꾀하고 부르 곧 제비를 뽑아 저희를 죽이고 멸하려 하였으나","reference":"에스더 9:24","category":"$undefined"},{"id":"12860","book":"에스더","book_name":"에스더","chapter":9,"verse":25,"text":"에스더가 왕의 앞에 나아감을 인하여 왕이 조서를 내려 하만이 유다인을 해하려던 악한 꾀를 그 머리에 돌려 보내어 하만과 그 여러 아들을 나무에 달게 하였으므로","reference":"에스더 9:25","category":"$undefined"},{"id":"12861","book":"에스더","book_name":"에스더","chapter":9,"verse":26,"text":"무리가 부르의 이름을 좇아 이 두 날을 부림이라 하고 유다인이 이 글의 모든 말과 이 일에 보고 당한 것을 인하여","reference":"에스더 9:26","category":"$undefined"},{"id":"12862","book":"에스더","book_name":"에스더","chapter":9,"verse":27,"text":"뜻을 정하고 자기와 자손과 자기와 화합한 자들이 해마다 그 기록한 정기에 이 두 날을 연하여 지켜 폐하지 아니하기로 작정하고","reference":"에스더 9:27","category":"$undefined"},{"id":"12863","book":"에스더","book_name":"에스더","chapter":9,"verse":28,"text":"각 도, 각 읍, 각 집에서 대대로 이 두 날을 기념하여 지키되 이 부림일을 유다인 중에서 폐하지 않게 하고 그 자손 중에서도 기념함이 폐하지 않게 하였더라","reference":"에스더 9:28","category":"$undefined"},{"id":"12864","book":"에스더","book_name":"에스더","chapter":9,"verse":29,"text":"아비하일의 딸 왕후 에스더와 유다인 모르드개가 전권으로 글을 쓰고 부림에 대한 이 둘째 편지를 굳이 지키게 하되","reference":"에스더 9:29","category":"$undefined"},{"id":"12865","book":"에스더","book_name":"에스더","chapter":9,"verse":30,"text":"화평하고 진실한 말로 편지를 써서 아하수에로의 나라 일백 이십 칠도에 있는 유다 모든 사람에게 보내어","reference":"에스더 9:30","category":"$undefined"},{"id":"12866","book":"에스더","book_name":"에스더","chapter":9,"verse":31,"text":"정한 기한에 이 부림일을 지키게 하였으니 이는 유다인 모르드개와 왕후 에스더의 명한 바와 유다인이 금식하며 부르짖은 것을 인하여 자기와 자기 자손을 위하여 정한 바가 있음이더라","reference":"에스더 9:31","category":"$undefined"},{"id":"12867","book":"에스더","book_name":"에스더","chapter":9,"verse":32,"text":"에스더의 명령이 이 부림에 대한 일을 견고히 하였고 그 일이 책에 기록되었더라","reference":"에스더 9:32","category":"$undefined"}],"bookSlug":"esther"}]
