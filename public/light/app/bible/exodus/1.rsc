2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":1,"verses":[{"id":"1534","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":1,"text":"야곱과 함께 각기 권속을 데리고 애굽에 이른 이스라엘 아들들의 이름은 이러하니","reference":"출애굽기 1:1","category":"$undefined"},{"id":"1535","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":2,"text":"르우벤과, 시므온과, 레위와, 유다와","reference":"출애굽기 1:2","category":"$undefined"},{"id":"1536","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":3,"text":"잇사갈과, 스불론과, 베냐민과","reference":"출애굽기 1:3","category":"$undefined"},{"id":"1537","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":4,"text":"단과, 납달리와, 갓과, 아셀이요","reference":"출애굽기 1:4","category":"$undefined"},{"id":"1538","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":5,"text":"이미 애굽에 있는 요셉까지 야곱의 혈속이 모두 칠십인이었더라","reference":"출애굽기 1:5","category":"$undefined"},{"id":"1539","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":6,"text":"요셉과 그의 모든 형제와 그 시대 사람은 다 죽었고","reference":"출애굽기 1:6","category":"$undefined"},{"id":"1540","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":7,"text":"이스라엘 자손은 생육이 중다하고 번식하고 창성하고 심히 강대하여 온 땅에 가득하게 되었더라","reference":"출애굽기 1:7","category":"$undefined"},{"id":"1541","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":8,"text":"그가 그 신민에게 이르되 `이 백성 이스라엘 자손이 우리보다 많고 강하도다","reference":"출애굽기 1:8","category":"$undefined"},{"id":"1542","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":9,"text":"자, 우리가 그들에게 대하여 지혜롭게 하자 두렵건대 그들이 더 많게 되면 전쟁이 일어날 때에 우리 대적과 합하여 우리와 싸우고 이 땅에서 갈까 하노라' 하고","reference":"출애굽기 1:9","category":"$undefined"},{"id":"1543","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":10,"text":"감독들을 그들 위에 세우고 그들에게 무거운 짐을 지워 괴롭게 하여 그들로 바로를 위하여 국고성 비돔과 라암셋을 건축하게 하니라","reference":"출애굽기 1:10","category":"$undefined"},{"id":"1544","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":11,"text":"그러나 학대를 받을수록 더욱 번식하고 창성하니 애굽 사람이 이스라엘 자손을 인하여 근심하여","reference":"출애굽기 1:11","category":"$undefined"},{"id":"1545","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":12,"text":"이스라엘 자손의 역사를 엄하게 하여","reference":"출애굽기 1:12","category":"$undefined"},{"id":"1546","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":13,"text":"고역으로 그들의 생활을 괴롭게 하니 곧 흙 이기기와 벽돌 굽기와 농사의 여러가지 일이라 그 시키는 역사가 다 엄하였더라","reference":"출애굽기 1:13","category":"$undefined"},{"id":"1547","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":14,"text":"애굽 왕이 히브리 산파 십브라라 하는 자와 부아라 하는 자에게 일러","reference":"출애굽기 1:14","category":"$undefined"},{"id":"1548","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":15,"text":"가로되 `너희는 히브리 여인을 위하여 조산할 때에 살펴서 남자여든 죽이고 여자여든 그는 살게 두라'","reference":"출애굽기 1:15","category":"$undefined"},{"id":"1549","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":16,"text":"그러나 산파들이 하나님을 두려워하여 애굽 왕의 명을 어기고 남자를 살린지라","reference":"출애굽기 1:16","category":"$undefined"},{"id":"1550","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":17,"text":"애굽 왕이 산파를 불러서 그들에게 이르되 `너희가 어찌 이같이 하여 남자를 살렸느냐 ?'","reference":"출애굽기 1:17","category":"$undefined"},{"id":"1551","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":18,"text":"산파가 바로에게 대답하되 `히브리 여인은 애굽 여인과 같지 아니하고 건장하여 산파가 그들에게 이르기 전에 해산하였더이다' 하매","reference":"출애굽기 1:18","category":"$undefined"},{"id":"1552","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":19,"text":"하나님이 그 산파들에게 은혜를 베푸시니라 백성은 생육이 번성하고 심히 강대하며","reference":"출애굽기 1:19","category":"$undefined"},{"id":"1553","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":20,"text":"산파는 하나님을 경외하였으므로 하나님이 그들의 집을 왕성케 하신지라","reference":"출애굽기 1:20","category":"$undefined"},{"id":"1554","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":21,"text":"그러므로 바로가 그 모든 신민에게 명하여 가로되 `남자가 나거든 너희는 그를 하수에 던지고 여자여든 살리라' 하였더라","reference":"출애굽기 1:21","category":"$undefined"},{"id":"1555","book":"출애굽기","book_name":"출애굽기","chapter":1,"verse":22,"text":"","reference":"출애굽기 1:22","category":"$undefined"}],"bookSlug":"exodus"}]
