11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":10,"verses":[{"id":"1779","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":1,"text":"여호와께서 모세에게 이르시되 바로에게로 들어가라 내가 그의 마음과 그 신하들의 마음을 완강케 함은 나의 표징을 그들 중에 보이기 위함이며","reference":"출애굽기 10:1","category":"$undefined"},{"id":"1780","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":2,"text":"너로 내가 애굽에서 행한 일들 곧 내가 그 가운데서 행한 표징을 네 아들과 네 자손의 귀에 전하게 하려 함이라 너희가 나를 여호와인줄 알리라","reference":"출애굽기 10:2","category":"$undefined"},{"id":"1781","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":3,"text":"모세와 아론이 바로에게 들어가서 그에게 이르되 `히브리 사람의 하나님 여호와께서 말씀하시기를 네가 어느 때까지 내 앞에 겸비치 아니하겠느냐 ? 내 백성을 보내라 ! 그들이 나를 섬길 것이라","reference":"출애굽기 10:3","category":"$undefined"},{"id":"1782","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":4,"text":"네가 만일 내 백성 보내기를 거절하면 내일 내가 메뚜기로 네 경내에 들어가게 하리니","reference":"출애굽기 10:4","category":"$undefined"},{"id":"1783","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":5,"text":"메뚜기가 지면을 덮어서 사람이 땅을 볼 수 없을 것이라 메뚜기가 네게 남은 그것 곧 우박을 면하고 남은 것을 먹으며 들에 너를 위하여 자라는 모든 나무를 먹을 것이며","reference":"출애굽기 10:5","category":"$undefined"},{"id":"1784","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":6,"text":"또 네 집들과 네 모든 신하의 집들과 모든 애굽 사람의 집들에 가득하리니 이는 네 아비와 네 조상이 세상에 있어 옴으로 오늘까지 보지 못하였던 것이리라 하셨다' 하고 돌이켜 바로에게서 나오니","reference":"출애굽기 10:6","category":"$undefined"},{"id":"1785","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":7,"text":"바로의 신하들이 그에게 고하되 `어느 때까지 이 사람이 우리의 함정이 되리이까 ? 그 사람들을 보내어 그 하나님 여호와를 섬기게 하소서 ! 왕은 아직도 애굽이 망한 줄을 알지 못하시나이까 ?' 하고","reference":"출애굽기 10:7","category":"$undefined"},{"id":"1786","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":8,"text":"모세와 아론을 바로에게로 다시 데려오니 바로가 그들에게 이르되 가서 너희 하나님 여호와를 섬기라 ! 갈 자는 누구 누구뇨 ?","reference":"출애굽기 10:8","category":"$undefined"},{"id":"1787","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":9,"text":"모세가 가로되 `우리가 여호와 앞에 절기를 지킬 것인즉 우리가 남녀 노소와 우양을 데리고 가겠나이다'","reference":"출애굽기 10:9","category":"$undefined"},{"id":"1788","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":10,"text":"바로가 그들에게 이르되 `내가 너희와 너희 어린 것들을 보내면 여호와를 너희와 함께하게 함과 일반이니라 삼갈지어다 너희 경영이 악하니라","reference":"출애굽기 10:10","category":"$undefined"},{"id":"1789","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":11,"text":"그는 불가하니 너희 남정만 가서 여호와를 섬기라 이것이 너희의 구하는 바니라' 이에 그들이 바로 앞에서 쫓겨나니라","reference":"출애굽기 10:11","category":"$undefined"},{"id":"1790","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":12,"text":"여호와께서 모세에게 이르시되 네 손을 애굽 땅 위에 들어 메뚜기로 애굽 땅에 올라와서 우박에 상하지 아니한 밭의 모든 채소를 먹게 하라","reference":"출애굽기 10:12","category":"$undefined"},{"id":"1791","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":13,"text":"모세가 애굽 땅 위에 그 지팡이를 들매 여호와께서 동풍을 일으켜 온 낮과 온 밤에 불게 하시니 아침에 미쳐 동풍이 메뚜기를 불어 들인지라","reference":"출애굽기 10:13","category":"$undefined"},{"id":"1792","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":14,"text":"메뚜기가 애굽 온 땅에 이르러 그 사방에 내리매 그 해가 심하니 이런 메뚜기는 전에도 없었고 후에도 없을러라","reference":"출애굽기 10:14","category":"$undefined"},{"id":"1793","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":15,"text":"메뚜기가 온 지면에 덮여 날으매 땅이 어둡게 되었고 메뚜기가 우박에 상하지 아니한 밭의 채소와 나무 열매를 다 먹었으므로 애굽 전경에 나무나 밭의 채소나 푸른 것은 남지 아니하였더라","reference":"출애굽기 10:15","category":"$undefined"},{"id":"1794","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":16,"text":"바로가 모세와 아론을 급히 불러서 이르되 `내가 너희 하나님 여호와와 너희에게 득죄하였으니","reference":"출애굽기 10:16","category":"$undefined"},{"id":"1795","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":17,"text":"청컨대 나의 죄를 이번만 용서하고 너희 하나님 여호와께 구하여 이 죽음만을 내게서 떠나게 하라'","reference":"출애굽기 10:17","category":"$undefined"},{"id":"1796","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":18,"text":"그가 바로에게서 나가서 여호와께 구하매","reference":"출애굽기 10:18","category":"$undefined"},{"id":"1797","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":19,"text":"여호와께서 돌이켜 강렬한 서풍이 불게 하사 메뚜기를 홍해에 몰아 넣으시니 애굽 온 지경에 메뚜기가 하나도 남지 아니하니라","reference":"출애굽기 10:19","category":"$undefined"},{"id":"1798","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":20,"text":"그러나 여호와께서 바로의 마음을 강퍅케 하셨으므로 이스라엘 자손을 보내지 아니하였더라","reference":"출애굽기 10:20","category":"$undefined"},{"id":"1799","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":21,"text":"여호와께서 모세에게 이르시되 하늘을 향하여 네 손을 들어서 애굽 땅위에 흑암이 있게 하라 곧 더듬을 만한 흑암이리라","reference":"출애굽기 10:21","category":"$undefined"},{"id":"1800","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":22,"text":"모세가 하늘을 향하여 손을 들매 캄캄한 흑암이 삼일 동안 애굽온 땅에 있어서","reference":"출애굽기 10:22","category":"$undefined"},{"id":"1801","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":23,"text":"그 동안은 사람 사람이 서로 볼 수 없으며 자기 처소에서 일어나는 자가 없으되 이스라엘 자손의 거하는 곳에는 광명이 있었더라","reference":"출애굽기 10:23","category":"$undefined"},{"id":"1802","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":24,"text":"바로가 모세를 불러서 이르되 `너희는 가서 여호와를 섬기되 너희 양과 소는 머물러두고 너희 어린 것은 너희와 함께 갈지니라'","reference":"출애굽기 10:24","category":"$undefined"},{"id":"1803","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":25,"text":"모세가 가로되 `왕이라도 우리 하나님 여호와께 드릴 희생과 번제물을 우리에게 주어야 하겠고","reference":"출애굽기 10:25","category":"$undefined"},{"id":"1804","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":26,"text":"우리의 생축도 우리와 함께 가고 한 마리도 남길 수 없으니 이는 우리가 그 중에서 취하여 우리 하나님 여호와를 섬길 것임이며 또 우리가 거기 이르기까지는 어떤 것으로 여호와를 섬기는지 알지 못함이니이다' 하나","reference":"출애굽기 10:26","category":"$undefined"},{"id":"1805","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":27,"text":"여호와께서 바로의 마음을 강퍅케 하셨으므로 그들을 보내기를 즐겨 아니하고","reference":"출애굽기 10:27","category":"$undefined"},{"id":"1806","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":28,"text":"모세에게 이르되 `너는 나를 떠나가고 스스로 삼가 다시 내 얼굴을 보지 말라 내 얼굴을 보는 날에는 죽으리라'","reference":"출애굽기 10:28","category":"$undefined"},{"id":"1807","book":"출애굽기","book_name":"출애굽기","chapter":10,"verse":29,"text":"모세가 가로되 `왕의 말씀이 옳으니이다 ! 내가 다시는 왕의 얼굴을 보지 아니하리이다 !'","reference":"출애굽기 10:29","category":"$undefined"}],"bookSlug":"exodus"}]
