11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":12,"verses":[{"id":"1818","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":1,"text":"여호와께서 애굽 땅에서 모세와 아론에게 일러 가라사대","reference":"출애굽기 12:1","category":"$undefined"},{"id":"1819","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":2,"text":"이 달로 너희에게 달의 시작 곧 해의 첫 달이 되게 하고","reference":"출애굽기 12:2","category":"$undefined"},{"id":"1820","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":3,"text":"너희는 이스라엘 회중에게 고하여 이르라 이 달 열흘에 너희 매인이 어린 양을 취할지니 각 가족대로 그 식구를 위하여 어린 양을 취하되","reference":"출애굽기 12:3","category":"$undefined"},{"id":"1821","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":4,"text":"그 어린 양에 대하여 식구가 너무 적으면 그 집의 이웃과 함께 수를 따라서 하나를 취하며 각 사람의 식량을 따라서 너희 어린 양을 계산할 것이며","reference":"출애굽기 12:4","category":"$undefined"},{"id":"1822","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":5,"text":"너희 어린 양은 흠 없고 일년 된 수컷으로 하되 양이나 염소 중에서 취하고","reference":"출애굽기 12:5","category":"$undefined"},{"id":"1823","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":6,"text":"이달 십사일까지 간직하였다가 해질 때에 이스라엘 회중이 그 양을 잡고","reference":"출애굽기 12:6","category":"$undefined"},{"id":"1824","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":7,"text":"양을 먹을 집 문 좌우 설주와 인방에 바르고","reference":"출애굽기 12:7","category":"$undefined"},{"id":"1825","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":8,"text":"그 밤에 그 고기를 불에 구워 무교병과 쓴 나물과 아울러 먹되","reference":"출애굽기 12:8","category":"$undefined"},{"id":"1826","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":9,"text":"날로나 물에 삶아서나 먹지 말고 그 머리와 정강이와 내장을 다 불에 구워 먹고","reference":"출애굽기 12:9","category":"$undefined"},{"id":"1827","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":10,"text":"아침까지 남겨 두지 말며 아침까지 남은 것은 곧 소화하라","reference":"출애굽기 12:10","category":"$undefined"},{"id":"1828","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":11,"text":"너희는 그것을 이렇게 먹을지니 허리에 띠를 띠고 발에 신을 신고 손에 지팡이를 잡고 급히 먹으라 ! 이것이 여호와의 유월절이니라 !","reference":"출애굽기 12:11","category":"$undefined"},{"id":"1829","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":12,"text":"내가 그 밤에 애굽 땅에 두루 다니며 사람과 짐승을 무론하고 애굽 나라 가운데 처음 난 것을 다 치고 애굽의 모든 신에게 벌을 내리리라 나는 여호와로라 !","reference":"출애굽기 12:12","category":"$undefined"},{"id":"1830","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":13,"text":"내가 애굽 땅을 칠 때에 그 피가 너희의 거하는 집에 있어서 너희를 위하여 표적이 될지라 내가 피를 볼때에 너희를 넘어가리니재앙이 너희에게 내려 멸하지 아니하리라","reference":"출애굽기 12:13","category":"$undefined"},{"id":"1831","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":14,"text":"너희는 이 날을 기념하여 여호와의 절기를 삼아 영원한 규례로 대대에 지킬지니라 !","reference":"출애굽기 12:14","category":"$undefined"},{"id":"1832","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":15,"text":"너희는 칠일동안 무교병을 먹을지니 그 첫날에 누룩을 너희 집에서 제하라 ! 무릇 첫날부터 칠일까지 유교병을 먹는 자는 이스라엘에서 끊쳐지리라","reference":"출애굽기 12:15","category":"$undefined"},{"id":"1833","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":16,"text":"너희에게 첫날에도 성회요 제 칠일에도 성회가 되리니 이 두 날에는 아무 일도 하지 말고 각인의 식물만 너희가 갖출 것이니라","reference":"출애굽기 12:16","category":"$undefined"},{"id":"1834","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":17,"text":"너희는 무교절을 지키라 ! 이 날에 내가 너희 군대를 애굽 땅에서 인도하여 내었음이니라 그러므로 너희가 영원한 규례를 삼아 이 날을 대대로 지킬지라 !","reference":"출애굽기 12:17","category":"$undefined"},{"id":"1835","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":18,"text":"정월에 그 달 십사일 저녁부터 이십 일일 저녁까지 너희는 무교병을 먹을 것이요","reference":"출애굽기 12:18","category":"$undefined"},{"id":"1836","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":19,"text":"칠일 동안은 누룩을 너희 집에 있지 않게 하라 무릇 유교물을 먹는 타국인이든지 본국에서 난 자든지 무론하고 이스라엘 회중에서 끊쳐지리니","reference":"출애굽기 12:19","category":"$undefined"},{"id":"1837","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":20,"text":"너희는 아무 유교물이든지 먹지 말고 너희 모든 유하는 곳에서 무교병을 먹을지니라","reference":"출애굽기 12:20","category":"$undefined"},{"id":"1838","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":21,"text":"모세가 이스라엘 모든 장로를 불러서 그들에게 이르되 `너희는 나가서 너희 가족대로 어린 양을 택하여 유월절 양으로 잡고","reference":"출애굽기 12:21","category":"$undefined"},{"id":"1839","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":22,"text":"너희는 우슬초 묶음을 취하여 그릇에 담은 피에 적시어서 그 피를 문 인방과 좌우 설주에 뿌리고 아침까지 한 사람도 자기 집 문밖에 나가지 말라","reference":"출애굽기 12:22","category":"$undefined"},{"id":"1840","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":23,"text":"여호와께서 애굽 사람을 치러 두루 다니실 때에 문 인방과 좌우설주의 피를 보시면 그 문을 넘으시고 멸하는 자로 너희 집에 들어가서 너희를 치지 못하게 하실 것임이니라","reference":"출애굽기 12:23","category":"$undefined"},{"id":"1841","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":24,"text":"너희는 이 일을 규례로 삼아 너희와 너희 자손이 영원히 지킬 것이니","reference":"출애굽기 12:24","category":"$undefined"},{"id":"1842","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":25,"text":"너희는 여호와께서 허락하신대로 너희에게 주시는 땅에 이를 때에 이 예식을 지킬 것이라","reference":"출애굽기 12:25","category":"$undefined"},{"id":"1843","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":26,"text":"이 후에 너희 자녀가 묻기를 이 예식이 무슨 뜻이냐 ? 하거든","reference":"출애굽기 12:26","category":"$undefined"},{"id":"1844","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":27,"text":"너희는 이르기를 이는 여호와의 유월절 제사라 여호와께서 애굽 사람을 치실 때에 애굽에 있는 이스라엘 자손의 집을 넘으사 우리의 집을 구원하셨느니라 하라' 하매 백성이 머리 숙여 경배하니라","reference":"출애굽기 12:27","category":"$undefined"},{"id":"1845","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":28,"text":"이스라엘 자손이 물러가서 그대로 행하되 여호와께서 모세와 아론에게 명하신 대로 행하니라","reference":"출애굽기 12:28","category":"$undefined"},{"id":"1846","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":29,"text":"밤중에 여호와께서 애굽 땅에서 모든 처음 난 것 곧 위에 앉은 바로의 장자로부터 옥에 갇힌 사람의 장자까지와 생축의 처음난 것을 다 치시매","reference":"출애굽기 12:29","category":"$undefined"},{"id":"1847","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":30,"text":"그 밤에 바로와 그 모든 신하와 모든 애굽 사람이 일어나고 애굽에 큰 호곡이 있었으니 이는 그 나라에 사망치 아니한 집이 하나도 없었음이었더라","reference":"출애굽기 12:30","category":"$undefined"},{"id":"1848","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":31,"text":"밤에 바로가 모세와 아론을 불러서 이르되 `너희와 이스라엘 자손은 일어나 내 백성 가운데서 떠나서 너희의 말대로 가서 여호와를 섬기며","reference":"출애굽기 12:31","category":"$undefined"},{"id":"1849","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":32,"text":"너희의 말대로 너희의 양도 소도 몰아가고 나를 위하여 축복하라' 하며","reference":"출애굽기 12:32","category":"$undefined"},{"id":"1850","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":33,"text":"애굽 사람들은 말하기를 `우리가 다 죽은 자가 되도다' 하고 백성을 재촉하여 그 지경에서 속히 보내려 하므로","reference":"출애굽기 12:33","category":"$undefined"},{"id":"1851","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":34,"text":"백성이 발교되지 못한 반죽 담은 그릇을 옷에 싸서 어깨에 메니라","reference":"출애굽기 12:34","category":"$undefined"},{"id":"1852","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":35,"text":"이스라엘 자손이 모세의 말대로 하여 애굽 사람에게 은금 패물과 의복을 구하매","reference":"출애굽기 12:35","category":"$undefined"},{"id":"1853","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":36,"text":"여호와께서 애굽 사람으로 백성에게 은혜를 입히게 하사 그들의 구하는대로 주게 하시므로 그들이 애굽 사람의 물품을 취하였더라","reference":"출애굽기 12:36","category":"$undefined"},{"id":"1854","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":37,"text":"이스라엘 자손이 라암셋에서 발행하여 숙곳에 이르니 유아 외에 보행하는 장정이 육십만 가량이요","reference":"출애굽기 12:37","category":"$undefined"},{"id":"1855","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":38,"text":"중다한 잡족과 양과 소와 심히 많은 생축이 그들과 함께 하였으며","reference":"출애굽기 12:38","category":"$undefined"},{"id":"1856","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":39,"text":"그들이 가지고 나온 발교되지 못한 반죽으로 무교병을 구웠으니 이는 그들이 애굽에서 쫓겨 남으로 지체할 수 없었음이며 아무 양식도 준비하지 못하였음이었더라","reference":"출애굽기 12:39","category":"$undefined"},{"id":"1857","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":40,"text":"이스라엘 자손이 애굽에 거주한지 사백 삼십년이라","reference":"출애굽기 12:40","category":"$undefined"},{"id":"1858","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":41,"text":"사백 삼십년이 마치는 그 날에 여호와의 군대가 다 애굽 땅에서 나왔은즉","reference":"출애굽기 12:41","category":"$undefined"},{"id":"1859","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":42,"text":"이 밤은 그들을 애굽 땅에서 인도하여 내심을 인하여 여호와 앞에 지킬 것이니 이는 여호와의 밤이라 이스라엘 자손이 다 대대로 지킬 것이니라","reference":"출애굽기 12:42","category":"$undefined"},{"id":"1860","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":43,"text":"여호와께서 모세와 아론에게 이르시되 유월절 규례가 이러하니라 이방 사람은 먹지 못할 것이나","reference":"출애굽기 12:43","category":"$undefined"},{"id":"1861","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":44,"text":"각 사람이 돈으로 산 종은 할례를 받은 후에 먹을 것이며","reference":"출애굽기 12:44","category":"$undefined"},{"id":"1862","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":45,"text":"거류인과 타국 품군은 먹지 못하리라","reference":"출애굽기 12:45","category":"$undefined"},{"id":"1863","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":46,"text":"한 집에서 먹되 그 고기를 조금도 집 밖으로 내지 말고 뼈도 꺾지 말지며","reference":"출애굽기 12:46","category":"$undefined"},{"id":"1864","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":47,"text":"이스라엘 회중이 다 이것을 지킬지니라","reference":"출애굽기 12:47","category":"$undefined"},{"id":"1865","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":48,"text":"너희와 함께 거하는 타국인이 여호와의 유월절을 지키고자 하거든 그 모든 남자는 할례를 받은 후에야 가까이하여 지킬지니 곧 그는 본토인과 같이 될 것이나 할례 받지 못한 자는 먹지 못할 것이니라","reference":"출애굽기 12:48","category":"$undefined"},{"id":"1866","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":49,"text":"본토인에게나 너희 중에 우거한 이방인에게나 이 법이 동일하니라 하셨으므로","reference":"출애굽기 12:49","category":"$undefined"},{"id":"1867","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":50,"text":"온 이스라엘 자손이 이와 같이 행하되 여호와께서 모세와 아론에게 명하신대로 행하였으며","reference":"출애굽기 12:50","category":"$undefined"},{"id":"1868","book":"출애굽기","book_name":"출애굽기","chapter":12,"verse":51,"text":"그 같은 날에 여호와께서 이스라엘 자손을 그 군대대로 애굽 땅에서 인도하여 내셨더라","reference":"출애굽기 12:51","category":"$undefined"}],"bookSlug":"exodus"}]
