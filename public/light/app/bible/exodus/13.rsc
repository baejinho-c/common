2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":13,"verses":[{"id":"1869","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 13:1","category":"$undefined"},{"id":"1870","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":2,"text":"이스라엘 자손 중에 사람이나 짐승이나 무론하고 초태생은 다 거룩히 구별하여 내게 돌리라 이는 내 것이니라 ! 하시니라","reference":"출애굽기 13:2","category":"$undefined"},{"id":"1871","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":3,"text":"모세가 백성에게 이르되 `너희는 애굽에서 곧 종 되었던 집에서 나온 그 날을 기념하여 유교병을 먹지 말라 여호와께서 그 손의 권능으로 너희를 그 곳에서 인도하여 내셨음이니라","reference":"출애굽기 13:3","category":"$undefined"},{"id":"1872","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":4,"text":"아빕월 이 날에 너희가 나왔으니","reference":"출애굽기 13:4","category":"$undefined"},{"id":"1873","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":5,"text":"여호와께서 너를 인도하여 가나안 사람과, 헷 사람과, 아모리 사람과, 히위 사람과, 여부스 사람의 땅 곧 네게 주시려고 네 조상들에게 맹세하신바 젖과 꿀이 흐르는 땅에 이르게 하시거든 너는 이 달에 이 예식을 지켜","reference":"출애굽기 13:5","category":"$undefined"},{"id":"1874","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":6,"text":"칠일 동안 무교병을 먹고 제 칠일에는 여호와께 절기를 지키라","reference":"출애굽기 13:6","category":"$undefined"},{"id":"1875","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":7,"text":"칠일 동안에는 무교병을 먹고 유교병을 너희 곳에 있게 하지 말며 네 지경 안에서 누룩을 네게 보이지도 말게 하며","reference":"출애굽기 13:7","category":"$undefined"},{"id":"1876","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":8,"text":"너는 그 날에 네 아들에게 뵈어 이르기를 이 예식은 내가 애굽에서 나올 때에 여호와께서 나를 위하여 행하신 일을 인함이라 하고","reference":"출애굽기 13:8","category":"$undefined"},{"id":"1877","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":9,"text":"이것으로 네 손의 기호와 네 미간의 표를 삼고 여호와의 율법으로 네 입에 있게 하라 이는 여호와께서 능하신 손으로 너를 애굽에서 인도하여 내셨음이니","reference":"출애굽기 13:9","category":"$undefined"},{"id":"1878","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":10,"text":"연년이 기한에 이르러 이 규례를 지킬지니라","reference":"출애굽기 13:10","category":"$undefined"},{"id":"1879","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":11,"text":"여호와께서 너와 네 조상에게 맹세하신대로 너를 가나안 사람의 땅에 인도하시고 그 땅을 네게 주시거든","reference":"출애굽기 13:11","category":"$undefined"},{"id":"1880","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":12,"text":"너는 무릇 초태생과 네게 있는 생축의 초태생을 다 구별하여 여호와께 돌리라 수컷은 여호와의 것이니라","reference":"출애굽기 13:12","category":"$undefined"},{"id":"1881","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":13,"text":"나귀의 첫새끼는 다 어린 양으로 대속할 것이요 그렇게 아니하려면 그 목을 꺽을 것이며 너의 아들중 모든 장자 된 자는 다 대속할지니라","reference":"출애굽기 13:13","category":"$undefined"},{"id":"1882","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":14,"text":"장래에 네 아들이 네게 묻기를 이것이 어찜이냐 ? 하거든 너는 그에게 이르기를 여호와께서 그 손의 권능으로 우리를 애굽에서 곧 종이 되었던 집에서 인도하여 내실쌔","reference":"출애굽기 13:14","category":"$undefined"},{"id":"1883","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":15,"text":"그 때에 바로가 강퍅하여 우리를 보내지 아니하매 여호와께서 애굽 나라 가운데 처음 낳은 것까지 다 죽이신고로 초태생의 수컷은 다 여호와께 희생으로 드리고 우리 장자는 다 대속하나니","reference":"출애굽기 13:15","category":"$undefined"},{"id":"1884","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":16,"text":"이것으로 네 손의 기호와 네 미간의 표를 삼으라 여호와께서 그 손의 권능으로 우리를 애굽에서 인도하여 내셨음이니라 할지니라'","reference":"출애굽기 13:16","category":"$undefined"},{"id":"1885","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":17,"text":"바로가 백성을 보낸 후에 블레셋 사람의 땅의 길은 가까울지라도 하나님이 그들을 그 길로 인도하지 아니하셨으니 이는 하나님이 말씀하시기를 이 백성이 전쟁을 보면 뉘우쳐 애굽으로 돌아갈까 하셨음이라","reference":"출애굽기 13:17","category":"$undefined"},{"id":"1886","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":18,"text":"그러므로 하나님이 홍해의 광야 길로 돌려 백성을 인도하시매 이스라엘 자손이 애굽 땅에서 항오를 지어 나올 때에","reference":"출애굽기 13:18","category":"$undefined"},{"id":"1887","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":19,"text":"모세가 요셉의 해골을 취하였으니 이는 요셉이 이스라엘 자손으로 단단히 맹세케 하여 이르기를 '하나님이 필연 너희를 권고하시리니 너희는 나의 해골을 여기서 가지고 나가라' 하였음이었더라","reference":"출애굽기 13:19","category":"$undefined"},{"id":"1888","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":20,"text":"그들이 숙곳에서 발행하여 광야 끝에 담에 장막을 치니","reference":"출애굽기 13:20","category":"$undefined"},{"id":"1889","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":21,"text":"여호와께서 그들 앞에 행하사 낮에는 구름 기둥으로 그들의 길을 인도하시고 밤에는 불기둥으로 그들에게 비취사 주야로 진행하게 하시니","reference":"출애굽기 13:21","category":"$undefined"},{"id":"1890","book":"출애굽기","book_name":"출애굽기","chapter":13,"verse":22,"text":"낮에는 구름 기둥,밤에는 불기둥이 백성 앞에서 떠나지 아니하니라","reference":"출애굽기 13:22","category":"$undefined"}],"bookSlug":"exodus"}]
