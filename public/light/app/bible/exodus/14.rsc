11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":14,"verses":[{"id":"1891","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 14:1","category":"$undefined"},{"id":"1892","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":2,"text":"이스라엘 자손을 명하여 돌쳐서 바다와 믹돌 사이의 비하히롯 앞 곧 바알스본 맞은편 바닷가에 장막을 치게 하라","reference":"출애굽기 14:2","category":"$undefined"},{"id":"1893","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":3,"text":"바로가 이스라엘 자손에 대하여 말하기를 `그들이 그 땅에서 아득하여 광야에 갇힌바 되었다 할지라'","reference":"출애굽기 14:3","category":"$undefined"},{"id":"1894","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":4,"text":"내가 바로의 마음을 강퍅케 한즉 바로가 그들의 뒤를 따르리니 내가 그와 그 온 군대를 인하여 영광을 얻어 애굽 사람으로 나를 여호와인 줄 알게 하리라 하시매 무리가 그대로 행하니라","reference":"출애굽기 14:4","category":"$undefined"},{"id":"1895","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":5,"text":"혹이 백성의 도망한 것을 애굽 왕에게 고하매 바로와 그 신하들이 백성에 대하여 마음이 변하여 가로되 '우리가 어찌 이같이 하여 이스라엘을 우리를 섬김에서 놓아 보내었는고 ?' 하고","reference":"출애굽기 14:5","category":"$undefined"},{"id":"1896","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":6,"text":"바로가 곧 그 병거를 갖추고 그 백성을 데리고 갈새","reference":"출애굽기 14:6","category":"$undefined"},{"id":"1897","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":7,"text":"특별 병거 육백승과 애굽의 모든 병거를 발하니 장관들이 다 거느렸더라","reference":"출애굽기 14:7","category":"$undefined"},{"id":"1898","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":8,"text":"여호와께서 애굽 왕 바로의 마음을 강퍅케 하셨으므로 그가 이스라엘 자손의 뒤를 따르니 이스라엘 자손이 담대히 나갔음이라","reference":"출애굽기 14:8","category":"$undefined"},{"id":"1899","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":9,"text":"애굽 사람들과 바로의 말들 병거들과 그 마병과 그 군대가 그들의 뒤를 따라 바알스본 맞은편 비하히롯 곁 해변 그 장막 친 데 미치니라","reference":"출애굽기 14:9","category":"$undefined"},{"id":"1900","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":10,"text":"바로가 가까와 올 때에 이스라엘 자손이 눈을 들어 본즉 애굽 사람들이 자기 뒤에 미친지라 이스라엘 자손이 심히 두려워하여 여호와께 부르짖고","reference":"출애굽기 14:10","category":"$undefined"},{"id":"1901","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":11,"text":"그들이 또 모세에게 이르되 `애굽에 매장지가 없으므로 당신이 우리를 이끌어 내어 이 광야에서 죽게 하느뇨 ? 어찌하여 당신이 우리를 애굽에서 이끌어 내어 이같이 우리에게 하느뇨 ?","reference":"출애굽기 14:11","category":"$undefined"},{"id":"1902","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":12,"text":"우리가 애굽에서 당신에게 고한 말이 이것이 아니뇨 ? 이르기를 우리를 버려 두라 우리가 애굽 사람을 섬길 것이라 하지 아니하더뇨 ? 애굽 사람을 섬기는 것이 광야에서 죽는 것보다 낫겠노라'","reference":"출애굽기 14:12","category":"$undefined"},{"id":"1903","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":13,"text":"모세가 백성에게 이르되 `너희는 두려워 말고 가만히 서서 여호와께서 오늘날 너희를 위하여 행하시는 구원을 보라 ! 너희가 오늘 본 애굽 사람을 또 다시는 영원히 보지 못하리라","reference":"출애굽기 14:13","category":"$undefined"},{"id":"1904","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":14,"text":"여호와께서 너희를 위하여 싸우시리니 너희는 가만히 있을지니라 !'","reference":"출애굽기 14:14","category":"$undefined"},{"id":"1905","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":15,"text":"여호와께서 모세에게 이르시되 너는 어찌하여 내게 부르짖느뇨 이스라엘 자손을 명하여 앞으로 나가게 하고","reference":"출애굽기 14:15","category":"$undefined"},{"id":"1906","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":16,"text":"지팡이를 들고 손을 바다 위로 내밀어 그것으로 갈라지게 하라 이스라엘 자손이 바다 가운데 육지로 행하리라","reference":"출애굽기 14:16","category":"$undefined"},{"id":"1907","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":17,"text":"내가 애굽 사람들의 마음을 강퍅케 할 것인즉 그들이 그 뒤를 따라 들어갈 것이라 내가 바로와 그 모든 군대와 그 병거와 마병을 인하여 영광을 얻으리니","reference":"출애굽기 14:17","category":"$undefined"},{"id":"1908","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":18,"text":"내가 바로와 그 병거와 마병으로 인하여 영광을 얻을 때에야 애굽 사람들이 나를 여호와인 줄 알리라 하시더니","reference":"출애굽기 14:18","category":"$undefined"},{"id":"1909","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":19,"text":"이스라엘 진 앞에 행하던 하나님의 사자가 옮겨 그 뒤로 행하매 구름 기둥도 앞에서 그 뒤로 옮겨","reference":"출애굽기 14:19","category":"$undefined"},{"id":"1910","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":20,"text":"애굽 진과 이스라엘 진 사이에 이르러 서니 저 편은 구름과 흑암이 있고 이 편은 밤이 광명하므로 밤새도록 저 편이 이 편에 가까이 못하였더라","reference":"출애굽기 14:20","category":"$undefined"},{"id":"1911","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":21,"text":"모세가 바다 위로 손을 내어민대 여호와께서 큰 동풍으로 밤새도록 바닷물을 물러가게 하시니 물이 갈라져 바다가 마른 땅이 된지라","reference":"출애굽기 14:21","category":"$undefined"},{"id":"1912","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":22,"text":"이스라엘 자손이 바다 가운데 육지로 행하고 물은 그들의 좌우에 벽이 되니","reference":"출애굽기 14:22","category":"$undefined"},{"id":"1913","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":23,"text":"애굽 사람들과 바로의 말들, 병거들과 그 마병들이 다 그 뒤를 쫓아 바다 가운데로 들어 오는지라","reference":"출애굽기 14:23","category":"$undefined"},{"id":"1914","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":24,"text":"새벽에 여호와께서 불 구름기둥 가운데서 애굽 군대를 보시고 그 군대를 어지럽게 하시며","reference":"출애굽기 14:24","category":"$undefined"},{"id":"1915","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":25,"text":"그 병거 바퀴를 벗겨서 달리기에 극난하게 하시니 애굽 사람들이 가로되 '이스라엘 앞에서 우리가 도망하자 ! 여호와가 그들을 위하여 싸워 애굽 사람들을 치는도다'","reference":"출애굽기 14:25","category":"$undefined"},{"id":"1916","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":26,"text":"여호와께서 모세에게 이르시되 네 손을 바다 위로 내어밀어 물이 애굽 사람들과 그 병거들과 마병들 위에 다시 흐르게 하라 하시니","reference":"출애굽기 14:26","category":"$undefined"},{"id":"1917","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":27,"text":"모세가 곧 손을 바다 위로 내어밀매 새벽에 미쳐 바다의 그 세력이 회복된지라 애굽 사람들이 물을 거스려 도망하나 여호와께서 애굽 사람들을 바다 가운데 엎으시니","reference":"출애굽기 14:27","category":"$undefined"},{"id":"1918","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":28,"text":"물이 다시 흘러 병거들과 기병들을 덮되 그들의 뒤를 쫓아 바다에 들어간 바로의 군대를 다 덮고 하나도 남기지 아니하였더라","reference":"출애굽기 14:28","category":"$undefined"},{"id":"1919","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":29,"text":"그러나 이스라엘 자손은 바다 가운데 육지로 행하였고 물이 좌우에 벽이 되었었더라","reference":"출애굽기 14:29","category":"$undefined"},{"id":"1920","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":30,"text":"그 날에 여호와께서 이같이 이스라엘을 애굽 사람의 손에서 구원하시매 이스라엘이 바닷가의 애굽 사람의 시체를 보았더라","reference":"출애굽기 14:30","category":"$undefined"},{"id":"1921","book":"출애굽기","book_name":"출애굽기","chapter":14,"verse":31,"text":"이스라엘이 여호와께서 애굽 사람들에게 베푸신 큰 일을 보았으므로 백성이 여호와를 경외하며 여호와와 그 종 모세를 믿었더라","reference":"출애굽기 14:31","category":"$undefined"}],"bookSlug":"exodus"}]
