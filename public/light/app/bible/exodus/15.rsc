11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":15,"verses":[{"id":"1922","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":1,"text":"이 때에 모세와 이스라엘 자손이 이 노래로 여호와께 노래하니 일렀으되 내가 여호와를 찬송하리니 그는 높고 영화로우심이요 말과 그 탄 자를 바다에 던지셨음이로다","reference":"출애굽기 15:1","category":"$undefined"},{"id":"1923","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":2,"text":"여호와는 나의 힘이요, 노래시며, 나의 구원이시로다 그는 나의 하나님이시니 내가 그를 찬송할 것이요 내 아비의 하나님이시니 내가 그를 높이리로다","reference":"출애굽기 15:2","category":"$undefined"},{"id":"1924","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":3,"text":"여호와는 용사시니 여호와는 그의 이름이시로다","reference":"출애굽기 15:3","category":"$undefined"},{"id":"1925","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":4,"text":"그가 바로의 병거와 그 군대를 바다에 던지시니 그 택한 장관이 홍해에 잠겼고","reference":"출애굽기 15:4","category":"$undefined"},{"id":"1926","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":5,"text":"큰 물이 그들을 덮으니 그들이 돌처럼 깊음에 내렸도다","reference":"출애굽기 15:5","category":"$undefined"},{"id":"1927","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":6,"text":"여호와여 주의 오른손이 권능으로 영광을 나타내시니이다 여호와여 ! 주의 오른 손이 원수를 부수시니이다","reference":"출애굽기 15:6","category":"$undefined"},{"id":"1928","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":7,"text":"주께서 주의 큰 위엄으로 주를 거스리는 자를 엎으시나이다 주께서 진노를 발하시니 그 진노가 그들을 초개같이 사르니이다","reference":"출애굽기 15:7","category":"$undefined"},{"id":"1929","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":8,"text":"주의 콧김에 물이 쌓이되 파도가 언덕 같이 일어서고 큰 물이 바다 가운데 엉기니이다","reference":"출애굽기 15:8","category":"$undefined"},{"id":"1930","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":9,"text":"대적의 말이 내가 쫓아 미쳐 탈취물을 나누리라 내가 그들로 인하여 내 마음을 채우리라 내가 내 칼을 빼리니 내 손이 그들을 멸하리라 하였으나","reference":"출애굽기 15:9","category":"$undefined"},{"id":"1931","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":10,"text":"주께서 주의 바람을 일으키시매 바다가 그들을 덮으니 그들이 흉용한 물에 납 같이 잠겼나이다","reference":"출애굽기 15:10","category":"$undefined"},{"id":"1932","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":11,"text":"여호와여 ! 신 중에 주와 같은 자 누구니이까 ? 주와 같이 거룩함에 영광스러우며 찬송할만한 위엄이 있으며 기이한 일을 행하는 자 누구니이까 ?","reference":"출애굽기 15:11","category":"$undefined"},{"id":"1933","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":12,"text":"주께서 오른손을 드신즉 땅이 그들을 삼켰나이다","reference":"출애굽기 15:12","category":"$undefined"},{"id":"1934","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":13,"text":"주께서 그 구속하신 백성을 은혜로 인도하시되 주의 힘으로 그들을 주의 성결한 처소에 들어가게 하시나이다","reference":"출애굽기 15:13","category":"$undefined"},{"id":"1935","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":14,"text":"열방이 듣고 떨며 블레셋 거민이 두려움에 잡히며","reference":"출애굽기 15:14","category":"$undefined"},{"id":"1936","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":15,"text":"에돔 방백이 놀라고 모압 영웅이 떨림에 잡히며 가나안 거민이 다 낙담하나이다","reference":"출애굽기 15:15","category":"$undefined"},{"id":"1937","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":16,"text":"놀람과 두려움이 그들에게 미치매 주의 팔이 큼을 인하여 그들이 돌같이 고요하였사오되 여호와여 ! 주의 백성이 통과하기까지 곧 주의 사신 백성이 통과하기까지였나이다","reference":"출애굽기 15:16","category":"$undefined"},{"id":"1938","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":17,"text":"주께서 백성을 인도하사 그들을 주의 기업의 산에 심으시리이다 여호와여 ! 이는 주의 처소를 삼으시려고 예비하신 것이라 주여 ! 이것이 주의 손으로 세우신 성소로소이다","reference":"출애굽기 15:17","category":"$undefined"},{"id":"1939","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":18,"text":"여호와의 다스리심이 영원무궁하시도다 하였더라","reference":"출애굽기 15:18","category":"$undefined"},{"id":"1940","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":19,"text":"바로의 말과 병거와 마병이 함께 바다에 들어가매 여호와께서 바닷물로 그들 위에 돌이켜 흐르게 하셨으나 이스라엘 자손은 바다가운데서 육지로 행한지라","reference":"출애굽기 15:19","category":"$undefined"},{"id":"1941","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":20,"text":"아론의 누이 선지자 미리암이 손에 소고를 잡으매 모든 여인도 그를 따라 나오며 소고를 잡고 춤추니","reference":"출애굽기 15:20","category":"$undefined"},{"id":"1942","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":21,"text":"미리암이 그들에게 화답하여 가로되 `너희는 여호와를 찬송하라 ! 그는 높고 영화로우심이요 말과 그 탄 자를 바다에 던지셨음이로다' 하였더라","reference":"출애굽기 15:21","category":"$undefined"},{"id":"1943","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":22,"text":"모세가 홍해에서 이스라엘을 인도하매 그들이 나와서 수르 광야로 들어가서 거기서 사흘길을 행하였으나 물을 얻지 못하고","reference":"출애굽기 15:22","category":"$undefined"},{"id":"1944","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":23,"text":"마라에 이르렀더니 그 곳 물이 써서 마시지 못하겠으므로 그 이름을 마라라 하였더라","reference":"출애굽기 15:23","category":"$undefined"},{"id":"1945","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":24,"text":"백성이 모세를 대하여 원망하여 가로되 `우리가 무엇을 마실까 ?' 하매","reference":"출애굽기 15:24","category":"$undefined"},{"id":"1946","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":25,"text":"모세가 여호와께 부르짖었더니 여호와께서 그에게 한 나무를 지시하시니 그가 물에 던지매 물이 달아졌더라 거기서 여호와께서 그들을 위하여 법도와 율례를 정하시고 그들을 시험하실쌔","reference":"출애굽기 15:25","category":"$undefined"},{"id":"1947","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":26,"text":"가라사대 너희가 너희 하나님 나 여호와의 말을 청종하고 나의 보기에 의를 행하며 내 계명에 귀를 기울이며 내 모든 규례를 지키면 내가 애굽 사람에게 내린 모든 질병의 하나도 너희에게 내리지 아니하리니 나는 너희를 치료하는 여호와임이니라 !","reference":"출애굽기 15:26","category":"$undefined"},{"id":"1948","book":"출애굽기","book_name":"출애굽기","chapter":15,"verse":27,"text":"그들이 엘림에 이르니 거기 물샘 열 둘과 종려 칠십주가 있는지라 거기서 그들이 그 물 곁에 장막을 치니라","reference":"출애굽기 15:27","category":"$undefined"}],"bookSlug":"exodus"}]
