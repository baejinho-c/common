2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":16,"verses":[{"id":"1949","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":1,"text":"이스라엘 자손의 온 회중이 엘림에서 떠나 엘림과 시내산 사이 신 광야에 이르니 애굽에서 나온 후 제 이월 십오일이라","reference":"출애굽기 16:1","category":"$undefined"},{"id":"1950","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":2,"text":"이스라엘 온 회중이 그 광야에서 모세와 아론을 원망하여","reference":"출애굽기 16:2","category":"$undefined"},{"id":"1951","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":3,"text":"그들에게 이르되 `우리가 애굽 땅에서 고기 가마 곁에 앉았던 때와 떡을 배불리 먹던 때에 여호와의 손에 죽었더면 좋았을 것을 너희가 이 광야로 우리를 인도하여 내어 이 온 회중으로 주려 죽게 하는도다'","reference":"출애굽기 16:3","category":"$undefined"},{"id":"1952","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":4,"text":"때에 여호와께서 모세에게 이르시되 `보라 ! 내가 너희를 위하여 하늘에서 양식을 비 같이 내리리니 백성이 나가서 일용할 것을 날마다 거둘 것이라 이같이 하여 그들이 나의 율법을 준행하나 아니하나 내가 시험하리라","reference":"출애굽기 16:4","category":"$undefined"},{"id":"1953","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":5,"text":"제 육일에는 그들이 그 거둔 것을 예비할지니 날마다 거두던 것의 갑절이 되리라'","reference":"출애굽기 16:5","category":"$undefined"},{"id":"1954","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":6,"text":"모세와 아론이 온 이스라엘 자손에게 이르되 `저녁이 되면 너희가 여호와께서 너희를 애굽 땅에서 인도하여 내셨음을 알 것이요","reference":"출애굽기 16:6","category":"$undefined"},{"id":"1955","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":7,"text":"아침에는 너희가 여호와의 영광을 보리니 이는 여호와께서 너희가 자기를 향하여 원망함을 들으셨음이라 우리가 누구관대 너희가 우리를 대하여 원망하느냐 ?'","reference":"출애굽기 16:7","category":"$undefined"},{"id":"1956","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":8,"text":"모세가 또 가로되 `여호와께서 저녁에는 너희에게 고기를 주어 먹이시고 아침에는 떡으로 배불리시리니 이는 여호와께서 자기를 향하여 너희의 원망하는 그 말을 들으셨음이니라 우리가 누구냐 ? 너희의 원망은 우리를 향하여 함이 아니요 여호와를 향하여 함이로다'","reference":"출애굽기 16:8","category":"$undefined"},{"id":"1957","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":9,"text":"모세가 또 아론에게 이르되 `이스라엘 자손의 온 회중에게 명하기를 여호와께 가까이 나아오라 ! 여호와께서 너희의 원망함을 들으셨느니라 하라'","reference":"출애굽기 16:9","category":"$undefined"},{"id":"1958","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":10,"text":"아론이 이스라엘 자손의 온 회중에게 말하매 그들이 광야를 바라보니 여호와의 영광이 구름 속에 나타나더라","reference":"출애굽기 16:10","category":"$undefined"},{"id":"1959","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":11,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 16:11","category":"$undefined"},{"id":"1960","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":12,"text":"내가 이스라엘 자손의 원망함을 들었노라 그들에게 고하여 이르기를 너희가 해 질 때에는 고기를 먹고 아침에는 떡으로 배부르리니 나는 여호와 너희의 하나님인 줄 알리라 하라 하시니라","reference":"출애굽기 16:12","category":"$undefined"},{"id":"1961","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":13,"text":"저녁에는 메추라기가 와서 진에 덮이고 아침에는 이슬이 진 사면에 있더니","reference":"출애굽기 16:13","category":"$undefined"},{"id":"1962","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":14,"text":"그 이슬이 마른 후에 광야 지면에 작고 둥글며 서리 같이 세미한 것이 있는지라","reference":"출애굽기 16:14","category":"$undefined"},{"id":"1963","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":15,"text":"이스라엘 자손이 보고 그것이 무엇인지 알지 못하여 서로 이르되 이것이 무엇이냐 ? 하니 모세가 그들에게 이르되 이는 여호와께서 너희에게 주어 먹게 하신 양식이라","reference":"출애굽기 16:15","category":"$undefined"},{"id":"1964","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":16,"text":"여호와께서 이같이 명하시기를 너희 각 사람의 식량대로 이것을 거둘지니 곧 너희 인수대로 매명에 한 오멜씩 취하되 각 사람이 그 장막에 있는 자들을 위하여 취할지니라 하셨느니라","reference":"출애굽기 16:16","category":"$undefined"},{"id":"1965","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":17,"text":"이스라엘 자손이 그같이 하였더니 그 거둔 것이 많기도 하고 적기도 하나","reference":"출애굽기 16:17","category":"$undefined"},{"id":"1966","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":18,"text":"오멜로 되어 본즉 많이 거둔 자도 남음이 없고 적게 거둔 자도 부족함이 없이 각기 식량대로 거두었더라","reference":"출애굽기 16:18","category":"$undefined"},{"id":"1967","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":19,"text":"모세가 그들에게 이르기를 `아무든지 아침까지 그것을 남겨 두지말라' 하였으나","reference":"출애굽기 16:19","category":"$undefined"},{"id":"1968","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":20,"text":"그들이 모세의 말을 청종치 아니하고 더러는 아침까지 두었더니 벌레가 생기고 냄새가 난지라 모세가 그들에게 노하니라","reference":"출애굽기 16:20","category":"$undefined"},{"id":"1969","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":21,"text":"무리가 아침마다 각기 식량대로 거두었고 해가 뜨겁게 쪼이면 그것이 스러졌더라","reference":"출애굽기 16:21","category":"$undefined"},{"id":"1970","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":22,"text":"제육일에는 각 사람이 갑절의 식물 곧 하나에 두 오멜씩 거둔지라 회중의 모든 두목이 와서 모세에게 고하매","reference":"출애굽기 16:22","category":"$undefined"},{"id":"1971","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":23,"text":"모세가 그들에게 이르되 `여호와께서 이같이 말씀하셨느니라 내일은 휴식이니 여호와께 거룩한 안식일이라 너희가 구울 것은 굽고 삶을 것은 삶고, 그 나머지는 다 너희를 위하여 아침까지 간수하라'","reference":"출애굽기 16:23","category":"$undefined"},{"id":"1972","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":24,"text":"그들이 모세의 명대로 아침까지 간수하였으나 냄새도 나지 아니하고 벌레도 생기지 아니한지라","reference":"출애굽기 16:24","category":"$undefined"},{"id":"1973","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":25,"text":"모세가 가로되 `오늘은 그것을 먹으라 오늘은 여호와께 안식일인즉 오늘은 너희가 그것을 들에서 얻지 못하리라","reference":"출애굽기 16:25","category":"$undefined"},{"id":"1974","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":26,"text":"육일 동안은 너희가 그것을 거두되 제 칠일은 안식일인즉 그날에는 없으리라 !' 하였으나","reference":"출애굽기 16:26","category":"$undefined"},{"id":"1975","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":27,"text":"제 칠일에 백성 중 더러가 거두러 나갔다가 얻지 못하니라","reference":"출애굽기 16:27","category":"$undefined"},{"id":"1976","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":28,"text":"여호와께서 모세에게 이르시되 어느 때까지 너희가 내 계명과 내 율법을 지키지 아니하려느냐 ?","reference":"출애굽기 16:28","category":"$undefined"},{"id":"1977","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":29,"text":"볼지어다 ! 여호와가 너희에게 안식일을 줌으로 제 육일에는 이들 양식을 너희에게 주는 것이니 너희는 각기 처소에 있고 제 칠일에는 아무도 그 처소에서 나오지 말지니라","reference":"출애굽기 16:29","category":"$undefined"},{"id":"1978","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":30,"text":"그러므로 백성이 제 칠일에 안식하니라","reference":"출애굽기 16:30","category":"$undefined"},{"id":"1979","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":31,"text":"이스라엘 족속이 그 이름을 만나라 하였으며 깟씨 같고도 희고 맛은 꿀 섞은 과자 같았더라","reference":"출애굽기 16:31","category":"$undefined"},{"id":"1980","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":32,"text":"모세가 가로되 `여호와께서 이같이 명하시기를 이것을 오멜에 채워서 너의 대대 후손을 위하여 간수하라 이는 내가 너희를 애굽 땅에서 인도하여 낼 때에 광야에서 너희에게 먹인 양식을 그들에게 보이기 위함이니라 하셨다' 하고","reference":"출애굽기 16:32","category":"$undefined"},{"id":"1981","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":33,"text":"또 아론에게 이르되 `항아리를 가져다가 그 속에 만나 한 오멜을 담아 여호와 앞에 두어 너희 대대로 간수하라'","reference":"출애굽기 16:33","category":"$undefined"},{"id":"1982","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":34,"text":"아론이 여호와께서 모세에게 명하신대로 그것을 증거판 앞에 두어 간수하게 하였고","reference":"출애굽기 16:34","category":"$undefined"},{"id":"1983","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":35,"text":"이스라엘 자손이 사람 사는 땅에 이르기까지 사십년 동안 만나를 먹되 곧 가나안 지경에 이르기까지 그들이 만나를 먹었더라","reference":"출애굽기 16:35","category":"$undefined"},{"id":"1984","book":"출애굽기","book_name":"출애굽기","chapter":16,"verse":36,"text":"오멜은 에바 십분의 일이더라","reference":"출애굽기 16:36","category":"$undefined"}],"bookSlug":"exodus"}]
