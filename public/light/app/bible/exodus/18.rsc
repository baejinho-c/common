2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":18,"verses":[{"id":"2001","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":1,"text":"모세의 장인 미디안 제사장 이드로가 하나님이 모세에게와 자기 백성 이스라엘에게 하신 일 곧 여호와께서 이스라엘을 애굽에서 인도하여 내신 모든 일을 들으니라","reference":"출애굽기 18:1","category":"$undefined"},{"id":"2002","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":2,"text":"모세의 장인 이드로가 모세가 돌려 보내었던 그의 아내 십보라와","reference":"출애굽기 18:2","category":"$undefined"},{"id":"2003","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":3,"text":"그 두 아들을 데렸으니 그 하나의 이름은 게르솜이라 이는 모세가 이르기를 '내가 이방에서 객이 되었다' 함이요","reference":"출애굽기 18:3","category":"$undefined"},{"id":"2004","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":4,"text":"하나의 이름은 엘리에셀이라 이는 `내 아버지의 하나님이 나를 도우사 바로의 칼에서 구원하셨다' 함이더라","reference":"출애굽기 18:4","category":"$undefined"},{"id":"2005","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":5,"text":"모세의 장인 이드로가 모세의 아들들과 그 아내로 더불어 광야에 들어와 모세에게 이르니 곧 모세가 하나님의 산에 진 친 곳이라","reference":"출애굽기 18:5","category":"$undefined"},{"id":"2006","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":6,"text":"그가 모세에게 전언하되 `그대의 장인 나 이드로가 그대의 아내와 그와 함께한 그 두 아들로 더불어 그대에게 왔노라'","reference":"출애굽기 18:6","category":"$undefined"},{"id":"2007","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":7,"text":"모세가 나가서 그 장인을 맞아 절하고 그에게 입맞추고 그들이 서로 문안하고 함께 장막에 들어가서","reference":"출애굽기 18:7","category":"$undefined"},{"id":"2008","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":8,"text":"모세가 여호와께서 이스라엘을 위하여 바로와 애굽 사람에게 행하신 모든 일과 길에서 그들의 당한 모든 고난과 여호와께서 그 들을 구원하신 일을 다 그 장인에게 고하매","reference":"출애굽기 18:8","category":"$undefined"},{"id":"2009","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":9,"text":"이드로가 여호와께서 이스라엘에게 모든 은혜를 베푸사 애굽 사람의 손에서 구원하심을 기뻐하여","reference":"출애굽기 18:9","category":"$undefined"},{"id":"2010","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":10,"text":"가로되 `여호와를 찬송하리로다 ! 너희를 애굽 사람의 손에서와 바로의 손에서 건져내시고 백성을 애굽 사람의 손 밑에서 건지셨도다","reference":"출애굽기 18:10","category":"$undefined"},{"id":"2011","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":11,"text":"이제 내가 알았도다 ! 여호와는 모든 신보다 크시므로 이스라엘에게 교만히 행하는 그들을 이기셨도다' 하고","reference":"출애굽기 18:11","category":"$undefined"},{"id":"2012","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":12,"text":"모세의 장인 이드로가 번제물과 희생을 하나님께 가져오매 아론과 이스라엘 모든 장로가 와서 모세의 장인과 함께 하나님 앞에서 떡을 먹으니라","reference":"출애굽기 18:12","category":"$undefined"},{"id":"2013","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":13,"text":"이튿날에 모세가 백성을 재판하느라고 앉았고 백성은 아침부터 저녁까지 모세의 곁에 섰는지라","reference":"출애굽기 18:13","category":"$undefined"},{"id":"2014","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":14,"text":"모세의 장인이 모세가 백성에게 행하는 모든 일을 보고 가로되 `그대가 이 백성에게 행하는 이 일이 어찜이뇨 ? 어찌하여 그대는 홀로 앉았고 백성은 아침부터 저녁까지 그대의 곁에 섰느뇨 ?'","reference":"출애굽기 18:14","category":"$undefined"},{"id":"2015","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":15,"text":"모세가 그 장인에게 대답하되 `백성이 하나님께 물으려고 내게로 옴이라","reference":"출애굽기 18:15","category":"$undefined"},{"id":"2016","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":16,"text":"그들이 일이 있으면 내게로 오나니 내가 그 양편을 판단하여 하나님의 율례와 법도를 알게 하나이다'","reference":"출애굽기 18:16","category":"$undefined"},{"id":"2017","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":17,"text":"모세의 장인이 그에게 이르되 `그대의 하는 것이 선하지 못하도다","reference":"출애굽기 18:17","category":"$undefined"},{"id":"2018","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":18,"text":"그대와 그대와 함께한 이 백성이 필연 기력이 쇠하리니 이 일이 그대에게 너무 중함이라 그대가 혼자 할 수 없으리라","reference":"출애굽기 18:18","category":"$undefined"},{"id":"2019","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":19,"text":"이제 내 말을 들으라 ! 내가 그대에게 방침을 가르치리니 하나님이 그대와 함께 계실지로다 ! 그대는 백성을 위하여 하나님 앞에 있어서 소송을 하나님께 베풀며","reference":"출애굽기 18:19","category":"$undefined"},{"id":"2020","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":20,"text":"그들에게 율례와 법도를 가르쳐서 마땅히 갈 길과 할 일을 그들에게 보이고","reference":"출애굽기 18:20","category":"$undefined"},{"id":"2021","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":21,"text":"그대는 또 온 백성 가운데서 재덕이 겸전한 자 곧 하나님을 두려워하며 진실무망하며 불의한 이를 미워하는 자를 빼서 백성 위에 세워 천부장과 백부장과 오십부장과 십부장을 삼아","reference":"출애굽기 18:21","category":"$undefined"},{"id":"2022","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":22,"text":"그들로 때를 따라 백성을 재판하게 하라 무릇 큰 일이면 그대에게 베풀 것이고 무릇 작은 일이면 그들이 스스로 재판할 것이니 그리하면 그들이 그대와 함께 담당할 것인즉 일이 그대에게 쉬우리라","reference":"출애굽기 18:22","category":"$undefined"},{"id":"2023","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":23,"text":"그대가 만일 이 일을 하고 하나님께서도 그대에게 인가하시면 그대가 이 일을 감당하고 이 모든 백성도 자기 곳으로 평안히 가리라'","reference":"출애굽기 18:23","category":"$undefined"},{"id":"2024","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":24,"text":"이에 모세가 자기 장인의 말을 듣고 그 모든 말대로 하여","reference":"출애굽기 18:24","category":"$undefined"},{"id":"2025","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":25,"text":"이스라엘 무리 중에서 재덕이 겸전한 자를 빼서 그들로 백성의 두목 곧 천부장과 백부장과 오십부장과 십부장을 삼으매","reference":"출애굽기 18:25","category":"$undefined"},{"id":"2026","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":26,"text":"그들이 때를 따라 백성을 재판하되 어려운 일은 모세에게 베풀고 쉬운 일은 자단하더라","reference":"출애굽기 18:26","category":"$undefined"},{"id":"2027","book":"출애굽기","book_name":"출애굽기","chapter":18,"verse":27,"text":"모세가 그 장인을 보내니 그가 자기 고향으로 돌아가니라","reference":"출애굽기 18:27","category":"$undefined"}],"bookSlug":"exodus"}]
