2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":19,"verses":[{"id":"2028","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":1,"text":"이스라엘 자손이 애굽 땅에서 나올 때부터 제 삼월 곧 그 때에 그들이 시내 광야에 이르니라","reference":"출애굽기 19:1","category":"$undefined"},{"id":"2029","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":2,"text":"그들이 르비딤을 떠나 시내 광야에 이르러 그 광야에 장막을 치되 산 앞에 장막을 치니라","reference":"출애굽기 19:2","category":"$undefined"},{"id":"2030","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":3,"text":"모세가 하나님 앞에 올라가니 여호와께서 산에서 그를 불러 가라사대 너는 이같이 야곱 족속에게 이르고 이스라엘 자손에게 고하라","reference":"출애굽기 19:3","category":"$undefined"},{"id":"2031","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":4,"text":"나의 애굽 사람에게 어떻게 행하였음과 내가 어떻게 독수리 날개로 너희를 업어 내게로 인도하였음을 너희가 보았느니라","reference":"출애굽기 19:4","category":"$undefined"},{"id":"2032","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":5,"text":"세계가 다 내게 속하였나니 너희가 내 말을 잘 듣고 내 언약을 지키면 너희는 열국 중에서 내 소유가 되겠고","reference":"출애굽기 19:5","category":"$undefined"},{"id":"2033","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":6,"text":"너희가 내게 대하여 제사장 나라가 되며 거룩한 백성이 되리라 너는 이 말을 이스라엘 자손에게 고할지니라 !","reference":"출애굽기 19:6","category":"$undefined"},{"id":"2034","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":7,"text":"모세가 와서 백성의 장로들을 불러 여호와께서 자기에게 명하신 그 모든 말씀을 그 앞에 진술하니","reference":"출애굽기 19:7","category":"$undefined"},{"id":"2035","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":8,"text":"백성이 일제히 응답하여 가로되 `여호와의 명하신대로 우리가 다 행하리이다 !' 모세가 백성의 말로 여호와께 회보하매","reference":"출애굽기 19:8","category":"$undefined"},{"id":"2036","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":9,"text":"여호와께서 모세에게 이르시되 내가 빽빽한 구름 가운데서 네게 일함은 내가 너와 말하는 것을 백성으로 듣게하며 또한 너를 영원히 믿게 하려함이니라 모세가 백성의 말로 여호와께 고하였으므로","reference":"출애굽기 19:9","category":"$undefined"},{"id":"2037","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":10,"text":"여호와께서 모세에게 이르시되 너는 백성에게로 가서 오늘과 내일 그들을 성결케 하며 그들로 옷을 빨고","reference":"출애굽기 19:10","category":"$undefined"},{"id":"2038","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":11,"text":"예비하여 제 삼일을 기다리게 하라 이는 제 삼일에 나 여호와가 온 백성의 목전에 시내산에 강림할 것임이니","reference":"출애굽기 19:11","category":"$undefined"},{"id":"2039","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":12,"text":"너는 백성을 위하여 사면으로 지경을 정하고 이르기를 너희는 삼가 산에 오르거나 그 지경을 범하지 말지니 산을 범하는 자는 정녕 죽임을 당할 것이라","reference":"출애굽기 19:12","category":"$undefined"},{"id":"2040","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":13,"text":"손을 그에게 댐이 없이 그런 자는 돌에 맞아 죽임을 당하거나 살에 쐬어 죽임을 당하리니 짐승이나 사람을 무론하고 살지 못하리라 나팔을 길게 불거든 산 앞에 이를 것이니라 하라","reference":"출애굽기 19:13","category":"$undefined"},{"id":"2041","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":14,"text":"모세가 산에서 내려 백성에게 이르러 백성으로 성결케 하니 그들이 자기 옷을 빨더라","reference":"출애굽기 19:14","category":"$undefined"},{"id":"2042","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":15,"text":"모세가 백성에게 이르되 `예비하여 제 삼일을 기다리고 여인을 가까이 말라' 하니라","reference":"출애굽기 19:15","category":"$undefined"},{"id":"2043","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":16,"text":"제 삼일 아침에 우뢰와 번개와 빽빽한 구름이 산 위에 있고 나팔소리가 심히 크니 진중 모든 백성이 다 떨더라","reference":"출애굽기 19:16","category":"$undefined"},{"id":"2044","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":17,"text":"모세가 하나님을 맞으려고 백성을 거느리고 진에서 나오매 그들이 산 기슭에 섰더니","reference":"출애굽기 19:17","category":"$undefined"},{"id":"2045","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":18,"text":"시내산에 연기가 자욱하니 여호와께서 불 가운데서 거기 강림하심이라 그 연기가 옹기점 연기 같이 떠오르고 온 산이 크게 진동하며","reference":"출애굽기 19:18","category":"$undefined"},{"id":"2046","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":19,"text":"나팔 소리가 점점 커질 때에 모세가 말한즉 하나님이 음성으로 대답하시더라","reference":"출애굽기 19:19","category":"$undefined"},{"id":"2047","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":20,"text":"여호와께서 시내산 곧 그 산꼭대기에 강림하시고 그리로 모세를 부르시니 모세가 올라 가매","reference":"출애굽기 19:20","category":"$undefined"},{"id":"2048","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":21,"text":"여호와께서 모세에게 이르시되 내려가서 백성을 신칙하라 백성이 돌파하고 나 여호와께로 와서 보려고 하다가 많이 죽을까 하노라","reference":"출애굽기 19:21","category":"$undefined"},{"id":"2049","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":22,"text":"또 여호와께 가까이 하는 제사장들로 그 몸을 성결히 하게 하라 나 여호와가 그들을 돌격할까 하노라","reference":"출애굽기 19:22","category":"$undefined"},{"id":"2050","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":23,"text":"모세가 여호와께 고하되 `주께서 우리에게 명하여 이르시기를 산사면에 지경을 세워 산을 거룩하게 하라 하셨사온즉 백성이 시내산에 오르지 못하리이다'","reference":"출애굽기 19:23","category":"$undefined"},{"id":"2051","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":24,"text":"여호와께서 그에게 이르시되 가라 너는 내려가서 아론과 함께 올라오고 제사장들과 백성에게는 돌파하고 나 여호와에게로 올라오지 못하게 하라 내가 그들을 돌격할까 하노라","reference":"출애굽기 19:24","category":"$undefined"},{"id":"2052","book":"출애굽기","book_name":"출애굽기","chapter":19,"verse":25,"text":"모세가 백성에게 내려가서 그들에게 고하니라","reference":"출애굽기 19:25","category":"$undefined"}],"bookSlug":"exodus"}]
