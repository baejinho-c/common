2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":2,"verses":[{"id":"1556","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":1,"text":"레위 족속 중 한 사람이 가서 레위 여자에게 장가 들었더니","reference":"출애굽기 2:1","category":"$undefined"},{"id":"1557","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":2,"text":"그 여자가 잉태하여 아들을 낳아 그 준수함을 보고 그를 석달을 숨겼더니","reference":"출애굽기 2:2","category":"$undefined"},{"id":"1558","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":3,"text":"더 숨길 수 없이 되매 그를 위하여 갈 상자를 가져다가 역청과 나무 진을 칠하고 아이를 거기 담아 하숫가 갈대 사이에 두고","reference":"출애굽기 2:3","category":"$undefined"},{"id":"1559","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":4,"text":"그 누이가 어떻게 되는 것을 알려고 멀리 섰더니","reference":"출애굽기 2:4","category":"$undefined"},{"id":"1560","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":5,"text":"바로의 딸이 목욕하러 하수로 내려오고 시녀들은 하숫가에 거닐 때에 그가 갈대 사이에 상자를 보고 시녀를 보내어 가져다가","reference":"출애굽기 2:5","category":"$undefined"},{"id":"1561","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":6,"text":"열고 그 아이를 보니 아이가 우는지라 그가 불쌍히 여겨 가로되 `이는 히브리 사람의 아이로다'","reference":"출애굽기 2:6","category":"$undefined"},{"id":"1562","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":7,"text":"그 누이가 바로의 딸에게 이르되 `내가 가서 히브리 여인 중에서 유모를 불러다가 당신을 위하여 이 아이를 젖 먹이게 하리이까 ?'","reference":"출애굽기 2:7","category":"$undefined"},{"id":"1563","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":8,"text":"바로의 딸이 그에게 이르되 `가라' 그 소녀가 가서 아이의 어미를 불러오니","reference":"출애굽기 2:8","category":"$undefined"},{"id":"1564","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":9,"text":"바로의 딸이 그에게 이르되 `이 아이를 데려다가 나를 위하여 젖을 먹이라 내가 그 삯을 주리라' 여인이 아이를 데려다가 젖을 먹이더니","reference":"출애굽기 2:9","category":"$undefined"},{"id":"1565","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":10,"text":"그 아이가 자라매 바로의 딸에게로 데려가니 그의 아들이 되니라 그가 그 이름을 모세라 하여 가로되 `이는 내가 그를 물에서 건져내었음이라' 하였더라","reference":"출애굽기 2:10","category":"$undefined"},{"id":"1566","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":11,"text":"모세가 장성한 후에 한번은 자기 형제들에게 나가서 그 고역함을 보더니 어떤 애굽 사람이 어떤 히브리 사람 곧 자기 형제를 치는 것을 본지라","reference":"출애굽기 2:11","category":"$undefined"},{"id":"1567","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":12,"text":"좌우로 살펴 사람이 없음을 보고 그 애굽 사람을 쳐죽여 모래에 감추니라","reference":"출애굽기 2:12","category":"$undefined"},{"id":"1568","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":13,"text":"이튿날 다시 나가니 두 히브리 사람이 서로 싸우는지라 그 그른 자에게 이르되 `네가 어찌하여 동포를 치느냐 ?' 하매","reference":"출애굽기 2:13","category":"$undefined"},{"id":"1569","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":14,"text":"그가 가로되 `누가 너로 우리의 주재와 법관을 삼았느냐 ? 네가 애굽 사람을 죽임같이 나도 죽이려느냐 ?' 모세가 두려워하여 가로되 `일이 탄로되었도다'","reference":"출애굽기 2:14","category":"$undefined"},{"id":"1570","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":15,"text":"바로가 이 일을 듣고 모세를 죽이고자 하여 찾은지라 모세가 바로의 낯을 피하여 미디안 땅에 머물며 하루는 우물 곁에 앉았더라","reference":"출애굽기 2:15","category":"$undefined"},{"id":"1571","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":16,"text":"미디안 제사장에게 일곱 딸이 있더니 그들이 와서 물을 길어 구유에 채우고 그 아비의 양무리에게 먹이려 하는데","reference":"출애굽기 2:16","category":"$undefined"},{"id":"1572","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":17,"text":"목자들이 와서 그들을 쫓는지라 모세가 일어나 그들을 도와 그 양무리에게 먹이니라","reference":"출애굽기 2:17","category":"$undefined"},{"id":"1573","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":18,"text":"그들이 그 아비 르우엘에게 이를 때에 아비가 가로되 `너희가 오늘은 어찌하여 이같이 속히 돌아오느냐 ?'","reference":"출애굽기 2:18","category":"$undefined"},{"id":"1574","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":19,"text":"그들이 가로되 `한 애굽 사람이 우리를 목자들의 손에서 건져내고 우리를 위하여 물을 길어 양무리에게 먹였나이다'","reference":"출애굽기 2:19","category":"$undefined"},{"id":"1575","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":20,"text":"아비가 딸들에게 이르되 `그 사람이 어디 있느냐 ? 너희가 어찌하여 그 사람을 버리고 왔느냐 ? 그를 청하여 음식으로 대접하라' 하였더라","reference":"출애굽기 2:20","category":"$undefined"},{"id":"1576","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":21,"text":"모세가 그와 동거하기를 기뻐하매 그가 그 딸 십보라를 모세에게 주었더니","reference":"출애굽기 2:21","category":"$undefined"},{"id":"1577","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":22,"text":"그가 아들을 낳으매 모세가 그 이름을 게르솜이라 하여 가로되 `내가 타국에서 객이 되었음이라' 하였더라","reference":"출애굽기 2:22","category":"$undefined"},{"id":"1578","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":23,"text":"여러 해 후에 애굽 왕은 죽었고 이스라엘 자손은 고역으로 인하여 탄식하며 부르짖으니 그 고역으로 인하여 부르짖는 소리가 하나님께 상달한지라","reference":"출애굽기 2:23","category":"$undefined"},{"id":"1579","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":24,"text":"하나님이 그 고통 소리를 들으시고 아브라함과 이삭과 야곱에게 세운 그 언약을 기억하사","reference":"출애굽기 2:24","category":"$undefined"},{"id":"1580","book":"출애굽기","book_name":"출애굽기","chapter":2,"verse":25,"text":"이스라엘 자손을 권념하셨더라","reference":"출애굽기 2:25","category":"$undefined"}],"bookSlug":"exodus"}]
