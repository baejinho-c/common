2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":20,"verses":[{"id":"2053","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":1,"text":"하나님이 이 모든 말씀으로 일러 가라사대","reference":"출애굽기 20:1","category":"$undefined"},{"id":"2054","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":2,"text":"나는 너를 애굽 땅 종 되었던 집에서 인도하여 낸 너의 하나님 여호와로라","reference":"출애굽기 20:2","category":"$undefined"},{"id":"2055","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":3,"text":"너는 나 외에는 다른 신들을 네게 있게 말지니라 !","reference":"출애굽기 20:3","category":"$undefined"},{"id":"2056","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":4,"text":"너를 위하여 새긴 우상을 만들지 말고 또 위로 하늘에 있는 것이나 아래로 땅에 있는 것이나 땅 아래 물 속에 있는 것의 아무 형상이든지 만들지 말며","reference":"출애굽기 20:4","category":"$undefined"},{"id":"2057","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":5,"text":"그것들에게 절하지 말며 그것들을 섬기지 말라 ! 나 여호와 너의 하나님은 질투하는 하나님인즉 나를 미워하는 자의 죄를 갚되 아비로부터 아들에게로 삼 사대까지 이르게 하거니와","reference":"출애굽기 20:5","category":"$undefined"},{"id":"2058","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":6,"text":"나를 사랑하고 내 계명을 지키는 자에게는 천대까지 은혜를 베푸느니라","reference":"출애굽기 20:6","category":"$undefined"},{"id":"2059","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":7,"text":"너는 너의 하나님 여호와의 이름을 망령되이 일컫지 말라 ! 나 여호와의 이름을 망령되이 일컫는 자를 죄 없다 하지 아니하리라","reference":"출애굽기 20:7","category":"$undefined"},{"id":"2060","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":8,"text":"안식일을 기억하여 거룩히 지키라 !","reference":"출애굽기 20:8","category":"$undefined"},{"id":"2061","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":9,"text":"엿새 동안은 힘써 네 모든 일을 행할 것이나","reference":"출애굽기 20:9","category":"$undefined"},{"id":"2062","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":10,"text":"제 칠일은 너의 하나님 여호와의 안식일인즉 너나 네 아들이나 네 육축이나 네 문안에 유하는 객이라도 아무 일도 하지 말라","reference":"출애굽기 20:10","category":"$undefined"},{"id":"2063","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":11,"text":"이는 엿새 동안에 나 여호와가 하늘과 땅과 바다와 그 가운데 모든 것을 만들고 제 칠일에 쉬었음이라 그러므로 나 여호와가 안식일을 복되게 하여 그 날을 거룩하게 하였느니라","reference":"출애굽기 20:11","category":"$undefined"},{"id":"2064","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":12,"text":"네 부모를 공경하라 ! 그리하면 너의 하나님 나 여호와가 네게 준 땅에서 네 생명이 길리라","reference":"출애굽기 20:12","category":"$undefined"},{"id":"2065","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":13,"text":"살인하지 말지니라 !","reference":"출애굽기 20:13","category":"$undefined"},{"id":"2066","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":14,"text":"간음하지 말지니라 !","reference":"출애굽기 20:14","category":"$undefined"},{"id":"2067","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":15,"text":"도적질하지 말지니라 !","reference":"출애굽기 20:15","category":"$undefined"},{"id":"2068","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":16,"text":"네 이웃에 대하여 거짓 증거하지 말지니라 !","reference":"출애굽기 20:16","category":"$undefined"},{"id":"2069","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":17,"text":"네 이웃의 집을 탐내지 말지니라 ! 네 이웃의 아내나, 그의 남종이나, 그의 여종이나, 그의 소나, 그의 나귀나, 무릇 네 이웃의 소유를 탐내지 말지니라 !","reference":"출애굽기 20:17","category":"$undefined"},{"id":"2070","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":18,"text":"뭇 백성이 우뢰와 번개와 나팔소리와 산의 연기를 본지라 그들이 볼 때에 떨며 멀리 서서","reference":"출애굽기 20:18","category":"$undefined"},{"id":"2071","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":19,"text":"모세에게 이르되 `당신이 우리에게 말씀하소서 우리가 들으리이다 하나님이 우리에게 말씀하시지 말게 하소서 우리가 죽을까 하나이다'","reference":"출애굽기 20:19","category":"$undefined"},{"id":"2072","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":20,"text":"모세가 백성에게 이르되 `두려워 말라 ! 하나님이 강림하심은 너희를 시험하고 너희로 경외하여 범죄치 않게 하려 하심이니라'","reference":"출애굽기 20:20","category":"$undefined"},{"id":"2073","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":21,"text":"백성은 멀리 섰고 모세는 하나님의 계신 암흑으로 가까이 가니라","reference":"출애굽기 20:21","category":"$undefined"},{"id":"2074","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":22,"text":"여호와께서 모세에게 이르시되 너는 이스라엘 자손에게 이같이 이르라 내가 하늘에서부터 너희에게 말하는 것을 너희가 친히 보았으니","reference":"출애굽기 20:22","category":"$undefined"},{"id":"2075","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":23,"text":"너희는 나를 비겨서 은으로 신상이나 금으로 신상을 너희를 위하여 만들지 말고","reference":"출애굽기 20:23","category":"$undefined"},{"id":"2076","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":24,"text":"내게 토단을 쌓고 그 위에 너의 양과 소로 너의 번제와 화목제를 드리라 내가 무릇 내 이름을 기념하게 하는 곳에서 네게 강림하여 복을 주리라","reference":"출애굽기 20:24","category":"$undefined"},{"id":"2077","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":25,"text":"네가 내게 돌로 단을 쌓거든 다듬은 돌로 쌓지 말라 네가 정으로 그것을 쪼면 부정하게 함이니라","reference":"출애굽기 20:25","category":"$undefined"},{"id":"2078","book":"출애굽기","book_name":"출애굽기","chapter":20,"verse":26,"text":"너는 층계로 내 단에 오르지 말라 네 하체가 그 위에서 드러날까 함이니라","reference":"출애굽기 20:26","category":"$undefined"}],"bookSlug":"exodus"}]
