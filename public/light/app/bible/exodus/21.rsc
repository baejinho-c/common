11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":21,"verses":[{"id":"2079","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":1,"text":"네가 백성 앞에 세울 율례는 이러하니라","reference":"출애굽기 21:1","category":"$undefined"},{"id":"2080","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":2,"text":"네가 히브리 종을 사면 그가 육년 동안 섬길 것이요 제 칠년에는 값 없이 나가 자유할 것이요","reference":"출애굽기 21:2","category":"$undefined"},{"id":"2081","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":3,"text":"그가 단신으로 왔으면 단신으로 나갈 것이요, 장가 들었으면 그 아내도 그와 함께 나가려니와","reference":"출애굽기 21:3","category":"$undefined"},{"id":"2082","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":4,"text":"상전이 그에게 아내를 줌으로 그 아내가 자녀간 낳았으면 그 아내와 그 자식들은 상전에게 속할 것이요 그는 단신으로 나갈 것이로되","reference":"출애굽기 21:4","category":"$undefined"},{"id":"2083","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":5,"text":"종이 진정으로 말하기를 `내가 상전과 내 처자를 사랑하니 나가서 자유하지 않겠노라' 하면","reference":"출애굽기 21:5","category":"$undefined"},{"id":"2084","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":6,"text":"상전이 그를 데리고 재판장에게로 갈 것이요 또 그를 문이나 문설주 앞으로 데리고 가서 그것에다가 송곳으로 그 귀를 뚫을 것이라 그가 영영히 그 상전을 섬기리라","reference":"출애굽기 21:6","category":"$undefined"},{"id":"2085","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":7,"text":"사람이 그 딸을 여종으로 팔았으면 그는 남종 같이 나오지 못할지며","reference":"출애굽기 21:7","category":"$undefined"},{"id":"2086","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":8,"text":"만일 상전이 그를 기뻐 아니하여 상관치 아니하면 그를 속신케 할것이나 그 여자를 속임이 되었으니 타국인에게 팔지 못할 것이요","reference":"출애굽기 21:8","category":"$undefined"},{"id":"2087","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":9,"text":"만일 그를 자기 아들에게 주기로 하였으면 그를 딸 같이 대접 할것이요","reference":"출애굽기 21:9","category":"$undefined"},{"id":"2088","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":10,"text":"만일 상전이 달리 장가를 들지라도 그의 의복과 음식과 동침하는 것은 끊지 못할 것이요","reference":"출애굽기 21:10","category":"$undefined"},{"id":"2089","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":11,"text":"이 세가지를 시행하지 아니하면 그는 속전을 내지 않고 거저 나가게 할 것이니라","reference":"출애굽기 21:11","category":"$undefined"},{"id":"2090","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":12,"text":"사람을 쳐 죽인 자는 반드시 죽일 것이나","reference":"출애굽기 21:12","category":"$undefined"},{"id":"2091","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":13,"text":"만일 사람이 계획한 일이 아니라 나 하나님이 사람을 그 손에 붙임이면 내가 위하여 한 곳을 정하리니 그 사람이 그리로 도망할 것이며","reference":"출애굽기 21:13","category":"$undefined"},{"id":"2092","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":14,"text":"사람이 그 이웃을 짐짓 모살하였으면 너는 그를 내 단에서라도 잡아내어 죽일지니라 !","reference":"출애굽기 21:14","category":"$undefined"},{"id":"2093","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":15,"text":"자기 아비나 어미를 치는 자는 반드시 죽일지니라 !","reference":"출애굽기 21:15","category":"$undefined"},{"id":"2094","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":16,"text":"사람을 후린 자가 그 사람을 팔았든지 자기 수하에 두었든지 그를 반드시 죽일지니라 !","reference":"출애굽기 21:16","category":"$undefined"},{"id":"2095","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":17,"text":"그 아비나 어미를 저주하는 자는 반드시 죽일지니라 !","reference":"출애굽기 21:17","category":"$undefined"},{"id":"2096","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":18,"text":"사람이 서로 싸우다가 하나가 돌이나 주먹으로 그 적수를 쳤으나 그가 죽지 않고 자리에 누었다가","reference":"출애굽기 21:18","category":"$undefined"},{"id":"2097","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":19,"text":"지팡이를 짚고 기동하면 그를 친 자가 형벌은 면하되 기간 손해를 배상하고 그로 전치되게 할지니라","reference":"출애굽기 21:19","category":"$undefined"},{"id":"2098","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":20,"text":"사람이 매로 그 남종이나 여종을 쳐서 당장에 죽으면 반드시 형벌을 받으려니와","reference":"출애굽기 21:20","category":"$undefined"},{"id":"2099","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":21,"text":"그가 일일이나 이일을 연명하면 형벌을 면하리니 그는 상전의 금전임이니라","reference":"출애굽기 21:21","category":"$undefined"},{"id":"2100","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":22,"text":"사람이 서로 싸우다가 아이 밴 여인을 다쳐 낙태케 하였으나 다른 해가 없으면 그 남편의 청구대로 반드시 벌금을 내되 재판장의 판결을 좇아 낼 것이니라","reference":"출애굽기 21:22","category":"$undefined"},{"id":"2101","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":23,"text":"그러나 다른 해가 있으면 갚되 생명은 생명으로,","reference":"출애굽기 21:23","category":"$undefined"},{"id":"2102","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":24,"text":"눈은 눈으로, 이는 이로, 손은 손으로, 발은 발로","reference":"출애굽기 21:24","category":"$undefined"},{"id":"2103","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":25,"text":"데운 것은 데움으로, 상하게 한것은 상함으로, 때린 것은 때림으로 갚을지니라 !","reference":"출애굽기 21:25","category":"$undefined"},{"id":"2104","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":26,"text":"사람이 그 남종의 한 눈이나 여종의 한 눈을 쳐서 상하게 하면 그 눈 대신에 그를 놓을 것이며","reference":"출애굽기 21:26","category":"$undefined"},{"id":"2105","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":27,"text":"그 남종의 한 이나 여종의 한 이를 쳐서 빠뜨리면 그 이 대신에 그를 놓을지니라","reference":"출애굽기 21:27","category":"$undefined"},{"id":"2106","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":28,"text":"소가 남자나 여자를 받아서 죽이면 그 소는 반드시 돌에 맞아 죽을 것이요 그 고기는 먹지 말 것이며 임자는 형벌을 면하려니와","reference":"출애굽기 21:28","category":"$undefined"},{"id":"2107","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":29,"text":"소는 본래 받는 버릇이 있고 그 임자는 그로 인하여 경고를 받았으되 단속하지 아니하므로 남녀 간에 받아 죽이면 그 소는 돌로 쳐 죽일 것이고 임자도 죽일 것이며","reference":"출애굽기 21:29","category":"$undefined"},{"id":"2108","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":30,"text":"만일 그에게 속죄금을 명하면 무릇 그 명한 것을 생명의 속으로 낼 것이요","reference":"출애굽기 21:30","category":"$undefined"},{"id":"2109","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":31,"text":"아들을 받든지 딸을 받든지 이 율례대로 그 임자에게 행할 것이며","reference":"출애굽기 21:31","category":"$undefined"},{"id":"2110","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":32,"text":"소가 만일 남종이나 여종을 받으면 소 임자가 은 삼십 세겔을 그 상전에게 줄 것이요 소는 돌에 맞아 죽을지니라 !","reference":"출애굽기 21:32","category":"$undefined"},{"id":"2111","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":33,"text":"사람이 구덩이를 열어 두거나 구덩이를 파고 덮지 아니함으로 소나 나귀가 거기에 빠지면","reference":"출애굽기 21:33","category":"$undefined"},{"id":"2112","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":34,"text":"그 구덩이 주인이 잘 조처하여 짐승의 임자에게 돈을 줄 것이요 죽은 것은 그의 차지가 될지니라 !","reference":"출애굽기 21:34","category":"$undefined"},{"id":"2113","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":35,"text":"이 사람의 소가 저 사람의 소를 받아 죽이면 산 소를 팔아 그 값을 반분하고 죽은 것도 반분하려니와","reference":"출애굽기 21:35","category":"$undefined"},{"id":"2114","book":"출애굽기","book_name":"출애굽기","chapter":21,"verse":36,"text":"그 소가 본래 받는 버릇이 있는 줄을 알고도 그 임자가 단속하지 아니하였으면 그는 소로 소를 갚을 것이요 죽은 것은 그의 차지가 될지니라","reference":"출애굽기 21:36","category":"$undefined"}],"bookSlug":"exodus"}]
