2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":22,"verses":[{"id":"2115","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":1,"text":"사람이 소나 양을 도적질하여 잡거나 팔면 그는 소 하나에 소 다섯으로 갚고 양 하나에 양 넷으로 갚을지니라 !","reference":"출애굽기 22:1","category":"$undefined"},{"id":"2116","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":2,"text":"도적이 뚫고 들어옴을 보고 그를 쳐 죽이면 피 흘린 죄가 없으나","reference":"출애굽기 22:2","category":"$undefined"},{"id":"2117","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":3,"text":"해 돋은 후이면 피 흘린 죄가 있으리라 도적은 반드시 배상할 것이나 배상할 것이 없으면 그 몸을 팔아 그 도적질한 것을 배상할 것이요","reference":"출애굽기 22:3","category":"$undefined"},{"id":"2118","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":4,"text":"도적질한 것이 살아 그 손에 있으면 소나 나귀나 양을 무론하고 갑절을 배상할지니라 !","reference":"출애굽기 22:4","category":"$undefined"},{"id":"2119","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":5,"text":"사람이 밭에서나 포도원에서 먹이다가 그 짐승을 놓아서 남의 밭에서 먹게 하면 자기 밭의 제일 좋은 것과 자기 포도원의 제일 좋은 것으로 배상할지니라 !","reference":"출애굽기 22:5","category":"$undefined"},{"id":"2120","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":6,"text":"불이 나서 가시나무에 미쳐 낟가리나 거두지 못한 곡식이나 전원을 태우면 불 놓은 자가 반드시 배상할지니라 !","reference":"출애굽기 22:6","category":"$undefined"},{"id":"2121","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":7,"text":"사람이 돈이나 물품을 이웃에게 맡겨 지키게 하였다가 그 이웃의 집에서 봉적하였는데 그 도적이 잡히면 갑절을 배상할 것이요","reference":"출애굽기 22:7","category":"$undefined"},{"id":"2122","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":8,"text":"도적이 잡히지 아니하면 그 집 주인이 재판장 앞에 가서 자기가 그 이웃의 물품에 손 댄 여부의 조사를 받을 것이며","reference":"출애굽기 22:8","category":"$undefined"},{"id":"2123","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":9,"text":"어떠한 과실에든지, 소에든지, 나귀에든지, 양에든지, 의복에든지, 또는 아무 잃은 물건에든지, 그것에 대하여 혹이 이르기를 이것이 그것이라 하면 두 편이 재판장 앞에 나아갈 것이요 재판장이 죄 있다고 하는 자가 그 상대편에게 갑절을 배상할지니라 !","reference":"출애굽기 22:9","category":"$undefined"},{"id":"2124","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":10,"text":"사람이 나귀나 소나 양이나 다른 짐승을 이웃에게 맡겨 지키게 하였다가 죽거나 상하거나 몰려가도 본 사람이 없으면","reference":"출애굽기 22:10","category":"$undefined"},{"id":"2125","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":11,"text":"두 사람 사이에 맡은 자가 이웃의 것에 손을 대지 아니하였다고 여호와로 맹세할 것이요 그 임자는 그대로 믿을 것이며 그 사람은 배상하지 아니하려니와","reference":"출애굽기 22:11","category":"$undefined"},{"id":"2126","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":12,"text":"만일 자기에게서 봉적하였으면 그 임자에게 배상할 것이며","reference":"출애굽기 22:12","category":"$undefined"},{"id":"2127","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":13,"text":"만일 찢겼으면 그것을 가져다가 증거할 것이요 그 찢긴 것에 대하여 배상하지 않을지니라 !","reference":"출애굽기 22:13","category":"$undefined"},{"id":"2128","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":14,"text":"만일 이웃에게 빌어온 것이 그 임자가 함께 있지 아니할 때에 상하거나 죽으면 반드시 배상하려니와","reference":"출애굽기 22:14","category":"$undefined"},{"id":"2129","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":15,"text":"그 임자가 그것과 함께 하였으면 배상하지 않을지며 세 낸것도 세를 위하여 왔은즉 배상하지 않을지니라 !","reference":"출애굽기 22:15","category":"$undefined"},{"id":"2130","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":16,"text":"사람이 정혼하지 아니한 처녀를 꾀어 동침하였으면 빙폐를 드려 아내로 삼을 것이요","reference":"출애굽기 22:16","category":"$undefined"},{"id":"2131","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":17,"text":"만일 그 아비가 그로 그에게 주기를 거절하면 그는 처녀에게 빙폐하는 일례로 돈을 낼지니라 !","reference":"출애굽기 22:17","category":"$undefined"},{"id":"2132","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":18,"text":"너는 무당을 살려 두지 말지니라 !","reference":"출애굽기 22:18","category":"$undefined"},{"id":"2133","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":19,"text":"짐승과 행음하는 자는 반드시 죽일지니라 !","reference":"출애굽기 22:19","category":"$undefined"},{"id":"2134","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":20,"text":"여호와 외에 다른 신에게 희생을 드리는 자는 멸할지니라 !","reference":"출애굽기 22:20","category":"$undefined"},{"id":"2135","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":21,"text":"너는 이방 나그네를 압제하지 말며 그들을 학대하지 말라 너희도 애굽 땅에서 나그네이었었음이니라","reference":"출애굽기 22:21","category":"$undefined"},{"id":"2136","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":22,"text":"너는 과부나 고아를 해롭게 하지 말라 !","reference":"출애굽기 22:22","category":"$undefined"},{"id":"2137","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":23,"text":"네가 만일 그들을 해롭게 하므로 그들이 내게 부르짖으면 내가 반드시 그 부르짖음을 들을지라","reference":"출애굽기 22:23","category":"$undefined"},{"id":"2138","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":24,"text":"나의 노가 맹렬하므로 내가 칼로 너희를 죽이리니 너희 아내는 과부가 되고 너희 자녀는 고아가 되리라","reference":"출애굽기 22:24","category":"$undefined"},{"id":"2139","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":25,"text":"네가 만일 너와 함께한 나의 백성 중 가난한 자에게 돈을 꾸이거든 너는 그에게 채주같이 하지 말며 변리를 받지 말 것이며","reference":"출애굽기 22:25","category":"$undefined"},{"id":"2140","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":26,"text":"네가 만일 이웃의 옷을 전당잡거든 해가 지기 전에 그에게 돌려보내라","reference":"출애굽기 22:26","category":"$undefined"},{"id":"2141","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":27,"text":"그 몸을 가릴 것이 이뿐이라 이는 그 살의 옷인즉 그가 무엇을 입고 자겠느냐 ? 그가 내게 부르짖으면 내가 들으리니 나는 자비한자임이니라","reference":"출애굽기 22:27","category":"$undefined"},{"id":"2142","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":28,"text":"너는 재판장을 욕하지 말며 백성의 유사를 저주하지 말지니라 !","reference":"출애굽기 22:28","category":"$undefined"},{"id":"2143","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":29,"text":"너는 너의 추수한 것과 너의 짜낸 즙을 드리기에 더디게 말지며 너의 처음 난 아들들을 내게 줄지며","reference":"출애굽기 22:29","category":"$undefined"},{"id":"2144","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":30,"text":"너의 소와 양도 그 일례로 하되 칠일 동안 어미와 함께 있게 하다가 팔일만에 내게 줄지니라 !","reference":"출애굽기 22:30","category":"$undefined"},{"id":"2145","book":"출애굽기","book_name":"출애굽기","chapter":22,"verse":31,"text":"너희는 내게 거룩한 사람이 될지니 들에서 짐승에게 찢긴 것의 고기를 먹지 말고 개에게 던질지니라 !","reference":"출애굽기 22:31","category":"$undefined"}],"bookSlug":"exodus"}]
