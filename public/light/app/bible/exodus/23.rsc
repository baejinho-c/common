2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":23,"verses":[{"id":"2146","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":1,"text":"너는 허망한 풍설을 전파하지 말며 악인과 연합하여 무함하는 증인이 되지 말며","reference":"출애굽기 23:1","category":"$undefined"},{"id":"2147","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":2,"text":"다수를 따라 악을 행하지 말며 송사에 다수를 따라 부정당한 증거를 하지 말며","reference":"출애굽기 23:2","category":"$undefined"},{"id":"2148","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":3,"text":"가난한 자의 송사라고 편벽되이 두호하지 말지니라 !","reference":"출애굽기 23:3","category":"$undefined"},{"id":"2149","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":4,"text":"네가 만일 네 원수의 길 잃은 소나 나귀를 만나 거든 반드시 그 사람에게로 돌릴지며","reference":"출애굽기 23:4","category":"$undefined"},{"id":"2150","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":5,"text":"네가 만일 너를 미워하는 자의 나귀가 짐을 싣고 엎드러짐을 보거든 삼가 버려두지 말고 그를 도와 그 짐을 부리울지니라 !","reference":"출애굽기 23:5","category":"$undefined"},{"id":"2151","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":6,"text":"너는 가난한 자의 송사라고 공평치 않게 하지 말며","reference":"출애굽기 23:6","category":"$undefined"},{"id":"2152","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":7,"text":"거짓 일을 멀리하며 무죄한 자와 의로운 자를 죽이지 말라 ! 나는 악인을 의롭다 하지 아니하겠노라","reference":"출애굽기 23:7","category":"$undefined"},{"id":"2153","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":8,"text":"너는 뇌물을 받지 말라 ! 뇌물은 밝은 자의 눈을 어둡게 하고 의로운 자의 말을 굽게 하느니라","reference":"출애굽기 23:8","category":"$undefined"},{"id":"2154","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":9,"text":"너는 이방 나그네를 압제하지 말라 ! 너희가 애굽 땅에서 나그네 되었었은즉 나그네의 정경을 아느니라","reference":"출애굽기 23:9","category":"$undefined"},{"id":"2155","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":10,"text":"너는 육년 동안은 너의 땅에 파종하여 그 소산을 거두고","reference":"출애굽기 23:10","category":"$undefined"},{"id":"2156","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":11,"text":"제 칠년에는 갈지말고 묵여 두어서 네 백성의 가난한 자로 먹게하라 그 남은 것은 들짐승이 먹으리라 너의 포도원과 감람원도 그리할지니라","reference":"출애굽기 23:11","category":"$undefined"},{"id":"2157","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":12,"text":"너는 육일 동안에 네 일을 하고 제 칠일에는 쉬라 네 소와 나귀가 쉴 것이며 네 계집 종의 자식과 나그네가 숨을 돌리리라","reference":"출애굽기 23:12","category":"$undefined"},{"id":"2158","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":13,"text":"내가 네게 이른 모든 일을 삼가 지키고 다른 신들의 이름은 부르지도 말며 네 입에서 들리게도 말지니라","reference":"출애굽기 23:13","category":"$undefined"},{"id":"2159","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":14,"text":"너는 매년 삼차 내게 절기를 지킬지니라 !","reference":"출애굽기 23:14","category":"$undefined"},{"id":"2160","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":15,"text":"너는 무교병의 절기를 지키라 ! 내가 네게 명한대로 아빕월의 정한때에 칠일동안 무교병을 먹을지니 이는 그 달에 네가 애굽에서 나왔음이라 빈 손으로 내게 보이지 말지니라 !","reference":"출애굽기 23:15","category":"$undefined"},{"id":"2161","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":16,"text":"맥추절을 지키라 ! 이는 네가 수고하여 밭에 뿌린 것의 첫 열매를 거둠이니라 수장절을 지키라 ! 이는 네가 수고하여 이룬 것을 연종에 밭에서부터 거두어 저장함이니라","reference":"출애굽기 23:16","category":"$undefined"},{"id":"2162","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":17,"text":"너의 모든 남자는 매년 세번씩 주 여호와께 보일지니라 !","reference":"출애굽기 23:17","category":"$undefined"},{"id":"2163","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":18,"text":"너는 내 희생의 피를 유교병과 함께 드리지 말며 내 절기 희생의 기름을 아침까지 남겨 두지 말지니라","reference":"출애굽기 23:18","category":"$undefined"},{"id":"2164","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":19,"text":"너의 토지에서 처음 익은 열매의 첫것을 가져다가 너의 하나님 여호와의 전에 드릴지니라 너는 염소 새끼를 그 어미의 젖으로 삶지 말지니라","reference":"출애굽기 23:19","category":"$undefined"},{"id":"2165","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":20,"text":"내가 사자를 네 앞서 보내어 길에서 너를 보호하여 너로 내가 예비한 곳에 이르게 하리니","reference":"출애굽기 23:20","category":"$undefined"},{"id":"2166","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":21,"text":"너희는 삼가 그 목소리를 청종하고 그를 노엽게 하지 말라 ! 그가 너희 허물을 사하지 아니할 것은 내 이름이 그에게 있음이니라","reference":"출애굽기 23:21","category":"$undefined"},{"id":"2167","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":22,"text":"네가 그 목소리를 잘 청종하고 나의 모든 말대로 행하면 내가 네 원수에게 원수가 되고 네 대적에게 대적이 될지라","reference":"출애굽기 23:22","category":"$undefined"},{"id":"2168","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":23,"text":"나의 사자가 네 앞서가서 너를 아모리 사람과, 헷 사람과, 브리스 사람과, 가나안 사람과, 히위 사람과, 여부스 사람에게로 인도하고 나는 그들을 끊으리니","reference":"출애굽기 23:23","category":"$undefined"},{"id":"2169","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":24,"text":"너는 그들의 신을 숭배하지 말며 섬기지 말며 그들의 소위를 본받지 말며 그것들을 다 훼파하며 그 주상을 타파하고","reference":"출애굽기 23:24","category":"$undefined"},{"id":"2170","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":25,"text":"너의 하나님 여호와를 섬기라 ! 그리하면 여호와가 너희의 양식과 물에 복을 내리고 너희 중에 병을 제하리니","reference":"출애굽기 23:25","category":"$undefined"},{"id":"2171","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":26,"text":"네 나라에 낙태하는 자가 없고 잉태치 못하는 자가 없을 것이라 내가 너의 날 수를 채우리라","reference":"출애굽기 23:26","category":"$undefined"},{"id":"2172","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":27,"text":"내가 내 위엄을 네 앞서 보내어 너의 이를 곳의 모든 백성을 파하고 너의 모든 원수로 너를 등지게 할 것이며","reference":"출애굽기 23:27","category":"$undefined"},{"id":"2173","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":28,"text":"내가 왕벌을 네 앞에 보내리니 그 벌이 히위 족속과, 가나안 족속과, 헷 족속을 네 앞에서 쫓아내리라","reference":"출애굽기 23:28","category":"$undefined"},{"id":"2174","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":29,"text":"그러나 그 땅이 황무하게 되어 들짐승이 번성하여 너희를 해할까 하여 일년 안에는 그들을 네 앞에서 쫓아내지 아니하고","reference":"출애굽기 23:29","category":"$undefined"},{"id":"2175","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":30,"text":"네가 번성하여 그 땅을 기업으로 얻을 때까지 내가 그들을 네 앞에서 조금씩 쫓아내리라","reference":"출애굽기 23:30","category":"$undefined"},{"id":"2176","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":31,"text":"너의 지경을 홍해에서부터 블레셋 바다까지 광야에서부터 하수까지 정하고 그 땅의 거민을 네 앞에서 쫓아낼지라","reference":"출애굽기 23:31","category":"$undefined"},{"id":"2177","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":32,"text":"너는 그들과 그들의 신과 언약하지 말라 !","reference":"출애굽기 23:32","category":"$undefined"},{"id":"2178","book":"출애굽기","book_name":"출애굽기","chapter":23,"verse":33,"text":"그들이 네 땅에 머무르지 못할것은 그들이 너로 내게 범죄케 할까 두려움이라 네가 그 신을 섬기면 그것이 너의 올무가 되리라","reference":"출애굽기 23:33","category":"$undefined"}],"bookSlug":"exodus"}]
