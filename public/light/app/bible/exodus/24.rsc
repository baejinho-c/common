2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":24,"verses":[{"id":"2179","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":1,"text":"또 모세에게 이르시되 너는 아론과 나답과 아비후와 이스라엘 장로 칠십인과 함께 여호와에게로 올라와 멀리서 경배하고","reference":"출애굽기 24:1","category":"$undefined"},{"id":"2180","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":2,"text":"너 모세만 여호와에게 가까이 나아오고 그들은 가까이 나아오지 말며 백성은 너와 함께 올라오지 말지니라 !","reference":"출애굽기 24:2","category":"$undefined"},{"id":"2181","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":3,"text":"모세가 와서 여호와의 모든 말씀과 그 모든 율례를 백성에게 고하매 그들이 한 소리로 응답하여 가로되 '여호와의 명하신 모든 말씀을 우리가 준행하리이다 !'","reference":"출애굽기 24:3","category":"$undefined"},{"id":"2182","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":4,"text":"모세가 여호와의 모든 말씀을 기록하고 이른 아침에 일어나 산 아래 단을 쌓고 이스라엘 십 이 지파대로 열 두 기둥을 세우고","reference":"출애굽기 24:4","category":"$undefined"},{"id":"2183","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":5,"text":"이스라엘 자손의 청년들을 보내어 번제와 소로 화목제를 여호와께 드리게 하고","reference":"출애굽기 24:5","category":"$undefined"},{"id":"2184","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":6,"text":"모세가 피를 취하여 반은 양푼에 담고, 반은 단에 뿌리고","reference":"출애굽기 24:6","category":"$undefined"},{"id":"2185","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":7,"text":"언약서를 가져 백성에게 낭독하여 들리매 그들이 가로되 `여호와의 모든 말씀을 우리가 준행하리이다'","reference":"출애굽기 24:7","category":"$undefined"},{"id":"2186","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":8,"text":"모세가 그 피를 취하여 백성에게 뿌려 가로되 `이는 여호와께서 이 모든 말씀에 대하여 너희와 세우신 언약의 피니라'","reference":"출애굽기 24:8","category":"$undefined"},{"id":"2187","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":9,"text":"모세와 아론과, 나답과, 아비후와 이스라엘 장로 칠십인이 올라가서","reference":"출애굽기 24:9","category":"$undefined"},{"id":"2188","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":10,"text":"이스라엘 하나님을 보니 그 발 아래에는 청옥을 편듯하고 하늘 같이 청명하더라","reference":"출애굽기 24:10","category":"$undefined"},{"id":"2189","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":11,"text":"하나님이 이스라엘의 존귀한 자들에게 손을 대지 아니하셨고 그들은 하나님을 보고 먹고 마셨더라","reference":"출애굽기 24:11","category":"$undefined"},{"id":"2190","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":12,"text":"여호와께서 모세에게 이르시되 너는 산에 올라 내게로 와서 거기 있으라 너로 그들을 가르치려고 내가 율법과 계명을 친히 기록한 돌판을 네게 주리라","reference":"출애굽기 24:12","category":"$undefined"},{"id":"2191","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":13,"text":"모세가 그 종자 여호수아와 함께 일어나 하나님의 산으로 올라가며","reference":"출애굽기 24:13","category":"$undefined"},{"id":"2192","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":14,"text":"장로들에게 이르되 `너희는 여기서 우리가 너희에게로 돌아오기까지 기다리라 아론과 훌이 너희와 함께하리니 무릇 일이 있는 자는 그들에게로 나아갈지니라' 하고","reference":"출애굽기 24:14","category":"$undefined"},{"id":"2193","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":15,"text":"모세가 산에 오르매 구름이 산을 가리며","reference":"출애굽기 24:15","category":"$undefined"},{"id":"2194","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":16,"text":"여호와의 영광이 시내산 위에 머무르고 구름이 육일 동안 산을 가리더니 제 칠일에 여호와께서 구름 가운데 모세를 부르시니라","reference":"출애굽기 24:16","category":"$undefined"},{"id":"2195","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":17,"text":"산 위의 여호와의 영광이 이스라엘 자손의 눈에 맹렬한 불 같이 보였고","reference":"출애굽기 24:17","category":"$undefined"},{"id":"2196","book":"출애굽기","book_name":"출애굽기","chapter":24,"verse":18,"text":"모세는 구름 속으로 들어가서 산 위에 올랐으며 사십일 사십야를 산에 있으니라","reference":"출애굽기 24:18","category":"$undefined"}],"bookSlug":"exodus"}]
