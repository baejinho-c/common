2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":25,"verses":[{"id":"2197","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 25:1","category":"$undefined"},{"id":"2198","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":2,"text":"이스라엘 자손에게 명하여 내게 예물을 가져오라 하고 무릇 즐거운 마음으로 내는 자에게서 내게 드리는 것을 너희는 받을지니라","reference":"출애굽기 25:2","category":"$undefined"},{"id":"2199","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":3,"text":"너희가 그들에게서 받을 예물은 이러하니 금과 은과 놋과","reference":"출애굽기 25:3","category":"$undefined"},{"id":"2200","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":4,"text":"청색, 자색, 홍색실과, 가는 베실과, 염소털과,","reference":"출애굽기 25:4","category":"$undefined"},{"id":"2201","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":5,"text":"붉은 물 들인 수양의 가죽과, 해달의 가죽과, 조각목과,","reference":"출애굽기 25:5","category":"$undefined"},{"id":"2202","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":6,"text":"등유와 관유에 드는 향품과 분향할 향을 만들 향품과","reference":"출애굽기 25:6","category":"$undefined"},{"id":"2203","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":7,"text":"호마노며 에봇과 흉패에 물릴 보석이니라","reference":"출애굽기 25:7","category":"$undefined"},{"id":"2204","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":8,"text":"내가 그들 중에 거할 성소를 그들을 시켜 나를 위하여 짓되","reference":"출애굽기 25:8","category":"$undefined"},{"id":"2205","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":9,"text":"무릇 내가 네게 보이는대로 장막의 식양과 그 기구의 식양을 따라 지을지니라","reference":"출애굽기 25:9","category":"$undefined"},{"id":"2206","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":10,"text":"그들은 조각목으로 궤를 짓되 장이 이 규빗 반, 광이 일 규빗 반, 고가 일 규빗 반이 되게 하고","reference":"출애굽기 25:10","category":"$undefined"},{"id":"2207","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":11,"text":"너는 정금으로 그것을 싸되 그 안팎을 싸고 윗가로 돌아가며 금테를 두르고","reference":"출애굽기 25:11","category":"$undefined"},{"id":"2208","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":12,"text":"금고리 넷을 부어 만들어 그 네 발에 달되 이편에 두 고리요, 저편에 두 고리며","reference":"출애굽기 25:12","category":"$undefined"},{"id":"2209","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":13,"text":"조각목으로 채를 만들고 금으로 싸고","reference":"출애굽기 25:13","category":"$undefined"},{"id":"2210","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":14,"text":"그 채를 궤 양편 고리에 꿰어서 궤를 메게 하며","reference":"출애굽기 25:14","category":"$undefined"},{"id":"2211","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":15,"text":"채를 궤의 고리에 꿴대로 두고 빼어내지 말지며","reference":"출애굽기 25:15","category":"$undefined"},{"id":"2212","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":16,"text":"내가 네게 줄 증거판을 궤 속에 둘지며","reference":"출애굽기 25:16","category":"$undefined"},{"id":"2213","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":17,"text":"정금으로 속죄소를 만들되 장이 이 규빗 반,광이 일 규빗 반이 되게 하고","reference":"출애굽기 25:17","category":"$undefined"},{"id":"2214","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":18,"text":"금으로 그룹 둘을 속죄소 두 끝에 쳐서 만들되","reference":"출애굽기 25:18","category":"$undefined"},{"id":"2215","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":19,"text":"한 그룹은 이 끝에,한 그룹은 저 끝에 곧 속죄소 두 끝에 속죄소와 한 덩이로 연하게 할지며","reference":"출애굽기 25:19","category":"$undefined"},{"id":"2216","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":20,"text":"그룹들은 그 날개를 높이 펴서 그 날개로 속죄소를 덮으며 그 얼굴을 서로 대하여 속죄소를 향하게 하고","reference":"출애굽기 25:20","category":"$undefined"},{"id":"2217","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":21,"text":"속죄소를 궤 위에 얹고 내가 네게 줄 증거판을 궤 속에 넣으라","reference":"출애굽기 25:21","category":"$undefined"},{"id":"2218","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":22,"text":"거기서 내가 너와 만나고 속죄소 위 곧 증거궤 위에 있는 두 그룹 사이에서 내가 이스라엘 자손을 위하여 네게 명할 모든 일을 네게 이르리라","reference":"출애굽기 25:22","category":"$undefined"},{"id":"2219","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":23,"text":"너는 조각목으로 상을 만들되 장이 이 규빗, 광이 일 규빗, 고가 일 규빗 반이 되게 하고","reference":"출애굽기 25:23","category":"$undefined"},{"id":"2220","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":24,"text":"정금으로 싸고 주위에 금테를 두르고","reference":"출애굽기 25:24","category":"$undefined"},{"id":"2221","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":25,"text":"그 사면에 손바닥 넓이만한 턱을 만들고 그 턱 주위에 금으로 테를 만들고","reference":"출애굽기 25:25","category":"$undefined"},{"id":"2222","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":26,"text":"그것을 위하여 금고리 넷을 만들어 네 발위 네 모퉁이에 달되","reference":"출애굽기 25:26","category":"$undefined"},{"id":"2223","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":27,"text":"턱 곁에 달라 이는 상 멜 채를 꿸 곳이며","reference":"출애굽기 25:27","category":"$undefined"},{"id":"2224","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":28,"text":"또 조각목으로 그 채를 만들고 금으로 싸라 상을 이것으로 멜 것이니라","reference":"출애굽기 25:28","category":"$undefined"},{"id":"2225","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":29,"text":"너는 대접과, 숟가락과, 병과 붓는 잔을 만들되 정금으로 만들지며","reference":"출애굽기 25:29","category":"$undefined"},{"id":"2226","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":30,"text":"상 위에 진설병을 두어 항상 내 앞에 있게 할지니라 !","reference":"출애굽기 25:30","category":"$undefined"},{"id":"2227","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":31,"text":"너는 정금으로 등대를 쳐서 만들되 그 밑판과, 줄기와, 잔과, 꽃받침과, 꽃을 한 덩이로 연하게 하고","reference":"출애굽기 25:31","category":"$undefined"},{"id":"2228","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":32,"text":"가지 여섯을 등대 곁에서 나오게 하되 그 세 가지는 이편으로 나오고 그 세 가지는 저편으로 나오게 하며","reference":"출애굽기 25:32","category":"$undefined"},{"id":"2229","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":33,"text":"이편 가지에 살구 꽃 형상의 잔 셋과 꽃받침과 꽃이 있게 하고 저편 가지에도 살구꽃 형상의 잔 셋과 꽃받침과 꽃이 있게 하여 등대에서 나온 여섯 가지를 같게 할지며","reference":"출애굽기 25:33","category":"$undefined"},{"id":"2230","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":34,"text":"등대 줄기에는 살구꽃 형상의 잔 넷과 꽃받침과 꽃이 있게 하고","reference":"출애굽기 25:34","category":"$undefined"},{"id":"2231","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":35,"text":"등대에서 나온 여섯 가지를 위하여 꽃받침이 있게 하되 두 가지 아래 한 꽃받침이 있어 줄기와 연하게 하며 또 두 가지 아래 한 꽃받침이 있어 줄기와 연하게 하고","reference":"출애굽기 25:35","category":"$undefined"},{"id":"2232","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":36,"text":"그 꽃받침과 가지를 줄기와 연하게 하여 전부를 정금으로 쳐 만들고","reference":"출애굽기 25:36","category":"$undefined"},{"id":"2233","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":37,"text":"등잔 일곱을 만들어 그 위에 두어 앞을 비추게 하며","reference":"출애굽기 25:37","category":"$undefined"},{"id":"2234","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":38,"text":"그 불집게와 불똥 그릇도 정금으로 만들지니","reference":"출애굽기 25:38","category":"$undefined"},{"id":"2235","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":39,"text":"등대와 이 모든 기구를 정금 한 달란트로 만들되","reference":"출애굽기 25:39","category":"$undefined"},{"id":"2236","book":"출애굽기","book_name":"출애굽기","chapter":25,"verse":40,"text":"너는 삼가 이 산에서 네게 보인 식양대로 할지니라 !","reference":"출애굽기 25:40","category":"$undefined"}],"bookSlug":"exodus"}]
