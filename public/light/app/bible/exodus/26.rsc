11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":26,"verses":[{"id":"2237","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":1,"text":"너는 성막을 만들되 앙장 열 폭을 가늘게 꼰 베실과, 청색, 자색, 홍색실로 그룹을 공교히 수 놓아 만들지니","reference":"출애굽기 26:1","category":"$undefined"},{"id":"2238","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":2,"text":"매 폭의 장은 이십 팔 규빗,광은 사 규빗으로 각 폭의 장단을 같게 하고","reference":"출애굽기 26:2","category":"$undefined"},{"id":"2239","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":3,"text":"그 앙장 다섯 폭을 서로 연하며, 다른 다섯 폭도 서로 연하고","reference":"출애굽기 26:3","category":"$undefined"},{"id":"2240","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":4,"text":"그 앙장의 연락할 말폭 가에 청색 고를 만들며, 다른 연락할 말폭가에도 그와 같이 하고","reference":"출애굽기 26:4","category":"$undefined"},{"id":"2241","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":5,"text":"앙장 말폭 가에 고 오십을 달며, 다른 앙장 말폭 가에도 고 오십을 달고 그 고들을 서로 대하게 하고","reference":"출애굽기 26:5","category":"$undefined"},{"id":"2242","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":6,"text":"금 갈고리 오십을 만들고, 그 갈고리로 앙장을 연합하여 한 성막을 이룰지며","reference":"출애굽기 26:6","category":"$undefined"},{"id":"2243","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":7,"text":"그 성막을 덮는 막 곧 앙장을 염소털로 만들되 열 한폭을 만들지며","reference":"출애굽기 26:7","category":"$undefined"},{"id":"2244","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":8,"text":"각 폭의 장은 삼십 규빗,광은 사 규빗으로 열 한폭의 장단을 같게 하고","reference":"출애굽기 26:8","category":"$undefined"},{"id":"2245","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":9,"text":"그 앙장 다섯 폭을 서로 연하며, 또 여섯 폭을 서로 연하고, 그 여섯째 폭 절반은 성막 전면에 접어 드리우고","reference":"출애굽기 26:9","category":"$undefined"},{"id":"2246","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":10,"text":"앙장을 연락할 말폭 가에 고 오십을 달며, 다른 연락할 말폭 가에도 고 오십을 달고","reference":"출애굽기 26:10","category":"$undefined"},{"id":"2247","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":11,"text":"놋 갈고리 오십을 만들고, 그 갈고리로 그 고를 꿰어 연합하여 한 막이 되게 하고","reference":"출애굽기 26:11","category":"$undefined"},{"id":"2248","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":12,"text":"그 막 곧 앙장의 나머지 그 반폭은 성막 뒤에 드리우고","reference":"출애굽기 26:12","category":"$undefined"},{"id":"2249","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":13,"text":"막 곧 앙장의 길이의 남은 것은 이편에 한 규빗,저편에 한 규빗씩 성막 좌우 양편에 덮어 드리우고","reference":"출애굽기 26:13","category":"$undefined"},{"id":"2250","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":14,"text":"붉은 물 들인 수양의 가죽으로 막의 덮개를 만들고, 해달의 가죽으로 그 웃덮개를 만들지니라 !","reference":"출애굽기 26:14","category":"$undefined"},{"id":"2251","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":15,"text":"너는 조각목으로 성막을 위하여 널판을 만들어 세우되","reference":"출애굽기 26:15","category":"$undefined"},{"id":"2252","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":16,"text":"각 판의 장은 십 규빗,광은 일 규빗 반으로 하고","reference":"출애굽기 26:16","category":"$undefined"},{"id":"2253","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":17,"text":"각 판에 두 촉씩 내어 서로 연하게 하되 너는 성막 널판을 다 그와 같이 하라","reference":"출애굽기 26:17","category":"$undefined"},{"id":"2254","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":18,"text":"너는 성막을 위하여 널판을 만들되, 남편을 위하여 널판 스물을 만들고","reference":"출애굽기 26:18","category":"$undefined"},{"id":"2255","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":19,"text":"스무 널판 아래 은받침 마흔을 만들지니 이 널판 아래에도 그 두촉을 위하여 두 받침을 만들고 저 널판 아래에도 그 두 촉을 위하여 두 받침을 만들지라","reference":"출애굽기 26:19","category":"$undefined"},{"id":"2256","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":20,"text":"성막 다른 편 곧 그 북편을 위하여도 널판 스물로 하고","reference":"출애굽기 26:20","category":"$undefined"},{"id":"2257","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":21,"text":"은받침 마흔을 이 널판 아래에도 두 받침,저 널판 아래에도 두 받침으로 하며","reference":"출애굽기 26:21","category":"$undefined"},{"id":"2258","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":22,"text":"성막 뒤 곧 그 서편을 위하여는 널판 여섯을 만들고","reference":"출애굽기 26:22","category":"$undefined"},{"id":"2259","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":23,"text":"성막 뒤 두 모퉁이 편을 위하여는 널판 둘을 만들되","reference":"출애굽기 26:23","category":"$undefined"},{"id":"2260","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":24,"text":"아래에서부터 위까지 각기 두겹 두께로 하여 윗고리에 이르게 하고 두 모퉁이 편을 다 그리하며","reference":"출애굽기 26:24","category":"$undefined"},{"id":"2261","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":25,"text":"그 여덟 널판에는 은받침이 열 여섯이니 이 판 아래에도 두 받침이요, 저 판 아래에도 두 받침이니라","reference":"출애굽기 26:25","category":"$undefined"},{"id":"2262","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":26,"text":"너는 조각목으로 띠를 만들지니 성막 이편 널판을 위하여 다섯이요","reference":"출애굽기 26:26","category":"$undefined"},{"id":"2263","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":27,"text":"성막 저편 널판을 위하여 다섯이요, 성막 뒤 곧 서편 널판을 위하여 다섯이요,","reference":"출애굽기 26:27","category":"$undefined"},{"id":"2264","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":28,"text":"널판 가운데 있는 중간 띠는 이 끝에서 저 끝에 미치게 하고","reference":"출애굽기 26:28","category":"$undefined"},{"id":"2265","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":29,"text":"그 널판들을 금으로 싸고 그 널판들의 띠를 꿸 금고리를 만들고 그 띠를 금으로 싸라","reference":"출애굽기 26:29","category":"$undefined"},{"id":"2266","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":30,"text":"너는 산에서 보인 식양대로 성막을 세울지니라 !","reference":"출애굽기 26:30","category":"$undefined"},{"id":"2267","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":31,"text":"너는 청색 자색 홍색실과 가늘게 꼰 베실로 짜서 장을 만들고 그 위에 그룹들을 공교히 수 놓아서","reference":"출애굽기 26:31","category":"$undefined"},{"id":"2268","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":32,"text":"금 갈고리로 네 기둥 위에 드리우되 그 네 기둥을 조각목으로 만들고 금으로 싸서 네 은받침 위에 둘지며","reference":"출애굽기 26:32","category":"$undefined"},{"id":"2269","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":33,"text":"그 장을 갈고리 아래 드리운 후에 증거궤를 그 장안에 들여 놓으라 그 장이 너희를 위하여 성소와 지성소를 구별하리라","reference":"출애굽기 26:33","category":"$undefined"},{"id":"2270","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":34,"text":"너는 지성소에 있는 증거궤 위에 속죄소를 두고","reference":"출애굽기 26:34","category":"$undefined"},{"id":"2271","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":35,"text":"그 장 바깥 북편에 상을 놓고 남편에 등대를 놓아 상과 대하게 할지며","reference":"출애굽기 26:35","category":"$undefined"},{"id":"2272","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":36,"text":"청색, 자색, 홍색실과, 가늘게 꼰 베실로 수 놓아 짜서 성막 문을 위하여 장을 만들고","reference":"출애굽기 26:36","category":"$undefined"},{"id":"2273","book":"출애굽기","book_name":"출애굽기","chapter":26,"verse":37,"text":"그 문장을 위하여 기둥 다섯을 조각목으로 만들어 금으로 싸고 그 갈고리도 금으로 만들찌며 또 그 기둥을 위하여 받침 다섯을 놋으로 부어 만들지니라 !","reference":"출애굽기 26:37","category":"$undefined"}],"bookSlug":"exodus"}]
