2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":27,"verses":[{"id":"2274","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":1,"text":"너는 조각목으로 장이 오 규빗, 광이 오 규빗의 단을 만들되 네모 반듯하게 하며 고는 삼 규빗으로 하고","reference":"출애굽기 27:1","category":"$undefined"},{"id":"2275","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":2,"text":"그 네 모퉁이 위에 뿔을 만들되 그 뿔이 그것에 연하게 하고 그 단을 놋으로 쌀지며","reference":"출애굽기 27:2","category":"$undefined"},{"id":"2276","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":3,"text":"재를 담는 통과, 부삽과, 대야와, 고기 갈고리와, 불 옮기는 그릇을 만들되 단의 그릇을 다 놋으로 만들지며","reference":"출애굽기 27:3","category":"$undefined"},{"id":"2277","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":4,"text":"단을 위하여 놋으로 그물을 만들고 그 위 네 모퉁이에 놋고리 넷을 만들고","reference":"출애굽기 27:4","category":"$undefined"},{"id":"2278","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":5,"text":"그물은 단 사면 가장자리 아래 곧 단 절반에 오르게 할지며","reference":"출애굽기 27:5","category":"$undefined"},{"id":"2279","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":6,"text":"또 그 단을 위하여 채를 만들되 조각목으로 만들고 놋으로 쌀지며","reference":"출애굽기 27:6","category":"$undefined"},{"id":"2280","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":7,"text":"단 양편 고리에 그 채를 꿰어 단을 메게 할지며","reference":"출애굽기 27:7","category":"$undefined"},{"id":"2281","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":8,"text":"단은 널판으로 비게 만들되 산에서 네게 보인대로 그들이 만들지니라 !","reference":"출애굽기 27:8","category":"$undefined"},{"id":"2282","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":9,"text":"너는 성막의 뜰을 만들찌니 남을 향하여 뜰 남편에 광이 백 규빗의 세마포장을 쳐서 그 한 편을 당하게 할지니","reference":"출애굽기 27:9","category":"$undefined"},{"id":"2283","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":10,"text":"그 기둥이 스물이며 그 받침 스물은 놋으로 하고 그 기둥의 갈고리와 가름대는 은으로 할찌며","reference":"출애굽기 27:10","category":"$undefined"},{"id":"2284","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":11,"text":"그 북편에도 광이 백 규빗의 포장을 치되 그 기둥이 스물이며 그 기둥의 받침 스물은 놋으로 하고 그 기둥의 갈고리와 가름대는 은으로 할지며","reference":"출애굽기 27:11","category":"$undefined"},{"id":"2285","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":12,"text":"뜰의 옆 곧 서편에 광 오십 규빗의 포장을 치되 그 기둥이 열이요, 받침이 열이며","reference":"출애굽기 27:12","category":"$undefined"},{"id":"2286","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":13,"text":"동을 향하여 뜰 동편의 광도 오십 규빗이 될지며","reference":"출애굽기 27:13","category":"$undefined"},{"id":"2287","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":14,"text":"문 이편을 위하여 포장이 십 오 규빗이며, 그 기둥이 셋이요, 받침이 셋이요","reference":"출애굽기 27:14","category":"$undefined"},{"id":"2288","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":15,"text":"문 저편을 위하여도 포장이 십오 규빗이며, 그 기둥이 셋이요, 받침이 셋이며","reference":"출애굽기 27:15","category":"$undefined"},{"id":"2289","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":16,"text":"뜰 문을 위하여는 청색, 자색, 홍색실과, 가늘게 꼰 베실로 수 놓아 짠 이십 규빗의 장이 있게 할지니 그 기둥이 넷이요, 받침이 넷이며","reference":"출애굽기 27:16","category":"$undefined"},{"id":"2290","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":17,"text":"뜰 사면 모든 기둥의 가름대와 갈고리는 은이요, 그 받침은 놋이며","reference":"출애굽기 27:17","category":"$undefined"},{"id":"2291","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":18,"text":"뜰의 장은 백 규빗이요, 광은 오십 규빗이요, 세마포장의 고는 오규빗이요, 그 받침은 놋이며","reference":"출애굽기 27:18","category":"$undefined"},{"id":"2292","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":19,"text":"성막에서 쓰는 모든 기구와 그 말뚝과 뜰의 포장 말뚝을 다 놋으로 할지니라 !","reference":"출애굽기 27:19","category":"$undefined"},{"id":"2293","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":20,"text":"너는 또 이스라엘 자손에게 명하여 감람으로 찧어낸 순결한 기름을 등불을 위하여 네게로 가져오게 하고 끊이지 말고 등불을 켜되","reference":"출애굽기 27:20","category":"$undefined"},{"id":"2294","book":"출애굽기","book_name":"출애굽기","chapter":27,"verse":21,"text":"아론과 그 아들들로 회막한 증거궤 앞 휘장 밖에서 저녁부터 아침까지 항상 여호와 앞에 그 등불을 간검하게 하라 ! 이는 이스라엘 자손의 대대로 영원한 규례니라","reference":"출애굽기 27:21","category":"$undefined"}],"bookSlug":"exodus"}]
