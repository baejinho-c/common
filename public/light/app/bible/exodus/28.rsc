11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":28,"verses":[{"id":"2295","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":1,"text":"너는 이스라엘 자손 중 네 형 아론과 그 아들들 곧 나답과, 아비후와, 엘르아살과, 이다말을 그와 함께 네게로 나아오게 하여 나를 섬기는 제사장 직분을 행하게 하되","reference":"출애굽기 28:1","category":"$undefined"},{"id":"2296","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":2,"text":"네 형 아론을 위하여 거룩한 옷을 지어서 영화롭고 아름답게 할지니","reference":"출애굽기 28:2","category":"$undefined"},{"id":"2297","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":3,"text":"너는 무릇 마음에 지혜 있는자, 곧 내가 지혜로운 영으로 채운 자들에게 말하여 아론의 옷을 지어 그를 거룩하게 하여 내게 제사장 직분을 행하게 하라","reference":"출애굽기 28:3","category":"$undefined"},{"id":"2298","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":4,"text":"그들의 지을 옷은 이러하니 곧 흉패와, 에봇과, 겉옷과, 반포 속옷과, 관과, 띠라 그들이 네 형 아론과 그 아들들을 위하여 거룩한 옷을 지어 아론으로 내게 제사장 직분을 행하게 할지며","reference":"출애굽기 28:4","category":"$undefined"},{"id":"2299","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":5,"text":"그들의 쓸것은 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실이니라","reference":"출애굽기 28:5","category":"$undefined"},{"id":"2300","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":6,"text":"그들이 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 공교히 짜서 에봇을 짓되","reference":"출애굽기 28:6","category":"$undefined"},{"id":"2301","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":7,"text":"그것에 견대 둘을 달아 그 두 끝을 연하게 하고","reference":"출애굽기 28:7","category":"$undefined"},{"id":"2302","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":8,"text":"에봇 위에 매는 띠는 에봇 짜는 법으로 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 에봇에 공교히 붙여 짤지며","reference":"출애굽기 28:8","category":"$undefined"},{"id":"2303","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":9,"text":"호마노 두개를 취하여 그 위에 이스라엘 아들들의 이름을 새기되","reference":"출애굽기 28:9","category":"$undefined"},{"id":"2304","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":10,"text":"그들의 연치대로 여섯 이름을 한 보석에 나머지 여섯 이름은 다른 보석에","reference":"출애굽기 28:10","category":"$undefined"},{"id":"2305","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":11,"text":"보석을 새기는 자가 인에 새김 같이 너는 이스라엘 아들들의 이름을 그 두 보석에 새겨 금테에 물리고","reference":"출애굽기 28:11","category":"$undefined"},{"id":"2306","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":12,"text":"그 두 보석을 에봇 두 견대에 붙여 이스라엘 아들들의 기념 보석을 삼되 아론이 여호와 앞에서 그들의 이름을 그 두 어깨에 메어서 기념이 되게 할지며","reference":"출애굽기 28:12","category":"$undefined"},{"id":"2307","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":13,"text":"너는 금으로 테를 만들고","reference":"출애굽기 28:13","category":"$undefined"},{"id":"2308","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":14,"text":"정금으로 노끈처럼 두 사슬을 땋고 그 땋은 사슬을 그 테에 달지니라","reference":"출애굽기 28:14","category":"$undefined"},{"id":"2309","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":15,"text":"너는 판결 흉패를 에봇 짜는 법으로 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 공교히 짜서 만들되","reference":"출애굽기 28:15","category":"$undefined"},{"id":"2310","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":16,"text":"장광이 한뼘씩 두 겹으로 네모 반듯하게 하고","reference":"출애굽기 28:16","category":"$undefined"},{"id":"2311","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":17,"text":"그것에 네 줄로 보석을 물리되 첫 줄은 홍보석, 황옥, 녹주옥이요,","reference":"출애굽기 28:17","category":"$undefined"},{"id":"2312","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":18,"text":"둘째 줄은 석류석, 남보석, 홍마노요,","reference":"출애굽기 28:18","category":"$undefined"},{"id":"2313","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":19,"text":"세째 줄은 호박, 백마노, 자수정이요,","reference":"출애굽기 28:19","category":"$undefined"},{"id":"2314","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":20,"text":"네째 줄은 녹보석, 호마노, 벽옥으로 다 금테에 물릴지니","reference":"출애굽기 28:20","category":"$undefined"},{"id":"2315","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":21,"text":"이 보석들은 이스라엘 아들들의 이름대로 열 둘이라 매 보석에 열두 지파의 한 이름씩 인을 새기는 법으로 새기고","reference":"출애굽기 28:21","category":"$undefined"},{"id":"2316","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":22,"text":"정금으로 노끈처럼 땋은 사슬을 흉패 위에 붙이고","reference":"출애굽기 28:22","category":"$undefined"},{"id":"2317","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":23,"text":"또 금고리 둘을 만들어 흉패 위 곧 흉패 두 끝에 그 두 고리를 달고","reference":"출애굽기 28:23","category":"$undefined"},{"id":"2318","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":24,"text":"땋은 두 금사슬로 흉패 두 끝 두 고리에 꿰어 매고","reference":"출애굽기 28:24","category":"$undefined"},{"id":"2319","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":25,"text":"두 땋은 사슬의 다른 두 끝을 에봇 앞 두 견대의 금테에 매고","reference":"출애굽기 28:25","category":"$undefined"},{"id":"2320","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":26,"text":"또 금고리 둘을 만들어 흉패 아래 양편 가 안쪽 곧 에봇에 닿은 곳에 달고","reference":"출애굽기 28:26","category":"$undefined"},{"id":"2321","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":27,"text":"또 금고리 둘을 만들어 에봇 앞 두 견대 아래 매는 자리 가까운편 곧 공교히 짠 띠 윗편에 달고","reference":"출애굽기 28:27","category":"$undefined"},{"id":"2322","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":28,"text":"청색 끈으로 흉패 고리와 에봇 고리에 꿰어 흉패로 공교히 짠 에봇 띠 위에 붙여 떠나지 않게 하라","reference":"출애굽기 28:28","category":"$undefined"},{"id":"2323","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":29,"text":"아론이 성소에 들어갈 때에는 이스라엘 아들들의 이름을 기록한 이 판결흉패를 가슴에 붙여 여호와 앞에 영원한 기념을 삼을 것이니라","reference":"출애굽기 28:29","category":"$undefined"},{"id":"2324","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":30,"text":"너는 우림과 둠밈을 판결 흉패 안에 넣어 아론으로 여호와 앞에 들어 갈 때에 그 가슴 위에 있게 하라 아론이 여호와 앞에서 이스라엘 자손의 판결을 항상 그 가슴 위에 둘지니라 !","reference":"출애굽기 28:30","category":"$undefined"},{"id":"2325","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":31,"text":"너는 에봇 받침 겉옷을 전부 청색으로 하되","reference":"출애굽기 28:31","category":"$undefined"},{"id":"2326","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":32,"text":"두 어깨 사이에 머리 들어갈 구멍을 내고 그 주위에 갑옷 깃 같이 깃을 짜서 찢어지지 않게 하고","reference":"출애굽기 28:32","category":"$undefined"},{"id":"2327","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":33,"text":"그 옷 가장자리로 돌아가며 청색, 자색, 홍색실로 석류를 수놓고 금방울을 간격하여 달되","reference":"출애굽기 28:33","category":"$undefined"},{"id":"2328","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":34,"text":"그 옷 가장자리로 돌아가며 한 금방울 한 석류, 한 금방울 한 석류가 있게 하라","reference":"출애굽기 28:34","category":"$undefined"},{"id":"2329","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":35,"text":"아론이 입고 여호와를 섬기러 성소에 들어갈 때와 성소에서 나갈때에 그 소리가 들릴 것이라 그리하면 그가 죽지 아니하리라 !","reference":"출애굽기 28:35","category":"$undefined"},{"id":"2330","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":36,"text":"너는 또 정금으로 패를 만들어 인을 새기는 법으로 그 위에 새기되 여호와께 성결이라 하고","reference":"출애굽기 28:36","category":"$undefined"},{"id":"2331","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":37,"text":"그 패를 청색 끈으로 관 위에 매되 곧 전면에 있게 하라","reference":"출애굽기 28:37","category":"$undefined"},{"id":"2332","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":38,"text":"이 패가 아론의 이마에 있어서 그로 이스라엘 자손의 거룩하게 드리는 성물의 죄건을 담당하게 하라 그 패가 아론의 이마에 늘 있으므로 그 성물을 여호와께서 받으시게 되리라","reference":"출애굽기 28:38","category":"$undefined"},{"id":"2333","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":39,"text":"너는 가는 베실로 반포 속옷을 짜고 가는 베실로 관을 만드고 띠를 수 놓아 만들지니라 !","reference":"출애굽기 28:39","category":"$undefined"},{"id":"2334","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":40,"text":"너는 아론의 아들들을 위하여 속옷을 만들며 그들을 위하여 띠를 만들며 그들을 위하여 관을 만들어서 영화롭고 아름답게 하되","reference":"출애굽기 28:40","category":"$undefined"},{"id":"2335","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":41,"text":"너는 그것들로 네 형 아론과 그와 함께한 그 아들들에게 입히고 그들에게 기름을 부어 위임하고 거룩하게 하여 그들로 제사장 직분을 내게 행하게 할지며","reference":"출애굽기 28:41","category":"$undefined"},{"id":"2336","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":42,"text":"또 그들을 위하여 베로 고의를 만들어 허리에서부터 넓적다리까지 이르게 하여 하체를 가리게 하라","reference":"출애굽기 28:42","category":"$undefined"},{"id":"2337","book":"출애굽기","book_name":"출애굽기","chapter":28,"verse":43,"text":"아론과 그 아들들이 회막에 들어갈 때에나 제단에 가까이 하여 거룩한 곳에서 섬길 때에 그것들을 입어야 죄를 지어서 죽지 아니하리니 그와 후손의 영원히 지킬 규례니라","reference":"출애굽기 28:43","category":"$undefined"}],"bookSlug":"exodus"}]
