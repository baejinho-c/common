2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":29,"verses":[{"id":"2338","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":1,"text":"너는 그들에게 나를 섬길 제사장 직분을 위임하여 그들로 거룩하게 할 일이 이러하니 곧 젊은 수소 하나와, 흠 없는 수양 둘을 취하고","reference":"출애굽기 29:1","category":"$undefined"},{"id":"2339","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":2,"text":"무교병과, 기름 섞인 무교 과자와, 기름 바른 무교 전병을 모두 고운 밀가루로 만들고","reference":"출애굽기 29:2","category":"$undefined"},{"id":"2340","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":3,"text":"그것들을 한 광주리에 담고 그것을 광주리에 담은 채 그 송아지와 두 양과 함께 가져 오고","reference":"출애굽기 29:3","category":"$undefined"},{"id":"2341","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":4,"text":"너는 아론과 그 아들들을 회막 문으로 데려다가 물로 씻기고","reference":"출애굽기 29:4","category":"$undefined"},{"id":"2342","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":5,"text":"의복을 가져다가 아론에게 속옷과, 에봇 받침 겉옷과, 에봇을 입히고 흉패를 달고 에봇에 공교히 짠 띠를 띠우고","reference":"출애굽기 29:5","category":"$undefined"},{"id":"2343","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":6,"text":"그 머리에 관을 씌우고 그 위에 성패를 더하고","reference":"출애굽기 29:6","category":"$undefined"},{"id":"2344","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":7,"text":"관유를 가져다가 그 머리에 부어 바르고","reference":"출애굽기 29:7","category":"$undefined"},{"id":"2345","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":8,"text":"그 아들들을 데려다가 그들에게 속옷을 입히고","reference":"출애굽기 29:8","category":"$undefined"},{"id":"2346","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":9,"text":"아론과 그 아들들에게 띠를 띠우며 관을 씌워서 제사장의 직분을 그들에게 맡겨 영원한 규례가 되게 하라 너는 이같이 아론과 그 아들들에게 위임하여 거룩하게 할지니라 !","reference":"출애굽기 29:9","category":"$undefined"},{"id":"2347","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":10,"text":"너는 수송아지를 회막 앞으로 끌어 오고 아론과 그 아들들은 그 송아지 머리에 안수할지며","reference":"출애굽기 29:10","category":"$undefined"},{"id":"2348","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":11,"text":"너는 회막문 여호와 앞에서 그 송아지를 잡고","reference":"출애굽기 29:11","category":"$undefined"},{"id":"2349","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":12,"text":"그 피를 네 손가락으로 단 뿔들에 바르고 그 피 전부를 단 밑에 쏟을지며","reference":"출애굽기 29:12","category":"$undefined"},{"id":"2350","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":13,"text":"내장에 덮인 모든 기름과 간 위에 있는 꺼풀과, 두 콩팥과, 그 위의 기름을 취하여 단 위에 불사르고","reference":"출애굽기 29:13","category":"$undefined"},{"id":"2351","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":14,"text":"그 수소의 고기와 가죽과 똥은 진 밖에서 불사르라 ! 이는 속죄제니라","reference":"출애굽기 29:14","category":"$undefined"},{"id":"2352","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":15,"text":"너는 또 수양 하나를 취하고 아론과 그 아들들은 그 수양의 머리위에 안수할지며","reference":"출애굽기 29:15","category":"$undefined"},{"id":"2353","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":16,"text":"너는 그 수양을 잡고 그 피를 취하여 단 위의 주위에 뿌리고","reference":"출애굽기 29:16","category":"$undefined"},{"id":"2354","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":17,"text":"그 수양의 각을 뜨고 그 장부와 다리는 씻어 각 뜬 고기와 그 머리와 함께 두고","reference":"출애굽기 29:17","category":"$undefined"},{"id":"2355","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":18,"text":"그 수양의 전부를 단 위에 불사르라 ! 이는 여호와께 드리는 번제요 이는 향기로운 냄새니 여호와께 드리는 화제니라","reference":"출애굽기 29:18","category":"$undefined"},{"id":"2356","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":19,"text":"너는 다른 수양을 취하고 아론과 그 아들들은 그 수양의 머리 위에 안수할지며","reference":"출애굽기 29:19","category":"$undefined"},{"id":"2357","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":20,"text":"너는 그 수양을 잡고 그 피를 취하여 아론의 오른 귓부리와, 그 아들들의 오른 귓부리에 바르고, 그 오른손 엄지와, 오른발 엄지에 바르고 그 피를 단 주위에 뿌리고","reference":"출애굽기 29:20","category":"$undefined"},{"id":"2358","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":21,"text":"단 위의 피와 관유를 취하여 아론과, 그 옷과, 그 아들들과, 그 아들들의 옷에 뿌리라 그와, 그 옷과, 그 아들들과, 그 아들들의 옷이 거룩하리라","reference":"출애굽기 29:21","category":"$undefined"},{"id":"2359","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":22,"text":"또 너는 그 수양의 기름과 기름진 꼬리와 그 내장에 덮인 기름과 간 위의 꺼풀과 두 콩팥과 그것들 위의 기름과 우편 넓적다리를 취하라 ! 이는 위임식의 수양이며","reference":"출애굽기 29:22","category":"$undefined"},{"id":"2360","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":23,"text":"또 여호와 앞에 있는 무교병 광주리에서 떡 한 덩이와 기름 바른 과자 하나와 전병 하나를 취하고","reference":"출애굽기 29:23","category":"$undefined"},{"id":"2361","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":24,"text":"그 전부를 아론의 손과 그 아들들의 손에 주고 그것을 흔들어 여호와 앞에 요제를 삼을지며","reference":"출애굽기 29:24","category":"$undefined"},{"id":"2362","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":25,"text":"너는 그것을 그들의 손에서 취하여 단 위에서 번제물을 더하여 불사르라 ! 이는 여호와 앞에 향기로운 냄새니 곧 여호와께 드리는 화제니라","reference":"출애굽기 29:25","category":"$undefined"},{"id":"2363","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":26,"text":"너는 위임식 수양의 가슴을 취하여 여호와 앞에 흔들어 요제를 삼으라 ! 이는 너의 분깃이니라","reference":"출애굽기 29:26","category":"$undefined"},{"id":"2364","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":27,"text":"너는 그 흔든 요제물 곧 아론과 그 아들들의 위임식 수양의 가슴과 넓적다리를 거룩하게 하라","reference":"출애굽기 29:27","category":"$undefined"},{"id":"2365","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":28,"text":"이는 이스라엘 자손이 아론과 그 자손에게 돌릴 영원한 분깃이요, 거제물이니 곧 이스라엘 자손이 화목제의 희생 중에서 취한 거제물로서 여호와께 드리는 거제물이니라","reference":"출애굽기 29:28","category":"$undefined"},{"id":"2366","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":29,"text":"아론의 성의는 아론의 후에 그 아들들에게 돌릴지니 그들이 그것을 입고 기름 부음으로 위임을 받을 것이며","reference":"출애굽기 29:29","category":"$undefined"},{"id":"2367","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":30,"text":"그를 이어 제사장이 되는 아들이 회막에 들어가서 성소에서 섬길때에는 칠일 동안 그것을 입을지니라 !","reference":"출애굽기 29:30","category":"$undefined"},{"id":"2368","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":31,"text":"너는 위임식 수양을 취하여 거룩한 곳에서 그 고기를 삶고","reference":"출애굽기 29:31","category":"$undefined"},{"id":"2369","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":32,"text":"아론과 그 아들들이 회막문에서 그 수양의 고기와 광주리에 있는 떡을 먹을찌라","reference":"출애굽기 29:32","category":"$undefined"},{"id":"2370","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":33,"text":"속죄물 곧 그들을 위임하며 그들은 거룩하게 하는데 쓰는것은 그들은 먹되 타인은 먹지 못할지니 이는 성물이 됨이며","reference":"출애굽기 29:33","category":"$undefined"},{"id":"2371","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":34,"text":"위임식 고기나 떡이 아침까지 남았으면 그것을 불에 사를지니 이는 거룩한즉 먹지 못할지니라 !","reference":"출애굽기 29:34","category":"$undefined"},{"id":"2372","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":35,"text":"너는 내가 무릇 네게 명한대로 아론과 그 아들들에게 그같이 하여 칠일동안 위임식을 행하되","reference":"출애굽기 29:35","category":"$undefined"},{"id":"2373","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":36,"text":"매일 수송아지 하나로 속죄하기 위하여 속죄제를 드리며 또 단을 위하여 깨끗케 하고 그것에 기름을 부어 거룩하게 하라","reference":"출애굽기 29:36","category":"$undefined"},{"id":"2374","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":37,"text":"네가 칠일 동안 단을 위하여 속죄하여 거룩하게 하라 ! 그리하면 지극히 거룩한 단이 되리니 무릇 단에 접촉하는 것이 거룩하리라","reference":"출애굽기 29:37","category":"$undefined"},{"id":"2375","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":38,"text":"네가 단 위에 드릴 것은 이러하니라 매일 일년 된 어린 양 두 마리니","reference":"출애굽기 29:38","category":"$undefined"},{"id":"2376","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":39,"text":"한 어린 양은 아침에 드리고, 한 어린 양은 저녁 때에 드릴지며","reference":"출애굽기 29:39","category":"$undefined"},{"id":"2377","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":40,"text":"한 어린 양에 고운 밀가루 에바 십분 일과, 찧은 기름 힌의 사분 일을 더하고 또 전제로 포도주 힌의 사분 일을 더할지며","reference":"출애굽기 29:40","category":"$undefined"},{"id":"2378","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":41,"text":"한 어린 양은 저녁 때에 드리되 아침과 일반으로 소제와 전제를 그것과 함께 드려 향기로운 냄새가 되게 하여 여호와께 화제를 삼을지니","reference":"출애굽기 29:41","category":"$undefined"},{"id":"2379","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":42,"text":"이는 너희가 대대로 여호와 앞 회막문에서 늘 드릴 번제라 내가 거기서 너희와 만나고 네게 말하리라","reference":"출애굽기 29:42","category":"$undefined"},{"id":"2380","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":43,"text":"내가 거기서 이스라엘 자손을 만나리니 내 영광을 인하여 회막이 거룩하게 될지라 !","reference":"출애굽기 29:43","category":"$undefined"},{"id":"2381","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":44,"text":"내가 그 회막과 단을 거룩하게 하며 아론과 그 아들들도 거룩하게 하여 내게 제사장 직분을 행하게 하며","reference":"출애굽기 29:44","category":"$undefined"},{"id":"2382","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":45,"text":"내가 이스라엘 자손 중에 거하여 그들의 하나님이 되리니","reference":"출애굽기 29:45","category":"$undefined"},{"id":"2383","book":"출애굽기","book_name":"출애굽기","chapter":29,"verse":46,"text":"그들은 내가 그들의 하나님 여호와로서 그들 중에 거하려고 그들을 애굽 땅에서 인도하여 낸 줄을 알리라 나는 그들의 하나님 여호와니라 !","reference":"출애굽기 29:46","category":"$undefined"}],"bookSlug":"exodus"}]
