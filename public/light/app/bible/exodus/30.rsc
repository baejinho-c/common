2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":30,"verses":[{"id":"2384","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":1,"text":"너는 분향할 단을 만들지니 곧 조각목으로 만들되","reference":"출애굽기 30:1","category":"$undefined"},{"id":"2385","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":2,"text":"장이 일 규빗,광이 일 규빗으로 네모 반듯하게 하고 고는 이 규빗으로 하며 그 뿔을 그것과 연하게 하고","reference":"출애굽기 30:2","category":"$undefined"},{"id":"2386","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":3,"text":"단 상면과 전후 좌우면과 뿔을 정금으로 싸고 주위에 금테를 두를지며","reference":"출애굽기 30:3","category":"$undefined"},{"id":"2387","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":4,"text":"금테 아래 양편에 금고리 둘을 만들되 곧 그 양편에 만들지니 이는 단을 메는 채를 꿸 곳이며","reference":"출애굽기 30:4","category":"$undefined"},{"id":"2388","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":5,"text":"그 채를 조각목으로 만들고 금으로 싸고","reference":"출애굽기 30:5","category":"$undefined"},{"id":"2389","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":6,"text":"그 단을 증거궤 위 속죄소 맞은편 곧 증거궤 앞에 있는 장 밖에 두라 그 속죄소는 내가 너와 만날 곳이며","reference":"출애굽기 30:6","category":"$undefined"},{"id":"2390","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":7,"text":"아론이 아침마다 그 위에 향기로운 향을 사르되 등불을 정리할 때에 사를지며","reference":"출애굽기 30:7","category":"$undefined"},{"id":"2391","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":8,"text":"또 저녁때 등불을 켤때에 사를지니 이향은 너희가 대대로 여호와앞에 끊지 못할지며","reference":"출애굽기 30:8","category":"$undefined"},{"id":"2392","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":9,"text":"너희는 그 위에 다른 향을 사르지 말며 번제나 소제를 드리지 말며 전제의 술을 붓지 말며","reference":"출애굽기 30:9","category":"$undefined"},{"id":"2393","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":10,"text":"아론이 일년 일차씩 이 향단 뿔을 위하여 속죄하되 속죄제의 피로 일년 일차씩 대대로 속죄할지니라 ! 이 단은 여호와께 지극히 거룩하니라","reference":"출애굽기 30:10","category":"$undefined"},{"id":"2394","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":11,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 30:11","category":"$undefined"},{"id":"2395","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":12,"text":"네가 이스라엘 자손의 수효를 따라 조사할 때에 조사 받은 각 사람은 그 생명의 속전을 여호와께 드릴지니 이는 그 계수할 때에 그들 중에 온역이 없게 하려 함이라","reference":"출애굽기 30:12","category":"$undefined"},{"id":"2396","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":13,"text":"무릇 계수 중에 드는 자마다 성소에 세겔대로 반 세겔을 낼지니 한 세겔은 이 십 게라라 그 반 세겔을 여호와께 드릴지며","reference":"출애굽기 30:13","category":"$undefined"},{"id":"2397","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":14,"text":"무릇 계수 중에 드는 자 곧 이십세 이상 된 자가 여호와께 드리되","reference":"출애굽기 30:14","category":"$undefined"},{"id":"2398","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":15,"text":"너희의 생명을 속하기 위하여 여호와께 드릴 때에 부자라고 반 세겔에서 더 내지 말고, 가난한 자라고 덜 내지 말지며","reference":"출애굽기 30:15","category":"$undefined"},{"id":"2399","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":16,"text":"너는 이스라엘 자손에게서 속전을 취하여 회막의 봉사에 쓰라 이것이 여호와 앞에서 이스라엘 자손의 기념이 되어서 너희의 생명을 속하리라","reference":"출애굽기 30:16","category":"$undefined"},{"id":"2400","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":17,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 30:17","category":"$undefined"},{"id":"2401","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":18,"text":"너는 물두멍을 놋으로 만들어 씻게 하되 그것을 회막과 단 사이에 두고 그 속에 물을 담으라","reference":"출애굽기 30:18","category":"$undefined"},{"id":"2402","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":19,"text":"아론과 그 아들들이 그 두멍에서 수족을 씻되","reference":"출애굽기 30:19","category":"$undefined"},{"id":"2403","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":20,"text":"그들이 회막에 들어갈 때에 물로 씻어 죽기를 면할 것이요 단에 가까이 가서 그 직분을 행하여 화제를 여호와 앞에 사를 때에도 그리할지니라","reference":"출애굽기 30:20","category":"$undefined"},{"id":"2404","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":21,"text":"이와 같이 그들이 그 수족을 씻어 죽기를 면할지니 이는 그와 그 자손이 대대로 영원히 지킬 규례니라","reference":"출애굽기 30:21","category":"$undefined"},{"id":"2405","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":22,"text":"여호와께서 모세에게 또 일러 가라사대","reference":"출애굽기 30:22","category":"$undefined"},{"id":"2406","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":23,"text":"너는 상등 향품을 취하되 액체 몰약 오백 세겔과, 그 반수의 향기로운 육계 이백 오십세겔과, 향기로운 창포 이백 오십세겔과,","reference":"출애굽기 30:23","category":"$undefined"},{"id":"2407","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":24,"text":"계피 오백 세겔을 성소의 세겔대로 하고 감람 기름 한 힌을 취하여","reference":"출애굽기 30:24","category":"$undefined"},{"id":"2408","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":25,"text":"그것으로 거룩한 관유를 만들되 향을 제조하는 법대로 향기름을 만들지니 그것이 거룩한 관유가 될지라","reference":"출애굽기 30:25","category":"$undefined"},{"id":"2409","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":26,"text":"너는 그것으로 회막과 증거궤에 바르고","reference":"출애굽기 30:26","category":"$undefined"},{"id":"2410","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":27,"text":"상과 그 모든 기구며 등대와 그 기구며 분향단과","reference":"출애굽기 30:27","category":"$undefined"},{"id":"2411","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":28,"text":"및 번제단과 그 모든 기구와 물두멍과 그 받침에 발라","reference":"출애굽기 30:28","category":"$undefined"},{"id":"2412","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":29,"text":"그것들을 지성물로 구별하라 ! 무릇 이것에 접촉하는 것이 거룩하리라","reference":"출애굽기 30:29","category":"$undefined"},{"id":"2413","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":30,"text":"너는 아론과 그 아들들에게 기름을 발라 그들을 거룩하게 하고 그들로 내게 제사장 직분을 행하게 하고","reference":"출애굽기 30:30","category":"$undefined"},{"id":"2414","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":31,"text":"이스라엘 자손에게 고하여 이르기를 이것은 너희 대대로 내게 거룩한 관유니","reference":"출애굽기 30:31","category":"$undefined"},{"id":"2415","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":32,"text":"사람의 몸에 붓지 말며 이 방법대로 이와 같은 것을 만들지 말라 이는 거룩하니 너희는 거룩히 여기라","reference":"출애굽기 30:32","category":"$undefined"},{"id":"2416","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":33,"text":"무릇 이와 같은 것을 만드는 자나 무릇 이것을 타인에게 붓는 자는 그 백성중에서 끊쳐지리라 하라","reference":"출애굽기 30:33","category":"$undefined"},{"id":"2417","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":34,"text":"여호와께서 모세에게 이르시되 너는 소합향과, 나감향과, 풍자향의 향품을 취하고 그 향품을 유향에 섞되 각기 동일한 중수로 하고","reference":"출애굽기 30:34","category":"$undefined"},{"id":"2418","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":35,"text":"그것으로 향을 만들되 향 만드는 법대로 만들고 그것에 소금을 쳐서 성결하게 하고","reference":"출애굽기 30:35","category":"$undefined"},{"id":"2419","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":36,"text":"그 향 얼마를 곱게 찧어 내가 너와 만날 회막 안 증거궤 앞에 두라 이 향은 너희에게 지극히 거룩하니라 !","reference":"출애굽기 30:36","category":"$undefined"},{"id":"2420","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":37,"text":"네가 만들 향은 여호와를 위하여 거룩한 것이니 그 방법대로 너희를 위하여 만들지 말라 !","reference":"출애굽기 30:37","category":"$undefined"},{"id":"2421","book":"출애굽기","book_name":"출애굽기","chapter":30,"verse":38,"text":"무릇 맡으려고 이같은 것을 만드는 자는 그 백성 중에서 끊쳐지리라 !","reference":"출애굽기 30:38","category":"$undefined"}],"bookSlug":"exodus"}]
