2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":31,"verses":[{"id":"2422","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 31:1","category":"$undefined"},{"id":"2423","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":2,"text":"내가 유다 지파 훌의 손자요 우리의 아들인 브사렐을 지명하여 부르고","reference":"출애굽기 31:2","category":"$undefined"},{"id":"2424","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":3,"text":"하나님의 신을 그에게 충만하게 하여 지혜와 총명과 지식과 여러가지 재주로","reference":"출애굽기 31:3","category":"$undefined"},{"id":"2425","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":4,"text":"공교한 일을 연구하여 금과 은과 놋으로 만들게 하며","reference":"출애굽기 31:4","category":"$undefined"},{"id":"2426","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":5,"text":"보석을 깍아 물리며 나무를 새겨서 여러가지 일을 하게 하고","reference":"출애굽기 31:5","category":"$undefined"},{"id":"2427","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":6,"text":"내가 또 단 지파 아히사막의 아들 오홀리압을 세워 그와 함께 하게 하며 무릇 지혜로운 마음이 있는 자에게 내가 지혜를 주어 그들로 내가 네게 명한 것을 다 만들게 할지니","reference":"출애굽기 31:6","category":"$undefined"},{"id":"2428","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":7,"text":"곧 회막과, 증거궤와, 그 위의 속죄소와, 회막의 모든 기구와","reference":"출애굽기 31:7","category":"$undefined"},{"id":"2429","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":8,"text":"상과, 그 기구와, 정금 등대와, 그 모든 기구와, 분향단과","reference":"출애굽기 31:8","category":"$undefined"},{"id":"2430","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":9,"text":"번제단과, 그 모든 기구와, 물두멍과, 그 받침과","reference":"출애굽기 31:9","category":"$undefined"},{"id":"2431","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":10,"text":"제사직을 행할 때에 입는 공교히 짠 의복 곧 제사장 아론의 성의와 그 아들들의 옷과","reference":"출애굽기 31:10","category":"$undefined"},{"id":"2432","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":11,"text":"관유와 성소의 향기로운 향이라 무릇 내가 네게 명한대로 그들이 만들지니라 !","reference":"출애굽기 31:11","category":"$undefined"},{"id":"2433","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":12,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 31:12","category":"$undefined"},{"id":"2434","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":13,"text":"너는 이스라엘 자손에게 고하여 이르기를 너희는 나의 안식일을 지키라 ! 이는 나와 너희 사이에 너희 대대의 표징이니 나는 너희를 거룩하게 하는 여호와인 줄 너희로 알게 함이라","reference":"출애굽기 31:13","category":"$undefined"},{"id":"2435","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":14,"text":"너희는 안식일을 지킬지니 이는 너희에게 성일이 됨이라 무릇 그날에 일하는 자는 그 백성 중에서 그 생명이 끊쳐지리라","reference":"출애굽기 31:14","category":"$undefined"},{"id":"2436","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":15,"text":"엿새 동안은 일할 것이나 제 칠일은 큰 안식일이니 여호와께 거룩한 것이라 무릇 안식일에 일하는 자를 반드시 죽일지니라 !","reference":"출애굽기 31:15","category":"$undefined"},{"id":"2437","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":16,"text":"이같이 이스라엘 자손이 안식일을 지켜서 그것으로 대대로 영원한 언약을 삼을 것이니","reference":"출애굽기 31:16","category":"$undefined"},{"id":"2438","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":17,"text":"이는 나와 이스라엘 자손 사이에 영원한 표징이며 나 여호와가 엿새 동안에 천지를 창조하고 제 칠일에 쉬어 평안하였음이니라 하라","reference":"출애굽기 31:17","category":"$undefined"},{"id":"2439","book":"출애굽기","book_name":"출애굽기","chapter":31,"verse":18,"text":"여호와께서 시내산 위에서 모세에게 이르시기를 마치신 때에 증거판 둘을 모세에게 주시니 이는 돌판이요 하나님이 친히 쓰신 것이더라","reference":"출애굽기 31:18","category":"$undefined"}],"bookSlug":"exodus"}]
