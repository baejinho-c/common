2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":32,"verses":[{"id":"2440","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":1,"text":"백성이 모세가 산에서 내려옴이 더딤을 보고 모여 아론에게 이르러 가로되 '일어나라 우리를 인도할 신을 우리를 위하여 만들라 이 모세 곧 우리를 애굽 땅에서 인도하여 낸 사람은 어찌 되었는지 알지 못함이라'","reference":"출애굽기 32:1","category":"$undefined"},{"id":"2441","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":2,"text":"아론이 그들에게 이르되 `너희 아내와 자녀의 귀의 금고리를 빼어 내게로 가져 오라'","reference":"출애굽기 32:2","category":"$undefined"},{"id":"2442","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":3,"text":"모든 백성이 그 귀에서 금고리를 빼어 아론에게로 가져 오매","reference":"출애굽기 32:3","category":"$undefined"},{"id":"2443","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":4,"text":"아론이 그들의 손에서 그 고리를 받아 부어서 각도로 새겨 송아지 형상을 만드니 그들이 말하되 '이스라엘아 ! 이는 너희를 애굽 땅에서 인도하여 낸 너희 신이로다' 하는지라","reference":"출애굽기 32:4","category":"$undefined"},{"id":"2444","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":5,"text":"아론이 보고 그 앞에 단을 쌓고 이에 공포하여 가로되 `내일은 여호와의 절일이니라' 하니","reference":"출애굽기 32:5","category":"$undefined"},{"id":"2445","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":6,"text":"이튿날에 그들이 일찌기 일어나 번제를 드리며 화목제를 드리고 앉아서 먹고 마시며 일어나서 뛰놀더라","reference":"출애굽기 32:6","category":"$undefined"},{"id":"2446","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":7,"text":"여호와께서 모세에게 이르시되 너는 내려가라 네가 애굽 땅에서 인도하여 낸 네 백성이 부패하였도다","reference":"출애굽기 32:7","category":"$undefined"},{"id":"2447","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":8,"text":"그들이 내가 그들에게 명한 길을 속히 떠나 자기를 위하여 송아지를 부어 만들고 그것을 숭배하며 그것에게 희생을 드리며 말하기를 애굽 땅에서 인도하여 낸 너희 신이라 하였도다","reference":"출애굽기 32:8","category":"$undefined"},{"id":"2448","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":9,"text":"여호와께서 또 모세에게 이르시되 내가 이 백성을 보니 목이 곧은 백성이로다","reference":"출애굽기 32:9","category":"$undefined"},{"id":"2449","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":10,"text":"그런즉 나대로 하게 하라 ! 내가 그들에게 진노하여 그들을 진멸하고 너로 큰 나라가 되게 하리라","reference":"출애굽기 32:10","category":"$undefined"},{"id":"2450","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":11,"text":"모세가 그 하나님 여호와께 구하여 가로되 '여호와여 ! 어찌하여 애굽 땅에서 인도하여 내신 주의 백성에게 진노하시나이까 ?","reference":"출애굽기 32:11","category":"$undefined"},{"id":"2451","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":12,"text":"어찌하여 애굽 사람으로 이르기를 여호와가 화를 내려 그 백성을 산에서 죽이고 지면에서 진멸하려고 인도하여 내었다 하게 하려 하시나이까 ? 주의 맹렬한 노를 그치시고 뜻을 돌이키사 주의 백성에게 이 화를 내리지 마옵소서 !","reference":"출애굽기 32:12","category":"$undefined"},{"id":"2452","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":13,"text":"주의 종 아브라함과 이삭과 이스라엘을 기억하소서 ! 주께서 주를 가리켜 그들에게 맹세하여 이르시기를 내가 너희 자손을 하늘의 별처럼 많게 하고 나의 허락한 이 온 땅을 너희의 자손에게 주어 영원한 기업이 되게 하리라 하셨나이다'","reference":"출애굽기 32:13","category":"$undefined"},{"id":"2453","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":14,"text":"여호와께서 뜻을 돌이키사 말씀하신 화를 그 백성에게 내리지 아니하시니라","reference":"출애굽기 32:14","category":"$undefined"},{"id":"2454","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":15,"text":"모세가 돌이켜 산에서 내려 오는데 증거의 두 판이 그 손에 있고 그 판의 양면 이편 저편에 글자가 있으니","reference":"출애굽기 32:15","category":"$undefined"},{"id":"2455","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":16,"text":"그 판은 하나님이 만드신 것이요, 글자는 하나님이 쓰셔서 판에 새기신 것이더라","reference":"출애굽기 32:16","category":"$undefined"},{"id":"2456","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":17,"text":"여호수아가 백성의 떠듦을 듣고 모세에게 말하되 `진중에서 싸우는 소리가 나나이다'","reference":"출애굽기 32:17","category":"$undefined"},{"id":"2457","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":18,"text":"모세가 가로되 `이는 승전가도 아니요, 패하여 부르짖는 소리도 아니라 나의 듣기에는 노래하는 소리로다' 하고","reference":"출애굽기 32:18","category":"$undefined"},{"id":"2458","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":19,"text":"진에 가까이 이르러 송아지와 그 춤 추는 것을 보고 대노하여 손에서 그 판들을 산 아래로 던져 깨뜨리니라","reference":"출애굽기 32:19","category":"$undefined"},{"id":"2459","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":20,"text":"모세가 그들의 만든 송아지를 가져 불살라 부수어 가루를 만들어 물에 뿌려 이스라엘 자손에게 마시우니라","reference":"출애굽기 32:20","category":"$undefined"},{"id":"2460","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":21,"text":"모세가 아론에게 이르되 `이 백성이 네게 어떻게 하였기에 네가 그들로 중죄에 빠지게 하였느뇨 ?'","reference":"출애굽기 32:21","category":"$undefined"},{"id":"2461","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":22,"text":"아론이 가로되 `내 주여, 노하지 마소서 이 백성의 악함을 당신이 아나이다","reference":"출애굽기 32:22","category":"$undefined"},{"id":"2462","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":23,"text":"그들이 내게 말하기를 우리를 위하여 우리를 인도할 신을 만들라 이 모세 곧 우리를 애굽 땅에서 인도하여 낸 사람은 어찌 되었는지 알 수 없노라 하기에","reference":"출애굽기 32:23","category":"$undefined"},{"id":"2463","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":24,"text":"내가 그들에게 이르기를 금이 있는 자는 빼어내라 한즉 그들이 그것을 내게로 가져왔기로 내가 불에 던졌더니 이 송아지가 나왔나이다'","reference":"출애굽기 32:24","category":"$undefined"},{"id":"2464","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":25,"text":"모세가 본즉 백성이 방자하니 이는 아론이 그들로 방자하게 하여 원수에게 조롱거리가 되게 하였음이라","reference":"출애굽기 32:25","category":"$undefined"},{"id":"2465","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":26,"text":"이에 모세가 진문에 서서 가로되 `누구든지 여호와의 편에 있는 자는 내게로 나아오라 !' 하매 레위 자손이 다 모여 그에게로 오는 지라","reference":"출애굽기 32:26","category":"$undefined"},{"id":"2466","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":27,"text":"모세가 그들에게 이르되 `이스라엘의 하나님 여호와께서 이같이 말씀하시기를 너희는 각각 허리에 칼을 차고 진 이 문에서 저 문까지 왕래하며 각 사람이 그 형제를,각 사람이 그 친구를,각 사람이 그 이웃을 도륙하라 하셨느니라'","reference":"출애굽기 32:27","category":"$undefined"},{"id":"2467","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":28,"text":"레위 자손이 모세의 말대로 행하매 이 날에 백성 중에 삼천명 가량이 죽인 바 된지라","reference":"출애굽기 32:28","category":"$undefined"},{"id":"2468","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":29,"text":"모세가 이르되 `각 사람이 그 아들과 그 형제를 쳤으니 오늘날 여호와께 헌신하게 되었느니라 그가 오늘날 너희에게 복을 내리시리라'","reference":"출애굽기 32:29","category":"$undefined"},{"id":"2469","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":30,"text":"이튿날 모세가 백성에게 이르되 `너희가 큰 죄를 범하였도다 내가 이제 여호와께로 올라가노니 혹 너희의 죄를 속할까 하노라' 하고","reference":"출애굽기 32:30","category":"$undefined"},{"id":"2470","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":31,"text":"여호와께로 다시 나아가 여짜오되 `슬프도소이다 ! 이 백성이 자기들을 위하여 금신을 만들었사오니 큰 죄를 범하였나이다","reference":"출애굽기 32:31","category":"$undefined"},{"id":"2471","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":32,"text":"그러나 합의하시면 이제 그들의 죄를 사하시옵소서 ! 그렇지 않사오면 원컨대 주의 기록하신 책에서 내 이름을 지워 버려주옵소서 !'","reference":"출애굽기 32:32","category":"$undefined"},{"id":"2472","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":33,"text":"여호와께서 모세에게 이르시되 누구든지 내게 범죄하면 그는 내가 내 책에서 지워버리리라","reference":"출애굽기 32:33","category":"$undefined"},{"id":"2473","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":34,"text":"이제 가서 내가 네게 말한 곳으로 백성을 인도하라 내 사자가 네 앞서 가리라 그러나 내가 보응할 날에는 그들의 죄를 보응하리라","reference":"출애굽기 32:34","category":"$undefined"},{"id":"2474","book":"출애굽기","book_name":"출애굽기","chapter":32,"verse":35,"text":"여호와께서 백성을 치시니 이는 그들이 아론의 만든바 그 송아지를 만들었음이더라","reference":"출애굽기 32:35","category":"$undefined"}],"bookSlug":"exodus"}]
