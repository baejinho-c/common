2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":33,"verses":[{"id":"2475","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":1,"text":"여호와께서 모세에게 이르시되 너는 네가 애굽 땅에서 인도하여 낸 백성과 함께 여기서 떠나서 내가 아브라함과 이삭과 야곱에게 맹세하기를 네 자손에게 주마 한 그 땅으로 올라가라","reference":"출애굽기 33:1","category":"$undefined"},{"id":"2476","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":2,"text":"내가 사자를 네 앞서 보내어 가나안 사람과, 아모리 사람과, 헷 사람과, 브리스 사람과, 히위 사람과, 여부스 사람을 쫓아내고","reference":"출애굽기 33:2","category":"$undefined"},{"id":"2477","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":3,"text":"너희로 젖과 꿀이 흐르는 땅에 이르게 하려니와 나는 너희와 함께 올라가지 아니하리니 너희는 목이 곧은 백성인즉 내가 중로에서 너희를 진멸할까 염려함이니라 하시니","reference":"출애굽기 33:3","category":"$undefined"},{"id":"2478","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":4,"text":"백성이 이 황송한 말씀을 듣고 슬퍼하여 한 사람도 그 몸을 단장하지 아니하니","reference":"출애굽기 33:4","category":"$undefined"},{"id":"2479","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":5,"text":"여호와께서 모세에게 이르시기를 이스라엘 자손에게 이르라 너희는 목이 곧은 백성인즉 내가 순식간이라도 너희 중에 행하면 너희를 진멸하리니 너희 단장품을 제하라 ! 그리하면 내가 너희에게 어떻게 할 일을 알겠노라 하셨음이라","reference":"출애굽기 33:5","category":"$undefined"},{"id":"2480","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":6,"text":"이스라엘 자손이 호렙 산에서부터 그 단장품을 제하니라","reference":"출애굽기 33:6","category":"$undefined"},{"id":"2481","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":7,"text":"모세가 항상 장막을 취하여 진 밖에 쳐서 진과 멀리 떠나게 하고 회막이라 이름하니 여호와를 앙모하는 자는 다 진 바깥 회막으로 나아가며","reference":"출애굽기 33:7","category":"$undefined"},{"id":"2482","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":8,"text":"모세가 회막으로 나아갈 때에는 백성이 다 일어나 자기 장막문에 서서 모세가 회막에 들어가기까지 바라보며","reference":"출애굽기 33:8","category":"$undefined"},{"id":"2483","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":9,"text":"모세가 회막에 들어갈 때에 구름 기둥이 내려 회막문에 서며 여호와께서 모세와 말씀하시니","reference":"출애굽기 33:9","category":"$undefined"},{"id":"2484","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":10,"text":"모든 백성이 회막문에 구름 기둥이 섰음을 보고 다 일어나 각기 장막문에 서서 경배하며","reference":"출애굽기 33:10","category":"$undefined"},{"id":"2485","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":11,"text":"사람이 그 친구와 이야기함 같이 여호와께서는 모세와 대면하여 말씀하시며 모세는 진으로 돌아오나 그 수종자 눈의 아들 청년 여호수아는 회막을 떠나지 아니하니라","reference":"출애굽기 33:11","category":"$undefined"},{"id":"2486","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":12,"text":"모세가 여호와께 고하되 `보시옵소서 ! 주께서 나더러 이 백성을 인도하여 올라가라 하시면서 나와 함께 보낼 자를 내게 지시하지 아니하시나이다 주께서 전에 말씀하시기를 나는 이름으로도 너를 알고 너도 내 앞에 은총을 입었다 하셨사온즉","reference":"출애굽기 33:12","category":"$undefined"},{"id":"2487","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":13,"text":"내가 참으로 주의 목전에 은총을 입게 하시며 이 족속을 주의 백성으로 여기소서 !'","reference":"출애굽기 33:13","category":"$undefined"},{"id":"2488","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":14,"text":"여호와께서 가라사대 내가 친히 가리라 ! 내가 너로 편케 하리라 !","reference":"출애굽기 33:14","category":"$undefined"},{"id":"2489","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":15,"text":"모세가 여호와께 고하되 `주께서 친히 가지 아니하시려거든 우리를 이곳에서 올려 보내지 마옵소서","reference":"출애굽기 33:15","category":"$undefined"},{"id":"2490","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":16,"text":"나와 주의 백성이 주의 목전에 은총 입은 줄을 무엇으로 알리이까 ? 주께서 우리와 함께 행하심으로 나와 주의 백성을 천하 만민 중에 구별하심이 아니니이까 ?'","reference":"출애굽기 33:16","category":"$undefined"},{"id":"2491","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":17,"text":"여호와께서 모세에게 이르시되 너의 말하는 이 일도 내가 하리니 너는 내 목전에 은총을 입었고 내가 이름으로도 너를 앎이니라","reference":"출애굽기 33:17","category":"$undefined"},{"id":"2492","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":18,"text":"모세가 가로되 `원컨대 주의 영광을 내게 보이소서 !'","reference":"출애굽기 33:18","category":"$undefined"},{"id":"2493","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":19,"text":"여호와께서 가라사대 내가 나의 모든 선한 형상을 네 앞으로 지나게 하고 여호와의 이름을 네 앞에 반포하리라 나는 은혜 줄 자에게 은혜를 주고 긍휼히 여길자에게 긍휼을 베푸느니라","reference":"출애굽기 33:19","category":"$undefined"},{"id":"2494","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":20,"text":"또 가라사대 네가 내 얼굴을 보지 못하리니 나를 보고 살 자가 없음이니라","reference":"출애굽기 33:20","category":"$undefined"},{"id":"2495","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":21,"text":"여호와께서 가라사대 보라 내 곁에 한 곳이 있으니 너는 그 반석 위에 섰으라","reference":"출애굽기 33:21","category":"$undefined"},{"id":"2496","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":22,"text":"내 영광이 지날 때에 내가 너를 반석 틈에 두고 내가 지나도록 내 손으로 너를 덮었다가","reference":"출애굽기 33:22","category":"$undefined"},{"id":"2497","book":"출애굽기","book_name":"출애굽기","chapter":33,"verse":23,"text":"손을 거두리니 네가 내 등을 볼 것이요 얼굴은 보지 못하리라","reference":"출애굽기 33:23","category":"$undefined"}],"bookSlug":"exodus"}]
