2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":34,"verses":[{"id":"2498","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":1,"text":"여호와께서 모세에게 이르시되 너는 돌판 둘을 처음 것과 같이 깍아 만들라 네가 깨뜨린바 처음 것과 같이 깎아 만들라 네가 깨뜨린바 처음 판에 있던 말을 내가 그 판에 쓰리니","reference":"출애굽기 34:1","category":"$undefined"},{"id":"2499","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":2,"text":"아침 전에 예비하고 아침에 시내 산에 올라와 산꼭대기에서 내게 보이되","reference":"출애굽기 34:2","category":"$undefined"},{"id":"2500","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":3,"text":"아무도 너와 함께 오르지 말며 온 산에 인적을 금하고 양과 소도 산 앞에서 먹지 못하게 하라","reference":"출애굽기 34:3","category":"$undefined"},{"id":"2501","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":4,"text":"모세가 돌판 둘을 처음 것과 같이 깎아 만들고 아침에 일찌기 일어나 그 두 돌판을 손에 들고 여호와의 명대로 시내산에 올라가니","reference":"출애굽기 34:4","category":"$undefined"},{"id":"2502","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":5,"text":"여호와께서 구름 가운데 강림하사 그와 함께 거기 서서 여호와의 이름을 반포하실쌔","reference":"출애굽기 34:5","category":"$undefined"},{"id":"2503","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":6,"text":"여호와께서 그의 앞으로 지나시며 반포하시되 여호와로라 ! 여호와로라 ! 자비롭고 은혜롭고 노하기를 더디하고 인자와 진실이 많은 하나님이로라","reference":"출애굽기 34:6","category":"$undefined"},{"id":"2504","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":7,"text":"인자를 천대까지 베풀며 악과 과실과 죄를 용서하나 형벌 받을 자는 결단코 면죄하지 않고 아비의 악을 자여손 삼사대까지 보응하리라","reference":"출애굽기 34:7","category":"$undefined"},{"id":"2505","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":8,"text":"모세가 급히 땅에 엎드리어 경배하며","reference":"출애굽기 34:8","category":"$undefined"},{"id":"2506","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":9,"text":"가로되 `주여 ! 내가 주께 은총을 입었거든 원컨대 주는 우리 중에서 행하옵소서 이는 목이 곧은 백성이니이다 우리의 악과 죄를 사하시고 우리로 주의 기업을 삼으소서 !'","reference":"출애굽기 34:9","category":"$undefined"},{"id":"2507","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":10,"text":"여호와께서 가라사대 보라 내가 언약을 세우나니 곧 내가 아직 온 땅 아무 국민에게도 행치 아니한 이적을 너희 전체 백성 앞에 행할 것이라 너의 머무는 나라 백성이 다 여호와의 소위를 보리니 내가 너를 위하여 행할 일이 두려운 것임이니라","reference":"출애굽기 34:10","category":"$undefined"},{"id":"2508","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":11,"text":"너는 내가 오늘 네게 명하는 것을 삼가 지키라 보라 ! 내가 네 앞에서 아모리 사람과, 가나안 사람과, 헷 사람과, 브리스 사람과, 히위 사람과, 여부스 사람을 쫓아내리니","reference":"출애굽기 34:11","category":"$undefined"},{"id":"2509","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":12,"text":"너는 스스로 삼가 네가 들어가는 땅의 거민과 언약을 세우지 말라 그들이 너희 중에 올무가 될까 하노라","reference":"출애굽기 34:12","category":"$undefined"},{"id":"2510","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":13,"text":"너희는 도리어 그들의 단들을 헐고 그들의 주상을 깨뜨리고 그들의 아세라 상을 찍을지어다 !","reference":"출애굽기 34:13","category":"$undefined"},{"id":"2511","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":14,"text":"너는 다른 신에게 절하지 말라 ! 여호와는 질투라 이름하는 질투의 하나님임이니라 !","reference":"출애굽기 34:14","category":"$undefined"},{"id":"2512","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":15,"text":"너는 삼가 그 땅의 거민과 언약을 세우지 말지니 이는 그들이 모든 신을 음란히 섬기며 그 신들에게 희생을 드리고 너를 청하면 네가 그 희생을 먹을까 함이며","reference":"출애굽기 34:15","category":"$undefined"},{"id":"2513","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":16,"text":"또 네가 그들의 딸들로 네 아들들의 아내를 삼음으로 그들의 딸들이 그 신들을 음란히 섬기며 네 아들로 그들의 신들을 음란히 섬기게 할까 함이니라","reference":"출애굽기 34:16","category":"$undefined"},{"id":"2514","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":17,"text":"너는 신상들을 부어 만들지 말지니라 !","reference":"출애굽기 34:17","category":"$undefined"},{"id":"2515","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":18,"text":"너는 무교절을 지키되 내가 네게 명한대로 아빕월 그 기한에 칠일 동안 무교병을 먹으라 이는 네가 아빕월에 애굽에서 나왔음이니라","reference":"출애굽기 34:18","category":"$undefined"},{"id":"2516","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":19,"text":"무릇 초태생은 다 내 것이며 무릇 네 가축의 수컷 처음 난 우양도 다 그러하며","reference":"출애굽기 34:19","category":"$undefined"},{"id":"2517","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":20,"text":"나귀의 첫새끼는 어린 양으로 대속할 것이요 그렇게 아니하려면 그 목을 꺾을 것이며 네 아들 중 장자는 다 대속할지며 빈손으로 내 얼굴을 보지 말지니라 !","reference":"출애굽기 34:20","category":"$undefined"},{"id":"2518","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":21,"text":"너는 엿새동안 일하고 제 칠일에는 쉴지니 밭 갈 때에나 거둘 때에도 쉴지며","reference":"출애굽기 34:21","category":"$undefined"},{"id":"2519","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":22,"text":"칠칠절 곧 맥추의 초실절을 지키고 가을에는 수장절을 지키라 !","reference":"출애굽기 34:22","category":"$undefined"},{"id":"2520","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":23,"text":"너희 모든 남자는 매년 세번씩 주 여호와 이스라엘의 하나님 앞에 보일지라","reference":"출애굽기 34:23","category":"$undefined"},{"id":"2521","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":24,"text":"내가 열방을 네 앞에서 쫓아내고 네 지경을 넓히리니 네가 매년 세번씩 여호와 너희 하나님께 보이러 올 때에 아무 사람도 네 땅을 탐내어 엿보지 못하리라 !","reference":"출애굽기 34:24","category":"$undefined"},{"id":"2522","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":25,"text":"너는 내 희생의 피를 유교병과 함께 드리지 말며 유월절 희생을 아침까지 두지 말지며","reference":"출애굽기 34:25","category":"$undefined"},{"id":"2523","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":26,"text":"너의 토지 소산의 처음 익은 것을 가져다가 너의 하나님 여호와의 전에 드릴지며 너는 염소 새끼를 그 어미의 젖으로 삶지 말지니라","reference":"출애굽기 34:26","category":"$undefined"},{"id":"2524","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":27,"text":"여호와께서 모세에게 이르시되 너는 이 말들을 기록하라 내가 이 말들의 뜻대로 너와 이스라엘과 언약을 세웠음이니라 하시니라","reference":"출애굽기 34:27","category":"$undefined"},{"id":"2525","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":28,"text":"모세가 여호와와 함께 사십일 사십야를 거기 있으면서 떡도 먹지 아니하였고 물도 마시지 아니하였으며 여호와께서는 언약의 말씀 곧 십계를 그 판들에 기록하셨더라","reference":"출애굽기 34:28","category":"$undefined"},{"id":"2526","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":29,"text":"모세가 그 증거의 두 판을 자기 손에 들고 시내산에서 내려오니 그 산에서 내려올 때에 모세는 자기가 여호와와 말씀하였음을 인하여 얼굴 꺼풀에 광채가 나나 깨닫지 못하였더라","reference":"출애굽기 34:29","category":"$undefined"},{"id":"2527","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":30,"text":"아론과 온 이스라엘 자손이 모세를 볼 때에 모세의 얼굴 꺼풀에 광채 남을 보고 그에게 가까이 하기를 두려워하더니","reference":"출애굽기 34:30","category":"$undefined"},{"id":"2528","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":31,"text":"모세가 그들을 부르니 아론과 회중의 모든 어른이 모세에게로 오고 모세가 그들과 말하니","reference":"출애굽기 34:31","category":"$undefined"},{"id":"2529","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":32,"text":"그 후에야 온 이스라엘 자손이 가까이 오는지라 모세가 여호와께서 시내산에서 자기에게 이르신 말씀을 다 그들에게 명하고","reference":"출애굽기 34:32","category":"$undefined"},{"id":"2530","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":33,"text":"그들에게 말하기를 마치고 수건으로 자기 얼굴을 가리웠더라","reference":"출애굽기 34:33","category":"$undefined"},{"id":"2531","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":34,"text":"그러나 모세가 여호와 앞에 들어가서 함께 말씀할 때에는 나오기까지 수건을 벗고 있다가 나와서는 그 명하신 일을 이스라엘 자손에게 고하며","reference":"출애굽기 34:34","category":"$undefined"},{"id":"2532","book":"출애굽기","book_name":"출애굽기","chapter":34,"verse":35,"text":"이스라엘 자손이 모세의 얼굴의 광채를 보는고로 모세가 여호와께 말씀하러 들어가기까지 다시 수건으로 자기 얼굴을 가리웠더라","reference":"출애굽기 34:35","category":"$undefined"}],"bookSlug":"exodus"}]
