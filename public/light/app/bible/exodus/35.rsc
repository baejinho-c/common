2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":35,"verses":[{"id":"2533","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":1,"text":"모세가 이스라엘의 온 회중을 모으고 그들에게 이르되 `여호와께서 너희에게 명하사 행하게 하신 말씀이 이러하니라","reference":"출애굽기 35:1","category":"$undefined"},{"id":"2534","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":2,"text":"엿새 동안은 일하고 제 칠일은 너희에게 성일이니 여호와께 특별한 안식일이라 무릇 이날에 일하는 자를 죽일지니","reference":"출애굽기 35:2","category":"$undefined"},{"id":"2535","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":3,"text":"안식일에는 너희의 모든 처소에서 불도 피우지 말지니라 !'","reference":"출애굽기 35:3","category":"$undefined"},{"id":"2536","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":4,"text":"모세가 이스라엘 자손의 온 회중에게 고하여 가로되 `여호와의 명하신 일이 이러하니라 이르시기를","reference":"출애굽기 35:4","category":"$undefined"},{"id":"2537","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":5,"text":"너희의 소유 중에서 너희는 여호와께 드릴 것을 취하되 무릇 마음에 원하는 자는 그것을 가져다가 여호와께 드릴지니 곧 금과 은과 놋과","reference":"출애굽기 35:5","category":"$undefined"},{"id":"2538","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":6,"text":"청색, 자색, 홍색실과, 가는 베실과, 염소털과","reference":"출애굽기 35:6","category":"$undefined"},{"id":"2539","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":7,"text":"붉은 물 들인 수양의 가죽과, 해달의 가죽과, 조각목과","reference":"출애굽기 35:7","category":"$undefined"},{"id":"2540","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":8,"text":"등유와, 및 관유에 드는 향품과, 분향할 향을 만드는 향품과","reference":"출애굽기 35:8","category":"$undefined"},{"id":"2541","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":9,"text":"호마노며, 에봇과, 흉패에 물릴 보석이니라","reference":"출애굽기 35:9","category":"$undefined"},{"id":"2542","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":10,"text":"무릇 너희 중 마음이 지혜로운 자는 와서 여호와의 명하신 것을 다 만들지니","reference":"출애굽기 35:10","category":"$undefined"},{"id":"2543","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":11,"text":"곧 성막과, 그 막과, 그 덮개와, 그 갈고리와, 그 널판과, 그 띠와, 그 기둥과, 그 받침과,","reference":"출애굽기 35:11","category":"$undefined"},{"id":"2544","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":12,"text":"증거궤와, 그 채와, 속죄소와, 그 가리는 장과,","reference":"출애굽기 35:12","category":"$undefined"},{"id":"2545","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":13,"text":"상과, 그 채와, 그 모든 기구와, 진설병과,","reference":"출애굽기 35:13","category":"$undefined"},{"id":"2546","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":14,"text":"불 켜는 등대와, 그 기구와, 그 등잔과, 등유와,","reference":"출애굽기 35:14","category":"$undefined"},{"id":"2547","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":15,"text":"분향단과, 그 채와, 관유와, 분향할 향품과, 성막문의 장과,","reference":"출애굽기 35:15","category":"$undefined"},{"id":"2548","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":16,"text":"번제단과, 그 놋 그물과, 그 채와, 그 모든 기구와, 물두멍과, 그 받침과,","reference":"출애굽기 35:16","category":"$undefined"},{"id":"2549","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":17,"text":"뜰의 포장과, 그 기둥과, 그 받침과, 뜰문의 장과,","reference":"출애굽기 35:17","category":"$undefined"},{"id":"2550","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":18,"text":"장막 말뚝과, 뜰의 포장 말뚝과, 그 줄과,","reference":"출애굽기 35:18","category":"$undefined"},{"id":"2551","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":19,"text":"성소에서 섬기기 위하여 공교히 만든 옷 곧 제사 직분을 행할 때에 입는 제사장 아론의 거룩한 옷과 그 아들들의 옷이니라","reference":"출애굽기 35:19","category":"$undefined"},{"id":"2552","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":20,"text":"이스라엘 자손의 온 회중이 모세 앞에서 물러갔더니","reference":"출애굽기 35:20","category":"$undefined"},{"id":"2553","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":21,"text":"무릇 마음이 감동된 자와 무릇 자원하는 자가 와서 성막을 짓기 위하여 그 속에서 쓸 모든 것을 위하여, 거룩한 옷을 위하여 예물을 가져 여호와께 드렸으니","reference":"출애굽기 35:21","category":"$undefined"},{"id":"2554","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":22,"text":"곧 마음에 원하는 남녀가 와서 가슴 핀과, 귀고리와, 가락지와, 목거리와, 여러가지 금품을 가져 왔으되 사람마다 여호와께 금 예물을 드렸으며","reference":"출애굽기 35:22","category":"$undefined"},{"id":"2555","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":23,"text":"무릇 청색, 자색, 홍색실과, 가는 베실과, 염소털과, 붉은 물 들인 수양의 가죽과, 해달의 가죽이 있는 자도 가져 왔으며","reference":"출애굽기 35:23","category":"$undefined"},{"id":"2556","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":24,"text":"무릇 은과 놋으로 예물을 삼는 자는 가져다가 여호와께 드렸으며 무릇 섬기는 일에 소용되는 조각목이 있는 자는 가져 왔으며","reference":"출애굽기 35:24","category":"$undefined"},{"id":"2557","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":25,"text":"마음이 슬기로운 모든 여인은 손수 실을 낳고 그 낳은 청색, 자색, 홍색실과, 가는 베실을 가져 왔으며","reference":"출애굽기 35:25","category":"$undefined"},{"id":"2558","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":26,"text":"마음에 감동을 받아 슬기로운 모든 여인은 염소털로 실을 낳았으며","reference":"출애굽기 35:26","category":"$undefined"},{"id":"2559","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":27,"text":"모든 족장은 호마노와 및 에봇과 흉패에 물릴 보석을 가져 왔으며","reference":"출애굽기 35:27","category":"$undefined"},{"id":"2560","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":28,"text":"등불과, 관유와, 분향할 향에 소용되는 기름과, 향품을 가져 왔으니","reference":"출애굽기 35:28","category":"$undefined"},{"id":"2561","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":29,"text":"마음에 원하는 이스라엘 자손의 남녀마다 여호와께서 모세의 손을 빙자하여 명하신 모든 것을 만들기 위하여 물품을 가져다가 여호와께 즐거이 드림이 이러하였더라","reference":"출애굽기 35:29","category":"$undefined"},{"id":"2562","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":30,"text":"모세가 이스라엘 자손에게 이르되 `볼지어다 여호와께서 유다 지파 훌의 손자요 우리의 아들인 브사렐을 지명하여 부르시고","reference":"출애굽기 35:30","category":"$undefined"},{"id":"2563","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":31,"text":"하나님의 신을 그에게 충만케 하여 지혜와 총명과 지식으로 여러가지 일을 하게 하시되","reference":"출애굽기 35:31","category":"$undefined"},{"id":"2564","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":32,"text":"공교한 일을 연구하여 금과 은과 놋으로 일하게 하시며","reference":"출애굽기 35:32","category":"$undefined"},{"id":"2565","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":33,"text":"보석을 깎아 물리며 나무를 새기는 여러가지 공교한 일을 하게 하셨고","reference":"출애굽기 35:33","category":"$undefined"},{"id":"2566","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":34,"text":"또 그와 단 지파 아히사막의 아들 오홀리압을 감동시키사 가르치게 하시며","reference":"출애굽기 35:34","category":"$undefined"},{"id":"2567","book":"출애굽기","book_name":"출애굽기","chapter":35,"verse":35,"text":"지혜로운 마음을 그들에게 충만하게 하사 여러가지 일을 하게 하시되 조각하는 일과, 공교로운 일과, 청색, 자색, 홍색실과, 가는 베실로 수 놓은 일과 짜는 일과 그 외에 여러가지 일을 하게 하시고 공교로운 일을 연구하게 하셨나니","reference":"출애굽기 35:35","category":"$undefined"}],"bookSlug":"exodus"}]
