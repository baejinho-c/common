2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":36,"verses":[{"id":"2568","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":1,"text":"브사렐과 오홀리압과 및 마음이 지혜로운 사람 곧 여호와께서 지혜와 총명을 부으사 성소에 쓸 모든 일을 할 줄 알게 하심을 입은 자들은 여호와의 무릇 명하신 대로 할 것이니라'","reference":"출애굽기 36:1","category":"$undefined"},{"id":"2569","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":2,"text":"모세가 브살렐과 오홀리압과 및 마음이 지혜로운 사람 곧 그 마음에 여호와께로 지혜를 얻고 와서 그 일을 하려고 마음에 원하는 모든 자를 부르매","reference":"출애굽기 36:2","category":"$undefined"},{"id":"2570","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":3,"text":"그들이 이스라엘 자손의 성소의 모든 것을 만들기 위하여 가져 온 예물을 모세에게서 받으니라 그러나 백성이 아침마다 자원하는 예물을 연하여 가져오는 고로","reference":"출애굽기 36:3","category":"$undefined"},{"id":"2571","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":4,"text":"성소의 모든 일을 하는 지혜로운 자들이 각기 하는 일을 정지하고 와서","reference":"출애굽기 36:4","category":"$undefined"},{"id":"2572","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":5,"text":"모세에게 고하여 가로되 `백성이 너무 많이 가져 오므로 여호와의 명하신 일에 쓰기에 남음이 있나이다'","reference":"출애굽기 36:5","category":"$undefined"},{"id":"2573","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":6,"text":"모세가 명을 내리매 그들이 진중에 공포하여 가로되 `무론 남녀하고 성소에 드릴 예물을 다시 만들지 말라' 하매 백성이 가져오기를 정지하니","reference":"출애굽기 36:6","category":"$undefined"},{"id":"2574","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":7,"text":"있는 재료가 모든 일을 하기에 넉넉하여 남음이 있었더라","reference":"출애굽기 36:7","category":"$undefined"},{"id":"2575","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":8,"text":"일하는 사람 중에 마음이 지혜로운 모든 사람이 열 폭 앙장으로 성막을 지었으니 곧 가늘게 꼰 베실과, 청색, 자색, 홍색실로 그룹들을 무늬 놓아 짜서 지은 것이라","reference":"출애굽기 36:8","category":"$undefined"},{"id":"2576","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":9,"text":"매폭의 장은 이십 팔 규빗,광은 사 규빗으로 각 폭의 장단을 같게 하여","reference":"출애굽기 36:9","category":"$undefined"},{"id":"2577","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":10,"text":"그 다섯 폭을 서로 연하며, 또 그 다섯 폭을 서로 연하고","reference":"출애굽기 36:10","category":"$undefined"},{"id":"2578","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":11,"text":"연락할 말폭 가에 청색 고를 만들며, 다른 연락할 말폭 가에도 고를 만들되","reference":"출애굽기 36:11","category":"$undefined"},{"id":"2579","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":12,"text":"그 연락할 한 폭에 고 오십을 달고, 다른 연락할 한 폭의 가에도 고 오십을 달아, 그 고들이 서로 대하게 하고","reference":"출애굽기 36:12","category":"$undefined"},{"id":"2580","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":13,"text":"금 갈고리 오십을 만들어, 그 갈고리로 두 앙장을 연하여 한 막을 이루었더라","reference":"출애굽기 36:13","category":"$undefined"},{"id":"2581","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":14,"text":"그 성막을 덮는 막 곧 앙장을 염소털로 만들되 십 일폭을 만들었으니","reference":"출애굽기 36:14","category":"$undefined"},{"id":"2582","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":15,"text":"각 폭의 장은 삼십 규빗,광은 사 규빗으로 십 일폭의 장단을 같게 하여","reference":"출애굽기 36:15","category":"$undefined"},{"id":"2583","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":16,"text":"그 앙장 다섯 폭을 서로 연하며, 또 여섯 폭을 서로 연하고","reference":"출애굽기 36:16","category":"$undefined"},{"id":"2584","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":17,"text":"앙장을 연락할 말폭 가에도 고 오십을 달며, 다른 연락할 말폭 가에도 고 오십을 달고","reference":"출애굽기 36:17","category":"$undefined"},{"id":"2585","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":18,"text":"놋 갈고리 오십을 만들어, 그 앙장을 연합하여 한 막이 되게 하고","reference":"출애굽기 36:18","category":"$undefined"},{"id":"2586","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":19,"text":"붉은 물 들인 수양의 가죽으로 막의 덮개를 만들고 해달의 가죽으로 그 웃덮개를 만들었더라","reference":"출애굽기 36:19","category":"$undefined"},{"id":"2587","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":20,"text":"그가 또 조각목으로 성막에 세울 널판들을 만들었으니","reference":"출애굽기 36:20","category":"$undefined"},{"id":"2588","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":21,"text":"각 판의 장은 십 규빗,광은 일 규빗 반이며","reference":"출애굽기 36:21","category":"$undefined"},{"id":"2589","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":22,"text":"각 판에 두 촉이 있어 서로 연하게 하였으니 성막의 모든 판이 그러하며","reference":"출애굽기 36:22","category":"$undefined"},{"id":"2590","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":23,"text":"성막을 위하여 널판을 만들었으되, 남으로는 남편에 널판이 이십이라","reference":"출애굽기 36:23","category":"$undefined"},{"id":"2591","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":24,"text":"그 이십 널판 밑에 은받침 사십을 만들었으되, 곧 이 널판 밑에도 두 받침이 그 두 촉을 받게 하였으며","reference":"출애굽기 36:24","category":"$undefined"},{"id":"2592","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":25,"text":"성막 다른 편 곧 북편을 위하여도 널판 이십을 만들고","reference":"출애굽기 36:25","category":"$undefined"},{"id":"2593","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":26,"text":"또 은받침 사십을 만들었으니 곧 이 판 밑에도 두 받침이요, 저 판 밑에도 두 받침이며","reference":"출애굽기 36:26","category":"$undefined"},{"id":"2594","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":27,"text":"장막 뒤 곧 서편을 위하여는 널판 여섯을 만들었고","reference":"출애굽기 36:27","category":"$undefined"},{"id":"2595","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":28,"text":"장막 뒤 두 모퉁이 편을 위하여는 널판 둘을 만들되","reference":"출애굽기 36:28","category":"$undefined"},{"id":"2596","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":29,"text":"아래서부터 위까지 각기 두 겹 두께로 하여 윗고리에 이르게 하고 두 모퉁이 편을 다 그리하며","reference":"출애굽기 36:29","category":"$undefined"},{"id":"2597","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":30,"text":"그 널판은 여덟이요, 그 받침은 은받침 열 여섯이라, 각 널판 밑에 둘씩이었더라","reference":"출애굽기 36:30","category":"$undefined"},{"id":"2598","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":31,"text":"그가 또 조각목으로 띠를 만들었으니 곧 성막 이편 널판을 위하여 다섯이요","reference":"출애굽기 36:31","category":"$undefined"},{"id":"2599","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":32,"text":"성막 저편 널판을 위하여 다섯이요, 성막 뒤 곧 서편 널판을 위하여 다섯이며","reference":"출애굽기 36:32","category":"$undefined"},{"id":"2600","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":33,"text":"그 중간 띠를 만들되, 널판 중간 이 끝에서 저 끝에 미치게 하였으며","reference":"출애굽기 36:33","category":"$undefined"},{"id":"2601","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":34,"text":"그 널판들을 금으로 싸고 그 널판에 띠를 꿸 금고리를 만들고, 그 띠도 금으로 쌌더라","reference":"출애굽기 36:34","category":"$undefined"},{"id":"2602","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":35,"text":"그가 또 청색, 자색, 홍색실과, 가늘게 꼰 베실로 장을 짜고 그 위에 그룹들을 공교히 수 놓고","reference":"출애굽기 36:35","category":"$undefined"},{"id":"2603","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":36,"text":"조각목으로 네 기둥을 만들어 금으로 쌌으며, 그 갈고리는 금이며 기둥의 네 받침은 은으로 부어 만들었으며","reference":"출애굽기 36:36","category":"$undefined"},{"id":"2604","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":37,"text":"청색, 자색, 홍색실과, 가늘게 꼰 베실로 수 놓아 장막 문을 위하여 장을 만들고","reference":"출애굽기 36:37","category":"$undefined"},{"id":"2605","book":"출애굽기","book_name":"출애굽기","chapter":36,"verse":38,"text":"문장의 기둥 다섯과 그 갈고리를 만들고, 기둥머리와 그 가름대를 금으로 쌌으며 그 다섯 받침은 놋이었더라","reference":"출애굽기 36:38","category":"$undefined"}],"bookSlug":"exodus"}]
