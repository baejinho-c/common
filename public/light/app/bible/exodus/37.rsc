2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":37,"verses":[{"id":"2606","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":1,"text":"브사렐이 조각목으로 궤를 만들었으니 장이 이 규빗 반, 광이 일 규빗 반, 고가 일 규빗 반이며","reference":"출애굽기 37:1","category":"$undefined"},{"id":"2607","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":2,"text":"정금으로 안팎을 싸고 윗가로 돌아가며 금테를 만들었으며","reference":"출애굽기 37:2","category":"$undefined"},{"id":"2608","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":3,"text":"금고리 넷을 부어 만들어 네 발에 달았으니 곧 이편에 두 고리요, 저편에 두 고리며","reference":"출애굽기 37:3","category":"$undefined"},{"id":"2609","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":4,"text":"조각목으로 채를 만들어 금으로 싸고","reference":"출애굽기 37:4","category":"$undefined"},{"id":"2610","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":5,"text":"그 채를 궤 양편 고리에 꿰어 궤를 메게 하였으며","reference":"출애굽기 37:5","category":"$undefined"},{"id":"2611","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":6,"text":"정금으로 속죄소를 만들었으니 장이 이 규빗 반, 광이 일 규빗 반이며","reference":"출애굽기 37:6","category":"$undefined"},{"id":"2612","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":7,"text":"금으로 그룹 둘을 속죄소 양편에 쳐서 만들었으되","reference":"출애굽기 37:7","category":"$undefined"},{"id":"2613","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":8,"text":"한 그룹은 이편 끝에, 한 그룹은 저편 끝에 곧 속죄소와 한 덩이로 그 양편에 만들었으니","reference":"출애굽기 37:8","category":"$undefined"},{"id":"2614","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":9,"text":"그룹들이 그 날개를 높이 펴서 그 날개로 속죄소를 덮으며 그 얼굴을 서로 대하여 속죄소를 향하였더라","reference":"출애굽기 37:9","category":"$undefined"},{"id":"2615","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":10,"text":"그가 또 조각목으로 상을 만들었으니 장이 이 규빗, 광이 일 규빗, 고가 일 규빗 반이며","reference":"출애굽기 37:10","category":"$undefined"},{"id":"2616","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":11,"text":"정금으로 싸고 윗가로 돌아가며 금테를 둘렀으며","reference":"출애굽기 37:11","category":"$undefined"},{"id":"2617","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":12,"text":"그 사면에 손바닥 넓이만한 턱을 만들고 그 턱 주위에 금으로 테를 만들었고","reference":"출애굽기 37:12","category":"$undefined"},{"id":"2618","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":13,"text":"상을 위하여 금고리 넷을 부어 만들어 네 발 위 네 모퉁이에 달았으니","reference":"출애굽기 37:13","category":"$undefined"},{"id":"2619","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":14,"text":"그 고리가 턱 곁에 있어서 상을 메는 채를 꿰게 하였으며","reference":"출애굽기 37:14","category":"$undefined"},{"id":"2620","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":15,"text":"또 조각목으로 상 멜 채를 만들어 금으로 쌌으며","reference":"출애굽기 37:15","category":"$undefined"},{"id":"2621","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":16,"text":"상 위의 기구 곧 대접과, 숟가락과, 잔과, 붓는 병을 정금으로 만들었더라","reference":"출애굽기 37:16","category":"$undefined"},{"id":"2622","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":17,"text":"그가 또 정금으로 등대를 만들되 그것을 쳐서 만들었으니 그 밑판과, 줄기와, 잔과, 꽃받침과, 꽃이 그것과 한 덩이로 되었고","reference":"출애굽기 37:17","category":"$undefined"},{"id":"2623","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":18,"text":"여섯 가지가 그 곁에서 나왔으니 곧 등대의 세 가지는 저편으로 나왔고, 등대의 세 가지는 이 편으로 나왔으며","reference":"출애굽기 37:18","category":"$undefined"},{"id":"2624","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":19,"text":"이 편 가지에 살구꽃 형상의 잔 셋과, 꽃받침과, 꽃이 있고 저편 가지에 살구꽃 형상의 잔 셋과, 꽃받침과, 꽃이 있어 등대에서 나온 여섯 가지가 그러하며","reference":"출애굽기 37:19","category":"$undefined"},{"id":"2625","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":20,"text":"등대 줄기에는 살구꽃 형상의 잔 넷과, 꽃받침과, 꽃이 있고","reference":"출애굽기 37:20","category":"$undefined"},{"id":"2626","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":21,"text":"등대에서 나온 여섯 가지를 위하여는 꽃받침이 있게 하였으되 두가지 아래 한 꽃받침이 있어 줄기와 연하였고 또 두 가지 아래 한 꽃받침이 있어 줄기와 연하게 하였으니","reference":"출애굽기 37:21","category":"$undefined"},{"id":"2627","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":22,"text":"이 꽃받침과 가지들을 줄기와 연하여 전부를 정금으로 쳐서 만들었으며","reference":"출애굽기 37:22","category":"$undefined"},{"id":"2628","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":23,"text":"등잔 일곱과, 그 불집게와, 불똥 그릇을 정금으로 만들었으니","reference":"출애굽기 37:23","category":"$undefined"},{"id":"2629","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":24,"text":"등대와 그 모든 기구는 정금 한 달란트로 만들었더라","reference":"출애굽기 37:24","category":"$undefined"},{"id":"2630","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":25,"text":"그가 또 조각목으로 분향할 단을 만들었으니 장이 일 규빗이요, 광이 일 규빗이라 네모 반듯하고 고는 이 규빗이며 그 뿔들이 단과 연하였으며","reference":"출애굽기 37:25","category":"$undefined"},{"id":"2631","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":26,"text":"단 상면과 전후 좌우면과 그 뿔을 정금으로 싸고 주위에 금테를 둘렀고","reference":"출애굽기 37:26","category":"$undefined"},{"id":"2632","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":27,"text":"그 테 아래 양 편에 금고리 둘을 만들었으되 곧 그 양 편에 만들어 단을 메는 채를 꿰게 하였으며","reference":"출애굽기 37:27","category":"$undefined"},{"id":"2633","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":28,"text":"조각목으로 그 채를 만들어 금으로 쌌으며","reference":"출애굽기 37:28","category":"$undefined"},{"id":"2634","book":"출애굽기","book_name":"출애굽기","chapter":37,"verse":29,"text":"거룩한 관유와 향품으로 정결한 향을 만들었으되 향을 만드는 법대로 하였더라","reference":"출애굽기 37:29","category":"$undefined"}],"bookSlug":"exodus"}]
