2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":38,"verses":[{"id":"2635","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":1,"text":"그가 또 조각목으로 번제단을 만들었으니 장이 오 규빗이요, 광이 오 규빗이라 네모 반듯하고 고는 삼 규빗이며","reference":"출애굽기 38:1","category":"$undefined"},{"id":"2636","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":2,"text":"그 네 모퉁이 위에 그 뿔을 만들되 그 뿔을 단과 연하게 하고 단을 놋으로 쌌으며","reference":"출애굽기 38:2","category":"$undefined"},{"id":"2637","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":3,"text":"단의 모든 기구 곧 통과, 부삽과, 대야와, 고기 갈고리와, 불 옮기는 그릇을 다 놋으로 만들고","reference":"출애굽기 38:3","category":"$undefined"},{"id":"2638","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":4,"text":"단을 위하여 놋 그물을 만들어 단 사면 가장자리 아래 두되 단 절반에 오르게 하고","reference":"출애굽기 38:4","category":"$undefined"},{"id":"2639","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":5,"text":"그 놋 그물 네 모퉁이에 채를 꿸 고리 넷을 부어 만들었으며","reference":"출애굽기 38:5","category":"$undefined"},{"id":"2640","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":6,"text":"채를 조각목으로 만들어 놋으로 싸고","reference":"출애굽기 38:6","category":"$undefined"},{"id":"2641","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":7,"text":"단 양편 고리에 그 채를 꿰어 메게 하였으며 단은 널판으로 비게 만들었더라","reference":"출애굽기 38:7","category":"$undefined"},{"id":"2642","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":8,"text":"그가 놋으로 물두멍을 만들고 그 받침도 놋으로 하였으니 곧 회막문에서 수종드는 여인들의 거울로 만들었더라","reference":"출애굽기 38:8","category":"$undefined"},{"id":"2643","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":9,"text":"그가 또 뜰을 만들었으니 남으로 뜰의 남편에는 세마포 포장이 백 규빗이라","reference":"출애굽기 38:9","category":"$undefined"},{"id":"2644","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":10,"text":"그 기둥이 스물이며, 그 받침이 스물이니, 놋이요 기둥의 갈고리와 가름대는 은이며","reference":"출애굽기 38:10","category":"$undefined"},{"id":"2645","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":11,"text":"그 북편에도 백 규빗이라, 그 기둥이 스물이며, 그 받침이 스물이니, 놋이요 기둥의 갈고리와 가름대는 은이며","reference":"출애굽기 38:11","category":"$undefined"},{"id":"2646","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":12,"text":"서편에 포장은 오십 규빗이라, 그 기둥이 열이요, 받침이 열이며, 기둥의 갈고리와, 가름대는 은이며","reference":"출애굽기 38:12","category":"$undefined"},{"id":"2647","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":13,"text":"동으로 동편에도 오십 규빗이라","reference":"출애굽기 38:13","category":"$undefined"},{"id":"2648","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":14,"text":"문 이편의 포장이 십 오 규빗이요, 그 기둥이 셋이요, 받침이 셋이며","reference":"출애굽기 38:14","category":"$undefined"},{"id":"2649","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":15,"text":"문 저편도 그와 같으니 뜰문 이편,저편의 포장이 십 오 규빗씩이요, 그 기둥이 셋씩, 받침이 셋씩이라","reference":"출애굽기 38:15","category":"$undefined"},{"id":"2650","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":16,"text":"뜰 사면의 포장은 세마포요","reference":"출애굽기 38:16","category":"$undefined"},{"id":"2651","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":17,"text":"기둥 받침은 놋이요, 기둥의 갈고리와 가름대는 은이요, 기둥머리 싸개는 은이며, 뜰의 모든 기둥에 은 가름대를 꿰었으며","reference":"출애굽기 38:17","category":"$undefined"},{"id":"2652","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":18,"text":"뜰의 문장을 청색, 자색, 홍색실과, 가늘게 꼰 베실로 수 놓아 짰으니 장은 이십 규빗이요, 광 곧 고는 뜰의 포장과 같이 오 규빗이며","reference":"출애굽기 38:18","category":"$undefined"},{"id":"2653","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":19,"text":"그 기둥은 넷인데 그 받침 넷은 놋이요, 그 갈고리는 은이요, 그 머리 싸개와 가름대도 은이며","reference":"출애굽기 38:19","category":"$undefined"},{"id":"2654","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":20,"text":"성막 말뚝과 뜰의 사면 포장 말뚝은 다 놋이더라","reference":"출애굽기 38:20","category":"$undefined"},{"id":"2655","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":21,"text":"성막 곧 증거막을 위하여 레위 사람의 쓴 재료의 물목은 제사장 아론의 아들 이다말이 모세의 명대로 계산하였으며","reference":"출애굽기 38:21","category":"$undefined"},{"id":"2656","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":22,"text":"유다 지파 훌의 손자요 우리의 아들인 브사렐은 여호와께서 모세에게 명하신 모든 것을 만들었고","reference":"출애굽기 38:22","category":"$undefined"},{"id":"2657","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":23,"text":"단 지파 아히사막의 아들 오홀리압은 그와 함께 하였으니 오홀리압은 재능이 있어서 조각하며 또 청색, 자색, 홍색실과, 가는 베실로 수 놓은 자더라","reference":"출애굽기 38:23","category":"$undefined"},{"id":"2658","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":24,"text":"성소 건축 비용으로 드린 금은 성소의 세겔대로 이십 구 달란트와 칠백 삼십 세겔이며","reference":"출애굽기 38:24","category":"$undefined"},{"id":"2659","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":25,"text":"조사를 받은 회중의 드린 은은 성소의 세겔대로 일백 달란트와 일천 칠백 칠십 오 세겔이니","reference":"출애굽기 38:25","category":"$undefined"},{"id":"2660","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":26,"text":"조사를 받은 자가 이십세 이상으로 육십만 삼천 오백 오십명인즉 성소의 세겔대로 매인에게 은 한 베가 곧 반 세겔씩이라","reference":"출애굽기 38:26","category":"$undefined"},{"id":"2661","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":27,"text":"은 일백 달란트로 성소의 판장 받침과 문장 기둥 받침 합 일백을 부어 만들었으니 매 받침에 한 달란트씩 합 일백 달란트요","reference":"출애굽기 38:27","category":"$undefined"},{"id":"2662","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":28,"text":"일천 칠백 칠십오 세겔로 기둥 갈고리를 만들고 기둥머리를 싸고 기둥 가름대를 만들었으며","reference":"출애굽기 38:28","category":"$undefined"},{"id":"2663","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":29,"text":"드린 놋은 칠십 달란트와 이천 사백 세겔이라","reference":"출애굽기 38:29","category":"$undefined"},{"id":"2664","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":30,"text":"이것으로 회막 문기둥 받침과, 놋 단과, 놋그물과, 단의 모든 기구를 만들었으며","reference":"출애굽기 38:30","category":"$undefined"},{"id":"2665","book":"출애굽기","book_name":"출애굽기","chapter":38,"verse":31,"text":"뜰 사면의 기둥 받침과 그 문장 기둥 받침이며 성막의 모든 말뚝과 뜰 사면의 모든 말뚝을 만들었더라","reference":"출애굽기 38:31","category":"$undefined"}],"bookSlug":"exodus"}]
