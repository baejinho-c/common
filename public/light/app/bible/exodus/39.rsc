2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":39,"verses":[{"id":"2666","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":1,"text":"그들이 여호와께서 모세에게 명하신대로 청색, 자색, 홍색실로 성소에서 섬기기 위한 정교한 옷을 만들고 또 아론을 위한 거룩한 옷을 만들었더라","reference":"출애굽기 39:1","category":"$undefined"},{"id":"2667","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":2,"text":"그가 또 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 에봇을 만들었으되","reference":"출애굽기 39:2","category":"$undefined"},{"id":"2668","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":3,"text":"금실을 얇게 쳐서 오려서 실을 만들어 청색, 자색, 홍색실과, 가는 베실에 섞어 공교히 짜고","reference":"출애굽기 39:3","category":"$undefined"},{"id":"2669","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":4,"text":"에봇을 위하여 견대를 만들어 그 두 끝에 달아 서로 연하게 하고","reference":"출애굽기 39:4","category":"$undefined"},{"id":"2670","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":5,"text":"에봇 위에 에봇을 매는 띠를 에봇과 같은 모양으로 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 에봇에 붙여 짰으니 여호와께서 모세에게 명하신대로 하였더라","reference":"출애굽기 39:5","category":"$undefined"},{"id":"2671","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":6,"text":"그들이 또 호마노를 깎아 금테에 물려 인을 새김 같이 이스라엘의 아들들의 이름을 그것에 새겨","reference":"출애굽기 39:6","category":"$undefined"},{"id":"2672","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":7,"text":"에봇 견대에 달아 이스라엘 자손의 기념 보석을 삼았으니 여호와께서 모세에게 명하신대로 하였더라","reference":"출애굽기 39:7","category":"$undefined"},{"id":"2673","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":8,"text":"그가 또 흉패를 공교히 짜되 에봇과 같은 모양으로 금실과, 청색, 자색, 홍색실과, 가늘게 꼰 베실로 하였으니","reference":"출애굽기 39:8","category":"$undefined"},{"id":"2674","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":9,"text":"그것의 장이 한 뼘, 광이 한 뼘으로 네모 반듯하고 두 겹이며","reference":"출애굽기 39:9","category":"$undefined"},{"id":"2675","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":10,"text":"그것에 네 줄 보석을 물렸으니 곧 홍보석, 황옥, 녹주옥이 첫 줄이요","reference":"출애굽기 39:10","category":"$undefined"},{"id":"2676","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":11,"text":"둘째 줄은 석류석, 남보석, 홍마노요","reference":"출애굽기 39:11","category":"$undefined"},{"id":"2677","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":12,"text":"세째 줄은 호박, 백마노, 자수정이요","reference":"출애굽기 39:12","category":"$undefined"},{"id":"2678","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":13,"text":"네째 줄은 녹보석, 호마노, 벽옥이라 다 금테에 물렸으니","reference":"출애굽기 39:13","category":"$undefined"},{"id":"2679","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":14,"text":"이 보석들은 이스라엘 아들들의 이름 곧 그들의 이름대로 열 둘이라 인을 새김 같이 그 열 두 지파의 각 이름을 새겼으며","reference":"출애굽기 39:14","category":"$undefined"},{"id":"2680","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":15,"text":"그들이 또 정금으로 사슬을 노끈처럼 땋아 흉패에 붙이고","reference":"출애굽기 39:15","category":"$undefined"},{"id":"2681","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":16,"text":"또 금테 둘과 금고리 둘을 만들어 그 두 고리를 흉패 두 끝에 달고","reference":"출애굽기 39:16","category":"$undefined"},{"id":"2682","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":17,"text":"그 두 땋은 금사슬을 흉패 끝 두 고리에 꿰어 매었으며","reference":"출애굽기 39:17","category":"$undefined"},{"id":"2683","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":18,"text":"그 땋은 두 사슬의 다른 두 끝을 에봇 앞 두 견대의 금테에 매고","reference":"출애굽기 39:18","category":"$undefined"},{"id":"2684","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":19,"text":"또 금고리 둘을 만들어 흉패 두 끝에 달았으니 곧 그 에봇에 대한 안쪽 가에 달았으며","reference":"출애굽기 39:19","category":"$undefined"},{"id":"2685","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":20,"text":"또 금고리 둘을 만들어 에봇 앞 두 견대 아래 매는 자리 가까운편 곧 공교히 짠 에봇띠 윗편에 달고","reference":"출애굽기 39:20","category":"$undefined"},{"id":"2686","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":21,"text":"청색 끈으로 흉패 고리와 에봇 고리에 꿰어 흉패로 공교히 짠 에봇 띠 위에 붙여서 에봇을 떠나지 않게 하였으니 여호와께서 모세에게 명하신대로 하였더라","reference":"출애굽기 39:21","category":"$undefined"},{"id":"2687","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":22,"text":"그가 에봇 받침 긴 옷을 전부 청색으로 짜서 만들되","reference":"출애굽기 39:22","category":"$undefined"},{"id":"2688","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":23,"text":"그 옷의 두 어깨 사이에 구멍을 내고 갑옷 깃 같이 그 구멍 주위에 깃을 짜서 찢어지지 않게 하고","reference":"출애굽기 39:23","category":"$undefined"},{"id":"2689","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":24,"text":"청색, 자색, 홍색실과, 가는 베실로 그 옷 가장자리에 석류를 수 놓고","reference":"출애굽기 39:24","category":"$undefined"},{"id":"2690","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":25,"text":"정금으로 방울을 만들어 그 옷 가장자리로 돌아가며 석류 사이 사이에 달되","reference":"출애굽기 39:25","category":"$undefined"},{"id":"2691","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":26,"text":"방울과 석류를 서로 간격하여 공직하는 그 옷 가장자리로 돌아가며 달았으니 여호와께서 모세에게 명하신대로 하였더라","reference":"출애굽기 39:26","category":"$undefined"},{"id":"2692","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":27,"text":"그들이 또 직조한 가는 베로 아론과 그 아들들을 위하여 속옷을 짓고","reference":"출애굽기 39:27","category":"$undefined"},{"id":"2693","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":28,"text":"세마포로 두건을 짓고 세마포로 빛난 관을 만들고 가는 베실로 짜서 세마포 고의들을 만들고","reference":"출애굽기 39:28","category":"$undefined"},{"id":"2694","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":29,"text":"가는 베실과, 청색, 자색, 홍색실로 수 놓아 띠를 만들었으니 여호와께서 모세에게 명하신대로 하였더라","reference":"출애굽기 39:29","category":"$undefined"},{"id":"2695","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":30,"text":"그들이 또 정금으로 거룩한 패를 만들고 인을 새김 같이 그 위에 여호와께 성결이라 새기고","reference":"출애굽기 39:30","category":"$undefined"},{"id":"2696","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":31,"text":"그 패를 청색 끈으로 관 전면에 달았으니 여호와께서 모세에게 명하신 대로 하였더라","reference":"출애굽기 39:31","category":"$undefined"},{"id":"2697","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":32,"text":"이스라엘 자손이 이와 같이 성막 곧 회막의 모든 역사를 준공하여 여호와께서 모세에게 명하신대로 다 행하고","reference":"출애굽기 39:32","category":"$undefined"},{"id":"2698","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":33,"text":"그들이 성막을 모세에게로 가져왔으니 곧 막과, 그 모든 기구와, 그 갈고리들과, 그 널판들과, 그 띠들과, 그 기둥들과, 그 받침들과,","reference":"출애굽기 39:33","category":"$undefined"},{"id":"2699","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":34,"text":"붉은 물 들인 수양의 가죽 덮개와, 해달의 가죽 덮개와, 가리우는 장과,","reference":"출애굽기 39:34","category":"$undefined"},{"id":"2700","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":35,"text":"증거궤와, 그 채들과, 속죄소와,","reference":"출애굽기 39:35","category":"$undefined"},{"id":"2701","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":36,"text":"상과, 그 모든 기구와, 진설병과,","reference":"출애굽기 39:36","category":"$undefined"},{"id":"2702","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":37,"text":"정금 등대와, 그 잔 곧 벌여놓은 등잔과, 그 모든 기구와, 등유와,","reference":"출애굽기 39:37","category":"$undefined"},{"id":"2703","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":38,"text":"금단과, 관유와, 향기로운 향과, 장막 문장과,","reference":"출애굽기 39:38","category":"$undefined"},{"id":"2704","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":39,"text":"놋단과, 그 놋 그물과, 그 채들과, 그 모든 기구와, 물두멍과, 그 받침과,","reference":"출애굽기 39:39","category":"$undefined"},{"id":"2705","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":40,"text":"뜰의 포장들과, 그 기둥들과, 그 받침들과, 뜰문의 장과, 그 줄들과, 그 말뚝들과, 회막의 소용 곧 성막의 모든 기구와,","reference":"출애굽기 39:40","category":"$undefined"},{"id":"2706","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":41,"text":"성소에서 섬기기 위한 정교한 옷 곧 제사 직분을 행할 때에 입는 제사장 아론의 거룩한 옷과 그 아들들의 옷이라","reference":"출애굽기 39:41","category":"$undefined"},{"id":"2707","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":42,"text":"여호와께서 모세에게 명하신대로 이스라엘 자손이 모든 역사를 필하매","reference":"출애굽기 39:42","category":"$undefined"},{"id":"2708","book":"출애굽기","book_name":"출애굽기","chapter":39,"verse":43,"text":"모세가 그 필한 모든 것을 본즉 여호와께서 명하신대로 되었으므로 그들에게 축복하였더라","reference":"출애굽기 39:43","category":"$undefined"}],"bookSlug":"exodus"}]
