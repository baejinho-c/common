2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":4,"verses":[{"id":"1603","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":1,"text":"모세가 대답하여 가로되 `그러나 그들이 나를 믿지 아니하며 내 말을 듣지 아니하고 이르기를 여호와께서 네게 나타나지 아니하셨다 하리이다'","reference":"출애굽기 4:1","category":"$undefined"},{"id":"1604","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":2,"text":"여호와께서 그에게 이르시되 네 손에 있는 것이 무엇이냐 ? 그가 가로되 `지팡이니이다'","reference":"출애굽기 4:2","category":"$undefined"},{"id":"1605","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":3,"text":"여호와께서 가라사대 그것을 땅에 던지라 ! 곧 땅에 던지니 그것이 뱀이 된지라 모세가 뱀 앞에서 피하매","reference":"출애굽기 4:3","category":"$undefined"},{"id":"1606","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":4,"text":"여호와께서 모세에게 이르시되 네 손을 내밀어 그 꼬리를 잡으라 ! 그가 손을 내밀어 잡으니 그 손에서 지팡이가 된지라","reference":"출애굽기 4:4","category":"$undefined"},{"id":"1607","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":5,"text":"또 가라사대 이는 그들로 그 조상의 하나님 곧 아브라함의 하나님, 이삭의 하나님, 야곱의 하나님 여호와가 네게 나타난 줄을 믿게 함이니라 하시고","reference":"출애굽기 4:5","category":"$undefined"},{"id":"1608","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":6,"text":"여호와께서 또 가라사대 네 손을 품에 넣으라 ! 하시매 손을 품에 넣었다가 내어보니 그 손에 문둥병이 발하여 눈 같이 흰지라","reference":"출애굽기 4:6","category":"$undefined"},{"id":"1609","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":7,"text":"가라사대 네 손을 다시 품에 넣으라 ! 하시매 그가 다시 손을 품에 넣었다가 내어보니 손이 여상하더라","reference":"출애굽기 4:7","category":"$undefined"},{"id":"1610","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":8,"text":"여호와께서 가라사대 그들이 너를 믿지 아니하며 그 처음 이적의 표징을 받지 아니하여도 둘째 이적의 표징은 믿으리라","reference":"출애굽기 4:8","category":"$undefined"},{"id":"1611","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":9,"text":"그들이 이 두 이적을 믿지 아니하며 네 말을 듣지 아니하거든 너는 하수를 조금 취하여다가 육지에 부으라 ! 네가 취한 하수가 육지에서 피가 되리라","reference":"출애굽기 4:9","category":"$undefined"},{"id":"1612","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":10,"text":"모세가 여호와께 고하되 `주여, 나는 본래 말에 능치 못한 자라 주께서 주의 종에게 명하신 후에도 그러하니 나는 입이 뻣뻣하고 혀가 둔한 자니이다'","reference":"출애굽기 4:10","category":"$undefined"},{"id":"1613","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":11,"text":"여호와께서 그에게 이르시되 누가 사람의 입을 지었느뇨 ! 누가 벙어리나 귀머거리나 눈 밝은 자나 소경이 되게 하였느뇨 ! 나 여호와가 아니뇨 ?","reference":"출애굽기 4:11","category":"$undefined"},{"id":"1614","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":12,"text":"이제 가라 내가 네 입과 함께 있어서 할 말을 가르치리라","reference":"출애굽기 4:12","category":"$undefined"},{"id":"1615","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":13,"text":"모세가 가로되 `주여, 보낼만한 자를 보내소서'","reference":"출애굽기 4:13","category":"$undefined"},{"id":"1616","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":14,"text":"여호와께서 모세를 향하여 노를 발하시고 가라사대 레위 사람 네 형 아론이 있지 아니하뇨 ? 그의 말 잘함을 내가 아노라 그가 너를 만나러 나오나니 그가 너를 볼 때에 마음에 기뻐할 것이라","reference":"출애굽기 4:14","category":"$undefined"},{"id":"1617","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":15,"text":"너는 그에게 말하고 그 입에 말을 주라 내가 네 입과 그의 입에 함께 있어서 너의 행할 일을 가르치리라","reference":"출애굽기 4:15","category":"$undefined"},{"id":"1618","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":16,"text":"그가 너를 대신하여 백성에게 말할 것이니 그는 네 입을 대신할 것이요 너는 그에게 하나님 같이 되리라","reference":"출애굽기 4:16","category":"$undefined"},{"id":"1619","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":17,"text":"너는 이 지팡이를 손에 잡고 이것으로 이적을 행할지니라","reference":"출애굽기 4:17","category":"$undefined"},{"id":"1620","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":18,"text":"모세가 장인 이드로에게로 돌아가서 그에게 이르되 `내가 애굽에 있는 내 형제들에게로 돌아가서 그들이 생존하였는지 보려하오니 나로 가게 하소서' 이드로가 그에게 '평안히 가라' 하니라","reference":"출애굽기 4:18","category":"$undefined"},{"id":"1621","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":19,"text":"여호와께서 미디안에서 모세에게 이르시되 애굽으로 돌아가라 네 생명을 찾던 자가 다 죽었느니라","reference":"출애굽기 4:19","category":"$undefined"},{"id":"1622","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":20,"text":"모세가 그 아내와 아들들을 나귀에 태우고 애굽으로 돌아가는데 하나님의 지팡이를 손에 잡았더라","reference":"출애굽기 4:20","category":"$undefined"},{"id":"1623","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":21,"text":"여호와께서 모세에게 이르시되 네가 애굽으로 돌아가거든 내가 네 손에 준 이적을 바로 앞에서 다 행하라 그러나 내가 그의 마음을 강퍅케 한즉 그가 백성을 놓지 아니하리니","reference":"출애굽기 4:21","category":"$undefined"},{"id":"1624","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":22,"text":"너는 바로에게 이르기를 여호와의 말씀에 이스라엘은 내 아들, 내 장자라 !","reference":"출애굽기 4:22","category":"$undefined"},{"id":"1625","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":23,"text":"내가 네게 이르기를 내 아들을 놓아서 나를 섬기게 하라 하여도 네가 놓기를 거절하니 내가 네 아들 네 장자를 죽이리라 하셨다 하라 하시니라","reference":"출애굽기 4:23","category":"$undefined"},{"id":"1626","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":24,"text":"여호와께서 길의 숙소에서 모세를 만나사 그를 죽이려 하시는지라","reference":"출애굽기 4:24","category":"$undefined"},{"id":"1627","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":25,"text":"십보라가 차돌을 취하여 그 아들의 양피를 베어 모세의 발 앞에 던지며 가로되 `당신은 참으로 내게 피 남편이로다' 하니","reference":"출애굽기 4:25","category":"$undefined"},{"id":"1628","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":26,"text":"여호와께서 모세를 놓으시니라 그 때에 십보라가 피 남편이라 함은 할례를 인함이었더라","reference":"출애굽기 4:26","category":"$undefined"},{"id":"1629","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":27,"text":"여호와께서 아론에게 이르시되 광야에 가서 모세를 맞으라 하시매 그가 가서 하나님의 산에서 모세를 만나 그에게 입맞추니","reference":"출애굽기 4:27","category":"$undefined"},{"id":"1630","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":28,"text":"모세가 여호와께서 자기에게 부탁하여 보내신 모든 말씀과 여호와께서 자기에게 명하신 모든 이적을 아론에게 고하니라","reference":"출애굽기 4:28","category":"$undefined"},{"id":"1631","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":29,"text":"모세와 아론이 가서 이스라엘 자손의 모든 장로를 모으고","reference":"출애굽기 4:29","category":"$undefined"},{"id":"1632","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":30,"text":"아론이 여호와께서 모세에게 명하신 모든 말씀을 전하고 백성 앞에서 이적을 행하니","reference":"출애굽기 4:30","category":"$undefined"},{"id":"1633","book":"출애굽기","book_name":"출애굽기","chapter":4,"verse":31,"text":"백성이 믿으며 여호와께서 이스라엘 자손을 돌아보시고 그 고난을 감찰하셨다 함을 듣고 머리 숙여 경배하였더라","reference":"출애굽기 4:31","category":"$undefined"}],"bookSlug":"exodus"}]
