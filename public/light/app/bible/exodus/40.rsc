2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":40,"verses":[{"id":"2709","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 40:1","category":"$undefined"},{"id":"2710","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":2,"text":"너는 정월 초일일에 성막 곧 회막을 세우고","reference":"출애굽기 40:2","category":"$undefined"},{"id":"2711","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":3,"text":"또 증거궤를 들여 놓고 또 장으로 그 궤를 가리우고","reference":"출애굽기 40:3","category":"$undefined"},{"id":"2712","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":4,"text":"또 상을 들여 놓고 그 위에 물품을 진설하고 등대를 들여 놓고 불을 켜고","reference":"출애굽기 40:4","category":"$undefined"},{"id":"2713","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":5,"text":"또 금 향단을 증거궤 앞에 두고 성막 문에 장을 달고","reference":"출애굽기 40:5","category":"$undefined"},{"id":"2714","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":6,"text":"또 번제단을 회막의 성막 문 앞에 놓고","reference":"출애굽기 40:6","category":"$undefined"},{"id":"2715","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":7,"text":"또 물두멍을 회막과 단 사이에 놓고 그 속에 물을 담고","reference":"출애굽기 40:7","category":"$undefined"},{"id":"2716","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":8,"text":"또 뜰 주위에 포장을 치고 뜰 문에 장을 달고","reference":"출애굽기 40:8","category":"$undefined"},{"id":"2717","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":9,"text":"또 관유를 취하여 성막과 그 안에 있는 모든 것에 발라 그것과 그 모든 기구를 거룩하게 하라 ! 그것이 거룩하리라","reference":"출애굽기 40:9","category":"$undefined"},{"id":"2718","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":10,"text":"너는 또 번제단과 그 모든 기구에 발라 그 안을 거룩하게 하라 ! 그 단이 지극히 거룩하리라","reference":"출애굽기 40:10","category":"$undefined"},{"id":"2719","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":11,"text":"너는 또 물두멍과 그 받침에 발라 거룩하게 하고","reference":"출애굽기 40:11","category":"$undefined"},{"id":"2720","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":12,"text":"또 아론과 그 아들들을 회막문으로 데려다가 물로 씻기고","reference":"출애굽기 40:12","category":"$undefined"},{"id":"2721","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":13,"text":"아론에게 거룩한 옷을 입히고 그에게 기름을 부어 거룩하게 하여 그로 내게 제사장의 직분을 행하게 하라","reference":"출애굽기 40:13","category":"$undefined"},{"id":"2722","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":14,"text":"너는 또 그 아들들을 데려다가 그들에게 겉옷을 입히고","reference":"출애굽기 40:14","category":"$undefined"},{"id":"2723","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":15,"text":"그 아비에게 기름을 부음 같이 그들에게도 부어서 그들로 내게 제사장 직분을 행하게 하라 그들이 기름 부음을 받았은즉 대대로 영영히 제사장이 되리라 하시매","reference":"출애굽기 40:15","category":"$undefined"},{"id":"2724","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":16,"text":"모세가 그같이 행하되 곧 여호와께서 자기에게 명하신대로 다 행하였더라","reference":"출애굽기 40:16","category":"$undefined"},{"id":"2725","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":17,"text":"제 이년 정월 곧 그 달 초일일에 성막을 세우니라","reference":"출애굽기 40:17","category":"$undefined"},{"id":"2726","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":18,"text":"모세가 성막을 세우되, 그 받침들을 놓고 그 널판들을 세우고, 그 띠를 띠우고 그 기둥들을 세우고,","reference":"출애굽기 40:18","category":"$undefined"},{"id":"2727","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":19,"text":"또 성막 위에 막을 펴고 그 위에 덮개를 덮으니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:19","category":"$undefined"},{"id":"2728","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":20,"text":"그가 또 증거판을 궤 속에 넣고 채를 궤에 꿰고 속죄소를 궤 위에 두고","reference":"출애굽기 40:20","category":"$undefined"},{"id":"2729","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":21,"text":"또 그 궤를 성막에 들여 놓고 장을 드리워서 그 증거궤를 가리우니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:21","category":"$undefined"},{"id":"2730","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":22,"text":"그가 또 회막 안 곧 성막 북편으로 장 밖에 상을 놓고","reference":"출애굽기 40:22","category":"$undefined"},{"id":"2731","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":23,"text":"또 여호와 앞 그 상 위에 떡을 진설하니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:23","category":"$undefined"},{"id":"2732","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":24,"text":"그가 또 회막 안 곧 성막 남편에 등대를 놓아 상과 대하게 하고","reference":"출애굽기 40:24","category":"$undefined"},{"id":"2733","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":25,"text":"또 여호와 앞에 등잔에 불을 켜니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:25","category":"$undefined"},{"id":"2734","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":26,"text":"그가 또 금 향단을 회막 안 장 앞에 두고","reference":"출애굽기 40:26","category":"$undefined"},{"id":"2735","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":27,"text":"그 위에 향기로운 향을 사르니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:27","category":"$undefined"},{"id":"2736","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":28,"text":"그가 또 성막문에 장을 달고","reference":"출애굽기 40:28","category":"$undefined"},{"id":"2737","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":29,"text":"또 회막의 성막 문 앞에 번제단을 두고 번제와 소제를 그 위에 드리니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:29","category":"$undefined"},{"id":"2738","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":30,"text":"그가 또 물두멍을 회막과 단 사이에 두고 거기 씻을 물을 담고","reference":"출애굽기 40:30","category":"$undefined"},{"id":"2739","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":31,"text":"자기와 아론과 그 아들들이 거기서 수족을 씻되","reference":"출애굽기 40:31","category":"$undefined"},{"id":"2740","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":32,"text":"그들이 회막에 들어갈 때와 단에 가까이 갈 때에 씻었으니 여호와께서 모세에게 명하신 대로 되니라","reference":"출애굽기 40:32","category":"$undefined"},{"id":"2741","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":33,"text":"그가 또 성막과 단 사면 뜰에 포장을 치고 뜰문의 장을 다니라 모세가 이같이 역사를 필하였더라","reference":"출애굽기 40:33","category":"$undefined"},{"id":"2742","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":34,"text":"그 후에 구름이 회막에 덮이고 여호와의 영광이 성막에 충만하매","reference":"출애굽기 40:34","category":"$undefined"},{"id":"2743","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":35,"text":"모세가 회막에 들어갈 수 없었으니 이는 구름이 회막 위에 덮이고 여호와의 영광이 성막에 충만함이었으며","reference":"출애굽기 40:35","category":"$undefined"},{"id":"2744","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":36,"text":"구름이 성막 위에서 떠오를 때에는 이스라엘 자손이 그 모든 행하는 길에 앞으로 발행하였고","reference":"출애굽기 40:36","category":"$undefined"},{"id":"2745","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":37,"text":"구름이 떠오르지 않을 때에는 떠오르는 날까지 발행하지 아니하였으며","reference":"출애굽기 40:37","category":"$undefined"},{"id":"2746","book":"출애굽기","book_name":"출애굽기","chapter":40,"verse":38,"text":"낮에는 여호와의 구름이 성막 위에 있고 밤에는 불이 그 구름 가운데 있음을 이스라엘의 온 족속이 그 모든 행하는 길에서 친히 보았더라","reference":"출애굽기 40:38","category":"$undefined"}],"bookSlug":"exodus"}]
