2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":5,"verses":[{"id":"1634","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":1,"text":"그 후에 모세와 아론이 가서 바로에게 이르되 `이스라엘 하나님 여호와의 말씀에 내 백성을 보내라 그들이 광야에서 내 앞에 절기를 지킬 것이니라 하셨나이다'","reference":"출애굽기 5:1","category":"$undefined"},{"id":"1635","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":2,"text":"바로가 가로되 `여호와가 누구관대 내가 그 말을 듣고 이스라엘을 보내겠느냐 ? 나는 여호와를 알지 못하니 이스라엘도 보내지 아니하리라'","reference":"출애굽기 5:2","category":"$undefined"},{"id":"1636","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":3,"text":"그들이 가로되 `히브리인의 하나님이 우리에게 나타나셨은즉 우리가 사흘길쯤 광야에 가서 우리 하나님 여호와께 희생을 드리려 하오니 가기를 허락하소서 여호와께서 온역이나 칼로 우리를 치실까 두려워하나이다'","reference":"출애굽기 5:3","category":"$undefined"},{"id":"1637","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":4,"text":"애굽왕이 그들에게 이르되 `모세와 아론아 ! 너희가 어찌하여 백성으로 역사를 쉬게 하느냐 ? 가서 너희의 역사나 하라'","reference":"출애굽기 5:4","category":"$undefined"},{"id":"1638","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":5,"text":"또 가로되 `이제 나라에 이 백성이 많거늘 너희가 그들로 역사를 쉬게 하는도다' 하고","reference":"출애굽기 5:5","category":"$undefined"},{"id":"1639","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":6,"text":"바로가 당일에 백성의 간역자들과 패장들에게 명하여 가로되","reference":"출애굽기 5:6","category":"$undefined"},{"id":"1640","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":7,"text":"`너희는 백성에게 다시는 벽돌 소용의 짚을 전과 같이 주지 말고 그들로 가서 스스로 줍게 하라","reference":"출애굽기 5:7","category":"$undefined"},{"id":"1641","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":8,"text":"또 그들의 전에 만든 벽돌 수효대로 그들로 만들게 하고 감하지 말라 그들이 게으르므로 소리질러 이르기를 우리가 가서 우리 하나님께 희생을 드리자 하나니","reference":"출애굽기 5:8","category":"$undefined"},{"id":"1642","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":9,"text":"그 사람들의 고역을 무겁게 함으로 수고롭게 하여 그들로 거짓말을 듣지 않게 하라'","reference":"출애굽기 5:9","category":"$undefined"},{"id":"1643","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":10,"text":"간역자들과 패장들이 나아가 백성에게 일러 가로되 `바로의 말씀에 내가 너희에게 짚을 주지 아니하리니","reference":"출애굽기 5:10","category":"$undefined"},{"id":"1644","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":11,"text":"너희는 짚을 얻을 곳으로 가서 주우라 너희 일은 조금도 감하지 아니하리라' 하셨느니라","reference":"출애굽기 5:11","category":"$undefined"},{"id":"1645","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":12,"text":"백성이 애굽 온 땅에 흩어져 곡초 그루터기를 거두어다가 짚을 대신하니","reference":"출애굽기 5:12","category":"$undefined"},{"id":"1646","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":13,"text":"간역자들이 그들을 독촉하여 가로되 `너희는 짚이 있을 때와 같이 당일 일을 당일에 마치라' 하며","reference":"출애굽기 5:13","category":"$undefined"},{"id":"1647","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":14,"text":"바로의 간역자들이 자기들의 세운바 이스라엘 자손의 패장들을 때리며 가로되 '너희가 어찌하여 어제와 오늘에 만드는 벽돌의 수효를 전과 같이 채우지 아니하였느냐 ?' 하니라","reference":"출애굽기 5:14","category":"$undefined"},{"id":"1648","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":15,"text":"이스라엘 자손의 패장들이 가서 바로에게 호소하여 가로되 `왕은 어찌하여 종들에게 이같이 하시나이까 ?","reference":"출애굽기 5:15","category":"$undefined"},{"id":"1649","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":16,"text":"종들에게 짚을 주지 아니하고 그들이 우리더러 벽돌을 만들라 하나이다 종들이 매를 맞으오니 이는 왕의 백성의 허물이니이다'","reference":"출애굽기 5:16","category":"$undefined"},{"id":"1650","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":17,"text":"바로가 가로되 `너희가 게으르다, 게으르다 그러므로 너희가 이르기를 우리가 가서 여호와께 희생을 드리자 하는도다","reference":"출애굽기 5:17","category":"$undefined"},{"id":"1651","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":18,"text":"이제 가서 일하라 짚은 너희에게 주지 않을지라도 너희가 벽돌을 여수히 바칠지니라'","reference":"출애굽기 5:18","category":"$undefined"},{"id":"1652","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":19,"text":"이스라엘 자손의 패장들이 너희의 매일 만드는 벽돌을 조금도 감하지 못하리라 함을 듣고 화가 몸에 미친 줄 알고","reference":"출애굽기 5:19","category":"$undefined"},{"id":"1653","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":20,"text":"그들이 바로를 떠나 나올 때에 모세와 아론이 길에 선 것을 만나","reference":"출애굽기 5:20","category":"$undefined"},{"id":"1654","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":21,"text":"그들에게 이르되 `너희가 우리로 바로의 눈과 그 신하의 눈에 미운 물건이 되게 하고 그들의 손에 칼을 주어 우리를 죽이게 하는도다 여호와는 너희를 감찰하시고 판단하시기를 원하노라'","reference":"출애굽기 5:21","category":"$undefined"},{"id":"1655","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":22,"text":"모세가 여호와께 돌아와서 고하되 `주여, 어찌하여 이 백성으로 학대를 당케 하셨나이까 ? 어찌하여 나를 보내셨나이까 ?","reference":"출애굽기 5:22","category":"$undefined"},{"id":"1656","book":"출애굽기","book_name":"출애굽기","chapter":5,"verse":23,"text":"내가 바로에게 와서 주의 이름으로 말함으로부터 그가 이 백성을 더 학대하며 주께서도 주의 백성을 구원치 아니하시나이다'","reference":"출애굽기 5:23","category":"$undefined"}],"bookSlug":"exodus"}]
