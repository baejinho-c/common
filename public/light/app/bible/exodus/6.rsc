11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":6,"verses":[{"id":"1657","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":1,"text":"여호와께서 모세에게 이르시되 이제 내가 바로에게 하는 일을 네가 보리라 강한 손을 더하므로 바로가 그들을 보내리라 강한 손을 더하므로 바로가 그들을 그 땅에서 쫓아내리라","reference":"출애굽기 6:1","category":"$undefined"},{"id":"1658","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":2,"text":"하나님이 모세에게 말씀하여 가라사대 나는 여호와로라 !","reference":"출애굽기 6:2","category":"$undefined"},{"id":"1659","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":3,"text":"내가 아브라함과 이삭과 야곱에게 전능의 하나님으로 나타났으나 나의 이름을 여호와로는 그들에게 알리지 아니하였고","reference":"출애굽기 6:3","category":"$undefined"},{"id":"1660","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":4,"text":"가나안 땅 곧 그들의 우거하는 땅을 주기로 그들과 언약하였더니","reference":"출애굽기 6:4","category":"$undefined"},{"id":"1661","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":5,"text":"이제 애굽 사람이 종을 삼은 이스라엘 자손의 신음을 듣고 나의 언약을 기억하노라","reference":"출애굽기 6:5","category":"$undefined"},{"id":"1662","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":6,"text":"그러므로 이스라엘 자손에게 말하기를 나는 여호와라 내가 애굽 사람의 무거운 짐 밑에서 너희를 빼어 내며 그 고역에서 너희를 건지며 편 팔과 큰 재앙으로 너희를 구속하여","reference":"출애굽기 6:6","category":"$undefined"},{"id":"1663","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":7,"text":"너희로 내 백성을 삼고 나는 너희 하나님이 되리니 나는 애굽 사람의 무거운 짐 밑에서 너희를 빼어낸 너희 하나님 여호와인줄 너희가 알지라","reference":"출애굽기 6:7","category":"$undefined"},{"id":"1664","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":8,"text":"내가 아브라함과 이삭과 야곱에게 주기로 맹세한 땅으로 너희를 인도하고 그 땅을 너희에게 주어 기업을 삼게 하리라 나는 여호와로라 하셨다 하라","reference":"출애굽기 6:8","category":"$undefined"},{"id":"1665","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":9,"text":"모세가 이와 같이 이스라엘 자손에게 전하나 그들이 마음의 상함과 역사의 혹독함을 인하여 모세를 듣지 아니하였더라","reference":"출애굽기 6:9","category":"$undefined"},{"id":"1666","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":10,"text":"여호와께서 모세에게 일러 가라사대","reference":"출애굽기 6:10","category":"$undefined"},{"id":"1667","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":11,"text":"들어가서 애굽왕 바로에게 말하여 이스라엘 자손을 그 땅에서 내어 보내게 하라","reference":"출애굽기 6:11","category":"$undefined"},{"id":"1668","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":12,"text":"모세가 여호와 앞에 고하여 가로되 `이스라엘 자손도 나를 듣지 아니하였거든 바로가 어찌 들으리이까 ? 나는 입이 둔한 자니이다'","reference":"출애굽기 6:12","category":"$undefined"},{"id":"1669","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":13,"text":"여호와께서 모세와 아론에게 말씀하사 그들로 이스라엘 자손과 애굽 왕 바로에게 명을 전하고 이스라엘 자손을 애굽 땅에서 인도하여 내게 하시니라","reference":"출애굽기 6:13","category":"$undefined"},{"id":"1670","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":14,"text":"그 조상을 따라 집의 어른은 이러하니라 이스라엘의 장자 르우벤의 아들 하녹과, 발루와, 헤스론과, 갈미니 이들은 르우벤의 족장이요","reference":"출애굽기 6:14","category":"$undefined"},{"id":"1671","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":15,"text":"시므온의 아들 여무엘과, 야민과, 오핫과, 야긴과, 소할과, 가나안 여인의 소생 사울이니 이들은 시므온의 족장이요","reference":"출애굽기 6:15","category":"$undefined"},{"id":"1672","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":16,"text":"레위의 아들들의 이름은 그 연치대로 이러하니 게르손과, 고핫과, 므라리요 레위의 수는 일백 삼십 칠세이었으며","reference":"출애굽기 6:16","category":"$undefined"},{"id":"1673","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":17,"text":"게르손의 아들들은 그 가족대로 립니와, 시므이요","reference":"출애굽기 6:17","category":"$undefined"},{"id":"1674","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":18,"text":"고핫의 아들들은 아므람과, 이스할과, 헤브론과, 웃시엘이요, 고핫의 수는 일백 삼십 삼세이었으며","reference":"출애굽기 6:18","category":"$undefined"},{"id":"1675","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":19,"text":"므라리의 아들은 마흘리와, 무시니 이들은 그 연치대로 레위의 족장이요","reference":"출애굽기 6:19","category":"$undefined"},{"id":"1676","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":20,"text":"아므람이 그 아비의 누이 요게벳을 아내로 취하였고 그가 아론과 모세를 낳았으며 아므람의 수는 일백 삼십 칠세이었으며","reference":"출애굽기 6:20","category":"$undefined"},{"id":"1677","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":21,"text":"이스할의 아들은 고라와, 네벡과, 시그리요","reference":"출애굽기 6:21","category":"$undefined"},{"id":"1678","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":22,"text":"웃시엘의 아들은 미사엘과, 엘사반과, 시드리요","reference":"출애굽기 6:22","category":"$undefined"},{"id":"1679","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":23,"text":"아론이 암미나답의 딸 나손의 누이 엘리세바를 아내로 취하였고 그가 나답과, 아비후와, 엘르아살과, 이다말을 낳았으며","reference":"출애굽기 6:23","category":"$undefined"},{"id":"1680","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":24,"text":"고라의 아들은 앗실과, 엘가나와, 아비아삽이니 이들은 고라 사람의 족장이요","reference":"출애굽기 6:24","category":"$undefined"},{"id":"1681","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":25,"text":"아론의 아들 엘르아살이 부디엘의 딸 중에서 아내를 취하였고 그가 비느하스를 낳았으니 이들은 레위 사람의 조상을 따라 가족의 어른들이라","reference":"출애굽기 6:25","category":"$undefined"},{"id":"1682","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":26,"text":"이스라엘 자손을 그 군대대로 애굽 땅에서 인도하라 하신 여호와의 명을 받은 자는 이 아론과 모세요","reference":"출애굽기 6:26","category":"$undefined"},{"id":"1683","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":27,"text":"애굽 왕 바로에게 이스라엘 자손을 애굽에서 내어 보내라 말한 자도 이 모세와 아론이었더라","reference":"출애굽기 6:27","category":"$undefined"},{"id":"1684","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":28,"text":"여호와께서 애굽 땅에서 모세에게 말씀하시던 날에","reference":"출애굽기 6:28","category":"$undefined"},{"id":"1685","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":29,"text":"여호와께서 모세에게 일러 가라사대 나는 여호와라 내가 네게 이르는 바를 너는 애굽 왕 바로에게 다 고하라","reference":"출애굽기 6:29","category":"$undefined"},{"id":"1686","book":"출애굽기","book_name":"출애굽기","chapter":6,"verse":30,"text":"모세가 여호와 앞에서 고하되 `나는 입이 둔한 자이오니 바로가 어찌 나를 들으리이까 ?'","reference":"출애굽기 6:30","category":"$undefined"}],"bookSlug":"exodus"}]
