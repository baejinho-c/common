2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":7,"verses":[{"id":"1687","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":1,"text":"여호와께서 모세에게 이르시되 볼지어다 ! 내가 너로 바로에게 신이 되게 하였은즉 네 형 아론은 네 대언자가 되리니","reference":"출애굽기 7:1","category":"$undefined"},{"id":"1688","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":2,"text":"내가 네게 명한 바를 너는 네 형 아론에게 말하고 그는 바로에게 말하여 그로 이스라엘 자손을 그 땅에서 보내게 할지니라","reference":"출애굽기 7:2","category":"$undefined"},{"id":"1689","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":3,"text":"내가 바로의 마음을 강퍅케 하고 나의 표징과 나의 이적을 애굽땅에 많이 행하리라마는","reference":"출애굽기 7:3","category":"$undefined"},{"id":"1690","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":4,"text":"바로가 너희를 듣지 아니할터인즉 내가 내 손을 애굽에 더하여 여러 큰 재앙을 내리고 내 군대 내 백성 이스라엘 자손을 그 땅에서 인도하여 낼지라","reference":"출애굽기 7:4","category":"$undefined"},{"id":"1691","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":5,"text":"내가 내 손을 애굽 위에 펴서 이스라엘 자손을 그 땅에서 인도하여 낼 때에야 애굽 사람이 나를 여호와인 줄 알리라 하시매","reference":"출애굽기 7:5","category":"$undefined"},{"id":"1692","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":6,"text":"모세와 아론이 여호와께서 자기들에게 명하신대로 곧 그대로 행하였더라","reference":"출애굽기 7:6","category":"$undefined"},{"id":"1693","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":7,"text":"그들이 바로에게 말할 때에 모세는 팔십세이었고 아론은 팔십 삼세이었더라","reference":"출애굽기 7:7","category":"$undefined"},{"id":"1694","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":8,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"출애굽기 7:8","category":"$undefined"},{"id":"1695","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":9,"text":"바로가 너희에게 이르기를 너희는 이적을 보이라 하거든 너는 아론에게 명하기를 너의 지팡이를 가져 바로 앞에 던지라 하라 그것이 뱀이 되리라","reference":"출애굽기 7:9","category":"$undefined"},{"id":"1696","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":10,"text":"모세와 아론이 바로에게 가서 여호와의 명하신대로 행하여 아론이 바로와 그 신하 앞에 지팡이를 던졌더니 뱀이 된지라","reference":"출애굽기 7:10","category":"$undefined"},{"id":"1697","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":11,"text":"바로도 박사와 박수를 부르매 그 애굽 술객들도 그 술법으로 그와 같이 행하되","reference":"출애굽기 7:11","category":"$undefined"},{"id":"1698","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":12,"text":"각 사람이 지팡이를 던지매 뱀이 되었으나 아론의 지팡이가 그들의 지팡이를 삼키니라","reference":"출애굽기 7:12","category":"$undefined"},{"id":"1699","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":13,"text":"그러나 바로의 마음이 강퍅하여 그들을 듣지 아니하니 여호와의 말씀과 같더라","reference":"출애굽기 7:13","category":"$undefined"},{"id":"1700","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":14,"text":"여호와께서 모세에게 이르시되 바로의 마음이 완강하여 백성 보내기를 거절하는도다","reference":"출애굽기 7:14","category":"$undefined"},{"id":"1701","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":15,"text":"아침에 너는 바로에게로 가라 그가 물로 나오리니 너는 하숫가에 서서 그를 맞으며 그 뱀 되었던 지팡이를 손에 잡고","reference":"출애굽기 7:15","category":"$undefined"},{"id":"1702","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":16,"text":"그에게 이르기를 히브리 사람의 하나님 여호와께서 나를 왕에게 보내어 이르시되 내 백성을 보내라 그들이 광야에서 나를 섬길 것이니라 하였으나 이제까지 네가 듣지 아니하도다","reference":"출애굽기 7:16","category":"$undefined"},{"id":"1703","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":17,"text":"여호와가 이같이 이르노니 네가 이로 인하여 나를 여호와인줄 알리라 하셨느니라 볼지어다 ! 내가 내 손의 지팡이로 하수를 치면 그것이 피로 변하고","reference":"출애굽기 7:17","category":"$undefined"},{"id":"1704","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":18,"text":"하수의 고기가 죽고 그 물에서는 악취가 나리니 애굽 사람들이 그 물 마시기를 싫어하리라 하라","reference":"출애굽기 7:18","category":"$undefined"},{"id":"1705","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":19,"text":"여호와께서 또 모세에게 이르시되 아론에게 명하기를 네 지팡이를 잡고 네 팔을 애굽의 물들과 하수들과 운하와 못과 모든 호수위에 펴라 하라 그것들이 피가 되리니 애굽 온 땅에와, 나무 그릇에와, 돌 그릇에 모두 피가 있으리라","reference":"출애굽기 7:19","category":"$undefined"},{"id":"1706","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":20,"text":"모세와 아론이 여호와의 명하신대로 행하여 바로와 그 신하의 목전에서 지팡이를 들어 하수를 치니 그 물이 다 피로 변하고","reference":"출애굽기 7:20","category":"$undefined"},{"id":"1707","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":21,"text":"하수의 고기가 죽고 그 물에서는 악취가 나니 애굽 사람들이 하수물을 마시지 못하며 애굽 온 땅에는 피가 있으나","reference":"출애굽기 7:21","category":"$undefined"},{"id":"1708","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":22,"text":"애굽 술객들도 자기 술법으로 그와 같이 행하므로 바로의 마음이 강퍅하여 그들을 듣지 아니하니 여호와의 말씀과 같더라","reference":"출애굽기 7:22","category":"$undefined"},{"id":"1709","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":23,"text":"바로가 돌이켜 궁으로 들어가고 그 일에도 관념하지 아니하였고","reference":"출애굽기 7:23","category":"$undefined"},{"id":"1710","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":24,"text":"애굽 사람들은 하수 물을 마실 수 없으므로 하숫가를 두루 파서 마실 물을 구하였더라","reference":"출애굽기 7:24","category":"$undefined"},{"id":"1711","book":"출애굽기","book_name":"출애굽기","chapter":7,"verse":25,"text":"여호와께서 하수를 치신 후 칠일이 지나니라","reference":"출애굽기 7:25","category":"$undefined"}],"bookSlug":"exodus"}]
