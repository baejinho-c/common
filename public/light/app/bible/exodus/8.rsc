2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":8,"verses":[{"id":"1712","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":1,"text":"여호와께서 모세에게 이르시되 너는 바로에게 가서 그에게 이르기를 여호와의 말씀에 내 백성을 보내라 그들이 나를 섬길 것이니라","reference":"출애굽기 8:1","category":"$undefined"},{"id":"1713","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":2,"text":"네가 만일 보내기를 거절하면 내가 개구리로 너의 온 지경을 칠지라","reference":"출애굽기 8:2","category":"$undefined"},{"id":"1714","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":3,"text":"개구리가 하수에서 무수히 생기고 올라와서 네 궁에와, 네 침실에와, 네 침상 위에와, 네 신하의 집에와, 네 백성에게와, 네 화덕에와, 네 떡반죽 그릇에 들어갈지며","reference":"출애굽기 8:3","category":"$undefined"},{"id":"1715","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":4,"text":"개구리가 네게와, 네 백성에게와, 네 모든 신하에게 오르리라 하셨다 하라","reference":"출애굽기 8:4","category":"$undefined"},{"id":"1716","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":5,"text":"여호와께서 모세에게 이르시되 아론에게 명하기를 네 지팡이를 잡고 네 팔을 강들과 운하들과 못 위에 펴서 개구리로 애굽 땅에올라오게 하라 할지니라","reference":"출애굽기 8:5","category":"$undefined"},{"id":"1717","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":6,"text":"아론이 팔을 애굽 물들 위에 펴매 개구리가 올라와서 애굽 땅에 덮이니","reference":"출애굽기 8:6","category":"$undefined"},{"id":"1718","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":7,"text":"술객들도 자기 술법대로 이와 같이 하여 개구리로 애굽 땅에 올라오게 하였더라","reference":"출애굽기 8:7","category":"$undefined"},{"id":"1719","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":8,"text":"바로가 모세와 아론을 불러 이르되 `여호와께 구하여 개구리를 나와 내 백성에게서 떠나게 하라 내가 이 백성을 보내리니 그들이 여호와께 희생을 드릴 것이니라'","reference":"출애굽기 8:8","category":"$undefined"},{"id":"1720","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":9,"text":"모세가 바로에게 이르되 `내가 왕과 왕의 신하와 왕의 백성을 위하여 어느 때에 구하여 이 개구리를 왕과 왕궁에서 끊어서 하수에만 있게 하오리이까 ? 내게 보이소서'","reference":"출애굽기 8:9","category":"$undefined"},{"id":"1721","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":10,"text":"그가 가로되 `내일이니라' 모세가 가로되 `왕의 말씀대로 하여 왕으로 우리 하나님 여호와와 같은 이가 없는 줄을 알게 하리니","reference":"출애굽기 8:10","category":"$undefined"},{"id":"1722","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":11,"text":"개구리가 왕과, 왕궁과, 왕의 신하와, 왕의 백성을 떠나서 하수에만 있으리이다' 하고","reference":"출애굽기 8:11","category":"$undefined"},{"id":"1723","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":12,"text":"모세와 아론이 바로를 떠나 나가서 바로에게 내리신 개구리에 대하여 모세가 여호와께 간구하매","reference":"출애굽기 8:12","category":"$undefined"},{"id":"1724","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":13,"text":"여호와께서 모세의 말대로 하시니 개구리가 집에서,마당에서,밭에서 나와서 죽은지라","reference":"출애굽기 8:13","category":"$undefined"},{"id":"1725","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":14,"text":"사람들이 모아 무더기로 쌓으니 땅에서 악취가 나더라","reference":"출애굽기 8:14","category":"$undefined"},{"id":"1726","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":15,"text":"그러나 바로가 숨을 통할 수 있음을 볼 때에 그 마음을 완강케 하여 그들을 듣지 아니하였으니 여호와의 말씀과 같더라","reference":"출애굽기 8:15","category":"$undefined"},{"id":"1727","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":16,"text":"여호와께서 모세에게 이르시되 아론에게 명하기를 네 지팡이를 들어 땅의 티끌을 치라 하라 그것이 애굽 온 땅에서 이가 되리라","reference":"출애굽기 8:16","category":"$undefined"},{"id":"1728","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":17,"text":"그들이 그대로 행할쌔 아론이 지팡이를 잡고 손을 들어 땅의 티끌을 치매 애굽 온 땅의 티끌이 다 이가 되어 사람과 생축에게 오르니","reference":"출애굽기 8:17","category":"$undefined"},{"id":"1729","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":18,"text":"술객들이 자기 술법으로 이같이 행하여 이를 내려 하였으나 못하였고 이는 사람과 생축에게 있은지라","reference":"출애굽기 8:18","category":"$undefined"},{"id":"1730","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":19,"text":"술객이 바로에게 고하되 `이는 하나님의 권능이니이다 !' 하나 바로의 마음이 강퍅케 되어 그들을 듣지 아니하였으니 여호와의 말씀과 같더라","reference":"출애굽기 8:19","category":"$undefined"},{"id":"1731","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":20,"text":"여호와께서 모세에게 이르시되 아침에 일찌기 일어나 바로 앞에 서라 그가 물로 나오리니 그에게 이르기를 여호와의 말씀에 내 백성을 보내라 그들이 나를 섬길 것이니라","reference":"출애굽기 8:20","category":"$undefined"},{"id":"1732","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":21,"text":"네가 만일 내 백성을 보내지 아니하면 내가 너와 네 신하와 네 백성을 보내지 아니하면 내가 너와 네 신하와 네 백성과 네 집들에 파리떼를 보내리니 애굽 사람의 집집에 파리 떼가 가득할 것이며 그들의 거하는 땅에도 그러하리라","reference":"출애굽기 8:21","category":"$undefined"},{"id":"1733","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":22,"text":"그 날에 내가 내 백성의 거하는 고센 땅을 구별하여 그 곳에는 파리떼가 없게 하리니 이로 말미암아 나는 세상 중의 여호와인 줄을 네가 알게 될 것이라","reference":"출애굽기 8:22","category":"$undefined"},{"id":"1734","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":23,"text":"내가 내 백성과 네 백성 사이에 구별을 두리니 내일 이 표징이 있으리라 하셨다 하라 하시고","reference":"출애굽기 8:23","category":"$undefined"},{"id":"1735","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":24,"text":"여호와께서 그와 같이 하시니 무수한 파리떼가 바로의 궁에와, 그 신하의 집에와, 애굽 전국에 이르니 파리떼로 인하여 땅이 해를 받더라","reference":"출애굽기 8:24","category":"$undefined"},{"id":"1736","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":25,"text":"바로가 모세와 아론을 불러 이르되 `너희는 가서 이 땅에서 너희 하나님께 희생을 드리라'","reference":"출애굽기 8:25","category":"$undefined"},{"id":"1737","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":26,"text":"모세가 가로되 `그리함은 불가하니이다 우리가 우리 하나님 여호와께 희생을 드리는 것은 애굽 사람의 미워하는 바이온즉 우리가 만일 애굽 사람의 목전에서 희생을 드리면 그들이 그것을 미워하여 우리를 돌로 치지 아니하리이까 ?","reference":"출애굽기 8:26","category":"$undefined"},{"id":"1738","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":27,"text":"우리가 사흘길쯤 광야로 들어가서 우리 하나님 여호와께 희생을 드리되 우리에게 명하시는대로 하려하나이다'","reference":"출애굽기 8:27","category":"$undefined"},{"id":"1739","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":28,"text":"바로가 가로되 `내가 너희를 보내리니 너희가 너희 하나님 여호와께 광야에서 희생을 드릴 것이나 너무 멀리는 가지 말라 그런즉 너희는 나를 위하여 기도하라'","reference":"출애굽기 8:28","category":"$undefined"},{"id":"1740","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":29,"text":"모세가 가로되 `내가 왕을 떠나 가서 여호와께 기도하리니 내일이면 파리떼가 바로와 바로의 신하와 바로의 백성을 떠나려니와 바로는 이 백성을 보내어 여호와께 희생을 드리는 일에 다시 거짓을 행치 마소서' 하고","reference":"출애굽기 8:29","category":"$undefined"},{"id":"1741","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":30,"text":"모세가 바로를 떠나 나와서 여호와께 기도하니","reference":"출애굽기 8:30","category":"$undefined"},{"id":"1742","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":31,"text":"여호와께서 모세의 말대로 하사 파리를 바로와 그 신하와 그 백성에게 몰수히 떠나게 하시니라","reference":"출애굽기 8:31","category":"$undefined"},{"id":"1743","book":"출애굽기","book_name":"출애굽기","chapter":8,"verse":32,"text":"그러나 바로가 이 때에도 마음을 완강케 하여 백성을 보내지 아니하였더라","reference":"출애굽기 8:32","category":"$undefined"}],"bookSlug":"exodus"}]
