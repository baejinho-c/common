2:["$","$L11",null,{"book":{"id":"exodus","name":"출애굽기","chapters":40,"testament":"old"},"chapter":9,"verses":[{"id":"1744","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":1,"text":"여호와께서 모세에게 이르시되 바로에게 들어가서 그에게 이르라 히브리 사람의 하나님 여호와께서 말씀하시기를 내 백성을 보내라 그들이 나를 섬길 것이니라","reference":"출애굽기 9:1","category":"$undefined"},{"id":"1745","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":2,"text":"네가 만일 그들 보내기를 거절하고 억지로 잡아 두면","reference":"출애굽기 9:2","category":"$undefined"},{"id":"1746","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":3,"text":"여호와의 손이 들에 있는 네 생축 곧 말과 나귀와 약대와 우양에게 더하리니 심한 악질이 있을 것이며","reference":"출애굽기 9:3","category":"$undefined"},{"id":"1747","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":4,"text":"여호와가 이스라엘의 생축과 애굽의 생축을 구별하리니 이스라엘 자손에 속한 것은 하나도 죽지 아니하리라 하셨다 하라 하시고","reference":"출애굽기 9:4","category":"$undefined"},{"id":"1748","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":5,"text":"여호와께서 기한을 정하여 가라사대 여호와가 내일 이 땅에서 이 일을 행하리라 하시더니","reference":"출애굽기 9:5","category":"$undefined"},{"id":"1749","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":6,"text":"이튿날에 여호와께서 이 일을 행하시니 애굽의 모든 생축은 죽었으나 이스라엘 자손의 생축은 하나도 죽지 아니한지라","reference":"출애굽기 9:6","category":"$undefined"},{"id":"1750","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":7,"text":"바로가 보내어 본즉 이스라엘의 생축은 하나도 죽지 아니하였더라 그러나 바로의 마음이 완강하여 백성을 보내지 아니하니라","reference":"출애굽기 9:7","category":"$undefined"},{"id":"1751","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":8,"text":"여호와께서 모세와 아론에게 이르시되 너희는 풀무의 재 두 움큼을 가지고 모세가 바로의 목전에서 하늘을 향하여 날리라","reference":"출애굽기 9:8","category":"$undefined"},{"id":"1752","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":9,"text":"그 재가 애굽 온 땅의 티끌이 되어 애굽 온 땅의 사람과 짐승에게 붙어서 독종이 발하리라","reference":"출애굽기 9:9","category":"$undefined"},{"id":"1753","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":10,"text":"그들이 풀무의 재를 가지고 바로 앞에 서서 모세가 하늘을 향하여 날리니 사람과 짐승에게 붙어 독종이 발하고","reference":"출애굽기 9:10","category":"$undefined"},{"id":"1754","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":11,"text":"술객도 독종으로 인하여 모세 앞에 서지 못하니 독종이 술객들로 부터 애굽 모든 사람에게 발하였음이라","reference":"출애굽기 9:11","category":"$undefined"},{"id":"1755","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":12,"text":"그러나 여호와께서 바로의 마음을 강퍅케 하셨으므로 그들을 듣지 아니하였으니 여호와께서 모세에게 말씀하심과 같더라","reference":"출애굽기 9:12","category":"$undefined"},{"id":"1756","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":13,"text":"여호와께서 모세에게 이르시되 아침에 일찌기 일어나 바로 앞에 서서 그에게 이르기를 히브리 사람의 하나님 여호와의 말씀에 내 백성을 보내라 그들이 나를 섬길 것이니라","reference":"출애굽기 9:13","category":"$undefined"},{"id":"1757","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":14,"text":"내가 이번에는 모든 재앙을 네 마음과 네 신하와 네 백성에게 내려 너로 온 천하에 나와 같은 자가 없음을 알게 하리라","reference":"출애굽기 9:14","category":"$undefined"},{"id":"1758","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":15,"text":"내가 손을 펴서 온역으로 너와 네 백성을 쳤더면 네가 세상에서 끊어졌을 것이나","reference":"출애굽기 9:15","category":"$undefined"},{"id":"1759","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":16,"text":"네가 너를 세웠음은 나의 능력을 네게 보이고 내 이름이 온 천하에 전파되게 하려 하였음이니라","reference":"출애굽기 9:16","category":"$undefined"},{"id":"1760","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":17,"text":"네가 여전히 내 백성 앞에 자고하고 그들을 보내지 아니하느냐 ?","reference":"출애굽기 9:17","category":"$undefined"},{"id":"1761","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":18,"text":"내일 이맘때면 내가 중한 우박을 내리리니 애굽 개국 이래로 그 같은 것이 있지 않던 것이리라","reference":"출애굽기 9:18","category":"$undefined"},{"id":"1762","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":19,"text":"이제 보내어 네 생축과 네 들에 있는 것을 다 모으라 사람이나 짐승이나 무릇 들에 있어서 집에 돌아오지 않은 자에게는 우박이그 위에 내리리니 그것들이 죽으리라 하셨다 하라 하시니라","reference":"출애굽기 9:19","category":"$undefined"},{"id":"1763","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":20,"text":"바로의 신하 중에 여호와의 말씀을 두려워하는 자들은 그 종들과 생축을 집으로 피하여 들였으나","reference":"출애굽기 9:20","category":"$undefined"},{"id":"1764","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":21,"text":"여호와의 말씀을 마음에 두지 아니하는 자는 그 종들과 생축을 들에 그대로 두었더라","reference":"출애굽기 9:21","category":"$undefined"},{"id":"1765","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":22,"text":"여호와께서 모세에게 이르시되 너는 하늘을 향하여 손을 들어 애굽 전국에 우박이 애굽땅의 사람과 짐승과 밭의 모든 채소에 내리게 하라","reference":"출애굽기 9:22","category":"$undefined"},{"id":"1766","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":23,"text":"모세가 하늘을 향하여 지팡이를 들매 여호와께서 뇌성과 우박을 보내시고 불을 내려 땅에 달리게 하시니라 여호와께서 우박을 애굽 땅에 내리시매","reference":"출애굽기 9:23","category":"$undefined"},{"id":"1767","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":24,"text":"우박의 내림과 불덩이가 우박에 섞여 내림이 심히 맹렬하니 애굽 전국에 그 개국 이래로 그 같은 것이 없던 것이라","reference":"출애굽기 9:24","category":"$undefined"},{"id":"1768","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":25,"text":"우박이 애굽 온 땅에서 사람과 짐승을 무론하고 무릇 밭에 있는 것을 쳤으며 우박이 또 밭의 모든 채소를 치고 들의 모든 나무를 꺽었으되","reference":"출애굽기 9:25","category":"$undefined"},{"id":"1769","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":26,"text":"이스라엘 자손의 거한 고센 땅에는 우박이 없었더라","reference":"출애굽기 9:26","category":"$undefined"},{"id":"1770","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":27,"text":"바로가 사람을 보내어 모세와 아론을 불러 그들에게 이르되 `이번은 내가 범죄하였노라 여호와는 의로우시고 나와 나의 백성은 악하도다","reference":"출애굽기 9:27","category":"$undefined"},{"id":"1771","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":28,"text":"여호와께 구하여 이 뇌성과 우박을 그만 그치게 하라 내가 너희를 보내리니 너희가 다시는 머물지 아니하리라'","reference":"출애굽기 9:28","category":"$undefined"},{"id":"1772","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":29,"text":"모세가 그에게 이르되 `내가 성에서 나가자 곧 내 손을 여호와를 향하여 펴리니 그리하면 뇌성이 그치고 우박이 다시 있지 않을지라 세상이 여호와께 속한 줄을 왕이 알리이다","reference":"출애굽기 9:29","category":"$undefined"},{"id":"1773","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":30,"text":"그러나 왕과 왕의 신하들이 여호와 하나님을 아직도 두려워 아니할 줄을 내가 아나이다'","reference":"출애굽기 9:30","category":"$undefined"},{"id":"1774","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":31,"text":"때에 보리는 이삭이 나왔고 삼은 꽃이 피었으므로 삼과 보리가 상하였으나","reference":"출애굽기 9:31","category":"$undefined"},{"id":"1775","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":32,"text":"그러나 밀과 나맥은 자라지 아니한고로 상하지 아니하였더라","reference":"출애굽기 9:32","category":"$undefined"},{"id":"1776","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":33,"text":"모세가 바로를 떠나 성에서 나가서 여호와를 향하여 손을 펴매 뇌성과 우박이 그치고 비가 땅에 내리지 아니하니라","reference":"출애굽기 9:33","category":"$undefined"},{"id":"1777","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":34,"text":"바로가 비와 우박과 뇌성의 그친 것을 볼 때에 다시 범죄하여 마음을 완강케 하니 그와 그 신하가 일반이라","reference":"출애굽기 9:34","category":"$undefined"},{"id":"1778","book":"출애굽기","book_name":"출애굽기","chapter":9,"verse":35,"text":"바로의 마음이 강퍅하여 이스라엘 자손을 보내지 아니하였으니 여호와께서 모세에게 말씀하심과 같더라","reference":"출애굽기 9:35","category":"$undefined"}],"bookSlug":"exodus"}]
