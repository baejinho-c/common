2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":1,"verses":[{"id":"20466","book":"에스겔","book_name":"에스겔","chapter":1,"verse":1,"text":"제 삼십년 사월 오일에 내가 그발강 가 사로잡힌 자 중에 있더니 하늘이 열리며 하나님의 이상을 내게 보이시니","reference":"에스겔 1:1","category":"$undefined"},{"id":"20467","book":"에스겔","book_name":"에스겔","chapter":1,"verse":2,"text":"여호야긴 왕의 사로잡힌지 오년 그 달 오일이라","reference":"에스겔 1:2","category":"$undefined"},{"id":"20468","book":"에스겔","book_name":"에스겔","chapter":1,"verse":3,"text":"갈대아 땅 그발강 가에서 여호와의 말씀이 부시의 아들 제사장 나 에스겔에게 특별히 임하고 여호와의 권능이 내 위에 있으니라","reference":"에스겔 1:3","category":"$undefined"},{"id":"20469","book":"에스겔","book_name":"에스겔","chapter":1,"verse":4,"text":"내가 보니 북방에서부터 폭풍과 큰 구름이 오는데 그 속에서 불이 번쩍 번쩍하여 빛이 그 사면에 비취며 그 불 가운데 단쇠 같은 것이 나타나 보이고","reference":"에스겔 1:4","category":"$undefined"},{"id":"20470","book":"에스겔","book_name":"에스겔","chapter":1,"verse":5,"text":"그 속에서 네 생물의 형상이 나타나는데 그 모양이 이러하니 사람의 형상이라","reference":"에스겔 1:5","category":"$undefined"},{"id":"20471","book":"에스겔","book_name":"에스겔","chapter":1,"verse":6,"text":"각각 네 얼굴과 네 날개가 있고","reference":"에스겔 1:6","category":"$undefined"},{"id":"20472","book":"에스겔","book_name":"에스겔","chapter":1,"verse":7,"text":"그 다리는 곧고 그 발바닥은 송아지 발바닥 같고 마광한 구리같이 빛나며","reference":"에스겔 1:7","category":"$undefined"},{"id":"20473","book":"에스겔","book_name":"에스겔","chapter":1,"verse":8,"text":"그 사면 날개 밑에는 각각 사람의 손이 있더라 그 네 생물의 얼굴과 날개가 이러하니","reference":"에스겔 1:8","category":"$undefined"},{"id":"20474","book":"에스겔","book_name":"에스겔","chapter":1,"verse":9,"text":"날개는 다 서로 연하였으며 행할 때에는 돌이키지 아니하고 일제히 앞으로 곧게 행하며","reference":"에스겔 1:9","category":"$undefined"},{"id":"20475","book":"에스겔","book_name":"에스겔","chapter":1,"verse":10,"text":"그 얼굴들의 모양은 넷의 앞은 사람의 얼굴요 넷의 우편은 사자의 얼굴이요 넷의 좌편은 소의 얼굴이요 넷의 뒤는 독수리의 얼굴이니","reference":"에스겔 1:10","category":"$undefined"},{"id":"20476","book":"에스겔","book_name":"에스겔","chapter":1,"verse":11,"text":"그 얼굴은 이러하며 그 날개는 들어 펴서 각기 둘씩 서로 연하였고 또 둘은 몸을 가리웠으며","reference":"에스겔 1:11","category":"$undefined"},{"id":"20477","book":"에스겔","book_name":"에스겔","chapter":1,"verse":12,"text":"신이 어느 편으로 가려면 그 생물들이 그대로 가되 돌이키지 아니하고 일제히 앞으로 곧게 행하며","reference":"에스겔 1:12","category":"$undefined"},{"id":"20478","book":"에스겔","book_name":"에스겔","chapter":1,"verse":13,"text":"또 생물의 모양은 숯불과 횃불 모양 같은데 그 불이 그 생물 사이에서 오르락 내리락 하며 그 불은 광채가 있고 그 가운데서는 번개가 나며","reference":"에스겔 1:13","category":"$undefined"},{"id":"20479","book":"에스겔","book_name":"에스겔","chapter":1,"verse":14,"text":"그 생물의 왕래가 번개 같이 빠르더라","reference":"에스겔 1:14","category":"$undefined"},{"id":"20480","book":"에스겔","book_name":"에스겔","chapter":1,"verse":15,"text":"내가 그 생물을 본즉 그 생물 곁 땅위에 바퀴가 있는데 그 네 얼굴을 따라 하나씩 있고","reference":"에스겔 1:15","category":"$undefined"},{"id":"20481","book":"에스겔","book_name":"에스겔","chapter":1,"verse":16,"text":"그 바퀴의 형상과 그 구조는 넷이 한결 같은데 황옥 같고 그 형상과 구조는 바퀴 안에 바퀴가 있는 것 같으며","reference":"에스겔 1:16","category":"$undefined"},{"id":"20482","book":"에스겔","book_name":"에스겔","chapter":1,"verse":17,"text":"행할 때에는 사방으로 향한 대로 돌이키지 않고 행하며","reference":"에스겔 1:17","category":"$undefined"},{"id":"20483","book":"에스겔","book_name":"에스겔","chapter":1,"verse":18,"text":"그 둘레는 높고 무서우며 그 네 둘레로 돌아가면서 눈이 가득하며","reference":"에스겔 1:18","category":"$undefined"},{"id":"20484","book":"에스겔","book_name":"에스겔","chapter":1,"verse":19,"text":"생물이 행할 때에 바퀴도 그 곁에서 행하고 생물이 땅에서 들릴때에 바퀴도 들려서","reference":"에스겔 1:19","category":"$undefined"},{"id":"20485","book":"에스겔","book_name":"에스겔","chapter":1,"verse":20,"text":"어디든지 신이 가려하면 생물도 신의 가려하는 곳으로 가고 바퀴도 그 곁에서 들리니 이는 생물의 신이 그 바퀴 가운데 있음이라","reference":"에스겔 1:20","category":"$undefined"},{"id":"20486","book":"에스겔","book_name":"에스겔","chapter":1,"verse":21,"text":"저들이 행하면 이들도 행하고 저들이 그치면 이들도 그치고 저들이 땅에서 들릴 때에는 이들도 그 곁에서 들리니 이는 생물의 신이 그 바퀴 가운데 있음이더라","reference":"에스겔 1:21","category":"$undefined"},{"id":"20487","book":"에스겔","book_name":"에스겔","chapter":1,"verse":22,"text":"그 생물의 머리 위에는 수정 같은 궁창의 형상이 펴 있어 보기에 심히 두려우며","reference":"에스겔 1:22","category":"$undefined"},{"id":"20488","book":"에스겔","book_name":"에스겔","chapter":1,"verse":23,"text":"그 궁창 밑에 생물들의 날개가 서로 향하여 펴 있는데 이 생물은 두 날개로 몸을 가리웠고 저 생물도 두 날개로 몸을 가리웠으며","reference":"에스겔 1:23","category":"$undefined"},{"id":"20489","book":"에스겔","book_name":"에스겔","chapter":1,"verse":24,"text":"생물들이 행할 때에 내가 그 날개 소리를 들은즉 많은 물 소리와도 같으며 전능자의 음성과도 같으며 떠드는 소리 곧 군대의 소리와도 같더니 그 생물이 설 때에 그 날개를 드리우더라","reference":"에스겔 1:24","category":"$undefined"},{"id":"20490","book":"에스겔","book_name":"에스겔","chapter":1,"verse":25,"text":"그 머리 위에 있는 궁창 위에 보좌의 형상이 있는데 그 모양이 남보석 같고 그 보좌의 형상 위에 한 형상이 있어 사람의 모양 같더라","reference":"에스겔 1:25","category":"$undefined"},{"id":"20491","book":"에스겔","book_name":"에스겔","chapter":1,"verse":26,"text":"그 머리 위에 있는 궁창 위에서 부터 음성이 나더라 그 생물이 설때에 그 날개를 드리우더라","reference":"에스겔 1:26","category":"$undefined"},{"id":"20492","book":"에스겔","book_name":"에스겔","chapter":1,"verse":27,"text":"그 머리 위에 있는 궁창 위에서 부터 음성이 나더라 그 생물이 설때에 그 날개를 드리우더라","reference":"에스겔 1:27","category":"$undefined"},{"id":"20493","book":"에스겔","book_name":"에스겔","chapter":1,"verse":28,"text":"그 머리 위에 있는 궁창 위에 보좌의 형상이 있는데 그 모양이 남보석 같고 그 보좌의 형상 위에 한 형상이 있어 사람의 모양 같더라 [ (Ezekiel 1:29) 내가 본즉 그 허리 이상의 모양은 단 쇠 같아서 그 속과 주위가 불 같고 그 허리 이하의 모양도 불 같아서 사면으로 광채가 나며 ] [ (Ezekiel 1:30) 그 사면 광채의 모양은 비 오는날 구름에 있는 무지개 같으니 이는 여호와의 영광의 형상의 모양이라 내가 보고 곧 엎드리어 그 말씀하시는 자의 음성을 들으니라 ]","reference":"에스겔 1:28","category":"$undefined"}],"bookSlug":"ezekiel"}]
