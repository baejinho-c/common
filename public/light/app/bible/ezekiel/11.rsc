2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":11,"verses":[{"id":"20657","book":"에스겔","book_name":"에스겔","chapter":11,"verse":1,"text":"때에 주의 신이 나를 들어 데리고 여호와의 전 동문 곧 동향한 문에 이르시기로 본즉 그 문에 이십 오인이 있는데 내가 그 중에서 앗술의 아들 야아사냐와 브나야의 아들 블라댜를 보았으니 그들은 백성의 방백이라","reference":"에스겔 11:1","category":"$undefined"},{"id":"20658","book":"에스겔","book_name":"에스겔","chapter":11,"verse":2,"text":"그가 내게 이르시되 인자야 ! 이 사람들은 불의를 품고 이 성중에서 악한 꾀를 베푸는 자니라","reference":"에스겔 11:2","category":"$undefined"},{"id":"20659","book":"에스겔","book_name":"에스겔","chapter":11,"verse":3,"text":"그들의 말이 집 건축할 때가 가깝지 아니한즉 이 성읍은 가마가 되고 우리는 고기가 된다 하나니","reference":"에스겔 11:3","category":"$undefined"},{"id":"20660","book":"에스겔","book_name":"에스겔","chapter":11,"verse":4,"text":"그러므로 인자야 너는 그들을 쳐서 예언하고 예언할지니라","reference":"에스겔 11:4","category":"$undefined"},{"id":"20661","book":"에스겔","book_name":"에스겔","chapter":11,"verse":5,"text":"여호와의 신이 내게 임하여 가라사대 너는 말하기를 여호와의 말씀에 이스라엘 족속아 너희가 이렇게 말하였도다 너희 마음에서 일어나는 것을 내가 다 아노라","reference":"에스겔 11:5","category":"$undefined"},{"id":"20662","book":"에스겔","book_name":"에스겔","chapter":11,"verse":6,"text":"너희가 이 성읍에서 많이 살륙하여 그 시체로 거리에 채웠도다","reference":"에스겔 11:6","category":"$undefined"},{"id":"20663","book":"에스겔","book_name":"에스겔","chapter":11,"verse":7,"text":"그러므로 나 주 여호와가 말하노라 이 성읍 중에서 너희가 살륙한 시체는 그 고기요 이 성읍은 그 가마려니와 너희는 그 가운데서 끌려 나오리라","reference":"에스겔 11:7","category":"$undefined"},{"id":"20664","book":"에스겔","book_name":"에스겔","chapter":11,"verse":8,"text":"나 주 여호와가 말하노라 너희가 칼을 두려워하니 내가 칼로 너희에게 임하게 하고","reference":"에스겔 11:8","category":"$undefined"},{"id":"20665","book":"에스겔","book_name":"에스겔","chapter":11,"verse":9,"text":"너희를 그 성읍 가운데서 끌어내어 타국인의 손에 붙여 너희에게 벌을 내리리니","reference":"에스겔 11:9","category":"$undefined"},{"id":"20666","book":"에스겔","book_name":"에스겔","chapter":11,"verse":10,"text":"너희가 칼에 엎드러질 것이라 내가 이스라엘 변경에서 너희를 국문하리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 11:10","category":"$undefined"},{"id":"20667","book":"에스겔","book_name":"에스겔","chapter":11,"verse":11,"text":"이 성읍은 너희 가마가 되지 아니하고 너희는 그 가운데 고기가 되지 아니할지라 내가 너희를 이스라엘 변경에서 국문하리니","reference":"에스겔 11:11","category":"$undefined"},{"id":"20668","book":"에스겔","book_name":"에스겔","chapter":11,"verse":12,"text":"너희가 나를 여호와인 줄 알리라 너희가 내 율례를 행치 아니하며 규례를 지키지 아니하고 너희 사면에 있는 이방인의 규례대로 행하였느니라 하셨다 하라","reference":"에스겔 11:12","category":"$undefined"},{"id":"20669","book":"에스겔","book_name":"에스겔","chapter":11,"verse":13,"text":"이에 내가 예언할 때에 브나야의 아들 블라댜가 죽기로 내가 엎드리어 큰 소리로 부르짖어 가로되 오호라 ! 주 여호와여 ! 이스라엘의 남은 자를 다 멸절하고자 하시나이까 ? 하니라","reference":"에스겔 11:13","category":"$undefined"},{"id":"20670","book":"에스겔","book_name":"에스겔","chapter":11,"verse":14,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 11:14","category":"$undefined"},{"id":"20671","book":"에스겔","book_name":"에스겔","chapter":11,"verse":15,"text":"인자야 ! 예루살렘 거민이 너의 형제 곧 너의 형제와 친속과 이스라엘 온 족속을 향하여 이르기를 너희는 여호와에게서 멀리 떠나라 이 땅은 우리에게 주어 기업이 되게 하신 것이라 하였나니","reference":"에스겔 11:15","category":"$undefined"},{"id":"20672","book":"에스겔","book_name":"에스겔","chapter":11,"verse":16,"text":"그런즉 너는 말하기를 주 여호와의 말씀에 내가 비록 그들을 멀리 이방인 가운데로 쫓고 열방에 흩었으나 그들이 이른 열방에서 내가 잠간 그들에게 성소가 되리라 하셨다 하고","reference":"에스겔 11:16","category":"$undefined"},{"id":"20673","book":"에스겔","book_name":"에스겔","chapter":11,"verse":17,"text":"너는 또 말하기를 주 여호와의 말씀에 내가 너희를 만민 가운데 모으며 너희를 흩은 열방 가운데서 모아 내고 이스라엘 땅으로 너희에게 주리라 하셨다 하라","reference":"에스겔 11:17","category":"$undefined"},{"id":"20674","book":"에스겔","book_name":"에스겔","chapter":11,"verse":18,"text":"그들이 그리로 가서 그 가운데 모든 미운 물건과 가증한 것을 제하여 버릴지라","reference":"에스겔 11:18","category":"$undefined"},{"id":"20675","book":"에스겔","book_name":"에스겔","chapter":11,"verse":19,"text":"내가 그들에게 일치한 마음을 주고 그 속에 새 신을 주며 그 몸에서 굳은 마음을 제하고 부드러운 마음을 주어서","reference":"에스겔 11:19","category":"$undefined"},{"id":"20676","book":"에스겔","book_name":"에스겔","chapter":11,"verse":20,"text":"내 율례를 좇으며 내 규례를 지켜 행하게 하리니 그들은 내 백성이 되고 나는 그들의 하나님이 되리라","reference":"에스겔 11:20","category":"$undefined"},{"id":"20677","book":"에스겔","book_name":"에스겔","chapter":11,"verse":21,"text":"그러나 미운 것과 가증한 것을 마음으로 좇는 자는 내가 그 행위대로 그 머리에 갚으리라 나 주 여호와의 말이니라","reference":"에스겔 11:21","category":"$undefined"},{"id":"20678","book":"에스겔","book_name":"에스겔","chapter":11,"verse":22,"text":"때에 그룹들이 날개를 드는데 바퀴도 그 곁에 있고 이스라엘 하나님의 영광도 그 위에 덮였더니","reference":"에스겔 11:22","category":"$undefined"},{"id":"20679","book":"에스겔","book_name":"에스겔","chapter":11,"verse":23,"text":"여호와의 영광이 성읍 중에서부터 올라가서 성읍 동편 산에 머물고","reference":"에스겔 11:23","category":"$undefined"},{"id":"20680","book":"에스겔","book_name":"에스겔","chapter":11,"verse":24,"text":"주의 신이 나를 들어 하나님의 신의 이상 중에 데리고 갈대아에 있는 사로잡힌 자중에 이르시더니 내가 보는 이상이 나를 떠난지라","reference":"에스겔 11:24","category":"$undefined"},{"id":"20681","book":"에스겔","book_name":"에스겔","chapter":11,"verse":25,"text":"내가 사로잡힌 자들에게 여호와께서 내게 보이신 모든 일로 고하니라","reference":"에스겔 11:25","category":"$undefined"}],"bookSlug":"ezekiel"}]
