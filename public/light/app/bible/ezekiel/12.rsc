2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":12,"verses":[{"id":"20682","book":"에스겔","book_name":"에스겔","chapter":12,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 12:1","category":"$undefined"},{"id":"20683","book":"에스겔","book_name":"에스겔","chapter":12,"verse":2,"text":"인자야 ! 네가 패역한 족속 중에 거하도다 그들은 볼 눈이 있어도 보지 아니하고 들을 귀가 있어도 듣지 아니하나니 그들은 패역한 족속임이니라","reference":"에스겔 12:2","category":"$undefined"},{"id":"20684","book":"에스겔","book_name":"에스겔","chapter":12,"verse":3,"text":"인자야 ! 너는 행구를 준비하고 낮에 그들의 목전에서 이사하라 네가 네 처소를 다른 곳으로 옮기는 것을 그들이 보면 비록 패역한 족속이라도 혹 생각이 있으리라","reference":"에스겔 12:3","category":"$undefined"},{"id":"20685","book":"에스겔","book_name":"에스겔","chapter":12,"verse":4,"text":"너는 낮에 그 목전에서 네 행구를 밖으로 내기를 이사하는 행구 같이 하고 저물 때에 너는 그 목전에서 밖으로 나가기를 포로되어 가는 자 같이 하라","reference":"에스겔 12:4","category":"$undefined"},{"id":"20686","book":"에스겔","book_name":"에스겔","chapter":12,"verse":5,"text":"너는 그 목전에서 성벽을 뚫고 그리로 좇아 옮기되","reference":"에스겔 12:5","category":"$undefined"},{"id":"20687","book":"에스겔","book_name":"에스겔","chapter":12,"verse":6,"text":"캄캄할 때에 그 목전에서 어깨에 메고 나가며 얼굴을 가리우고 땅을 보지 말지어다 이는 내가 너를 세워 이스라엘 족속에게 징조가 되게 함이니라 하시기로","reference":"에스겔 12:6","category":"$undefined"},{"id":"20688","book":"에스겔","book_name":"에스겔","chapter":12,"verse":7,"text":"내가 그 명대로 행하여 낮에 나의 행구를 이사하는 행구같이 내어 놓고 저물 때에 내 손으로 성벽을 뚫고 캄캄할 때에 행구를 내어다가 그 목전에서 어깨에 메고 나가니라","reference":"에스겔 12:7","category":"$undefined"},{"id":"20689","book":"에스겔","book_name":"에스겔","chapter":12,"verse":8,"text":"이튿날 아침에 여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 12:8","category":"$undefined"},{"id":"20690","book":"에스겔","book_name":"에스겔","chapter":12,"verse":9,"text":"인자야 ! 이스라엘 족속 곧 그 패역한 족속이 네게 묻기를 무엇을 하느냐 하지 아니하더냐","reference":"에스겔 12:9","category":"$undefined"},{"id":"20691","book":"에스겔","book_name":"에스겔","chapter":12,"verse":10,"text":"너는 그들에게 말하기를 주 여호와의 말씀에 이것은 예루살렘 왕과 그 가운데 있는 이스라엘 온 족속에 대한 예조라 하셨다 하고","reference":"에스겔 12:10","category":"$undefined"},{"id":"20692","book":"에스겔","book_name":"에스겔","chapter":12,"verse":11,"text":"또 말하기를 나는 너희 징조라 내가 행한대로 그들이 당하여 사로잡혀 옮겨갈지라","reference":"에스겔 12:11","category":"$undefined"},{"id":"20693","book":"에스겔","book_name":"에스겔","chapter":12,"verse":12,"text":"무리가 성벽을 뚫고 행구를 그리로 가지고 나가고 그 중에 왕은 어두울 때에 어깨에 행구를 메고 나가며 눈으로 땅을 보지 아니하려고 자기 얼굴을 가리우리라 하라","reference":"에스겔 12:12","category":"$undefined"},{"id":"20694","book":"에스겔","book_name":"에스겔","chapter":12,"verse":13,"text":"내가 또 내 그물을 그의 위에 치고 내 올무에 걸리게 하여 그를 끌고 갈대아 땅 바벨론에 이르리니 그가 거기서 죽으려니와 그 땅을 보지 못하리라","reference":"에스겔 12:13","category":"$undefined"},{"id":"20695","book":"에스겔","book_name":"에스겔","chapter":12,"verse":14,"text":"내가 그 호위하는 자와 부대들을 다 사방으로 흩고 또 그 뒤를 따라 칼을 빼리라","reference":"에스겔 12:14","category":"$undefined"},{"id":"20696","book":"에스겔","book_name":"에스겔","chapter":12,"verse":15,"text":"내가 그들을 이방인 가운데로 흩으며 열방 중에 헤친 후에야 그들이 나를 여호와인 줄 알리라","reference":"에스겔 12:15","category":"$undefined"},{"id":"20697","book":"에스겔","book_name":"에스겔","chapter":12,"verse":16,"text":"그러나 내가 그 중 몇 사람을 남겨 칼과 기근과 온역을 벗어나게 하여 그들로 이르는 이방인 중에 자기의 모든 가증한 일을 자백하게 하리니 그들이 나를 여호와인 줄 알리라","reference":"에스겔 12:16","category":"$undefined"},{"id":"20698","book":"에스겔","book_name":"에스겔","chapter":12,"verse":17,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 12:17","category":"$undefined"},{"id":"20699","book":"에스겔","book_name":"에스겔","chapter":12,"verse":18,"text":"인자야 ! 너는 떨면서 네 식물을 먹고 놀라고 근심하면서 네 물을 마시며","reference":"에스겔 12:18","category":"$undefined"},{"id":"20700","book":"에스겔","book_name":"에스겔","chapter":12,"verse":19,"text":"이 땅 백성에게 말하되 주 여호와께서 예루살렘 거민과 이스라엘 땅에 대하여 이르시기를 그들이 근심하면서 그 식물을 먹으며 놀라면서 그 물을 마실 것은 이 땅 모든 거민의 강포를 인하여 땅에 가득한 것이 황무하게 됨이라","reference":"에스겔 12:19","category":"$undefined"},{"id":"20701","book":"에스겔","book_name":"에스겔","chapter":12,"verse":20,"text":"사람의 거하는 성읍들이 황폐하며 땅이 황무하리니 너희가 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 12:20","category":"$undefined"},{"id":"20702","book":"에스겔","book_name":"에스겔","chapter":12,"verse":21,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 12:21","category":"$undefined"},{"id":"20703","book":"에스겔","book_name":"에스겔","chapter":12,"verse":22,"text":"인자야 ! 이스라엘 땅에서 이르기를 날이 더디고 모든 묵시가 응험이 없다 하는 너희의 속담이 어찜이뇨","reference":"에스겔 12:22","category":"$undefined"},{"id":"20704","book":"에스겔","book_name":"에스겔","chapter":12,"verse":23,"text":"그러므로 너는 그들에게 이르기를 주 여호와의 말씀에 내가 이 속담을 그치게 하리니 사람이 다시는 이스라엘 가운데서 이 속담을 못하리라 하셨다 하고 또 그들에게 이르기를 날과 모든 묵시의 응함이 가까우니","reference":"에스겔 12:23","category":"$undefined"},{"id":"20705","book":"에스겔","book_name":"에스겔","chapter":12,"verse":24,"text":"이스라엘 족속 중에 허탄한 묵시나 아첨하는 복술이 다시 있지 못하리라 하라","reference":"에스겔 12:24","category":"$undefined"},{"id":"20706","book":"에스겔","book_name":"에스겔","chapter":12,"verse":25,"text":"나는 여호와라 ! 내가 말하리니 내가 하는 말이 다시는 더디지 아니하고 응하리라 패역한 족속아 내가 너희 생전에 말하고 이루리라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 12:25","category":"$undefined"},{"id":"20707","book":"에스겔","book_name":"에스겔","chapter":12,"verse":26,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 12:26","category":"$undefined"},{"id":"20708","book":"에스겔","book_name":"에스겔","chapter":12,"verse":27,"text":"인자야 이스라엘 족속의 말이 그의 보는 묵시는 여러 날 후의 일이라 그가 먼 때에 대하여 예언하는도다 하나니","reference":"에스겔 12:27","category":"$undefined"},{"id":"20709","book":"에스겔","book_name":"에스겔","chapter":12,"verse":28,"text":"그러므로 너는 그들에게 이르기를 주 여호와의 말씀에 나의 말이 하나도 다시 더디지 않을지니 나의 한 말이 이루리라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 12:28","category":"$undefined"}],"bookSlug":"ezekiel"}]
