2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":13,"verses":[{"id":"20710","book":"에스겔","book_name":"에스겔","chapter":13,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 13:1","category":"$undefined"},{"id":"20711","book":"에스겔","book_name":"에스겔","chapter":13,"verse":2,"text":"인자야 ! 너는 이스라엘의 예언하는 선지자를 쳐서 예언하되 자기 마음에서 나는 대로 예언하는 자에게 말하기를 너희는 여호와의 말씀을 들으라","reference":"에스겔 13:2","category":"$undefined"},{"id":"20712","book":"에스겔","book_name":"에스겔","chapter":13,"verse":3,"text":"주 여호와의 말씀에 본 것이 없이 자기 심령을 따라 예언하는 우매한 선지자에게 화 있을진저","reference":"에스겔 13:3","category":"$undefined"},{"id":"20713","book":"에스겔","book_name":"에스겔","chapter":13,"verse":4,"text":"이스라엘아 너의 선지자들은 황무지에 있는 여우 같으니라","reference":"에스겔 13:4","category":"$undefined"},{"id":"20714","book":"에스겔","book_name":"에스겔","chapter":13,"verse":5,"text":"너희 선지자들이 성 무너진 곳에 올라 가지도 아니하였으며 이스라엘 족속을 위하여 여호와의 날에 전쟁을 방비하게 하려고 성벽을 수축하지도 아니하였느니라","reference":"에스겔 13:5","category":"$undefined"},{"id":"20715","book":"에스겔","book_name":"에스겔","chapter":13,"verse":6,"text":"여호와께서 말씀하셨다고 하는 자들이 허탄한 것과 거짓된 점괘를 보며 사람으로 그 말이 굳게 이루기를 바라게 하거니와 여호와가 보낸 자가 아니라","reference":"에스겔 13:6","category":"$undefined"},{"id":"20716","book":"에스겔","book_name":"에스겔","chapter":13,"verse":7,"text":"너희가 말하기는 여호와의 말씀이라 하여도 내가 말한 것이 아닌즉 어찌 허탄한 묵시를 보며 거짓된 점괘를 말한 것이 아니냐","reference":"에스겔 13:7","category":"$undefined"},{"id":"20717","book":"에스겔","book_name":"에스겔","chapter":13,"verse":8,"text":"그러므로 나 주 여호와가 또 말하노라 너희가 허탄한 것을 말하며 거짓된 것을 보았은즉 내가 너희를 치리라 나 주 여호와의 말이니라","reference":"에스겔 13:8","category":"$undefined"},{"id":"20718","book":"에스겔","book_name":"에스겔","chapter":13,"verse":9,"text":"그 선지자들이 허탄한 묵시를 보며 거짓 것을 점쳤으니 내 손이 그들을 쳐서 내 백성의 공회에 들어오지 못하게 하며 이스라엘 족속의 호적에도 기록되지 못하게 하며 이스라엘 땅에도 들어가지 못하게 하리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 13:9","category":"$undefined"},{"id":"20719","book":"에스겔","book_name":"에스겔","chapter":13,"verse":10,"text":"이렇게 칠 것은 그들이 내 백성을 유혹하여 평강이 없으나 평강이 있다 함이라 혹이 담을 쌓을 때에 그들이 회칠을 하는도다","reference":"에스겔 13:10","category":"$undefined"},{"id":"20720","book":"에스겔","book_name":"에스겔","chapter":13,"verse":11,"text":"그러므로 너는 회칠하는 자에게 이르기를 그것이 무너지리라 폭우가 내리며 큰 우박덩이가 떨어지며 폭풍이 열파하리니","reference":"에스겔 13:11","category":"$undefined"},{"id":"20721","book":"에스겔","book_name":"에스겔","chapter":13,"verse":12,"text":"그 담이 무너진즉 혹이 너희에게 말하기를 그것에 칠한 회가 어디 있느뇨 하지 아니하겠느냐","reference":"에스겔 13:12","category":"$undefined"},{"id":"20722","book":"에스겔","book_name":"에스겔","chapter":13,"verse":13,"text":"그러므로 나 주 여호와가 말하노라 내가 분노하여 폭풍으로 열파하고 내가 진노하여 폭우를 내리고 분노하여 큰 우박덩이로 훼멸하리라","reference":"에스겔 13:13","category":"$undefined"},{"id":"20723","book":"에스겔","book_name":"에스겔","chapter":13,"verse":14,"text":"회칠한 담을 내가 이렇게 훼파하여 땅에 넘어뜨리고 그 기초를 드러낼 것이라 담이 무너진즉 너희가 그 가운데서 망하리니 나를 여호와인 줄 알리라","reference":"에스겔 13:14","category":"$undefined"},{"id":"20724","book":"에스겔","book_name":"에스겔","chapter":13,"verse":15,"text":"이와 같이 내가 내 노를 담과 회칠한 자에게 다 이루고 또 너희에게 말하기를 담도 없어지고 칠한 자들도 없어졌다 하리니","reference":"에스겔 13:15","category":"$undefined"},{"id":"20725","book":"에스겔","book_name":"에스겔","chapter":13,"verse":16,"text":"이들은 예루살렘에 대하여 예언하여 평강이 없으나 평강의 묵시를 본다 하는 이스라엘의 선지자들이니라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 13:16","category":"$undefined"},{"id":"20726","book":"에스겔","book_name":"에스겔","chapter":13,"verse":17,"text":"너 인자야 너의 백성 중 자기 마음에서 나는대로 예언하는 부녀들을 대면하여 쳐서 예언하여","reference":"에스겔 13:17","category":"$undefined"},{"id":"20727","book":"에스겔","book_name":"에스겔","chapter":13,"verse":18,"text":"이르기를 주 여호와의 말씀에 사람의 영혼을 사냥하고자 하여 방석을 모든 팔뚝에 꿰어 매고 수건을 키가 큰 자나 작은 자의 머리를 위하여 만드는 부녀들에게 화있을진저 너희가 어찌하여 내 백성의 영혼을 사냥하면서 자기를 위하여 영혼을 살리려 하느냐 ?","reference":"에스겔 13:18","category":"$undefined"},{"id":"20728","book":"에스겔","book_name":"에스겔","chapter":13,"verse":19,"text":"너희가 두어 웅큼 보리와 두어조각 떡을 위하여 나를 내 백성 가운데서 욕되게 하여 거짓말을 지어서 죽지 아니할 영혼을 죽이고 살지 못할 영혼을 살리는도다","reference":"에스겔 13:19","category":"$undefined"},{"id":"20729","book":"에스겔","book_name":"에스겔","chapter":13,"verse":20,"text":"그러므로 나 주 여호와가 말하노라 너희가 새를 사냥하듯 영혼들을 사냥하는 그 방석을 내가 너희 팔에서 떼어 버리고 너희가 새처럼 사냥한 그 영혼들을 놓으며","reference":"에스겔 13:20","category":"$undefined"},{"id":"20730","book":"에스겔","book_name":"에스겔","chapter":13,"verse":21,"text":"또 너희 수건을 찢고 내 백성을 너희 손에서 건지고 다시는 너희 손에 사냥물이 되지 않게 하리니 너희가 나를 여호와인줄 알리라","reference":"에스겔 13:21","category":"$undefined"},{"id":"20731","book":"에스겔","book_name":"에스겔","chapter":13,"verse":22,"text":"내가 슬프게 하지 아니한 의인의 마음을 너희가 거짓말로 근심하게 하며 너희가 또 악인의 손을 굳게 하여 그 악한 길에서 돌이켜 떠나 삶을 얻지 못하게 하였은즉","reference":"에스겔 13:22","category":"$undefined"},{"id":"20732","book":"에스겔","book_name":"에스겔","chapter":13,"verse":23,"text":"너희가 다시는 허탄한 묵시를 보지 못하고 점복도 못할지라 내가 내 백성을 너희 손에서 건져 내리니 너희가 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 13:23","category":"$undefined"}],"bookSlug":"ezekiel"}]
