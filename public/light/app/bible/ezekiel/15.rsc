2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":15,"verses":[{"id":"20756","book":"에스겔","book_name":"에스겔","chapter":15,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 15:1","category":"$undefined"},{"id":"20757","book":"에스겔","book_name":"에스겔","chapter":15,"verse":2,"text":"인자야 ! 포도나무가 모든 나무보다 나은 것이 무엇이랴 삼림 중 여러 나무 가운데 있는 그 포도나무 가지가 나은 것이 무엇이랴","reference":"에스겔 15:2","category":"$undefined"},{"id":"20758","book":"에스겔","book_name":"에스겔","chapter":15,"verse":3,"text":"그 나무를 가지고 무엇을 제조할 수 있겠느냐 그것으로 무슨 그릇을 걸 못을 만들 수 있겠느냐 ?","reference":"에스겔 15:3","category":"$undefined"},{"id":"20759","book":"에스겔","book_name":"에스겔","chapter":15,"verse":4,"text":"불에 던질 화목이 될 뿐이라 불이 그 두 끝을 사르고 그 가운데도 태웠으면 제조에 무슨 소용이 있겠느냐 ?","reference":"에스겔 15:4","category":"$undefined"},{"id":"20760","book":"에스겔","book_name":"에스겔","chapter":15,"verse":5,"text":"그것이 온전할 때에도 아무 제조에 합당치 않았거든 하물며 불에 살라지고 탄 후에 어찌 제조에 합당하겠느냐 ?","reference":"에스겔 15:5","category":"$undefined"},{"id":"20761","book":"에스겔","book_name":"에스겔","chapter":15,"verse":6,"text":"그러므로 주 여호와 내가 말하노라 내가 수풀 가운데 포도나무를 불에 던질 화목이 되게 한 것같이 내가 예루살렘 거민도 그같이 할지라","reference":"에스겔 15:6","category":"$undefined"},{"id":"20762","book":"에스겔","book_name":"에스겔","chapter":15,"verse":7,"text":"내가 그들을 대적한즉 그들이 그 불에서 나와도 불이 그들을 사르리니 내가 그들을 대적할 때에 너희가 나를 여호와인 줄 알리라","reference":"에스겔 15:7","category":"$undefined"},{"id":"20763","book":"에스겔","book_name":"에스겔","chapter":15,"verse":8,"text":"내가 그 땅을 황무케 하리니 이는 그들이 범법함이니라 나 주 여호와의 말이니라 하시니라","reference":"에스겔 15:8","category":"$undefined"}],"bookSlug":"ezekiel"}]
