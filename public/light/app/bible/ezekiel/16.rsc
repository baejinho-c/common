2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":16,"verses":[{"id":"20764","book":"에스겔","book_name":"에스겔","chapter":16,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 16:1","category":"$undefined"},{"id":"20765","book":"에스겔","book_name":"에스겔","chapter":16,"verse":2,"text":"인자야 예루살렘으로 그 가증한 일을 알게 하여","reference":"에스겔 16:2","category":"$undefined"},{"id":"20766","book":"에스겔","book_name":"에스겔","chapter":16,"verse":3,"text":"이르기를 주 여호와께서 예루살렘에 대하여 말씀하시되 네 근본과 난 땅은 가나안이요 네 아비는 아모리 사람이요 네 어미는 헷 사람이라","reference":"에스겔 16:3","category":"$undefined"},{"id":"20767","book":"에스겔","book_name":"에스겔","chapter":16,"verse":4,"text":"너의 난 것을 말하건대 네가 날 때에 네 배꼽줄을 자르지 아니하였고 너를 물로 씻어 정결케 하지 아니하였고 네게 소금을 뿌리지 아니하였고 너를 강보에 싸지도 아니하였나니","reference":"에스겔 16:4","category":"$undefined"},{"id":"20768","book":"에스겔","book_name":"에스겔","chapter":16,"verse":5,"text":"너를 돌아 보아 이 중에 한 가지라도 네게 행하여 너를 긍휼히 여긴 자가 없었으므로 네가 나던 날에 네 몸이 꺼린바 되어 네가 들에 버리웠었느니라","reference":"에스겔 16:5","category":"$undefined"},{"id":"20769","book":"에스겔","book_name":"에스겔","chapter":16,"verse":6,"text":"내가 네 곁으로 지나 갈 때에 네가 피투성이가 되어 발짓하는 것을 보고 네게 이르기를 너는 피투성이라도 살라 다시 이르기를 너는 피투성이라도 살라 하고","reference":"에스겔 16:6","category":"$undefined"},{"id":"20770","book":"에스겔","book_name":"에스겔","chapter":16,"verse":7,"text":"내가 너로 들의 풀 같이 많게 하였더니 네가 크게 자라고 심히 아름다우며 유방이 뚜렷하고 네 머리털이 자랐으나 네가 오히려 벌거벗은 적신이더라","reference":"에스겔 16:7","category":"$undefined"},{"id":"20771","book":"에스겔","book_name":"에스겔","chapter":16,"verse":8,"text":"내가 네 곁으로 지나며 보니 네 때가 사랑스러운 때라 내 옷으로 너를 덮어 벌거벗은 것을 가리우고 네게 맹세하고 언약하여 너로 내게 속하게 하였었느니라 나 주 여호와의 말이니라","reference":"에스겔 16:8","category":"$undefined"},{"id":"20772","book":"에스겔","book_name":"에스겔","chapter":16,"verse":9,"text":"내가 물로 너를 씻겨서 네 피를 없이 하며 네게 기름을 바르고","reference":"에스겔 16:9","category":"$undefined"},{"id":"20773","book":"에스겔","book_name":"에스겔","chapter":16,"verse":10,"text":"수 놓은 옷을 입히고 물돼지 가죽신을 신기고 가는 베로 띠우고 명주로 덧입히고","reference":"에스겔 16:10","category":"$undefined"},{"id":"20774","book":"에스겔","book_name":"에스겔","chapter":16,"verse":11,"text":"패물을 채우고 팔고리를 손목에 끼우고 사슬을 목에 드리우고","reference":"에스겔 16:11","category":"$undefined"},{"id":"20775","book":"에스겔","book_name":"에스겔","chapter":16,"verse":12,"text":"코고리를 코에 달고 귀고리를 귀에 달고 화려한 면류관을 머리에 씌웠나니","reference":"에스겔 16:12","category":"$undefined"},{"id":"20776","book":"에스겔","book_name":"에스겔","chapter":16,"verse":13,"text":"이와 같이 네가 금 은으로 장식하고 가는 베와 명주와 수놓은 것을 입으며 또 고운 밀가루와 꿀과 기름을 먹음으로 극히 곱고 형통하여 왕후의 지위에 나아갔느니라","reference":"에스겔 16:13","category":"$undefined"},{"id":"20777","book":"에스겔","book_name":"에스겔","chapter":16,"verse":14,"text":"네 화려함을 인하여 네 명성이 이방인 중에 퍼졌음은 내가 네게 입힌 영화로 네 화려함이 온전함이니라 나 주 여호와의 말이니라","reference":"에스겔 16:14","category":"$undefined"},{"id":"20778","book":"에스겔","book_name":"에스겔","chapter":16,"verse":15,"text":"그러나 네가 네 화려함을 믿고 네 명성을 인하여 행음하되 무릇 지나가는 자면 더불어 음란을 많이 행하므로 네 몸이 그들의 것이 되도다","reference":"에스겔 16:15","category":"$undefined"},{"id":"20779","book":"에스겔","book_name":"에스겔","chapter":16,"verse":16,"text":"네가 네 의복을 취하여 색스러운 산당을 너를 위하여 만들고 거기서 행음하였나니 이런 일은 전무후무하니라","reference":"에스겔 16:16","category":"$undefined"},{"id":"20780","book":"에스겔","book_name":"에스겔","chapter":16,"verse":17,"text":"네가 또 나의 준 금,은 장식품으로 너를 위하여 남자 우상을 만들어 행음하며","reference":"에스겔 16:17","category":"$undefined"},{"id":"20781","book":"에스겔","book_name":"에스겔","chapter":16,"verse":18,"text":"또 네 수 놓은 옷으로 그 우상에게 입히고 나의 기름과 향으로 그 앞에 베풀며","reference":"에스겔 16:18","category":"$undefined"},{"id":"20782","book":"에스겔","book_name":"에스겔","chapter":16,"verse":19,"text":"또 내가 네게 주어 먹게 한 내 식물 곧 고운 밀가루와 기름과 꿀을 네가 그 앞에 베풀어 향기를 삼았나니 과연 그렇게 하였느니라 나 주 여호와의 말이니라","reference":"에스겔 16:19","category":"$undefined"},{"id":"20783","book":"에스겔","book_name":"에스겔","chapter":16,"verse":20,"text":"또 네가 나를 위하여 낳은 네 자녀를 가져 그들에게 드려 제물을 삼아 불살랐느니라 네가 너의 음행을 작은 일로 여겨서","reference":"에스겔 16:20","category":"$undefined"},{"id":"20784","book":"에스겔","book_name":"에스겔","chapter":16,"verse":21,"text":"나의 자녀들을 죽여 우상에게 붙여 불 가운데로 지나가게 하였느냐 ?","reference":"에스겔 16:21","category":"$undefined"},{"id":"20785","book":"에스겔","book_name":"에스겔","chapter":16,"verse":22,"text":"네 어렸을 때에 벌거벗어 적신이었으며 피투성이가 되어서 발짓하던 것을 기억지 아니하고 네가 모든 가증한 일과 음란을 행하였느니라","reference":"에스겔 16:22","category":"$undefined"},{"id":"20786","book":"에스겔","book_name":"에스겔","chapter":16,"verse":23,"text":"나 주 여호와가 말하노라 너는 화 있을진저 화 있을진저 네가 모든 악을 행한 후에","reference":"에스겔 16:23","category":"$undefined"},{"id":"20787","book":"에스겔","book_name":"에스겔","chapter":16,"verse":24,"text":"너를 위하여 누를 건축하며 모든 거리에 높은 대를 쌓았도다","reference":"에스겔 16:24","category":"$undefined"},{"id":"20788","book":"에스겔","book_name":"에스겔","chapter":16,"verse":25,"text":"네가 높은 대를 모든 길 머리에 쌓고 네 아름다움을 가증하게 하여 모든 지나가는 자에게 다리를 벌려 심히 행음하고","reference":"에스겔 16:25","category":"$undefined"},{"id":"20789","book":"에스겔","book_name":"에스겔","chapter":16,"verse":26,"text":"하체가 큰 네 이웃나라 애굽 사람과도 행음하되 심히 음란히 하여 내 노를 격동하였도다","reference":"에스겔 16:26","category":"$undefined"},{"id":"20790","book":"에스겔","book_name":"에스겔","chapter":16,"verse":27,"text":"그러므로 내가 내 손을 네 위에 펴서 네 일용 양식을 감하고 너를 미워하는 블레셋 여자 곧 네 더러운 행실을 부끄러워하는 자에게 너를 붙여 임의로 하게 하였거늘","reference":"에스겔 16:27","category":"$undefined"},{"id":"20791","book":"에스겔","book_name":"에스겔","chapter":16,"verse":28,"text":"네가 음욕이 차지 아니하여 또 앗수르 사람과 행음하고 그들과 행음하고도 오히려 부족히 여겨","reference":"에스겔 16:28","category":"$undefined"},{"id":"20792","book":"에스겔","book_name":"에스겔","chapter":16,"verse":29,"text":"장사하는 땅 갈대아에까지 심히 행음하되 오히려 족한 줄을 알지못하였느니라","reference":"에스겔 16:29","category":"$undefined"},{"id":"20793","book":"에스겔","book_name":"에스겔","chapter":16,"verse":30,"text":"나 주 여호와가 말하노라 네가 이 모든 일을 행하니 이는 방자한 음부의 행위라 네 마음이 어찌 그리 약한지","reference":"에스겔 16:30","category":"$undefined"},{"id":"20794","book":"에스겔","book_name":"에스겔","chapter":16,"verse":31,"text":"네가 누를 모든 길 머리에 건축하며 높은 대를 모든 거리에 쌓고도 값을 싫어하니 창기 같지도 않도다","reference":"에스겔 16:31","category":"$undefined"},{"id":"20795","book":"에스겔","book_name":"에스겔","chapter":16,"verse":32,"text":"그 지아비 대신에 외인과 사통하여 간음하는 아내로다","reference":"에스겔 16:32","category":"$undefined"},{"id":"20796","book":"에스겔","book_name":"에스겔","chapter":16,"verse":33,"text":"사람들은 모든 창기에게 선물을 주거늘 오직 너는 네 모든 정든 자에게 선물을 주며 값을 주어서 사방에서 와서 너와 행음하게 하니","reference":"에스겔 16:33","category":"$undefined"},{"id":"20797","book":"에스겔","book_name":"에스겔","chapter":16,"verse":34,"text":"사람들은 모든 창기에게 선물을 주거늘 오직 너는 네 모든 정든 자에게 선물을 주며 값을 주어서 사방에서 와서 너와 행음하게 하니","reference":"에스겔 16:34","category":"$undefined"},{"id":"20798","book":"에스겔","book_name":"에스겔","chapter":16,"verse":35,"text":"너의 음란함이 다른 여인과 같지 아니함은 행음하려고 너를 따르는 자가 없음이며 또 네가 값을 받지 아니하고 도리어 줌이라 그런즉 다른 여인과 같지 아니하니라","reference":"에스겔 16:35","category":"$undefined"},{"id":"20799","book":"에스겔","book_name":"에스겔","chapter":16,"verse":36,"text":"그러므로 너 음부야 여호와의 말을 들을지어다","reference":"에스겔 16:36","category":"$undefined"},{"id":"20800","book":"에스겔","book_name":"에스겔","chapter":16,"verse":37,"text":"나 주 여호와가 말하노라 네가 네 누추한 것을 쏟으며 네 정든 자와 행음함으로 벗은 몸을 드러내며 또 가증한 우상을 위하여 네 자녀의 피를 그 우상에게 드렸은즉","reference":"에스겔 16:37","category":"$undefined"},{"id":"20801","book":"에스겔","book_name":"에스겔","chapter":16,"verse":38,"text":"내가 저의 즐거워하는 정든 자와 사랑하던 모든 자와 미워하던 모든 자를 모으되 사방에서 모아 너를 대적하게 할 것이요 또 네 벗은 몸을 그 앞에 드러내어 그들로 그것을 다 보게 할 것이며","reference":"에스겔 16:38","category":"$undefined"},{"id":"20802","book":"에스겔","book_name":"에스겔","chapter":16,"verse":39,"text":"내가 또 간음하고 사람의 피를 흘리는 여인을 국문함 같이 너를 국문하여 진노의 피와 투기의 피를 네게 돌리고","reference":"에스겔 16:39","category":"$undefined"},{"id":"20803","book":"에스겔","book_name":"에스겔","chapter":16,"verse":40,"text":"내가 또 너를 그들의 손에 붙이리니 그들이 네 누를 헐며 네 높은 대를 훼파하며 네 의복을 벗기고 네 장식품을 빼앗고 네 몸을 벌거벗겨 버려두며","reference":"에스겔 16:40","category":"$undefined"},{"id":"20804","book":"에스겔","book_name":"에스겔","chapter":16,"verse":41,"text":"무리를 데리고 와서 너를 돌로 치며 칼로 찌르며","reference":"에스겔 16:41","category":"$undefined"},{"id":"20805","book":"에스겔","book_name":"에스겔","chapter":16,"verse":42,"text":"불로 너의 집들을 사르고 여러 여인의 목전에서 너를 벌할지라 내가 너로 곧 음행을 그치게 하리니 네가 다시는 값을 주지 아니하리라","reference":"에스겔 16:42","category":"$undefined"},{"id":"20806","book":"에스겔","book_name":"에스겔","chapter":16,"verse":43,"text":"그리한즉 내가 네게 대한 내 분노가 그치며 내 투기가 네게서 떠나고 마음이 평안하여 다시는 노하지 아니하리라","reference":"에스겔 16:43","category":"$undefined"},{"id":"20807","book":"에스겔","book_name":"에스겔","chapter":16,"verse":44,"text":"네가 어렸을 때를 기억지 아니하고 이 모든 일로 나를 격노케 하였은즉 내가 네 행위대로 네 머리에 보응하리니 네가 이 음란과 네 모든 가증한 일을 다시는 행하지 아니하리라 나 주 여호와의 말이니라","reference":"에스겔 16:44","category":"$undefined"},{"id":"20808","book":"에스겔","book_name":"에스겔","chapter":16,"verse":45,"text":"무릇 속담하는 자가 네게 대하여 속담하기를 어미가 어떠하면 딸도 그렇다 하리라","reference":"에스겔 16:45","category":"$undefined"},{"id":"20809","book":"에스겔","book_name":"에스겔","chapter":16,"verse":46,"text":"너는 그 남편과 자녀를 싫어한 어미의 딸이요 너는 그 남편과 자녀를 싫어한 형의 동생이로다 네 어미는 헷 사람이요 네 아비는 아모리 사람이며","reference":"에스겔 16:46","category":"$undefined"},{"id":"20810","book":"에스겔","book_name":"에스겔","chapter":16,"verse":47,"text":"네 형은 그 딸들과 함께 네 좌편에 거하는 사마리아요 네 아우는 그 딸들과 함께 네 우편에 거하는 소돔이라","reference":"에스겔 16:47","category":"$undefined"},{"id":"20811","book":"에스겔","book_name":"에스겔","chapter":16,"verse":48,"text":"네가 그들의 행위대로만 행치 아니하며 그 가증한대로만 행치 아니하고 그것을 적게 여겨서 네 모든 행위가 그보다 더욱 부패하였도다","reference":"에스겔 16:48","category":"$undefined"},{"id":"20812","book":"에스겔","book_name":"에스겔","chapter":16,"verse":49,"text":"나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 네 아우 소돔 곧 그와 그 딸들은 너와 네 딸들의 행위 같이 행치 아니하였느니라","reference":"에스겔 16:49","category":"$undefined"},{"id":"20813","book":"에스겔","book_name":"에스겔","chapter":16,"verse":50,"text":"네 아우 소돔의 죄악은 이러하니 그와 그 딸들에게 교만함과 식물의 풍족함과 태평함이 있음이며 또 그가 가난하고 궁핍한 자를 도와주지 아니하며","reference":"에스겔 16:50","category":"$undefined"},{"id":"20814","book":"에스겔","book_name":"에스겔","chapter":16,"verse":51,"text":"거만하여 가증한 일을 내 앞에서 행하였음이라 그러므로 내가 보고 곧 그들을 없이 하였느니라","reference":"에스겔 16:51","category":"$undefined"},{"id":"20815","book":"에스겔","book_name":"에스겔","chapter":16,"verse":52,"text":"사마리아는 네 죄의 절반도 범치 아니하였느니라 네가 그들보다 가증한 일을 심히 행한고로 너의 가증한 행위로 네 형과 아우를 의롭게 하였느니라","reference":"에스겔 16:52","category":"$undefined"},{"id":"20816","book":"에스겔","book_name":"에스겔","chapter":16,"verse":53,"text":"네가 네 형과 아우를 논단하였은즉 너도 네 수치를 담당할찌니라 네가 그들보다 더욱 가증한 죄를 범하므로 그들이 너보다 의롭게 되었나니 네가 네 형과 아우를 의롭게 하였은즉 너는 놀라며 네 수치를 담당할지니라","reference":"에스겔 16:53","category":"$undefined"},{"id":"20817","book":"에스겔","book_name":"에스겔","chapter":16,"verse":54,"text":"내가 그들의 사로잡힘 곧 소돔과 그 딸들의 사로잡힘과 사마리아와 그 딸들의 사로잡힘과 그들 중에 너의 사로잡힌 자의 사로잡힘을 돌이켜서","reference":"에스겔 16:54","category":"$undefined"},{"id":"20818","book":"에스겔","book_name":"에스겔","chapter":16,"verse":55,"text":"너로 네 수욕을 담당하고 너의 행한 모든 일을 인하여 부끄럽게 하리니 이는 네가 그들에게 위로가 됨이라","reference":"에스겔 16:55","category":"$undefined"},{"id":"20819","book":"에스겔","book_name":"에스겔","chapter":16,"verse":56,"text":"네 아우 소돔과 그 딸들이 옛 지위를 회복할 것이요 사마리아와 그 딸들도 그 옛 지위를 회복할 것이며 너와 네 딸들도 너희 옛 지위를 회복할 것이니라","reference":"에스겔 16:56","category":"$undefined"},{"id":"20820","book":"에스겔","book_name":"에스겔","chapter":16,"verse":57,"text":"네가 교만하던 때에 네 아우 소돔을 네 입으로 말하지도 아니하였나니","reference":"에스겔 16:57","category":"$undefined"},{"id":"20821","book":"에스겔","book_name":"에스겔","chapter":16,"verse":58,"text":"곧 네 악이 드러나기 전에며 아람 딸들이 너를 능욕하기 전에며 너의 사방에 둘러 있는 블레셋 딸들이 너를 멸시하기 전에니라","reference":"에스겔 16:58","category":"$undefined"},{"id":"20822","book":"에스겔","book_name":"에스겔","chapter":16,"verse":59,"text":"네 음란과 네 가증한 일을 네가 담당하였느니라 나 여호와의 말이니라","reference":"에스겔 16:59","category":"$undefined"},{"id":"20823","book":"에스겔","book_name":"에스겔","chapter":16,"verse":60,"text":"나 주 여호와가 말하노라 네가 맹세를 멸시하여 언약을 배반하였은즉 내가 네 행한대로 네게 행하리라","reference":"에스겔 16:60","category":"$undefined"},{"id":"20824","book":"에스겔","book_name":"에스겔","chapter":16,"verse":61,"text":"그러나 내가 너의 어렸을 때에 너와 세운 언약을 기억하고 너와 영원한 언약을 세우리라","reference":"에스겔 16:61","category":"$undefined"},{"id":"20825","book":"에스겔","book_name":"에스겔","chapter":16,"verse":62,"text":"네가 네 형과 아우를 접대할 때에 네 행위를 기억하고 부끄러워할 것이라 내가 그들을 네게 딸로 주려니와 네 언약으로 말미암음이 아니니라","reference":"에스겔 16:62","category":"$undefined"},{"id":"20826","book":"에스겔","book_name":"에스겔","chapter":16,"verse":63,"text":"내가 네게 내 언약을 세워서 너로 나를 여호와인 줄 알게 하리니 [ (Ezekiel 16:64) 이는 내가 네 모든 행한 일을 용서한 후에 너로 기억하고 놀라고 부끄러워서 다시는 입을 열지 못하게 하려 함이니라 나 주 여호와의 말이니라 하셨다 하라 ]","reference":"에스겔 16:63","category":"$undefined"}],"bookSlug":"ezekiel"}]
