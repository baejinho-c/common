2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":17,"verses":[{"id":"20827","book":"에스겔","book_name":"에스겔","chapter":17,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 17:1","category":"$undefined"},{"id":"20828","book":"에스겔","book_name":"에스겔","chapter":17,"verse":2,"text":"인자야 너는 수수께끼와 비유를 이스라엘 족속에게 베풀어","reference":"에스겔 17:2","category":"$undefined"},{"id":"20829","book":"에스겔","book_name":"에스겔","chapter":17,"verse":3,"text":"이르기를 주 여호와의 말씀에 채색이 구비하고 날개가 크고 깃이 길고 털이 숱한 큰 독수리가 레바논에 이르러 백향목 높은 가지를 취하되","reference":"에스겔 17:3","category":"$undefined"},{"id":"20830","book":"에스겔","book_name":"에스겔","chapter":17,"verse":4,"text":"그 연한 가지 끝을 꺾어 가지고 장사하는 땅에 이르러 상고의 성읍에 두고","reference":"에스겔 17:4","category":"$undefined"},{"id":"20831","book":"에스겔","book_name":"에스겔","chapter":17,"verse":5,"text":"또 그 땅의 종자를 취하여 옥토에 심되 수양버들 가지처럼 큰 물가에 심더니","reference":"에스겔 17:5","category":"$undefined"},{"id":"20832","book":"에스겔","book_name":"에스겔","chapter":17,"verse":6,"text":"그것이 자라며 퍼져서 높지 아니한 포도나무 곧 굵은 가지와 가는 가지가 난 포도나무가 되어 그 가지는 독수리를 향하였고 그 뿌리는 독수리의 아래 있었더라","reference":"에스겔 17:6","category":"$undefined"},{"id":"20833","book":"에스겔","book_name":"에스겔","chapter":17,"verse":7,"text":"또 날개가 크고 털이 많은 큰 독수리에게 물을 받으려고 그 심긴 두둑에서 그를 향하여 뿌리가 발하고 가지가 퍼졌도다","reference":"에스겔 17:7","category":"$undefined"},{"id":"20834","book":"에스겔","book_name":"에스겔","chapter":17,"verse":8,"text":"그 포도나무를 큰 물 가 옥토에 심은 것은 가지를 내고 열매를 맺어서 아름다운 포도나무를 이루게 하려 하였음이니라","reference":"에스겔 17:8","category":"$undefined"},{"id":"20835","book":"에스겔","book_name":"에스겔","chapter":17,"verse":9,"text":"너는 이르기를 주 여호와의 말씀에 그 나무가 능히 번성하겠느냐 이 독수리가 어찌 그 뿌리를 빼고 실과를 따며 그 나무로 시들게 하지 아니하겠으며 그 연한 잎사귀로 마르게 하지 아니하겠느냐 많은 백성이나 강한 팔이 아니라도 그 뿌리를 뽑으리라","reference":"에스겔 17:9","category":"$undefined"},{"id":"20836","book":"에스겔","book_name":"에스겔","chapter":17,"verse":10,"text":"볼지어다 그것이 심겼으나 번성하겠느냐 동풍이 부딪힐 때에 아주 마르지 아니하겠느냐 그 자라던 두둑에서 마르리라 하셨다 하라","reference":"에스겔 17:10","category":"$undefined"},{"id":"20837","book":"에스겔","book_name":"에스겔","chapter":17,"verse":11,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 17:11","category":"$undefined"},{"id":"20838","book":"에스겔","book_name":"에스겔","chapter":17,"verse":12,"text":"너는 패역한 족속에게 묻기를 너희가 이 비유를 깨닫지 못하겠느냐 하고 그들에게 고하기를 바벨론 왕이 예루살렘에 이르러 왕과 방백을 사로잡아 바벨론 자기에게로 끌어가고","reference":"에스겔 17:12","category":"$undefined"},{"id":"20839","book":"에스겔","book_name":"에스겔","chapter":17,"verse":13,"text":"그 왕족 중에 하나를 택하여 언약을 세우고 그로 맹세케 하고 또 그 땅의 능한 자들을 옮겨 갔나니","reference":"에스겔 17:13","category":"$undefined"},{"id":"20840","book":"에스겔","book_name":"에스겔","chapter":17,"verse":14,"text":"이는 나라를 낮추어 스스로 서지 못하고 그 언약을 지켜야 능히 서게 하려 하였음이어늘","reference":"에스겔 17:14","category":"$undefined"},{"id":"20841","book":"에스겔","book_name":"에스겔","chapter":17,"verse":15,"text":"그가 사자를 애굽에 보내어 말과 군대를 구함으로 바벨론 왕을 배반하였으니 형통하겠느냐 이런 일을 행한 자가 피하겠느냐 언약을 배반하고야 피하겠느냐","reference":"에스겔 17:15","category":"$undefined"},{"id":"20842","book":"에스겔","book_name":"에스겔","chapter":17,"verse":16,"text":"나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 바벨론 왕이 그를 왕으로 세웠거늘 그가 맹세를 업신여겨 언약을 배반하였은즉 그 왕의 거하는 곳 바벨론 중에서 왕과 함께 있다가 죽을 것이라","reference":"에스겔 17:16","category":"$undefined"},{"id":"20843","book":"에스겔","book_name":"에스겔","chapter":17,"verse":17,"text":"대적이 토성을 쌓으며 운제를 세우고 많은 사람을 멸절하려 할 때에 바로가 그 큰 군대와 많은 무리로도 그 전쟁에 그를 도와 주지 못하리라","reference":"에스겔 17:17","category":"$undefined"},{"id":"20844","book":"에스겔","book_name":"에스겔","chapter":17,"verse":18,"text":"그가 이미 손을 내어 밀어 언약하였거늘 맹세를 업신여겨 언약을 배반하고 이 모든 일을 행하였으니 피하지 못하리라","reference":"에스겔 17:18","category":"$undefined"},{"id":"20845","book":"에스겔","book_name":"에스겔","chapter":17,"verse":19,"text":"그러므로 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 그가 내 맹세를 업신여기고 내 언약을 배반하였은즉 내가 그 죄를 그 머리에 돌리되","reference":"에스겔 17:19","category":"$undefined"},{"id":"20846","book":"에스겔","book_name":"에스겔","chapter":17,"verse":20,"text":"내 그물을 그 위에 베풀며 내 올무에 걸리게 하여 끌고 바벨론으로 가서 나를 반역한 그 반역을 거기서 국문할지며","reference":"에스겔 17:20","category":"$undefined"},{"id":"20847","book":"에스겔","book_name":"에스겔","chapter":17,"verse":21,"text":"그 모든 군대에서 도망한 자들은 다 칼에 엎드러질 것이요 그 남은 자는 사방으로 흩어지리니 나 여호와가 이것을 말한 줄을 너희가 알리라","reference":"에스겔 17:21","category":"$undefined"},{"id":"20848","book":"에스겔","book_name":"에스겔","chapter":17,"verse":22,"text":"나 주 여호와가 말하노라 내가 또 백향목 꼭대기에서 높은 가지를 취하여 심으리라 내가 그 높은 새 가지 끝에서 연한 가지를 꺾어 높고 빼어난 산에 심되","reference":"에스겔 17:22","category":"$undefined"},{"id":"20849","book":"에스겔","book_name":"에스겔","chapter":17,"verse":23,"text":"이스라엘 높은 산에 심으리니 그 가지가 무성하고 열매를 맺어서 아름다운 백향목을 이룰 것이요 각양 새가 그 아래 깃들이며 그 가지 그늘에 거할지라","reference":"에스겔 17:23","category":"$undefined"},{"id":"20850","book":"에스겔","book_name":"에스겔","chapter":17,"verse":24,"text":"들의 모든 나무가 나 여호와는 높은 나무를 낮추고 낮은 나무를 높이며 푸른 나무를 말리우고 마른 나무를 무성케 하는줄 알리라 나 여호와는 말하고 이루느니라 하라","reference":"에스겔 17:24","category":"$undefined"}],"bookSlug":"ezekiel"}]
