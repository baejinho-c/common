2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":18,"verses":[{"id":"20851","book":"에스겔","book_name":"에스겔","chapter":18,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 18:1","category":"$undefined"},{"id":"20852","book":"에스겔","book_name":"에스겔","chapter":18,"verse":2,"text":"너희가 이스라엘 땅에 대한 속담에 이르기를 아비가 신 포도를 먹었으므로 아들의 이가 시다고 함은 어찜이뇨","reference":"에스겔 18:2","category":"$undefined"},{"id":"20853","book":"에스겔","book_name":"에스겔","chapter":18,"verse":3,"text":"나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 너희가 이스라엘 가운데서 다시는 이 속담을 쓰지 못하게 되리라","reference":"에스겔 18:3","category":"$undefined"},{"id":"20854","book":"에스겔","book_name":"에스겔","chapter":18,"verse":4,"text":"모든 영혼이 다 내게 속한지라 아비의 영혼이 내게 속함 같이 아들의 영혼도 내게 속하였나니 범죄하는 그 영혼이 죽으리라","reference":"에스겔 18:4","category":"$undefined"},{"id":"20855","book":"에스겔","book_name":"에스겔","chapter":18,"verse":5,"text":"사람이 만일 의로워서 법과 의를 따라 행하며","reference":"에스겔 18:5","category":"$undefined"},{"id":"20856","book":"에스겔","book_name":"에스겔","chapter":18,"verse":6,"text":"산 위에서 제물을 먹지 아니하며 이스라엘 족속의 우상에게 눈을 들지 아니하며 이웃의 아내를 더럽히지 아니하며 월경 중에 있는 여인을 가까이 하지 아니하며","reference":"에스겔 18:6","category":"$undefined"},{"id":"20857","book":"에스겔","book_name":"에스겔","chapter":18,"verse":7,"text":"사람이 학대하지 아니하며 빚진 자의 전당물을 도로 주며 억탈하지 아니하며 주린 자에게 식물을 주며 벗은 자에게 옷을 입히며","reference":"에스겔 18:7","category":"$undefined"},{"id":"20858","book":"에스겔","book_name":"에스겔","chapter":18,"verse":8,"text":"변을 위하여 꾸이지 아니하며 이식을 받지 아니하며 스스로 손을 금하여 죄악을 짓지 아니하며 사람 사람 사이에 진실히 판단하며","reference":"에스겔 18:8","category":"$undefined"},{"id":"20859","book":"에스겔","book_name":"에스겔","chapter":18,"verse":9,"text":"내 율례를 좇으며 내 규례를 지켜 진실히 행할진대 그는 의인이니 정녕 살리라 나 주 여호와의 말이니라","reference":"에스겔 18:9","category":"$undefined"},{"id":"20860","book":"에스겔","book_name":"에스겔","chapter":18,"verse":10,"text":"가령 그가 아들을 낳았다 하자 그 아들이 이 모든 선은 하나도 행치 아니하고 이 악 중 하나를 범하여 강포하거나 살인하거나","reference":"에스겔 18:10","category":"$undefined"},{"id":"20861","book":"에스겔","book_name":"에스겔","chapter":18,"verse":11,"text":"산 위에서 제물을 먹거나 이웃의 아내를 더럽히거나","reference":"에스겔 18:11","category":"$undefined"},{"id":"20862","book":"에스겔","book_name":"에스겔","chapter":18,"verse":12,"text":"가난하고 궁핍한 자를 학대하거나 억탈하거나 빚진 자의 전당물을 도로 주지 아니하거나 우상에게 눈을 들거나 가증한 일을 행하거나","reference":"에스겔 18:12","category":"$undefined"},{"id":"20863","book":"에스겔","book_name":"에스겔","chapter":18,"verse":13,"text":"변을 위하여 꾸이거나 이식을 받거나 할진대 그가 살겠느냐 살지 못하리니 이 모든 가증한 일을 행하였은즉 정녕 죽을지라 자기의 피가 자기에게 돌아가리라","reference":"에스겔 18:13","category":"$undefined"},{"id":"20864","book":"에스겔","book_name":"에스겔","chapter":18,"verse":14,"text":"또 가령 그가 아들을 낳았다 하자 그 아들이 그 아비의 행한 모든 죄를 보고 두려워하여 그대로 행하지 아니하고","reference":"에스겔 18:14","category":"$undefined"},{"id":"20865","book":"에스겔","book_name":"에스겔","chapter":18,"verse":15,"text":"산 위에서 제물을 먹지도 아니하며 이스라엘 족속의 우상에게 눈을 들지도 아니하며 이웃의 아내를 더럽히지도 아니하며","reference":"에스겔 18:15","category":"$undefined"},{"id":"20866","book":"에스겔","book_name":"에스겔","chapter":18,"verse":16,"text":"사람을 학대하지도 아니하며 전당을 잡지도 아니하며 억탈하지도 아니하고 주린 자에게 식물을 주며 벗은 자에게 옷을 입히며","reference":"에스겔 18:16","category":"$undefined"},{"id":"20867","book":"에스겔","book_name":"에스겔","chapter":18,"verse":17,"text":"손을 금하여 가난한 자를 압제하지 아니하며 변이나 이식을 취하지 아니하여 내 규례를 지키며 내 율례를 행할진대 이 사람은 그아비의 죄악으로 인하여 죽지 아니하고 정녕 살겠고","reference":"에스겔 18:17","category":"$undefined"},{"id":"20868","book":"에스겔","book_name":"에스겔","chapter":18,"verse":18,"text":"그 아비는 심히 포학하여 그 동족을 억탈하고 민간에 불선을 행하였으므로 그는 그 죄악으로 인하여 죽으리라","reference":"에스겔 18:18","category":"$undefined"},{"id":"20869","book":"에스겔","book_name":"에스겔","chapter":18,"verse":19,"text":"그런데 너희는 이르기를 아들이 어찌 아비의 죄를 담당치 않겠느뇨 하는도다 아들이 법과 의를 행하며 내 모든 율례를 지켜 행하였으면 그는 정녕 살려니와","reference":"에스겔 18:19","category":"$undefined"},{"id":"20870","book":"에스겔","book_name":"에스겔","chapter":18,"verse":20,"text":"범죄하는 그 영혼은 죽을지라 아들은 아비의 죄악을 담당치 아니할 것이요 아비는 아들의 죄악을 담당치 아니하리니 의인의 의도 자기에게로 돌아 가고 악인의 악도 자기에게로 돌아가리라","reference":"에스겔 18:20","category":"$undefined"},{"id":"20871","book":"에스겔","book_name":"에스겔","chapter":18,"verse":21,"text":"그러나 악인이 만일 그 행한 모든 죄에서 돌이켜 떠나 내 모든 율례를 지키고 법과 의를 행하면 정녕 살고 죽지 아니할 것이라","reference":"에스겔 18:21","category":"$undefined"},{"id":"20872","book":"에스겔","book_name":"에스겔","chapter":18,"verse":22,"text":"그 범죄한 것이 하나도 기억함이 되지 아니하리니 그 행한 의로 인하여 살리라","reference":"에스겔 18:22","category":"$undefined"},{"id":"20873","book":"에스겔","book_name":"에스겔","chapter":18,"verse":23,"text":"나 주 여호와가 말하노라 내가 어찌 악인의 죽는 것을 조금인들 기뻐하랴 그가 돌이켜 그 길에서 떠나서 사는 것을 어찌 기뻐하지 아니하겠느냐","reference":"에스겔 18:23","category":"$undefined"},{"id":"20874","book":"에스겔","book_name":"에스겔","chapter":18,"verse":24,"text":"만일 의인이 돌이켜 그 의에서 떠나서 범죄하고 악인의 행하는 모든 가증한 일대로 행하면 살겠느냐 그 행한 의로운 일은 하나도 기억함이 되지 아니하리니 그가 그 범한 허물과 그 지은 죄로 인하여 죽으리라","reference":"에스겔 18:24","category":"$undefined"},{"id":"20875","book":"에스겔","book_name":"에스겔","chapter":18,"verse":25,"text":"그런데 너희는 이르기를 주의 길이 공평치 않다 하는도다 이스라엘 족속아 들을지어다 내 길이 어찌 공평치 아니하냐 너희 길이 공평치 않은 것이 아니냐","reference":"에스겔 18:25","category":"$undefined"},{"id":"20876","book":"에스겔","book_name":"에스겔","chapter":18,"verse":26,"text":"만일 의인이 그 의를 떠나 죄악을 행하고 인하여 죽으면 그 행한 죄악으로 인하여 죽는 것이요","reference":"에스겔 18:26","category":"$undefined"},{"id":"20877","book":"에스겔","book_name":"에스겔","chapter":18,"verse":27,"text":"만일 악인이 그 행한 악을 떠나 법과 의를 행하면 그 영혼을 보전하리라","reference":"에스겔 18:27","category":"$undefined"},{"id":"20878","book":"에스겔","book_name":"에스겔","chapter":18,"verse":28,"text":"그가 스스로 헤아리고 그 행한 모든 죄악에서 돌이켜 떠났으니 정녕 살고 죽지 아니하리라","reference":"에스겔 18:28","category":"$undefined"},{"id":"20879","book":"에스겔","book_name":"에스겔","chapter":18,"verse":29,"text":"그런데 이스라엘 족속은 이르기를 주의 길이 공평치 않다 하는도다 이스라엘 족속아 나의 길이 어찌 공평치 아니하냐 너희 길이 공평치 않은 것이 아니냐","reference":"에스겔 18:29","category":"$undefined"},{"id":"20880","book":"에스겔","book_name":"에스겔","chapter":18,"verse":30,"text":"나 주 여호와가 말하노라 이스라엘 족속아 내가 너희 각 사람의 행한대로 국문할지니라 너희는 돌이켜 회개하고 모든 죄에서 떠날지어다 그리한즉 죄악이 너희를 패망케 아니하리라","reference":"에스겔 18:30","category":"$undefined"},{"id":"20881","book":"에스겔","book_name":"에스겔","chapter":18,"verse":31,"text":"너희는 범한 모든 죄악을 버리고 마음과 영을 새롭게 할지어다 이스라엘 족속아 너희가 어찌하여 죽고자 하느냐","reference":"에스겔 18:31","category":"$undefined"},{"id":"20882","book":"에스겔","book_name":"에스겔","chapter":18,"verse":32,"text":"나 주 여호와가 말하노라 죽는 자의 죽는 것은 내가 기뻐하지 아니하노니 너희는 스스로 돌이키고 살지니라","reference":"에스겔 18:32","category":"$undefined"}],"bookSlug":"ezekiel"}]
