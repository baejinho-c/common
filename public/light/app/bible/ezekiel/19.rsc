2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":19,"verses":[{"id":"20883","book":"에스겔","book_name":"에스겔","chapter":19,"verse":1,"text":"너는 이스라엘 방백들을 위하여 애가를 지어","reference":"에스겔 19:1","category":"$undefined"},{"id":"20884","book":"에스겔","book_name":"에스겔","chapter":19,"verse":2,"text":"부르기를 네 어미는 무엇이냐 암사자라 그가 사자들 가운데 엎드리어 젊은 사자 중에서 그 새끼를 기르는데","reference":"에스겔 19:2","category":"$undefined"},{"id":"20885","book":"에스겔","book_name":"에스겔","chapter":19,"verse":3,"text":"그 새끼 하나를 키우매 젊은 사자가 되어 식물 움키기를 배워 사람을 삼키매","reference":"에스겔 19:3","category":"$undefined"},{"id":"20886","book":"에스겔","book_name":"에스겔","chapter":19,"verse":4,"text":"이방이 듣고 함정으로 그를 잡아 갈고리로 꿰어끌고 애굽 땅으로 간지라","reference":"에스겔 19:4","category":"$undefined"},{"id":"20887","book":"에스겔","book_name":"에스겔","chapter":19,"verse":5,"text":"암사자가 기다리다가 소망이 끊어진 줄을 알고 그 새끼 하나를 또 취하여 젊은 사자가 되게 하니","reference":"에스겔 19:5","category":"$undefined"},{"id":"20888","book":"에스겔","book_name":"에스겔","chapter":19,"verse":6,"text":"젊은 사자가 되매 여러 사자 가운데 왕래하며 식물 움키기를 배워 사람을 삼키며","reference":"에스겔 19:6","category":"$undefined"},{"id":"20889","book":"에스겔","book_name":"에스겔","chapter":19,"verse":7,"text":"그의 궁실들을 헐고 성읍들을 훼파하니 그 우는 소리로 인하여 땅과 그 가득한 것이 황무한지라","reference":"에스겔 19:7","category":"$undefined"},{"id":"20890","book":"에스겔","book_name":"에스겔","chapter":19,"verse":8,"text":"이방이 둘려 있는 지방에서 그를 치러 와서 그의 위에 그물을 치고 함정에 잡아","reference":"에스겔 19:8","category":"$undefined"},{"id":"20891","book":"에스겔","book_name":"에스겔","chapter":19,"verse":9,"text":"갈고리로 꿰고 철롱에 넣어 끌고 바벨론 왕에게 이르렀나니 그를 옥에 가두어서 그 소리로 다시 이스라엘 산에 들리지 않게 하려 함이니라","reference":"에스겔 19:9","category":"$undefined"},{"id":"20892","book":"에스겔","book_name":"에스겔","chapter":19,"verse":10,"text":"네 피의 어미는 물 가에 심긴 포도나무 같아서 물이 많으므로 실과가 많고 가지가 무성하며","reference":"에스겔 19:10","category":"$undefined"},{"id":"20893","book":"에스겔","book_name":"에스겔","chapter":19,"verse":11,"text":"그 가지들은 견강하여 권세 잡은 자의 홀이 될만한데 그 하나의 키가 굵은 가지 가운데서 높았으며 많은 가지 가운데서 뛰어나서 보이다가","reference":"에스겔 19:11","category":"$undefined"},{"id":"20894","book":"에스겔","book_name":"에스겔","chapter":19,"verse":12,"text":"분노 중에 뽑혀서 땅에 던짐을 당하매 그 실과는 동풍에 마르고 그 견강한 가지들은 꺾이고 말라 불에 탔더니","reference":"에스겔 19:12","category":"$undefined"},{"id":"20895","book":"에스겔","book_name":"에스겔","chapter":19,"verse":13,"text":"이제는 광야,메마르고 가물이 든 땅에 심긴바 되고","reference":"에스겔 19:13","category":"$undefined"},{"id":"20896","book":"에스겔","book_name":"에스겔","chapter":19,"verse":14,"text":"불이 그 가지 중 하나에서부터 나와서 그 실과를 태우니 권세 잡은 자의 홀이 될만한 견강한 가지가 없도다 이것이 애가라 후에도 애가가 되리라","reference":"에스겔 19:14","category":"$undefined"}],"bookSlug":"ezekiel"}]
