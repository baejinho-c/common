2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":20,"verses":[{"id":"20897","book":"에스겔","book_name":"에스겔","chapter":20,"verse":1,"text":"제 칠년 오월 십일에 이스라엘 장로 두어 사람이 여호와께 물으려고 와서 내 앞에 앉으니","reference":"에스겔 20:1","category":"$undefined"},{"id":"20898","book":"에스겔","book_name":"에스겔","chapter":20,"verse":2,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 20:2","category":"$undefined"},{"id":"20899","book":"에스겔","book_name":"에스겔","chapter":20,"verse":3,"text":"인자야 이스라엘 장로들에게 고하여 이르기를 주 여호와의 말씀에 너희가 내게 물으려고 왔느냐 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 너희가 내게 묻기를 내가 용납지 아니하리라 하셨다 하라","reference":"에스겔 20:3","category":"$undefined"},{"id":"20900","book":"에스겔","book_name":"에스겔","chapter":20,"verse":4,"text":"인자야 네가 그들을 국문하려느냐 네가 그들을 국문 하려하느냐 너는 그들로 그 열조의 가증한 일을 알게 하여","reference":"에스겔 20:4","category":"$undefined"},{"id":"20901","book":"에스겔","book_name":"에스겔","chapter":20,"verse":5,"text":"이르기를 주 여호와의 말씀에 옛날에 내가 이스라엘을 택하고 야곱 집의 후예를 향하여 맹세하고 애굽 땅에서 그들에게 나타나서 맹세하여 이르기를 나는 여호와 너희 하나님이라 하였었노라","reference":"에스겔 20:5","category":"$undefined"},{"id":"20902","book":"에스겔","book_name":"에스겔","chapter":20,"verse":6,"text":"그 날에 내가 그들에게 맹세하기를 애굽 땅에서 인도하여 내어서 그들을 위하여 찾아 두었던 땅 곧 젖과 꿀이 흐르는 땅이요 모든 땅 중의 아름다운 곳에 이르게 하리라 하고","reference":"에스겔 20:6","category":"$undefined"},{"id":"20903","book":"에스겔","book_name":"에스겔","chapter":20,"verse":7,"text":"또 그들에게 이르기를 너희는 눈을 드는바 가증한 것을 각기 버리고 애굽의 우상들로 스스로 더럽히지 말라 나는 여호와 너희 하나님이니라 하였으나","reference":"에스겔 20:7","category":"$undefined"},{"id":"20904","book":"에스겔","book_name":"에스겔","chapter":20,"verse":8,"text":"그들이 내게 패역하여 내 말을 즐겨 듣지 아니하고 그 눈을 드는 바 가증한 것을 각기 버리지 아니하며 애굽의 우상들을 떠나지 아니하므로 내가 말하기를 내가 애굽 땅에서 나의 분을 그들의 위에 쏟으며 노를 그들에게 이루리라 하였었노라","reference":"에스겔 20:8","category":"$undefined"},{"id":"20905","book":"에스겔","book_name":"에스겔","chapter":20,"verse":9,"text":"그러나 내가 그들의 거하는 이방인의 목전에서 그들에게 나타나서 그들을 애굽 땅에서 인도하여 내었었나니 이는 내 이름을 위 함이라 내 이름을 그 이방인의 목전에서 더럽히지 않으려 하여 행하였음이로라","reference":"에스겔 20:9","category":"$undefined"},{"id":"20906","book":"에스겔","book_name":"에스겔","chapter":20,"verse":10,"text":"그러므로 내가 그들로 애굽 땅에서 나와서 광야에 이르게 하고","reference":"에스겔 20:10","category":"$undefined"},{"id":"20907","book":"에스겔","book_name":"에스겔","chapter":20,"verse":11,"text":"사람이 준행하면 그로 인하여 삶을 얻을 내 율례를 주며 내 규례를 알게 하였고","reference":"에스겔 20:11","category":"$undefined"},{"id":"20908","book":"에스겔","book_name":"에스겔","chapter":20,"verse":12,"text":"또 나는 그들을 거룩하게 하는 여호와인 줄 알게 하려하여 내가 내 안식일을 주어 그들과 나 사이에 표징을 삼았었노라","reference":"에스겔 20:12","category":"$undefined"},{"id":"20909","book":"에스겔","book_name":"에스겔","chapter":20,"verse":13,"text":"그러나 이스라엘 족속이 광야에서 내게 패역하여 사람이 준행하면 그로 인하여 삶을 얻을 나의 율례를 준행치 아니하며 나의 규례를 멸시하였고 나의 안식일을 크게 더럽혔으므로 내가 이르기를 내가 내 분노를 광야에서 그들의 위에 쏟아 멸하리라 하였으나","reference":"에스겔 20:13","category":"$undefined"},{"id":"20910","book":"에스겔","book_name":"에스겔","chapter":20,"verse":14,"text":"내가 내 이름을 위하여 달리 행하였었나니 내가 그들을 인도하여 내는 것을 목도한 열국 앞에서 내 이름을 더럽히지 아니하려 하였음이로라","reference":"에스겔 20:14","category":"$undefined"},{"id":"20911","book":"에스겔","book_name":"에스겔","chapter":20,"verse":15,"text":"또 내가 광야에서 그들에게 맹세하기를 내가 그들에게 허한 땅 곧 젖과 꿀이 흐르는 땅이요 모든 땅 중의 아름다운 곳으로 그들을 인도하여 들이지 아니하리라 한 것은","reference":"에스겔 20:15","category":"$undefined"},{"id":"20912","book":"에스겔","book_name":"에스겔","chapter":20,"verse":16,"text":"그들이 마음으로 우상을 좇아 나의 규례를 업신여기며 나의 율례를 행치 아니하며 나의 안식일을 더럽혔음이니라","reference":"에스겔 20:16","category":"$undefined"},{"id":"20913","book":"에스겔","book_name":"에스겔","chapter":20,"verse":17,"text":"그러나 내가 그들을 아껴 보아 광야에서 멸하여 아주 없이 하지 아니하였었노라","reference":"에스겔 20:17","category":"$undefined"},{"id":"20914","book":"에스겔","book_name":"에스겔","chapter":20,"verse":18,"text":"내가 광야에서 그들의 자손에게 이르기를 너희 열조의 율례를 좇지 말며 그 규례를 지키지 말며 그 우상들로 스스로 더럽히지 말라","reference":"에스겔 20:18","category":"$undefined"},{"id":"20915","book":"에스겔","book_name":"에스겔","chapter":20,"verse":19,"text":"나는 여호와 너희 하나님이라 너희는 나의 율례를 좇으며 나의 규례를 지켜 행하고","reference":"에스겔 20:19","category":"$undefined"},{"id":"20916","book":"에스겔","book_name":"에스겔","chapter":20,"verse":20,"text":"또 나의 안식일을 거룩하게 할지어다 이것이 나와 너희 사이에 표징이 되어 너희로 내가 여호와 너희 하나님인 줄 알게 하리라 하였었노라","reference":"에스겔 20:20","category":"$undefined"},{"id":"20917","book":"에스겔","book_name":"에스겔","chapter":20,"verse":21,"text":"그러나 그 자손이 내게 패역하여 사람이 준행하면 그로 인하여 삶을 얻을 나의 율례를 좇지 아니하며 나의 규례를 지켜 행하지 아니하였고 나의 안식일을 더럽혔는지라 이에 내가 이르기를 내가 광야에서 내 분을 그들의 위에 쏟으며 내 노를 그들에게 이루리라 하였으나","reference":"에스겔 20:21","category":"$undefined"},{"id":"20918","book":"에스겔","book_name":"에스겔","chapter":20,"verse":22,"text":"내가 내 이름을 위하여 내 손을 금하고 달리 행하였었나니 내가 그들을 인도하여 내는 것을 목도한 열국 앞에서 내 이름을 더럽히지 아니하려 하였음이로다","reference":"에스겔 20:22","category":"$undefined"},{"id":"20919","book":"에스겔","book_name":"에스겔","chapter":20,"verse":23,"text":"또 내가 광야에서 그들에게 맹세하기를 내가 그들을 이방인 중에 흩으며 열방 중에 헤치리라 하였었나니","reference":"에스겔 20:23","category":"$undefined"},{"id":"20920","book":"에스겔","book_name":"에스겔","chapter":20,"verse":24,"text":"이는 그들이 나의 규례를 행치 아니하며 나의 율례를 멸시하며 내 안식일을 더럽히고 눈으로 그 열조의 우상들을 사모함이며","reference":"에스겔 20:24","category":"$undefined"},{"id":"20921","book":"에스겔","book_name":"에스겔","chapter":20,"verse":25,"text":"또 내가 그들에게 선치 못한 율례와 능히 살게 하지 못할 규례를 주었고","reference":"에스겔 20:25","category":"$undefined"},{"id":"20922","book":"에스겔","book_name":"에스겔","chapter":20,"verse":26,"text":"그들이 장자를 다 화제로 드리는 그 예물로 내가 그들을 더럽혔음은 그들로 멸망케 하여 나를 여호와인 줄 알게하려 하였음이니라","reference":"에스겔 20:26","category":"$undefined"},{"id":"20923","book":"에스겔","book_name":"에스겔","chapter":20,"verse":27,"text":"그런즉 인자야 이스라엘 족속에게 고하여 이르기를 주 여호와의 말씀에 너희 열조가 또 내게 범죄하여 나를 욕되게 하였느니라","reference":"에스겔 20:27","category":"$undefined"},{"id":"20924","book":"에스겔","book_name":"에스겔","chapter":20,"verse":28,"text":"내가 그들에게 주기로 맹세한 땅으로 그들을 인도하여 들였더니 그들이 모든 높은 산과 모든 무성한 나무를 보고 거기서 제사를 드리고 격노케 하는 제물을 올리며 거기서 또 분향하고 전제를 부어 드린지라","reference":"에스겔 20:28","category":"$undefined"},{"id":"20925","book":"에스겔","book_name":"에스겔","chapter":20,"verse":29,"text":"이에 내가 그들에게 이르기를 너희가 다니는 산당이 무엇이냐 하였노라 (그것을 오늘날까지 바마라 일컫느니라)","reference":"에스겔 20:29","category":"$undefined"},{"id":"20926","book":"에스겔","book_name":"에스겔","chapter":20,"verse":30,"text":"그러므로 너는 이스라엘 족속에게 이르기를 주 여호와의 말씀에 너희가 열조의 풍속을 따라 스스로 더럽히며 그 모든 가증한 것을 좇아 행음하느냐","reference":"에스겔 20:30","category":"$undefined"},{"id":"20927","book":"에스겔","book_name":"에스겔","chapter":20,"verse":31,"text":"너희가 또 너희 아들로 화제를 삼아 예물로 드려 오늘날까지 우상들로 스스로 더럽히느냐 이스라엘 족속아 너희가 내게 묻기를 내가 용납하겠느냐 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 너희가 내게 묻기를 내가 용납지 아니하리라","reference":"에스겔 20:31","category":"$undefined"},{"id":"20928","book":"에스겔","book_name":"에스겔","chapter":20,"verse":32,"text":"너희가 스스로 이르기를 우리가 이방인 곧 열국 족속 같이 되어서 목석을 숭배하리라 하거니와 너희 마음에 품은 것을 결코 이루지 못하리라","reference":"에스겔 20:32","category":"$undefined"},{"id":"20929","book":"에스겔","book_name":"에스겔","chapter":20,"verse":33,"text":"나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 내가 능한 손과 편 팔로 분노를 쏟아 너희를 단정코 다스릴지라","reference":"에스겔 20:33","category":"$undefined"},{"id":"20930","book":"에스겔","book_name":"에스겔","chapter":20,"verse":34,"text":"능한 손과 편 팔로 분노를 쏟아 너희를 열국 중에서 나오게 하며 너희의 흩어진 열방 중에서 모아내고","reference":"에스겔 20:34","category":"$undefined"},{"id":"20931","book":"에스겔","book_name":"에스겔","chapter":20,"verse":35,"text":"너희를 인도하여 열국 광야에 이르러 거기서 너희를 대면하여 국문하되","reference":"에스겔 20:35","category":"$undefined"},{"id":"20932","book":"에스겔","book_name":"에스겔","chapter":20,"verse":36,"text":"내가 애굽 땅 광야에서 너희 열조를 국문한 것 같이 너희를 국문하리라 나 주 여호와의 말이니라","reference":"에스겔 20:36","category":"$undefined"},{"id":"20933","book":"에스겔","book_name":"에스겔","chapter":20,"verse":37,"text":"내가 너희를 막대기 아래로 지나게 하며 언약의 줄로 매려니와","reference":"에스겔 20:37","category":"$undefined"},{"id":"20934","book":"에스겔","book_name":"에스겔","chapter":20,"verse":38,"text":"너희 가운데서 패역한 자와 내게 범죄한 자를 모두 제하여 버릴지라 그들을 그 우거하던 땅에서는 나오게 하여도 이스라엘 땅에는 들어가지 못하게 하리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 20:38","category":"$undefined"},{"id":"20935","book":"에스겔","book_name":"에스겔","chapter":20,"verse":39,"text":"나 주 여호와가 말하노라 이스라엘 족속아 너희가 내 말을 듣지 아니하려거든 가서 각각 그 우상을 섬기고 이 후에도 그리하려무나마는 다시는 너희 예물과 너희 우상들로 내 거룩한 이름을 더럽히지 말지니라","reference":"에스겔 20:39","category":"$undefined"},{"id":"20936","book":"에스겔","book_name":"에스겔","chapter":20,"verse":40,"text":"나 주 여호와가 말하노라 이스라엘 온 족속이 그 땅에 있어서 내 거룩한 산 곧 이스라엘의 높은 산에서 다 나를 섬기리니 거기서 내가 그들을 기쁘게 받을지라 거기서 너희 예물과 너희 천신하는 첫 열매와 너희 모든 성물을 요구하리라","reference":"에스겔 20:40","category":"$undefined"},{"id":"20937","book":"에스겔","book_name":"에스겔","chapter":20,"verse":41,"text":"내가 너희를 인도하여 열국 중에서 나오게 하고 너희의 흩어진 열방 중에서 모아 낼 때에 내가 너희를 향기로 받고 내가 또 너희로 말미암아 내 거룩함을 열국의 목전에서 나타낼 것이며","reference":"에스겔 20:41","category":"$undefined"},{"id":"20938","book":"에스겔","book_name":"에스겔","chapter":20,"verse":42,"text":"내가 너희 열조에게 주기로 맹세한 땅 곧 이스라엘 땅으로 너희를 인도하여 들일 때에 너희가 나를 여호와인줄 알고","reference":"에스겔 20:42","category":"$undefined"},{"id":"20939","book":"에스겔","book_name":"에스겔","chapter":20,"verse":43,"text":"거기서 너희의 길과 스스로 더럽힌 모든 행위를 기억하고 이미 행한 모든 악을 인하여 스스로 미워하리라","reference":"에스겔 20:43","category":"$undefined"},{"id":"20940","book":"에스겔","book_name":"에스겔","chapter":20,"verse":44,"text":"이스라엘 족속아 내가 너희의 악한 길과 더러운 행위대로 하지 아니하고 내 이름을 위하여 행한 후에야 너희가 나를 여호와인 줄 알리라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 20:44","category":"$undefined"},{"id":"20941","book":"에스겔","book_name":"에스겔","chapter":20,"verse":45,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 20:45","category":"$undefined"},{"id":"20942","book":"에스겔","book_name":"에스겔","chapter":20,"verse":46,"text":"인자야 너는 얼굴을 남으로 향하라 남으로 향하여 소리내어 남방들의 삼림을 쳐서 예언하라","reference":"에스겔 20:46","category":"$undefined"},{"id":"20943","book":"에스겔","book_name":"에스겔","chapter":20,"verse":47,"text":"남방 삼림에게 이르기를 여호와의 말씀을 들을지어다 주 여호와의 말씀에 내가 너의 가운데 불을 일으켜 모든 푸른 나무와 모든 마른 나무를 멸하리니 맹렬한 불꽃이 꺼지지 아니하고 남에서 북까지 모든 얼굴이 그슬릴지라","reference":"에스겔 20:47","category":"$undefined"},{"id":"20944","book":"에스겔","book_name":"에스겔","chapter":20,"verse":48,"text":"무릇 혈기 있는자는 나 여호와가 그 불을 일으킨 줄을 알리니 그것이 꺼지지 아니하리라 하셨다 하라 하시기로","reference":"에스겔 20:48","category":"$undefined"},{"id":"20945","book":"에스겔","book_name":"에스겔","chapter":20,"verse":49,"text":"내가 가로되 오호라 주 여호와여 그들이 나를 가리켜 말하기를 그는 비유로 말하는 자가 아니냐 하나이다 하니라","reference":"에스겔 20:49","category":"$undefined"}],"bookSlug":"ezekiel"}]
