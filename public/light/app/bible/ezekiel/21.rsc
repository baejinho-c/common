2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":21,"verses":[{"id":"20946","book":"에스겔","book_name":"에스겔","chapter":21,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 21:1","category":"$undefined"},{"id":"20947","book":"에스겔","book_name":"에스겔","chapter":21,"verse":2,"text":"인자야 너는 얼굴을 예루살렘으로 향하며 성소를 향하여 소리내어 이스라엘 땅을 쳐서 예언하라","reference":"에스겔 21:2","category":"$undefined"},{"id":"20948","book":"에스겔","book_name":"에스겔","chapter":21,"verse":3,"text":"이스라엘 땅에게 이르기를 여호와의 말씀에 내가 너를 대적하여 내 칼을 집에서 빼어 의인과 악인을 네게서 끊을지라","reference":"에스겔 21:3","category":"$undefined"},{"id":"20949","book":"에스겔","book_name":"에스겔","chapter":21,"verse":4,"text":"내가 의인과 악인을 네게서 끊을터이므로 내 칼을 집에서 빼어 무릇 혈기 있는 자를 남에서 북까지 치리니","reference":"에스겔 21:4","category":"$undefined"},{"id":"20950","book":"에스겔","book_name":"에스겔","chapter":21,"verse":5,"text":"무릇 혈기 있는 자는 나 여호와가 내 칼을 집에서 빼어 낸 줄을 알지라 칼이 다시 꽂혀지지 아니하리라 하셨다 하라","reference":"에스겔 21:5","category":"$undefined"},{"id":"20951","book":"에스겔","book_name":"에스겔","chapter":21,"verse":6,"text":"인자야 너는 탄식하되 허리가 끊어지는 듯이 그들의 목전에서 슬피 탄식하라","reference":"에스겔 21:6","category":"$undefined"},{"id":"20952","book":"에스겔","book_name":"에스겔","chapter":21,"verse":7,"text":"그들이 네게 묻기를 네가 어찌하여 탄식하느냐 ? 하거든 대답하기를 소문을 인함이라 재앙이 오나니 각 마음이 녹으며 모든 손이 약하여지며 각 영이 쇠하며 모든 무릎이 물과 같이 약하리라 보라 재앙이 오나니 정녕 이루리라 나 주 여호와의 말이니라 하라","reference":"에스겔 21:7","category":"$undefined"},{"id":"20953","book":"에스겔","book_name":"에스겔","chapter":21,"verse":8,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 21:8","category":"$undefined"},{"id":"20954","book":"에스겔","book_name":"에스겔","chapter":21,"verse":9,"text":"인자야 너는 예언하여 이르기를 여호와의 말씀에 칼이여, 칼이여 날카롭고도 마광되었도다","reference":"에스겔 21:9","category":"$undefined"},{"id":"20955","book":"에스겔","book_name":"에스겔","chapter":21,"verse":10,"text":"그 칼이 날카로움은 살륙을 위함이요 마광됨은 번개 같이 되기 위함이니 우리가 즐거워하겠느냐 내 아들의 홀이 모든 나무를 업신여기는도다","reference":"에스겔 21:10","category":"$undefined"},{"id":"20956","book":"에스겔","book_name":"에스겔","chapter":21,"verse":11,"text":"그 칼이 손에 잡아 쓸만하도록 마광되되 살륙하는 자의 손에 붙이기 위하여 날카롭고도 마광되었도다 하셨다 하라","reference":"에스겔 21:11","category":"$undefined"},{"id":"20957","book":"에스겔","book_name":"에스겔","chapter":21,"verse":12,"text":"인자야 너는 부르짖어 슬피 울지어다 이것이 내 백성에게 임하며 이스라엘 모든 방백에게 임함이로다 그들과 내 백성이 함께 칼에 붙인바 되었으니 너는 네 넓적다리를 칠지어다","reference":"에스겔 21:12","category":"$undefined"},{"id":"20958","book":"에스겔","book_name":"에스겔","chapter":21,"verse":13,"text":"이것이 시험이라 만일 업신여기는 홀이 없어지면 어찌할꼬 나 주 여호와의 말이니라","reference":"에스겔 21:13","category":"$undefined"},{"id":"20959","book":"에스겔","book_name":"에스겔","chapter":21,"verse":14,"text":"그러므로 인자야 너는 예언하며 손뼉을 쳐서 칼로 세 번 거듭 씌우게 하라 이 칼은 중상케 하는 칼이라 밀실에 들어가서 대인을 중상케 하는 칼이로다","reference":"에스겔 21:14","category":"$undefined"},{"id":"20960","book":"에스겔","book_name":"에스겔","chapter":21,"verse":15,"text":"내가 그들로 낙담하여 많이 엎드러지게 하려고 그 모든 성문을 향하여 번쩍번쩍하는 칼을 베풀었도다 오호라 그 칼이 번개 같고 살륙을 위하여 날카로왔도다","reference":"에스겔 21:15","category":"$undefined"},{"id":"20961","book":"에스겔","book_name":"에스겔","chapter":21,"verse":16,"text":"칼아 모이라 우향하라 항오를 차리라 좌향하라 향한대로 가라","reference":"에스겔 21:16","category":"$undefined"},{"id":"20962","book":"에스겔","book_name":"에스겔","chapter":21,"verse":17,"text":"나도 내 손뼉을 치며 내 분을 다 하리로다 나 여호와의 말이니라","reference":"에스겔 21:17","category":"$undefined"},{"id":"20963","book":"에스겔","book_name":"에스겔","chapter":21,"verse":18,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 21:18","category":"$undefined"},{"id":"20964","book":"에스겔","book_name":"에스겔","chapter":21,"verse":19,"text":"인자야 너는 바벨론 왕의 칼이 올 두 길을 한 땅에서 나오도록 그리되 곧 성으로 들어가는 길 머리에다가 길이 나뉘는 지시표를 하여","reference":"에스겔 21:19","category":"$undefined"},{"id":"20965","book":"에스겔","book_name":"에스겔","chapter":21,"verse":20,"text":"칼이 암몬 족속의 랍바에 이르는 길과 유다 견고한 성 예루살렘에 이르는 길을 그리라","reference":"에스겔 21:20","category":"$undefined"},{"id":"20966","book":"에스겔","book_name":"에스겔","chapter":21,"verse":21,"text":"바벨론 왕이 갈랫길 곧 두 길 머리에 서서 점을 치되 살들을 흔들어 우상에게 묻고 희생의 간을 살펴서","reference":"에스겔 21:21","category":"$undefined"},{"id":"20967","book":"에스겔","book_name":"에스겔","chapter":21,"verse":22,"text":"오른손에 예루살렘으로 갈 점괘를 얻었으므로 공성퇴를 베풀며 입을 벌리고 살륙하며 소리를 높여 외치며 성문을 향하여 공성퇴를 베풀고 토성을 쌓고 운제를 세우게 되었나니","reference":"에스겔 21:22","category":"$undefined"},{"id":"20968","book":"에스겔","book_name":"에스겔","chapter":21,"verse":23,"text":"전에 그들에게 맹약한 자들은 그것을 헛점으로 여길 것이나 바벨론 왕은 그 죄악을 기억하고 그 무리를 잡으리라","reference":"에스겔 21:23","category":"$undefined"},{"id":"20969","book":"에스겔","book_name":"에스겔","chapter":21,"verse":24,"text":"그러므로 나 주 여호와가 말하노라 너희의 악이 기억을 일으키며 너희의 건과가 드러나며 너희 모든 행위의 죄가 나타났도다 너희가 기억한바 되었은즉 그 손에 잡히리라","reference":"에스겔 21:24","category":"$undefined"},{"id":"20970","book":"에스겔","book_name":"에스겔","chapter":21,"verse":25,"text":"너 극악하여 중상을 당할 이스라엘 왕아 네 날이 이르렀나니 곧 죄악의 끝 때니라","reference":"에스겔 21:25","category":"$undefined"},{"id":"20971","book":"에스겔","book_name":"에스겔","chapter":21,"verse":26,"text":"나 주 여호와가 말하노라 관을 제하며 면류관을 벗길지라 그대로 두지 못하리니 낮은 자를 높이고 높은 자를 낮출 것이니라","reference":"에스겔 21:26","category":"$undefined"},{"id":"20972","book":"에스겔","book_name":"에스겔","chapter":21,"verse":27,"text":"내가 엎드러뜨리고, 엎드러뜨리고, 엎드러뜨리려니와 이것도 다시 있지 못하리라 마땅히 얻을 자가 이르면 그에게 주리라","reference":"에스겔 21:27","category":"$undefined"},{"id":"20973","book":"에스겔","book_name":"에스겔","chapter":21,"verse":28,"text":"인자야 주 여호와께서 암몬 족속과 그 능욕에 대하여 말씀하셨다고 너는 예언하라 너는 이르기를 칼이 뽑히도다 칼이 뽑히도다 살륙하며 멸절하며 번개 같이 되기 위하여 마광되었도다","reference":"에스겔 21:28","category":"$undefined"},{"id":"20974","book":"에스겔","book_name":"에스겔","chapter":21,"verse":29,"text":"네게 대하여 허무한 것을 보며 네게 대하여 거짓 복술을 하는 자가 너를 중상을 당한 악인의 목 위에 두리니 이는 그의 날 곧 죄악의 끝 때가 이름이로다","reference":"에스겔 21:29","category":"$undefined"},{"id":"20975","book":"에스겔","book_name":"에스겔","chapter":21,"verse":30,"text":"그러나 칼을 그 집에 꽂을지어다 네가 지음을 받은 곳에서 너의 생장한 땅에서 내가 너를 국문하리로다","reference":"에스겔 21:30","category":"$undefined"},{"id":"20976","book":"에스겔","book_name":"에스겔","chapter":21,"verse":31,"text":"내가 내 분노를 네게 쏟으며 내 진노의 불을 네게 불고 너를 짐승 같은 자 곧 멸하기에 익숙한 자의 손에 붙이리로다","reference":"에스겔 21:31","category":"$undefined"},{"id":"20977","book":"에스겔","book_name":"에스겔","chapter":21,"verse":32,"text":"네가 불에 섶과 같이 될 것이며 네 피가 나라 가운데 있을 것이며 네가 다시 기억되지 못할 것이니 나 여호와가 말하였음이니라 하라","reference":"에스겔 21:32","category":"$undefined"}],"bookSlug":"ezekiel"}]
