2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":22,"verses":[{"id":"20978","book":"에스겔","book_name":"에스겔","chapter":22,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 22:1","category":"$undefined"},{"id":"20979","book":"에스겔","book_name":"에스겔","chapter":22,"verse":2,"text":"인자야 네가 국문하려느냐 ? 이 피 흘린 성읍을 국문하려느냐 ? 그리하거든 자기의 모든 가증한 일을 그들로 알게 하라","reference":"에스겔 22:2","category":"$undefined"},{"id":"20980","book":"에스겔","book_name":"에스겔","chapter":22,"verse":3,"text":"너는 이르기를 주 여호와의 말씀에 자기 가운데 피를 흘려 벌 받을 때로 이르게 하며 우상을 만들어 스스로 더럽히는 성아","reference":"에스겔 22:3","category":"$undefined"},{"id":"20981","book":"에스겔","book_name":"에스겔","chapter":22,"verse":4,"text":"네가 흘린 피로 인하여 죄가 있고 네가 만든 우상으로 인하여 스스로 더럽혔으니 네 날이 가까왔고 네 연한이 찼도다 그러므로 내가 너로 이방의 능욕을 받으며 만국의 조롱거리가 되게 하였노라","reference":"에스겔 22:4","category":"$undefined"},{"id":"20982","book":"에스겔","book_name":"에스겔","chapter":22,"verse":5,"text":"너 이름이 더럽고 어지러움이 많은 자여 가까운 자나 먼 자나 다 너를 조롱하리라","reference":"에스겔 22:5","category":"$undefined"},{"id":"20983","book":"에스겔","book_name":"에스겔","chapter":22,"verse":6,"text":"이스라엘 모든 방백은 각기 권세대로 피를 흘리려고 네 가운데 있었도다","reference":"에스겔 22:6","category":"$undefined"},{"id":"20984","book":"에스겔","book_name":"에스겔","chapter":22,"verse":7,"text":"그들이 네 가운데서 부모를 업신여겼으며 네 가운데서 나그네를 학대하였으며 네 가운데서 고아와 과부를 해하였도다","reference":"에스겔 22:7","category":"$undefined"},{"id":"20985","book":"에스겔","book_name":"에스겔","chapter":22,"verse":8,"text":"너는 나의 성물들을 업신여겼으며 나의 안식일을 더럽혔으며","reference":"에스겔 22:8","category":"$undefined"},{"id":"20986","book":"에스겔","book_name":"에스겔","chapter":22,"verse":9,"text":"네 가운데 피를 흘리려고 이간을 붙이는 자도 있었으며 네 가운데 산 위에서 제물을 먹는 자도 있었으며 네 가운데 음란하는 자도 있었으며","reference":"에스겔 22:9","category":"$undefined"},{"id":"20987","book":"에스겔","book_name":"에스겔","chapter":22,"verse":10,"text":"네 가운데 자기 아비의 하체를 드러내는 자도 있었으며 네 가운데 월경하는 부정한 여인에게 구합하는 자도 있었으며","reference":"에스겔 22:10","category":"$undefined"},{"id":"20988","book":"에스겔","book_name":"에스겔","chapter":22,"verse":11,"text":"혹은 그 이웃의 아내와 가증한 일을 행하였으며 혹은 그 며느리를 더럽혀 음행하였으며 네 가운데 혹은 그 자매 곧 아비의 딸과 구합하였으며","reference":"에스겔 22:11","category":"$undefined"},{"id":"20989","book":"에스겔","book_name":"에스겔","chapter":22,"verse":12,"text":"네 가운데 피를 흘리려고 뇌물을 받는 자도 있었으며 네가 변전과 이식을 취하였으며 이를 탐하여 이웃에게 토색하였으며 나를 잊어버렸도다 나 주 여호와의 말이니라","reference":"에스겔 22:12","category":"$undefined"},{"id":"20990","book":"에스겔","book_name":"에스겔","chapter":22,"verse":13,"text":"너의 불의를 행하여 이를 얻은 일과 네 가운데 피 흘린 일을 인하여 내가 손뼉을 쳤나니","reference":"에스겔 22:13","category":"$undefined"},{"id":"20991","book":"에스겔","book_name":"에스겔","chapter":22,"verse":14,"text":"내가 네게 보응하는 날에 네 마음이 견디겠느냐 네 손이 힘이 있겠느냐 나 여호와가 말하였으니 이룰지라","reference":"에스겔 22:14","category":"$undefined"},{"id":"20992","book":"에스겔","book_name":"에스겔","chapter":22,"verse":15,"text":"내가 너를 열국 중에 흩으며 각 나라에 헤치고 너의 더러운 것을 네 가운데서 멸하리라","reference":"에스겔 22:15","category":"$undefined"},{"id":"20993","book":"에스겔","book_name":"에스겔","chapter":22,"verse":16,"text":"네가 자기 까닭으로 열국의 목전에서 수치를 당하리니 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 22:16","category":"$undefined"},{"id":"20994","book":"에스겔","book_name":"에스겔","chapter":22,"verse":17,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 22:17","category":"$undefined"},{"id":"20995","book":"에스겔","book_name":"에스겔","chapter":22,"verse":18,"text":"인자야 이스라엘 족속이 내게 찌끼가 되었나니 곧 풀무 가운데 있는 놋이나 상납이나 철이나 납이며 은의 찌끼로다","reference":"에스겔 22:18","category":"$undefined"},{"id":"20996","book":"에스겔","book_name":"에스겔","chapter":22,"verse":19,"text":"그러므로 나 주 여호와가 말하노라 너희가 다 찌끼가 되었은즉 내가 너희를 예루살렘 가운데로 모으고","reference":"에스겔 22:19","category":"$undefined"},{"id":"20997","book":"에스겔","book_name":"에스겔","chapter":22,"verse":20,"text":"사람이 은이나, 놋이나, 철이나, 납이나, 상납이나 모아서 풀무 속에 넣고 불을 불어 녹이는 것 같이 내가 노와 분으로 너희를 모아 거기 두고 녹일지라","reference":"에스겔 22:20","category":"$undefined"},{"id":"20998","book":"에스겔","book_name":"에스겔","chapter":22,"verse":21,"text":"내가 너희를 모으고 내 분노의 불을 너희에게 분즉 너희가 그 가운데서 녹되","reference":"에스겔 22:21","category":"$undefined"},{"id":"20999","book":"에스겔","book_name":"에스겔","chapter":22,"verse":22,"text":"은이 풀무 가운데서 녹는 것 같이 너희가 그 가운데서 녹으리니 나 여호와가 분노를 너희 위에 쏟은 줄을 너희가 알리라","reference":"에스겔 22:22","category":"$undefined"},{"id":"21000","book":"에스겔","book_name":"에스겔","chapter":22,"verse":23,"text":"여호와의 말씀이 네게 임하여 가라사대","reference":"에스겔 22:23","category":"$undefined"},{"id":"21001","book":"에스겔","book_name":"에스겔","chapter":22,"verse":24,"text":"인자야 너는 그에게 이르기를 너는 정결함을 얻지 못한 땅이요 진노의 날에 비를 얻지 못한 땅이로다 하라","reference":"에스겔 22:24","category":"$undefined"},{"id":"21002","book":"에스겔","book_name":"에스겔","chapter":22,"verse":25,"text":"그 가운데서 선지자들의 배역함이 우는 사자가 식물을 움킴 같았도다 그들이 사람의 영혼을 삼켰으며 전재와 보물을 탈취하며 과부로 그 가운데 많게 하였으며","reference":"에스겔 22:25","category":"$undefined"},{"id":"21003","book":"에스겔","book_name":"에스겔","chapter":22,"verse":26,"text":"그 제사장들은 내 율법을 범하였으며 나의 성물을 더럽혔으며 거룩함과 속된 것을 분변치 아니하였으며 부정함과 정한 것을 사람으로 분변하게 하지 아니하였으며 그 눈을 가리워 나의 안식일을 보지 아니하였으므로 내가 그 가운데서 더럽힘을 받았느니라","reference":"에스겔 22:26","category":"$undefined"},{"id":"21004","book":"에스겔","book_name":"에스겔","chapter":22,"verse":27,"text":"그 가운데 그 방백들은 식물을 삼키는 이리 같아서 불의의 이를 취하려고 피를 흘려 영혼을 멸하거늘","reference":"에스겔 22:27","category":"$undefined"},{"id":"21005","book":"에스겔","book_name":"에스겔","chapter":22,"verse":28,"text":"그 선지자들이 그들을 위하여 회를 칠하고 스스로 허탄한 이상을 보며 거짓 복술을 행하며 여호와가 말하지 아니하였어도 주 여호와의 말씀이라 하였으며","reference":"에스겔 22:28","category":"$undefined"},{"id":"21006","book":"에스겔","book_name":"에스겔","chapter":22,"verse":29,"text":"이 땅 백성은 강포하며 늑탈하여 가난하고 궁핍한 자를 압제하였으며 우거한 자를 불법하게 학대하였으므로","reference":"에스겔 22:29","category":"$undefined"},{"id":"21007","book":"에스겔","book_name":"에스겔","chapter":22,"verse":30,"text":"이 땅을 위하여 성을 쌓으며 성 무너진 데를 막아서서 나로 멸하지 못하게 할 사람을 내가 그 가운데서 찾다가 얻지 못한고로","reference":"에스겔 22:30","category":"$undefined"},{"id":"21008","book":"에스겔","book_name":"에스겔","chapter":22,"verse":31,"text":"내가 내 분으로 그 위에 쏟으며 내 진노의 불로 멸하여 그 행위대로 그 머리에 보응하였느니라 나 주 여호와의 말이니라","reference":"에스겔 22:31","category":"$undefined"}],"bookSlug":"ezekiel"}]
