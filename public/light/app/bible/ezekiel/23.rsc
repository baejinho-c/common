2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":23,"verses":[{"id":"21009","book":"에스겔","book_name":"에스겔","chapter":23,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 23:1","category":"$undefined"},{"id":"21010","book":"에스겔","book_name":"에스겔","chapter":23,"verse":2,"text":"인자야 두 여인이 있었으니 한 어미의 딸이라","reference":"에스겔 23:2","category":"$undefined"},{"id":"21011","book":"에스겔","book_name":"에스겔","chapter":23,"verse":3,"text":"그들이 애굽에서 행음하되 어렸을 때에 행음하여 그들의 유방이 눌리며 그 처녀의 가슴이 어루만진 바 되었었나니","reference":"에스겔 23:3","category":"$undefined"},{"id":"21012","book":"에스겔","book_name":"에스겔","chapter":23,"verse":4,"text":"그 이름이 형은 오홀라요 아우는 오홀리바라 그들이 내게 속하여 자녀를 낳았나니 그 이름으로 말하면 오홀라는 사마리아요 오홀리바는 예루살렘이니라","reference":"에스겔 23:4","category":"$undefined"},{"id":"21013","book":"에스겔","book_name":"에스겔","chapter":23,"verse":5,"text":"오홀라가 내게 속하였을 때에 행음하여 그 연애하는 자 곧 그 이웃 앗수르 사람을 사모하였나니","reference":"에스겔 23:5","category":"$undefined"},{"id":"21014","book":"에스겔","book_name":"에스겔","chapter":23,"verse":6,"text":"그들은 다 자색 옷을 입은 방백과 감독이요 준수한 소년,말 타는 자들이라","reference":"에스겔 23:6","category":"$undefined"},{"id":"21015","book":"에스겔","book_name":"에스겔","chapter":23,"verse":7,"text":"그가 앗수르 중에 잘 생긴 그 모든 자들과 행음하고 누구를 연애하든지 그들의 모든 우상으로 스스로 더럽혔으며","reference":"에스겔 23:7","category":"$undefined"},{"id":"21016","book":"에스겔","book_name":"에스겔","chapter":23,"verse":8,"text":"그가 젊었을 때에 애굽사람과 동침하매 그 처녀의 가슴이 어루만진바 되며 그 몸에 음란을 쏟음을 당한바 되었더니 그가 그 때부터 행음함을 마지 아니하였느니라","reference":"에스겔 23:8","category":"$undefined"},{"id":"21017","book":"에스겔","book_name":"에스겔","chapter":23,"verse":9,"text":"그러므로 내가 그를 그 정든 자 곧 그 연애하는 앗수르 사람의 손에 붙였더니","reference":"에스겔 23:9","category":"$undefined"},{"id":"21018","book":"에스겔","book_name":"에스겔","chapter":23,"verse":10,"text":"그들이 그 하체를 드러내고 그 자녀를 빼앗으며 칼로 그를 죽여 그 누명을 여자에게 드러내었나니 이는 그들이 그에게 심문을 행함이니라","reference":"에스겔 23:10","category":"$undefined"},{"id":"21019","book":"에스겔","book_name":"에스겔","chapter":23,"verse":11,"text":"그 아우 오홀리바가 이것을 보고도 그 형보다 음욕을 더하며 그 형의 간음함보다 그 간음이 더 심하므로 그 형보다 더 부패하여 졌느니라","reference":"에스겔 23:11","category":"$undefined"},{"id":"21020","book":"에스겔","book_name":"에스겔","chapter":23,"verse":12,"text":"그가 그 이웃 앗수르 사람을 연애하였나니 그들은 화려한 의복을 입은 방백과 감독이요 말타는 자들과 준수한 소년이었느니라","reference":"에스겔 23:12","category":"$undefined"},{"id":"21021","book":"에스겔","book_name":"에스겔","chapter":23,"verse":13,"text":"그 두 여인이 한 길로 행하므로 그도 더러워졌음을 내가 보았노라","reference":"에스겔 23:13","category":"$undefined"},{"id":"21022","book":"에스겔","book_name":"에스겔","chapter":23,"verse":14,"text":"그가 음행을 더하였음은 붉은 것으로 벽에 그린 사람의 형상 곧 갈대아 사람의 형상을 보았음이니","reference":"에스겔 23:14","category":"$undefined"},{"id":"21023","book":"에스겔","book_name":"에스겔","chapter":23,"verse":15,"text":"그 형상은 허리를 띠로 동이고 머리를 긴 수건으로 쌌으며 용모는 다 존귀한 자 곧 그 고토 갈대아 바벨론 사람 같은 것이라","reference":"에스겔 23:15","category":"$undefined"},{"id":"21024","book":"에스겔","book_name":"에스겔","chapter":23,"verse":16,"text":"그가 보고 곧 연애하여 사자를 갈대아 그들에게로 보내매","reference":"에스겔 23:16","category":"$undefined"},{"id":"21025","book":"에스겔","book_name":"에스겔","chapter":23,"verse":17,"text":"바벨론 사람이 나아와 연애하는 침상에 올라 음란으로 그를 더럽히매 그가 더럽힘을 입은 후에 그들을 싫어하는 마음이 생겼느니라","reference":"에스겔 23:17","category":"$undefined"},{"id":"21026","book":"에스겔","book_name":"에스겔","chapter":23,"verse":18,"text":"그가 이와 같이 그 음행을 나타내며 그 하체를 드러내므로 내 마음이 그 형을 싫어한 것 같이 그를 싫어하였으나","reference":"에스겔 23:18","category":"$undefined"},{"id":"21027","book":"에스겔","book_name":"에스겔","chapter":23,"verse":19,"text":"그가 그 음행을 더하여 그 젊었을 때 곧 애굽 땅에서 음행하던 때를 생각하고","reference":"에스겔 23:19","category":"$undefined"},{"id":"21028","book":"에스겔","book_name":"에스겔","chapter":23,"verse":20,"text":"그 하체는 나귀 같고 그 정수는 말 같은 음란한 간부를 연애하였도다","reference":"에스겔 23:20","category":"$undefined"},{"id":"21029","book":"에스겔","book_name":"에스겔","chapter":23,"verse":21,"text":"네가 젊었을 때에 행음하여 애굽 사람에게 네 가슴과 유방이 어루만진바 되었던 것을 오히려 생각하도다","reference":"에스겔 23:21","category":"$undefined"},{"id":"21030","book":"에스겔","book_name":"에스겔","chapter":23,"verse":22,"text":"그러므로 오홀리바야 나 주 여호와가 말하노라 내가 너의 연애하다가 싫어하던 자들을 격동시켜서 그들로 사방에서 와서 너를 치게 하리니","reference":"에스겔 23:22","category":"$undefined"},{"id":"21031","book":"에스겔","book_name":"에스겔","chapter":23,"verse":23,"text":"그들은 바벨론 사람과 갈대아 모든 무리 브곳과 소아와 고아 사람과 또 그와 함께 한 모든 앗수르 사람 곧 준수한 소년이며 다 방백과 감독이며 귀인과 유명한 자, 다 말 타는 자들이라","reference":"에스겔 23:23","category":"$undefined"},{"id":"21032","book":"에스겔","book_name":"에스겔","chapter":23,"verse":24,"text":"그들이 병기와 병거와 수레와 크고 작은 방패를 이끌고 투구 쓴 군대를 거느리고 치러 와서 너를 에워쌀지라 내가 심문권을 그들에게 맡긴즉 그들이 그 심문권대로 너를 심문하리라","reference":"에스겔 23:24","category":"$undefined"},{"id":"21033","book":"에스겔","book_name":"에스겔","chapter":23,"verse":25,"text":"내가 너를 향하여 투기를 발하리니 그들이 분노로 네게 행하여 네 코와 귀를 깎아버리고 남은 자를 칼로 엎드러뜨리며 네 자녀를 빼앗고 그 남은 자를 불에 사르며","reference":"에스겔 23:25","category":"$undefined"},{"id":"21034","book":"에스겔","book_name":"에스겔","chapter":23,"verse":26,"text":"또 네 옷을 벗기며 네 장식품을 빼앗을지라","reference":"에스겔 23:26","category":"$undefined"},{"id":"21035","book":"에스겔","book_name":"에스겔","chapter":23,"verse":27,"text":"이와 같이 내가 네 음란과 애굽 땅에서부터 음행하던 것을 그치게 하여 너로 그들을 향하여 눈을 들지도 못하게 하며 다시는 애굽을 기억하지도 못하게 하리라","reference":"에스겔 23:27","category":"$undefined"},{"id":"21036","book":"에스겔","book_name":"에스겔","chapter":23,"verse":28,"text":"나 주 여호와가 말하노라 내가 너의 미워하는 자와 네 마음에 싫어하는 자의 손에 너를 붙이리니","reference":"에스겔 23:28","category":"$undefined"},{"id":"21037","book":"에스겔","book_name":"에스겔","chapter":23,"verse":29,"text":"그들이 미워하는 마음으로 네게 행하여 네 모든 수고한 것을 빼앗고 너를 벌거벗겨 적신으로 두어서 네 음행의 벗은 몸 곧 네 음란하며 음행하던 것을 드러낼 것이라","reference":"에스겔 23:29","category":"$undefined"},{"id":"21038","book":"에스겔","book_name":"에스겔","chapter":23,"verse":30,"text":"네가 이같이 당할 것은 네가 음란히 이방을 좇고 그 우상들로 더럽혔음이로다","reference":"에스겔 23:30","category":"$undefined"},{"id":"21039","book":"에스겔","book_name":"에스겔","chapter":23,"verse":31,"text":"네가 네 형의 길로 행하였은즉 내가 그의 잔을 네 손에 주리라","reference":"에스겔 23:31","category":"$undefined"},{"id":"21040","book":"에스겔","book_name":"에스겔","chapter":23,"verse":32,"text":"나 주 여호와가 말하노라 깊고 크고 가득히 담긴 네 형의 잔을 네가 마시고 비소와 조롱을 당하리라","reference":"에스겔 23:32","category":"$undefined"},{"id":"21041","book":"에스겔","book_name":"에스겔","chapter":23,"verse":33,"text":"네가 네 형 사마리아의 잔 곧 놀람과 패망의 잔에 넘치게 취하고 근심할지라","reference":"에스겔 23:33","category":"$undefined"},{"id":"21042","book":"에스겔","book_name":"에스겔","chapter":23,"verse":34,"text":"네가 그 잔을 다 기울여 마시고 그 깨어진 조각을 씹으며 네 유방을 꼬집을 것은 내가 이렇게 말하였음이니라 나 주 여호와의 말이니라","reference":"에스겔 23:34","category":"$undefined"},{"id":"21043","book":"에스겔","book_name":"에스겔","chapter":23,"verse":35,"text":"그러므로 나 주 여호와가 말하노라 네가 나를 잊었고 또 나를 네 등 뒤에 버렸은즉 너는 네 음란과 네 음행의 죄를 담당할지니라 하시니라","reference":"에스겔 23:35","category":"$undefined"},{"id":"21044","book":"에스겔","book_name":"에스겔","chapter":23,"verse":36,"text":"여호와께서 또 내게 이르시되 인자야 네가 오홀라와 오홀리바를 국문하려느냐 그러면 그 가증한 일을 그들에게 고하라","reference":"에스겔 23:36","category":"$undefined"},{"id":"21045","book":"에스겔","book_name":"에스겔","chapter":23,"verse":37,"text":"그들이 행음하였으며 피를 손에 묻혔으며 또 그 우상과 행음하며 내게 낳아준 자식들을 우상을 위하여 화제로 살랐으며","reference":"에스겔 23:37","category":"$undefined"},{"id":"21046","book":"에스겔","book_name":"에스겔","chapter":23,"verse":38,"text":"이외에도 그들이 내게 행한 것이 있나니 당일에 내 성소를 더럽히며 내 안식일을 범하였도다","reference":"에스겔 23:38","category":"$undefined"},{"id":"21047","book":"에스겔","book_name":"에스겔","chapter":23,"verse":39,"text":"그들이 자녀를 죽여 그 우상에게 드린 당일에 내 성소에 들어와서 더럽혔으되 그들이 내 성전 가운데서 그렇게 행하였으며","reference":"에스겔 23:39","category":"$undefined"},{"id":"21048","book":"에스겔","book_name":"에스겔","chapter":23,"verse":40,"text":"또 사자를 원방에 보내어 사람을 불러오게 하고 그들이 오매 그들을 위하여 목욕하며 눈썹을 그리며 스스로 단장하고","reference":"에스겔 23:40","category":"$undefined"},{"id":"21049","book":"에스겔","book_name":"에스겔","chapter":23,"verse":41,"text":"화려한 자리에 앉아 앞에 상을 베풀고 내 향과 기름을 그 위에 놓고","reference":"에스겔 23:41","category":"$undefined"},{"id":"21050","book":"에스겔","book_name":"에스겔","chapter":23,"verse":42,"text":"그 무리와 편히 지껄이고 즐겼으며 또 광야에서 잡류와 술취한 사람을 청하여 오매 그들이 팔쇠를 그 손목에 끼우고 아름다운 면류관을 그 머리에 씌웠도다","reference":"에스겔 23:42","category":"$undefined"},{"id":"21051","book":"에스겔","book_name":"에스겔","chapter":23,"verse":43,"text":"내가 음행으로 쇠한 여인을 가리켜 말하노라 그가 그래도 그들과 피차 행음하는도다","reference":"에스겔 23:43","category":"$undefined"},{"id":"21052","book":"에스겔","book_name":"에스겔","chapter":23,"verse":44,"text":"그들이 그에게 나아오기를 기생에게 나아옴 같이 음란한 여인 오홀라와 오홀리바에게 나아왔은즉","reference":"에스겔 23:44","category":"$undefined"},{"id":"21053","book":"에스겔","book_name":"에스겔","chapter":23,"verse":45,"text":"의인이 음부를 심문함 같이 심문하며 피를 흘린 여인을 심문함 같이 심문하리니 그들은 음부요 또 피가 그 손에 묻었음이니라","reference":"에스겔 23:45","category":"$undefined"},{"id":"21054","book":"에스겔","book_name":"에스겔","chapter":23,"verse":46,"text":"나 주 여호와가 말하노라 내가 군대를 거느리고 와서 치게 하여 그들로 학대와 약탈을 당하게 하리니","reference":"에스겔 23:46","category":"$undefined"},{"id":"21055","book":"에스겔","book_name":"에스겔","chapter":23,"verse":47,"text":"그 군대가 그들을 돌로 치며 칼로 죽이고 그 자녀도 죽이며 그 집들을 불사르리라","reference":"에스겔 23:47","category":"$undefined"},{"id":"21056","book":"에스겔","book_name":"에스겔","chapter":23,"verse":48,"text":"이와 같이 내가 이 땅에서 음란을 그치게 한즉 모든 여인이 경성하여 너희 음행을 본받지 아니하리라","reference":"에스겔 23:48","category":"$undefined"},{"id":"21057","book":"에스겔","book_name":"에스겔","chapter":23,"verse":49,"text":"그들이 너희 음란으로 너희에게 보응한즉 너희가 모든 우상을 위하던 죄를 담당할지라 너희가 나를 주 여호와인 줄 알리라 하시니라","reference":"에스겔 23:49","category":"$undefined"}],"bookSlug":"ezekiel"}]
