2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":24,"verses":[{"id":"21058","book":"에스겔","book_name":"에스겔","chapter":24,"verse":1,"text":"제 구년 시월 십일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 24:1","category":"$undefined"},{"id":"21059","book":"에스겔","book_name":"에스겔","chapter":24,"verse":2,"text":"인자야 너는 날짜 곧 오늘날을 기록하라 바벨론 왕이 오늘날 예루살렘에 핍근하였느니라","reference":"에스겔 24:2","category":"$undefined"},{"id":"21060","book":"에스겔","book_name":"에스겔","chapter":24,"verse":3,"text":"너는 이 패역한 족속에게 비유를 베풀어 이르기를 주 여호와의 말씀에 한 가마를 걸라","reference":"에스겔 24:3","category":"$undefined"},{"id":"21061","book":"에스겔","book_name":"에스겔","chapter":24,"verse":4,"text":"건 후에 물을 붓고 양떼에서 고른 것을 가지고 각을 뜨고 그 넓적다리와 어깨고기의 모든 좋은 덩이를 그 가운데 모아 넣으며 고른 뼈를 가득히 담고 그 뼈를 위하여 가마 밑에 나무를 쌓아 넣고 잘 삶되 가마 속의 뼈가 무르도록 삶을지어다","reference":"에스겔 24:4","category":"$undefined"},{"id":"21062","book":"에스겔","book_name":"에스겔","chapter":24,"verse":5,"text":"(4절과 같음)","reference":"에스겔 24:5","category":"$undefined"},{"id":"21063","book":"에스겔","book_name":"에스겔","chapter":24,"verse":6,"text":"그러므로 나 주 여호와가 말하노라 피흘린 성읍,녹슨 가마 곧 그속의 녹을 없이 하지 아니한 가마여 화 있을진저 제비 뽑을 것도 없이 그 덩이를 일일이 꺼낼지어다","reference":"에스겔 24:6","category":"$undefined"},{"id":"21064","book":"에스겔","book_name":"에스겔","chapter":24,"verse":7,"text":"그 피가 그 가운데 있음이여 피를 땅에 쏟아서 티끌이 덮이게 하지 않고 말간 반석 위에 두었도다","reference":"에스겔 24:7","category":"$undefined"},{"id":"21065","book":"에스겔","book_name":"에스겔","chapter":24,"verse":8,"text":"내가 그 피를 말간 반석 위에 두고 덮이지 않게 함은 분노를 발하여 보응하려 함이로라","reference":"에스겔 24:8","category":"$undefined"},{"id":"21066","book":"에스겔","book_name":"에스겔","chapter":24,"verse":9,"text":"그러므로 나 주 여호와가 말하노라 화 있을진저 피를 흘린 성읍이여 내가 또 나무 무더기를 크게 하리라","reference":"에스겔 24:9","category":"$undefined"},{"id":"21067","book":"에스겔","book_name":"에스겔","chapter":24,"verse":10,"text":"나무를 많이 쌓고 불을 피워 그 고기를 삶아 녹이고 국물을 졸이고 그 뼈를 태우고","reference":"에스겔 24:10","category":"$undefined"},{"id":"21068","book":"에스겔","book_name":"에스겔","chapter":24,"verse":11,"text":"가마가 빈 후에는 숯불 위에 놓아 뜨겁게 하며 그 가마의 놋을 달궈서 그 속에 더러운 것을 녹게 하며 녹이 소멸하게 하라","reference":"에스겔 24:11","category":"$undefined"},{"id":"21069","book":"에스겔","book_name":"에스겔","chapter":24,"verse":12,"text":"이 성읍이 수고하므로 스스로 곤비하나 많은 녹이 그 속에서 벗어지지 아니하며 불에서도 없어지지 아니하는도다","reference":"에스겔 24:12","category":"$undefined"},{"id":"21070","book":"에스겔","book_name":"에스겔","chapter":24,"verse":13,"text":"너의 더러운 중에 음란이 하나이라 내가 너를 정하게 하나 네가 정하여지지 아니하니 내가 네게 향한 분노를 풀기 전에는 네 더러움이 다시 정하여지지 아니하리라","reference":"에스겔 24:13","category":"$undefined"},{"id":"21071","book":"에스겔","book_name":"에스겔","chapter":24,"verse":14,"text":"나 여호와가 말하였은즉 그 일이 이룰지라 내가 돌이키지도 아니하며 아끼지도 아니하며 뉘우치지도 아니하고 행하리니 그들이 네 모든 행위대로 너를 심문하리라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 24:14","category":"$undefined"},{"id":"21072","book":"에스겔","book_name":"에스겔","chapter":24,"verse":15,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 24:15","category":"$undefined"},{"id":"21073","book":"에스겔","book_name":"에스겔","chapter":24,"verse":16,"text":"인자야 내가 네 눈에 기뻐하는 것을 한번 쳐서 빼앗으리니 너는 슬퍼하거나 울거나 눈물을 흘리거나 하지 말며","reference":"에스겔 24:16","category":"$undefined"},{"id":"21074","book":"에스겔","book_name":"에스겔","chapter":24,"verse":17,"text":"죽은 자들을 위하여 슬퍼하지 말고 종용히 탄식하며 수건으로 머리를 동이고 발에 신을 신고 입술을 가리우지 말고 사람의 부의하는 식물을 먹지 말라 하신지라","reference":"에스겔 24:17","category":"$undefined"},{"id":"21075","book":"에스겔","book_name":"에스겔","chapter":24,"verse":18,"text":"내가 아침에 백성에게 고하였더니 저녁에 내 아내가 죽기로 아침에 내가 받은 명령대로 행하매","reference":"에스겔 24:18","category":"$undefined"},{"id":"21076","book":"에스겔","book_name":"에스겔","chapter":24,"verse":19,"text":"백성이 내게 이르되 네가 행하는 이 일이 우리에게 무슨 상관이 되는지 너는 우리에게 고하지 아니하겠느냐 하므로","reference":"에스겔 24:19","category":"$undefined"},{"id":"21077","book":"에스겔","book_name":"에스겔","chapter":24,"verse":20,"text":"내가 그들에게 대답하기를 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 24:20","category":"$undefined"},{"id":"21078","book":"에스겔","book_name":"에스겔","chapter":24,"verse":21,"text":"너는 이스라엘 족속에게 이르기를 주 여호와의 말씀에 내 성소는 너희 세력의 영광이요 너희 눈의 기쁨이요 너희 마음에 아낌이 되거니와 내가 더럽힐 것이며 너희의 버려둔 자녀를 칼에 엎드러지게 할지라","reference":"에스겔 24:21","category":"$undefined"},{"id":"21079","book":"에스겔","book_name":"에스겔","chapter":24,"verse":22,"text":"너희가 에스겔의 행한 바와 같이 행하여 입술을 가리우지 아니하며 사람의 식물을 먹지 아니하며","reference":"에스겔 24:22","category":"$undefined"},{"id":"21080","book":"에스겔","book_name":"에스겔","chapter":24,"verse":23,"text":"수건으로 머리를 동인 채 발에 신을 신은 채로 두고 슬퍼하지도 아니하며 울지도 아니하되 죄악 중에 쇠패하여 피차 바라보고 탄식하리라","reference":"에스겔 24:23","category":"$undefined"},{"id":"21081","book":"에스겔","book_name":"에스겔","chapter":24,"verse":24,"text":"이와 같이 에스겔이 너희에게 표징이 되리니 그가 행한대로 너희가 다 행할지라 이 일이 이루면 너희가 나를 주 여호와인 줄 알리라 하라 하셨느니라","reference":"에스겔 24:24","category":"$undefined"},{"id":"21082","book":"에스겔","book_name":"에스겔","chapter":24,"verse":25,"text":"인자야 내가 그 힘과 그 즐거워하는 영광과 그 눈의 기뻐하는 것과 그 마음의 간절히 생각하는 자녀를 제하는 날","reference":"에스겔 24:25","category":"$undefined"},{"id":"21083","book":"에스겔","book_name":"에스겔","chapter":24,"verse":26,"text":"곧 그 날에 도피한 자가 네게 나아와서 네 귀에 그 일을 들리지 아니하겠느냐","reference":"에스겔 24:26","category":"$undefined"},{"id":"21084","book":"에스겔","book_name":"에스겔","chapter":24,"verse":27,"text":"그 날에 네 입이 열려서 도피한 자에게 말하고 다시는 잠잠하지 아니하리라 이와 같이 너는 그들에게 표징이 되고 그들은 내가 여호와인 줄 알리라","reference":"에스겔 24:27","category":"$undefined"}],"bookSlug":"ezekiel"}]
