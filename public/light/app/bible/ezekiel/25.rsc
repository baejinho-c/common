2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":25,"verses":[{"id":"21085","book":"에스겔","book_name":"에스겔","chapter":25,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 25:1","category":"$undefined"},{"id":"21086","book":"에스겔","book_name":"에스겔","chapter":25,"verse":2,"text":"인자야 암몬 족속을 향하여 그들을 쳐서 예언하라 너는 암몬 족속에게 이르기를 너희는 주 여호와의 말씀을 들을지어다 주 여호와의 말씀에 내 성소를 더럽힐 때에 네가 그것을 대하여,이스라엘 땅이 황무할 때에 네가 그것을 대하여,유다 족속이 사로 잡힐때에 네가 그들을 대하여 이르기를 아하 좋다 하였도다","reference":"에스겔 25:2","category":"$undefined"},{"id":"21087","book":"에스겔","book_name":"에스겔","chapter":25,"verse":3,"text":"(2절과같음)","reference":"에스겔 25:3","category":"$undefined"},{"id":"21088","book":"에스겔","book_name":"에스겔","chapter":25,"verse":4,"text":"그러므로 내가 너를 동방 사람에게 기업으로 붙이리니 그들이 네 가운데 진을 치며 네 가운데 그 거처를 베풀며 네 실과를 먹으며 네 젖을 마실지라","reference":"에스겔 25:4","category":"$undefined"},{"id":"21089","book":"에스겔","book_name":"에스겔","chapter":25,"verse":5,"text":"내가 랍바로 약대의 우리를 만들며 암몬 족속의 땅으로 양무리의 눕는 곳을 삼은즉 너희가 나를 여호와인 줄 알리라","reference":"에스겔 25:5","category":"$undefined"},{"id":"21090","book":"에스겔","book_name":"에스겔","chapter":25,"verse":6,"text":"나 주 여호와가 말하노라 네가 이스라엘 땅을 대하여 손뼉을 치며 발을 구르며 마음을 다하여 멸시하며 즐거워하였나니","reference":"에스겔 25:6","category":"$undefined"},{"id":"21091","book":"에스겔","book_name":"에스겔","chapter":25,"verse":7,"text":"그런즉 내가 손을 네 위에 펴서 너를 다른 민족에게 붙여 노략을 당하게 하며 너를 만민 중에 끊어버리며 너를 열국 중에서 패망케 하여 멸하리니 네가 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 25:7","category":"$undefined"},{"id":"21092","book":"에스겔","book_name":"에스겔","chapter":25,"verse":8,"text":"나 주 여호와가 말하노라 모압과 세일이 이르기를 유다 족속은 모든 이방과 일반이라 하도다","reference":"에스겔 25:8","category":"$undefined"},{"id":"21093","book":"에스겔","book_name":"에스겔","chapter":25,"verse":9,"text":"그러므로 내가 모압의 한편 곧 그 나라 변경에 있는 영화로운 성읍들 벧여시못과 바알므온과 기랴다임을 열고","reference":"에스겔 25:9","category":"$undefined"},{"id":"21094","book":"에스겔","book_name":"에스겔","chapter":25,"verse":10,"text":"암몬 족속 일반으로 동방 사람에게 붙여 기업을 삼게 할 것이라 암몬 족속으로 다시는 이방 가운데서 기억되지 아니하게 하려니와","reference":"에스겔 25:10","category":"$undefined"},{"id":"21095","book":"에스겔","book_name":"에스겔","chapter":25,"verse":11,"text":"내가 모압에 벌을 내리리니 그들이 나를 여호와인 줄 알리라","reference":"에스겔 25:11","category":"$undefined"},{"id":"21096","book":"에스겔","book_name":"에스겔","chapter":25,"verse":12,"text":"나 주 여호와가 말하노라 에돔이 유다 족속을 쳐서 원수를 갚았고 원수를 갚음으로 심히 범죄하였도다","reference":"에스겔 25:12","category":"$undefined"},{"id":"21097","book":"에스겔","book_name":"에스겔","chapter":25,"verse":13,"text":"그러므로 나 주 여호와가 말하노라 내가 내 손을 에돔 위에 펴서 사람과 짐승을 그 가운데서 끊어 데만에서부터 황무하게 하리니 드단까지 칼에 엎드러지리라","reference":"에스겔 25:13","category":"$undefined"},{"id":"21098","book":"에스겔","book_name":"에스겔","chapter":25,"verse":14,"text":"내가 내 백성 이스라엘의 손을 빙자하여 내 원수를 에돔에게 갚으리니 그들이 내 노와 분을 따라 에돔에 행한즉 내가 원수를 갚음인 줄을 에돔이 알리라 나 주 여호와의 말이니라","reference":"에스겔 25:14","category":"$undefined"},{"id":"21099","book":"에스겔","book_name":"에스겔","chapter":25,"verse":15,"text":"나 주 여호와가 말하노라 블레셋 사람이 옛날부터 미워하여 멸시하는 마음으로 원수를 갚아 진멸코자 하였도다","reference":"에스겔 25:15","category":"$undefined"},{"id":"21100","book":"에스겔","book_name":"에스겔","chapter":25,"verse":16,"text":"그러므로 나 주 여호와가 말하노라 내가 블레셋 사람 위에 손을 펴서 그렛 사람을 끊으며 해변에 남은 자를 진멸하되","reference":"에스겔 25:16","category":"$undefined"},{"id":"21101","book":"에스겔","book_name":"에스겔","chapter":25,"verse":17,"text":"분노의 책벌로 내 원수를 그들에게 크게 갚으리라 내가 그들에게 원수를 갚은즉 그들이 나를 여호와인 줄 알리라 하시니라","reference":"에스겔 25:17","category":"$undefined"}],"bookSlug":"ezekiel"}]
