2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":26,"verses":[{"id":"21102","book":"에스겔","book_name":"에스겔","chapter":26,"verse":1,"text":"제 십 일년 어느날 초 일일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 26:1","category":"$undefined"},{"id":"21103","book":"에스겔","book_name":"에스겔","chapter":26,"verse":2,"text":"인자야 두로가 예루살렘을 쳐서 이르기를 아하 좋다 만민의 문이 깨어져서 내게로 돌아왔도다 그가 황무하였으니 내가 충만함을 얻으리라 하였도다","reference":"에스겔 26:2","category":"$undefined"},{"id":"21104","book":"에스겔","book_name":"에스겔","chapter":26,"verse":3,"text":"그러므로 나 주 여호와가 말하노라 두로야 내가 너를 대적하여 바다가 그 파도로 흉용케함 같이 열국으로 와서 너를 치게 하리니","reference":"에스겔 26:3","category":"$undefined"},{"id":"21105","book":"에스겔","book_name":"에스겔","chapter":26,"verse":4,"text":"그들이 두로의 성벽을 훼파하며 그 망대를 헐 것이요 나도 티끌을 그 위에서 쓸어 버려서 말간 반석이 되게 하며","reference":"에스겔 26:4","category":"$undefined"},{"id":"21106","book":"에스겔","book_name":"에스겔","chapter":26,"verse":5,"text":"바다 가운데 그물 치는 곳이 되게 하리니 내가 말하였음이니라 나 주 여호와의 말이니라 그가 이방의 노략거리가 될 것이요","reference":"에스겔 26:5","category":"$undefined"},{"id":"21107","book":"에스겔","book_name":"에스겔","chapter":26,"verse":6,"text":"들에 있는 그의 딸들은 칼에 죽으리니 그들이 나를 여호와인 줄알리라","reference":"에스겔 26:6","category":"$undefined"},{"id":"21108","book":"에스겔","book_name":"에스겔","chapter":26,"verse":7,"text":"나 주 여호와가 말하노라 내가 열왕의 왕 곧 바벨론 왕 느부갓네살로 북방에서 말과 병거와 기병과 군대와 백성의 큰 무리를 거느리고 와서 두로를 치게 할 때에","reference":"에스겔 26:7","category":"$undefined"},{"id":"21109","book":"에스겔","book_name":"에스겔","chapter":26,"verse":8,"text":"그가 들에 있는 너의 딸들을 칼로 죽이고 너를 치려고 운제를 세우며 토성을 쌓으며 방패를 갖출 것이며","reference":"에스겔 26:8","category":"$undefined"},{"id":"21110","book":"에스겔","book_name":"에스겔","chapter":26,"verse":9,"text":"공성퇴를 베풀어 네 성을 치며 도끼로 망대를 찍을 것이며","reference":"에스겔 26:9","category":"$undefined"},{"id":"21111","book":"에스겔","book_name":"에스겔","chapter":26,"verse":10,"text":"말이 많으므로 그 티끌이 너를 가리울 것이며 사람이 훼파된 성 구멍으로 들어가는 것 같이 그가 네 성문으로 들어갈 때에 그 기병과 수레와 병거의 소리로 인하여 네 성곽이 진동할 것이며","reference":"에스겔 26:10","category":"$undefined"},{"id":"21112","book":"에스겔","book_name":"에스겔","chapter":26,"verse":11,"text":"그가 그 말굽으로 네 모든 거리를 밟을 것이며 칼로 네 백성을 죽일 것이며 네 견고한 석상을 땅에 엎드러뜨릴 것이며","reference":"에스겔 26:11","category":"$undefined"},{"id":"21113","book":"에스겔","book_name":"에스겔","chapter":26,"verse":12,"text":"네 재물을 빼앗을 것이며 네 무역한 것을 노략할 것이며 네 성을 헐 것이며 네 기뻐하는 집을 무너뜨릴 것이며 또 네 돌들과 네 재목과 네 흙을 다 물 가운데 던질 것이라","reference":"에스겔 26:12","category":"$undefined"},{"id":"21114","book":"에스겔","book_name":"에스겔","chapter":26,"verse":13,"text":"내가 네 노래 소리로 그치게 하며 네 수금 소리로 다시 들리지 않게 하고","reference":"에스겔 26:13","category":"$undefined"},{"id":"21115","book":"에스겔","book_name":"에스겔","chapter":26,"verse":14,"text":"너로 말간 반석이 되게 한즉 네가 그물 말리는 곳이 되고 다시는 건축되지 못하리니 나 여호와가 말하였음이니라 나 주 여호와의 말이니라","reference":"에스겔 26:14","category":"$undefined"},{"id":"21116","book":"에스겔","book_name":"에스겔","chapter":26,"verse":15,"text":"주 여호와께서 두로를 대하여 말씀하시되 너의 엎드러지는 소리에 모든 섬이 진동하지 아니하겠느냐 ? 곧 너희 중에 상한 자가 부르짖으며 살륙을 당할 때에라","reference":"에스겔 26:15","category":"$undefined"},{"id":"21117","book":"에스겔","book_name":"에스겔","chapter":26,"verse":16,"text":"그 때에 바다의 모든 왕이 그 보좌에서 내려 조복을 벗으며 수 놓은 옷을 버리고 떨림을 입듯하고 땅에 앉아서 너로 인하여 무시로 떨며 놀랄 것이며","reference":"에스겔 26:16","category":"$undefined"},{"id":"21118","book":"에스겔","book_name":"에스겔","chapter":26,"verse":17,"text":"그들이 너를 위하여 애가를 불러 이르기를 항해자의 거한 유명한 성이여 너와 너의 거민이 바다 가운데 있어 견고하였었도다 해변의 모든 거민을 두렵게 하였더니 어찌 그리 멸망하였는고","reference":"에스겔 26:17","category":"$undefined"},{"id":"21119","book":"에스겔","book_name":"에스겔","chapter":26,"verse":18,"text":"너의 무너지는 그 날에 섬들이 진동할 것임이여 바다 가운데 섬들이 네 결국을 보고 놀라리로다 하리라","reference":"에스겔 26:18","category":"$undefined"},{"id":"21120","book":"에스겔","book_name":"에스겔","chapter":26,"verse":19,"text":"나 주 여호와가 말하노라 내가 너로 거민이 없는 성과 같이 황무한 성이 되게 하고 깊은 바다로 네 위에 오르게 하며 큰 물로 너를 덮게 할 때에","reference":"에스겔 26:19","category":"$undefined"},{"id":"21121","book":"에스겔","book_name":"에스겔","chapter":26,"verse":20,"text":"내가 너로 구덩이에 내려가는 자와 함께 내려가서 옛적 사람에게로 나아가게 하고 너로 그 구덩이에 내려간 자와 함께 땅깊은 곳에로부터 황적한 곳에 거하게 할지라 네가 다시는 사람이 거하는 곳이 되지 못하리니 산 자의 땅에서 영광을 얻지 못하리라","reference":"에스겔 26:20","category":"$undefined"},{"id":"21122","book":"에스겔","book_name":"에스겔","chapter":26,"verse":21,"text":"내가 너를 패망케 하여 다시 있지 못하게 하리니 사람이 비록 너를 찾으나 다시는 영원히 만나지 못하리라 나 주 여호와의 말이니라","reference":"에스겔 26:21","category":"$undefined"}],"bookSlug":"ezekiel"}]
