2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":27,"verses":[{"id":"21123","book":"에스겔","book_name":"에스겔","chapter":27,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 27:1","category":"$undefined"},{"id":"21124","book":"에스겔","book_name":"에스겔","chapter":27,"verse":2,"text":"인자야 너는 두로를 위하여 애가를 지으라","reference":"에스겔 27:2","category":"$undefined"},{"id":"21125","book":"에스겔","book_name":"에스겔","chapter":27,"verse":3,"text":"너는 두로를 향하여 이르기를 바다 어귀에 거하여 여러 섬 백성과 통상하는 자여 주 여호와의 말씀에 두로야 네가 말하기를 나는 온전히 아름답다 하였도다","reference":"에스겔 27:3","category":"$undefined"},{"id":"21126","book":"에스겔","book_name":"에스겔","chapter":27,"verse":4,"text":"네 지경이 바다 가운데 있음이여 너를 지은 자가 네 아름다움을 온전케 하였도다","reference":"에스겔 27:4","category":"$undefined"},{"id":"21127","book":"에스겔","book_name":"에스겔","chapter":27,"verse":5,"text":"스닐의 잣나무로 네 판자를 만들었음이여 너를 위하여 레바논 백향목을 가져 돛대를 만들었도다","reference":"에스겔 27:5","category":"$undefined"},{"id":"21128","book":"에스겔","book_name":"에스겔","chapter":27,"verse":6,"text":"바산 상수리나무로 네 노를 만들었음이여 깃딤섬 황양목에 상아로 꾸며 갑판을 만들었도다","reference":"에스겔 27:6","category":"$undefined"},{"id":"21129","book":"에스겔","book_name":"에스겔","chapter":27,"verse":7,"text":"애굽의 수 놓은 가는 베로 돛을 만들어 기를 삼았음이여 엘리사 섬의 청색 자색 베로 차일을 만들었도다","reference":"에스겔 27:7","category":"$undefined"},{"id":"21130","book":"에스겔","book_name":"에스겔","chapter":27,"verse":8,"text":"시돈과 아르왓 거민들이 네 사공이 되었음이여 두로야 네 가운데 있는 박사가 네 선장이 되었도다","reference":"에스겔 27:8","category":"$undefined"},{"id":"21131","book":"에스겔","book_name":"에스겔","chapter":27,"verse":9,"text":"그발의 노인과 박사들이 네 가운데서 배의 틈을 막는 자가 되었음이여 바다의 모든 배와 그 사공들은 네 가운데서 무역하였도다","reference":"에스겔 27:9","category":"$undefined"},{"id":"21132","book":"에스겔","book_name":"에스겔","chapter":27,"verse":10,"text":"바사와 룻과 붓이 네 군대 가운데서 병정이 되었음이여 네 가운데서 방패와 투구를 달아 네 영광을 나타내었도다","reference":"에스겔 27:10","category":"$undefined"},{"id":"21133","book":"에스겔","book_name":"에스겔","chapter":27,"verse":11,"text":"아르왓 사람과 네 군대는 네 사면 성 위에 있었고 용사들은 네 여러 망대에 있었음이여 네 사면 성 위에 방패를 달아 네 아름다움을 온전케 하였도다","reference":"에스겔 27:11","category":"$undefined"},{"id":"21134","book":"에스겔","book_name":"에스겔","chapter":27,"verse":12,"text":"다시스는 각종 보화가 풍부하므로 너와 통상하였음이여 은과 철과 상납과 납을 가지고 네 물품을 무역하였도다","reference":"에스겔 27:12","category":"$undefined"},{"id":"21135","book":"에스겔","book_name":"에스겔","chapter":27,"verse":13,"text":"야완과 두발과 메섹은 네 장사가 되었음이여 사람과 놋그릇을 가지고 네 상품을 무역하였도다","reference":"에스겔 27:13","category":"$undefined"},{"id":"21136","book":"에스겔","book_name":"에스겔","chapter":27,"verse":14,"text":"도갈마 족속은 말과 전마와 노새를 가지고 네 물품을 무역하며","reference":"에스겔 27:14","category":"$undefined"},{"id":"21137","book":"에스겔","book_name":"에스겔","chapter":27,"verse":15,"text":"드단 사람은 네 장사가 되었음이여 여러 섬이 너와 통상하여 상아와 오목을 가져 네 물품을 무역하였도다","reference":"에스겔 27:15","category":"$undefined"},{"id":"21138","book":"에스겔","book_name":"에스겔","chapter":27,"verse":16,"text":"너의 제조품이 풍부하므로 아람은 너와 통상하였음이여 남보석과 자색 베와 수 놓은 것과 가는 베와 산호와 홍보석을 가지고 네 물품을 무역하였도다","reference":"에스겔 27:16","category":"$undefined"},{"id":"21139","book":"에스겔","book_name":"에스겔","chapter":27,"verse":17,"text":"유다와 이스라엘 땅 사람이 네 장사가 되었음이여 민닛 밀과 과자와 꿀과 기름과 유향을 가지고 네 물품을 무역하였도다","reference":"에스겔 27:17","category":"$undefined"},{"id":"21140","book":"에스겔","book_name":"에스겔","chapter":27,"verse":18,"text":"너의 제조품이 많고 각종 보화가 풍부하므로 다메섹이 너와 통상하였음이여 헬본 포도주와 흰 양털을 가지고 너와 무역하였도다","reference":"에스겔 27:18","category":"$undefined"},{"id":"21141","book":"에스겔","book_name":"에스겔","chapter":27,"verse":19,"text":"워단과 야완은 길쌈하는 실로 네 물품을 무역하였음이여 백철과 육계와 창포가 네 상품중에 있었도다","reference":"에스겔 27:19","category":"$undefined"},{"id":"21142","book":"에스겔","book_name":"에스겔","chapter":27,"verse":20,"text":"드단은 네 장사가 되었음이여 탈 때 까는 담으로 너와 무역하였도다","reference":"에스겔 27:20","category":"$undefined"},{"id":"21143","book":"에스겔","book_name":"에스겔","chapter":27,"verse":21,"text":"그들이 다 너를 위하여 머리털을 밀고 굵은 베로 띠를 띠고 마음이 아프게 슬피 통곡하리로다","reference":"에스겔 27:21","category":"$undefined"},{"id":"21144","book":"에스겔","book_name":"에스겔","chapter":27,"verse":22,"text":"아라비아와 게달의 모든 방백은 네 수하에 상고가 되어 어린 양과 수양과 염소들 그것으로 너와 무역하였도다","reference":"에스겔 27:22","category":"$undefined"},{"id":"21145","book":"에스겔","book_name":"에스겔","chapter":27,"verse":23,"text":"아라비아와 게달의 모든 방백은 네 수하에 상고가 되어 어린 양과 수양과 염소들 그것으로 너와 무역하였도다","reference":"에스겔 27:23","category":"$undefined"},{"id":"21146","book":"에스겔","book_name":"에스겔","chapter":27,"verse":24,"text":"그들이 다 너를 위하여 머리털을 밀고 굵은 베로 띠를 띠고 마음이 아프게 슬피 통곡하리로다","reference":"에스겔 27:24","category":"$undefined"},{"id":"21147","book":"에스겔","book_name":"에스겔","chapter":27,"verse":25,"text":"스바와 라아마의 장사들도 너의 장사들이 됨이여 각종 상등 향재료와 각종 보석과 황금으로 네 물품을 무역하였도다","reference":"에스겔 27:25","category":"$undefined"},{"id":"21148","book":"에스겔","book_name":"에스겔","chapter":27,"verse":26,"text":"하란과 간네와 에덴과 스바와 앗수르와 길맛의 장사들도 너의 장사들이라","reference":"에스겔 27:26","category":"$undefined"},{"id":"21149","book":"에스겔","book_name":"에스겔","chapter":27,"verse":27,"text":"이들이 아름다운 물화 곧 청색 옷과 수놓은 물품과 빛난 옷을 백향목 상자에 담고 노끈으로 묶어 가지고 너와 통상하여 네 물품을 무역하였도다","reference":"에스겔 27:27","category":"$undefined"},{"id":"21150","book":"에스겔","book_name":"에스겔","chapter":27,"verse":28,"text":"다시스의 배는 떼를 지어 네 물화를 실었음이여 네가 바다 중심에서 풍부하여 영화가 극하였도다","reference":"에스겔 27:28","category":"$undefined"},{"id":"21151","book":"에스겔","book_name":"에스겔","chapter":27,"verse":29,"text":"네 사공이 너를 인도하여 큰 물에 이름이여 동풍이 바다 중심에서 너를 파하도다","reference":"에스겔 27:29","category":"$undefined"},{"id":"21152","book":"에스겔","book_name":"에스겔","chapter":27,"verse":30,"text":"네 재물과 상품과 무역한 물건과 네 사공과 선장과 네 배의 틈을 막는 자와 네 장사와 네 가운데 있는 모든 용사와 네 가운데 있는 모든 무리가 네 패망하는 날에 다 바다 중심에 빠질 것임이여","reference":"에스겔 27:30","category":"$undefined"},{"id":"21153","book":"에스겔","book_name":"에스겔","chapter":27,"verse":31,"text":"네 선장의 부르짖는 소리에 물결이 흔들리리로다","reference":"에스겔 27:31","category":"$undefined"},{"id":"21154","book":"에스겔","book_name":"에스겔","chapter":27,"verse":32,"text":"무릇 노를 잡은 자와 사공과 바다의 선장들이 다 배에 내려 언덕에 서서","reference":"에스겔 27:32","category":"$undefined"},{"id":"21155","book":"에스겔","book_name":"에스겔","chapter":27,"verse":33,"text":"너를 위하여 크게 소리질러 통곡하고 티끌을 머리에 무릎쓰며 재 가운데 굶이여","reference":"에스겔 27:33","category":"$undefined"},{"id":"21156","book":"에스겔","book_name":"에스겔","chapter":27,"verse":34,"text":"그들이 다 너를 위하여 머리털을 밀고 굵은 베로 띠를 띠고 마음이 아프게 슬피 통곡하리로다","reference":"에스겔 27:34","category":"$undefined"},{"id":"21157","book":"에스겔","book_name":"에스겔","chapter":27,"verse":35,"text":"그들이 통곡할 때에 너를 위하여 애가를 불러 조상하는 말씀이여 두로 같이 바다 가운데서 적막한 자 누구인고","reference":"에스겔 27:35","category":"$undefined"},{"id":"21158","book":"에스겔","book_name":"에스겔","chapter":27,"verse":36,"text":"네 물품을 바다로 실어 낼 때에 네가 여러 백성을 풍족하게 하였음이여 네 재물과 무역품이 많으므로 세상 열왕을 풍부케 하였었도다 [ (Ezekiel 27:37) 네가 바다 깊은데서 파선한 때에 네 무역품과 네 승객이 다 빠졌음이여 ] [ (Ezekiel 27:38) 섬의 거민들이 너를 인하여 놀라고 열왕이 심히 두려워하여 얼굴에 근심이 나타나도다 ] [ (Ezekiel 27:39) 열국의 상고가 다 너를 비웃음이여 네가 경계거리가 되고 네가 영원히 다시 있지 못하리라 하리로다 하셨다 하라 ]","reference":"에스겔 27:36","category":"$undefined"}],"bookSlug":"ezekiel"}]
