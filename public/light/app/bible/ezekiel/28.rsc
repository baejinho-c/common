2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":28,"verses":[{"id":"21159","book":"에스겔","book_name":"에스겔","chapter":28,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 28:1","category":"$undefined"},{"id":"21160","book":"에스겔","book_name":"에스겔","chapter":28,"verse":2,"text":"인자야 너는 두로 왕에게 이르기를 주 여호와의 말씀에 네 마음이 교만하여 말하기를 나는 신이라 내가 하나님의 자리 곧 바다 중심에 앉았다 하도다 네 마음이 하나님의 마음 같은 체 할지라도 너는 사람이요 신이 아니어늘","reference":"에스겔 28:2","category":"$undefined"},{"id":"21161","book":"에스겔","book_name":"에스겔","chapter":28,"verse":3,"text":"네가 다니엘보다 지혜로와서 은밀한 것을 깨닫지 못할 것이 없다하고","reference":"에스겔 28:3","category":"$undefined"},{"id":"21162","book":"에스겔","book_name":"에스겔","chapter":28,"verse":4,"text":"네 지혜와 총명으로 재물을 얻었으며 금 은을 곳간에 저축하였으며","reference":"에스겔 28:4","category":"$undefined"},{"id":"21163","book":"에스겔","book_name":"에스겔","chapter":28,"verse":5,"text":"네 큰 지혜와 장사함으로 재물을 더하고 그 재물로 인하여 네 마음이 교만하였도다","reference":"에스겔 28:5","category":"$undefined"},{"id":"21164","book":"에스겔","book_name":"에스겔","chapter":28,"verse":6,"text":"그러므로 나 주 여호와가 말하노라 네 마음이 하나님의 마음 같은 체 하였으니","reference":"에스겔 28:6","category":"$undefined"},{"id":"21165","book":"에스겔","book_name":"에스겔","chapter":28,"verse":7,"text":"그런즉 내가 외인 곧 열국의 강포한 자를 거느리고 와서 너를 치리니 그들이 칼을 빼어 네 지혜의 아름다운 것을 치며 네 영화를 더럽히며","reference":"에스겔 28:7","category":"$undefined"},{"id":"21166","book":"에스겔","book_name":"에스겔","chapter":28,"verse":8,"text":"또 너를 구덩이에 빠뜨려서 너로 바다 가운데서 살륙을 당한 자의 죽음 같이 바다 중심에서 죽게 할지라","reference":"에스겔 28:8","category":"$undefined"},{"id":"21167","book":"에스겔","book_name":"에스겔","chapter":28,"verse":9,"text":"너를 살륙하는 자 앞에서 네가 그래도 말하기를 내가 하나님이라 하겠느냐 너를 치는 자의 수중에서 사람뿐이요 신이 아니라","reference":"에스겔 28:9","category":"$undefined"},{"id":"21168","book":"에스겔","book_name":"에스겔","chapter":28,"verse":10,"text":"네가 외인의 손에서 죽기를 할례 받지 않은 자의 죽음 같이 하리니 내가 말하였음이니라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 28:10","category":"$undefined"},{"id":"21169","book":"에스겔","book_name":"에스겔","chapter":28,"verse":11,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 28:11","category":"$undefined"},{"id":"21170","book":"에스겔","book_name":"에스겔","chapter":28,"verse":12,"text":"인자야 두로 왕을 위하여 애가를 지어 그에게 이르기를 주 여호와의 말씀에 너는 완전한 인이었고 지혜가 충족하며 온전히 아름다왔도다","reference":"에스겔 28:12","category":"$undefined"},{"id":"21171","book":"에스겔","book_name":"에스겔","chapter":28,"verse":13,"text":"네가 옛적에 하나님의 동산 에덴에 있어서 각종 보석 곧 홍보석과, 황보석과, 금강석과, 황옥과, 홍마노와, 창옥과, 청보석과, 남보석과, 홍옥과, 황금으로 단장하였었음이여 네가 지음을 받던 날에 너를 위하여 소고와 비파가 예비되었었도다","reference":"에스겔 28:13","category":"$undefined"},{"id":"21172","book":"에스겔","book_name":"에스겔","chapter":28,"verse":14,"text":"너는 기름 부음을 받은 덮는 그룹임이여 내가 너를 세우매 네가 하나님의 성산에 있어서 화광석 사이에 왕래하였었도다","reference":"에스겔 28:14","category":"$undefined"},{"id":"21173","book":"에스겔","book_name":"에스겔","chapter":28,"verse":15,"text":"네가 지음을 받던 날로부터 네 모든 길에 완전하더니 마침내 불의가 드러났도다","reference":"에스겔 28:15","category":"$undefined"},{"id":"21174","book":"에스겔","book_name":"에스겔","chapter":28,"verse":16,"text":"네 무역이 풍성하므로 네 가운데 강포가 가득하여 네가 범죄하였도다 너 덮는 그룹아 그러므로 내가 너를 더럽게 여겨 하나님의 산에서 쫓아 내었고 화광석 사이에서 멸하였도다","reference":"에스겔 28:16","category":"$undefined"},{"id":"21175","book":"에스겔","book_name":"에스겔","chapter":28,"verse":17,"text":"네가 아름다우므로 마음이 교만하였으며 네가 영화로우므로 네 지혜를 더럽혔음이여 내가 너를 땅에 던져 열왕 앞에 두어 그들의 구경거리가 되게 하였도다","reference":"에스겔 28:17","category":"$undefined"},{"id":"21176","book":"에스겔","book_name":"에스겔","chapter":28,"verse":18,"text":"네가 죄악이 많고 무역이 불의하므로 네 모든 성소를 더럽혔음이여 내가 네 가운데서 불을 내어 너를 사르게 하고 너를 목도하는 모든 자 앞에서 너로 땅 위에 재가 되게 하였도다","reference":"에스겔 28:18","category":"$undefined"},{"id":"21177","book":"에스겔","book_name":"에스겔","chapter":28,"verse":19,"text":"만민 중에 너를 아는 자가 너로 인하여 다 놀랄 것임이여 네가 경계거리가 되고 네가 영원히 다시 있지 못하리로다 하셨다 하라","reference":"에스겔 28:19","category":"$undefined"},{"id":"21178","book":"에스겔","book_name":"에스겔","chapter":28,"verse":20,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 28:20","category":"$undefined"},{"id":"21179","book":"에스겔","book_name":"에스겔","chapter":28,"verse":21,"text":"인자야 너는 낯을 시돈으로 향하고 그를 쳐서 예언하라","reference":"에스겔 28:21","category":"$undefined"},{"id":"21180","book":"에스겔","book_name":"에스겔","chapter":28,"verse":22,"text":"너는 이르기를 주 여호와의 말씀에 시돈아 내가 너를 대적하나니 네 가운데서 내 영광이 나타나리라 하셨다 하라 내가 그 가운데서 국문을 행하여 내 거룩함을 나타낼 때에 무리가 나를 여호와인 줄 알지라","reference":"에스겔 28:22","category":"$undefined"},{"id":"21181","book":"에스겔","book_name":"에스겔","chapter":28,"verse":23,"text":"내가 그에게 염병을 보내며 그의 거리에 피가 흐르게 하리니 사방에서 오는 칼에 상한 자가 그 가운데 엎드러질 것인즉 무리가 나를 여호와인 줄 알겠고","reference":"에스겔 28:23","category":"$undefined"},{"id":"21182","book":"에스겔","book_name":"에스겔","chapter":28,"verse":24,"text":"이스라엘 족속에게는 그 사면에서 그들을 멸시하는 자 중에 찌르는 가시와 아프게 하는 가시가 다시는 없으리니 그들이 나를 주 여호와인 줄 알리라","reference":"에스겔 28:24","category":"$undefined"},{"id":"21183","book":"에스겔","book_name":"에스겔","chapter":28,"verse":25,"text":"나 주 여호와가 말하노라 내가 열방에 흩어 있는 이스라엘 족속을 모으고 그들로 인하여 열국의 목전에서 내 거룩함을 나타낼 때에 그들이 고토 곧 내 종 야곱에게 준 땅에 거할지라","reference":"에스겔 28:25","category":"$undefined"},{"id":"21184","book":"에스겔","book_name":"에스겔","chapter":28,"verse":26,"text":"그들이 그 가운데 평안히 거하여 집을 건축하며 포도원을 심고 그들의 사면에서 멸시하던 모든 자를 내가 국문할 때에 그들이 평안히 살며 나를 그 하나님 여호와인 줄 알리라","reference":"에스겔 28:26","category":"$undefined"}],"bookSlug":"ezekiel"}]
