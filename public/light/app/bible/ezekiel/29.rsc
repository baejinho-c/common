2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":29,"verses":[{"id":"21185","book":"에스겔","book_name":"에스겔","chapter":29,"verse":1,"text":"제 십년 시월 십 이일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 29:1","category":"$undefined"},{"id":"21186","book":"에스겔","book_name":"에스겔","chapter":29,"verse":2,"text":"인자야 너는 애굽 왕 바로와 온 애굽으로 낯을 향하고 쳐서 예언하라","reference":"에스겔 29:2","category":"$undefined"},{"id":"21187","book":"에스겔","book_name":"에스겔","chapter":29,"verse":3,"text":"너는 말하여 이르기를 주 여호와의 말씀에 애굽왕 바로야 내가 너를 대적하노라 너는 자기의 강들 중에 누운 큰 악어라 스스로 이르기를 내 이 강은 내 것이라 내가 나를 위하여 만들었다 하는도다","reference":"에스겔 29:3","category":"$undefined"},{"id":"21188","book":"에스겔","book_name":"에스겔","chapter":29,"verse":4,"text":"내가 갈고리로 네 아가미를 꿰고 네 강의 고기로 네 비늘에 붙게하고 네 비늘에 붙은 강의 모든 고기와 함께 너를 네 강들 중에서 끌어내고","reference":"에스겔 29:4","category":"$undefined"},{"id":"21189","book":"에스겔","book_name":"에스겔","chapter":29,"verse":5,"text":"너와 네 강의 모든 고기를 들에 던지리니 네가 지면에 떨어지고 다시는 거두거나 모음을 입지 못할 것은 내가 너를 들짐승과 공중의 새의 식물로 주었음이라","reference":"에스겔 29:5","category":"$undefined"},{"id":"21190","book":"에스겔","book_name":"에스겔","chapter":29,"verse":6,"text":"애굽의 모든 거민이 나를 여호와인 줄 알리라 애굽은 본래 이스라엘 족속에게 갈대 지팡이라","reference":"에스겔 29:6","category":"$undefined"},{"id":"21191","book":"에스겔","book_name":"에스겔","chapter":29,"verse":7,"text":"그들이 너를 손으로 잡은즉 네가 부러져서 그들의 모든 어깨를 찢었고 그들이 너를 의지한즉 네가 부러져서 그들의 모든 허리로 흔들리게 하였느니라","reference":"에스겔 29:7","category":"$undefined"},{"id":"21192","book":"에스겔","book_name":"에스겔","chapter":29,"verse":8,"text":"그러므로 나 주 여호와가 말하노라 내가 칼로 네게 임하게 하여 네게서 사람과 짐승을 끊은즉","reference":"에스겔 29:8","category":"$undefined"},{"id":"21193","book":"에스겔","book_name":"에스겔","chapter":29,"verse":9,"text":"애굽 땅이 사막과 황무지가 되리니 그들이 나를 여호와인 줄 알리라 네가 스스로 이르기를 이 강은 내 것이라 내가 만들었다 하도다","reference":"에스겔 29:9","category":"$undefined"},{"id":"21194","book":"에스겔","book_name":"에스겔","chapter":29,"verse":10,"text":"그러므로 내가 너와 네 강들을 쳐서 애굽 땅 믹돌에서부터 수에네 곧 구스 지경까지 황무한 황무지 곧 사막이 되게 하리니","reference":"에스겔 29:10","category":"$undefined"},{"id":"21195","book":"에스겔","book_name":"에스겔","chapter":29,"verse":11,"text":"그 가운데로 사람의 발도 지나가지 아니하며 짐승의 발도 지나가지 아니하고 거접하는 사람이 없이 사십년이 지날지라","reference":"에스겔 29:11","category":"$undefined"},{"id":"21196","book":"에스겔","book_name":"에스겔","chapter":29,"verse":12,"text":"내가 애굽땅으로 황무한 열국 같이 황무하게 하며 애굽 성읍도 사막이 된 열국의 성읍 같이 사십년 동안 황무하게 하고 애굽 사람들은 각국 가운데로 흩으며 열방 가운데로 헤치리라","reference":"에스겔 29:12","category":"$undefined"},{"id":"21197","book":"에스겔","book_name":"에스겔","chapter":29,"verse":13,"text":"나 주 여호와가 말하노라 사십년 끝에 내가 만민 중에 흩은 애굽사람을 다시 모아 내되","reference":"에스겔 29:13","category":"$undefined"},{"id":"21198","book":"에스겔","book_name":"에스겔","chapter":29,"verse":14,"text":"애굽의 사로잡힌 자들을 돌이켜 바드로스 땅 곧 그 고토로 돌아가게 할 것이라 그들이 거기서 미약한 나라가 되되","reference":"에스겔 29:14","category":"$undefined"},{"id":"21199","book":"에스겔","book_name":"에스겔","chapter":29,"verse":15,"text":"나라 중에 지극히 미약한 나라가 되어 다시는 열국 위에 스스로 높이지 못하리니 내가 그들을 감하여 다시는 열국을 다스리지 못하게 할 것임이라","reference":"에스겔 29:15","category":"$undefined"},{"id":"21200","book":"에스겔","book_name":"에스겔","chapter":29,"verse":16,"text":"그들이 다시는 이스라엘 족속의 의뢰가 되지 못할 것이요 이스라엘 족속은 돌이켜 그들을 바라보지 아니하므로 그 죄악이 기억나게 되지 아니하리니 그들이 나를 주 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 29:16","category":"$undefined"},{"id":"21201","book":"에스겔","book_name":"에스겔","chapter":29,"verse":17,"text":"제 이십 칠년 정월 초 일일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 29:17","category":"$undefined"},{"id":"21202","book":"에스겔","book_name":"에스겔","chapter":29,"verse":18,"text":"인자야 바벨론 왕 느부갓네살이 그 군대로 두로를 치게 할 때에 크게 수고하여 각 머리털이 무지러졌고 각 어깨가 벗어졌으나 그와 군대가 그 수고한 보수를 두로에서 얻지 못하였느니라","reference":"에스겔 29:18","category":"$undefined"},{"id":"21203","book":"에스겔","book_name":"에스겔","chapter":29,"verse":19,"text":"그러므로 나 주 여호와가 말하노라 내가 애굽 땅을 바벨론 왕 느부갓네살에게 붙이리니 그가 그 무리를 옮겨가며 물건을 노략하며 빼앗아 갈 것이라 이것이 그 군대의 보수가 되리라","reference":"에스겔 29:19","category":"$undefined"},{"id":"21204","book":"에스겔","book_name":"에스겔","chapter":29,"verse":20,"text":"그들의 수고는 나를 위하여 함인즉 그 보수로 내가 애굽 땅을 그에게 주었느니라 나 주 여호와의 말이니라","reference":"에스겔 29:20","category":"$undefined"},{"id":"21205","book":"에스겔","book_name":"에스겔","chapter":29,"verse":21,"text":"그 날에 내가 이스라엘 족속에게 한 뿔이 솟아나게 하고 내가 또 너로 그들 중에서 입을 열게 하리니 그들이 나를 여호와인줄 알리라","reference":"에스겔 29:21","category":"$undefined"}],"bookSlug":"ezekiel"}]
