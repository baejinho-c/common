2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":3,"verses":[{"id":"20504","book":"에스겔","book_name":"에스겔","chapter":3,"verse":1,"text":"그가 또 내게 이르시되 인자야 ! 너는 받는 것을 먹으라 너는 이 두루마리를 먹고 가서 이스라엘 족속에게 고하라 하시기로","reference":"에스겔 3:1","category":"$undefined"},{"id":"20505","book":"에스겔","book_name":"에스겔","chapter":3,"verse":2,"text":"내가 입을 벌리니 그가 그 두루마리를 내게 먹이시며","reference":"에스겔 3:2","category":"$undefined"},{"id":"20506","book":"에스겔","book_name":"에스겔","chapter":3,"verse":3,"text":"내게 이르시되 인자야 ! 내가 네게 주는 이 두루마리로 네 배에 넣으며 네 창자에 채우라 하시기에 내가 먹으니 그것이 내 입에서 달기가 꿀 같더라","reference":"에스겔 3:3","category":"$undefined"},{"id":"20507","book":"에스겔","book_name":"에스겔","chapter":3,"verse":4,"text":"그가 또 내게 이르시되 인자야 ! 이스라엘 족속에게 가서 내 말로 그들에게 고하라","reference":"에스겔 3:4","category":"$undefined"},{"id":"20508","book":"에스겔","book_name":"에스겔","chapter":3,"verse":5,"text":"너를 방언이 다르거나 말이 어려운 백성에게 보내는 것이 아니요 이스라엘 족속에게 보내는 것이라","reference":"에스겔 3:5","category":"$undefined"},{"id":"20509","book":"에스겔","book_name":"에스겔","chapter":3,"verse":6,"text":"너를 방언이 다르거나 말이 어려워 네가 알아듣지 못할 열국에 보내는 것이 아니니라 내가 너를 그들에게 보내었더면 그들은 정녕 네 말을 들었으리라","reference":"에스겔 3:6","category":"$undefined"},{"id":"20510","book":"에스겔","book_name":"에스겔","chapter":3,"verse":7,"text":"그러나 이스라엘 족속은 이마가 굳고 마음이 강퍅하여 네 말을 듣고자 아니하리니 이는 내 말을 듣고자 아니함이니라","reference":"에스겔 3:7","category":"$undefined"},{"id":"20511","book":"에스겔","book_name":"에스겔","chapter":3,"verse":8,"text":"내가 그들의 얼굴을 대하도록 네 얼굴을 굳게 하였고 그들의 이마를 대하도록 네 이마를 굳게 하였으되","reference":"에스겔 3:8","category":"$undefined"},{"id":"20512","book":"에스겔","book_name":"에스겔","chapter":3,"verse":9,"text":"네 이마로 화석보다 굳은 금강석 같이 하였으니 그들이 비록 패역한 족속이라도 두려워 말며 그 얼굴을 무서워 말라 하시고","reference":"에스겔 3:9","category":"$undefined"},{"id":"20513","book":"에스겔","book_name":"에스겔","chapter":3,"verse":10,"text":"또 내게 이르시되 인자야 ! 내가 네게 이를 모든 말을 너는 마음으로 받으며 귀로 듣고","reference":"에스겔 3:10","category":"$undefined"},{"id":"20514","book":"에스겔","book_name":"에스겔","chapter":3,"verse":11,"text":"사로잡힌 네 민족에게로 가서 그들이 듣든지 아니 듣든지 그들에게 고하여 이르기를 주 여호와의 말씀이 이러하시다 하라 하시더라","reference":"에스겔 3:11","category":"$undefined"},{"id":"20515","book":"에스겔","book_name":"에스겔","chapter":3,"verse":12,"text":"때에 주의 신이 나를 들어 올리시는데 내 뒤에 크게 울리는 소리가 들려 이르기를 여호와의 처소에서 나는 영광을 찬송할지어다 하니","reference":"에스겔 3:12","category":"$undefined"},{"id":"20516","book":"에스겔","book_name":"에스겔","chapter":3,"verse":13,"text":"이는 생물들의 날개가 서로 부딪히는 소리와 생물 곁에 바퀴 소리라 크게 울리는 소리더라","reference":"에스겔 3:13","category":"$undefined"},{"id":"20517","book":"에스겔","book_name":"에스겔","chapter":3,"verse":14,"text":"주의 신이 나를 들어올려 데리고 가시는데 내가 근심하고 분한 마음으로 행하니 여호와의 권능이 힘있게 나를 감동하시더라","reference":"에스겔 3:14","category":"$undefined"},{"id":"20518","book":"에스겔","book_name":"에스겔","chapter":3,"verse":15,"text":"이에 내가 델아빕에 이르러 그 사로잡힌 백성 곧 그발강 가에 거하는 자들에게 나아가 그 중에서 민답히 칠일을 지내니라","reference":"에스겔 3:15","category":"$undefined"},{"id":"20519","book":"에스겔","book_name":"에스겔","chapter":3,"verse":16,"text":"칠일 후에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 3:16","category":"$undefined"},{"id":"20520","book":"에스겔","book_name":"에스겔","chapter":3,"verse":17,"text":"인자야 ! 내가 너를 이스라엘 족속의 파숫군으로 세웠으니 너는 내 입의 말을 듣고 나를 대신하여 그들을 깨우치라","reference":"에스겔 3:17","category":"$undefined"},{"id":"20521","book":"에스겔","book_name":"에스겔","chapter":3,"verse":18,"text":"가령 내가 악인에게 말하기를 너는 꼭 죽으리라 할 때에 네가 깨우치지 아니하거나 말로 악인에게 일러서 그 악한 길을 떠나 생명을 구원케 하지 아니하면 그 악인은 그 죄악 중에서 죽으려니와 내가 그 피 값을 네 손에서 찾을 것이고","reference":"에스겔 3:18","category":"$undefined"},{"id":"20522","book":"에스겔","book_name":"에스겔","chapter":3,"verse":19,"text":"네가 악인을 깨우치되 그가 그 악한 마음과 악한 행위에서 돌이키지 아니하면 그는 그 죄악 중에서 죽으려니와 너는 네 생명을 보존하리라","reference":"에스겔 3:19","category":"$undefined"},{"id":"20523","book":"에스겔","book_name":"에스겔","chapter":3,"verse":20,"text":"또 의인이 그 의에서 돌이켜 악을 행할 때에는 이미 행한 그 의는 기억할 바 아니라 내가 그 앞에 거치는 것을 두면 그가 죽을지니 이는 네가 그를 깨우치지 않음이라 그가 그 죄 중에서 죽으려니와 그 피 값은 내가 네 손에서 찾으리라","reference":"에스겔 3:20","category":"$undefined"},{"id":"20524","book":"에스겔","book_name":"에스겔","chapter":3,"verse":21,"text":"그러나 네가 그 의인을 깨우쳐 범죄치 않게 하므로 그가 범죄치 아니하면 정녕 살리니 이는 깨우침을 받음이며 너도 네 영혼을 보존하리라","reference":"에스겔 3:21","category":"$undefined"},{"id":"20525","book":"에스겔","book_name":"에스겔","chapter":3,"verse":22,"text":"여호와께서 권능으로 거기서 내게 임하시고 또 내게 이르시되 일어나 들로 나아가라 내가 거기서 너와 말하리라 하시기로","reference":"에스겔 3:22","category":"$undefined"},{"id":"20526","book":"에스겔","book_name":"에스겔","chapter":3,"verse":23,"text":"내가 일어나 들로 나아가니 여호와의 영광이 거기 머물렀는데 내가 전에 그발강 가에서 보던 영광과 같은지라 내가 곧 엎드리니","reference":"에스겔 3:23","category":"$undefined"},{"id":"20527","book":"에스겔","book_name":"에스겔","chapter":3,"verse":24,"text":"주의 신이 내게 임하사 나를 일으켜 세우시고 내게 말씀하여 가라사대 너는 가서 네 집에 들어가 문을 닫으라","reference":"에스겔 3:24","category":"$undefined"},{"id":"20528","book":"에스겔","book_name":"에스겔","chapter":3,"verse":25,"text":"인자야 ! 무리가 줄로 너를 동여매리니 네가 그들 가운데서 나오지 못할 것이라","reference":"에스겔 3:25","category":"$undefined"},{"id":"20529","book":"에스겔","book_name":"에스겔","chapter":3,"verse":26,"text":"내가 네 혀로 네 입천장에 붙게 하여 너로 벙어리 되어 그들의 책망자가 되지 못하게 하리니 그들은 패역한 족속임이니라","reference":"에스겔 3:26","category":"$undefined"},{"id":"20530","book":"에스겔","book_name":"에스겔","chapter":3,"verse":27,"text":"그러나 내가 너와 말할 때에 네 입을 열리니 너는 그들에게 이르기를 주 여호와의 말씀이 이러하시다 하라 들을 자는 들을 것이요 듣기 싫은 자는 듣지 아니하리니 그들은 패역한 족속임이니라","reference":"에스겔 3:27","category":"$undefined"}],"bookSlug":"ezekiel"}]
