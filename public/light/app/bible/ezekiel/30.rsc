2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":30,"verses":[{"id":"21206","book":"에스겔","book_name":"에스겔","chapter":30,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 30:1","category":"$undefined"},{"id":"21207","book":"에스겔","book_name":"에스겔","chapter":30,"verse":2,"text":"인자야 너는 예언하여 이르라 주 여호와의 말씀에 너희는 통곡하며 이르기를 슬프다 이 날이여 하라","reference":"에스겔 30:2","category":"$undefined"},{"id":"21208","book":"에스겔","book_name":"에스겔","chapter":30,"verse":3,"text":"그 날이 가까왔도다 여호와의 날이 가까왔도다 구름의 날일 것이요 열국의 때이리로다","reference":"에스겔 30:3","category":"$undefined"},{"id":"21209","book":"에스겔","book_name":"에스겔","chapter":30,"verse":4,"text":"애굽에 칼이 임할 것이라 애굽에서 살륙 당한 자들이 엎드러질 때에 구스에 심한 근심이 있을 것이며 애굽의 무리가 옮기우며 그 기지가 헐릴 것이요","reference":"에스겔 30:4","category":"$undefined"},{"id":"21210","book":"에스겔","book_name":"에스겔","chapter":30,"verse":5,"text":"구스와 붓과 룻과 모든 섞인 백성과 굽과 및 동맹한 땅의 백성들이 그들과 함께 칼에 엎드러지리라","reference":"에스겔 30:5","category":"$undefined"},{"id":"21211","book":"에스겔","book_name":"에스겔","chapter":30,"verse":6,"text":"나 여호와가 말하노라 애굽을 붙들어 주는 자도 엎드러질 것이요 애굽의 교만한 권세도 낮아질 것이라 믹돌에서부터 수에네까지 무리가 그 가운데서 칼에 엎드러지리라 나 주 여호와의 말이니라","reference":"에스겔 30:6","category":"$undefined"},{"id":"21212","book":"에스겔","book_name":"에스겔","chapter":30,"verse":7,"text":"황무한 열방 같이 그들도 황무할 것이며 사막이 된 성읍들 같이 그 성읍들도 사막이 될 것이라","reference":"에스겔 30:7","category":"$undefined"},{"id":"21213","book":"에스겔","book_name":"에스겔","chapter":30,"verse":8,"text":"내가 애굽에 불을 일으키며 그 모든 돕는 자를 멸할 때에 그들이 나를 여호와인 줄 알리라","reference":"에스겔 30:8","category":"$undefined"},{"id":"21214","book":"에스겔","book_name":"에스겔","chapter":30,"verse":9,"text":"그 날에 사자들이 내 앞에서 배로 나아가서 염려 없는 구스 사람을 두렵게 하리니 애굽의 재앙의 날과 같이 그들에게도 심한 근심이 있으리라 이것이 오리로다","reference":"에스겔 30:9","category":"$undefined"},{"id":"21215","book":"에스겔","book_name":"에스겔","chapter":30,"verse":10,"text":"나 주 여호와가 말하노라 내가 또 바벨론 왕 느부갓네살의 손으로 애굽 무리들을 끊으리니","reference":"에스겔 30:10","category":"$undefined"},{"id":"21216","book":"에스겔","book_name":"에스겔","chapter":30,"verse":11,"text":"그가 열국 중에 강포한 자기 군대를 거느리고 와서 그 땅을 멸할때에 칼을 빼어 애굽을 쳐서 살륙 당한 자로 땅에 가득하게 하리라","reference":"에스겔 30:11","category":"$undefined"},{"id":"21217","book":"에스겔","book_name":"에스겔","chapter":30,"verse":12,"text":"내가 그 모든 강을 말리우고 그 땅을 악인의 손에 팔겠으며 타국 사람의 손으로 그 땅과 그 가운데 있는 모든 것을 황무케 하리라 나 여호와의 말이니라","reference":"에스겔 30:12","category":"$undefined"},{"id":"21218","book":"에스겔","book_name":"에스겔","chapter":30,"verse":13,"text":"나 주 여호와가 말하노라 내가 그 우상들을 멸하며 신상들을 놉 가운데서 끊으며 애굽 땅에서 왕이 다시 나지 못하게 하고 그 땅에 두려움이 있게 하리라","reference":"에스겔 30:13","category":"$undefined"},{"id":"21219","book":"에스겔","book_name":"에스겔","chapter":30,"verse":14,"text":"내가 바드로스를 황무케 하며 소안에 불을 일으키며 노를 국문하며","reference":"에스겔 30:14","category":"$undefined"},{"id":"21220","book":"에스겔","book_name":"에스겔","chapter":30,"verse":15,"text":"내 분노를 애굽의 견고한 성 신에 쏟고 또 노의 무리를 끊을 것이라","reference":"에스겔 30:15","category":"$undefined"},{"id":"21221","book":"에스겔","book_name":"에스겔","chapter":30,"verse":16,"text":"내가 애굽에 불을 일으키리니 신이 심히 근심할 것이며 노는 찢어 나뉠 것이며 놉은 날로 대적이 있을 것이며","reference":"에스겔 30:16","category":"$undefined"},{"id":"21222","book":"에스겔","book_name":"에스겔","chapter":30,"verse":17,"text":"아웬과 비베셋의 소년들은 칼에 엎드러질 것이며 그 성읍 거민들은 포로될 것이라","reference":"에스겔 30:17","category":"$undefined"},{"id":"21223","book":"에스겔","book_name":"에스겔","chapter":30,"verse":18,"text":"내가 애굽 멍에를 꺾으며 그 교만한 권세를 그 가운데서 그치게 할 때에 드합느헤스에서는 날이 어둡겠고 그 성읍에는 구름이 덮일 것이며 그 딸들은 포로 될 것이라","reference":"에스겔 30:18","category":"$undefined"},{"id":"21224","book":"에스겔","book_name":"에스겔","chapter":30,"verse":19,"text":"이와 같이 내가 애굽을 국문하리니 그들이 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 30:19","category":"$undefined"},{"id":"21225","book":"에스겔","book_name":"에스겔","chapter":30,"verse":20,"text":"제 십일년 정월 칠일에 여호와의 말씀이 네게 임하여 가라사대","reference":"에스겔 30:20","category":"$undefined"},{"id":"21226","book":"에스겔","book_name":"에스겔","chapter":30,"verse":21,"text":"인자야 내가 애굽 왕 바로의 팔을 꺾었더니 칼을 잡을 힘이 있도록 그것을 그저 싸매지도 못하였고 약을 붙여 싸매지도 못하였느니라","reference":"에스겔 30:21","category":"$undefined"},{"id":"21227","book":"에스겔","book_name":"에스겔","chapter":30,"verse":22,"text":"그러므로 나 주 여호와가 말하노라 내가 애굽 왕 바로를 대적하여 그 두 팔 곧 성한 팔과 이미 꺾인 팔을 꺾어서 칼이 그 손에서 떨어지게 하고","reference":"에스겔 30:22","category":"$undefined"},{"id":"21228","book":"에스겔","book_name":"에스겔","chapter":30,"verse":23,"text":"애굽 사람을 열국 가운데로 흩으며 열방 가운데로 헤칠지라","reference":"에스겔 30:23","category":"$undefined"},{"id":"21229","book":"에스겔","book_name":"에스겔","chapter":30,"verse":24,"text":"내가 바벨론 왕의 팔을 견고하게 하고 내 칼을 그 손에 붙이려니와 내가 바로의 팔을 꺾으리니 그가 바벨론 왕의 앞에서 고통하기를 죽게 상한 자의 고통하듯 하리라","reference":"에스겔 30:24","category":"$undefined"},{"id":"21230","book":"에스겔","book_name":"에스겔","chapter":30,"verse":25,"text":"내가 바벨론 왕의 팔은 들어 주고 바로의 팔은 떨어뜨릴 것이라 내가 내 칼을 바벨론 왕의 손에 붙이고 그로 들어 애굽 땅을 치게 하리니 그들이 나를 여호와인 줄 알겠고","reference":"에스겔 30:25","category":"$undefined"},{"id":"21231","book":"에스겔","book_name":"에스겔","chapter":30,"verse":26,"text":"내가 애굽 사람을 열국 가운데로 흩으며 열방 가운데로 헤치리니 그들이 나를 여호와인 줄 알리라","reference":"에스겔 30:26","category":"$undefined"}],"bookSlug":"ezekiel"}]
