2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":31,"verses":[{"id":"21232","book":"에스겔","book_name":"에스겔","chapter":31,"verse":1,"text":"제 십 일년 삼월 초 일일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 31:1","category":"$undefined"},{"id":"21233","book":"에스겔","book_name":"에스겔","chapter":31,"verse":2,"text":"인자야 너는 애굽 왕 바로와 그 무리에게 이르기를 네 큰 위엄을 뉘게 비하랴","reference":"에스겔 31:2","category":"$undefined"},{"id":"21234","book":"에스겔","book_name":"에스겔","chapter":31,"verse":3,"text":"볼지어다 앗수르 사람은 가지가 아름답고 그늘은 삼림의 그늘 같으며 키가 높고 꼭대기가 구름에 닿은 레바논 백향목이었느니라","reference":"에스겔 31:3","category":"$undefined"},{"id":"21235","book":"에스겔","book_name":"에스겔","chapter":31,"verse":4,"text":"물들이 그것을 기르며 깊은 물이 그것을 자라게 하며 강들이 그 심긴 곳을 둘러 흐르며 보의 물이 들의 모든 나무에까지 미치매","reference":"에스겔 31:4","category":"$undefined"},{"id":"21236","book":"에스겔","book_name":"에스겔","chapter":31,"verse":5,"text":"그 나무가 물이 많으므로 키가 들의 모든 나무보다 높으며 굵은 가지가 번성하며 가는 가지가 길게 빼어났고","reference":"에스겔 31:5","category":"$undefined"},{"id":"21237","book":"에스겔","book_name":"에스겔","chapter":31,"verse":6,"text":"공중의 모든 새가 그 큰 가지에 깃들이며 들의 모든 짐승이 그 가는 가지 밑에 새끼를 낳으며 모든 큰 나라가 그 그늘 아래 거하였었느니라","reference":"에스겔 31:6","category":"$undefined"},{"id":"21238","book":"에스겔","book_name":"에스겔","chapter":31,"verse":7,"text":"그 뿌리가 큰 물가에 있으므로 그 나무가 크고 가지가 길어 모양이 아름다우매","reference":"에스겔 31:7","category":"$undefined"},{"id":"21239","book":"에스겔","book_name":"에스겔","chapter":31,"verse":8,"text":"하나님의 동산의 백향목이 능히 그를 가리우지 못하며 잣나무가 그 굵은 가지만 못하며 단풍나무가 그 가는 가지만 못하며 하나님의 동산의 아무 나무도 그 아름다운 모양과 같지 못하였도다","reference":"에스겔 31:8","category":"$undefined"},{"id":"21240","book":"에스겔","book_name":"에스겔","chapter":31,"verse":9,"text":"내가 그 가지로 많게 하여 모양이 아름답게 하였더니 하나님의 동산 에덴에 있는 모든 나무가지가 다 투기하였느니라","reference":"에스겔 31:9","category":"$undefined"},{"id":"21241","book":"에스겔","book_name":"에스겔","chapter":31,"verse":10,"text":"그러므로 나 주 여호와가 말하노라 그의 키가 높고 꼭대기가 구름에 닿아서 높이 빼어났으므로 마음이 교만하였은즉","reference":"에스겔 31:10","category":"$undefined"},{"id":"21242","book":"에스겔","book_name":"에스겔","chapter":31,"verse":11,"text":"내가 열국의 능한 자의 손에 붙일지라 그가 임의로 대접할 것은 내가 그의 악을 인하여 쫓아 내었음이라","reference":"에스겔 31:11","category":"$undefined"},{"id":"21243","book":"에스겔","book_name":"에스겔","chapter":31,"verse":12,"text":"열국의 강포한 다른 민족이 그를 찍어버렸으므로 그 가는 가지가 산과 모든 골짜기에 떨어졌고 그 굵은 가지가 그 땅 모든 물가에 꺽어졌으며 세상 모든 백성이 그를 버리고 그 그늘 아래서 떠나매","reference":"에스겔 31:12","category":"$undefined"},{"id":"21244","book":"에스겔","book_name":"에스겔","chapter":31,"verse":13,"text":"공중의 모든 새가 그 넘어진 나무에 거하며 들의 모든 짐승이 그 가지에 있으리니","reference":"에스겔 31:13","category":"$undefined"},{"id":"21245","book":"에스겔","book_name":"에스겔","chapter":31,"verse":14,"text":"이는 물 가에 있는 모든 나무로 키가 높다고 교만치 못하게 하며 그 꼭대기로 구름에 닿지 못하게 하며 또 물 대임을 받는 능한 자로 스스로 높아 서지 못하게 함이니 그들을 다 죽는데 붙여서 인생 중 구덩이로 내려가는 자와 함께 지하로 내려가게 하였음이니라","reference":"에스겔 31:14","category":"$undefined"},{"id":"21246","book":"에스겔","book_name":"에스겔","chapter":31,"verse":15,"text":"나 주 여호와가 말하노라 그가 음부에 내려가던 날에 내가 그를 위하여 애곡하게 하며 깊은 바다를 덮으며 모든 강을 쉬게 하며 큰 물을 그치게 하고 레바논으로 그를 위하여 애곡하게 하며 들의 모든 나무로 그로 인하여 쇠잔하게 하였느니라","reference":"에스겔 31:15","category":"$undefined"},{"id":"21247","book":"에스겔","book_name":"에스겔","chapter":31,"verse":16,"text":"내가 그로 구덩이에 내려가는 자와 함께 음부에 떨어뜨리던 때에 열국으로 그 떨어지는 소리를 인하여 진동하게 하였고 물 대임을받은 에덴의 모든 나무 곧 레바논의 뛰어나고 아름다운 나무들로 지하에서 위로를 받게 하였느니라","reference":"에스겔 31:16","category":"$undefined"},{"id":"21248","book":"에스겔","book_name":"에스겔","chapter":31,"verse":17,"text":"그러나 그들도 그와 함께 음부에 내려 칼에 살륙을 당한 자에게 이르렀나니 그들은 옛적에 그의 팔이 된 자요 열국 중에서 그 그늘 아래 거하던 자니라","reference":"에스겔 31:17","category":"$undefined"},{"id":"21249","book":"에스겔","book_name":"에스겔","chapter":31,"verse":18,"text":"너의 영화와 광대함이 에덴 모든 나무 중에 어떤 것과 같은고 그러나 네가 에덴 나무와 함께 지하에 내려갈 것이요 거기서 할례 받지 못하고 칼에 살륙 당한 자 중에 누우리라 이들은 바로와 그 모든 군대니라 나 주 여호와의 말이니라 하라","reference":"에스겔 31:18","category":"$undefined"}],"bookSlug":"ezekiel"}]
