11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":32,"verses":[{"id":"21250","book":"에스겔","book_name":"에스겔","chapter":32,"verse":1,"text":"제 십 이년 십 이월 초일일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 32:1","category":"$undefined"},{"id":"21251","book":"에스겔","book_name":"에스겔","chapter":32,"verse":2,"text":"인자야 너는 애굽 왕 바로에 대하여 애가를 불러 그에게 이르라 너를 열국에서 젊은 사자에 비하였더니 실상은 바다 가운데 큰 악어라 강에서 뛰어 일어나 발로 물을 요동하여 그 강을 더럽혔도다","reference":"에스겔 32:2","category":"$undefined"},{"id":"21252","book":"에스겔","book_name":"에스겔","chapter":32,"verse":3,"text":"나 주 여호와의 말이여 내가 많은 백성의 무리를 거느리고 내 그물을 네 위에 치고 그 그물로 너를 끌어 오리로다","reference":"에스겔 32:3","category":"$undefined"},{"id":"21253","book":"에스겔","book_name":"에스겔","chapter":32,"verse":4,"text":"내가 너를 뭍에 버리며 들에 던져 공중의 새들로 네 위에 앉게 할 것임이며 온 땅의 짐승으로 너를 먹어 배부르게 하리로다","reference":"에스겔 32:4","category":"$undefined"},{"id":"21254","book":"에스겔","book_name":"에스겔","chapter":32,"verse":5,"text":"내가 네 고기를 여러 산에 두며 네 시체를 여러 골짜기에 채울 것임이여","reference":"에스겔 32:5","category":"$undefined"},{"id":"21255","book":"에스겔","book_name":"에스겔","chapter":32,"verse":6,"text":"네 피로 네 헤엄치는 땅에 물 대듯하여 산에 미치게 하며 그 모든 개천에 채우리로다","reference":"에스겔 32:6","category":"$undefined"},{"id":"21256","book":"에스겔","book_name":"에스겔","chapter":32,"verse":7,"text":"내가 너를 불 끄듯 할 때에 하늘을 가리워 별로 어둡게 하며 해를 구름으로 가리우며 달로 빛을 발하지 못하게 할 것임이여","reference":"에스겔 32:7","category":"$undefined"},{"id":"21257","book":"에스겔","book_name":"에스겔","chapter":32,"verse":8,"text":"하늘의 모든 밝은 빛을 내가 네 위에서 어둡게 하여 어두움을 네 땅에 베풀리로다 나 주 여호와의 말이로다","reference":"에스겔 32:8","category":"$undefined"},{"id":"21258","book":"에스겔","book_name":"에스겔","chapter":32,"verse":9,"text":"내가 네 패망의 소문으로 열국 곧 너의 알지 못하는 열방에 이르게 할 때에 많은 백성의 마음을 번뇌케 할 것임이여","reference":"에스겔 32:9","category":"$undefined"},{"id":"21259","book":"에스겔","book_name":"에스겔","chapter":32,"verse":10,"text":"내가 그 많은 백성으로 너를 인하여 놀라게 할 것이며 내가 내 칼로 그들의 왕 앞에서 춤추게 할 때에 그 왕이 너를 인하여 심히 두려워할 것이며 네가 엎드러지는 날에 그들이 각각 자기 생명을 위하여 무시로 떨리로다","reference":"에스겔 32:10","category":"$undefined"},{"id":"21260","book":"에스겔","book_name":"에스겔","chapter":32,"verse":11,"text":"나 주 여호와가 말함이여 바벨론 왕의 칼이 네게 임하리로다","reference":"에스겔 32:11","category":"$undefined"},{"id":"21261","book":"에스겔","book_name":"에스겔","chapter":32,"verse":12,"text":"내가 네 무리로 용사 곧 열국의 무서운 자들의 칼에 엎드러지게 할 것임이여 그들이 애굽의 교만을 폐하며 그 모든 무리를 멸하리로다","reference":"에스겔 32:12","category":"$undefined"},{"id":"21262","book":"에스겔","book_name":"에스겔","chapter":32,"verse":13,"text":"내가 또 그 모든 짐승을 큰 물가에서 멸하리니 사람의 발이나 짐승의 굽이 다시는 그 물을 흐리지 못할 것임이여","reference":"에스겔 32:13","category":"$undefined"},{"id":"21263","book":"에스겔","book_name":"에스겔","chapter":32,"verse":14,"text":"그 때에 내가 그 물을 맑게 하여 그 강으로 기름 같이 흐르게 하리로다 나 주 여호와의 말이로다","reference":"에스겔 32:14","category":"$undefined"},{"id":"21264","book":"에스겔","book_name":"에스겔","chapter":32,"verse":15,"text":"내가 애굽 땅으로 황무하여 사막이 되게 하여 거기 풍성한 것이 없게 할 것임이여 그 가운데 모든 거민을 치리니 그들이 나를 여호와인 줄 알리로다","reference":"에스겔 32:15","category":"$undefined"},{"id":"21265","book":"에스겔","book_name":"에스겔","chapter":32,"verse":16,"text":"이는 슬피 부를 애가니 열국 여자들이 이것을 슬피 부름이여 애굽과 그 모든 무리를 위하여 이것을 슬피 부르리로다 나 주 여호와의 말이로다 하라","reference":"에스겔 32:16","category":"$undefined"},{"id":"21266","book":"에스겔","book_name":"에스겔","chapter":32,"verse":17,"text":"제 십 이년 어느 달 십 오일에 여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 32:17","category":"$undefined"},{"id":"21267","book":"에스겔","book_name":"에스겔","chapter":32,"verse":18,"text":"인자야 애굽의 무리를 애곡하고 그와 유명한 나라 여자들을 구덩이에 내려가는 자와 함께 지하에 던지며","reference":"에스겔 32:18","category":"$undefined"},{"id":"21268","book":"에스겔","book_name":"에스겔","chapter":32,"verse":19,"text":"이르라 너의 아름다움이 누구보다 지나가는고 너는 내려가서 할례 받지 않은 자와 함께 뉘울지어다","reference":"에스겔 32:19","category":"$undefined"},{"id":"21269","book":"에스겔","book_name":"에스겔","chapter":32,"verse":20,"text":"그들이 살륙 당한 자 중에 엎드러질 것임이여 그는 칼에 붙인바 되었은즉 그와 그 모든 무리를 끌지어다","reference":"에스겔 32:20","category":"$undefined"},{"id":"21270","book":"에스겔","book_name":"에스겔","chapter":32,"verse":21,"text":"용사 중에 강한 자가 그를 돕는 자와 함께 음부 가운데서 그에게 말함이여 할례 받지 않은 자 곧 칼에 살륙 당한 자들이 내려와서 가만히 누웠다 하리로다","reference":"에스겔 32:21","category":"$undefined"},{"id":"21271","book":"에스겔","book_name":"에스겔","chapter":32,"verse":22,"text":"거기 앗수르와 그 온 무리가 있음이여 다 살륙을 당하여 칼에 엎드러진 자라 그 무덤이 그 사방에 있도다","reference":"에스겔 32:22","category":"$undefined"},{"id":"21272","book":"에스겔","book_name":"에스겔","chapter":32,"verse":23,"text":"그 무덤이 구덩이 깊은 곳에 베풀렸고 그 무리가 그 무덤 사방에 있음이여 그들은 다 살륙을 당하여 칼에 엎드러진 자 곧 생존 세상에서 사람을 두렵게 하던 자로다","reference":"에스겔 32:23","category":"$undefined"},{"id":"21273","book":"에스겔","book_name":"에스겔","chapter":32,"verse":24,"text":"거기 엘람이 있고 그 모든 무리가 그 무덤 사면에 있음이여 그들은 다 할례를 받지 못하고 살륙을 당하여 칼에 엎드러져 지하에 내려간 자로다 그들이 생존 세상에서 두렵게 하였었으나 이제는 구덩이에 내려가는 자와 함께 수치를 당하였도다","reference":"에스겔 32:24","category":"$undefined"},{"id":"21274","book":"에스겔","book_name":"에스겔","chapter":32,"verse":25,"text":"그와 그 모든 무리를 위하여 침상을 살륙 당한 자 중에 베풀었고 그 여러 무덤은 사면에 있음이여 그들은 다 할례를 받지 못하고 칼에 살륙을 당한 자로다 그들이 생존 세상에서 두렵게 하였었으나 이제는 구덩이에 내려가는 자와 함께 수치를 당하고 살륙 당한 자 중에 뉘었도다","reference":"에스겔 32:25","category":"$undefined"},{"id":"21275","book":"에스겔","book_name":"에스겔","chapter":32,"verse":26,"text":"거기 메섹과 두발과 그 모든 무리가 있고 그 여러 무덤은 사면에 있음이여 그들은 다 할례를 받지 못하고 칼에 살륙을 당한 자로다 그들이 생존 세상에서 두렵게 하였었으나","reference":"에스겔 32:26","category":"$undefined"},{"id":"21276","book":"에스겔","book_name":"에스겔","chapter":32,"verse":27,"text":"그들이 할례 받지 못한 자 중에 이미 엎드러진 용사와 함께 누운 것이 마땅치 아니하냐 이 용사들은 다 병기를 가지고 음부에 내려 자기의 칼을 베게 하였으니 그 백골이 자기 죄악을 졌음이여 생존 세상에서 용사의 두려움이 있던 자로다","reference":"에스겔 32:27","category":"$undefined"},{"id":"21277","book":"에스겔","book_name":"에스겔","chapter":32,"verse":28,"text":"오직 너는 할례 받지 못한 자와 일반으로 패망할 것임이여 칼에 살륙 당한 자와 함께 누우리로다","reference":"에스겔 32:28","category":"$undefined"},{"id":"21278","book":"에스겔","book_name":"에스겔","chapter":32,"verse":29,"text":"거기 에돔 곧 그 열왕과 그 모든 방백이 있음이여 그들이 강성하였었으나 칼에 살륙 당한 자와 함께 있겠고 할례 받지 못하고 구덩이에 내려간 자와 함께 누우리로다","reference":"에스겔 32:29","category":"$undefined"},{"id":"21279","book":"에스겔","book_name":"에스겔","chapter":32,"verse":30,"text":"거기 살륙 당한 자와 함께 내려간 북방 모든 방백과 모든 시돈 사람이 있음이여 그들이 본래는 강성하였으므로 두렵게 하였었으나 이제는 부끄러움을 품고 할례 받지 못하고 칼에 살륙 당한 자와 함께 누웠고 구덩이에 내려가는 자와 함께 수욕을 당하였도다","reference":"에스겔 32:30","category":"$undefined"},{"id":"21280","book":"에스겔","book_name":"에스겔","chapter":32,"verse":31,"text":"바로가 그들을 보고 그 모든 무리로 인하여 위로를 받을 것임이여 칼에 살륙당한 바로와 그 온 군대가 그러하리로다 나 주 여호와의 말이로다","reference":"에스겔 32:31","category":"$undefined"},{"id":"21281","book":"에스겔","book_name":"에스겔","chapter":32,"verse":32,"text":"내가 바로로 생존 세상에서 사람을 두렵게 하게 하였었으나 이제는 그가 그 모든 무리로 더불어 할례받지 못한 자 곧 칼에 살륙 당한 자와 함께 뉘우리로다 나 주 여호와의 말이로다","reference":"에스겔 32:32","category":"$undefined"}],"bookSlug":"ezekiel"}]
