2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":33,"verses":[{"id":"21282","book":"에스겔","book_name":"에스겔","chapter":33,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 33:1","category":"$undefined"},{"id":"21283","book":"에스겔","book_name":"에스겔","chapter":33,"verse":2,"text":"인자야 너는 네 민족에게 고하여 이르라 가령 내가 칼을 한 땅에 임하게 한다 하자 그 땅 백성이 자기 중에 하나를 택하여 파숫군을 삼은","reference":"에스겔 33:2","category":"$undefined"},{"id":"21284","book":"에스겔","book_name":"에스겔","chapter":33,"verse":3,"text":"그 사람이 칼이 그 땅에 임함을 보고 나팔을 불어 백성에게 경고하되","reference":"에스겔 33:3","category":"$undefined"},{"id":"21285","book":"에스겔","book_name":"에스겔","chapter":33,"verse":4,"text":"나팔 소리를 듣고도 경비를 하지 아니하므로 그 임하는 칼에 제함을 당하면 그 피가 자기의 머리로 돌아갈 것이라","reference":"에스겔 33:4","category":"$undefined"},{"id":"21286","book":"에스겔","book_name":"에스겔","chapter":33,"verse":5,"text":"그가 경비를 하였던들 자기 생명을 보전하였을 것이나 나팔 소리를 듣고도 경비를 하지 아니하였으니 그 피가 자기에게로 돌아가리라","reference":"에스겔 33:5","category":"$undefined"},{"id":"21287","book":"에스겔","book_name":"에스겔","chapter":33,"verse":6,"text":"그러나 파숫군이 칼이 임함을 보고도 나팔을 불지 아니하여 백성에게 경고치 아니하므로 그 중에 한 사람이 그 임하는 칼에 제함을 당하면 그는 자기 죄악 중에서 제한바 되려니와 그 죄를 내가 파숫군의 손에서 찾으리라","reference":"에스겔 33:6","category":"$undefined"},{"id":"21288","book":"에스겔","book_name":"에스겔","chapter":33,"verse":7,"text":"인자야 내가 너로 이스라엘 족속의 파숫군을 삼음이 이와 같으니라 그런즉 너는 내 입의 말을 듣고 나를 대신하여 그들에게 경고할지어다","reference":"에스겔 33:7","category":"$undefined"},{"id":"21289","book":"에스겔","book_name":"에스겔","chapter":33,"verse":8,"text":"가령 내가 악인에게 이르기를 악인아 너는 정녕 죽으리라 하였다하자 네가 그 악인에게 말로 경고하여 그 길에서 떠나게 아니하면 그 악인은 자기 죄악 중에서 죽으려니와 내가 그 피를 네 손에서 찾으리라","reference":"에스겔 33:8","category":"$undefined"},{"id":"21290","book":"에스겔","book_name":"에스겔","chapter":33,"verse":9,"text":"그러나 너는 악인에게 경고하여 돌이켜 그 길에서 떠나라고 하되 그가 돌이켜 그 길에서 떠나지 아니하면 그는 자기 죄악 중에서 죽으려니와 너는 네 생명을 보전하리라","reference":"에스겔 33:9","category":"$undefined"},{"id":"21291","book":"에스겔","book_name":"에스겔","chapter":33,"verse":10,"text":"그런즉 인자야 너는 이스라엘 족속에게 이르기를 너희가 말하여 이르되 우리의 허물과 죄가 이미 우리에게 있어 우리로 그 중에서 쇠패하게 하니 어찌 능히 살리요 하거니와","reference":"에스겔 33:10","category":"$undefined"},{"id":"21292","book":"에스겔","book_name":"에스겔","chapter":33,"verse":11,"text":"주 여호와의 말씀에 나의 삶을 두고 맹세하노니 나는 악인의 죽는 것을 기뻐하지 아니하고 악인이 그 길에서 돌이켜 떠나서 사는 것을 기뻐하노라 이스라엘 족속아 돌이키고 돌이키라 너희 악한 길에서 떠나라 어찌 죽고자 하느냐 하셨다 하라","reference":"에스겔 33:11","category":"$undefined"},{"id":"21293","book":"에스겔","book_name":"에스겔","chapter":33,"verse":12,"text":"인자야 너는 네 민족에게 이르기를 의인이 범죄하는 날에는 그 의가 구원치 못할 것이요 악이 돌이켜 그 악에서 떠나는 날에는 그 악이 그를 엎드러뜨리지 못할 것인즉 의인이 범죄하는 날에는 그 의로 인하여는 살지 못하리라","reference":"에스겔 33:12","category":"$undefined"},{"id":"21294","book":"에스겔","book_name":"에스겔","chapter":33,"verse":13,"text":"가령 내가 의인에게 말하기를 너는 살리라 하였다 하자 그가 그 의를 스스로 믿고 죄악을 행하면 그 모든 의로운 행위가 하나도 기억되지 아니하리니 그가 그 지은 죄악 중 곧 그 중에서 죽으리라","reference":"에스겔 33:13","category":"$undefined"},{"id":"21295","book":"에스겔","book_name":"에스겔","chapter":33,"verse":14,"text":"가령 내가 악인에게 말하기를 너는 죽으리라 하였다 하자 그가 돌이켜 자기의 죄에서 떠나서 법과 의대로 행하여","reference":"에스겔 33:14","category":"$undefined"},{"id":"21296","book":"에스겔","book_name":"에스겔","chapter":33,"verse":15,"text":"전당물을 도로 주며 억탈물을 돌려 보내고 생명의 율례를 준행하여 다시는 죄악을 짓지 아니하면 그가 정녕 살고 죽지 않을지라","reference":"에스겔 33:15","category":"$undefined"},{"id":"21297","book":"에스겔","book_name":"에스겔","chapter":33,"verse":16,"text":"그의 본래 범한 모든 죄가 기억되지 아니하리니 그가 정녕 살리라 이는 법과 의를 행하였음이니라 하라","reference":"에스겔 33:16","category":"$undefined"},{"id":"21298","book":"에스겔","book_name":"에스겔","chapter":33,"verse":17,"text":"그래도 네 민족은 말하기를 주의 길이 공평치 않다 하는도다 그러나 실상은 그들의 길이 공평치 아니하니라","reference":"에스겔 33:17","category":"$undefined"},{"id":"21299","book":"에스겔","book_name":"에스겔","chapter":33,"verse":18,"text":"만일 의인이 돌이켜 그 의에서 떠나 죄악을 지으면 그가 그 가운데서 죽을 것이고","reference":"에스겔 33:18","category":"$undefined"},{"id":"21300","book":"에스겔","book_name":"에스겔","chapter":33,"verse":19,"text":"만일 악인이 돌이켜 그 악에서 떠나 법과 의대로 행하면 그가 그로 인하여 살리라","reference":"에스겔 33:19","category":"$undefined"},{"id":"21301","book":"에스겔","book_name":"에스겔","chapter":33,"verse":20,"text":"그러나 너희가 이르기를 주의 길이 공평치 않다 하는도다 이스라엘 족속아 내가 너희의 각기 행한대로 심판하리라 하시니라","reference":"에스겔 33:20","category":"$undefined"},{"id":"21302","book":"에스겔","book_name":"에스겔","chapter":33,"verse":21,"text":"우리가 사로잡힌지 십 이년 시월 오일에 예루살렘에서부터 도망하여 온 자가 내게 나아와 말하기를 그 성이 함락되었다 하였는데","reference":"에스겔 33:21","category":"$undefined"},{"id":"21303","book":"에스겔","book_name":"에스겔","chapter":33,"verse":22,"text":"그 도망한 자가 내게 나아오기 전날 저녁에 여호와의 손이 내게 임하여 내 입을 여시더니 다음 아침 그 사람이 내게 나아올 임시에 내 입이 열리기로 내가 다시는 잠잠하지 아니하였노라","reference":"에스겔 33:22","category":"$undefined"},{"id":"21304","book":"에스겔","book_name":"에스겔","chapter":33,"verse":23,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 33:23","category":"$undefined"},{"id":"21305","book":"에스겔","book_name":"에스겔","chapter":33,"verse":24,"text":"인자야 이 이스라엘 황무한 땅에 거한 자들이 말하여 이르기를 아브라함은 오직 한 사람이라도 이 땅을 기업으로 얻었나니 우리가 중다한즉 더욱 이 땅으로 우리에게 기업으로 주신 것이 되느니라 하는도다","reference":"에스겔 33:24","category":"$undefined"},{"id":"21306","book":"에스겔","book_name":"에스겔","chapter":33,"verse":25,"text":"그러므로 너는 그들에게 이르기를 주 여호와의 말씀에 너희가 피있는 고기를 먹으며 너희 우상들에게 눈을 들며 피를 흘리니 그 땅이 너희의 기업이 될까보냐","reference":"에스겔 33:25","category":"$undefined"},{"id":"21307","book":"에스겔","book_name":"에스겔","chapter":33,"verse":26,"text":"너희가 칼을 믿어 가증한 일을 행하며 각기 이웃의 아내를 더럽히니 그 땅이 너희의 기업이 될까보냐 하고","reference":"에스겔 33:26","category":"$undefined"},{"id":"21308","book":"에스겔","book_name":"에스겔","chapter":33,"verse":27,"text":"너는 그들에게 또 이르기를 주 여호와의 말씀에 내가 나의 삶을 두고 맹세하노니 황무지에 있는 자는 칼에 엎드러뜨리고 들에 있는 자는 들짐승에게 붙여 먹게 하고 산성과 굴에 있는 자는 온역에 죽게 하리라","reference":"에스겔 33:27","category":"$undefined"},{"id":"21309","book":"에스겔","book_name":"에스겔","chapter":33,"verse":28,"text":"내가 그 땅으로 황무지와 놀라움이 되게 하고 그 권능의 교만을 그치게 하리니 이스라엘의 산들이 황무하여 지나갈 사람이 없으리라","reference":"에스겔 33:28","category":"$undefined"},{"id":"21310","book":"에스겔","book_name":"에스겔","chapter":33,"verse":29,"text":"내가 그들의 행한 모든 가증한 일로 인하여 그 땅으로 황무지와 놀라움이 되게 하면 그 때에 그들이 나를 여호와인 줄 알리라 하라","reference":"에스겔 33:29","category":"$undefined"},{"id":"21311","book":"에스겔","book_name":"에스겔","chapter":33,"verse":30,"text":"인자야 네 민족이 담 곁에서와 집 문에서 너를 의논하며 각각 그 형제로 더불어 말하여 이르기를 자, 가서 여호와께로부터 무슨 말씀이 나오는가 들어보자 하고","reference":"에스겔 33:30","category":"$undefined"},{"id":"21312","book":"에스겔","book_name":"에스겔","chapter":33,"verse":31,"text":"백성이 모이는 것 같이 네게 나아오며 내 백성처럼 네 앞에 앉아서 네 말을 들으나 그대로 행치 아니하니 이는 그 입으로는 사랑을 나타내어도 마음은 이욕을 좇음이라","reference":"에스겔 33:31","category":"$undefined"},{"id":"21313","book":"에스겔","book_name":"에스겔","chapter":33,"verse":32,"text":"그들이 너를 음악을 잘하며 고운 음성으로 사랑의 노래를 하는 자 같이 여겼나니 네 말을 듣고도 준행치 아니하거니와","reference":"에스겔 33:32","category":"$undefined"},{"id":"21314","book":"에스겔","book_name":"에스겔","chapter":33,"verse":33,"text":"그 말이 응하리니 응할 때에는 그들이 한 선지자가 자기 가운데 있었던 줄을 알리라","reference":"에스겔 33:33","category":"$undefined"}],"bookSlug":"ezekiel"}]
