2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":34,"verses":[{"id":"21315","book":"에스겔","book_name":"에스겔","chapter":34,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 34:1","category":"$undefined"},{"id":"21316","book":"에스겔","book_name":"에스겔","chapter":34,"verse":2,"text":"인자야 너는 이스라엘 목자들을 쳐서 예언하라 그들 곧 목자들에게 예언하여 이르기를 주 여호와의 말씀에 자기만 먹이는 이스라엘 목자들은 화 있을진저 목자들이 양의 무리를 먹이는 것이 마땅치 아니하냐 ?","reference":"에스겔 34:2","category":"$undefined"},{"id":"21317","book":"에스겔","book_name":"에스겔","chapter":34,"verse":3,"text":"너희가 살진 양을 잡아 그 기름을 먹으며 그 털을 입되 양의 무리는 먹이지 아니하는도다","reference":"에스겔 34:3","category":"$undefined"},{"id":"21318","book":"에스겔","book_name":"에스겔","chapter":34,"verse":4,"text":"너희가 그 연약한 자를 강하게 아니하며 병든 자를 고치지 아니하며 상한 자를 싸매어 주지 아니하며 쫓긴 자를 돌아오게 아니하며 잃어버린 자를 찾지 아니하고 다만 강포로 그것들을 다스렸도다","reference":"에스겔 34:4","category":"$undefined"},{"id":"21319","book":"에스겔","book_name":"에스겔","chapter":34,"verse":5,"text":"목자가 없으므로 그것들이 흩어지며 흩어져서 모든 들짐승의 밥이 되었도다","reference":"에스겔 34:5","category":"$undefined"},{"id":"21320","book":"에스겔","book_name":"에스겔","chapter":34,"verse":6,"text":"내 양의 무리가 모든 산과 높은 멧부리에마다 유리되었고 내 양의 무리가 온 지면에 흩어졌으되 찾고 찾는 자가 없었도다","reference":"에스겔 34:6","category":"$undefined"},{"id":"21321","book":"에스겔","book_name":"에스겔","chapter":34,"verse":7,"text":"그러므로 목자들아 여호와의 말씀을 들을지어다","reference":"에스겔 34:7","category":"$undefined"},{"id":"21322","book":"에스겔","book_name":"에스겔","chapter":34,"verse":8,"text":"주 여호와의 말씀에 내가 나의 삶을 두고 맹세하노라 내 양의 무리가 노략거리가 되고 모든 들짐승의 밥이 된 것은 목자가 없음이라 내 목자들이 양을 찾지 아니하고 자기만 먹이고 내 양의 무리를 먹이지 아니하였도다","reference":"에스겔 34:8","category":"$undefined"},{"id":"21323","book":"에스겔","book_name":"에스겔","chapter":34,"verse":9,"text":"그러므로 너희 목자들아 여호와의 말씀을 들을지어다","reference":"에스겔 34:9","category":"$undefined"},{"id":"21324","book":"에스겔","book_name":"에스겔","chapter":34,"verse":10,"text":"주 여호와의 말씀에 내가 목자들을 대적하여 내 양의 무리를 그들의 손에서 찾으리니 목자들이 양을 먹이지 못할 뿐 아니라 그들이 다시는 자기를 먹이지 못할지라 내가 내 양을 그들의 입에서 건져내어서 다시는 그 식물이 되지 않게 하리라","reference":"에스겔 34:10","category":"$undefined"},{"id":"21325","book":"에스겔","book_name":"에스겔","chapter":34,"verse":11,"text":"나 주 여호와가 말하노라 나 곧 내가 내 양을 찾고 찾되","reference":"에스겔 34:11","category":"$undefined"},{"id":"21326","book":"에스겔","book_name":"에스겔","chapter":34,"verse":12,"text":"목자가 양 가운데 있는 날에 양이 흩어졌으면 그 떼를 찾는 것 같이 내가 내 양을 찾아서 흐리고 캄캄한 날에 그 흩어진 모든 곳에서 그것들을 건져낼지라","reference":"에스겔 34:12","category":"$undefined"},{"id":"21327","book":"에스겔","book_name":"에스겔","chapter":34,"verse":13,"text":"내가 그것들을 만민 중에서 끌어내며 열방 중에서 모아 그 본토로 데리고 가서 이스라엘 산 위에와 시냇가에와 그 땅 모든 거주지에서 먹이되","reference":"에스겔 34:13","category":"$undefined"},{"id":"21328","book":"에스겔","book_name":"에스겔","chapter":34,"verse":14,"text":"좋은 꼴로 먹이고 그 우리를 이스라엘 높은 산 위에 두리니 그것들이 거기서 좋은 우리에 누워 있으며 이스라엘 산 위에서 살진 꼴을 먹으리라","reference":"에스겔 34:14","category":"$undefined"},{"id":"21329","book":"에스겔","book_name":"에스겔","chapter":34,"verse":15,"text":"나 주 여호와가 말하노라 내가 친히 내 양의 목자가 되어 그것들로 누워 있게 할지라","reference":"에스겔 34:15","category":"$undefined"},{"id":"21330","book":"에스겔","book_name":"에스겔","chapter":34,"verse":16,"text":"그 잃어버린 자를 내가 찾으며 쫓긴 자를 내가 돌아오게 하며 상한 자를 내가 싸매어 주며 병든 자를 내가 강하게 하려니와 살진자와 강한 자는 내가 멸하고 공의대로 그것들을 먹이리라","reference":"에스겔 34:16","category":"$undefined"},{"id":"21331","book":"에스겔","book_name":"에스겔","chapter":34,"verse":17,"text":"나 주 여호와가 말하노라 나의 양떼 너희여 내가 양과 양의 사이와 수양과 수염소의 사이에 심판하노라","reference":"에스겔 34:17","category":"$undefined"},{"id":"21332","book":"에스겔","book_name":"에스겔","chapter":34,"verse":18,"text":"너희가 좋은 꼴 먹은 것을 작은 일로 여기느냐 어찌하여 남은 꼴을 발로 밟았느냐 ? 너희가 맑은 물 마신 것을 작은 일로 여기느냐 어찌하여 남은 물을 발로 더럽혔느냐","reference":"에스겔 34:18","category":"$undefined"},{"id":"21333","book":"에스겔","book_name":"에스겔","chapter":34,"verse":19,"text":"나의 양은 너희 발로 밟은 것을 먹으며 너희 발로 더럽힌 것을 마시는도다 하셨느니라","reference":"에스겔 34:19","category":"$undefined"},{"id":"21334","book":"에스겔","book_name":"에스겔","chapter":34,"verse":20,"text":"그러므로 주 여호와께서 그들에게 대하여 말씀하시기를 나 곧 내가 살찐 양과 파리한 양 사이에 심판하리라","reference":"에스겔 34:20","category":"$undefined"},{"id":"21335","book":"에스겔","book_name":"에스겔","chapter":34,"verse":21,"text":"너희가 옆구리와 어깨로 밀뜨리고 모든 병든 자를 뿔로 받아 무리로 밖으로 흩어지게 하는도다","reference":"에스겔 34:21","category":"$undefined"},{"id":"21336","book":"에스겔","book_name":"에스겔","chapter":34,"verse":22,"text":"그러므로 내가 내 양떼를 구원하여 그들로 다시는 노략거리가 되지 않게 하고 양과 양 사이에 심판하리라","reference":"에스겔 34:22","category":"$undefined"},{"id":"21337","book":"에스겔","book_name":"에스겔","chapter":34,"verse":23,"text":"내가 한 목자를 그들의 위에 세워 먹이게 하리니 그는 내 종 다윗이라 그가 그들을 먹이고 그들의 목자가 될지라","reference":"에스겔 34:23","category":"$undefined"},{"id":"21338","book":"에스겔","book_name":"에스겔","chapter":34,"verse":24,"text":"나 여호와는 그들의 하나님이 되고 내 종 다윗은 그들 중에 왕이 되리라 나는 여호와의 말이니라","reference":"에스겔 34:24","category":"$undefined"},{"id":"21339","book":"에스겔","book_name":"에스겔","chapter":34,"verse":25,"text":"내가 또 그들과 화평의 언약을 세우고 악한 짐승을 그 땅에서 그치게 하리니 그들이 빈 들에 평안히 거하며 수풀 가운데서 잘찌라","reference":"에스겔 34:25","category":"$undefined"},{"id":"21340","book":"에스겔","book_name":"에스겔","chapter":34,"verse":26,"text":"내가 그들에게 복을 내리며 내 산 사면 모든 곳도 복되게 하여 때를 따라 비를 내리되 복된 장마비를 내리리라 !","reference":"에스겔 34:26","category":"$undefined"},{"id":"21341","book":"에스겔","book_name":"에스겔","chapter":34,"verse":27,"text":"그리한즉 밭에 나무가 열매를 맺으며 땅이 그 소산을 내리니 그들이 그 땅에서 평안할지라 내가 그들의 멍엣목을 꺾고 그들로 종을 삼은 자의 손에서 그들을 건져낸 후에 그들이 나를 여호와인 줄 알겠고","reference":"에스겔 34:27","category":"$undefined"},{"id":"21342","book":"에스겔","book_name":"에스겔","chapter":34,"verse":28,"text":"그들이 다시는 이방의 노략거리가 되지 아니하며 땅의 짐승의 삼킨바 되지 아니하고 평안히 거하리니 놀랠 사람이 없으리라","reference":"에스겔 34:28","category":"$undefined"},{"id":"21343","book":"에스겔","book_name":"에스겔","chapter":34,"verse":29,"text":"내가 그들을 위하여 유명한 종식할 땅을 일으키리니 그들이 다시는 그 땅에서 기근으로 멸망하지 아니할지며 다시는 열국의 수치를 받지 아니할지라","reference":"에스겔 34:29","category":"$undefined"},{"id":"21344","book":"에스겔","book_name":"에스겔","chapter":34,"verse":30,"text":"그들이 나 여호와 그들의 하나님이 그들과 함께 있는 줄을 알며 그들 곧 이스라엘 족속이 내 백성인 줄 알리라 나 주 여호와의 말이라","reference":"에스겔 34:30","category":"$undefined"},{"id":"21345","book":"에스겔","book_name":"에스겔","chapter":34,"verse":31,"text":"내 양 곧 내 초장의 양, 너희는 사람이요 나는 너희 하나님이라 나 주 여호와의 말이니라","reference":"에스겔 34:31","category":"$undefined"}],"bookSlug":"ezekiel"}]
