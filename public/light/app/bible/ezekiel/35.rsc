2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":35,"verses":[{"id":"21346","book":"에스겔","book_name":"에스겔","chapter":35,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 35:1","category":"$undefined"},{"id":"21347","book":"에스겔","book_name":"에스겔","chapter":35,"verse":2,"text":"인자야 네 얼굴을 세일산으로 향하고 그를 쳐서 예언하여","reference":"에스겔 35:2","category":"$undefined"},{"id":"21348","book":"에스겔","book_name":"에스겔","chapter":35,"verse":3,"text":"이르기를 주 여호와의 말씀에 세일산아 내가 너를 대적하여 내 손을 네 위에 펴서 너로 황무지와 놀라움이 되게 할지라","reference":"에스겔 35:3","category":"$undefined"},{"id":"21349","book":"에스겔","book_name":"에스겔","chapter":35,"verse":4,"text":"내가 네 성읍들을 무너뜨리며 너로 황무케 하리니 네가 나를 여호와인 줄 알리라","reference":"에스겔 35:4","category":"$undefined"},{"id":"21350","book":"에스겔","book_name":"에스겔","chapter":35,"verse":5,"text":"네가 옛날부터 한을 품고 이스라엘 족속의 환난 때 곧 죄악의 끝때에 칼의 권능에 그들을 붙였도다","reference":"에스겔 35:5","category":"$undefined"},{"id":"21351","book":"에스겔","book_name":"에스겔","chapter":35,"verse":6,"text":"그러므로 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 내가 너로 피를 만나게 한즉 피가 너를 따르리라 네가 피를 미워하지 아니하였은즉 피가 너를 따르리라","reference":"에스겔 35:6","category":"$undefined"},{"id":"21352","book":"에스겔","book_name":"에스겔","chapter":35,"verse":7,"text":"내가 세일산으로 놀라움과 황무지가 되게 하여 그 위에 왕래하는 자를 다 끊을지라","reference":"에스겔 35:7","category":"$undefined"},{"id":"21353","book":"에스겔","book_name":"에스겔","chapter":35,"verse":8,"text":"내가 그 살륙 당한 자로 그 여러 산에 채우되 칼에 살륙당한 자로 네 여러 멧부리에 골짜기에 모든 시내에 엎드러지게 하고","reference":"에스겔 35:8","category":"$undefined"},{"id":"21354","book":"에스겔","book_name":"에스겔","chapter":35,"verse":9,"text":"너로 영원히 황무케 하여 네 성읍들에 다시는 거하는 자가 없게하리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 35:9","category":"$undefined"},{"id":"21355","book":"에스겔","book_name":"에스겔","chapter":35,"verse":10,"text":"네가 말하기를 이 두 민족과 이 두 땅은 다 내게로 돌아와서 내 기업이 되리라 하였도다 그러나 나 여호와가 거기 있었느니라","reference":"에스겔 35:10","category":"$undefined"},{"id":"21356","book":"에스겔","book_name":"에스겔","chapter":35,"verse":11,"text":"그러므로 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 네가 그들을 미워하여 노하며 질투한대로 내가 네게 행하여 너를 국문할 때에 그들로 나를 알게 하리라","reference":"에스겔 35:11","category":"$undefined"},{"id":"21357","book":"에스겔","book_name":"에스겔","chapter":35,"verse":12,"text":"네가 이스라엘 산들을 가리켜 말하기를 저 산들이 황무하였으니 우리에게 붙이워서 삼키게 되었다 하여 욕하는 모든 말을 나 여호와가 들은 줄을 네가 알리로다","reference":"에스겔 35:12","category":"$undefined"},{"id":"21358","book":"에스겔","book_name":"에스겔","chapter":35,"verse":13,"text":"너희가 나를 대적하여 입으로 자랑하며 나를 대적하여 여러가지로 말한 것을 내가 들었노라","reference":"에스겔 35:13","category":"$undefined"},{"id":"21359","book":"에스겔","book_name":"에스겔","chapter":35,"verse":14,"text":"나 주 여호와가 말하노라 온 땅이 즐거워할 때에 내가 너를 황무케 하되","reference":"에스겔 35:14","category":"$undefined"},{"id":"21360","book":"에스겔","book_name":"에스겔","chapter":35,"verse":15,"text":"이스라엘 족속의 기업이 황무함을 인하여 네가 즐거워한 것 같이 내가 너로 황무케 하리라 세일산아 너와 에돔 온 땅이 황무하리니 무리가 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 35:15","category":"$undefined"}],"bookSlug":"ezekiel"}]
