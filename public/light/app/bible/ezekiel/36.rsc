2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":36,"verses":[{"id":"21361","book":"에스겔","book_name":"에스겔","chapter":36,"verse":1,"text":"인자야 너는 이스라엘 산들에게 예언하여 이르기를 이스라엘 산들아 여호와의 말씀을 들으라","reference":"에스겔 36:1","category":"$undefined"},{"id":"21362","book":"에스겔","book_name":"에스겔","chapter":36,"verse":2,"text":"주 여호와의 말씀에 대적이 네게 대하여 말하기를 하하 옛적 높은 곳이 우리의 기업이 되었도다 하였느니라","reference":"에스겔 36:2","category":"$undefined"},{"id":"21363","book":"에스겔","book_name":"에스겔","chapter":36,"verse":3,"text":"그러므로 너는 예언하여 이르기를 주 여호와의 말씀에 그들이 너희를 황무케 하고 너희 사방을 삼켜서 너희로 남은 이방인의 기업이 되게 하여 사람의 말거리와 백성의 비방거리가 되게 하였도다","reference":"에스겔 36:3","category":"$undefined"},{"id":"21364","book":"에스겔","book_name":"에스겔","chapter":36,"verse":4,"text":"그러므로 이스라엘 산들아 주 여호와의 말씀을 들을지어다 주 여호와께서 산들과 멧부리들과 시내들과 골짜기들과 황무한 사막들과 사면에 남아 있는 이방인의 노략거리와 조롱거리가 된 버린 성읍들에게 말씀하셨느니라","reference":"에스겔 36:4","category":"$undefined"},{"id":"21365","book":"에스겔","book_name":"에스겔","chapter":36,"verse":5,"text":"주 여호와의 말씀에 내가 진실로 내 맹렬한 투기로 남아 있는 이방인과 에돔 온 땅을 쳐서 말하였노니 이는 그들이 심히 즐거워 하는 마음과 멸시하는 심령으로 내 땅을 빼앗아 노략하여 자기 소유를 삼았음이니라","reference":"에스겔 36:5","category":"$undefined"},{"id":"21366","book":"에스겔","book_name":"에스겔","chapter":36,"verse":6,"text":"그러므로 너는 이스라엘 땅을 대하여 예언하되 그 산들과 멧부리들과 시내들과 골짜기들을 대하여 이르기를 주 여호와의 말씀에 내가 내 투기와 내 분노로 말하였나니 이는 너희가 이방의 수욕을 당하였음이라","reference":"에스겔 36:6","category":"$undefined"},{"id":"21367","book":"에스겔","book_name":"에스겔","chapter":36,"verse":7,"text":"그러므로 주 여호와의 말씀에 내가 맹세하였은즉 너희 사면에 있는 이방인이 자기 수욕을 정녕 당하리라","reference":"에스겔 36:7","category":"$undefined"},{"id":"21368","book":"에스겔","book_name":"에스겔","chapter":36,"verse":8,"text":"그러나 너희 이스라엘 산들아 너희는 가지를 내고 내 백성 이스라엘을 위하여 과실을 맺으리니 그들의 올 때가 가까이 이르렀음이니라","reference":"에스겔 36:8","category":"$undefined"},{"id":"21369","book":"에스겔","book_name":"에스겔","chapter":36,"verse":9,"text":"내가 돌이켜 너희와 함께 하리니 사람이 너희를 갈고 심을 것이며","reference":"에스겔 36:9","category":"$undefined"},{"id":"21370","book":"에스겔","book_name":"에스겔","chapter":36,"verse":10,"text":"내가 또 사람을 너희 위에 많게 하리니 이들은 이스라엘 온 족속이라 그들로 성읍들에 거하게 하며 빈 땅에 건축하게 하리라","reference":"에스겔 36:10","category":"$undefined"},{"id":"21371","book":"에스겔","book_name":"에스겔","chapter":36,"verse":11,"text":"내가 너희 위에 사람과 짐승으로 많게 하되 생육이 중다하고 번성하게 할 것이라 너희 전 지위대로 사람이 거하게 하여 너희를 처음보다 낫게 대접하리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 36:11","category":"$undefined"},{"id":"21372","book":"에스겔","book_name":"에스겔","chapter":36,"verse":12,"text":"내가 사람으로 너희 위에 행하게 하리니 그들은 내 백성 이스라엘이라 그들은 너를 얻고 너는 그 기업이 되어 다시는 그들로 자식들을 잃어버리지 않게 하리라","reference":"에스겔 36:12","category":"$undefined"},{"id":"21373","book":"에스겔","book_name":"에스겔","chapter":36,"verse":13,"text":"나 주 여호와가 말하노라 그들이 너희에게 이르기를 너는 사람을 삼키는 자요 네 나라 백성을 제한 자라 하거니와","reference":"에스겔 36:13","category":"$undefined"},{"id":"21374","book":"에스겔","book_name":"에스겔","chapter":36,"verse":14,"text":"네가 다시는 사람을 삼키지 아니하며 다시는 네 나라 백성을 제하지 아니하리라 나 주 여호와의 말이니라","reference":"에스겔 36:14","category":"$undefined"},{"id":"21375","book":"에스겔","book_name":"에스겔","chapter":36,"verse":15,"text":"내가 또 너로 열국의 수욕을 듣지 않게 하며 만민의 비방을 다시받지 않게 하며 네 나라 백성을 다시 넘어뜨리지 않게 하리라 나 주 여호와의 말이니라 하셨다 하라","reference":"에스겔 36:15","category":"$undefined"},{"id":"21376","book":"에스겔","book_name":"에스겔","chapter":36,"verse":16,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 36:16","category":"$undefined"},{"id":"21377","book":"에스겔","book_name":"에스겔","chapter":36,"verse":17,"text":"인자야 이스라엘 족속이 그 고토에 거할 때에 그 행위로 그 땅을 더럽혔나니 나 보기에 그 소위가 월경 중에 있는 여인의 부정함과 같았느니라","reference":"에스겔 36:17","category":"$undefined"},{"id":"21378","book":"에스겔","book_name":"에스겔","chapter":36,"verse":18,"text":"그들이 땅 위에 피를 쏟았으며 그 우상들로 더럽혔으므로 내가 분노를 그들의 위에 쏟아","reference":"에스겔 36:18","category":"$undefined"},{"id":"21379","book":"에스겔","book_name":"에스겔","chapter":36,"verse":19,"text":"그들을 그 행위대로 심판하여 각국에 흩으며 열방에 헤쳤더니","reference":"에스겔 36:19","category":"$undefined"},{"id":"21380","book":"에스겔","book_name":"에스겔","chapter":36,"verse":20,"text":"그들의 이른바 그 열국에서 내 거룩한 이름이 그들로 인하여 더러워졌나니 곧 사람들이 그들을 가리켜 이르기를 이들은 여호와의 백성이라도 여호와의 땅에서 떠난 자라 하였음이니라","reference":"에스겔 36:20","category":"$undefined"},{"id":"21381","book":"에스겔","book_name":"에스겔","chapter":36,"verse":21,"text":"그러나 이스라엘 족속이 들어간 그 열국에서 더럽힌 내 거룩한 이름을 내가 아꼈노라","reference":"에스겔 36:21","category":"$undefined"},{"id":"21382","book":"에스겔","book_name":"에스겔","chapter":36,"verse":22,"text":"그러므로 너는 이스라엘 족속에게 이르기를 주 여호와의 말씀에 이스라엘 족속아 내가 이렇게 행함은 너희를 위함이 아니요 너희가 들어간 그 열국에서 더럽힌 나의 거룩한 이름을 위함이라","reference":"에스겔 36:22","category":"$undefined"},{"id":"21383","book":"에스겔","book_name":"에스겔","chapter":36,"verse":23,"text":"열국 가운데서 더럽힘을 받은 이름 곧 너희가 그들 중에서 더럽힌 나의 큰 이름을 내가 거룩하게 할지라 내가 그들의 목전에서 너희로 인하여 나의 거룩함을 나타내리니 열국 사람이 나를 여호와인 줄 알리라 나 주 여호와의 말이니라","reference":"에스겔 36:23","category":"$undefined"},{"id":"21384","book":"에스겔","book_name":"에스겔","chapter":36,"verse":24,"text":"내가 너희를 열국 중에서 취하여 내고 열국 중에서 모아 데리고 고토에 들어가서","reference":"에스겔 36:24","category":"$undefined"},{"id":"21385","book":"에스겔","book_name":"에스겔","chapter":36,"verse":25,"text":"맑은 물로 너희에게 뿌려서 너희로 정결케 하되 곧 너희 모든 더러운 것에서와 모든 우상을 섬김에서 너희를 정결케 할 것이며","reference":"에스겔 36:25","category":"$undefined"},{"id":"21386","book":"에스겔","book_name":"에스겔","chapter":36,"verse":26,"text":"또 새 영(靈)을 너희 속에 두고 새 마음을 너희에게 주되 너희 육신에서 굳은 마음을 제하고 부드러운 마음을 줄 것이며","reference":"에스겔 36:26","category":"$undefined"},{"id":"21387","book":"에스겔","book_name":"에스겔","chapter":36,"verse":27,"text":"또 내 신(神)을 너희 속에 두어 너희로 내 율례를 행하게 하리니 너희가 내 규례를 지켜 행할지라","reference":"에스겔 36:27","category":"$undefined"},{"id":"21388","book":"에스겔","book_name":"에스겔","chapter":36,"verse":28,"text":"내가 너희 열조에게 준 땅에 너희가 거하여 내 백성이 되고 나는 너희 하나님이 되리라","reference":"에스겔 36:28","category":"$undefined"},{"id":"21389","book":"에스겔","book_name":"에스겔","chapter":36,"verse":29,"text":"내가 너희를 모든 더러운 데서 구원하고 곡식으로 풍성하게 하여 기근이 너희에게 임하지 아니하게 할 것이며","reference":"에스겔 36:29","category":"$undefined"},{"id":"21390","book":"에스겔","book_name":"에스겔","chapter":36,"verse":30,"text":"또 나무의 실과와 밭의 소산을 풍성케 하여 너희로 다시는 기근의 욕을 열국에게 받지 않게 하리니","reference":"에스겔 36:30","category":"$undefined"},{"id":"21391","book":"에스겔","book_name":"에스겔","chapter":36,"verse":31,"text":"그 때에 너희가 너희 악한 길과 너희 불선한 행위를 기억하고 너희 모든 죄악과 가증한 일을 인하여 스스로 밉게 보리라","reference":"에스겔 36:31","category":"$undefined"},{"id":"21392","book":"에스겔","book_name":"에스겔","chapter":36,"verse":32,"text":"나 주 여호와가 말하노라 내가 이렇게 행함은 너희를 위함이 아닌 줄을 너희가 알리라 이스라엘 족속아 너희 행위를 인하여 부끄러워하고 한탄할지어다","reference":"에스겔 36:32","category":"$undefined"},{"id":"21393","book":"에스겔","book_name":"에스겔","chapter":36,"verse":33,"text":"나 주 여호와가 말하노라 내가 너희를 모든 죄악에서 정결케 하는 날에 성읍들에 사람이 거접되게 하며 황폐한 것이 건축되게 할 것인즉","reference":"에스겔 36:33","category":"$undefined"},{"id":"21394","book":"에스겔","book_name":"에스겔","chapter":36,"verse":34,"text":"전에는 지나가는 자의 눈에 황무하게 보이던 그 황무한 땅이 장차 기경이 될지라","reference":"에스겔 36:34","category":"$undefined"},{"id":"21395","book":"에스겔","book_name":"에스겔","chapter":36,"verse":35,"text":"사람이 이르기를 이 땅이 황무하더니 이제는 에덴 동산 같이 되었고 황량하고 적막하고 무너진 성읍들에 성벽과 거민이 있다 하리니","reference":"에스겔 36:35","category":"$undefined"},{"id":"21396","book":"에스겔","book_name":"에스겔","chapter":36,"verse":36,"text":"너희 사면에 남은 이방 사람이 나 여호와가 무너진 곳을 건축하며 황무한 자리에 심은 줄 알리라 나 여호와가 말하였으니 이루리라","reference":"에스겔 36:36","category":"$undefined"},{"id":"21397","book":"에스겔","book_name":"에스겔","chapter":36,"verse":37,"text":"나 주 여호와가 말하노라 그래도 이스라엘 족속이 이와 같이 자기들에게 이루어 주기를 내게 구하여야 할지라 내가 그들의 인수로 양떼 같이 많아지게 하되","reference":"에스겔 36:37","category":"$undefined"},{"id":"21398","book":"에스겔","book_name":"에스겔","chapter":36,"verse":38,"text":"제사드릴 양떼 곧 예루살렘 정한 절기의 양떼 같이 황폐한 성읍에 사람의 떼로 채우리라 그리한즉 그들이 나를 여호와인줄 알리라 하셨느니라","reference":"에스겔 36:38","category":"$undefined"}],"bookSlug":"ezekiel"}]
