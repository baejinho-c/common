2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":37,"verses":[{"id":"21399","book":"에스겔","book_name":"에스겔","chapter":37,"verse":1,"text":"여호와께서 권능으로 내게 임하시고 그 신으로 나를 데리고 가서 골짜기 가운데 두셨는데 거기 뼈가 가득하더라","reference":"에스겔 37:1","category":"$undefined"},{"id":"21400","book":"에스겔","book_name":"에스겔","chapter":37,"verse":2,"text":"나를 그 뼈 사방으로 지나게 하시기로 본즉 그 골짜기 지면에 뼈가 심히 많고 아주 말랐더라","reference":"에스겔 37:2","category":"$undefined"},{"id":"21401","book":"에스겔","book_name":"에스겔","chapter":37,"verse":3,"text":"그가 내게 이르시되 인자야 이 뼈들이 능히 살겠느냐 하시기로 내가 대답하되 주 여호와여 주께서 아시나이다","reference":"에스겔 37:3","category":"$undefined"},{"id":"21402","book":"에스겔","book_name":"에스겔","chapter":37,"verse":4,"text":"또 내게 이르시되 너는 이 모든 뼈에게 대언하여 이르기를 너희 마른 뼈들아 여호와의 말씀을 들을지어다","reference":"에스겔 37:4","category":"$undefined"},{"id":"21403","book":"에스겔","book_name":"에스겔","chapter":37,"verse":5,"text":"주 여호와께서 이 뼈들에게 말씀하시기를 내가 생기로 너희에게 들어가게 하리니 너희가 살리라","reference":"에스겔 37:5","category":"$undefined"},{"id":"21404","book":"에스겔","book_name":"에스겔","chapter":37,"verse":6,"text":"너희 위에 힘줄을 두고 살을 입히고 가죽으로 덮고 너희 속에 생기를 두리니 너희가 살리라 또 나를 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 37:6","category":"$undefined"},{"id":"21405","book":"에스겔","book_name":"에스겔","chapter":37,"verse":7,"text":"이에 내가 명을 좇아 대언하니 대언할 때에 소리가 나고 움직이더니 이 뼈, 저 뼈가 들어 맞아서 뼈들이 서로 연락하더라","reference":"에스겔 37:7","category":"$undefined"},{"id":"21406","book":"에스겔","book_name":"에스겔","chapter":37,"verse":8,"text":"내가 또 보니 그 뼈에 힘줄이 생기고 살이 오르며 그 위에 가죽이 덮이나 그 속에 생기는 없더라","reference":"에스겔 37:8","category":"$undefined"},{"id":"21407","book":"에스겔","book_name":"에스겔","chapter":37,"verse":9,"text":"또 내게 이르시되 인자야 너는 생기를 향하여 대언하라 생기에게 대언하여 이르기를 주 여호와의 말씀에 생기야 사방에서부터 와서 이 사망을 당한 자에게 불어서 살게 하라 하셨다 하라","reference":"에스겔 37:9","category":"$undefined"},{"id":"21408","book":"에스겔","book_name":"에스겔","chapter":37,"verse":10,"text":"이에 내가 그 명대로 대언하였더니 생기가 그들에게 들어가매 그들이 곧 살아 일어나서 서는데 극히 큰 군대더라","reference":"에스겔 37:10","category":"$undefined"},{"id":"21409","book":"에스겔","book_name":"에스겔","chapter":37,"verse":11,"text":"또 내게 이르시되 인자야 이 뼈들은 이스라엘 온 족속이라 그들이 이르기를 우리의 뼈들이 말랐고 우리의 소망이 없어졌으니 우리는 다 멸절되었다 하느니라","reference":"에스겔 37:11","category":"$undefined"},{"id":"21410","book":"에스겔","book_name":"에스겔","chapter":37,"verse":12,"text":"그러므로 너는 대언하여 그들에게 이르기를 주 여호와의 말씀에 내 백성들아 내가 너희 무덤을 열고 너희로 거기서 나오게 하고 이스라엘 땅으로 들어가게 하리라","reference":"에스겔 37:12","category":"$undefined"},{"id":"21411","book":"에스겔","book_name":"에스겔","chapter":37,"verse":13,"text":"내 백성들아 내가 너희 무덤을 열고 너희로 거기서 나오게 한즉 너희가 나를 여호와인 줄 알리라","reference":"에스겔 37:13","category":"$undefined"},{"id":"21412","book":"에스겔","book_name":"에스겔","chapter":37,"verse":14,"text":"내가 또 내 신을 너희 속에 두어 너희로 살게 하고 내가 또 너희를 너희 고토에 거하게 하리니 나 여호와가 이 일을 말하고 이룬 줄을 너희가 알리라 나 여호와의 말이니라 하셨다 하라","reference":"에스겔 37:14","category":"$undefined"},{"id":"21413","book":"에스겔","book_name":"에스겔","chapter":37,"verse":15,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 37:15","category":"$undefined"},{"id":"21414","book":"에스겔","book_name":"에스겔","chapter":37,"verse":16,"text":"인자야 너는 막대기 하나를 취하여 그 위에 유다와 그 짝 이스라엘 자손이라 쓰고 또 다른 막대기 하나를 취하여 그 위에 에브라임의 막대기 곧 요셉과 그 짝 이스라엘 온 족속이라 쓰고","reference":"에스겔 37:16","category":"$undefined"},{"id":"21415","book":"에스겔","book_name":"에스겔","chapter":37,"verse":17,"text":"그 막대기들을 서로 연합하여 하나가 되게 하라 네 손에서 둘이 하나가 되리라","reference":"에스겔 37:17","category":"$undefined"},{"id":"21416","book":"에스겔","book_name":"에스겔","chapter":37,"verse":18,"text":"네 민족이 네게 말하여 이르기를 이것이 무슨 뜻인지 우리에게 고하지 아니하겠느냐 ? 하거든","reference":"에스겔 37:18","category":"$undefined"},{"id":"21417","book":"에스겔","book_name":"에스겔","chapter":37,"verse":19,"text":"너는 곧 이르기를 주 여호와의 말씀에 내가 에브라임의 손에 있는바 요셉과 그 짝 이스라엘 지파들의 막대기를 취하여 유다의 막대기에 붙여서 한 막대기가 되게 한즉 내 손에서 하나가 되리라 하셨다 하고","reference":"에스겔 37:19","category":"$undefined"},{"id":"21418","book":"에스겔","book_name":"에스겔","chapter":37,"verse":20,"text":"너는 그 글 쓴 막대기들을 무리의 목전에서 손에 잡고","reference":"에스겔 37:20","category":"$undefined"},{"id":"21419","book":"에스겔","book_name":"에스겔","chapter":37,"verse":21,"text":"그들에게 이르기를 주 여호와의 말씀에 내가 이스라엘 자손을 그 간바 열국에서 취하며 그 사면에서 모아서 그 고토로 돌아가게 하고","reference":"에스겔 37:21","category":"$undefined"},{"id":"21420","book":"에스겔","book_name":"에스겔","chapter":37,"verse":22,"text":"그 땅 이스라엘 모든 산에서 그들로 한 나라를 이루어서 한 임금이 모두 다스리게 하리니 그들이 다시는 두 민족이 되지 아니하며 두 나라로 나누이지 아니할지라","reference":"에스겔 37:22","category":"$undefined"},{"id":"21421","book":"에스겔","book_name":"에스겔","chapter":37,"verse":23,"text":"그들이 그 우상들과 가증한 물건과 그 모든 죄악으로 스스로 더럽히지 아니하리라 내가 그들을 그 범죄한 모든 처소에서 구원하여 정결케 한즉 그들은 내 백성이 되고 나는 그들의 하나님이 되리라","reference":"에스겔 37:23","category":"$undefined"},{"id":"21422","book":"에스겔","book_name":"에스겔","chapter":37,"verse":24,"text":"내 조상 다윗이 그들의 왕이 되리니 그들에게 다 한 목자가 있을 것이라 그들이 내 규례를 준행하고 내 율례를 지켜 행하며","reference":"에스겔 37:24","category":"$undefined"},{"id":"21423","book":"에스겔","book_name":"에스겔","chapter":37,"verse":25,"text":"내가 내 종 야곱에게 준 땅 곧 그 열조가 거하던 땅에 그들이 거하되 그들과 그 자자손손이 영원히 거기 거할 것이요 내 종 다윗이 영원히 그 왕이 되리라","reference":"에스겔 37:25","category":"$undefined"},{"id":"21424","book":"에스겔","book_name":"에스겔","chapter":37,"verse":26,"text":"내가 그들과 화평의 언약을 세워서 영원한 언약이 되게 하고 또 그들을 견고하고 번성케 하며 내 성소를 그 가운데 세워서 영원히 이르게 하리니","reference":"에스겔 37:26","category":"$undefined"},{"id":"21425","book":"에스겔","book_name":"에스겔","chapter":37,"verse":27,"text":"내 처소가 그들의 가운데 있을 것이며 나는 그들의 하나님이 되고 그들은 내 백성이 되리라","reference":"에스겔 37:27","category":"$undefined"},{"id":"21426","book":"에스겔","book_name":"에스겔","chapter":37,"verse":28,"text":"내 성소가 영원토록 그들의 가운데 있으리니 열국이 나를 이스라엘을 거룩케 하는 여호와인 줄 알리라 하셨다 하라","reference":"에스겔 37:28","category":"$undefined"}],"bookSlug":"ezekiel"}]
