2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":38,"verses":[{"id":"21427","book":"에스겔","book_name":"에스겔","chapter":38,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 38:1","category":"$undefined"},{"id":"21428","book":"에스겔","book_name":"에스겔","chapter":38,"verse":2,"text":"인자야 너는 마곡 땅에 있는 곡, 곧 로스와 메섹과 두발 왕에게로 얼굴을 향하고 그를 쳐서 예언하여","reference":"에스겔 38:2","category":"$undefined"},{"id":"21429","book":"에스겔","book_name":"에스겔","chapter":38,"verse":3,"text":"이르기를 주 여호와의 말씀에 로스와 메섹과 두발 왕 곡아 내가 너를 대적하여","reference":"에스겔 38:3","category":"$undefined"},{"id":"21430","book":"에스겔","book_name":"에스겔","chapter":38,"verse":4,"text":"너를 돌이켜 갈고리로 네 아가리를 꿰고 너와 말과 기병 곧 네 온 군대를 끌어내되 완전한 갑옷을 입고 큰 방패와 작은 방패를 가지며 칼을 잡은 큰 무리와","reference":"에스겔 38:4","category":"$undefined"},{"id":"21431","book":"에스겔","book_name":"에스겔","chapter":38,"verse":5,"text":"그들과 함께 한바 방패와 투구를 갖춘 바사와 구스와 붓과","reference":"에스겔 38:5","category":"$undefined"},{"id":"21432","book":"에스겔","book_name":"에스겔","chapter":38,"verse":6,"text":"고멜과 그 모든 떼와 극한 북방의 도갈마 족속과 그 모든 떼 곧 많은 백성의 무리를 너와 함께 끌어 내리라","reference":"에스겔 38:6","category":"$undefined"},{"id":"21433","book":"에스겔","book_name":"에스겔","chapter":38,"verse":7,"text":"너는 스스로 예비하되 너와 네게 모인 무리들이 다 스스로 예비하고 너는 그들의 대장이 될지어다","reference":"에스겔 38:7","category":"$undefined"},{"id":"21434","book":"에스겔","book_name":"에스겔","chapter":38,"verse":8,"text":"여러날 후 곧 말년에 네가 명령을 받고 그 땅 곧 오래 황무하였던 이스라엘 산에 이르리니 그 땅 백성은 칼을 벗어나서 열국에서부터 모여 들어 오며 이방에서부터 나와서 다 평안히 거하는 중이라","reference":"에스겔 38:8","category":"$undefined"},{"id":"21435","book":"에스겔","book_name":"에스겔","chapter":38,"verse":9,"text":"네가 올라오되 너와 네 모든 떼와 너와 함께한 많은 백성이 광풍같이 이르고 구름 같이 땅을 덮으리라","reference":"에스겔 38:9","category":"$undefined"},{"id":"21436","book":"에스겔","book_name":"에스겔","chapter":38,"verse":10,"text":"나 주 여호와가 말하노라 그 날에 네 마음에서 여러가지 생각이 나서 악한 꾀를 내어","reference":"에스겔 38:10","category":"$undefined"},{"id":"21437","book":"에스겔","book_name":"에스겔","chapter":38,"verse":11,"text":"말하기를 내가 평원의 고을들로 올라가리라 성벽도 없고 문이나 빗장이 없어도 염려없이 다 평안히 거하는 백성에게 나아가서","reference":"에스겔 38:11","category":"$undefined"},{"id":"21438","book":"에스겔","book_name":"에스겔","chapter":38,"verse":12,"text":"물건을 겁탈하며 노략하리라 하고 네 손을 들어서 황무하였다가 지금 사람이 거처하는 땅과 열국 중에서 모여서 짐승과 재물을 얻고 세상 중앙에 거하는 백성을 치고자 할 때에","reference":"에스겔 38:12","category":"$undefined"},{"id":"21439","book":"에스겔","book_name":"에스겔","chapter":38,"verse":13,"text":"스바와 드단과 다시스의 상고와 그 부자들이 네게 이르기를 네가 탈취하러 왔느냐 ? 네가 네 무리를 모아 노략하고자 하느냐 ? 은과 금을 빼앗으며 짐승과 재물을 취하며 물건을 크게 약탈하여 가고자 하느냐 하리라 하셨다 하라","reference":"에스겔 38:13","category":"$undefined"},{"id":"21440","book":"에스겔","book_name":"에스겔","chapter":38,"verse":14,"text":"인자야 너는 또 예언하여 곡에게 이르기를 주 여호와의 말씀에 내 백성 이스라엘이 평안히 거하는 날에 네가 어찌 그것을 알지 못하겠느냐 ?","reference":"에스겔 38:14","category":"$undefined"},{"id":"21441","book":"에스겔","book_name":"에스겔","chapter":38,"verse":15,"text":"네가 네 고토 극한 북방에서 많은 백성 곧 다 말을 탄 큰 떼와 능한 군대와 함께 오되","reference":"에스겔 38:15","category":"$undefined"},{"id":"21442","book":"에스겔","book_name":"에스겔","chapter":38,"verse":16,"text":"구름이 땅에 덮임 같이 내 백성 이스라엘을 치러 오리라 곡아 끝날에 내가 너를 이끌어다가 내 땅을 치게 하리니 이는 내가 너로 말미암아 이방 사람의 목전에서 내 거룩함을 나타내어 그들로 다 나를 알게 하려 함이니라","reference":"에스겔 38:16","category":"$undefined"},{"id":"21443","book":"에스겔","book_name":"에스겔","chapter":38,"verse":17,"text":"나 주 여호와가 말하노라 내가 옛적에 내 종 이스라엘 선지자들을 빙자하여 말한 사람이 네가 아니냐 ? 그들이 그 때에 여러 해 동안 예언하기를 내가 너를 이끌어다가 그들을 치게 하리라 하였느니라 하셨다 하라","reference":"에스겔 38:17","category":"$undefined"},{"id":"21444","book":"에스겔","book_name":"에스겔","chapter":38,"verse":18,"text":"나 주 여호와가 말하노라 그날에 곡이 이스라엘 땅을 치러 오면 내 노가 내 얼굴에 나타나리라","reference":"에스겔 38:18","category":"$undefined"},{"id":"21445","book":"에스겔","book_name":"에스겔","chapter":38,"verse":19,"text":"내가 투기와 맹렬한 노로 말하였거니와 그 날에 큰 지진이 이스라엘 땅에 일어나서","reference":"에스겔 38:19","category":"$undefined"},{"id":"21446","book":"에스겔","book_name":"에스겔","chapter":38,"verse":20,"text":"바다의 고기들과 공중의 새들과 들의 짐승들과 땅에 기는 모든 벌레와 지면에 있는 모든 사람이 내 앞에서 떨 것이며 모든 산이 무너지며 절벽이 떨어지며 모든 성벽이 땅에 무너지리라","reference":"에스겔 38:20","category":"$undefined"},{"id":"21447","book":"에스겔","book_name":"에스겔","chapter":38,"verse":21,"text":"나 주 여호와가 말하노라 내가 내 모든 산 중에서 그를 칠 칼을 부르리니 각 사람의 칼이 그 형제를 칠 것이며","reference":"에스겔 38:21","category":"$undefined"},{"id":"21448","book":"에스겔","book_name":"에스겔","chapter":38,"verse":22,"text":"내가 또 온역과 피로 그를 국문하며 쏟아지는 폭우와 큰 우박덩이와 불과 유황으로 그와 그 모든 떼와 그 함께한 많은 백성에게 비를 내리듯 하리라","reference":"에스겔 38:22","category":"$undefined"},{"id":"21449","book":"에스겔","book_name":"에스겔","chapter":38,"verse":23,"text":"이와 같이 내가 여러 나라의 눈에 내 존대함과 내 거룩함을 나타내어 나를 알게 하리니 그들이 나를 여호와인줄 알리라","reference":"에스겔 38:23","category":"$undefined"}],"bookSlug":"ezekiel"}]
