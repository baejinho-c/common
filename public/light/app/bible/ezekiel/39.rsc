2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":39,"verses":[{"id":"21450","book":"에스겔","book_name":"에스겔","chapter":39,"verse":1,"text":"그러므로 인자야 너는 곡을 쳐서 예언하여 이르기를 주 여호와의 말씀에 로스와 메섹과 두발 왕 곡아 내가 너를 대적하여","reference":"에스겔 39:1","category":"$undefined"},{"id":"21451","book":"에스겔","book_name":"에스겔","chapter":39,"verse":2,"text":"너를 돌이켜서 이끌고 먼 북방에서부터 나와서 이스라엘 산 위에 이르러","reference":"에스겔 39:2","category":"$undefined"},{"id":"21452","book":"에스겔","book_name":"에스겔","chapter":39,"verse":3,"text":"네 활을 쳐서 네 왼손에서 떨어뜨리고 네 살을 네 오른손에서 떨어뜨리리니","reference":"에스겔 39:3","category":"$undefined"},{"id":"21453","book":"에스겔","book_name":"에스겔","chapter":39,"verse":4,"text":"너와 네 모든 떼와 너와 함께한 백성이 다 이스라엘 산에 엎드러지리라 내가 너를 각종 움키는 새와 들짐승에게 붙여 먹게 하리니","reference":"에스겔 39:4","category":"$undefined"},{"id":"21454","book":"에스겔","book_name":"에스겔","chapter":39,"verse":5,"text":"네가 빈들에 엎드러지리라 이는 내가 말하였음이니라 나 주 여호와의 말이니라","reference":"에스겔 39:5","category":"$undefined"},{"id":"21455","book":"에스겔","book_name":"에스겔","chapter":39,"verse":6,"text":"내가 또 불을 마곡과 및 섬에 평안히 거하는 자에게 내리리니 그들이 나를 여호와인 줄 알리라","reference":"에스겔 39:6","category":"$undefined"},{"id":"21456","book":"에스겔","book_name":"에스겔","chapter":39,"verse":7,"text":"내가 내 거룩한 이름을 내 백성 이스라엘 가운데 알게 하여 다시는 내 거룩한 이름을 더럽히지 않게 하리니 열국이 나를 여호와 곧 이스라엘의 거룩한 자인 줄 알리라 하셨다 하라","reference":"에스겔 39:7","category":"$undefined"},{"id":"21457","book":"에스겔","book_name":"에스겔","chapter":39,"verse":8,"text":"나 주 여호와가 말하노라 볼지어다 그 일이 이르고 이루리니 내가 말한 그 날이 이 날이니라","reference":"에스겔 39:8","category":"$undefined"},{"id":"21458","book":"에스겔","book_name":"에스겔","chapter":39,"verse":9,"text":"이스라엘 성읍들에 거한 자가 나가서 그 병기를 불 피워 사르되 큰 방패와 작은 방패와 활과 살과 몽둥이와 창을 취하여 칠년 동안 불 피우리라","reference":"에스겔 39:9","category":"$undefined"},{"id":"21459","book":"에스겔","book_name":"에스겔","chapter":39,"verse":10,"text":"이와 같이 그 병기로 불을 피울 것이므로 그들이 들에서 나무를 취하지 아니하며 삼림에서 벌목하지 아니하겠고 전에 자기에게서 약탈하던 자의 것을 약탈하며 전에 자기에게서 늑탈하던 자의 것을 늑탈하리라 나 주 여호와의 말이니라","reference":"에스겔 39:10","category":"$undefined"},{"id":"21460","book":"에스겔","book_name":"에스겔","chapter":39,"verse":11,"text":"그 날에 내가 곡을 위하여 이스라엘 땅 곧 바다 동편 사람의 통행하는 골짜기를 매장지로 주리니 통행하던 것이 막힐 것이라 사람이 거기서 곡과 그 모든 무리를 장사하고 그 이름을 하몬곡의 골짜기라 일컬으리라","reference":"에스겔 39:11","category":"$undefined"},{"id":"21461","book":"에스겔","book_name":"에스겔","chapter":39,"verse":12,"text":"이스라엘 족속이 일곱 달 동안에 그들을 장사하여 그 땅을 정결케 할 것이라","reference":"에스겔 39:12","category":"$undefined"},{"id":"21462","book":"에스겔","book_name":"에스겔","chapter":39,"verse":13,"text":"그 땅 모든 백성이 그들을 장사하고 그로 말미암아 이름을 얻으리니 이는 나의 영광이 나타나는 날이니라 나 주 여호와의 말이니라","reference":"에스겔 39:13","category":"$undefined"},{"id":"21463","book":"에스겔","book_name":"에스겔","chapter":39,"verse":14,"text":"그들이 사람을 택하여 그 땅에 늘 순행하며 장사할 사람으로 더불어 지면에 남아 있는 시체를 장사하여 그 땅을 정결케 할 것이라 일곱달 후에 그들이 살펴 보되","reference":"에스겔 39:14","category":"$undefined"},{"id":"21464","book":"에스겔","book_name":"에스겔","chapter":39,"verse":15,"text":"순행하는 자가 그 땅으로 통행하다가 사람의 뼈를 보면 그 곁에 표를 세워 장사하는 자로 와서 하몬곡 골짜기에 장사하게 할 것이요","reference":"에스겔 39:15","category":"$undefined"},{"id":"21465","book":"에스겔","book_name":"에스겔","chapter":39,"verse":16,"text":"성의 이름도 하모나라 하리라 그들이 이와 같이 그 땅을 정결케하리라","reference":"에스겔 39:16","category":"$undefined"},{"id":"21466","book":"에스겔","book_name":"에스겔","chapter":39,"verse":17,"text":"너 인자야 나 주 여호와가 말하노라 너는 각종 새와 들의 각종 짐승에게 이르기를 너희는 모여 오라 내가 너희를 위한 잔치 곧 이스라엘 산 위에 예비한 큰 잔치로 너희는 사방에서 모여서 고기를 먹으며 피를 마실지어다","reference":"에스겔 39:17","category":"$undefined"},{"id":"21467","book":"에스겔","book_name":"에스겔","chapter":39,"verse":18,"text":"너희가 용사의 고기를 먹으며 세상 왕들의 피를 마시기를 바산의 살진 짐승 곧 수양이나 어린 양이나 염소나 수송아지를 먹듯 할지라","reference":"에스겔 39:18","category":"$undefined"},{"id":"21468","book":"에스겔","book_name":"에스겔","chapter":39,"verse":19,"text":"내가 너희를 위하여 예비한 잔치의 기름을 너희가 배불리 먹으며 그 피를 취토록 마시되","reference":"에스겔 39:19","category":"$undefined"},{"id":"21469","book":"에스겔","book_name":"에스겔","chapter":39,"verse":20,"text":"내 상에서 말과 기병과 용사와 모든 군사를 배불리 먹을지니라 하라 나 주 여호와의 말이니라","reference":"에스겔 39:20","category":"$undefined"},{"id":"21470","book":"에스겔","book_name":"에스겔","chapter":39,"verse":21,"text":"내가 내 영광을 열국 중에 나타내어 열국으로 나의 행한 심판과 내가 그 위에 나타낸 권능을 보게 하리니","reference":"에스겔 39:21","category":"$undefined"},{"id":"21471","book":"에스겔","book_name":"에스겔","chapter":39,"verse":22,"text":"그 날 이후에 이스라엘 족속은 나를 여호와 자기들의 하나님인 줄 알겠고","reference":"에스겔 39:22","category":"$undefined"},{"id":"21472","book":"에스겔","book_name":"에스겔","chapter":39,"verse":23,"text":"열국은 이스라엘 족속이 그 죄악으로 인하여 사로잡혀 갔던 줄 알지라 그들이 내게 범죄하였으므로 내 얼굴을 그들에게 가리우고 그들을 그 대적의 손에 붙여 다 칼에 엎드러지게 하였으되","reference":"에스겔 39:23","category":"$undefined"},{"id":"21473","book":"에스겔","book_name":"에스겔","chapter":39,"verse":24,"text":"내가 그들의 더러움과 그들의 범죄한대로 행하여 그들에게 내 얼굴을 가리웠었느니라","reference":"에스겔 39:24","category":"$undefined"},{"id":"21474","book":"에스겔","book_name":"에스겔","chapter":39,"verse":25,"text":"그러므로 나 주 여호와가 말하노라 내가 이제 내 거룩한 이름을 위하여 열심을 내어 야곱의 사로잡힌 자를 돌아오게 하며 이스라엘 온 족속에게 긍휼을 베풀지라","reference":"에스겔 39:25","category":"$undefined"},{"id":"21475","book":"에스겔","book_name":"에스겔","chapter":39,"verse":26,"text":"그들이 그 땅에 평안히 거하고 두렵게 할 자가 없게 될 때에 부끄러움을 품고 내게 범한 죄를 뉘우치리니","reference":"에스겔 39:26","category":"$undefined"},{"id":"21476","book":"에스겔","book_name":"에스겔","chapter":39,"verse":27,"text":"곧 내가 그들을 만민 중에서 돌아오게 하고 적국 중에서 모아내어 열국 목전에서 그들로 인하여 나의 거룩함을 나타낼 때에라","reference":"에스겔 39:27","category":"$undefined"},{"id":"21477","book":"에스겔","book_name":"에스겔","chapter":39,"verse":28,"text":"전에는 내가 그들로 사로잡혀 열국에 이르게 하였거니와 후에는 내가 그들을 모아 고토로 돌아오게 하고 그 한 사람도 이방에 남기지 아니하리니 그들이 나를 여호와 자기들의 하나님인 줄 알리라","reference":"에스겔 39:28","category":"$undefined"},{"id":"21478","book":"에스겔","book_name":"에스겔","chapter":39,"verse":29,"text":"내가 다시는 내 얼굴을 그들에게 가리우지 아니하리니 이는 내가 내 신을 이스라엘 족속에게 쏟았음이니라 나 주 여호와의 말이니라","reference":"에스겔 39:29","category":"$undefined"}],"bookSlug":"ezekiel"}]
