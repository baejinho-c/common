2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":4,"verses":[{"id":"20531","book":"에스겔","book_name":"에스겔","chapter":4,"verse":1,"text":"너 인자야 ! 박석을 가져다가 네 앞에 놓고 한 성읍 곧 예루살렘을 그 위에 그리고","reference":"에스겔 4:1","category":"$undefined"},{"id":"20532","book":"에스겔","book_name":"에스겔","chapter":4,"verse":2,"text":"그 성읍을 에워싸되 운제를 세우고 토둔을 쌓고 진을 치고 공성퇴를 둘러 세우고","reference":"에스겔 4:2","category":"$undefined"},{"id":"20533","book":"에스겔","book_name":"에스겔","chapter":4,"verse":3,"text":"또 전철을 가져다가 너와 성읍 사이에 두어 철성을 삼고 성을 향하여 에워싸는 것처럼 에워싸라 이것이 이스라엘 족속에게 징조가 되리라","reference":"에스겔 4:3","category":"$undefined"},{"id":"20534","book":"에스겔","book_name":"에스겔","chapter":4,"verse":4,"text":"너는 또 좌편으로 누워 이스라엘 족속의 죄악을 당하되 네 눕는 날 수대로 그 죄악을 담당할지니라","reference":"에스겔 4:4","category":"$undefined"},{"id":"20535","book":"에스겔","book_name":"에스겔","chapter":4,"verse":5,"text":"내가 그들의 범죄한 햇수대로 네게 날수를 정하였나니 곧 삼백 구십일이니라 너는 이렇게 이스라엘 족속의 죄악을 담당하고","reference":"에스겔 4:5","category":"$undefined"},{"id":"20536","book":"에스겔","book_name":"에스겔","chapter":4,"verse":6,"text":"그 수가 차거든 너는 우편으로 누워 유다 족속의 죄악을 담당하라 내가 네게 사십일로 정하였나니 일일이 일년이니라","reference":"에스겔 4:6","category":"$undefined"},{"id":"20537","book":"에스겔","book_name":"에스겔","chapter":4,"verse":7,"text":"너는 또 에워싼 예루살렘을 향하여 팔을 벗어메고 예언하라","reference":"에스겔 4:7","category":"$undefined"},{"id":"20538","book":"에스겔","book_name":"에스겔","chapter":4,"verse":8,"text":"내가 줄로 너를 동이리니 네가 에워싸는 날이 맞도록 몸을 이리 저리 돌리지 못하리라","reference":"에스겔 4:8","category":"$undefined"},{"id":"20539","book":"에스겔","book_name":"에스겔","chapter":4,"verse":9,"text":"너는 말과, 보리와, 콩과, 팥과, 조와, 귀리를 가져다가 한 그릇에 담고 떡을 만들어 네 모로 눕는 날수 곧 삼백 구십일에 먹되","reference":"에스겔 4:9","category":"$undefined"},{"id":"20540","book":"에스겔","book_name":"에스겔","chapter":4,"verse":10,"text":"너는 식물을 달아서 하루 이십 세겔 중씩 때를 따라 먹고","reference":"에스겔 4:10","category":"$undefined"},{"id":"20541","book":"에스겔","book_name":"에스겔","chapter":4,"verse":11,"text":"물도 힌 육분 일씩 되어서 때를 따라 마시라","reference":"에스겔 4:11","category":"$undefined"},{"id":"20542","book":"에스겔","book_name":"에스겔","chapter":4,"verse":12,"text":"너는 그것을 보리떡처럼 만들어 먹되 그들의 목전에서 인분 불을 피워 구울지니라","reference":"에스겔 4:12","category":"$undefined"},{"id":"20543","book":"에스겔","book_name":"에스겔","chapter":4,"verse":13,"text":"여호와께서 또 가라사대 내가 열국으로 쫓아 흩을 이스라엘 자손이 거기서 이와 같이 부정한 떡을 먹으리라 하시기로","reference":"에스겔 4:13","category":"$undefined"},{"id":"20544","book":"에스겔","book_name":"에스겔","chapter":4,"verse":14,"text":"내가 가로되 오호라 ! 주 여호와여 ! 나는 영혼을 더럽힌 일이 없었나이다 어려서부터 지금까지 스스로 죽은 것이나 짐승에게 찢긴 것을 먹지 아니하였고 가증한 고기를 입에 넣지 아니하였나이다","reference":"에스겔 4:14","category":"$undefined"},{"id":"20545","book":"에스겔","book_name":"에스겔","chapter":4,"verse":15,"text":"여호와께서 내게 이르시되 쇠똥으로 인분을 대신하기를 허하노니 너는 그것으로 떡을 구울지니라","reference":"에스겔 4:15","category":"$undefined"},{"id":"20546","book":"에스겔","book_name":"에스겔","chapter":4,"verse":16,"text":"또 내게 이르시되 인자야 내가 예루살렘에서 의뢰하는 양식을 끊으리니 백성이 경겁 중에 떡을 달아 먹고 민답 중에 물을 되어 마시다가","reference":"에스겔 4:16","category":"$undefined"},{"id":"20547","book":"에스겔","book_name":"에스겔","chapter":4,"verse":17,"text":"떡과 물이 결핍하여 피차에 민답하여 하며 그 죄악 중에서 쇠패하리라","reference":"에스겔 4:17","category":"$undefined"}],"bookSlug":"ezekiel"}]
