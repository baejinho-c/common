2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":40,"verses":[{"id":"21479","book":"에스겔","book_name":"에스겔","chapter":40,"verse":1,"text":"우리가 사로잡힌지 이십 오년이요 성이 함락된 후 십 사년 정월 십일 곧 그 날에 여호와의 권능이 내게 임하여 나를 데리고 이스라엘 땅으로 가시되","reference":"에스겔 40:1","category":"$undefined"},{"id":"21480","book":"에스겔","book_name":"에스겔","chapter":40,"verse":2,"text":"하나님의 이상 중에 나를 데리고 그 땅에 이르러 나를 극히 높은산 위에 내려 놓으시는데 거기서 남으로 향하여 성읍 형상 같은 것이 있더라","reference":"에스겔 40:2","category":"$undefined"},{"id":"21481","book":"에스겔","book_name":"에스겔","chapter":40,"verse":3,"text":"나를 데리시고 거기 이르시니 모양이 놋 같이 빛난 사람 하나가 손에 삼줄과 척량하는 장대를 가지고 문에 서서 있더니","reference":"에스겔 40:3","category":"$undefined"},{"id":"21482","book":"에스겔","book_name":"에스겔","chapter":40,"verse":4,"text":"그 사람이 내게 이르되 인자야 내가 네게 보이는 그것을 눈으로 보고 귀로 들으며 네 마음으로 생각할지어다 내가 이것을 네게 보이려고 이리로 데리고 왔나니 너는 본 것을 다 이스라엘 족속에게 고할지어다 하더라","reference":"에스겔 40:4","category":"$undefined"},{"id":"21483","book":"에스겔","book_name":"에스겔","chapter":40,"verse":5,"text":"내가 본즉 집 바깥 사면으로 담이 있더라 그 사람의 손에 척량하는 장대를 잡았는데 그 장이 팔꿈치에서 손가락에 이르고 한 손바닥 넓이가 더한 자로 육척이라 그 담을 척량하니 두께가 한 장대요 고도 한 장대며","reference":"에스겔 40:5","category":"$undefined"},{"id":"21484","book":"에스겔","book_name":"에스겔","chapter":40,"verse":6,"text":"그가 동향한 문에 이르러 층계에 올라 그 문통을 척량하니 장이 한 장대요 그 문 안통의 장도 한 장대며","reference":"에스겔 40:6","category":"$undefined"},{"id":"21485","book":"에스겔","book_name":"에스겔","chapter":40,"verse":7,"text":"그 문간에 문지기 방들이 있는데 각기 장이 한 장대요 광이 한 장대요 매방 사이 벽이 오척이며 안 문통의 장이 한 장대요 그 앞에 현관이 있고 그 앞에 안 문이 있으며","reference":"에스겔 40:7","category":"$undefined"},{"id":"21486","book":"에스겔","book_name":"에스겔","chapter":40,"verse":8,"text":"그가 또 안 문의 현관을 척량하니 한 장대며","reference":"에스겔 40:8","category":"$undefined"},{"id":"21487","book":"에스겔","book_name":"에스겔","chapter":40,"verse":9,"text":"안 문의 현관을 또 척량하니 팔척이요 그 문 벽은 이척이라 그 문의 현관이 안으로 향하였으며","reference":"에스겔 40:9","category":"$undefined"},{"id":"21488","book":"에스겔","book_name":"에스겔","chapter":40,"verse":10,"text":"그 동문간의 문지기 방은 좌편에 셋이 있고 우편에 셋이 있으니 그 셋이 각각 한 척수요 그 좌우편 벽도 다 한 척수며","reference":"에스겔 40:10","category":"$undefined"},{"id":"21489","book":"에스겔","book_name":"에스겔","chapter":40,"verse":11,"text":"또 그 문통을 척량하니 광이 십척이요 장이 십 삼척이며","reference":"에스겔 40:11","category":"$undefined"},{"id":"21490","book":"에스겔","book_name":"에스겔","chapter":40,"verse":12,"text":"방 앞에 퇴가 있는데 이편 퇴도 일척이요 저편 퇴도 일척이며 그 방은 이편도 육척이요 저편도 육척이며","reference":"에스겔 40:12","category":"$undefined"},{"id":"21491","book":"에스겔","book_name":"에스겔","chapter":40,"verse":13,"text":"그가 그 문간을 척량하니 이 방 지붕 가에서 저 방 지붕 가까지 광이 이십 오척인데 방 문은 서로 반대되었으며","reference":"에스겔 40:13","category":"$undefined"},{"id":"21492","book":"에스겔","book_name":"에스겔","chapter":40,"verse":14,"text":"그가 또 현관을 척량하니 광이 이십척이요 현관 사면에 뜰이 있으며","reference":"에스겔 40:14","category":"$undefined"},{"id":"21493","book":"에스겔","book_name":"에스겔","chapter":40,"verse":15,"text":"바깥 문통에서부터 안 문 현관 앞까지 오십척이며","reference":"에스겔 40:15","category":"$undefined"},{"id":"21494","book":"에스겔","book_name":"에스겔","chapter":40,"verse":16,"text":"문지기 방에는 각각 닫힌 창이 있고 문안 좌우편에 있는 벽 사이에도 창이 있고 그 현관도 그러하고 그 창은 안 좌우편으로 벌여있으며 각 문 벽 위에는 종려나무를 새겼더라","reference":"에스겔 40:16","category":"$undefined"},{"id":"21495","book":"에스겔","book_name":"에스겔","chapter":40,"verse":17,"text":"그가 나를 데리고 바깥 뜰에 들어가니 뜰 삼면에 박석 깔린 땅이 있고 그 박석 깔린 땅 위에 여러 방이 있는데 모두 삼십이며","reference":"에스겔 40:17","category":"$undefined"},{"id":"21496","book":"에스겔","book_name":"에스겔","chapter":40,"verse":18,"text":"그 박석 깔린 땅의 위치는 각 문간의 좌우편인데 그 광이 문간 길이와 같으니 이는 아래 박석 땅이며","reference":"에스겔 40:18","category":"$undefined"},{"id":"21497","book":"에스겔","book_name":"에스겔","chapter":40,"verse":19,"text":"그가 아래 문간 앞에서부터 안 뜰 바깥 문간 앞까지 척량하니 그 광이 일백척이며 동편과 북편이 일반이더라","reference":"에스겔 40:19","category":"$undefined"},{"id":"21498","book":"에스겔","book_name":"에스겔","chapter":40,"verse":20,"text":"그가 바깥 뜰 북향한 문간의 장광을 척량하니","reference":"에스겔 40:20","category":"$undefined"},{"id":"21499","book":"에스겔","book_name":"에스겔","chapter":40,"verse":21,"text":"장이 오십척이요 광이 이십 오척이며 문지기 방이 이편에도 셋이요 저편에도 셋이요 그 벽과 그 현관도 먼저 척량한 문간과 같으며","reference":"에스겔 40:21","category":"$undefined"},{"id":"21500","book":"에스겔","book_name":"에스겔","chapter":40,"verse":22,"text":"그 창과 현관의 장광과 종려나무가 다 동향한 문간과 같으며 그 문간으로 올라가는 일곱 층계가 있고 그 안에 현관이 있으며","reference":"에스겔 40:22","category":"$undefined"},{"id":"21501","book":"에스겔","book_name":"에스겔","chapter":40,"verse":23,"text":"안 뜰에도 북편 문간과 동편 문간과 마주 대한 문간들이 있는데 그가 이 문간에서 맞은편 문간까지 척량하니 일백척이더라","reference":"에스겔 40:23","category":"$undefined"},{"id":"21502","book":"에스겔","book_name":"에스겔","chapter":40,"verse":24,"text":"그가 또 나를 이끌고 남으로 간즉 남향한 문간이 있는데 그 벽과 현관을 척량하니 먼저 척량한 것과 같고","reference":"에스겔 40:24","category":"$undefined"},{"id":"21503","book":"에스겔","book_name":"에스겔","chapter":40,"verse":25,"text":"그 문간과 현관 좌우에 있는 창도 먼저 말한 창과 같더라 그 문간의 장이 오십척이요 광이 이십 오척이며","reference":"에스겔 40:25","category":"$undefined"},{"id":"21504","book":"에스겔","book_name":"에스겔","chapter":40,"verse":26,"text":"또 그리로 올라가는 일곱 층계가 있고 그 안에 현관이 있으며 또 이편 저편 문 벽위에 종려나무를 새겼으며","reference":"에스겔 40:26","category":"$undefined"},{"id":"21505","book":"에스겔","book_name":"에스겔","chapter":40,"verse":27,"text":"안 뜰에도 남향한 문간이 있는데 그가 남향한 그 문간에서 맞은편 문간까지 척량하니 일백척이더라","reference":"에스겔 40:27","category":"$undefined"},{"id":"21506","book":"에스겔","book_name":"에스겔","chapter":40,"verse":28,"text":"그가 나를 데리고 그 남문으로 말미암아 안 뜰에 들어가서 그 남문간을 척량하니 척수는","reference":"에스겔 40:28","category":"$undefined"},{"id":"21507","book":"에스겔","book_name":"에스겔","chapter":40,"verse":29,"text":"장이 오십척이요 광이 이십 오척이며 그 문지기 방과 벽과 현관도 먼저 척량한 것과 같고 그 문간과 그 현관 좌우에도 창이 있으며","reference":"에스겔 40:29","category":"$undefined"},{"id":"21508","book":"에스겔","book_name":"에스겔","chapter":40,"verse":30,"text":"그 사면 현관의 장은 이십 오척이요 광은 오척이며","reference":"에스겔 40:30","category":"$undefined"},{"id":"21509","book":"에스겔","book_name":"에스겔","chapter":40,"verse":31,"text":"현관이 바깥 뜰로 향하였고 그 문 벽 위에도 종려나무를 새겼으며 그 문간으로 올라가는 여덟 층계가 있더라","reference":"에스겔 40:31","category":"$undefined"},{"id":"21510","book":"에스겔","book_name":"에스겔","chapter":40,"verse":32,"text":"그가 나를 데리고 안 뜰 동편으로 가서 그 문간을 척량하니 척수는","reference":"에스겔 40:32","category":"$undefined"},{"id":"21511","book":"에스겔","book_name":"에스겔","chapter":40,"verse":33,"text":"장이 오십척이요 광이 이십 오척이며 그 문지기 방과 벽과 현관이 먼저 척량한 것과 같고 그 문간과 그 현관 좌우에도 창이 있으며","reference":"에스겔 40:33","category":"$undefined"},{"id":"21512","book":"에스겔","book_name":"에스겔","chapter":40,"verse":34,"text":"그 현관이 바깥 뜰로 향하였고 그 이편 저편 문 벽 위에도 종려나무를 새겼으며 그 문간으로 올라가는 여덟 층계가 있더라","reference":"에스겔 40:34","category":"$undefined"},{"id":"21513","book":"에스겔","book_name":"에스겔","chapter":40,"verse":35,"text":"그가 또 나를 데리고 북문에 이르러 척량하니 척수는","reference":"에스겔 40:35","category":"$undefined"},{"id":"21514","book":"에스겔","book_name":"에스겔","chapter":40,"verse":36,"text":"장이 오십척이요 광이 이십 오척이며 그 문지기 방과 벽과 현관이 다 그러하여 그 좌우에도 창이 있으며","reference":"에스겔 40:36","category":"$undefined"},{"id":"21515","book":"에스겔","book_name":"에스겔","chapter":40,"verse":37,"text":"그 현관이 바깥 뜰로 향하였고 그 이편 저편 문 벽 위에도 종려나무를 새겼으며 그 문간으로 올라가는 여덟 층계가 있더라","reference":"에스겔 40:37","category":"$undefined"},{"id":"21516","book":"에스겔","book_name":"에스겔","chapter":40,"verse":38,"text":"그 문 벽 곁에 문이 있는 방이 있는데 그것은 번제물을 씻는 방이며","reference":"에스겔 40:38","category":"$undefined"},{"id":"21517","book":"에스겔","book_name":"에스겔","chapter":40,"verse":39,"text":"그 문의 현관 이편에 상 둘이 있고 저편에 상 둘이 있으니 그 위에서 번제와 속죄제와 속건제의 희생을 잡게 한 것이며","reference":"에스겔 40:39","category":"$undefined"},{"id":"21518","book":"에스겔","book_name":"에스겔","chapter":40,"verse":40,"text":"그 북문 바깥 곧 입구로 올라가는 곳 이편에 상 둘이 있고 문의 현관 저편에 상 둘이 있으니","reference":"에스겔 40:40","category":"$undefined"},{"id":"21519","book":"에스겔","book_name":"에스겔","chapter":40,"verse":41,"text":"문 곁 이편에 상이 넷이 있고 저편에 상이 넷이 있어 합이 여덟상이라 그 위에서 희생을 잡는 소용이며","reference":"에스겔 40:41","category":"$undefined"},{"id":"21520","book":"에스겔","book_name":"에스겔","chapter":40,"verse":42,"text":"또 다듬은 돌로 만들어서 번제에 쓰는 상 넷이 있는데 각 장이 일척 반이요 광이 일척 반이요 고가 일척이라 번제의 희생을 잡을 때에 쓰는 기구가 그 위에 놓였으며","reference":"에스겔 40:42","category":"$undefined"},{"id":"21521","book":"에스겔","book_name":"에스겔","chapter":40,"verse":43,"text":"현관 안에는 길이가 손바닥 넓이 만한 갈고리가 사면에 박혔으며 상들에는 희생의 고기가 있더라","reference":"에스겔 40:43","category":"$undefined"},{"id":"21522","book":"에스겔","book_name":"에스겔","chapter":40,"verse":44,"text":"안 문안 안 뜰에는 방 둘이 있는데 북문 곁에 있는 방은 남으로 향하였고 남문 곁에 있는 방은 북으로 향하였더라","reference":"에스겔 40:44","category":"$undefined"},{"id":"21523","book":"에스겔","book_name":"에스겔","chapter":40,"verse":45,"text":"그가 내게 이르되 남향한 이 방은 성전을 수직하는 제사장들의 쓸 것이요","reference":"에스겔 40:45","category":"$undefined"},{"id":"21524","book":"에스겔","book_name":"에스겔","chapter":40,"verse":46,"text":"북향한 방은 제단을 수직하는 제사장들의 쓸 것이라 이들은 레위의 후손 중 사독의 자손으로서 여호와께 가까이 나아가 수종드는자니라 하고","reference":"에스겔 40:46","category":"$undefined"},{"id":"21525","book":"에스겔","book_name":"에스겔","chapter":40,"verse":47,"text":"그가 또 그 뜰을 척량하니 장이 일백척이요 광이 일백척이라 네모 반듯하며 제단은 전 앞에 있더라","reference":"에스겔 40:47","category":"$undefined"},{"id":"21526","book":"에스겔","book_name":"에스겔","chapter":40,"verse":48,"text":"그가 나를 데리고 전문 현관에 이르러 그 문의 좌우 벽을 척량하니 광이 이편도 오척이요 저편도 오척이며 두께가 문 이편도 삼 척이요 문 저편도 삼척이며","reference":"에스겔 40:48","category":"$undefined"},{"id":"21527","book":"에스겔","book_name":"에스겔","chapter":40,"verse":49,"text":"그 현관의 광은 이십척이요 장은 십 일척이며 문간으로 올라가는 층계가 있고 문 벽 곁에는 기둥이 있는데 하나는 이편에 있고 하나는 저편에 있더라","reference":"에스겔 40:49","category":"$undefined"}],"bookSlug":"ezekiel"}]
