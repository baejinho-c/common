2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":41,"verses":[{"id":"21528","book":"에스겔","book_name":"에스겔","chapter":41,"verse":1,"text":"그가 나를 데리고 성소에 이르러 그 문벽을 척량하니 이편 두께도 육척이요 저편 두께도 육척이라 두께가 이와 같으며","reference":"에스겔 41:1","category":"$undefined"},{"id":"21529","book":"에스겔","book_name":"에스겔","chapter":41,"verse":2,"text":"그 문통의 광이 십척이요 문통 이편 벽의 광이 오척이요 저편 벽의 광이 오척이며 그가 성소를 척량하니 그 장이 사십척이요 그 광이 이십척이며","reference":"에스겔 41:2","category":"$undefined"},{"id":"21530","book":"에스겔","book_name":"에스겔","chapter":41,"verse":3,"text":"그가 안으로 들어가서 내전 문통의 벽을 척량하니 두께가 이척이요 문통이 육척이요 문통의 벽의 광이 각기 칠척이며","reference":"에스겔 41:3","category":"$undefined"},{"id":"21531","book":"에스겔","book_name":"에스겔","chapter":41,"verse":4,"text":"그가 내전을 척량하니 장이 이십척이요 광이 이십척이라 그가 내게 이르되 이는 지성소니라 하고","reference":"에스겔 41:4","category":"$undefined"},{"id":"21532","book":"에스겔","book_name":"에스겔","chapter":41,"verse":5,"text":"전의 벽을 척량하니 두께가 육척이며 전 삼면에 골방이 있는데 광이 각기 사척이며","reference":"에스겔 41:5","category":"$undefined"},{"id":"21533","book":"에스겔","book_name":"에스겔","chapter":41,"verse":6,"text":"골방은 삼층인데 골방 위에 골방이 있어 모두 삼십이라 그 삼면 골방이 전 벽 밖으로 그 벽에 의지하였고 전 벽 속은 범하지 아니하였으며","reference":"에스겔 41:6","category":"$undefined"},{"id":"21534","book":"에스겔","book_name":"에스겔","chapter":41,"verse":7,"text":"이 두루 있는 골방이 그 층이 높아갈수록 넓으므로 전에 둘린 이골방이 높아갈수록 전에 가까와졌으나 전의 넓이는 아래 위가 같으며 골방은 아랫층에서 중층으로 윗층에 올라가게 되었더라","reference":"에스겔 41:7","category":"$undefined"},{"id":"21535","book":"에스겔","book_name":"에스겔","chapter":41,"verse":8,"text":"내가 보니 전 삼면의 지대 곧 모든 골방 밑 지대의 고가 한 장대 곧 큰 자로 육척인데","reference":"에스겔 41:8","category":"$undefined"},{"id":"21536","book":"에스겔","book_name":"에스겔","chapter":41,"verse":9,"text":"전을 의지한 그 골방 바깥벽 두께는 오척이요 그 외에 빈 터가 남았으며","reference":"에스겔 41:9","category":"$undefined"},{"id":"21537","book":"에스겔","book_name":"에스겔","chapter":41,"verse":10,"text":"전 골방 삼면에 광이 이십척 되는 뜰이 둘려 있으며","reference":"에스겔 41:10","category":"$undefined"},{"id":"21538","book":"에스겔","book_name":"에스겔","chapter":41,"verse":11,"text":"그 골방 문은 다 빈 터로 향하였는데 한 문은 북으로 향하였고 한 문은 남으로 향하였으며 그 둘려 있는 빈 터의 광은 오척이더라","reference":"에스겔 41:11","category":"$undefined"},{"id":"21539","book":"에스겔","book_name":"에스겔","chapter":41,"verse":12,"text":"서편 뜰 뒤에 건물이 있는데 광이 칠십척이요 장이 구십척이며 그 사면 벽의 두께가 오척이더라","reference":"에스겔 41:12","category":"$undefined"},{"id":"21540","book":"에스겔","book_name":"에스겔","chapter":41,"verse":13,"text":"그가 전을 척량하니 장이 일백척이요 또 서편 뜰과 그 건물과 그 벽을 합하여 장이 일백척이요","reference":"에스겔 41:13","category":"$undefined"},{"id":"21541","book":"에스겔","book_name":"에스겔","chapter":41,"verse":14,"text":"전 전면의 광이 일백척이요 그 앞 동향한 뜰의 광도 그러하며","reference":"에스겔 41:14","category":"$undefined"},{"id":"21542","book":"에스겔","book_name":"에스겔","chapter":41,"verse":15,"text":"그가 뒷뜰 뒤에 있는 건물을 척량하니 그 좌우편 다락까지 일백 척이더라 내전과 외전과 그 뜰의 현관과","reference":"에스겔 41:15","category":"$undefined"},{"id":"21543","book":"에스겔","book_name":"에스겔","chapter":41,"verse":16,"text":"문통 벽과 닫힌 창과 삼면에 둘려 있는 다락은 문통 안편에서부터 땅에서 창까지 널판으로 가리웠고 (창은 이미 닫히었더라)","reference":"에스겔 41:16","category":"$undefined"},{"id":"21544","book":"에스겔","book_name":"에스겔","chapter":41,"verse":17,"text":"문통 위와 내전과 외전의 사면 벽도 다 그러하니 곧 척량한 대소 대로며","reference":"에스겔 41:17","category":"$undefined"},{"id":"21545","book":"에스겔","book_name":"에스겔","chapter":41,"verse":18,"text":"널판에는 그룹들과 종려나무를 새겼는데 두 그룹 사이에 종려나무 하나가 있으며 매 그룹에 두 얼굴이 있으니","reference":"에스겔 41:18","category":"$undefined"},{"id":"21546","book":"에스겔","book_name":"에스겔","chapter":41,"verse":19,"text":"하나는 사람의 얼굴이라 이편 종려나무를 향하였고 하나는 어린 사자의 얼굴이라 저편 종려나무를 향하였으며 온 전 사면이 다 그러하여","reference":"에스겔 41:19","category":"$undefined"},{"id":"21547","book":"에스겔","book_name":"에스겔","chapter":41,"verse":20,"text":"땅에서부터 문통 위에까지 그룹들과 종려나무들을 새겼으니 성전벽이 다 그러하더라","reference":"에스겔 41:20","category":"$undefined"},{"id":"21548","book":"에스겔","book_name":"에스겔","chapter":41,"verse":21,"text":"외전 문설주는 네모졌고 내전 전면에 있는 식양은 이러하니","reference":"에스겔 41:21","category":"$undefined"},{"id":"21549","book":"에스겔","book_name":"에스겔","chapter":41,"verse":22,"text":"곧 나무 제단의 고가 삼척이요 장이 이척이며 그 모퉁이와 옆과 면을 다 나무로 만들었더라 그가 내게 이르되 이는 여호와의 앞의 상이라 하더라","reference":"에스겔 41:22","category":"$undefined"},{"id":"21550","book":"에스겔","book_name":"에스겔","chapter":41,"verse":23,"text":"내전과 외전에 각기 문이 있는데","reference":"에스겔 41:23","category":"$undefined"},{"id":"21551","book":"에스겔","book_name":"에스겔","chapter":41,"verse":24,"text":"문마다 각기 두 문짝 곧 접치는 두 문짝이 있어 이 문에 두 짝이요 저 문에 두 짝이며","reference":"에스겔 41:24","category":"$undefined"},{"id":"21552","book":"에스겔","book_name":"에스겔","chapter":41,"verse":25,"text":"이 성전 문에 그룹과 종려나무를 새겼는데 벽에 있는 것과 같고 현관 앞에는 나무 디딤판이 있으며","reference":"에스겔 41:25","category":"$undefined"},{"id":"21553","book":"에스겔","book_name":"에스겔","chapter":41,"verse":26,"text":"현관 좌우편에는 닫힌 창도 있고 종려나무도 새겼고 전의 골방과 디딤판도 그러하더라","reference":"에스겔 41:26","category":"$undefined"}],"bookSlug":"ezekiel"}]
