2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":42,"verses":[{"id":"21554","book":"에스겔","book_name":"에스겔","chapter":42,"verse":1,"text":"그가 나를 데리고 밖으로 나가 북편 뜰로 가서 두 방에 이르니 그 두 방의 하나는 골방 앞 뜰을 향하였고 하나는 북편 건물을 향하였는데","reference":"에스겔 42:1","category":"$undefined"},{"id":"21555","book":"에스겔","book_name":"에스겔","chapter":42,"verse":2,"text":"그 방들의 자리의 장이 일백척이요 광이 오십척이며 그 문은 북을 향하였고","reference":"에스겔 42:2","category":"$undefined"},{"id":"21556","book":"에스겔","book_name":"에스겔","chapter":42,"verse":3,"text":"그 방 삼층에 툇마루들이 있는데 한 방의 툇마루는 이십척 되는 안 뜰과 마주 대하였고 한 방의 툇마루는 바깥 뜰 박석 깔린 곳과 마주 대하였으며","reference":"에스겔 42:3","category":"$undefined"},{"id":"21557","book":"에스겔","book_name":"에스겔","chapter":42,"verse":4,"text":"그 두 방 사이에 통한 길이 있어 광이 십척이요 장이 일백척이며 그 문들은 북을 향하였으며","reference":"에스겔 42:4","category":"$undefined"},{"id":"21558","book":"에스겔","book_name":"에스겔","chapter":42,"verse":5,"text":"그 상층의 방은 제일 좁으니 이는 툇마루를 인하여 하층과 중층보다 상층이 더 줄어짐이라","reference":"에스겔 42:5","category":"$undefined"},{"id":"21559","book":"에스겔","book_name":"에스겔","chapter":42,"verse":6,"text":"그 방이 삼층이라도 뜰의 기둥 같은 기둥이 없으므로 그 상층이 하층과 중층보다 더욱 좁아짐이더라","reference":"에스겔 42:6","category":"$undefined"},{"id":"21560","book":"에스겔","book_name":"에스겔","chapter":42,"verse":7,"text":"그 한 방의 바깥 담 곧 뜰의 담과 마주 대한 담의 장이 오십척이니","reference":"에스겔 42:7","category":"$undefined"},{"id":"21561","book":"에스겔","book_name":"에스겔","chapter":42,"verse":8,"text":"바깥 뜰로 향한 방의 장이 오십척임이며 성전 앞을 향한 방은 일백척이며","reference":"에스겔 42:8","category":"$undefined"},{"id":"21562","book":"에스겔","book_name":"에스겔","chapter":42,"verse":9,"text":"이 방들 아래에 동편에서 들어가는 통행구가 있으니 곧 바깥 뜰에서 들어가는 통행구더라","reference":"에스겔 42:9","category":"$undefined"},{"id":"21563","book":"에스겔","book_name":"에스겔","chapter":42,"verse":10,"text":"남편 골방 뜰 맞은편과 남편 건물 맞은편에도 방 둘이 있는데","reference":"에스겔 42:10","category":"$undefined"},{"id":"21564","book":"에스겔","book_name":"에스겔","chapter":42,"verse":11,"text":"그 두 방 사이에 길이 있고 그 방들의 모양은 북편 방 같고 그 장광도 같으며 그 출입구와 문도 그와 같으며","reference":"에스겔 42:11","category":"$undefined"},{"id":"21565","book":"에스겔","book_name":"에스겔","chapter":42,"verse":12,"text":"남편 방에 출입하는 문이 있는데 담 동편 길머리에 있더라","reference":"에스겔 42:12","category":"$undefined"},{"id":"21566","book":"에스겔","book_name":"에스겔","chapter":42,"verse":13,"text":"그가 내게 이르되 좌우 골방 뜰 앞 곧 북편 남편에 있는 방들은 거룩한 방이라 여호와를 가까이 하는 제사장들이 지성물을 거기서 먹을 것이며 지성물 곧 소제와 속죄제와 속건제의 제물을 거기 둘 것이며 이는 거룩한 곳이라","reference":"에스겔 42:13","category":"$undefined"},{"id":"21567","book":"에스겔","book_name":"에스겔","chapter":42,"verse":14,"text":"제사장의 의복은 거룩하므로 제사장이 성소에 들어갔다가 나올 때에 바로 바깥 뜰로 가지 못하고 수종드는 그 의복을 그 방에 두고 다른 옷을 입고 백성의 뜰로 나갈 것이니라 하더라","reference":"에스겔 42:14","category":"$undefined"},{"id":"21568","book":"에스겔","book_name":"에스겔","chapter":42,"verse":15,"text":"그가 안에 있는 전 척량하기를 마친 후에 나를 데리고 동향한 문길로 나가서 사면 담을 척량하는데","reference":"에스겔 42:15","category":"$undefined"},{"id":"21569","book":"에스겔","book_name":"에스겔","chapter":42,"verse":16,"text":"그가 척량하는 장대 곧 그 장대로 동편을 척량하니 오백척이요","reference":"에스겔 42:16","category":"$undefined"},{"id":"21570","book":"에스겔","book_name":"에스겔","chapter":42,"verse":17,"text":"그 장대로 북편을 척량하니 오백척이요","reference":"에스겔 42:17","category":"$undefined"},{"id":"21571","book":"에스겔","book_name":"에스겔","chapter":42,"verse":18,"text":"그 장대로 남편을 척량하니 오백척이요","reference":"에스겔 42:18","category":"$undefined"},{"id":"21572","book":"에스겔","book_name":"에스겔","chapter":42,"verse":19,"text":"서편으로 돌이켜 그 장대로 척량하니 오백척이라","reference":"에스겔 42:19","category":"$undefined"},{"id":"21573","book":"에스겔","book_name":"에스겔","chapter":42,"verse":20,"text":"그가 이와 같이 그 사방을 척량하니 그 사방 담 안 마당의 장과 광이 오백척씩이라 그 담은 거룩한 것과 속된 것을 구별하는 것이더라","reference":"에스겔 42:20","category":"$undefined"}],"bookSlug":"ezekiel"}]
