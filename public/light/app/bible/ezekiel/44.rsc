11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":44,"verses":[{"id":"21601","book":"에스겔","book_name":"에스겔","chapter":44,"verse":1,"text":"그가 나를 데리고 성소 동향한 바깥문에 돌아오시니 그 문이 닫히었더라","reference":"에스겔 44:1","category":"$undefined"},{"id":"21602","book":"에스겔","book_name":"에스겔","chapter":44,"verse":2,"text":"여호와께서 내게 이르시되 이 문은 닫고 다시 열지 못할지니 아무 사람도 그리로 들어 오지 못할 것은 이스라엘 하나님 나 여호와가 그리로 들어 왔음이라 그러므로 닫아 둘지니라","reference":"에스겔 44:2","category":"$undefined"},{"id":"21603","book":"에스겔","book_name":"에스겔","chapter":44,"verse":3,"text":"왕은 왕인 까닭에 안 길로 이 문 현관으로 들어와서 거기 앉아서 나 여호와 앞에서 음식을 먹고 그 길로 나갈 것이니라","reference":"에스겔 44:3","category":"$undefined"},{"id":"21604","book":"에스겔","book_name":"에스겔","chapter":44,"verse":4,"text":"그가 또 나를 데리고 북문을 통하여 전 앞에 이르시기로 내가 보니 여호와의 영광이 여호와의 전에 가득한지라 내가 얼굴을 땅에 대고 엎드린대","reference":"에스겔 44:4","category":"$undefined"},{"id":"21605","book":"에스겔","book_name":"에스겔","chapter":44,"verse":5,"text":"여호와께서 내게 이르시되 인자야 너는 전심으로 주목하여 내가 네게 말하는바 여호와의 전의 모든 규례와 모든 율례를 귀로 듣고 또 전의 입구와 성소의 출구를 전심으로 주의하고","reference":"에스겔 44:5","category":"$undefined"},{"id":"21606","book":"에스겔","book_name":"에스겔","chapter":44,"verse":6,"text":"너는 패역한 자 곧 이스라엘 족속에게 이르기를 주 여호와의 말씀이 이스라엘 족속아 너희의 모든 가증한 일이 족하니라","reference":"에스겔 44:6","category":"$undefined"},{"id":"21607","book":"에스겔","book_name":"에스겔","chapter":44,"verse":7,"text":"대저 너희가 마음과 몸에 할례 받지 아니한 이방인을 데려오고 떡과 기름과 피를 드릴 때에 그들로 내 성소 안에 있게 하여 내 전을 더럽히므로 너희의 모든 가증한 일 외에 그들이 내 언약을 위반케 하는 것이 되었으며","reference":"에스겔 44:7","category":"$undefined"},{"id":"21608","book":"에스겔","book_name":"에스겔","chapter":44,"verse":8,"text":"너희가 내 성물의 직분을 지키지 아니하고 내 성소에 사람을 두어 너희 직분을 대신 지키게 하였느니라","reference":"에스겔 44:8","category":"$undefined"},{"id":"21609","book":"에스겔","book_name":"에스겔","chapter":44,"verse":9,"text":"나 주 여호와가 말하노라 이스라엘 족속 중에 있는 이방인 중에 마음과 몸이 할례를 받지 아니한 이방인은 내 성소에 들어오지 못하리라","reference":"에스겔 44:9","category":"$undefined"},{"id":"21610","book":"에스겔","book_name":"에스겔","chapter":44,"verse":10,"text":"이스라엘 족속이 그릇하여 나를 떠날 때에 레위 사람도 그릇하여 그 우상을 좇아 나를 멀리 떠났으니 그 죄악을 담당하리라","reference":"에스겔 44:10","category":"$undefined"},{"id":"21611","book":"에스겔","book_name":"에스겔","chapter":44,"verse":11,"text":"그러나 그들이 내 성소에서 수종들어 전문을 맡을 것이며 전에서 수종들어 백성의 번제의 희생과 및 다른 희생을 잡아 앞에 서서 수종들게 되리라","reference":"에스겔 44:11","category":"$undefined"},{"id":"21612","book":"에스겔","book_name":"에스겔","chapter":44,"verse":12,"text":"나 주 여호와가 말하노라 그들이 전에 백성을 위하여 그 우상 앞에서 수종들어서 이스라엘 족속으로 죄악에 거치게 하였으므로 내가 내 손을 들어 쳐서 그들로 그 죄악을 담당하여","reference":"에스겔 44:12","category":"$undefined"},{"id":"21613","book":"에스겔","book_name":"에스겔","chapter":44,"verse":13,"text":"내게 가까이 나아와 제사장의 직분을 행치 못하게 하며 또 내 성물 곧 지성물에 가까이 오지 못하게 하리니 그들이 자기의 수욕과 그 행한바 가증한 일을 담당하리라","reference":"에스겔 44:13","category":"$undefined"},{"id":"21614","book":"에스겔","book_name":"에스겔","chapter":44,"verse":14,"text":"그러나 내가 그들을 세워 전을 수직하게 하고 전에 모든 수종드는 일과 그 가운데서 행하는 모든 일을 맡기리라","reference":"에스겔 44:14","category":"$undefined"},{"id":"21615","book":"에스겔","book_name":"에스겔","chapter":44,"verse":15,"text":"이스라엘 족속이 그릇하여 나를 떠날 때에 사독의 자손 레위 사람 제사장들은 내 성소의 직분을 지켰은즉 그들은 내게 가까이 나아와 수종을 들되 내 앞에 서서 기름과 피를 내게 드릴지니라 나 주 여호와의 말이니라","reference":"에스겔 44:15","category":"$undefined"},{"id":"21616","book":"에스겔","book_name":"에스겔","chapter":44,"verse":16,"text":"그들이 내 성소에 들어오며 또 내 상에 가까이 나아와 내게 수종들어 나의 맡긴 직분을 지키되","reference":"에스겔 44:16","category":"$undefined"},{"id":"21617","book":"에스겔","book_name":"에스겔","chapter":44,"verse":17,"text":"그들이 안 뜰 문에 들어올 때에나 안뜰 문과 전 안에서 수종들 때에는 양털 옷을 입지 말고 가는 베 옷을 입을 것이니","reference":"에스겔 44:17","category":"$undefined"},{"id":"21618","book":"에스겔","book_name":"에스겔","chapter":44,"verse":18,"text":"가는 베 관을 머리에 쓰며 가는 베 바지를 입고 땀 나게 하는 것으로 허리를 동이지 말 것이며","reference":"에스겔 44:18","category":"$undefined"},{"id":"21619","book":"에스겔","book_name":"에스겔","chapter":44,"verse":19,"text":"그들이 바깥 뜰 백성에게로 나갈 때에는 수종드는 옷을 벗어 거룩한 방에 두고 다른 옷을 입을지니 이는 그 옷으로 백성을 거룩케 할까 함이니라","reference":"에스겔 44:19","category":"$undefined"},{"id":"21620","book":"에스겔","book_name":"에스겔","chapter":44,"verse":20,"text":"그들은 또 머리털을 밀지도 말며 머리털을 길게 자라게도 말고 그 머리털을 깎기만 할 것이며","reference":"에스겔 44:20","category":"$undefined"},{"id":"21621","book":"에스겔","book_name":"에스겔","chapter":44,"verse":21,"text":"아무 제사장이든지 안 뜰에 들어갈 때에는 포도주를 마시지 말 것이며","reference":"에스겔 44:21","category":"$undefined"},{"id":"21622","book":"에스겔","book_name":"에스겔","chapter":44,"verse":22,"text":"과부나 이혼한 여인에게 장가 들지 말고 오직 이스라엘 족속의 처녀나 혹시 제사장의 과부에게 장가 들 것이며","reference":"에스겔 44:22","category":"$undefined"},{"id":"21623","book":"에스겔","book_name":"에스겔","chapter":44,"verse":23,"text":"내 백성에게 거룩한 것과 속된 것의 구별을 가르치며 부정한 것과 정한 것을 분별하게 할 것이며","reference":"에스겔 44:23","category":"$undefined"},{"id":"21624","book":"에스겔","book_name":"에스겔","chapter":44,"verse":24,"text":"송사하는 일을 재판하되 내 규례대로 재판할 것이며 내 모든 정한 절기에는 내 법도와 율례를 지킬 것이며 또 내 안식일을 거룩케 하며","reference":"에스겔 44:24","category":"$undefined"},{"id":"21625","book":"에스겔","book_name":"에스겔","chapter":44,"verse":25,"text":"시체를 가까이하여 스스로 더럽히지 못할 것이로되 부모나 자녀나 형제나 시집 가지 아니한 자매를 위하여는 더럽힐 수 있으며","reference":"에스겔 44:25","category":"$undefined"},{"id":"21626","book":"에스겔","book_name":"에스겔","chapter":44,"verse":26,"text":"이런 자는 스스로 정결케 한 후에 칠일을 더 지낼 것이요","reference":"에스겔 44:26","category":"$undefined"},{"id":"21627","book":"에스겔","book_name":"에스겔","chapter":44,"verse":27,"text":"성소에 수종들려 하여 안 뜰과 성소에 들어갈 때에는 속죄제를 드릴지니라 나 주 여호와의 말이니라","reference":"에스겔 44:27","category":"$undefined"},{"id":"21628","book":"에스겔","book_name":"에스겔","chapter":44,"verse":28,"text":"그들은 기업이 있으리니 내가 곧 그 기업이라 너희는 이스라엘 가운데서 그들에게 산업을 주지 말라 나는 그 산업이 됨이니라","reference":"에스겔 44:28","category":"$undefined"},{"id":"21629","book":"에스겔","book_name":"에스겔","chapter":44,"verse":29,"text":"그들은 소제와 속죄제와 속건제의 제물을 먹을지니 이스라엘 중에서 구별하여 드리는 물건을 다 그들에게 돌리며","reference":"에스겔 44:29","category":"$undefined"},{"id":"21630","book":"에스겔","book_name":"에스겔","chapter":44,"verse":30,"text":"또 각종 처음 익은 열매와 너희 모든 예물 중에 각종 거제 제물을 다 제사장에게 돌리고 너희가 또 첫 밀가루를 제사장에게 주어 그들로 네 집에 복이 임하도록 하게 하라","reference":"에스겔 44:30","category":"$undefined"},{"id":"21631","book":"에스겔","book_name":"에스겔","chapter":44,"verse":31,"text":"무릇 새나 육축의 스스로 죽은 것이나 찢긴 것은 다 제사장이 먹지 못할 것이니라","reference":"에스겔 44:31","category":"$undefined"}],"bookSlug":"ezekiel"}]
