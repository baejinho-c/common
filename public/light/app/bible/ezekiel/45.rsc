2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":45,"verses":[{"id":"21632","book":"에스겔","book_name":"에스겔","chapter":45,"verse":1,"text":"너희는 제비 뽑아 땅을 나누어 기업을 삼을 때에 한 구역을 거룩한 땅으로 삼아 여호와께 예물로 드릴지니 그 장은 이만 오천척이요 광은 일만척이라 그 구역 안 전부가 거룩하리라","reference":"에스겔 45:1","category":"$undefined"},{"id":"21633","book":"에스겔","book_name":"에스겔","chapter":45,"verse":2,"text":"그 중에서 성소에 속할 땅은 장이 오백척이요 광이 오백척이니 네모 반듯하며 그 외에 사면 오십척으로 뜰이 되게 하되","reference":"에스겔 45:2","category":"$undefined"},{"id":"21634","book":"에스겔","book_name":"에스겔","chapter":45,"verse":3,"text":"이 척량한 중에서 장 이만 오천척과 광 일만 척을 척량하고 그 가운데 성소를 둘지니 지극히 거룩한 곳이요","reference":"에스겔 45:3","category":"$undefined"},{"id":"21635","book":"에스겔","book_name":"에스겔","chapter":45,"verse":4,"text":"그 땅의 거룩한 구역이라 여호와께 가까이 나아가서 성소에서 수종드는 제사장에게 돌려 그 집을 위하여 있는 곳이 되게 하며 성소를 위하여 있는 거룩한 곳이 되게 하고","reference":"에스겔 45:4","category":"$undefined"},{"id":"21636","book":"에스겔","book_name":"에스겔","chapter":45,"verse":5,"text":"또 장 이만 오천척과 광 일만 척을 척량하여 전에서 수종드는 레위 사람에게 돌려 그들의 산업을 삼아 촌 이십을 세우게 하고","reference":"에스겔 45:5","category":"$undefined"},{"id":"21637","book":"에스겔","book_name":"에스겔","chapter":45,"verse":6,"text":"구별한 거룩한 구역 옆에 광 오천척과 장 이만 오천척을 척량하여 성읍의 기지를 삼아 이스라엘 온 족속에게 돌리고","reference":"에스겔 45:6","category":"$undefined"},{"id":"21638","book":"에스겔","book_name":"에스겔","chapter":45,"verse":7,"text":"드린바 거룩한 구역과 성읍의 기지 된 땅의 좌우편 곧 드린바 거룩한 구역의 옆과 성읍의 기지 옆의 땅을 왕에게 돌리되 서편으로 향하여 서편 국경까지와 동편으로 향하여 동편 국경까지니 그장이 구역 하나와 서로 같을지니라","reference":"에스겔 45:7","category":"$undefined"},{"id":"21639","book":"에스겔","book_name":"에스겔","chapter":45,"verse":8,"text":"이 땅으로 왕에게 돌려 이스라엘 중에 기업을 삼게 하면 나의 왕들이 다시는 내 백성을 압제하지 아니하리라 그 나머지 땅은 이스라엘 족속에게 그 지파대로 나눠 줄지니라","reference":"에스겔 45:8","category":"$undefined"},{"id":"21640","book":"에스겔","book_name":"에스겔","chapter":45,"verse":9,"text":"나 주 여호와가 말하노라 이스라엘의 치리자들아 너희에게 족하니라 너희는 강포와 겁탈을 제하여 버리고 공평과 공의를 행하여내 백성에게 토색함을 그칠지니라 나 주 여호와의 말이니라","reference":"에스겔 45:9","category":"$undefined"},{"id":"21641","book":"에스겔","book_name":"에스겔","chapter":45,"verse":10,"text":"너희는 공평한 저울과, 공평한 에바와, 공평한 밧을 쓸지니","reference":"에스겔 45:10","category":"$undefined"},{"id":"21642","book":"에스겔","book_name":"에스겔","chapter":45,"verse":11,"text":"에바와 밧은 그 용량을 동일히 하되 호멜의 용량을 따라 밧은 호멜 십분지 일을 담게 하고 에바도 호멜 십분지 일을 담게 할 것이며","reference":"에스겔 45:11","category":"$undefined"},{"id":"21643","book":"에스겔","book_name":"에스겔","chapter":45,"verse":12,"text":"세겔은 이십 게라니 이십 세겔과, 이십 오 세겔과, 십 오 세겔로 너희 마네가 되게 하라","reference":"에스겔 45:12","category":"$undefined"},{"id":"21644","book":"에스겔","book_name":"에스겔","chapter":45,"verse":13,"text":"너희의 마땅히 드릴 예물이 이러하니 밀 한 호멜에서는 에바 육분지 일을 드리고 보리 한 호멜에서도 에바 육분지 일을 드리며","reference":"에스겔 45:13","category":"$undefined"},{"id":"21645","book":"에스겔","book_name":"에스겔","chapter":45,"verse":14,"text":"기름은 정한 규례대로 한 고르에서 밧 십분지 일을 드릴지니 기름의 밧으로 말하면 한 고르는 십 밧 곧 한 호멜이며(십 밧은 한호멜이라)","reference":"에스겔 45:14","category":"$undefined"},{"id":"21646","book":"에스겔","book_name":"에스겔","chapter":45,"verse":15,"text":"또 이스라엘 윤택한 초장의 떼 이백 마리에서는 한 어린 양을 드릴 것이라 백성을 속죄하기 위하여 이것들로 소제와 번제와 감사 제물을 삼을지니라 나 주 여호와의 말이니라","reference":"에스겔 45:15","category":"$undefined"},{"id":"21647","book":"에스겔","book_name":"에스겔","chapter":45,"verse":16,"text":"이 땅 모든 백성은 이 예물로 이스라엘 왕에게 드리고","reference":"에스겔 45:16","category":"$undefined"},{"id":"21648","book":"에스겔","book_name":"에스겔","chapter":45,"verse":17,"text":"왕은 본분대로 번제와 소제와 전제를 절기와 월삭과 안식일과 이스라엘 족속의 모든 정한 절기에 드릴지니 이스라엘 족속을 속죄하기 위하여 이 속죄제와 소제와 번제와 감사 제물을 갖출지니라","reference":"에스겔 45:17","category":"$undefined"},{"id":"21649","book":"에스겔","book_name":"에스겔","chapter":45,"verse":18,"text":"나 여호와가 말하노라 정월 초 하룻날에 흠없는 수송아지 하나를 취하여 성소를 정결케 하되","reference":"에스겔 45:18","category":"$undefined"},{"id":"21650","book":"에스겔","book_name":"에스겔","chapter":45,"verse":19,"text":"제사장이 그 속죄제 희생의 피를 취하여 전 문설주와 제단 아랫층 네 모퉁이와 안 뜰 문설주에 바를 것이요","reference":"에스겔 45:19","category":"$undefined"},{"id":"21651","book":"에스겔","book_name":"에스겔","chapter":45,"verse":20,"text":"그 달 칠일에도 모든 그릇 범죄한 자와 부지중 범죄한 자를 위하여 역시 그렇게 하여 전을 속죄할지니라","reference":"에스겔 45:20","category":"$undefined"},{"id":"21652","book":"에스겔","book_name":"에스겔","chapter":45,"verse":21,"text":"정월 십 사일에는 유월절 곧 칠일 절기를 지키며 누룩 없는 떡을 먹을 것이라","reference":"에스겔 45:21","category":"$undefined"},{"id":"21653","book":"에스겔","book_name":"에스겔","chapter":45,"verse":22,"text":"그 날에 왕은 자기와 이 땅 모든 백성을 위하여 송아지 하나를 갖추어 속죄제를 드릴 것이요","reference":"에스겔 45:22","category":"$undefined"},{"id":"21654","book":"에스겔","book_name":"에스겔","chapter":45,"verse":23,"text":"또 절기 칠일 동안에는 그가 나 여호와를 위하여 번제를 갖추되 곧 칠일 동안에 매일 흠 없는 수송아지 일곱과 수양 일곱이며 또 매일 수염소 하나를 갖추어 속죄제를 드릴 것이며","reference":"에스겔 45:23","category":"$undefined"},{"id":"21655","book":"에스겔","book_name":"에스겔","chapter":45,"verse":24,"text":"또 소제를 갖추되 수송아지 하나에는 밀가루 한 에바요 수양 하나에도 한 에바며 밀가루 한 에바에는 기름 한 힌씩이며","reference":"에스겔 45:24","category":"$undefined"},{"id":"21656","book":"에스겔","book_name":"에스겔","chapter":45,"verse":25,"text":"칠월 십 오일 절기 칠일 동안에도 이대로 행하여 속죄제와 번제며 그 밀가루와 기름을 드릴지니라","reference":"에스겔 45:25","category":"$undefined"}],"bookSlug":"ezekiel"}]
