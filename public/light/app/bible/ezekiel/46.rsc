2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":46,"verses":[{"id":"21657","book":"에스겔","book_name":"에스겔","chapter":46,"verse":1,"text":"나 주 여호와가 말하노라 안 뜰 동향한 문을 일하는 육일 동안에는 닫되 안식일에는 열며 월삭에도 열고","reference":"에스겔 46:1","category":"$undefined"},{"id":"21658","book":"에스겔","book_name":"에스겔","chapter":46,"verse":2,"text":"왕은 바깥 문 현관을 통하여 들어와서 문 벽 곁에 서고 제사장은 그를 위하여 번제와 감사제를 드릴 것이요 왕은 문통에서 경배한 후에 밖으로 나가고 그 문은 저녁까지 닫지 말 것이며","reference":"에스겔 46:2","category":"$undefined"},{"id":"21659","book":"에스겔","book_name":"에스겔","chapter":46,"verse":3,"text":"이 땅 백성도 안식일과 월삭에 이 문통에서 나 여호와 앞에 경배할 것이며","reference":"에스겔 46:3","category":"$undefined"},{"id":"21660","book":"에스겔","book_name":"에스겔","chapter":46,"verse":4,"text":"안식일에 왕이 여호와께 드릴 번제는 흠 없는 어린 양 여섯과 흠없는 수양 하나라","reference":"에스겔 46:4","category":"$undefined"},{"id":"21661","book":"에스겔","book_name":"에스겔","chapter":46,"verse":5,"text":"그 소제는 수양 하나에는 밀가루 한 에바요 모든 어린 양에는 그 힘대로 할 것이며 밀가루 한 에바에는 기름 한 힌씩이니라","reference":"에스겔 46:5","category":"$undefined"},{"id":"21662","book":"에스겔","book_name":"에스겔","chapter":46,"verse":6,"text":"월삭에는 흠 없는 수송아지 하나와 어린 양 여섯과 수양 하나를 드리되 모두 흠 없는 것으로 할 것이며","reference":"에스겔 46:6","category":"$undefined"},{"id":"21663","book":"에스겔","book_name":"에스겔","chapter":46,"verse":7,"text":"또 소제를 갖추되 수송아지에는 밀가루 한 에바요 수양에도 밀가루 한 에바며 모든 어린 양에는 그 힘대로 할 것이요 밀가루 한 에바에는 기름 한 힌씩이며","reference":"에스겔 46:7","category":"$undefined"},{"id":"21664","book":"에스겔","book_name":"에스겔","chapter":46,"verse":8,"text":"왕이 올 때에는 이 문 현관을 통하여 들어오고 나갈 때에도 그리할지니라","reference":"에스겔 46:8","category":"$undefined"},{"id":"21665","book":"에스겔","book_name":"에스겔","chapter":46,"verse":9,"text":"그러나 모든 정한 절기에 이 땅 거민이 나 여호와 앞에 나아올 때에는 북문으로 들어와서 경배하는 자는 남문으로 나가고 남문으로 들어오는 자는 북문으로 나갈지라 들어온 문으로 도로 나가지 말고 그 몸이 앞으로 향한대로 나갈지며","reference":"에스겔 46:9","category":"$undefined"},{"id":"21666","book":"에스겔","book_name":"에스겔","chapter":46,"verse":10,"text":"왕은 무리 가운데 있어서 그들의 들어올 때에 들어오고 그들의 나갈 때에 나갈지니라","reference":"에스겔 46:10","category":"$undefined"},{"id":"21667","book":"에스겔","book_name":"에스겔","chapter":46,"verse":11,"text":"절기와 성회 때에 그 소제는 수송아지 하나에 밀가루 한 에바요 수양 하나에도 한 에바요 모든 어린 양에는 그 힘대로 할 것이며 밀가루 한 에바에는 기름 한 힌씩이며","reference":"에스겔 46:11","category":"$undefined"},{"id":"21668","book":"에스겔","book_name":"에스겔","chapter":46,"verse":12,"text":"만일 왕이 자원하여 번제를 갖추거나 혹 자원하여 감사제를 갖추어 나 여호와께 드릴 때에는 그를 위하여 동향한 문을 열고 그가 번제와 감사제를 안식일에 드림 같이 드리고 밖으로 나갈지며 나간 후에 문을 닫을지니라","reference":"에스겔 46:12","category":"$undefined"},{"id":"21669","book":"에스겔","book_name":"에스겔","chapter":46,"verse":13,"text":"아침마다 일년 되고 흠 없는 어린 양 하나로 번제를 갖추어 나 여호와께 드리고","reference":"에스겔 46:13","category":"$undefined"},{"id":"21670","book":"에스겔","book_name":"에스겔","chapter":46,"verse":14,"text":"또 아침마다 그것과 함께 드릴 소제를 갖추되 곧 밀가루 에바 육분지 일과 기름 힌 삼분지 일을 섞을 것이니 이는 영원한 규례를 삼아 항상 나 여호와께 드릴 소제라","reference":"에스겔 46:14","category":"$undefined"},{"id":"21671","book":"에스겔","book_name":"에스겔","chapter":46,"verse":15,"text":"이와 같이 아침마다 그 어린 양과 밀가루와 기름을 갖추어 항상 드리는 번제를 삼을지니라","reference":"에스겔 46:15","category":"$undefined"},{"id":"21672","book":"에스겔","book_name":"에스겔","chapter":46,"verse":16,"text":"나 주 여호와가 말하노라 왕이 만일 한 아들에게 선물을 준즉 그의 기업이 되어 그 자손에게 속하나니 이는 그 기업을 이어 받음이어니와","reference":"에스겔 46:16","category":"$undefined"},{"id":"21673","book":"에스겔","book_name":"에스겔","chapter":46,"verse":17,"text":"왕이 만일 그 기업으로 한 종에게 선물로 준즉 그 종에게 속하여 희년까지 이르고 그 후에는 왕에게로 돌아갈 것이니 왕의 기업은 그 아들이 이어 받을 것임이니라","reference":"에스겔 46:17","category":"$undefined"},{"id":"21674","book":"에스겔","book_name":"에스겔","chapter":46,"verse":18,"text":"왕은 백성의 기업을 취하여 그 산업에서 쫓아내지 못할지니 왕이 자기 아들에게 기업으로 줄 것은 자기 산업으로만 할 것임이니라 백성으로 각각 그 산업을 떠나 흩어지지 않게 할 것이니라","reference":"에스겔 46:18","category":"$undefined"},{"id":"21675","book":"에스겔","book_name":"에스겔","chapter":46,"verse":19,"text":"그 후에 그가 나를 데리고 문곁 통행구로 말미암아 제사장의 북향한 거룩한 방에 들어가시니 그 방뒤 서편에 한 처소가 있더라","reference":"에스겔 46:19","category":"$undefined"},{"id":"21676","book":"에스겔","book_name":"에스겔","chapter":46,"verse":20,"text":"그가 내게 이르시되 이는 제사장이 속건제와 속죄제 희생을 삶으며 소제 제물을 구울 처소니 그들이 이 성물을 가지고 바깥 뜰에 나가면 백성을 거룩하게 할까 함이니라 하시고","reference":"에스겔 46:20","category":"$undefined"},{"id":"21677","book":"에스겔","book_name":"에스겔","chapter":46,"verse":21,"text":"나를 데리고 바깥 뜰로 나가서 나로 뜰 네 구석을 지나가게 하시는데 본즉 그 뜰 매 구석에 또 뜰이 있는데","reference":"에스겔 46:21","category":"$undefined"},{"id":"21678","book":"에스겔","book_name":"에스겔","chapter":46,"verse":22,"text":"뜰 네 구석에 있는 그 뜰에 담이 둘렸으니 뜰의 장이 사십척이요 광이 삼십척이라 구석의 네 뜰이 한 척수며","reference":"에스겔 46:22","category":"$undefined"},{"id":"21679","book":"에스겔","book_name":"에스겔","chapter":46,"verse":23,"text":"그 작은 네 뜰 사면으로 돌아가며 부엌이 있고 그 사면 부엌에 삶는 기구가 설비되었었는데","reference":"에스겔 46:23","category":"$undefined"},{"id":"21680","book":"에스겔","book_name":"에스겔","chapter":46,"verse":24,"text":"그가 내게 이르시되 이는 삶는 부엌이니 전에 수종드는 자가 백성의 제물을 여기서 삶을 것이니라 하시더라","reference":"에스겔 46:24","category":"$undefined"}],"bookSlug":"ezekiel"}]
