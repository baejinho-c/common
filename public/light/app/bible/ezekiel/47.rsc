2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":47,"verses":[{"id":"21681","book":"에스겔","book_name":"에스겔","chapter":47,"verse":1,"text":"그가 나를 데리고 전 문에 이르시니 전의 전면이 동을 향하였는데 그 문지방 밑에서 물이 나와서 동으로 흐르다가 전 우편 제단남편으로 흘러 내리더라","reference":"에스겔 47:1","category":"$undefined"},{"id":"21682","book":"에스겔","book_name":"에스겔","chapter":47,"verse":2,"text":"그가 또 나를 데리고 북문으로 나가서 바깥 길로 말미암아 꺾여 동향한 바깥 문에 이르시기로 본즉 물이 그 우편에서 스미어 나오더라","reference":"에스겔 47:2","category":"$undefined"},{"id":"21683","book":"에스겔","book_name":"에스겔","chapter":47,"verse":3,"text":"그 사람이 손에 줄을 잡고 동으로 나아가며 일천척을 척량한 후에 나로 그 물을 건너게 하시니 물이 발목에 오르더니","reference":"에스겔 47:3","category":"$undefined"},{"id":"21684","book":"에스겔","book_name":"에스겔","chapter":47,"verse":4,"text":"다시 일천척을 척량하고 나로 물을 건너게 하시니 물이 무릎에 오르고 다시 일천척을 척량하고 나로 물을 건너게 하시니 물이 허리에 오르고","reference":"에스겔 47:4","category":"$undefined"},{"id":"21685","book":"에스겔","book_name":"에스겔","chapter":47,"verse":5,"text":"다시 일천척을 척량하시니 물이 내가 건너지 못할 강이 된지라 그 물이 창일하여 헤엄할 물이요 사람이 능히 건너지 못할 강이더라","reference":"에스겔 47:5","category":"$undefined"},{"id":"21686","book":"에스겔","book_name":"에스겔","chapter":47,"verse":6,"text":"그가 내게 이르시되 인자야 네가 이것을 보았느냐 하시고 나를 인도하여 강가로 돌아가게 하시기로","reference":"에스겔 47:6","category":"$undefined"},{"id":"21687","book":"에스겔","book_name":"에스겔","chapter":47,"verse":7,"text":"내가 돌아간즉 강 좌우편에 나무가 심히 많더라","reference":"에스겔 47:7","category":"$undefined"},{"id":"21688","book":"에스겔","book_name":"에스겔","chapter":47,"verse":8,"text":"그가 내게 이르시되 이 물이 동방으로 향하여 흘러 아라바로 내려가서 바다에 이르리니 이 흘러 내리는 물로 그 바다의 물이 소성함을 얻을지라","reference":"에스겔 47:8","category":"$undefined"},{"id":"21689","book":"에스겔","book_name":"에스겔","chapter":47,"verse":9,"text":"이 강물이 이르는 곳마다 번성하는 모든 생물이 살고 또 고기가 심히 많으리니 이 물이 흘러 들어 가므로 바닷물이 소성함을 얻겠고 이 강이 이르는 각처에 모든 것이 살 것이며","reference":"에스겔 47:9","category":"$undefined"},{"id":"21690","book":"에스겔","book_name":"에스겔","chapter":47,"verse":10,"text":"또 이 강 가에 어부가 설 것이니 엔게디에서부터 에네글라임까지 그물 치는 곳이 될 것이라 그 고기가 각기 종류를 따라 큰 바다의 고기 같이 심히 많으려니와","reference":"에스겔 47:10","category":"$undefined"},{"id":"21691","book":"에스겔","book_name":"에스겔","chapter":47,"verse":11,"text":"그 진펄과 개펄은 소성되지 못하고 소금 땅이 될 것이며","reference":"에스겔 47:11","category":"$undefined"},{"id":"21692","book":"에스겔","book_name":"에스겔","chapter":47,"verse":12,"text":"강 좌우 가에는 각종 먹을 실과나무가 자라서 그 잎이 시들지 아니하며 실과가 끊치지 아니하고 달마다 새 실과를 맺으리니 그 물이 성소로 말미암아 나옴이라 그 실과는 먹을만하고 그 잎사귀는 약 재료가 되리라","reference":"에스겔 47:12","category":"$undefined"},{"id":"21693","book":"에스겔","book_name":"에스겔","chapter":47,"verse":13,"text":"나 주 여호와가 말하노라 너희는 이 지계대로 이스라엘 십 이 지파에게 이 땅을 나누어 기업이 되게 하되 요셉에게는 두 분깃이니라","reference":"에스겔 47:13","category":"$undefined"},{"id":"21694","book":"에스겔","book_name":"에스겔","chapter":47,"verse":14,"text":"내가 옛적에 맹세하여 이 땅으로 너희 열조에게 주마 하였었나니 너희는 피차 없이 나누어 기업을 삼으라 이 땅이 너희의 기업이 되리라","reference":"에스겔 47:14","category":"$undefined"},{"id":"21695","book":"에스겔","book_name":"에스겔","chapter":47,"verse":15,"text":"이 땅 지계는 이러하니라 북방은 대해에서 헤들론 길로 말미암아 스닷 어귀까지니","reference":"에스겔 47:15","category":"$undefined"},{"id":"21696","book":"에스겔","book_name":"에스겔","chapter":47,"verse":16,"text":"곧 하맛과 브로다며 다메섹 지계와 하맛 지계 사이에 있는 시브라임과 하우란 지계 곁에 있는 하셀핫디곤이라","reference":"에스겔 47:16","category":"$undefined"},{"id":"21697","book":"에스겔","book_name":"에스겔","chapter":47,"verse":17,"text":"그 지계가 바닷가에서부터 다메섹과 지계에 있는 하살에논까지요 그 지계가 또 극북방에 있는 하맛 지계에 미쳤나니 이는 그 북방이요","reference":"에스겔 47:17","category":"$undefined"},{"id":"21698","book":"에스겔","book_name":"에스겔","chapter":47,"verse":18,"text":"동방은 하우란과 다메섹과 및 길르앗과 이스라엘 땅 사이에 있는 요단강이니 북편 지계에서부터 동해까지 척량하라 이는 그 동방이요","reference":"에스겔 47:18","category":"$undefined"},{"id":"21699","book":"에스겔","book_name":"에스겔","chapter":47,"verse":19,"text":"남방은 다말에서부터 므리봇 가데스 물에 이르고 애굽 시내를 따라 대해에 이르나니 이는 그 남방이요","reference":"에스겔 47:19","category":"$undefined"},{"id":"21700","book":"에스겔","book_name":"에스겔","chapter":47,"verse":20,"text":"서방은 대해라 남편 지계에서부터 맞은편 하맛 어귀까지 이르나니 이는 그 서방이니라","reference":"에스겔 47:20","category":"$undefined"},{"id":"21701","book":"에스겔","book_name":"에스겔","chapter":47,"verse":21,"text":"그런즉 너희가 이스라엘 모든 지파대로 이 땅을 나누어 차지하라","reference":"에스겔 47:21","category":"$undefined"},{"id":"21702","book":"에스겔","book_name":"에스겔","chapter":47,"verse":22,"text":"너희는 이 땅을 나누되 제비 뽑아 너희와 너희 가운데 우거하는 외인 곧 너희 가운데서 자녀를 낳은 자의 기업이 되게 할지니 너희는 그 외인을 본토에서 난 이스라엘 족속같이 여기고 그들로 이스라엘 지파 중에서 너희와 함께 기업을 얻게 하되","reference":"에스겔 47:22","category":"$undefined"},{"id":"21703","book":"에스겔","book_name":"에스겔","chapter":47,"verse":23,"text":"외인이 우거하는 그 지파에서 그 기업을 줄지니라 나 주 여호와의 말이니라","reference":"에스겔 47:23","category":"$undefined"}],"bookSlug":"ezekiel"}]
