2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":48,"verses":[{"id":"21704","book":"에스겔","book_name":"에스겔","chapter":48,"verse":1,"text":"모든 지파의 이름대로 이 같을지니라 극북에서부터 헤들론 길로 말미암아 하맛 어귀를 지나서 다메섹 지계에 있는 하살에논까지 곧 북으로 하맛 지계에 미치는 땅 동편에서 서편까지는 단의 분깃이요","reference":"에스겔 48:1","category":"$undefined"},{"id":"21705","book":"에스겔","book_name":"에스겔","chapter":48,"verse":2,"text":"단 지계 다음으로 동편에서 서편까지는 아셀의 분깃이요","reference":"에스겔 48:2","category":"$undefined"},{"id":"21706","book":"에스겔","book_name":"에스겔","chapter":48,"verse":3,"text":"아셀 지계 다음으로 동편에서 서편까지는 납달리의 분깃이요","reference":"에스겔 48:3","category":"$undefined"},{"id":"21707","book":"에스겔","book_name":"에스겔","chapter":48,"verse":4,"text":"납달리 지계 다음으로 동편에서 서편까지는 므낫세의 분깃이요","reference":"에스겔 48:4","category":"$undefined"},{"id":"21708","book":"에스겔","book_name":"에스겔","chapter":48,"verse":5,"text":"므낫세 지계 다음으로 동편에서 서편까지는 에브라임의 분깃이요","reference":"에스겔 48:5","category":"$undefined"},{"id":"21709","book":"에스겔","book_name":"에스겔","chapter":48,"verse":6,"text":"에브라임 지계 다음으로 동편에서 서편까지는 르우벤의 분깃이요","reference":"에스겔 48:6","category":"$undefined"},{"id":"21710","book":"에스겔","book_name":"에스겔","chapter":48,"verse":7,"text":"르우벤 지계 다음으로 동편에서 서편까지는 유다의 분깃이요","reference":"에스겔 48:7","category":"$undefined"},{"id":"21711","book":"에스겔","book_name":"에스겔","chapter":48,"verse":8,"text":"유다 지계 다음으로 동편에서 서편까지는 너희가 예물로 드릴 땅이라 광이 이만 오천척이요 장은 다른 분깃의 동편에서 서편까지와 같고 성소는 그 중앙에 있을지니","reference":"에스겔 48:8","category":"$undefined"},{"id":"21712","book":"에스겔","book_name":"에스겔","chapter":48,"verse":9,"text":"곧 너희가 여호와께 드려 예물로 삼을 땅의 장이 이만 오천척이요 광이 일만 척이라","reference":"에스겔 48:9","category":"$undefined"},{"id":"21713","book":"에스겔","book_name":"에스겔","chapter":48,"verse":10,"text":"이 드리는 거룩한 땅은 제사장에게 돌릴지니 북편으로 장이 이만 오천척이요 서편으로 광이 일만척이요 동편으로 광이 일만척이요 남편으로 장이 이만 오천척이라 그 중앙에 여호와의 성소가 있게 하고","reference":"에스겔 48:10","category":"$undefined"},{"id":"21714","book":"에스겔","book_name":"에스겔","chapter":48,"verse":11,"text":"이 땅으로 사독의 자손 중 거룩히 구별한 제사장에게 돌릴지어다 그들은 직분을 지키고 이스라엘 족속이 그릇할 때에 레위 사람의 그릇한 것처럼 그릇까지 아니하였느니라","reference":"에스겔 48:11","category":"$undefined"},{"id":"21715","book":"에스겔","book_name":"에스겔","chapter":48,"verse":12,"text":"이 온 땅 중에서 예물로 드리는 땅 곧 레위 지계와 연접한 땅을 그들이 지극히 거룩한 것으로 여길지니라","reference":"에스겔 48:12","category":"$undefined"},{"id":"21716","book":"에스겔","book_name":"에스겔","chapter":48,"verse":13,"text":"제사장의 지계를 따라 레위 사람의 분깃을 주되 장이 이만 오천척이요 광이 일만 척으로 할지니 이 구역의 장이 이만 오천척이요 광이 각기 일만 척이라","reference":"에스겔 48:13","category":"$undefined"},{"id":"21717","book":"에스겔","book_name":"에스겔","chapter":48,"verse":14,"text":"그들이 그 땅을 팔지도 못하며 바꾸지도 못하며 그 땅의 처음 익은 열매를 남에게 주지도 못하리니 이는 나 여호와에게 거룩히 구별한 것임이니라","reference":"에스겔 48:14","category":"$undefined"},{"id":"21718","book":"에스겔","book_name":"에스겔","chapter":48,"verse":15,"text":"이 이만 오천척 다음으로 광 오천척은 속된 땅으로 하여 성읍을 세우며 거하는 곳과 들을 삼되 성이 그 중앙에 있게 할지니","reference":"에스겔 48:15","category":"$undefined"},{"id":"21719","book":"에스겔","book_name":"에스겔","chapter":48,"verse":16,"text":"그 척수는 북편도 사천 오백척이요 남편도 사천 오백척이요, 동편도 사천 오백척이요, 서편도 사천 오백척이며","reference":"에스겔 48:16","category":"$undefined"},{"id":"21720","book":"에스겔","book_name":"에스겔","chapter":48,"verse":17,"text":"그 성의 들은 북으로 이백 오십 척이요 남으로 이백 오십 척이요, 동으로 이백 오십척이요, 서으로 이백 오십척이며","reference":"에스겔 48:17","category":"$undefined"},{"id":"21721","book":"에스겔","book_name":"에스겔","chapter":48,"verse":18,"text":"예물을 삼아 거룩히 구별할 땅과 연접하여 남아 있는 땅의 장이 동으로 일만 척이요 서으로 일만척이라 곧 예물을 삼아 거룩히 구별할 땅과 연접하였으며 그 땅의 소산은 성읍에서 역사하는 자의 양식을 삼을지라","reference":"에스겔 48:18","category":"$undefined"},{"id":"21722","book":"에스겔","book_name":"에스겔","chapter":48,"verse":19,"text":"이스라엘 모든 지파 중에 그 성읍에서 역사하는 자는 그 땅을 기경할지니라","reference":"에스겔 48:19","category":"$undefined"},{"id":"21723","book":"에스겔","book_name":"에스겔","chapter":48,"verse":20,"text":"그런즉 예물로 드리는 땅의 도합은 장도 이만 오천척이요 광도 이만 오천척이라 너희가 거룩히 구별하여 드릴 땅은 성읍의 기지와 합하여 네모 반듯할 것이니라","reference":"에스겔 48:20","category":"$undefined"},{"id":"21724","book":"에스겔","book_name":"에스겔","chapter":48,"verse":21,"text":"거룩히 구별할 땅과 성읍의 기지 좌우편에 남은 땅은 왕에게 돌릴지니 곧 거룩히 구별할 땅의 동향한 그 지계 앞 이만 오천척이라 다른 분깃들과 연접한 땅이니 이것을 왕에게 돌릴 것이며 거룩히 구별할 땅과 전의 성소가 그 중간에 있으리라","reference":"에스겔 48:21","category":"$undefined"},{"id":"21725","book":"에스겔","book_name":"에스겔","chapter":48,"verse":22,"text":"그런즉 왕에게 돌려 그에게 속할 땅은 레위 사람의 기업 좌우편과 성읍의 기지 좌우편이며 유다 지경과 베냐민 지경 사이에 있 을지니라","reference":"에스겔 48:22","category":"$undefined"},{"id":"21726","book":"에스겔","book_name":"에스겔","chapter":48,"verse":23,"text":"그 나머지 모든 지파는 동편에서 서편까지는 베냐민의 분깃이요","reference":"에스겔 48:23","category":"$undefined"},{"id":"21727","book":"에스겔","book_name":"에스겔","chapter":48,"verse":24,"text":"베냐민 지계 다음으로 동편에서 서편까지는 시므온의 분깃이요","reference":"에스겔 48:24","category":"$undefined"},{"id":"21728","book":"에스겔","book_name":"에스겔","chapter":48,"verse":25,"text":"시므온 지계 다음으로 동편에서 서편까지는 잇사갈의 분깃이요","reference":"에스겔 48:25","category":"$undefined"},{"id":"21729","book":"에스겔","book_name":"에스겔","chapter":48,"verse":26,"text":"잇사갈 지계 다음으로 동편에서 서편까지는 스불론의 분깃이요","reference":"에스겔 48:26","category":"$undefined"},{"id":"21730","book":"에스겔","book_name":"에스겔","chapter":48,"verse":27,"text":"스불론 지계 다음으로 동편에서 서편까지는 갓의 분깃이며","reference":"에스겔 48:27","category":"$undefined"},{"id":"21731","book":"에스겔","book_name":"에스겔","chapter":48,"verse":28,"text":"갓 지계 다음으로 남편 지계는 다말에서부터 므리바가데스 물에 이르고 애굽 시내를 따라 대해에 이르나니","reference":"에스겔 48:28","category":"$undefined"},{"id":"21732","book":"에스겔","book_name":"에스겔","chapter":48,"verse":29,"text":"이것은 너희가 제비 뽑아 이스라엘 지파에게 나누어 주어 기업이 되게 할 땅이요 또 이것들은 그들의 분깃이니라 나 주 여호와의 말이니라","reference":"에스겔 48:29","category":"$undefined"},{"id":"21733","book":"에스겔","book_name":"에스겔","chapter":48,"verse":30,"text":"그 성읍의 출입구는 이러하니라 북편의 광이 사천 오백척이라","reference":"에스겔 48:30","category":"$undefined"},{"id":"21734","book":"에스겔","book_name":"에스겔","chapter":48,"verse":31,"text":"그 성읍의 문들은 이스라엘 지파들의 이름을 따를 것인데 북으로 문이 셋이라 하나는 르우벤 문이요, 하나는 유다 문이요, 하나는 레위 문이며","reference":"에스겔 48:31","category":"$undefined"},{"id":"21735","book":"에스겔","book_name":"에스겔","chapter":48,"verse":32,"text":"동편의 광이 사천 오백척이니 또한 문이 셋이라 하나는 요셉 문이요, 하나는 베냐민 문이요, 하나는 단 문이며","reference":"에스겔 48:32","category":"$undefined"},{"id":"21736","book":"에스겔","book_name":"에스겔","chapter":48,"verse":33,"text":"남편의 광이 사천 오백척이니 또한 문이 셋이라 하나는 시므온 문이요, 하나는 잇사갈 문이요, 하나는 스불론 문이며","reference":"에스겔 48:33","category":"$undefined"},{"id":"21737","book":"에스겔","book_name":"에스겔","chapter":48,"verse":34,"text":"서편도 사천 오백척이니 또한 문이 셋이라 하나는 갓 문이요, 하나는 아셀 문이요, 하나는 납달리 문이며","reference":"에스겔 48:34","category":"$undefined"},{"id":"21738","book":"에스겔","book_name":"에스겔","chapter":48,"verse":35,"text":"그 사면의 도합이 일만 팔천척이라 그 날 후로는 그 성읍의 이름을 여호와 삼마라 하리라","reference":"에스겔 48:35","category":"$undefined"}],"bookSlug":"ezekiel"}]
