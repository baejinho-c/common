2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":5,"verses":[{"id":"20548","book":"에스겔","book_name":"에스겔","chapter":5,"verse":1,"text":"인자야 ! 너는 날카로운 칼을 취하여 삭도를 삼아 네 머리털과 수염을 깎아서 저울에 달아 나누었다가","reference":"에스겔 5:1","category":"$undefined"},{"id":"20549","book":"에스겔","book_name":"에스겔","chapter":5,"verse":2,"text":"그 성읍을 에워싸는 날이 차거든 너는 터럭 삼분지 일은 성읍 안에서 불사르고 삼분지 일은 가지고 성읍 사방에서 칼로 치고 또 삼분지 일은 바람에 흩으라 내가 그 뒤를 따라 칼을 빼리라","reference":"에스겔 5:2","category":"$undefined"},{"id":"20550","book":"에스겔","book_name":"에스겔","chapter":5,"verse":3,"text":"너는 터럭 중에서 조금을 가져 네 옷자락에 싸고","reference":"에스겔 5:3","category":"$undefined"},{"id":"20551","book":"에스겔","book_name":"에스겔","chapter":5,"verse":4,"text":"또 그 가운데서 얼마를 가져 불에 던져 사르라 그 속에서 불이 이스라엘 온 족속에게로 나오리라","reference":"에스겔 5:4","category":"$undefined"},{"id":"20552","book":"에스겔","book_name":"에스겔","chapter":5,"verse":5,"text":"주 여호와께서 가라사대 이것이 곧 예루살렘이라 내가 그를 이방인 가운데 두어 열방으로 둘러 있게 하였거늘","reference":"에스겔 5:5","category":"$undefined"},{"id":"20553","book":"에스겔","book_name":"에스겔","chapter":5,"verse":6,"text":"그가 내 규례를 거스려서 이방인보다 악을 더 행하며 내 율례도 그리함이 그 둘러 있는 열방보다 더하니 이는 그들이 내 규례를 버리고 내 율례를 행치 아니하였음이니라","reference":"에스겔 5:6","category":"$undefined"},{"id":"20554","book":"에스겔","book_name":"에스겔","chapter":5,"verse":7,"text":"그러므로 나 주 여호와가 말하노라 너희 요란함이 너희를 둘러 있는 이방인보다 더하여 내 율례를 행치 아니하며 내 규례를 지키지 아니하고 너희를 둘러 있는 이방인의 규례대로도 행치 아니하였느니라","reference":"에스겔 5:7","category":"$undefined"},{"id":"20555","book":"에스겔","book_name":"에스겔","chapter":5,"verse":8,"text":"그러므로 나 주 여호와가 말하노라 나 곧 내가 저를 치며 이방인의 목전에서 너희 중에 벌을 내리되","reference":"에스겔 5:8","category":"$undefined"},{"id":"20556","book":"에스겔","book_name":"에스겔","chapter":5,"verse":9,"text":"네 모든 가증한 일로 인하여 내가 전무후무하게 네게 내릴지라","reference":"에스겔 5:9","category":"$undefined"},{"id":"20557","book":"에스겔","book_name":"에스겔","chapter":5,"verse":10,"text":"그리한즉 너희 중에서 아비가 아들을 먹고 아들이 그 아비를 먹으리라 내가 벌을 네게 내리고 너희 중에 남은 자를 다 사방에 흩으리라","reference":"에스겔 5:10","category":"$undefined"},{"id":"20558","book":"에스겔","book_name":"에스겔","chapter":5,"verse":11,"text":"그러므로 나 주 여호와가 말하노라 내가 나의 삶을 두고 맹세하노니 네가 모든 미운 물건과 모든 가증한 일로 내 성소를 더럽혔은즉 나도 너를 아껴 보지 아니하며 긍휼을 베풀지 아니하고 미약하게 하리니","reference":"에스겔 5:11","category":"$undefined"},{"id":"20559","book":"에스겔","book_name":"에스겔","chapter":5,"verse":12,"text":"너희 가운데서 삼분지 일은 온역으로 죽으며 기근으로 멸망할 것이요 삼분지 일은 너희 사방에서 칼에 엎드러질 것이며 삼분지 일은 내가 사방에 흩고 또 그 뒤를 따라 칼을 빼리라","reference":"에스겔 5:12","category":"$undefined"},{"id":"20560","book":"에스겔","book_name":"에스겔","chapter":5,"verse":13,"text":"이와 같이 내 노가 다한즉 그들에게 향한 분이 풀려서 내 마음이 시원하리라 내 분이 그들에게 다 한즉 나 여호와가 열심으로 말한 줄을 그들이 알리라","reference":"에스겔 5:13","category":"$undefined"},{"id":"20561","book":"에스겔","book_name":"에스겔","chapter":5,"verse":14,"text":"내가 또 너로 황무케 하고 너를 둘러 있는 이방인 중에서 모든 지나가는 자의 목전에 능욕거리가 되게 하리니","reference":"에스겔 5:14","category":"$undefined"},{"id":"20562","book":"에스겔","book_name":"에스겔","chapter":5,"verse":15,"text":"내 노와 분과 중한 책망으로 네게 벌을 내린즉 너를 둘러 있는 이방인에게 네가 수욕과 조롱을 당하고 경계와 괴이한 것이 되리라 나 여호와의 말이니라","reference":"에스겔 5:15","category":"$undefined"},{"id":"20563","book":"에스겔","book_name":"에스겔","chapter":5,"verse":16,"text":"내가 멸망케 하는 기근의 독한 살로 너희를 멸하러 보내되 기근을 더하여 너희의 의뢰하는 양식을 끊을 것이라","reference":"에스겔 5:16","category":"$undefined"},{"id":"20564","book":"에스겔","book_name":"에스겔","chapter":5,"verse":17,"text":"내가 기근과 악한 짐승을 너희에게 보내어 외롭게 하고 너희 가운데 온역과 살륙으로 행하게 하고 또 칼이 너희에게 임하게 하리라 나 여호와의 말이니라","reference":"에스겔 5:17","category":"$undefined"}],"bookSlug":"ezekiel"}]
