2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":6,"verses":[{"id":"20565","book":"에스겔","book_name":"에스겔","chapter":6,"verse":1,"text":"여호와의 말씀이 내게 임하여 가라사대","reference":"에스겔 6:1","category":"$undefined"},{"id":"20566","book":"에스겔","book_name":"에스겔","chapter":6,"verse":2,"text":"인자야 ! 너는 이스라엘 산을 향하여 그들에게 예언하여","reference":"에스겔 6:2","category":"$undefined"},{"id":"20567","book":"에스겔","book_name":"에스겔","chapter":6,"verse":3,"text":"이르기를 이스라엘 산들아 주 여호와의 말씀을 들으라 주 여호와께서 산과 작은 산과 시내와 골짜기를 대하여 말씀하시기를 나 곧 내가 칼로 너희에게 임하게 하여 너희 산당을 멸하리니","reference":"에스겔 6:3","category":"$undefined"},{"id":"20568","book":"에스겔","book_name":"에스겔","chapter":6,"verse":4,"text":"너희 제단이 황무하고 태양상이 훼파될 것이며 내가 또 너희 중에서 살륙을 당하여 너희 우상 앞에 엎드러지게 할 것이라","reference":"에스겔 6:4","category":"$undefined"},{"id":"20569","book":"에스겔","book_name":"에스겔","chapter":6,"verse":5,"text":"이스라엘 자손의 시체를 그 우상 앞에 두며 너희 해골을 너희 제단 사방에 흩으리라","reference":"에스겔 6:5","category":"$undefined"},{"id":"20570","book":"에스겔","book_name":"에스겔","chapter":6,"verse":6,"text":"내가 너희 거하는 모든 성읍으로 사막이 되며 산당으로 황무하게하리니 이는 너희 제단이 깨어지고 황폐하며 너희 우상들이 깨어져 없어지며 너희 태양상들이 찍히며 너희 만든 것이 다 폐하며","reference":"에스겔 6:6","category":"$undefined"},{"id":"20571","book":"에스겔","book_name":"에스겔","chapter":6,"verse":7,"text":"또 너희 중에서 살륙을 당하여 엎드러지게 하여 너희로 나를 여호와인 줄 알게 하려 함이니라","reference":"에스겔 6:7","category":"$undefined"},{"id":"20572","book":"에스겔","book_name":"에스겔","chapter":6,"verse":8,"text":"그러나 너희가 열방에 흩어질 때에 내가 너희 중에서 칼을 피하여 이방 중에 남아 있는 자가 있게 할지라","reference":"에스겔 6:8","category":"$undefined"},{"id":"20573","book":"에스겔","book_name":"에스겔","chapter":6,"verse":9,"text":"너희 중 피한 자가 사로잡혀 이방인 중에 있어서 나를 기억하되 그들이 음란한 마음으로 나를 떠나고 음란한 눈으로 우상을 섬겨 나로 근심케 한 것을 기억하고 스스로 한탄하리니 이는 그 모든 가증한 일로 악을 행하였음이라","reference":"에스겔 6:9","category":"$undefined"},{"id":"20574","book":"에스겔","book_name":"에스겔","chapter":6,"verse":10,"text":"그 때에야 그들이 나를 여호와인 줄 알리라 내가 이런 재앙을 그들에게 내리겠다 한 말이 헛되지 아니하니라","reference":"에스겔 6:10","category":"$undefined"},{"id":"20575","book":"에스겔","book_name":"에스겔","chapter":6,"verse":11,"text":"주 여호와께서 가라사대 너는 손뼉을 치고 발을 구르며 말할지어다 오호라 ! 이스라엘 족속이 모든 가증한 악을 행하므로 필경 칼과 기근과 온역에 망하되","reference":"에스겔 6:11","category":"$undefined"},{"id":"20576","book":"에스겔","book_name":"에스겔","chapter":6,"verse":12,"text":"먼데 있는 자는 온역에 죽고 가까운데 있는 자는 칼에 엎드러지고 남아 있어 에워싸인 자는 기근에 죽으리라 이같이 내 진노를 그들에게 이룬즉","reference":"에스겔 6:12","category":"$undefined"},{"id":"20577","book":"에스겔","book_name":"에스겔","chapter":6,"verse":13,"text":"그 살륙 당한 시체가 그 우상 사이에, 제단 사방에, 각 높은 고개에, 모든 산꼭대기에,모든 푸른 나무 아래에,무성한 상수리나무 아래 곧 그 우상에게 분향하던 곳에 있으리니 너희가 나를 여호와인 줄 알리라","reference":"에스겔 6:13","category":"$undefined"},{"id":"20578","book":"에스겔","book_name":"에스겔","chapter":6,"verse":14,"text":"내가 내 손을 그들의 위에 펴서 그 거하는 온 땅 곧 광야에서부터 디블라까지 처량하고 황무하게 하리니 그들이 나를 여호와인 줄 알리라","reference":"에스겔 6:14","category":"$undefined"}],"bookSlug":"ezekiel"}]
