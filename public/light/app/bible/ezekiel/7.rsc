2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":7,"verses":[{"id":"20579","book":"에스겔","book_name":"에스겔","chapter":7,"verse":1,"text":"여호와의 말씀이 또 내게 임하여 가라사대","reference":"에스겔 7:1","category":"$undefined"},{"id":"20580","book":"에스겔","book_name":"에스겔","chapter":7,"verse":2,"text":"너 인자야 ! 주 여호와 내가 이스라엘 땅에 대하여 말하노라 끝났도다 이 땅 사방의 일이 끝났도다","reference":"에스겔 7:2","category":"$undefined"},{"id":"20581","book":"에스겔","book_name":"에스겔","chapter":7,"verse":3,"text":"이제는 네게 끝이 이르렀나니 내가 내 진노를 네게 발하여 네 행위를 국문하고 너의 모든 가증한 일을 보응하리라","reference":"에스겔 7:3","category":"$undefined"},{"id":"20582","book":"에스겔","book_name":"에스겔","chapter":7,"verse":4,"text":"내가 너를 아껴 보지 아니하며 긍휼히 여기지도 아니하고 네 행위대로 너를 벌하여 너의 가증한 일이 너희 중에 나타나게 하리니 너희가 나를 여호와인줄 알리라","reference":"에스겔 7:4","category":"$undefined"},{"id":"20583","book":"에스겔","book_name":"에스겔","chapter":7,"verse":5,"text":"주 여호와께서 가라사대 재앙이로다, 비상한 재앙이로다 볼지어다 ! 임박하도다","reference":"에스겔 7:5","category":"$undefined"},{"id":"20584","book":"에스겔","book_name":"에스겔","chapter":7,"verse":6,"text":"끝이 났도다, 끝이 났도다 끝이 너를 치러 일어났나니 볼지어다 ! 임박하도다","reference":"에스겔 7:6","category":"$undefined"},{"id":"20585","book":"에스겔","book_name":"에스겔","chapter":7,"verse":7,"text":"이 땅 거민아 정한 재앙이 네게 임하도다 때가 이르렀고 날이 가까왔으니 요란한 날이요 산에서 즐거이 부르는 날이 아니로다","reference":"에스겔 7:7","category":"$undefined"},{"id":"20586","book":"에스겔","book_name":"에스겔","chapter":7,"verse":8,"text":"이제 내가 속히 분을 네게 쏟고 내 진노를 네게 이루어서 네 행위대로 너를 심판하여 네 모든 가증한 일을 네게 보응하되","reference":"에스겔 7:8","category":"$undefined"},{"id":"20587","book":"에스겔","book_name":"에스겔","chapter":7,"verse":9,"text":"내가 너를 아껴 보지 아니하며 긍휼히 여기지도 아니하고 네 행위대로 너를 벌하여 너의 가증한 일이 너희 중에 나타나게 하리니 나 여호와가 치는 줄을 네가 알리라","reference":"에스겔 7:9","category":"$undefined"},{"id":"20588","book":"에스겔","book_name":"에스겔","chapter":7,"verse":10,"text":"볼지어다 ! 그 날이로다 볼지어다 ! 임박하도다 정한 재앙이 이르렀으니 몽둥이가 꽃 피며 교만이 싹났도다","reference":"에스겔 7:10","category":"$undefined"},{"id":"20589","book":"에스겔","book_name":"에스겔","chapter":7,"verse":11,"text":"포학이 일어나서 죄악의 몽둥이가 되었은즉 그들도,그 무리도,그 재물도 하나도 남지 아니하고 그 중의 아름다운 것도 없어지리로다","reference":"에스겔 7:11","category":"$undefined"},{"id":"20590","book":"에스겔","book_name":"에스겔","chapter":7,"verse":12,"text":"때가 이르렀고 날이 가까왔으니 사는 자도 기뻐하지 말고 파는 자도 근심하지 말 것은 진노가 그 모든 무리에게 임함이로다","reference":"에스겔 7:12","category":"$undefined"},{"id":"20591","book":"에스겔","book_name":"에스겔","chapter":7,"verse":13,"text":"판 자가 살아 있다 할지라도 다시 돌아가서 그 판 것을 얻지 못하니 이는 묵시로 그 모든 무리를 가리켜 말하기를 하나도 돌아 갈 자가 없겠고 악한 생활로 스스로 강하게 할 자도 없으리라 하였음이로다","reference":"에스겔 7:13","category":"$undefined"},{"id":"20592","book":"에스겔","book_name":"에스겔","chapter":7,"verse":14,"text":"그들이 나팔을 불어 온갖 것을 예비하였을지라도 전쟁에 나갈 사람이 없나니 이는 내 진노가 그 모든 무리에게 미쳤음이라","reference":"에스겔 7:14","category":"$undefined"},{"id":"20593","book":"에스겔","book_name":"에스겔","chapter":7,"verse":15,"text":"밖에는 칼이 있고 안에는 온역과 기근이 있어서 밭에 있는 자는 칼에 죽을 것이요 성읍에 있는 자는 기근과 온역에 망할 것이며","reference":"에스겔 7:15","category":"$undefined"},{"id":"20594","book":"에스겔","book_name":"에스겔","chapter":7,"verse":16,"text":"도망하는 자는 산 위로 피하여 다 각기 자기 죄악 까닭에 골짜기 비둘기처럼 슬피 울 것이며","reference":"에스겔 7:16","category":"$undefined"},{"id":"20595","book":"에스겔","book_name":"에스겔","chapter":7,"verse":17,"text":"모든 손은 피곤하고 모든 무릎은 물과 같이 약할 것이라","reference":"에스겔 7:17","category":"$undefined"},{"id":"20596","book":"에스겔","book_name":"에스겔","chapter":7,"verse":18,"text":"그들이 굵은 베로 허리를 묶을 것이요 두려움이 그들을 덮을 것이요 모든 얼굴에는 수치가 있고 모든 머리는 대머리가 될 것이며","reference":"에스겔 7:18","category":"$undefined"},{"id":"20597","book":"에스겔","book_name":"에스겔","chapter":7,"verse":19,"text":"그들이 그 은을 거리에 던지며 그 금을 오예물 같이 여기리니 이는 여호와 내가 진노를 베푸는 날에 그 은과 금이 능히 그들을 건지지 못하며 능히 그 심령을 족하게 하거나 그 창자를 채우지 못하고 오직 죄악에 빠치는 것이 됨이로다","reference":"에스겔 7:19","category":"$undefined"},{"id":"20598","book":"에스겔","book_name":"에스겔","chapter":7,"verse":20,"text":"그들이 그 화려한 장식으로 인하여 교만을 품었고 또 그것으로 가증한 우상과 미운 물건을 지었은즉 내가 그것으로 그들에게 오예물이 되게 하여","reference":"에스겔 7:20","category":"$undefined"},{"id":"20599","book":"에스겔","book_name":"에스겔","chapter":7,"verse":21,"text":"외인의 손에 붙여 노략하게 하며 세상 악인에게 붙여 그들로 약탈하여 더럽히게 하고","reference":"에스겔 7:21","category":"$undefined"},{"id":"20600","book":"에스겔","book_name":"에스겔","chapter":7,"verse":22,"text":"내가 또 내 얼굴을 그들에게서 돌이키리니 그들이 내 은밀한 처소를 더럽히고 강포한 자도 거기 들어와서 더럽히리라","reference":"에스겔 7:22","category":"$undefined"},{"id":"20601","book":"에스겔","book_name":"에스겔","chapter":7,"verse":23,"text":"너는 쇠사슬을 만들라 이는 피 흘리는 죄가 그 땅에 가득하고 강포가 그 성읍에 찼음이라","reference":"에스겔 7:23","category":"$undefined"},{"id":"20602","book":"에스겔","book_name":"에스겔","chapter":7,"verse":24,"text":"내가 극히 악한 이방인으로 이르러 그 집들을 점령하게 하고 악한 자의 교만을 그치게 하리니 그 성소가 더럽힘을 당하리라","reference":"에스겔 7:24","category":"$undefined"},{"id":"20603","book":"에스겔","book_name":"에스겔","chapter":7,"verse":25,"text":"패망이 이르리니 그들이 평강을 구하여도 없을 것이라","reference":"에스겔 7:25","category":"$undefined"},{"id":"20604","book":"에스겔","book_name":"에스겔","chapter":7,"verse":26,"text":"환난에 환난이 더하고 소문에 소문이 더할 때에 그들이 선지자에게 묵시를 구하나 헛될 것이며 제사장에게는 율법이 없어질 것이요 장로에게는 모략이 없어질 것이며","reference":"에스겔 7:26","category":"$undefined"},{"id":"20605","book":"에스겔","book_name":"에스겔","chapter":7,"verse":27,"text":"왕은 애통하고 방백은 놀람을 옷 입듯하며 거민의 손은 떨리리라 내가 그 행위대로 그들에게 갚고 그 죄악대로 그들을 국문한즉 그들이 나를 여호와인 줄 알리라","reference":"에스겔 7:27","category":"$undefined"}],"bookSlug":"ezekiel"}]
