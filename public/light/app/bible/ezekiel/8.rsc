2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":8,"verses":[{"id":"20606","book":"에스겔","book_name":"에스겔","chapter":8,"verse":1,"text":"제 육년 유월 오일에 나는 집에 앉았고 유다 장로들은 내 앞에 앉았는데 주 여호와의 권능이 거기서 내게 임하기로","reference":"에스겔 8:1","category":"$undefined"},{"id":"20607","book":"에스겔","book_name":"에스겔","chapter":8,"verse":2,"text":"내가 보니 불같은 형상이 있어 그 허리 이하 모양은 불 같고 허리 이상은 광채가 나서 단 쇠 같은데","reference":"에스겔 8:2","category":"$undefined"},{"id":"20608","book":"에스겔","book_name":"에스겔","chapter":8,"verse":3,"text":"그가 손 같은 것을 펴서 내 머리털 한 모숨을 잡으며 주의 신이 나를 들어 천지 사이로 올리시고 하나님의 이상 가운데 나를 이끌어 예루살렘으로 가서 안뜰로 들어가는 북향한 문에 이르시니 거기는 투기의 우상 곧 투기를 격발케 하는 우상의 자리가 있는 곳이라","reference":"에스겔 8:3","category":"$undefined"},{"id":"20609","book":"에스겔","book_name":"에스겔","chapter":8,"verse":4,"text":"이스라엘 하나님의 영광이 거기 있는데 내가 들에서 보던 이상과 같더라","reference":"에스겔 8:4","category":"$undefined"},{"id":"20610","book":"에스겔","book_name":"에스겔","chapter":8,"verse":5,"text":"그가 내게 이르시되 인자야 ! 이제 너는 눈을 들어 북편을 바라보라 하시기로 내가 눈을 들어 북편을 바라보니 제단문 어귀 북편에 그 투기의 우상이 있더라","reference":"에스겔 8:5","category":"$undefined"},{"id":"20611","book":"에스겔","book_name":"에스겔","chapter":8,"verse":6,"text":"그가 또 내게 이르시되 인자야 ! 이스라엘 족속의 행하는 일을 보느냐 그들이 여기서 크게 가증한 일을 행하여 나로 내 성소를 멀리 떠나게 하느니라 너는 다시 다른 큰 가증한 일을 보리라 하시더라","reference":"에스겔 8:6","category":"$undefined"},{"id":"20612","book":"에스겔","book_name":"에스겔","chapter":8,"verse":7,"text":"그가 나를 이끌고 뜰 문에 이르시기로 내가 본즉 담에 구멍이 있더라","reference":"에스겔 8:7","category":"$undefined"},{"id":"20613","book":"에스겔","book_name":"에스겔","chapter":8,"verse":8,"text":"그가 내게 이르시되 인자야 ! 너는 이 담을 헐라 하시기로 내가 그 담을 허니 한 문이 있더라","reference":"에스겔 8:8","category":"$undefined"},{"id":"20614","book":"에스겔","book_name":"에스겔","chapter":8,"verse":9,"text":"또 내게 이르시되 들어가서 그들이 거기서 행하는 가증하고 악한 일을 보라 하시기로","reference":"에스겔 8:9","category":"$undefined"},{"id":"20615","book":"에스겔","book_name":"에스겔","chapter":8,"verse":10,"text":"내가 들어가 보니 각양 곤충과 가증한 짐승과 이스라엘 족속의 모든 우상을 그 사면 벽에 그렸고","reference":"에스겔 8:10","category":"$undefined"},{"id":"20616","book":"에스겔","book_name":"에스겔","chapter":8,"verse":11,"text":"이스라엘 족속의 장로 중 칠십인이 그 앞에 섰으며 사반의 아들 야아사냐도 그 가운데 섰고 각기 손에 향로를 들었는데 향연이 구름같이 오르더라","reference":"에스겔 8:11","category":"$undefined"},{"id":"20617","book":"에스겔","book_name":"에스겔","chapter":8,"verse":12,"text":"또 내게 이르시되 인자야 ! 이스라엘 족속의 장로들이 각각 그 우상의 방안 어두운 가운데서 행하는 것을 네가 보았느냐 그들이 이르기를 여호와께서 우리를 보지 아니하시며 이 땅을 버리셨다 하느니라","reference":"에스겔 8:12","category":"$undefined"},{"id":"20618","book":"에스겔","book_name":"에스겔","chapter":8,"verse":13,"text":"또 내게 이르시되 너는 다시 그들의 행하는바 다른 큰 가증한 일을 보리라 하시더라","reference":"에스겔 8:13","category":"$undefined"},{"id":"20619","book":"에스겔","book_name":"에스겔","chapter":8,"verse":14,"text":"그가 또 나를 데리고 여호와의 전으로 들어가는 북문에 이르시기로 보니 거기 여인들이 앉아 담무스를 위하여 애곡하더라","reference":"에스겔 8:14","category":"$undefined"},{"id":"20620","book":"에스겔","book_name":"에스겔","chapter":8,"verse":15,"text":"그가 또 내게 이르시되 인자야 ! 네가 그것을 보았느냐 너는 또 이보다 더 큰 가증한 일을 보리라 하시더라","reference":"에스겔 8:15","category":"$undefined"},{"id":"20621","book":"에스겔","book_name":"에스겔","chapter":8,"verse":16,"text":"그가 또 나를 데리고 여호와의 전 안뜰에 들어가시기로 보니 여호와의 전문 앞 현관과 제단 사이에서 약 이십 오인이 여호와의 전을 등지고 낯을 동으로 향하여 동방 태양에 경배하더라","reference":"에스겔 8:16","category":"$undefined"},{"id":"20622","book":"에스겔","book_name":"에스겔","chapter":8,"verse":17,"text":"또 내게 이르시되 인자야 ! 네가 보았느냐 유다 족속이 여기서 행한 가증한 일을 적다 하겠느냐 그들이 강포로 이 땅에 채우고 또 다시 내 노를 격동하고 심지어 나무가지를 그 코에 두었느니라","reference":"에스겔 8:17","category":"$undefined"},{"id":"20623","book":"에스겔","book_name":"에스겔","chapter":8,"verse":18,"text":"그러므로 나도 분노로 갚아 아껴 보지 아니하고 긍휼을 베풀지도 아니하리니 그들이 큰 소리로 내 귀에 부르짖을지라도 내가 듣지아니하리라","reference":"에스겔 8:18","category":"$undefined"}],"bookSlug":"ezekiel"}]
