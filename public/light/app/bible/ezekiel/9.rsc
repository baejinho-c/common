2:["$","$L11",null,{"book":{"id":"ezekiel","name":"에스겔","chapters":48,"testament":"old"},"chapter":9,"verses":[{"id":"20624","book":"에스겔","book_name":"에스겔","chapter":9,"verse":1,"text":"그가 또 큰 소리로 내 귀에 외쳐 가라사대 이 성읍을 관할하는 자들로 각기 살륙하는 기계를 손에 들고 나아오게 하라 하시더라","reference":"에스겔 9:1","category":"$undefined"},{"id":"20625","book":"에스겔","book_name":"에스겔","chapter":9,"verse":2,"text":"내가 본즉 여섯 사람이 북향한 윗문 길로 좇아 오는데 각 사람의 손에 살륙하는 기계를 잡았고 그 중에 한 사람은 가는 베옷을 입고 허리에 서기관의 먹 그릇을 찼더라 그들이 들어 와서 놋 제단 곁에 서더라","reference":"에스겔 9:2","category":"$undefined"},{"id":"20626","book":"에스겔","book_name":"에스겔","chapter":9,"verse":3,"text":"그룹에 머물러 있던 이스라엘 하나님의 영광이 올라 성전 문지방에 이르더니 여호와께서 그 가는 베옷을 입고 서기관의 먹 그릇을 찬 사람을 불러","reference":"에스겔 9:3","category":"$undefined"},{"id":"20627","book":"에스겔","book_name":"에스겔","chapter":9,"verse":4,"text":"이르시되 너는 예루살렘 성읍 중에 순행하여 그 가운데서 행하는 모든 가증한 일로 인하여 탄식하며 우는 자의 이마에 표하라 하시고","reference":"에스겔 9:4","category":"$undefined"},{"id":"20628","book":"에스겔","book_name":"에스겔","chapter":9,"verse":5,"text":"나의 듣는데 또 그 남은 자에게 이르시되 너희는 그 뒤를 좇아 성읍 중에 순행하며 아껴보지도 말며 긍휼을 베풀지도 말고 쳐서","reference":"에스겔 9:5","category":"$undefined"},{"id":"20629","book":"에스겔","book_name":"에스겔","chapter":9,"verse":6,"text":"늙은 자와 젊은 자와 처녀와 어린 아이와 부녀를 다 죽이되 이마에 표 있는 자에게는 가까이 말라 내 성소에서 시작할지니라 하시매 그들이 성전 앞에 있는 늙은 자들로부터 시작하더라","reference":"에스겔 9:6","category":"$undefined"},{"id":"20630","book":"에스겔","book_name":"에스겔","chapter":9,"verse":7,"text":"그가 또 그들에게 이르시되 너희는 성전을 더럽혀 시체로 모든 뜰에 채우라 너희는 나가라 하시매 그들이 나가서 성읍 중에서 치더라","reference":"에스겔 9:7","category":"$undefined"},{"id":"20631","book":"에스겔","book_name":"에스겔","chapter":9,"verse":8,"text":"그들이 칠 때에 내가 홀로 있는지라 엎드리어 부르짖어 가로되 오호라 ! 주 여호와여 ! 예루살렘을 향하여 분노를 쏟으시오니 이스라엘 남은 자를 모두 멸하려 하시나이까","reference":"에스겔 9:8","category":"$undefined"},{"id":"20632","book":"에스겔","book_name":"에스겔","chapter":9,"verse":9,"text":"그가 내게 이르시되 이스라엘과 유다 족속의 죄악이 심히 중하여 그 땅에 피가 가득하며 그 성읍에 불법이 찼나니 이는 그들이 이르기를 여호와께서 이 땅을 버리셨으며 보지 아니하신다 함이라","reference":"에스겔 9:9","category":"$undefined"},{"id":"20633","book":"에스겔","book_name":"에스겔","chapter":9,"verse":10,"text":"그러므로 내가 그들을 아껴 보지 아니하며 긍휼을 베풀지 아니하고 그 행위대로 그 머리에 갚으리라 하시더라","reference":"에스겔 9:10","category":"$undefined"},{"id":"20634","book":"에스겔","book_name":"에스겔","chapter":9,"verse":11,"text":"가는 베옷을 입고 허리에 먹 그릇을 찬 사람이 복명하여 가로되 주께서 내게 명하신 대로 내가 준행하였나이다 하더라","reference":"에스겔 9:11","category":"$undefined"}],"bookSlug":"ezekiel"}]
