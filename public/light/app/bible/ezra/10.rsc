2:["$","$L11",null,{"book":{"id":"ezra","name":"에스라","chapters":10,"testament":"old"},"chapter":10,"verses":[{"id":"12254","book":"에스라","book_name":"에스라","chapter":10,"verse":1,"text":"에스라가 하나님의 전 앞에 엎드려 울며 기도하여 죄를 자복할 때에 많은 백성이 심히 통곡하매 이스라엘 중에서 백성의 남녀와 어린 아이의 큰 무리가 그 앞에 모인지라","reference":"에스라 10:1","category":"$undefined"},{"id":"12255","book":"에스라","book_name":"에스라","chapter":10,"verse":2,"text":"엘람 자손 중 여히엘의 아들 스가냐가 에스라에게 이르되 `우리가 우리 하나님께 범죄하여 이 땅 이방 여자를 취하여 아내를 삼았으나 이스라엘에게 오히려 소망이 있나니","reference":"에스라 10:2","category":"$undefined"},{"id":"12256","book":"에스라","book_name":"에스라","chapter":10,"verse":3,"text":"곧 내 주의 교훈을 좇으며 우리 하나님의 명령을 떨며 준행하는 자의 의논을 좇아 이 모든 아내와 그 소생을 다 내어 보내기로 우리 하나님과 언약을 세우고 율법대로 행할 것이라","reference":"에스라 10:3","category":"$undefined"},{"id":"12257","book":"에스라","book_name":"에스라","chapter":10,"verse":4,"text":"이는 당신의 주장할 일이니 일어나소서 우리가 도우리니 힘써 행하소서'","reference":"에스라 10:4","category":"$undefined"},{"id":"12258","book":"에스라","book_name":"에스라","chapter":10,"verse":5,"text":"이에 에스라가 일어나 제사장들과 레위 사람들과 온 이스라엘에게 이 말대로 행하기를 맹세하게 하매 무리가 맹세하는지라","reference":"에스라 10:5","category":"$undefined"},{"id":"12259","book":"에스라","book_name":"에스라","chapter":10,"verse":6,"text":"이에 에스라가 하나님의 전 앞에서 일어나 엘리아십의 아들 여호하난의 방으로 들어가니라 저가 들어가서 사로잡혔던 자의 죄를 근심하여 떡도 먹지 아니하며 물도 마시지 아니하더니","reference":"에스라 10:6","category":"$undefined"},{"id":"12260","book":"에스라","book_name":"에스라","chapter":10,"verse":7,"text":"유다와 예루살렘의 사로잡혔던 자의 자손들에게 공포하기를 `너희는 예루살렘으로 모이라","reference":"에스라 10:7","category":"$undefined"},{"id":"12261","book":"에스라","book_name":"에스라","chapter":10,"verse":8,"text":"누구든지 방백들과 장로들의 훈시를 좇아 삼일 내에 오지 아니하면 그 재산을 적몰하고 사로잡혔던 자의 회에서 쫓아내리라' 하매","reference":"에스라 10:8","category":"$undefined"},{"id":"12262","book":"에스라","book_name":"에스라","chapter":10,"verse":9,"text":"유다와 베냐민 모든 사람이 삼일 내에 예루살렘에 모이니 때는 구월 이십일이라 무리가 하나님의 전 앞 광장에 앉아서 이 일과 비를 인하여 떨더니","reference":"에스라 10:9","category":"$undefined"},{"id":"12263","book":"에스라","book_name":"에스라","chapter":10,"verse":10,"text":"제사장 에스라가 일어서서 저희에게 이르되 `너희가 범죄하여 이방 여자로 아내를 삼아 이스라엘의 죄를 더하게 하였으니","reference":"에스라 10:10","category":"$undefined"},{"id":"12264","book":"에스라","book_name":"에스라","chapter":10,"verse":11,"text":"이제 너희 열조의 하나님 앞에서 죄를 자복하고 그 뜻대로 행하여 이 땅 족속들과 이방 여인을 끊어 버리라'","reference":"에스라 10:11","category":"$undefined"},{"id":"12265","book":"에스라","book_name":"에스라","chapter":10,"verse":12,"text":"회 무리가 큰 소리로 대답하여 가로되 `당신의 말씀대로 우리가 마땅히 행할 것이니이다","reference":"에스라 10:12","category":"$undefined"},{"id":"12266","book":"에스라","book_name":"에스라","chapter":10,"verse":13,"text":"그러나 백성이 많고 또 큰 비가 내리는 때니 능히 밖에 서지 못할 것이요 우리가 이 일로 크게 범죄하였은즉 하루 이틀에 할 일이 아니오니","reference":"에스라 10:13","category":"$undefined"},{"id":"12267","book":"에스라","book_name":"에스라","chapter":10,"verse":14,"text":"이제 온 회중을 위하여 우리 방백들을 세우고 우리 모든 성읍에 이방 여자에게 장가든 자는 다 기한에 본성 장로들과 재판장과 함께 오게하여 우리 하나님의 이 일로 인하신 진노가 우리에게서 떠나게 하소서' 하나","reference":"에스라 10:14","category":"$undefined"},{"id":"12268","book":"에스라","book_name":"에스라","chapter":10,"verse":15,"text":"오직 아사헬의 아들 요나단과 디과의 아들 야스야가 일어나 그 일을 반대하고 므술람과 레위 사람 삽브대가 저희를 돕더라","reference":"에스라 10:15","category":"$undefined"},{"id":"12269","book":"에스라","book_name":"에스라","chapter":10,"verse":16,"text":"사로잡혔던 자의 자손이 그대로 한지라 제사장 에스라가 그 종족을 따라 각기 지명된 족장 몇 사람을 위임하고 시월 초하루에 앉아 그 일을 조사하여","reference":"에스라 10:16","category":"$undefined"},{"id":"12270","book":"에스라","book_name":"에스라","chapter":10,"verse":17,"text":"정월 초하루에 이르러 이방 여인을 취한 자의 일 조사하기를 마치니라","reference":"에스라 10:17","category":"$undefined"},{"id":"12271","book":"에스라","book_name":"에스라","chapter":10,"verse":18,"text":"제사장의 무리 중에 이방 여인을 취한 자는 예수아 자손 중 요사닥의 아들과, 그 형제 마아세야와, 엘리에셀과, 야립과, 그달랴라","reference":"에스라 10:18","category":"$undefined"},{"id":"12272","book":"에스라","book_name":"에스라","chapter":10,"verse":19,"text":"저희가 다 손을 잡아 맹세하여 그 아내를 보내기로 하고 또 그 죄를 인하여 수양 하나를 속건제로 드렸으며","reference":"에스라 10:19","category":"$undefined"},{"id":"12273","book":"에스라","book_name":"에스라","chapter":10,"verse":20,"text":"또 임멜 자손 중에는 하나니와, 스바댜요","reference":"에스라 10:20","category":"$undefined"},{"id":"12274","book":"에스라","book_name":"에스라","chapter":10,"verse":21,"text":"하림 자손 중에는 마아세야와, 엘리야와, 스마야와, 여히엘과, 웃시야요","reference":"에스라 10:21","category":"$undefined"},{"id":"12275","book":"에스라","book_name":"에스라","chapter":10,"verse":22,"text":"바스훌 자손 중에는 엘료에내와, 마아세야와, 이스마엘과, 느다넬과, 요사밧과, 엘라사였더라","reference":"에스라 10:22","category":"$undefined"},{"id":"12276","book":"에스라","book_name":"에스라","chapter":10,"verse":23,"text":"레위 사람 중에는 요사밧과, 시므이와, 글라야라 하는 글리다와, 브다히야와, 유다와, 엘리에셀이었더라","reference":"에스라 10:23","category":"$undefined"},{"id":"12277","book":"에스라","book_name":"에스라","chapter":10,"verse":24,"text":"노래하는 자 중에는 엘리아십이요 문지기 중에는 살룸과, 델렘과, 우리였더라","reference":"에스라 10:24","category":"$undefined"},{"id":"12278","book":"에스라","book_name":"에스라","chapter":10,"verse":25,"text":"이스라엘 중에는 바로스 자손 중 라먀와, 잇시야와, 말기야와, 미야민과, 엘르아살과, 말기야와, 브나야요,","reference":"에스라 10:25","category":"$undefined"},{"id":"12279","book":"에스라","book_name":"에스라","chapter":10,"verse":26,"text":"엘람 자손 중 맛다냐와, 스가랴와, 여히엘과, 압디와, 여레못과, 엘리야요,","reference":"에스라 10:26","category":"$undefined"},{"id":"12280","book":"에스라","book_name":"에스라","chapter":10,"verse":27,"text":"삿두 자손 중 엘료에내와, 엘리아십과, 맛다냐와, 여레못과, 사밧과, 아시사요,","reference":"에스라 10:27","category":"$undefined"},{"id":"12281","book":"에스라","book_name":"에스라","chapter":10,"verse":28,"text":"베배 자손 중 여호하난과, 하나냐와, 삽배와, 아들래요,","reference":"에스라 10:28","category":"$undefined"},{"id":"12282","book":"에스라","book_name":"에스라","chapter":10,"verse":29,"text":"바니 자손 중 므술람과, 말룩과, 아다야와, 야숩과, 스알과, 여레못이요,","reference":"에스라 10:29","category":"$undefined"},{"id":"12283","book":"에스라","book_name":"에스라","chapter":10,"verse":30,"text":"바핫모압 자손 중 앗나와, 글랄과, 브나야와, 마아세야와, 맛다냐와, 브사렐과, 빈누이와, 므낫세요,","reference":"에스라 10:30","category":"$undefined"},{"id":"12284","book":"에스라","book_name":"에스라","chapter":10,"verse":31,"text":"하림 자손 중 엘리에셀과, 잇시야와, 말기야와, 스마야와, 시므온과,","reference":"에스라 10:31","category":"$undefined"},{"id":"12285","book":"에스라","book_name":"에스라","chapter":10,"verse":32,"text":"베냐민과, 말룩과, 스마랴요,","reference":"에스라 10:32","category":"$undefined"},{"id":"12286","book":"에스라","book_name":"에스라","chapter":10,"verse":33,"text":"하숨 자손 중 맛드내와, 맛닷다와, 사밧과, 엘리벨렛과, 여레매와, 므낫세와, 시므이요,","reference":"에스라 10:33","category":"$undefined"},{"id":"12287","book":"에스라","book_name":"에스라","chapter":10,"verse":34,"text":"바니 자손 중 마아대와, 아므람과, 우엘과,","reference":"에스라 10:34","category":"$undefined"},{"id":"12288","book":"에스라","book_name":"에스라","chapter":10,"verse":35,"text":"브나야와, 베드야와, 글루히와,","reference":"에스라 10:35","category":"$undefined"},{"id":"12289","book":"에스라","book_name":"에스라","chapter":10,"verse":36,"text":"와냐와, 므레못과, 에랴십과,","reference":"에스라 10:36","category":"$undefined"},{"id":"12290","book":"에스라","book_name":"에스라","chapter":10,"verse":37,"text":"맛다냐와, 맛드내와, 야아수와,","reference":"에스라 10:37","category":"$undefined"},{"id":"12291","book":"에스라","book_name":"에스라","chapter":10,"verse":38,"text":"바니와, 빈누이와, 시므이와,","reference":"에스라 10:38","category":"$undefined"},{"id":"12292","book":"에스라","book_name":"에스라","chapter":10,"verse":39,"text":"셀레먀와, 나단과, 아다야와,","reference":"에스라 10:39","category":"$undefined"},{"id":"12293","book":"에스라","book_name":"에스라","chapter":10,"verse":40,"text":"막나드배와, 사새와, 사래와,","reference":"에스라 10:40","category":"$undefined"},{"id":"12294","book":"에스라","book_name":"에스라","chapter":10,"verse":41,"text":"아사렐과, 셀레먀와, 스마랴와,","reference":"에스라 10:41","category":"$undefined"},{"id":"12295","book":"에스라","book_name":"에스라","chapter":10,"verse":42,"text":"살룸과, 아마랴와, 요셉이요,","reference":"에스라 10:42","category":"$undefined"},{"id":"12296","book":"에스라","book_name":"에스라","chapter":10,"verse":43,"text":"느보 자손 중 여이엘과, 맛디디야와, 사밧과, 스비내와, 잇도와, 요엘과, 브나야였더라","reference":"에스라 10:43","category":"$undefined"},{"id":"12297","book":"에스라","book_name":"에스라","chapter":10,"verse":44,"text":"이상은 모두 이방 여인을 취한 자라 그 중에 자녀를 낳은 여인도 있었더라","reference":"에스라 10:44","category":"$undefined"}],"bookSlug":"ezra"}]
