2:["$","$L11",null,{"book":{"id":"ezra","name":"에스라","chapters":10,"testament":"old"},"chapter":2,"verses":[{"id":"12029","book":"에스라","book_name":"에스라","chapter":2,"verse":1,"text":"옛적에 바벨론 왕 느부갓네살에게 사로잡혀 바벨론으로 갔던 자의 자손 중에서 놓임을 받고 예루살렘과 유다 도로 돌아와 각기 본성에 이른 자","reference":"에스라 2:1","category":"$undefined"},{"id":"12030","book":"에스라","book_name":"에스라","chapter":2,"verse":2,"text":"곧 스룹바벨과, 예수아와, 느헤미야와, 스라야와, 르엘라야와, 모르드개와, 빌산과, 미스발과, 비그왜와, 르훔과, 바아나 등과 함께 나온 이스라엘 백성의 명수가 이러하니","reference":"에스라 2:2","category":"$undefined"},{"id":"12031","book":"에스라","book_name":"에스라","chapter":2,"verse":3,"text":"바로스 자손이 이천 일백 칠십 이명이요","reference":"에스라 2:3","category":"$undefined"},{"id":"12032","book":"에스라","book_name":"에스라","chapter":2,"verse":4,"text":"스바댜 자손이 삼백 칠십 이명이요","reference":"에스라 2:4","category":"$undefined"},{"id":"12033","book":"에스라","book_name":"에스라","chapter":2,"verse":5,"text":"아라 자손이 칠백 칠십 오명이요","reference":"에스라 2:5","category":"$undefined"},{"id":"12034","book":"에스라","book_name":"에스라","chapter":2,"verse":6,"text":"바핫모압 자손 곧 예수아와 요압 자손이 이천 팔백 십 이명이요","reference":"에스라 2:6","category":"$undefined"},{"id":"12035","book":"에스라","book_name":"에스라","chapter":2,"verse":7,"text":"엘람 자손이 일천 이백 오십 사명이요","reference":"에스라 2:7","category":"$undefined"},{"id":"12036","book":"에스라","book_name":"에스라","chapter":2,"verse":8,"text":"삿두 자손이 구백 사십 오명이요","reference":"에스라 2:8","category":"$undefined"},{"id":"12037","book":"에스라","book_name":"에스라","chapter":2,"verse":9,"text":"삭개 자손이 칠백 육십명이요","reference":"에스라 2:9","category":"$undefined"},{"id":"12038","book":"에스라","book_name":"에스라","chapter":2,"verse":10,"text":"바니 자손이 육백 사십 이명이요","reference":"에스라 2:10","category":"$undefined"},{"id":"12039","book":"에스라","book_name":"에스라","chapter":2,"verse":11,"text":"브배 자손이 육백 이십 삼명이요","reference":"에스라 2:11","category":"$undefined"},{"id":"12040","book":"에스라","book_name":"에스라","chapter":2,"verse":12,"text":"아스갓 자손이 일천 이백 이십 이명이요","reference":"에스라 2:12","category":"$undefined"},{"id":"12041","book":"에스라","book_name":"에스라","chapter":2,"verse":13,"text":"아도니감 자손이 육백 육십 육명이요","reference":"에스라 2:13","category":"$undefined"},{"id":"12042","book":"에스라","book_name":"에스라","chapter":2,"verse":14,"text":"비그왜 자손이 이천 오십 육명이요","reference":"에스라 2:14","category":"$undefined"},{"id":"12043","book":"에스라","book_name":"에스라","chapter":2,"verse":15,"text":"아딘 자손이 사백 오십 사명이요","reference":"에스라 2:15","category":"$undefined"},{"id":"12044","book":"에스라","book_name":"에스라","chapter":2,"verse":16,"text":"아델 자손 곧 히스기야 자손이 구십 팔명이요","reference":"에스라 2:16","category":"$undefined"},{"id":"12045","book":"에스라","book_name":"에스라","chapter":2,"verse":17,"text":"베새 자손이 삼백 이십 삼명이요","reference":"에스라 2:17","category":"$undefined"},{"id":"12046","book":"에스라","book_name":"에스라","chapter":2,"verse":18,"text":"요라 자손이 일백 십 이명이요","reference":"에스라 2:18","category":"$undefined"},{"id":"12047","book":"에스라","book_name":"에스라","chapter":2,"verse":19,"text":"하숨 자손이 이백 이십 삼명이요","reference":"에스라 2:19","category":"$undefined"},{"id":"12048","book":"에스라","book_name":"에스라","chapter":2,"verse":20,"text":"깁발 자손이 구십 오명이요","reference":"에스라 2:20","category":"$undefined"},{"id":"12049","book":"에스라","book_name":"에스라","chapter":2,"verse":21,"text":"베들레헴 사람이 일백 이십 삼명이요","reference":"에스라 2:21","category":"$undefined"},{"id":"12050","book":"에스라","book_name":"에스라","chapter":2,"verse":22,"text":"느도바 사람이 오십 륙명이요","reference":"에스라 2:22","category":"$undefined"},{"id":"12051","book":"에스라","book_name":"에스라","chapter":2,"verse":23,"text":"아나돗 사람이 일백 이십 팔명이요","reference":"에스라 2:23","category":"$undefined"},{"id":"12052","book":"에스라","book_name":"에스라","chapter":2,"verse":24,"text":"아스마웹 자손이 사십 이명이요","reference":"에스라 2:24","category":"$undefined"},{"id":"12053","book":"에스라","book_name":"에스라","chapter":2,"verse":25,"text":"기랴다림과 그비라와 브에롯 자손이 칠백 사십 삼명이요","reference":"에스라 2:25","category":"$undefined"},{"id":"12054","book":"에스라","book_name":"에스라","chapter":2,"verse":26,"text":"라마와 게바 자손이 육백 이십 일명이요","reference":"에스라 2:26","category":"$undefined"},{"id":"12055","book":"에스라","book_name":"에스라","chapter":2,"verse":27,"text":"믹마스 사람이 일백 이십 이명이요","reference":"에스라 2:27","category":"$undefined"},{"id":"12056","book":"에스라","book_name":"에스라","chapter":2,"verse":28,"text":"벧엘과 아이 사람이 이백 이십 삼명이요","reference":"에스라 2:28","category":"$undefined"},{"id":"12057","book":"에스라","book_name":"에스라","chapter":2,"verse":29,"text":"느보 자손이 오십 이명이요","reference":"에스라 2:29","category":"$undefined"},{"id":"12058","book":"에스라","book_name":"에스라","chapter":2,"verse":30,"text":"막비스 자손이 일백 오십 육명이요","reference":"에스라 2:30","category":"$undefined"},{"id":"12059","book":"에스라","book_name":"에스라","chapter":2,"verse":31,"text":"다른 엘람 자손이 일천 이백 오십 사명이요","reference":"에스라 2:31","category":"$undefined"},{"id":"12060","book":"에스라","book_name":"에스라","chapter":2,"verse":32,"text":"하림 자손이 삼백 이십명이요","reference":"에스라 2:32","category":"$undefined"},{"id":"12061","book":"에스라","book_name":"에스라","chapter":2,"verse":33,"text":"로드와 하딧과 오노 자손이 칠백 이십 오명이요","reference":"에스라 2:33","category":"$undefined"},{"id":"12062","book":"에스라","book_name":"에스라","chapter":2,"verse":34,"text":"여리고 자손이 삼백 사십 오명이요","reference":"에스라 2:34","category":"$undefined"},{"id":"12063","book":"에스라","book_name":"에스라","chapter":2,"verse":35,"text":"스나아 자손이 삼천 육백 삼십명이었더라","reference":"에스라 2:35","category":"$undefined"},{"id":"12064","book":"에스라","book_name":"에스라","chapter":2,"verse":36,"text":"제사장들은 예수아의 집 여다야 자손이 구백 칠십 삼명이요","reference":"에스라 2:36","category":"$undefined"},{"id":"12065","book":"에스라","book_name":"에스라","chapter":2,"verse":37,"text":"임멜 자손이 일천 오십 이명이요","reference":"에스라 2:37","category":"$undefined"},{"id":"12066","book":"에스라","book_name":"에스라","chapter":2,"verse":38,"text":"바스훌 자손이 일천 이백 사십 칠명이요","reference":"에스라 2:38","category":"$undefined"},{"id":"12067","book":"에스라","book_name":"에스라","chapter":2,"verse":39,"text":"하림 자손이 일천 십 칠명이었더라","reference":"에스라 2:39","category":"$undefined"},{"id":"12068","book":"에스라","book_name":"에스라","chapter":2,"verse":40,"text":"레위 사람은 호다위야 자손 곧 예수아와, 갓미엘 자손이 칠십 사명이요","reference":"에스라 2:40","category":"$undefined"},{"id":"12069","book":"에스라","book_name":"에스라","chapter":2,"verse":41,"text":"노래하는 자들은 아삽 자손이 일백 이십 팔명이요","reference":"에스라 2:41","category":"$undefined"},{"id":"12070","book":"에스라","book_name":"에스라","chapter":2,"verse":42,"text":"문지기의 자손들은 살룸과, 아델과, 달문과, 악굽과, 하디다와, 소배 자손이 모두 일백 삼십 구명이였더라","reference":"에스라 2:42","category":"$undefined"},{"id":"12071","book":"에스라","book_name":"에스라","chapter":2,"verse":43,"text":"느디님 사람들은 시하 자손과, 하수바 자손과, 답바옷 자손과,","reference":"에스라 2:43","category":"$undefined"},{"id":"12072","book":"에스라","book_name":"에스라","chapter":2,"verse":44,"text":"게로스 자손과, 시아하 자손과, 바돈 자손과,","reference":"에스라 2:44","category":"$undefined"},{"id":"12073","book":"에스라","book_name":"에스라","chapter":2,"verse":45,"text":"르바나 자손과, 하가바 자손과, 악굽 자손과,","reference":"에스라 2:45","category":"$undefined"},{"id":"12074","book":"에스라","book_name":"에스라","chapter":2,"verse":46,"text":"하갑 자손과, 사믈래 자손과, 하난 자손과,","reference":"에스라 2:46","category":"$undefined"},{"id":"12075","book":"에스라","book_name":"에스라","chapter":2,"verse":47,"text":"깃델 자손과, 가할 자손과, 르아야 자손과,","reference":"에스라 2:47","category":"$undefined"},{"id":"12076","book":"에스라","book_name":"에스라","chapter":2,"verse":48,"text":"르신 자손과, 느고다 자손과, 갓삼 자손과,","reference":"에스라 2:48","category":"$undefined"},{"id":"12077","book":"에스라","book_name":"에스라","chapter":2,"verse":49,"text":"웃사 자손과, 바세아 자손과, 베새 자손과,","reference":"에스라 2:49","category":"$undefined"},{"id":"12078","book":"에스라","book_name":"에스라","chapter":2,"verse":50,"text":"아스나 자손과, 므우님 자손과, 느부심 자손과,","reference":"에스라 2:50","category":"$undefined"},{"id":"12079","book":"에스라","book_name":"에스라","chapter":2,"verse":51,"text":"박북 자손과, 하그바 자손과, 할훌 자손과,","reference":"에스라 2:51","category":"$undefined"},{"id":"12080","book":"에스라","book_name":"에스라","chapter":2,"verse":52,"text":"바슬룻 자손과, 므히다 자손과, 하르사 자손과,","reference":"에스라 2:52","category":"$undefined"},{"id":"12081","book":"에스라","book_name":"에스라","chapter":2,"verse":53,"text":"바르고스 자손과, 시스라 자손과, 데마 자손과,","reference":"에스라 2:53","category":"$undefined"},{"id":"12082","book":"에스라","book_name":"에스라","chapter":2,"verse":54,"text":"느시야 자손과, 하디바 자손이었더라","reference":"에스라 2:54","category":"$undefined"},{"id":"12083","book":"에스라","book_name":"에스라","chapter":2,"verse":55,"text":"솔로몬의 신복의 자손은 소대 자손과, 하소베렛 자손과, 브루다 자손과,","reference":"에스라 2:55","category":"$undefined"},{"id":"12084","book":"에스라","book_name":"에스라","chapter":2,"verse":56,"text":"야알라 자손과, 다르곤 자손과, 깃델 자손과,","reference":"에스라 2:56","category":"$undefined"},{"id":"12085","book":"에스라","book_name":"에스라","chapter":2,"verse":57,"text":"스바댜 자손과, 하딜 자손과, 보게렛하스바임 자손과, 아미 자손이니","reference":"에스라 2:57","category":"$undefined"},{"id":"12086","book":"에스라","book_name":"에스라","chapter":2,"verse":58,"text":"모든 느디님 사람과 솔로몬의 신복의 자손이 삼백 구십 이명이었더라","reference":"에스라 2:58","category":"$undefined"},{"id":"12087","book":"에스라","book_name":"에스라","chapter":2,"verse":59,"text":"델멜라와, 델하르사와, 그룹과, 앗단과,임멜에서 올라온 자가 있으나 그 종족과 보계가 이스라엘에 속하였는지는 증거할 수 없으니","reference":"에스라 2:59","category":"$undefined"},{"id":"12088","book":"에스라","book_name":"에스라","chapter":2,"verse":60,"text":"저희는 들라야 자손과, 도비야 자손과, 느고다 자손이라 도합이 육백 오십 이명이요","reference":"에스라 2:60","category":"$undefined"},{"id":"12089","book":"에스라","book_name":"에스라","chapter":2,"verse":61,"text":"제사장 중에는 하바야 자손과, 학고스 자손과, 바르실래 자손이니 바르실래는 길르앗 사람 바르실래의 딸 중에 하나로 아내를 삼고 바르실래의 이름으로 이름한 자라","reference":"에스라 2:61","category":"$undefined"},{"id":"12090","book":"에스라","book_name":"에스라","chapter":2,"verse":62,"text":"이 사람들이 보계 중에서 자기 이름을 찾아도 얻지 못한 고로 저희를 부정하게 여겨 제사장의 직분을 행치 못하게 하고","reference":"에스라 2:62","category":"$undefined"},{"id":"12091","book":"에스라","book_name":"에스라","chapter":2,"verse":63,"text":"방백이 저희에게 명하여 '우림과 둠밈을 가진 제사장이 일어나기 전에는 지성물을 먹지 말라' 하였느니라","reference":"에스라 2:63","category":"$undefined"},{"id":"12092","book":"에스라","book_name":"에스라","chapter":2,"verse":64,"text":"온 회중의 합계가 사만 이천 삼백 육십명이요","reference":"에스라 2:64","category":"$undefined"},{"id":"12093","book":"에스라","book_name":"에스라","chapter":2,"verse":65,"text":"그 외에 노비가 칠천 삼백 삼십 칠명이요, 노래하는 남녀가 이백명이요","reference":"에스라 2:65","category":"$undefined"},{"id":"12094","book":"에스라","book_name":"에스라","chapter":2,"verse":66,"text":"말이 칠백 삼십 륙이요, 노새가 이백 사십 오요","reference":"에스라 2:66","category":"$undefined"},{"id":"12095","book":"에스라","book_name":"에스라","chapter":2,"verse":67,"text":"약대가 사백 삼십 오요, 나귀가 육천 칠백 이십이었더라","reference":"에스라 2:67","category":"$undefined"},{"id":"12096","book":"에스라","book_name":"에스라","chapter":2,"verse":68,"text":"어떤 족장들이 예루살렘 여호와의 전 터에 이르러 하나님의 전을 그곳에 다시 건축하려고 예물을 즐거이 드리되","reference":"에스라 2:68","category":"$undefined"},{"id":"12097","book":"에스라","book_name":"에스라","chapter":2,"verse":69,"text":"역량대로 역사하는 곳간에 드리니 금이 육만 일천 다릭이요, 은이 오천 마네요, 제사장의 옷이 일백 벌이었더라","reference":"에스라 2:69","category":"$undefined"},{"id":"12098","book":"에스라","book_name":"에스라","chapter":2,"verse":70,"text":"이에 제사장들과 레위 사람들과 백성 몇과 노래하는 자들과 문지기들과 느디님 사람들이 그 본성들에 거하고 이스라엘 무리도 그 본성들에 거하였느니라","reference":"에스라 2:70","category":"$undefined"}],"bookSlug":"ezra"}]
