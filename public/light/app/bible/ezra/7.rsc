2:["$","$L11",null,{"book":{"id":"ezra","name":"에스라","chapters":10,"testament":"old"},"chapter":7,"verses":[{"id":"12175","book":"에스라","book_name":"에스라","chapter":7,"verse":1,"text":"이 일 후 바사 왕 아닥사스다가 위에 있을 때에 에스라라 하는 자가 있으니라 저는 스라야의 아들이요, 아사랴의 손자요, 힐기야의 증손이요","reference":"에스라 7:1","category":"$undefined"},{"id":"12176","book":"에스라","book_name":"에스라","chapter":7,"verse":2,"text":"살룸의 현손이요, 사독의 오대손이요, 아히둡의 육대손이요,","reference":"에스라 7:2","category":"$undefined"},{"id":"12177","book":"에스라","book_name":"에스라","chapter":7,"verse":3,"text":"아마랴의 칠대손이요, 아사랴의 팔대손이요, 므라욧의 구대손이요,","reference":"에스라 7:3","category":"$undefined"},{"id":"12178","book":"에스라","book_name":"에스라","chapter":7,"verse":4,"text":"스라히야의 십대손이요, 웃시엘의 십 일대손이요, 북기의 십 이대손이요,","reference":"에스라 7:4","category":"$undefined"},{"id":"12179","book":"에스라","book_name":"에스라","chapter":7,"verse":5,"text":"아비수아의 십 삼대손이요, 비느하스의 십 사대손이요, 엘르아살의 십 오대손이요, 대제사장 아론의 십 륙대손이라","reference":"에스라 7:5","category":"$undefined"},{"id":"12180","book":"에스라","book_name":"에스라","chapter":7,"verse":6,"text":"이 에스라가 바벨론에서 올라왔으니 저는 이스라엘 하나님 여호와께서 주신 바 모세의 율법에 익숙한 학사로서 그 하나님 여호와의 도우심을 입으므로 왕에게 구하는 것은 다 받는 자더니","reference":"에스라 7:6","category":"$undefined"},{"id":"12181","book":"에스라","book_name":"에스라","chapter":7,"verse":7,"text":"아닥사스다 왕 칠년에 이스라엘 자손과 제사장들과 레위 사람들과 노래하는 자들과 문지기들과 느디님 사람들 중에 몇사람이 예루살렘으로 올라올 때에","reference":"에스라 7:7","category":"$undefined"},{"id":"12182","book":"에스라","book_name":"에스라","chapter":7,"verse":8,"text":"이 에스라가 올라왔으니 왕의 칠년 오월이라","reference":"에스라 7:8","category":"$undefined"},{"id":"12183","book":"에스라","book_name":"에스라","chapter":7,"verse":9,"text":"정월 초하루에 바벨론에서 길을 떠났고 하나님의 선한 손의 도우심을 입어 오월 초하루에 예루살렘에 이르니라","reference":"에스라 7:9","category":"$undefined"},{"id":"12184","book":"에스라","book_name":"에스라","chapter":7,"verse":10,"text":"에스라가 여호와의 율법을 연구하여 준행하며 율례와 규례를 이스라엘에게 가르치기로 결심하였었더라","reference":"에스라 7:10","category":"$undefined"},{"id":"12185","book":"에스라","book_name":"에스라","chapter":7,"verse":11,"text":"여호와의 계명의 말씀과 이스라엘에게 주신 율례의 학사인 학사겸 제사장 에스라에게 아닥사스다 왕이 내린 조서 초본은 아래와 같으니라","reference":"에스라 7:11","category":"$undefined"},{"id":"12186","book":"에스라","book_name":"에스라","chapter":7,"verse":12,"text":"모든 왕의 왕 아닥사스다는 하늘의 하나님의 율법에 완전한 학사겸 제사장 에스라에게","reference":"에스라 7:12","category":"$undefined"},{"id":"12187","book":"에스라","book_name":"에스라","chapter":7,"verse":13,"text":"조서하노니 우리 나라에 있는 이스라엘 백성과 저희 제사장들과 레위 사람들 중에 예루살렘으로 올라갈 뜻이 있는 자는 누구든지 너와 함께 갈지어다","reference":"에스라 7:13","category":"$undefined"},{"id":"12188","book":"에스라","book_name":"에스라","chapter":7,"verse":14,"text":"너는 네 손에 있는 네 하나님의 율법을 좇아 유다와 예루살렘의 정형을 살피기 위하여 왕과 일곱 모사의 보냄을 받았으니","reference":"에스라 7:14","category":"$undefined"},{"id":"12189","book":"에스라","book_name":"에스라","chapter":7,"verse":15,"text":"왕과 모사들이 예루살렘에 거하신 이스라엘 하나님께 성심으로 드리는 은금을 가져가고","reference":"에스라 7:15","category":"$undefined"},{"id":"12190","book":"에스라","book_name":"에스라","chapter":7,"verse":16,"text":"또 네가 바벨론 온 도에서 얻을 모든 은금과 및 백성과 제사장들이 예루살렘 그 하나님의 전을 위하여 즐거이 드릴 예물을 가져다가","reference":"에스라 7:16","category":"$undefined"},{"id":"12191","book":"에스라","book_name":"에스라","chapter":7,"verse":17,"text":"그 돈으로 수송아지와 수양과 어린 양과 그 소제와 그 전제의 물품을 신속히 사서 예루살렘 네 하나님의 전 단 위에 드리고","reference":"에스라 7:17","category":"$undefined"},{"id":"12192","book":"에스라","book_name":"에스라","chapter":7,"verse":18,"text":"그 나머지 은금은 너와 너의 형제가 선히 여기는 일에 너희 하나님의 뜻을 좇아 쓸지며","reference":"에스라 7:18","category":"$undefined"},{"id":"12193","book":"에스라","book_name":"에스라","chapter":7,"verse":19,"text":"네 하나님의 전에서 섬기는 일을 위하여 네게 준 기명은 예루살렘 하나님 앞에 드리고","reference":"에스라 7:19","category":"$undefined"},{"id":"12194","book":"에스라","book_name":"에스라","chapter":7,"verse":20,"text":"그 외에도 네 하나님의 전에 쓰일 것이 있어서 네가 드리고자 하거든 무엇이든지 왕의 내탕고에서 취하여 드릴지니라","reference":"에스라 7:20","category":"$undefined"},{"id":"12195","book":"에스라","book_name":"에스라","chapter":7,"verse":21,"text":"나 곧 나 아닥사스다 왕이 강 서편 모든 고지기에게 조서를 내려 이르기를 하늘의 하나님의 율법의 학사겸 제사장 에스라가 무릇 너희에게 구하는 것은 신속히 시행하되","reference":"에스라 7:21","category":"$undefined"},{"id":"12196","book":"에스라","book_name":"에스라","chapter":7,"verse":22,"text":"은은 일백 달란트까지 밀은 일백 고르까지, 포도주는 일백 밧까지, 기름도 일백 밧까지 하고 소금은 정수 없이 하라","reference":"에스라 7:22","category":"$undefined"},{"id":"12197","book":"에스라","book_name":"에스라","chapter":7,"verse":23,"text":"무릇 하늘의 하나님의 전을 위하여 하늘의 하나님의 명하신 것은 삼가 행하라 ! 어찌하여 진노가 왕과 왕자의 나라에 임하게 하랴","reference":"에스라 7:23","category":"$undefined"},{"id":"12198","book":"에스라","book_name":"에스라","chapter":7,"verse":24,"text":"내가 너희에게 이르노니 제사장들이나 레위 사람들이나 노래하는 자들이나 문지기들이나 느디님 사람들이나 혹 하나님의 전에서 일하는 자들에게 조공과 잡세와 부세를 받는 것이 불가하니라 하였노라","reference":"에스라 7:24","category":"$undefined"},{"id":"12199","book":"에스라","book_name":"에스라","chapter":7,"verse":25,"text":"에스라여 ! 너는 네 손에 있는 네 하나님의 지혜를 따라 네 하나님의 율법을 아는 자로 유사와 재판관을 삼아 강 서편 모든 백성을 재판하게 하고 그 알지 못하는 자는 너희가 가르치라","reference":"에스라 7:25","category":"$undefined"},{"id":"12200","book":"에스라","book_name":"에스라","chapter":7,"verse":26,"text":"무릇 네 하나님의 명령과 왕의 명령을 준행치 아니하는 자는 속히 그 죄를 정하여 혹 죽이거나 정배하거나 가산을 적몰하거나 옥에 가둘지니라 하였더라","reference":"에스라 7:26","category":"$undefined"},{"id":"12201","book":"에스라","book_name":"에스라","chapter":7,"verse":27,"text":"우리 열조의 하나님 여호와를 송축할지로다 ! 그가 왕의 마음에 예루살렘 여호와의 전을 아름답게 할 뜻을 두시고","reference":"에스라 7:27","category":"$undefined"},{"id":"12202","book":"에스라","book_name":"에스라","chapter":7,"verse":28,"text":"또 나로 왕과 그 모사들의 앞과 왕의 권세 있는 모든 방백의 앞에서 은혜를 얻게 하셨도다 나의 하나님 여호와의 손이 나의 위에 있으므로 내가 힘을 얻어 이스라엘 중에 두목을 모아 나와 함께 올라오게 하였노라","reference":"에스라 7:28","category":"$undefined"}],"bookSlug":"ezra"}]
