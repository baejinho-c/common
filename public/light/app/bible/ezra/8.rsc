2:["$","$L11",null,{"book":{"id":"ezra","name":"에스라","chapters":10,"testament":"old"},"chapter":8,"verses":[{"id":"12203","book":"에스라","book_name":"에스라","chapter":8,"verse":1,"text":"아닥사스다 왕이 위에 있을 때에 나와 함께 바벨론에서 올라온 족장들과 그들의 보계가 이러하니라","reference":"에스라 8:1","category":"$undefined"},{"id":"12204","book":"에스라","book_name":"에스라","chapter":8,"verse":2,"text":"비느하스 자손 중에서는 게르솜이요, 이다말 자손 중에서는 다니엘이요, 다윗 자손 중에서는 핫두스요","reference":"에스라 8:2","category":"$undefined"},{"id":"12205","book":"에스라","book_name":"에스라","chapter":8,"verse":3,"text":"스가냐 자손 곧 바로스 자손 중에서는 스가랴니 그와 함께 족보에 기록된 남자가 일백 오십명이요","reference":"에스라 8:3","category":"$undefined"},{"id":"12206","book":"에스라","book_name":"에스라","chapter":8,"verse":4,"text":"바핫모압 자손 중에서는 스라히야의 아들 엘여호에내니 그와 함께한 남자가 이백명이요","reference":"에스라 8:4","category":"$undefined"},{"id":"12207","book":"에스라","book_name":"에스라","chapter":8,"verse":5,"text":"스가냐 자손 중에서는 야하시엘의 아들이니 그와 함께한 남자가 삼백명이요","reference":"에스라 8:5","category":"$undefined"},{"id":"12208","book":"에스라","book_name":"에스라","chapter":8,"verse":6,"text":"아딘 자손 중에서는 요나단의 아들 에벳이니 그와 함께한 남자가 오십명이요","reference":"에스라 8:6","category":"$undefined"},{"id":"12209","book":"에스라","book_name":"에스라","chapter":8,"verse":7,"text":"엘람 자손 중에서는 아달리야의 아들 여사야니 그와 함께한 남자가 칠십명이요","reference":"에스라 8:7","category":"$undefined"},{"id":"12210","book":"에스라","book_name":"에스라","chapter":8,"verse":8,"text":"스바댜 자손 중에서는 미가엘의 아들 스바댜니 그와 함께한 남자가 팔십명이요","reference":"에스라 8:8","category":"$undefined"},{"id":"12211","book":"에스라","book_name":"에스라","chapter":8,"verse":9,"text":"요압 자손 중에서는 여히엘의 아들 오바댜니 그와 함께한 남자가 이백 십 팔명이요","reference":"에스라 8:9","category":"$undefined"},{"id":"12212","book":"에스라","book_name":"에스라","chapter":8,"verse":10,"text":"슬로밋 자손 중에서는 요시뱌의 아들이니 그와 함께한 남자가 일백 육십명이요","reference":"에스라 8:10","category":"$undefined"},{"id":"12213","book":"에스라","book_name":"에스라","chapter":8,"verse":11,"text":"베배 자손 중에서는 베배의 아들 스가랴니 그와 함께한 남자가 이십 팔명이요","reference":"에스라 8:11","category":"$undefined"},{"id":"12214","book":"에스라","book_name":"에스라","chapter":8,"verse":12,"text":"아스갓 자손 중에서는 학가단의 아들 요하난이니 그와 함께한 남자가 일백 십명이요","reference":"에스라 8:12","category":"$undefined"},{"id":"12215","book":"에스라","book_name":"에스라","chapter":8,"verse":13,"text":"아도니감 자손 중에 나중된 자의 이름은 엘리벨렛과, 여우엘과, 스마야니 그와 함께한 남자가 육십명이요","reference":"에스라 8:13","category":"$undefined"},{"id":"12216","book":"에스라","book_name":"에스라","chapter":8,"verse":14,"text":"비그왜 자손 중에서는 우대와 사붓이니 그와 함께한 남자가 칠십명이었느니라","reference":"에스라 8:14","category":"$undefined"},{"id":"12217","book":"에스라","book_name":"에스라","chapter":8,"verse":15,"text":"내가 무리를 아하와로 흐르는 강가에 모으고 거기서 삼일 동안 장막에 유하며 백성과 제사장들을 살핀즉 그 중에 레위 자손이 하나도 없는지라","reference":"에스라 8:15","category":"$undefined"},{"id":"12218","book":"에스라","book_name":"에스라","chapter":8,"verse":16,"text":"이에 모든 족장 곧 엘리에셀과, 아리엘과, 스마야와, 엘라단과, 야립과, 엘라단과, 나단과, 스가랴와, 므술람을 부르고 또 명철한 사람 요야립과 엘라단을 불러","reference":"에스라 8:16","category":"$undefined"},{"id":"12219","book":"에스라","book_name":"에스라","chapter":8,"verse":17,"text":"가시뱌 지방으로 보내어 그곳 족장 잇도에게 나아가게 하고 잇도와 그 형제 곧 가시뱌 지방에 거한 느디님 사람들에게 할 말을 일러주고 우리 하나님의 전을 위하여 수종들 자를 데리고 오라 하였더니","reference":"에스라 8:17","category":"$undefined"},{"id":"12220","book":"에스라","book_name":"에스라","chapter":8,"verse":18,"text":"우리 하나님의 선한 손의 도우심을 입고 저희가 이스라엘의 손자 레위의 아들 말리의 자손 중에서 한 명철한 사람을 데려오고 또 세레뱌와 그 아들들과 형제 십 팔명과","reference":"에스라 8:18","category":"$undefined"},{"id":"12221","book":"에스라","book_name":"에스라","chapter":8,"verse":19,"text":"하사뱌와 므라리 자손 중 여사야와 그 형제와 저의 아들들 이십명을 데려오고","reference":"에스라 8:19","category":"$undefined"},{"id":"12222","book":"에스라","book_name":"에스라","chapter":8,"verse":20,"text":"또 느디님 사람 곧 다윗과 방백들이 주어 레위 사람에게 수종들게 한 그 느디님 사람 중 이백 이십명을 데려왔으니 그 이름이 다 기록되었느니라","reference":"에스라 8:20","category":"$undefined"},{"id":"12223","book":"에스라","book_name":"에스라","chapter":8,"verse":21,"text":"때에 내가 아하와강 가에서 금식을 선포하고 우리 하나님 앞에서 스스로 겸비하여 우리와 우리 어린 것과 모든 소유를 위하여 평탄한 길을 그에게 간구하였으니","reference":"에스라 8:21","category":"$undefined"},{"id":"12224","book":"에스라","book_name":"에스라","chapter":8,"verse":22,"text":"이는 우리가 전에 왕에게 고하기를 우리 하나님의 손은 자기를 찾는 모든 자에게 선을 베푸시고 자기를 배반하는 모든 자에게는 권능과 진노를 베푸신다 하였으므로 길에서 적군을 막고 우리를 도울 보병과 마병을 왕에게 구하기를 부끄러워 하였음이라","reference":"에스라 8:22","category":"$undefined"},{"id":"12225","book":"에스라","book_name":"에스라","chapter":8,"verse":23,"text":"그러므로 우리가 이를 위하여 금식하며 우리 하나님께 간구하였더니 그 응낙하심을 입었느니라","reference":"에스라 8:23","category":"$undefined"},{"id":"12226","book":"에스라","book_name":"에스라","chapter":8,"verse":24,"text":"그 때에 내가 제사장의 두목 중 십 이인 곧 세레뱌와 하사뱌와 그 형제 십인을 따로 세우고","reference":"에스라 8:24","category":"$undefined"},{"id":"12227","book":"에스라","book_name":"에스라","chapter":8,"verse":25,"text":"저희에게 왕과 모사들과 방백들과 또 그곳에 있는 이스라엘 무리가 우리 하나님의 전을 위하여 드린 은과 금과 기명들을 달아서 주었으니","reference":"에스라 8:25","category":"$undefined"},{"id":"12228","book":"에스라","book_name":"에스라","chapter":8,"verse":26,"text":"내가 달아서 저희 손에 준 것은 은이 육백 오십 달란트요, 은 기명이 일백 달란트요, 금이 일백 달란트며","reference":"에스라 8:26","category":"$undefined"},{"id":"12229","book":"에스라","book_name":"에스라","chapter":8,"verse":27,"text":"또 금잔이 이십개라 중수는 일천 다릭이요 또 아름답고 빛나 금같이 보배로운 놋그릇이 두 개라","reference":"에스라 8:27","category":"$undefined"},{"id":"12230","book":"에스라","book_name":"에스라","chapter":8,"verse":28,"text":"내가 저희에게 이르되 `너희는 여호와께 거룩한 자요 이 기명들도 거룩하고 그 은과 금은 너희 열조의 하나님 여호와께 즐거이 드린 예물이니","reference":"에스라 8:28","category":"$undefined"},{"id":"12231","book":"에스라","book_name":"에스라","chapter":8,"verse":29,"text":"너희는 예루살렘 여호와의 전 골방에 이르러 제사장의 두목들과 레위 사람의 두목들과 이스라엘 족장 앞에서 이 기명을 달기까지 삼가 지키라 !'","reference":"에스라 8:29","category":"$undefined"},{"id":"12232","book":"에스라","book_name":"에스라","chapter":8,"verse":30,"text":"이에 제사장들과 레위 사람들이 은과 금과 기명을 예루살렘 우리 하나님의 전으로 가져가려 하여 그 중수대로 받으니라","reference":"에스라 8:30","category":"$undefined"},{"id":"12233","book":"에스라","book_name":"에스라","chapter":8,"verse":31,"text":"정월 십 이일에 우리가 아하와 강을 떠나 예루살렘으로 갈새 우리 하나님의 손이 우리를 도우사 대적과 길에 매복한 자의 손에서 건지신지라","reference":"에스라 8:31","category":"$undefined"},{"id":"12234","book":"에스라","book_name":"에스라","chapter":8,"verse":32,"text":"이에 예루살렘에 이르러 거기서 삼일을 유하고","reference":"에스라 8:32","category":"$undefined"},{"id":"12235","book":"에스라","book_name":"에스라","chapter":8,"verse":33,"text":"제 사일에 우리 하나님의 전에서 은과 금과 기명을 달아서 제사장 우리아의 아들 므레못의 손에 붙이니 비느하스의 아들 엘르아살과, 레위 사람 예수아의 아들 요사밧과, 빈누이의 아들 노아댜가 함께 있어","reference":"에스라 8:33","category":"$undefined"},{"id":"12236","book":"에스라","book_name":"에스라","chapter":8,"verse":34,"text":"모든 것을 다 계수하고 달아보고 그 중수를 당장에 책에 기록하였느니라","reference":"에스라 8:34","category":"$undefined"},{"id":"12237","book":"에스라","book_name":"에스라","chapter":8,"verse":35,"text":"사로잡혔던 자의 자손 곧 이방에서 돌아온 자들이 이스라엘 하나님께 번제를 드렸는데 이스라엘 전체를 위한 수송아지가 열 둘이요, 또 수양이 아흔 여섯이요, 어린 양이 일흔 일곱이요, 또 속죄제의 수염소가 열 둘이니 모두 여호와께 드린 번제물이라","reference":"에스라 8:35","category":"$undefined"},{"id":"12238","book":"에스라","book_name":"에스라","chapter":8,"verse":36,"text":"무리가 또 왕의 조서를 왕의 관원과 강 서편 총독들에게 부치매 저희가 백성과 하나님의 전을 도왔느니라","reference":"에스라 8:36","category":"$undefined"}],"bookSlug":"ezra"}]
