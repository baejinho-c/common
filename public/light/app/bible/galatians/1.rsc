2:["$","$L11",null,{"book":{"id":"galatians","name":"갈라디아서","chapters":6,"testament":"new"},"chapter":1,"verses":[{"id":"29059","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":1,"text":"사람들에게서 난 것도 아니요 사람으로 말미암은 것도 아니요 오직 예수 그리스도와 및 죽은 자 가운데서 그리스도를 살리신 하나님 아버지로 말미암아 사도 된 바울은","reference":"갈라디아서 1:1","category":"$undefined"},{"id":"29060","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":2,"text":"함께 있는 모든 형제로 더불어 갈라디아 여러 교회들에게","reference":"갈라디아서 1:2","category":"$undefined"},{"id":"29061","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":3,"text":"우리 하나님 아버지와 주 예수 그리스도로 좇아 은혜와 평강이 있기를 원하노라","reference":"갈라디아서 1:3","category":"$undefined"},{"id":"29062","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":4,"text":"그리스도께서 하나님 곧 우리 아버지의 뜻을 따라 이 악한 세대에서 우리를 건지시려고 우리 죄를 위하여 자기 몸을 드리셨으니","reference":"갈라디아서 1:4","category":"$undefined"},{"id":"29063","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":5,"text":"영광이 저에게 세세토록 있을지어다 ! 아멘","reference":"갈라디아서 1:5","category":"$undefined"},{"id":"29064","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":6,"text":"그리스도의 은혜로 너희를 부르신 이를 이같이 속히 떠나 다른 복음 좇는 것을 내가 이상히 여기노라","reference":"갈라디아서 1:6","category":"$undefined"},{"id":"29065","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":7,"text":"다른 복음은 없나니 다만 어떤 사람들이 너희를 요란케 하여 그리스도의 복음을 변하려 함이라","reference":"갈라디아서 1:7","category":"$undefined"},{"id":"29066","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":8,"text":"그러나 우리나 혹 하늘로부터 온 천사라도 우리가 너희에게 전한 복음 외에 다른 복음을 전하면 저주를 받을지어다 !","reference":"갈라디아서 1:8","category":"$undefined"},{"id":"29067","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":9,"text":"우리가 전에 말하였거니와 내가 지금 다시 말하노니 만일 누구든지 너희의 받은 것 외에 다른 복음을 전하면 저주를 받을지어다 !","reference":"갈라디아서 1:9","category":"$undefined"},{"id":"29068","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":10,"text":"이제 내가 사람들에게 좋게 하랴 하나님께 좋게 하랴 사람들에게 기쁨을 구하랴 내가 지금까지 사람의 기쁨을 구하는 것이었더면 그리스도의 종이 아니니라","reference":"갈라디아서 1:10","category":"$undefined"},{"id":"29069","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":11,"text":"형제들아 내가 너희에게 알게 하노니 내가 전한 복음이 사람의 뜻을 따라 된 것이 아니라","reference":"갈라디아서 1:11","category":"$undefined"},{"id":"29070","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":12,"text":"이는 내가 사람에게서 받은 것도 아니요 배운 것도 아니요 오직 예수 그리스도의 계시로 말미암은 것이라","reference":"갈라디아서 1:12","category":"$undefined"},{"id":"29071","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":13,"text":"내가 이전에 유대교에 있을 때에 행한 일을 너희가 들었거니와 하나님의 교회를 심히 핍박하여 잔해하고","reference":"갈라디아서 1:13","category":"$undefined"},{"id":"29072","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":14,"text":"내가 내 동족 중 여러 연갑자(年甲者)보다 유대교를 지나치게 믿어 내 조상의 유전에 대하여 더욱 열심이 있었으나","reference":"갈라디아서 1:14","category":"$undefined"},{"id":"29073","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":15,"text":"그러나 내 어머니의 태로부터 나를 택정(擇定)하시고 은혜로 나를 부르신 이가","reference":"갈라디아서 1:15","category":"$undefined"},{"id":"29074","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":16,"text":"그 아들을 이방에 전하기 위하여 그를 내 속에 나타내시기를 기뻐하실 때에 내가 곧 혈육과 의논하지 아니하고","reference":"갈라디아서 1:16","category":"$undefined"},{"id":"29075","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":17,"text":"또 나보다 먼저 사도 된 자들을 만나려고 예루살렘으로 가지 아니하고 오직 아라비아로 갔다가 다시 다메섹으로 돌아갔노라","reference":"갈라디아서 1:17","category":"$undefined"},{"id":"29076","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":18,"text":"그 후 삼년만에 내가 게바를 심방하려고 예루살렘에 올라가서 저와 함께 십 오일을 유할쌔","reference":"갈라디아서 1:18","category":"$undefined"},{"id":"29077","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":19,"text":"주의 형제 야고보 외에 다른 사도들을 보지 못하였노라","reference":"갈라디아서 1:19","category":"$undefined"},{"id":"29078","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":20,"text":"보라 내가 너희에게 쓰는 것은 하나님 앞에서 거짓말이 아니로라","reference":"갈라디아서 1:20","category":"$undefined"},{"id":"29079","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":21,"text":"그 후에 내가 수리아와 길리기아 지방에 이르렀으나","reference":"갈라디아서 1:21","category":"$undefined"},{"id":"29080","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":22,"text":"유대에 그리스도 안에 있는 교회들이 나를 얼굴로 알지 못하고","reference":"갈라디아서 1:22","category":"$undefined"},{"id":"29081","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":23,"text":"다만 우리를 핍박하던 자가 전에 잔해하던 그 믿음을 지금 전한다 함을 듣고","reference":"갈라디아서 1:23","category":"$undefined"},{"id":"29082","book":"갈라디아서","book_name":"갈라디아서","chapter":1,"verse":24,"text":"나로 말미암아 영광을 하나님께 돌리니라","reference":"갈라디아서 1:24","category":"$undefined"}],"bookSlug":"galatians"}]
