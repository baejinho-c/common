2:["$","$L11",null,{"book":{"id":"galatians","name":"갈라디아서","chapters":6,"testament":"new"},"chapter":2,"verses":[{"id":"29083","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":1,"text":"십 사년 후에 내가 바나바와 함께 디도를 데리고 다시 예루살렘에 올라갔노니","reference":"갈라디아서 2:1","category":"$undefined"},{"id":"29084","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":2,"text":"계시를 인하여 올라가 내가 이방 가운데서 전파하는 복음을 저희에게 제출하되 유명한 자들에게 사사로이 한 것은 내가 달음질하는 것이나 달음질한 것이 헛되지 않게 하려 함이라","reference":"갈라디아서 2:2","category":"$undefined"},{"id":"29085","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":3,"text":"그러나 나와 함께 있는 헬라인 디도라도 억지로 할례를 받게 아니하였으니","reference":"갈라디아서 2:3","category":"$undefined"},{"id":"29086","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":4,"text":"이는 가만히 들어온 거짓 형제 까닭이라 저희가 가만히 들어온 것은 그리스도 예수 안에서 우리의 가진 자유를 엿보고 우리를 종으로 삼고자 함이로되","reference":"갈라디아서 2:4","category":"$undefined"},{"id":"29087","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":5,"text":"우리가 일시라도 복종치 아니하였으니 이는 복음의 진리로 너희 가운데 항상 있게 하려 함이라","reference":"갈라디아서 2:5","category":"$undefined"},{"id":"29088","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":6,"text":"유명하다는 이들 중에 (본래 어떤 이들이든지 내게 상관이 없으며 하나님은 사람의 외모를 취하지 아니하시나니) 저 유명한 이들은 내게 더하여 준 것이 없고","reference":"갈라디아서 2:6","category":"$undefined"},{"id":"29089","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":7,"text":"도리어 내가 무할례자에게 복음 전함을 맡기를 베드로가 할례자에게 맡음과 같이 한 것을 보고","reference":"갈라디아서 2:7","category":"$undefined"},{"id":"29090","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":8,"text":"베드로에게 역사하사 그를 할례자의 사도로 삼으신 이가 또한 내게 역사하사 나를 이방인에게 사도로 삼으셨느니라","reference":"갈라디아서 2:8","category":"$undefined"},{"id":"29091","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":9,"text":"또 내게 주신 은혜를 알므로 기둥같이 여기는 야고보와 게바와 요한도 나와 바나바에게 교제의 악수를 하였으니 이는 우리는 이방인에게로, 저희는 할례자에게로 가게 하려 함이라","reference":"갈라디아서 2:9","category":"$undefined"},{"id":"29092","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":10,"text":"다만 우리에게 가난한 자들 생각하는 것을 부탁하였으니 이것을 나도 본래 힘써 행하노라","reference":"갈라디아서 2:10","category":"$undefined"},{"id":"29093","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":11,"text":"게바가 안디옥에 이르렀을 때에 책망할 일이 있기로 내가 저를 면책(面責)하였노라","reference":"갈라디아서 2:11","category":"$undefined"},{"id":"29094","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":12,"text":"야고보에게서 온 어떤 이들이 이르기 전에 게바가 이방인과 함께 먹다가 저희가 오매 그가 할례자들을 두려워하여 떠나 물러가매","reference":"갈라디아서 2:12","category":"$undefined"},{"id":"29095","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":13,"text":"남은 유대인들도 저와 같이 외식하므로 바나바도 저희의 외식에 유혹되었느니라","reference":"갈라디아서 2:13","category":"$undefined"},{"id":"29096","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":14,"text":"그러므로 나는 저희가 복음의 진리를 따라 바로 행하지 아니함을 보고 모든 자 앞에서 게바에게 이르되 네가 유대인으로서 이방을 좇고 유대인답게 살지 아니하면서 어찌하여 억지로 이방인을 유대인답게 살게 하려느냐 하였노라","reference":"갈라디아서 2:14","category":"$undefined"},{"id":"29097","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":15,"text":"우리는 본래 유대인이요 이방 죄인이 아니로되","reference":"갈라디아서 2:15","category":"$undefined"},{"id":"29098","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":16,"text":"사람이 의롭게 되는 것은 율법의 행위에서 난 것이 아니요 오직 예수 그리스도를 믿음으로 말미암는 줄 아는고로 우리도 그리스도 예수를 믿나니 이는 우리가 율법의 행위에서 아니고 그리스도를 믿음으로서 의롭다 함을 얻으려 함이라 율법의 행위로서는 의롭다 함을 얻을 육체가 없느니라","reference":"갈라디아서 2:16","category":"$undefined"},{"id":"29099","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":17,"text":"만일 우리가 그리스도 안에서 의롭게 되려 하다가 죄인으로 나타나면 그리스도께서 죄를 짓게 하는 자냐 결코 그럴 수 없느니라","reference":"갈라디아서 2:17","category":"$undefined"},{"id":"29100","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":18,"text":"만일 내가 헐었던 것을 다시 세우면 내가 나를 범법한 자로 만드는 것이라","reference":"갈라디아서 2:18","category":"$undefined"},{"id":"29101","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":19,"text":"내가 율법으로 말미암아 율법을 향하여 죽었나니 이는 하나님을 향하여 살려 함이니라","reference":"갈라디아서 2:19","category":"$undefined"},{"id":"29102","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":20,"text":"내가 그리스도와 함께 십자가에 못 박혔나니 그런즉 이제는 내가 산 것이 아니요 오직 내 안에 그리스도께서 사신 것이라 이제 내가 육체 가운데 사는 것은 나를 사랑하사 나를 위하여 자기 몸을 버리신 하나님의 아들을 믿는 믿음 안에서 사는 것이라","reference":"갈라디아서 2:20","category":"$undefined"},{"id":"29103","book":"갈라디아서","book_name":"갈라디아서","chapter":2,"verse":21,"text":"내가 하나님의 은혜를 폐하지 아니하노니 만일 의롭게 되는 것이 율법으로 말미암으면 그리스도께서 헛되이 죽으셨느니라","reference":"갈라디아서 2:21","category":"$undefined"}],"bookSlug":"galatians"}]
