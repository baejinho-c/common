2:["$","$L11",null,{"book":{"id":"galatians","name":"갈라디아서","chapters":6,"testament":"new"},"chapter":4,"verses":[{"id":"29133","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":1,"text":"내가 또 말하노니 유업을 이을 자가 모든 것의 주인이나 어렸을 동안에는 종과 다름이 없어서","reference":"갈라디아서 4:1","category":"$undefined"},{"id":"29134","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":2,"text":"그 아버지의 정한 때까지 후견인과 청지기 아래 있나니","reference":"갈라디아서 4:2","category":"$undefined"},{"id":"29135","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":3,"text":"이와 같이 우리도 어렸을 때에 이 세상 초등 학문 아래 있어서 종노릇하였더니","reference":"갈라디아서 4:3","category":"$undefined"},{"id":"29136","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":4,"text":"때가 차매 하나님이 그 아들을 보내사 여자에게서 나게 하시고 율법 아래 나게 하신 것은","reference":"갈라디아서 4:4","category":"$undefined"},{"id":"29137","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":5,"text":"율법 아래 있는 자들을 속량하시고 우리로 아들의 명분을 얻게 하려 하심이라","reference":"갈라디아서 4:5","category":"$undefined"},{"id":"29138","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":6,"text":"너희가 아들인고로 하나님이 그 아들의 영을 우리 마음 가운데 보내사 아바, 아버지라 부르게 하셨느니라","reference":"갈라디아서 4:6","category":"$undefined"},{"id":"29139","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":7,"text":"그러므로 네가 이 후로는 종이 아니요 아들이니 아들이면 하나님으로 말미암아 유업을 이을 자니라","reference":"갈라디아서 4:7","category":"$undefined"},{"id":"29140","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":8,"text":"그러나 너희가 그 때에는 하나님을 알지 못하여 본질상 하나님이 아닌 자들에게 종노릇하였더니","reference":"갈라디아서 4:8","category":"$undefined"},{"id":"29141","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":9,"text":"이제는 너희가 하나님을 알 뿐더러 하나님의 아신 바 되었거늘 어찌하여 다시 약하고 천한 초등 학문으로 돌아 가서 다시 저희에게 종노릇하려 하느냐","reference":"갈라디아서 4:9","category":"$undefined"},{"id":"29142","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":10,"text":"너희가 날과 달과 절기와 해를 삼가 지키니","reference":"갈라디아서 4:10","category":"$undefined"},{"id":"29143","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":11,"text":"내가 너희를 위하여 수고한 것이 헛될까 두려워하노라","reference":"갈라디아서 4:11","category":"$undefined"},{"id":"29144","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":12,"text":"형제들아 내가 너희와 같이 되었은즉 너희도 나와 같이 되기를 구하노라 너희가 내게 해롭게 하지 아니하였느니라","reference":"갈라디아서 4:12","category":"$undefined"},{"id":"29145","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":13,"text":"내가 처음에 육체의 약함을 인하여 너희에게 복음을 전한 것을 너희가 아는 바라","reference":"갈라디아서 4:13","category":"$undefined"},{"id":"29146","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":14,"text":"너희를 시험하는 것이 내 육체에 있으되 이것을 너희가 업신여기지도 아니하며 버리지도 아니하고 오직 나를 하나님의 천사와 같이 또는 그리스도 예수와 같이 영접하였도다","reference":"갈라디아서 4:14","category":"$undefined"},{"id":"29147","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":15,"text":"너희의 복이 지금 어디 있느냐 ? 내가 너희에게 증거하노니 너희가 할 수만 있었더면 너희의 눈이라도 빼어 나를 주었으리라","reference":"갈라디아서 4:15","category":"$undefined"},{"id":"29148","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":16,"text":"그런즉 내가 너희에게 참된 말을 하므로 원수가 되었느냐 ?","reference":"갈라디아서 4:16","category":"$undefined"},{"id":"29149","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":17,"text":"저희가 너희를 대하여 열심내는 것이 좋은 뜻이 아니요 오직 너희를 이간 붙여 너희로 저희를 대하여 열심내게 하려 함이라","reference":"갈라디아서 4:17","category":"$undefined"},{"id":"29150","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":18,"text":"좋은 일에 대하여 열심으로 사모함을 받음은 내가 너희를 대하였을 때뿐 아니라 언제든지 좋으니라","reference":"갈라디아서 4:18","category":"$undefined"},{"id":"29151","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":19,"text":"나의 자녀들아 너희 속에 그리스도의 형상이 이루기까지 다시 너를 위하여 해산하는 수고를 하노니","reference":"갈라디아서 4:19","category":"$undefined"},{"id":"29152","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":20,"text":"내가 이제라도 너희와 함께 있어 내 음성을 변하려 함은 너희를 대하여 의심이 있음이라","reference":"갈라디아서 4:20","category":"$undefined"},{"id":"29153","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":21,"text":"내게 말하라 율법 아래 있고자 하는 자들아 율법을 듣지 못하였느냐 ?","reference":"갈라디아서 4:21","category":"$undefined"},{"id":"29154","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":22,"text":"기록된 바 아브라함이 두 아들이 있으니 하나는 계집종에게서 하나는 자유하는 여자에게서 났다 하였으나","reference":"갈라디아서 4:22","category":"$undefined"},{"id":"29155","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":23,"text":"계집종에게서는 육체를 따라 났고 자유하는 여자에게서는 약속으로 말미암았느니라","reference":"갈라디아서 4:23","category":"$undefined"},{"id":"29156","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":24,"text":"이것은 비유니 이 여자들은 두 언약이라 하나는 시내산으로부터 종을 낳은 자니 곧 하가라","reference":"갈라디아서 4:24","category":"$undefined"},{"id":"29157","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":25,"text":"이 하가는 아라비아에 있는 시내산으로 지금 있는 예루살렘과 같은 데니 저가 그 자녀들로 더불어 종노릇하고","reference":"갈라디아서 4:25","category":"$undefined"},{"id":"29158","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":26,"text":"오직 위에 있는 예루살렘은 자유자니 곧 우리 어머니라","reference":"갈라디아서 4:26","category":"$undefined"},{"id":"29159","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":27,"text":"기록된 바 잉태치 못한 자여 즐거워하라 구로치 못한 자여 소리 질러 외치라 이는 홀로 사는 자의 자녀가 남편 있는 자의 자녀보다 많음이라 하였으니","reference":"갈라디아서 4:27","category":"$undefined"},{"id":"29160","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":28,"text":"형제들아 ! 너희는 이삭과 같이 약속의 자녀라","reference":"갈라디아서 4:28","category":"$undefined"},{"id":"29161","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":29,"text":"그러나 그 때에 육체를 따라 난 자가 성령을 따라 난 자를 핍박한 것같이 이제도 그러하도다","reference":"갈라디아서 4:29","category":"$undefined"},{"id":"29162","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":30,"text":"그러나 성경이 무엇을 말하느뇨 계집종과 그 아들을 내어 쫓으라 계집종의 아들이 자유하는 여자의 아들로 더불어 유업을 얻지 못하리라 하였느니라","reference":"갈라디아서 4:30","category":"$undefined"},{"id":"29163","book":"갈라디아서","book_name":"갈라디아서","chapter":4,"verse":31,"text":"그런즉 형제들아 ! 우리는 계집종의 자녀가 아니요 자유하는 여자의 자녀니라","reference":"갈라디아서 4:31","category":"$undefined"}],"bookSlug":"galatians"}]
