2:["$","$L11",null,{"book":{"id":"galatians","name":"갈라디아서","chapters":6,"testament":"new"},"chapter":5,"verses":[{"id":"29164","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":1,"text":"그리스도께서 우리로 자유케 하려고 자유를 주셨으니 그러므로 굳세게 서서 다시는 종의 멍에를 메지 말라 !","reference":"갈라디아서 5:1","category":"$undefined"},{"id":"29165","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":2,"text":"보라 나 바울은 너희에게 말하노니 너희가 만일 할례를 받으면 그리스도께서 너희에게 아무 유익이 없으리라","reference":"갈라디아서 5:2","category":"$undefined"},{"id":"29166","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":3,"text":"내가 할례를 받는 각 사람에게 다시 증거하노니 그는 율법 전체를 행할 의무를 가진 자라","reference":"갈라디아서 5:3","category":"$undefined"},{"id":"29167","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":4,"text":"율법 안에서 의롭다 함을 얻으려 하는 너희는 그리스도에게서 끊어지고 은혜에서 떨어진 자로다","reference":"갈라디아서 5:4","category":"$undefined"},{"id":"29168","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":5,"text":"우리가 성령으로 믿음을 좇아 의의 소망을 기다리노니","reference":"갈라디아서 5:5","category":"$undefined"},{"id":"29169","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":6,"text":"그리스도 예수 안에서는 할례나 무할례가 효력이 없되 사랑으로써 역사하는 믿음 뿐이니라 !","reference":"갈라디아서 5:6","category":"$undefined"},{"id":"29170","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":7,"text":"너희가 달음질을 잘하더니 누가 너희를 막아 진리를 순종치 않게 하더냐 ?","reference":"갈라디아서 5:7","category":"$undefined"},{"id":"29171","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":8,"text":"그 권면이 너희를 부르신 이에게서 난 것이 아니라","reference":"갈라디아서 5:8","category":"$undefined"},{"id":"29172","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":9,"text":"적은 누룩이 온 덩이에 퍼지느니라","reference":"갈라디아서 5:9","category":"$undefined"},{"id":"29173","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":10,"text":"나는 너희가 아무 다른 마음도 품지 아니할 줄을 주 안에서 확신하노라 그러나 너희를 요동케 하는 자는 누구든지 심판을 받으리라","reference":"갈라디아서 5:10","category":"$undefined"},{"id":"29174","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":11,"text":"형제들아 ! 내가 지금까지 할례를 전하면 어찌하여 지금까지 핍박을 받으리요 그리하였으면 십자가의 거치는 것이 그쳤으리니","reference":"갈라디아서 5:11","category":"$undefined"},{"id":"29175","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":12,"text":"너희를 어지럽게 하는 자들이 스스로 베어버리기를 원하노라","reference":"갈라디아서 5:12","category":"$undefined"},{"id":"29176","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":13,"text":"형제들아 ! 너희가 자유를 위하여 부르심을 입었으나 그러나 그 자유로 육체의 기회를 삼지 말고 오직 사랑으로 서로 종노릇하라 !","reference":"갈라디아서 5:13","category":"$undefined"},{"id":"29177","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":14,"text":"온 율법은 네 이웃 사랑하기를 네 몸같이 하라 하신 한 말씀에 이루었나니","reference":"갈라디아서 5:14","category":"$undefined"},{"id":"29178","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":15,"text":"만일 서로 물고 먹으면 피차 멸망할까 조심하라","reference":"갈라디아서 5:15","category":"$undefined"},{"id":"29179","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":16,"text":"내가 이르노니 너희는 성령을 좇아 행하라 그리하면 육체의 욕심을 이루지 아니하리라","reference":"갈라디아서 5:16","category":"$undefined"},{"id":"29180","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":17,"text":"육체의 소욕은 성령을 거스리고 성령의 소욕은 육체를 거스리나니 이 둘이 서로 대적함으로 너희의 원하는 것을 하지 못하게 하려 함이니라","reference":"갈라디아서 5:17","category":"$undefined"},{"id":"29181","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":18,"text":"너희가 만일 성령의 인도하시는 바가 되면 율법 아래 있지 아니하리라","reference":"갈라디아서 5:18","category":"$undefined"},{"id":"29182","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":19,"text":"육체의 일은 현저하니 곧 음행과, 더러운 것과, 호색과,","reference":"갈라디아서 5:19","category":"$undefined"},{"id":"29183","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":20,"text":"우상 숭배와, 술수와, 원수를 맺는 것과, 분쟁과, 시기와, 분냄과, 당짓는 것과, 분리함과, 이단과,","reference":"갈라디아서 5:20","category":"$undefined"},{"id":"29184","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":21,"text":"투기와, 술 취함과, 방탕함과, 또 그와 같은 것들이라 전에 너희에게 경계한 것같이 경계하노니 이런 일을 하는 자들은 하나님의 나라를 유업으로 받지 못할 것이요","reference":"갈라디아서 5:21","category":"$undefined"},{"id":"29185","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":22,"text":"오직 성령의 열매는 사랑과, 희락과, 화평과, 오래 참음과, 자비와, 양선과, 충성과,","reference":"갈라디아서 5:22","category":"$undefined"},{"id":"29186","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":23,"text":"온유와, 절제니 이같은 것을 금지할 법이 없느니라","reference":"갈라디아서 5:23","category":"$undefined"},{"id":"29187","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":24,"text":"그리스도 예수의 사람들은 육체와 함께 그 정과 욕심을 십자가에 못 박았느니라","reference":"갈라디아서 5:24","category":"$undefined"},{"id":"29188","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":25,"text":"만일 우리가 성령으로 살면 또한 성령으로 행할지니","reference":"갈라디아서 5:25","category":"$undefined"},{"id":"29189","book":"갈라디아서","book_name":"갈라디아서","chapter":5,"verse":26,"text":"헛된 영광을 구하여 서로 격동하고 서로 투기하지 말지니라","reference":"갈라디아서 5:26","category":"$undefined"}],"bookSlug":"galatians"}]
