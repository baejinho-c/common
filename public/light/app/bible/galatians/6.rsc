2:["$","$L11",null,{"book":{"id":"galatians","name":"갈라디아서","chapters":6,"testament":"new"},"chapter":6,"verses":[{"id":"29190","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":1,"text":"형제들아 ! 사람이 만일 무슨 범죄한 일이 드러나거든 신령한 너희는 온유한 심령으로 그러한 자를 바로 잡고 네 자신을 돌아보아 너도 시험을 받을까 두려워하라","reference":"갈라디아서 6:1","category":"$undefined"},{"id":"29191","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":2,"text":"너희가 짐을 서로 지라 ! 그리하여 그리스도의 법을 성취하라","reference":"갈라디아서 6:2","category":"$undefined"},{"id":"29192","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":3,"text":"만일 누가 아무 것도 되지 못하고 된 줄로 생각하면 스스로 속임이니라","reference":"갈라디아서 6:3","category":"$undefined"},{"id":"29193","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":4,"text":"각각 자기의 일을 살피라 그리하면 자랑할 것이 자기에게만 있고 남에게는 있지 아니하리니","reference":"갈라디아서 6:4","category":"$undefined"},{"id":"29194","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":5,"text":"각각 자기의 짐을 질 것임이니라","reference":"갈라디아서 6:5","category":"$undefined"},{"id":"29195","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":6,"text":"가르침을 받는 자는 말씀을 가르치는 자와 모든 좋은 것을 함께 하라 !","reference":"갈라디아서 6:6","category":"$undefined"},{"id":"29196","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":7,"text":"스스로 속이지 말라 ! 하나님은 만홀히 여김을 받지 아니하시나니 사람이 무엇으로 심든지 그대로 거두리라 !","reference":"갈라디아서 6:7","category":"$undefined"},{"id":"29197","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":8,"text":"자기의 육체를 위하여 심는 자는 육체로부터 썩어진 것을 거두고 성령을 위하여 심는 자는 성령으로부터 영생을 거두리라","reference":"갈라디아서 6:8","category":"$undefined"},{"id":"29198","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":9,"text":"우리가 선을 행하되 낙심하지 말지니 피곤하지 아니하면 때가 이르매 거두리라","reference":"갈라디아서 6:9","category":"$undefined"},{"id":"29199","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":10,"text":"그러므로 우리는 기회 있는 대로 모든 이에게 착한 일을 하되 더욱 믿음의 가정들에게 할지니라","reference":"갈라디아서 6:10","category":"$undefined"},{"id":"29200","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":11,"text":"내 손으로 너희에게 이렇게 큰 글자로 쓴 것을 보라","reference":"갈라디아서 6:11","category":"$undefined"},{"id":"29201","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":12,"text":"무릇 육체의 모양을 내려 하는 자들이 억지로 너희로 할례 받게 함은 저희가 그리스도의 십자가를 인하여 핍박을 면하려 함뿐이라","reference":"갈라디아서 6:12","category":"$undefined"},{"id":"29202","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":13,"text":"할례 받은 저희라도 스스로 율법은 지키지 아니하고 너희로 할례 받게 하려 하는 것은 너희의 육체로 자랑하려 함이니라","reference":"갈라디아서 6:13","category":"$undefined"},{"id":"29203","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":14,"text":"그러나 내게는 우리 주 예수 그리스도의 십자가 외에 결코 자랑할 것이 없으니 그리스도로 말미암아 세상이 나를 대하여 십자가에 못 박히고 내가 또한 세상을 대하여 그러하니라","reference":"갈라디아서 6:14","category":"$undefined"},{"id":"29204","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":15,"text":"할례나 무할례가 아무 것도 아니로되 오직 새로 지으심을 받은 자뿐이니라","reference":"갈라디아서 6:15","category":"$undefined"},{"id":"29205","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":16,"text":"무릇 이 규례를 행하는 자에게와 하나님의 이스라엘에게 평강과 긍휼이 있을지어다 !","reference":"갈라디아서 6:16","category":"$undefined"},{"id":"29206","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":17,"text":"이 후로는 누구든지 나를 괴롭게 말라 내가 내 몸에 예수의 흔적을 가졌노라","reference":"갈라디아서 6:17","category":"$undefined"},{"id":"29207","book":"갈라디아서","book_name":"갈라디아서","chapter":6,"verse":18,"text":"형제들아 ! 우리 주 예수 그리스도의 은혜가 너희 심령에 있을지어다 ! 아멘","reference":"갈라디아서 6:18","category":"$undefined"}],"bookSlug":"galatians"}]
