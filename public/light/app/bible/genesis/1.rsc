2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":1,"verses":[{"id":"1","book":"창세기","book_name":"창세기","chapter":1,"verse":1,"text":"태초에 하나님이 천지를 창조하시니라 !","reference":"창세기 1:1","category":"$undefined"},{"id":"2","book":"창세기","book_name":"창세기","chapter":1,"verse":2,"text":"땅이 혼돈하고 공허하며 흑암이 깊음 위에 있고 하나님의 신(神)은 수면에 운행하시니라","reference":"창세기 1:2","category":"$undefined"},{"id":"3","book":"창세기","book_name":"창세기","chapter":1,"verse":3,"text":"하나님이 가라사대 빛이 있으라 ! 하시매 빛이 있었고","reference":"창세기 1:3","category":"$undefined"},{"id":"4","book":"창세기","book_name":"창세기","chapter":1,"verse":4,"text":"그 빛이 하나님의 보시기에 좋았더라 하나님이 빛과 어두움을 나누사","reference":"창세기 1:4","category":"$undefined"},{"id":"5","book":"창세기","book_name":"창세기","chapter":1,"verse":5,"text":"빛을 낮이라 칭하시고 어두움을 밤이라 칭하시니라 저녁이 되며 아침이 되니 이는 첫째 날이니라","reference":"창세기 1:5","category":"$undefined"},{"id":"6","book":"창세기","book_name":"창세기","chapter":1,"verse":6,"text":"하나님이 가라사대 물 가운데 궁창이 있어 물과 물로 나뉘게 하리라 ! 하시고","reference":"창세기 1:6","category":"$undefined"},{"id":"7","book":"창세기","book_name":"창세기","chapter":1,"verse":7,"text":"하나님이 궁창을 만드사 궁창 아래의 물과 궁창 위의 물로 나뉘게 하시매 그대로 되니라","reference":"창세기 1:7","category":"$undefined"},{"id":"8","book":"창세기","book_name":"창세기","chapter":1,"verse":8,"text":"하나님이 궁창을 하늘이라 칭하시니라 저녁이 되며 아침이 되니 이는 둘째 날이니라","reference":"창세기 1:8","category":"$undefined"},{"id":"9","book":"창세기","book_name":"창세기","chapter":1,"verse":9,"text":"하나님이 가라사대 천하의 물이 한곳으로 모이고 뭍이 드러나라 ! 하시매 그대로 되니라","reference":"창세기 1:9","category":"$undefined"},{"id":"10","book":"창세기","book_name":"창세기","chapter":1,"verse":10,"text":"하나님이 뭍을 땅이라 칭하시고 모인 물을 바다라 칭하시니라 하나님의 보시기에 좋았더라","reference":"창세기 1:10","category":"$undefined"},{"id":"11","book":"창세기","book_name":"창세기","chapter":1,"verse":11,"text":"하나님이 가라사대 땅은 풀과 씨 맺는 채소와 각기 종류대로 씨 가진 열매 맺는 과목을 내라 하시매 그대로 되어","reference":"창세기 1:11","category":"$undefined"},{"id":"12","book":"창세기","book_name":"창세기","chapter":1,"verse":12,"text":"땅이 풀과 각기 종류대로 씨 맺는 채소와 각기 종류대로 씨 가진 열매 맺는 나무를 내니 하나님의 보시기에 좋았더라","reference":"창세기 1:12","category":"$undefined"},{"id":"13","book":"창세기","book_name":"창세기","chapter":1,"verse":13,"text":"저녁이 되며 아침이 되니 이는 세째 날이니라","reference":"창세기 1:13","category":"$undefined"},{"id":"14","book":"창세기","book_name":"창세기","chapter":1,"verse":14,"text":"하나님이 가라사대 하늘의 궁창에 광명이 있어 주야를 나뉘게 하라 또 그 광명으로 하여 징조와 사시와 일자와 연한이 이루라","reference":"창세기 1:14","category":"$undefined"},{"id":"15","book":"창세기","book_name":"창세기","chapter":1,"verse":15,"text":"또 그 광명이 하늘의 궁창에 있어 땅에 비취라 하시고 (그대로 되니라)","reference":"창세기 1:15","category":"$undefined"},{"id":"16","book":"창세기","book_name":"창세기","chapter":1,"verse":16,"text":"하나님이 두 큰 광명을 만드사 큰 광명으로 낮을 주관하게 하시고 작은 광명으로 밤을 주관하게 하시며 또 별들을 만드시고","reference":"창세기 1:16","category":"$undefined"},{"id":"17","book":"창세기","book_name":"창세기","chapter":1,"verse":17,"text":"하나님이 그것들을 하늘의 궁창에 두어 땅에 비취게 하시며","reference":"창세기 1:17","category":"$undefined"},{"id":"18","book":"창세기","book_name":"창세기","chapter":1,"verse":18,"text":"주야를 주관하게 하시며 빛과 어두움을 나뉘게 하시니라 하나님의 보시기에 좋았더라","reference":"창세기 1:18","category":"$undefined"},{"id":"19","book":"창세기","book_name":"창세기","chapter":1,"verse":19,"text":"저녁이 되며 아침이 되니 이는 네째 날이니라","reference":"창세기 1:19","category":"$undefined"},{"id":"20","book":"창세기","book_name":"창세기","chapter":1,"verse":20,"text":"하나님이 가라사대 물들은 생물로 번성케 하라 땅 위 하늘의 궁창에는 새가 날으라 하시고","reference":"창세기 1:20","category":"$undefined"},{"id":"21","book":"창세기","book_name":"창세기","chapter":1,"verse":21,"text":"하나님이 큰 물고기와 물에서 번성하여 움직이는 모든 생물을 그 종류대로, 날개 있는 모든 새를 그 종류대로 창조하시니 하나님의 보시기에 좋았더라","reference":"창세기 1:21","category":"$undefined"},{"id":"22","book":"창세기","book_name":"창세기","chapter":1,"verse":22,"text":"하나님이 그들에게 복을 주어 가라사대 생육하고 번성하여 여러 바다물에 충만하라 새들도 땅에 번성하라 하시니라","reference":"창세기 1:22","category":"$undefined"},{"id":"23","book":"창세기","book_name":"창세기","chapter":1,"verse":23,"text":"저녁이 되며 아침이 되니 이는 다섯째 날이니라","reference":"창세기 1:23","category":"$undefined"},{"id":"24","book":"창세기","book_name":"창세기","chapter":1,"verse":24,"text":"하나님이 가라사대 땅은 생물을 그 종류대로 내되 육축과 기는 것과 땅의 짐승을 종류대로 내라 하시고 (그대로 되니라)","reference":"창세기 1:24","category":"$undefined"},{"id":"25","book":"창세기","book_name":"창세기","chapter":1,"verse":25,"text":"하나님이 땅의 짐승을 그 종류대로, 육축을 그 종류대로, 땅에 기는 모든 것을 그 종류대로 만드시니 하나님의 보시기에 좋았더라","reference":"창세기 1:25","category":"$undefined"},{"id":"26","book":"창세기","book_name":"창세기","chapter":1,"verse":26,"text":"하나님이 가라사대 우리의 형상을 따라 우리의 모양대로 우리가 사람을 만들고 그로 바다의 고기와, 공중의 새와, 육축과, 온 땅과, 땅에 기는 모든 것을 다스리게 하자 하시고","reference":"창세기 1:26","category":"$undefined"},{"id":"27","book":"창세기","book_name":"창세기","chapter":1,"verse":27,"text":"하나님이 자기 형상 곧 하나님의 형상대로 사람을 창조하시되 남자와 여자를 창조하시고","reference":"창세기 1:27","category":"$undefined"},{"id":"28","book":"창세기","book_name":"창세기","chapter":1,"verse":28,"text":"하나님이 그들에게 복을 주시며 그들에게 이르시되 생육하고 번성하여 땅에 충만하라, 땅을 정복하라, 바다의 고기와 공중의 새와 땅에 움직이는 모든 생물을 다스리라 하시니라","reference":"창세기 1:28","category":"$undefined"},{"id":"29","book":"창세기","book_name":"창세기","chapter":1,"verse":29,"text":"하나님이 가라사대 내가 온 지면의 씨 맺는 모든 채소와 씨 가진 열매 맺는 모든 나무를 너희에게 주노니 너희 식물이 되리라","reference":"창세기 1:29","category":"$undefined"},{"id":"30","book":"창세기","book_name":"창세기","chapter":1,"verse":30,"text":"또 땅의 모든 짐승과 공중의 모든 새와 생명이 있어 땅에 기는 모든 것에게는 내가 모든 푸른 풀을 식물로 주노라 하시니 그대로 되니라","reference":"창세기 1:30","category":"$undefined"},{"id":"31","book":"창세기","book_name":"창세기","chapter":1,"verse":31,"text":"하나님이 그 지으신 모든 것을 보시니 보시기에 심히 좋았더라 저녁이 되며 아침이 되니 이는 여섯째 날이니라","reference":"창세기 1:31","category":"$undefined"}],"bookSlug":"genesis"}]
