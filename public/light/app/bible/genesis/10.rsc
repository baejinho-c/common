2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":10,"verses":[{"id":"236","book":"창세기","book_name":"창세기","chapter":10,"verse":1,"text":"노아의 아들 셈과, 함과, 야벳의 후예는 이러하니라 홍수 후에 그들이 아들들을 낳았으니","reference":"창세기 10:1","category":"$undefined"},{"id":"237","book":"창세기","book_name":"창세기","chapter":10,"verse":2,"text":"야벳의 아들은 고멜과, 마곡과, 마대와, 야완과, 두발과, 메섹과, 디라스요","reference":"창세기 10:2","category":"$undefined"},{"id":"238","book":"창세기","book_name":"창세기","chapter":10,"verse":3,"text":"고멜의 아들은 아스그나스와, 리밧과, 도갈마요","reference":"창세기 10:3","category":"$undefined"},{"id":"239","book":"창세기","book_name":"창세기","chapter":10,"verse":4,"text":"야완의 아들은 엘리사와, 달시스와, 깃딤과, 도다님이라","reference":"창세기 10:4","category":"$undefined"},{"id":"240","book":"창세기","book_name":"창세기","chapter":10,"verse":5,"text":"이들로부터 여러 나라 백성으로 나뉘어서 각기 방언과 종족과 나라대로 바닷가의 땅에 머물렀더라","reference":"창세기 10:5","category":"$undefined"},{"id":"241","book":"창세기","book_name":"창세기","chapter":10,"verse":6,"text":"함의 아들은 구스와, 미스라임과, 붓과, 가나안이요","reference":"창세기 10:6","category":"$undefined"},{"id":"242","book":"창세기","book_name":"창세기","chapter":10,"verse":7,"text":"구스의 아들은 스바와, 하윌라와, 삽다와, 라아마와, 삽드가요, 라아마의 아들은 스바와, 드단이며","reference":"창세기 10:7","category":"$undefined"},{"id":"243","book":"창세기","book_name":"창세기","chapter":10,"verse":8,"text":"구스가 또 니므롯을 낳았으니 그는 세상에 처음 영걸이라","reference":"창세기 10:8","category":"$undefined"},{"id":"244","book":"창세기","book_name":"창세기","chapter":10,"verse":9,"text":"그가 여호와 앞에서 특이한 사냥군이 되었으므로 속담에 이르기를 아무는 여호와 앞에 니므롯 같은 특이한 사냥군이로다 하더라","reference":"창세기 10:9","category":"$undefined"},{"id":"245","book":"창세기","book_name":"창세기","chapter":10,"verse":10,"text":"그의 나라는 시날땅의 바벨과, 에렉과, 악갓과, 갈레에서 시작되었으며","reference":"창세기 10:10","category":"$undefined"},{"id":"246","book":"창세기","book_name":"창세기","chapter":10,"verse":11,"text":"그가 그 땅에서 앗수르로 나아가 니느웨와, 르호보딜과, 갈라와","reference":"창세기 10:11","category":"$undefined"},{"id":"247","book":"창세기","book_name":"창세기","chapter":10,"verse":12,"text":"및 니느웨와 갈라 사이의 레센(이는 큰 성이라)을 건축하였으며","reference":"창세기 10:12","category":"$undefined"},{"id":"248","book":"창세기","book_name":"창세기","chapter":10,"verse":13,"text":"미스라임은 루딤과, 아나밈과, 르하빔과, 납두힘과","reference":"창세기 10:13","category":"$undefined"},{"id":"249","book":"창세기","book_name":"창세기","chapter":10,"verse":14,"text":"바드루심과, 가슬루힘과, 갑도림을 낳았더라 (블레셋이 가슬루힘에게서 나왔더라)","reference":"창세기 10:14","category":"$undefined"},{"id":"250","book":"창세기","book_name":"창세기","chapter":10,"verse":15,"text":"가나안은 장자 시돈과, 헷을 낳고","reference":"창세기 10:15","category":"$undefined"},{"id":"251","book":"창세기","book_name":"창세기","chapter":10,"verse":16,"text":"또 여부스 족속과, 아모리 족속과, 기르가스 족속과","reference":"창세기 10:16","category":"$undefined"},{"id":"252","book":"창세기","book_name":"창세기","chapter":10,"verse":17,"text":"히위 족속과, 알가 족속과, 신 족속과","reference":"창세기 10:17","category":"$undefined"},{"id":"253","book":"창세기","book_name":"창세기","chapter":10,"verse":18,"text":"아르왓 족속과, 스말 족속과, 하맛 족속의 조상을 낳았더니 이 후로 가나안 자손의 족속이 흩어져 처하였더라","reference":"창세기 10:18","category":"$undefined"},{"id":"254","book":"창세기","book_name":"창세기","chapter":10,"verse":19,"text":"가나안의 지경은 시돈에서부터 그랄을 지나 가사까지와, 소돔과, 고모라와, 아드마와, 스보임을 지나 라사까지였더라","reference":"창세기 10:19","category":"$undefined"},{"id":"255","book":"창세기","book_name":"창세기","chapter":10,"verse":20,"text":"이들은 함의 자손이라 각기 족속과 방언과 지방과 나라대로이었더라","reference":"창세기 10:20","category":"$undefined"},{"id":"256","book":"창세기","book_name":"창세기","chapter":10,"verse":21,"text":"셈은 에벨 온 자손의 조상이요 야벳의 형이라 그에게도 자녀가 출생하였으니","reference":"창세기 10:21","category":"$undefined"},{"id":"257","book":"창세기","book_name":"창세기","chapter":10,"verse":22,"text":"셈의 아들은 엘람과, 앗수르와, 아르박삿과, 룻과, 아람이요","reference":"창세기 10:22","category":"$undefined"},{"id":"258","book":"창세기","book_name":"창세기","chapter":10,"verse":23,"text":"아람의 아들은 우스와, 훌과, 게델과, 마스며","reference":"창세기 10:23","category":"$undefined"},{"id":"259","book":"창세기","book_name":"창세기","chapter":10,"verse":24,"text":"아르박삿은 셀라를 낳고, 셀라는 에벨을 낳았으며","reference":"창세기 10:24","category":"$undefined"},{"id":"260","book":"창세기","book_name":"창세기","chapter":10,"verse":25,"text":"에벨은 두 아들을 낳고, 하나의 이름을 벨렉이라 하였으니 그 때에 세상이 나뉘었음이요 벨렉의 아우의 이름은 욕단이며","reference":"창세기 10:25","category":"$undefined"},{"id":"261","book":"창세기","book_name":"창세기","chapter":10,"verse":26,"text":"욕단은 알모닷과, 셀렙과, 하살마웹과, 예라와","reference":"창세기 10:26","category":"$undefined"},{"id":"262","book":"창세기","book_name":"창세기","chapter":10,"verse":27,"text":"하도람과, 우살과, 디글라와","reference":"창세기 10:27","category":"$undefined"},{"id":"263","book":"창세기","book_name":"창세기","chapter":10,"verse":28,"text":"오발과, 아비마엘과, 스바와","reference":"창세기 10:28","category":"$undefined"},{"id":"264","book":"창세기","book_name":"창세기","chapter":10,"verse":29,"text":"오빌과, 하윌라와, 요밥을 낳았으니 이들은 다 욕단의 아들이며","reference":"창세기 10:29","category":"$undefined"},{"id":"265","book":"창세기","book_name":"창세기","chapter":10,"verse":30,"text":"그들의 거하는 곳은 메사에서부터 스발로 가는 길의 동편 산이었더라","reference":"창세기 10:30","category":"$undefined"},{"id":"266","book":"창세기","book_name":"창세기","chapter":10,"verse":31,"text":"이들은 셈의 자손이라 그 족속과 방언과 지방과 나라대로였더라","reference":"창세기 10:31","category":"$undefined"},{"id":"267","book":"창세기","book_name":"창세기","chapter":10,"verse":32,"text":"이들은 노아 자손의 족속들이요 그 세계와 나라대로라 홍수 후에 이들에게서 땅의 열국 백성이 나뉘었더라","reference":"창세기 10:32","category":"$undefined"}],"bookSlug":"genesis"}]
