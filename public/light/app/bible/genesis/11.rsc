2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":11,"verses":[{"id":"268","book":"창세기","book_name":"창세기","chapter":11,"verse":1,"text":"온 땅의 구음이 하나이요 언어가 하나이었더라","reference":"창세기 11:1","category":"$undefined"},{"id":"269","book":"창세기","book_name":"창세기","chapter":11,"verse":2,"text":"이에 그들이 동방으로 옮기다가 시날 평지를 만나 거기 거하고","reference":"창세기 11:2","category":"$undefined"},{"id":"270","book":"창세기","book_name":"창세기","chapter":11,"verse":3,"text":"서로 말하되 `자, 벽돌을 만들어 견고히 굽자' 하고 이에 벽돌로 돌을 대신하며 역청으로 진흙을 대신하고","reference":"창세기 11:3","category":"$undefined"},{"id":"271","book":"창세기","book_name":"창세기","chapter":11,"verse":4,"text":"또 말하되 `자, 성과 대를 쌓아 대 꼭대기를 하늘에 닿게 하여 우리 이름을 내고 온 지면에 흩어짐을 면하자' 하였더니","reference":"창세기 11:4","category":"$undefined"},{"id":"272","book":"창세기","book_name":"창세기","chapter":11,"verse":5,"text":"여호와께서 인생들의 쌓는 성과 대를 보시려고 강림하셨더라","reference":"창세기 11:5","category":"$undefined"},{"id":"273","book":"창세기","book_name":"창세기","chapter":11,"verse":6,"text":"여호와께서 가라사대 이 무리가 한 족속이요, 언어도 하나이므로 이같이 시작하였으니 이후로는 그 경영하는 일을 금지할 수 없으리로다","reference":"창세기 11:6","category":"$undefined"},{"id":"274","book":"창세기","book_name":"창세기","chapter":11,"verse":7,"text":"자, 우리가 내려가서 거기서 그들의 언어를 혼잡케 하여 그들로 서로 알아듣지 못하게 하자 하시고","reference":"창세기 11:7","category":"$undefined"},{"id":"275","book":"창세기","book_name":"창세기","chapter":11,"verse":8,"text":"여호와께서 거기서 그들을 온 지면에 흩으신 고로 그들이 성 쌓기를 그쳤더라","reference":"창세기 11:8","category":"$undefined"},{"id":"276","book":"창세기","book_name":"창세기","chapter":11,"verse":9,"text":"그러므로 그 이름을 바벨이라 하니 이는 여호와께서 거기서 온 땅의 언어를 혼잡케 하셨음이라 여호와께서 거기서 그들을 온 지면에 흩으셨더라","reference":"창세기 11:9","category":"$undefined"},{"id":"277","book":"창세기","book_name":"창세기","chapter":11,"verse":10,"text":"셈의 후예는 이러하니라 셈은 일백세 곧 홍수 후 이년에 아르박삿을 낳았고","reference":"창세기 11:10","category":"$undefined"},{"id":"278","book":"창세기","book_name":"창세기","chapter":11,"verse":11,"text":"아르박삿을 낳은 후에 오백년을 지내며 자녀를 낳았으며","reference":"창세기 11:11","category":"$undefined"},{"id":"279","book":"창세기","book_name":"창세기","chapter":11,"verse":12,"text":"아르박삿은 삼십 오세에 셀라를 낳았고","reference":"창세기 11:12","category":"$undefined"},{"id":"280","book":"창세기","book_name":"창세기","chapter":11,"verse":13,"text":"셀라를 낳은 후에 사백 삼년을 지내며 자녀를 낳았으며","reference":"창세기 11:13","category":"$undefined"},{"id":"281","book":"창세기","book_name":"창세기","chapter":11,"verse":14,"text":"셀라는 삼십세에 에벨을 낳았고","reference":"창세기 11:14","category":"$undefined"},{"id":"282","book":"창세기","book_name":"창세기","chapter":11,"verse":15,"text":"에벨을 낳은 후에 사백 삼년을 지내며 자녀를 낳았으며","reference":"창세기 11:15","category":"$undefined"},{"id":"283","book":"창세기","book_name":"창세기","chapter":11,"verse":16,"text":"에벨은 삼십 사세에 벨렉을 낳았고","reference":"창세기 11:16","category":"$undefined"},{"id":"284","book":"창세기","book_name":"창세기","chapter":11,"verse":17,"text":"벨렉을 낳은 후에 사백 삼십년을 지내며 자녀를 낳았으며","reference":"창세기 11:17","category":"$undefined"},{"id":"285","book":"창세기","book_name":"창세기","chapter":11,"verse":18,"text":"벨렉은 삼십세에 르우를 낳았고","reference":"창세기 11:18","category":"$undefined"},{"id":"286","book":"창세기","book_name":"창세기","chapter":11,"verse":19,"text":"르우를 낳은 후에 이백 구년을 지내며 자녀를 낳았으며","reference":"창세기 11:19","category":"$undefined"},{"id":"287","book":"창세기","book_name":"창세기","chapter":11,"verse":20,"text":"르우는 삼십 이세에 스룩을 낳았고","reference":"창세기 11:20","category":"$undefined"},{"id":"288","book":"창세기","book_name":"창세기","chapter":11,"verse":21,"text":"스룩을 낳은 후에 이백 칠년을 지내며 자녀를 낳았으며","reference":"창세기 11:21","category":"$undefined"},{"id":"289","book":"창세기","book_name":"창세기","chapter":11,"verse":22,"text":"스룩은 삼십세에 나홀을 낳았고","reference":"창세기 11:22","category":"$undefined"},{"id":"290","book":"창세기","book_name":"창세기","chapter":11,"verse":23,"text":"나홀을 낳은 후에 이백년을 지내며 자녀를 낳았으며","reference":"창세기 11:23","category":"$undefined"},{"id":"291","book":"창세기","book_name":"창세기","chapter":11,"verse":24,"text":"나홀은 이십 구세에 데라를 낳았고","reference":"창세기 11:24","category":"$undefined"},{"id":"292","book":"창세기","book_name":"창세기","chapter":11,"verse":25,"text":"데라를 낳은 후에 일백 십 구년을 지내며 자녀를 낳았으며","reference":"창세기 11:25","category":"$undefined"},{"id":"293","book":"창세기","book_name":"창세기","chapter":11,"verse":26,"text":"데라는 칠십세에 아브람과, 나홀과, 하란을 낳았더라","reference":"창세기 11:26","category":"$undefined"},{"id":"294","book":"창세기","book_name":"창세기","chapter":11,"verse":27,"text":"데라의 후예는 이러하니라 데라는 아브람과, 나홀과, 하란을 낳았고 하란은 롯을 낳았으며","reference":"창세기 11:27","category":"$undefined"},{"id":"295","book":"창세기","book_name":"창세기","chapter":11,"verse":28,"text":"하란은 그 아비 데라보다 먼저 본토 갈대아 우르에서 죽었더라","reference":"창세기 11:28","category":"$undefined"},{"id":"296","book":"창세기","book_name":"창세기","chapter":11,"verse":29,"text":"아브람과 나홀이 장가 들었으니 아브람의 아내 이름은 사래며 나홀의 아내 이름은 밀가니 하란의 딸이요 하란은 밀가의 아비며 또 이스가의 아비더라","reference":"창세기 11:29","category":"$undefined"},{"id":"297","book":"창세기","book_name":"창세기","chapter":11,"verse":30,"text":"사래는 잉태하지 못하므로 자식이 없었더라","reference":"창세기 11:30","category":"$undefined"},{"id":"298","book":"창세기","book_name":"창세기","chapter":11,"verse":31,"text":"데라가 그 아들 아브람과 하란의 아들 그 손자 롯과 그 자부 아브람의 아내 사래를 데리고 갈대아 우르에서 떠나 가나안 땅으로 가고자 하더니 하란에 이르러 거기 거하였으며","reference":"창세기 11:31","category":"$undefined"},{"id":"299","book":"창세기","book_name":"창세기","chapter":11,"verse":32,"text":"데라는 이백 오세를 향수하고 하란에서 죽었더라","reference":"창세기 11:32","category":"$undefined"}],"bookSlug":"genesis"}]
