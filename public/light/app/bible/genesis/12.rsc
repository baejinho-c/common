2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":12,"verses":[{"id":"300","book":"창세기","book_name":"창세기","chapter":12,"verse":1,"text":"여호와께서 아브람에게 이르시되 너는 너의 본토 친척 아비 집을 떠나 내가 네게 지시할 땅으로 가라","reference":"창세기 12:1","category":"$undefined"},{"id":"301","book":"창세기","book_name":"창세기","chapter":12,"verse":2,"text":"내가 너로 큰 민족을 이루고 네게 복을 주어 네 이름을 창대케 하리니 너는 복의 근원이 될지라 !","reference":"창세기 12:2","category":"$undefined"},{"id":"302","book":"창세기","book_name":"창세기","chapter":12,"verse":3,"text":"너를 축복하는 자에게는 내가 복을 내리고 너를 저주하는 자에게는 내가 저주하리니 땅의 모든 족속이 너를 인하여 복을 얻을 것이니라 하신지라","reference":"창세기 12:3","category":"$undefined"},{"id":"303","book":"창세기","book_name":"창세기","chapter":12,"verse":4,"text":"이에 아브람이 여호와의 말씀을 좇아 갔고 롯도 그와 함께 갔으며 아브람이 하란을 떠날 때에 그 나이 칠십 오세였더라","reference":"창세기 12:4","category":"$undefined"},{"id":"304","book":"창세기","book_name":"창세기","chapter":12,"verse":5,"text":"아브람이 그 아내 사래와 조카 롯과 하란에서 모은 모든 소유와 얻은 사람들을 이끌고 가나안 땅으로 가려고 떠나서 마침내 가나안 땅에 들어 갔더라","reference":"창세기 12:5","category":"$undefined"},{"id":"305","book":"창세기","book_name":"창세기","chapter":12,"verse":6,"text":"아브람이 그 땅을 통과하여 세겜 땅 모레 상수리 나무에 이르니 그 때에 가나안 사람이 그 땅에 거하였더라","reference":"창세기 12:6","category":"$undefined"},{"id":"306","book":"창세기","book_name":"창세기","chapter":12,"verse":7,"text":"여호와께서 아브람에게 나타나 가라사대 내가 이 땅을 네 자손에게 주리라 하신지라 그가 자기에게 나타나신 여호와를 위하여 그 곳에 단을 쌓고","reference":"창세기 12:7","category":"$undefined"},{"id":"307","book":"창세기","book_name":"창세기","chapter":12,"verse":8,"text":"거기서 벧엘 동편 산으로 옮겨 장막을 치니 서는 벧엘이요, 동은 아이라 그가 그 곳에서 여호와를 위하여 단을 쌓고 여호와의 이름을 부르더니","reference":"창세기 12:8","category":"$undefined"},{"id":"308","book":"창세기","book_name":"창세기","chapter":12,"verse":9,"text":"점점 남방으로 옮겨 갔더라","reference":"창세기 12:9","category":"$undefined"},{"id":"309","book":"창세기","book_name":"창세기","chapter":12,"verse":10,"text":"그 땅에 기근이 있으므로 아브람이 애굽에 우거하려 하여 그리로 내려갔으니 이는 그 땅에 기근이 심하였음이라","reference":"창세기 12:10","category":"$undefined"},{"id":"310","book":"창세기","book_name":"창세기","chapter":12,"verse":11,"text":"그가 애굽에 가까이 이를 때에 그 아내 사래더러 말하되 `나 알기에 그대는 아리따운 여인이라","reference":"창세기 12:11","category":"$undefined"},{"id":"311","book":"창세기","book_name":"창세기","chapter":12,"verse":12,"text":"애굽 사람이 그대를 볼 때에 이르기를 이는 그의 아내라 하고 나는 죽이고 그대는 살리리니","reference":"창세기 12:12","category":"$undefined"},{"id":"312","book":"창세기","book_name":"창세기","chapter":12,"verse":13,"text":"원컨대 그대는 나의 누이라 하라 그리하면 내가 그대로 인하여 안전하고 내 목숨이 그대로 인하여 보존하겠노라' 하니라","reference":"창세기 12:13","category":"$undefined"},{"id":"313","book":"창세기","book_name":"창세기","chapter":12,"verse":14,"text":"아브람이 애굽에 이르렀을 때에 애굽 사람들이 그 여인의 심히 아리따움을 보았고","reference":"창세기 12:14","category":"$undefined"},{"id":"314","book":"창세기","book_name":"창세기","chapter":12,"verse":15,"text":"바로의 대신들도 그를 보고 바로 앞에 칭찬하므로 그 여인을 바로의 궁으로 취하여 들인지라","reference":"창세기 12:15","category":"$undefined"},{"id":"315","book":"창세기","book_name":"창세기","chapter":12,"verse":16,"text":"이에 바로가 그를 인하여 아브람을 후대하므로 아브람이 양과, 소와, 노비와, 암수 나귀와, 약대를 얻었더라","reference":"창세기 12:16","category":"$undefined"},{"id":"316","book":"창세기","book_name":"창세기","chapter":12,"verse":17,"text":"여호와께서 아브람의 아내 사래의 연고로 바로와 그 집에 큰 재앙을 내리신지라","reference":"창세기 12:17","category":"$undefined"},{"id":"317","book":"창세기","book_name":"창세기","chapter":12,"verse":18,"text":"바로가 아브람을 불러서 이르되 `네가 어찌하여 나를 이렇게 대접하였느냐 ? 네가 어찌하여 그를 네 아내라고 내게 고하지 아니하였느냐 ?","reference":"창세기 12:18","category":"$undefined"},{"id":"318","book":"창세기","book_name":"창세기","chapter":12,"verse":19,"text":"네가 어찌 그를 누이라 하여 나로 그를 취하여 아내를 삼게 하였느냐 ? 네 아내가 여기 있으니 이제 데려 가라' 하고","reference":"창세기 12:19","category":"$undefined"},{"id":"319","book":"창세기","book_name":"창세기","chapter":12,"verse":20,"text":"바로가 사람들에게 그의 일을 명하매 그들이 그 아내와 그 모든 소유를 보내었더라","reference":"창세기 12:20","category":"$undefined"}],"bookSlug":"genesis"}]
