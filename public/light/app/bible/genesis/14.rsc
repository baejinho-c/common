2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":14,"verses":[{"id":"338","book":"창세기","book_name":"창세기","chapter":14,"verse":1,"text":"당시에 시날 왕 아므라벨과, 엘라살 왕 아리옥과, 엘람 왕 그돌라오멜과, 고임 왕 디달이","reference":"창세기 14:1","category":"$undefined"},{"id":"339","book":"창세기","book_name":"창세기","chapter":14,"verse":2,"text":"소돔 왕 베라와, 고모라 왕 비르사와, 아드마 왕 시납과, 수보임 왕 세메벨과, 벨라 곧 소알 왕과 싸우니라","reference":"창세기 14:2","category":"$undefined"},{"id":"340","book":"창세기","book_name":"창세기","chapter":14,"verse":3,"text":"이들이 다 싯딤 골짜기 곧 지금 염해에 모였더라","reference":"창세기 14:3","category":"$undefined"},{"id":"341","book":"창세기","book_name":"창세기","chapter":14,"verse":4,"text":"이들이 십 이년 동안 그돌라오멜을 섬기다가 제 십 삼년에 배반한지라","reference":"창세기 14:4","category":"$undefined"},{"id":"342","book":"창세기","book_name":"창세기","chapter":14,"verse":5,"text":"제 십 사년에 그돌라오멜과 그와 동맹한 왕들이 나와서 아스드롯 가르나임에서 르바 족속을, 함에서 수스 족속을, 사웨기랴다임에서 엠 족속을 치고","reference":"창세기 14:5","category":"$undefined"},{"id":"343","book":"창세기","book_name":"창세기","chapter":14,"verse":6,"text":"호리 족속을 그 산 세일에서 쳐서 광야 근방 엘바란까지 이르렀으며","reference":"창세기 14:6","category":"$undefined"},{"id":"344","book":"창세기","book_name":"창세기","chapter":14,"verse":7,"text":"그들이 돌이켜 엔미스밧 곧 가데스에 이르러 아말렉 족속의 온 땅과 하사손다말에 사는 아모리 족속을 친지라","reference":"창세기 14:7","category":"$undefined"},{"id":"345","book":"창세기","book_name":"창세기","chapter":14,"verse":8,"text":"소돔 왕과, 고모라 왕과, 아드마 왕과, 스보임 왕과, 벨라 곧 소알 왕이 나와서 싯딤 골짜기에서 그들과 접전하였으니","reference":"창세기 14:8","category":"$undefined"},{"id":"346","book":"창세기","book_name":"창세기","chapter":14,"verse":9,"text":"곧 그 다섯 왕이 엘람 왕 그돌라오멜과, 고임 왕 디달과, 시날 왕 아므라벨과, 엘라살 왕 아리옥 네 왕과 교전하였더라","reference":"창세기 14:9","category":"$undefined"},{"id":"347","book":"창세기","book_name":"창세기","chapter":14,"verse":10,"text":"싯딤 골짜기에는 역청 구덩이가 많은지라 소돔 왕과 고모라 왕이 달아날 때에 군사가 거기 빠지고 그 나머지는 산으로 도망하매","reference":"창세기 14:10","category":"$undefined"},{"id":"348","book":"창세기","book_name":"창세기","chapter":14,"verse":11,"text":"네 왕이 소돔과 고모라의 모든 재물과 양식을 빼앗아 가고","reference":"창세기 14:11","category":"$undefined"},{"id":"349","book":"창세기","book_name":"창세기","chapter":14,"verse":12,"text":"소돔에 거하는 아브람의 조카 롯도 사로잡고 그 재물까지 노략하여 갔더라","reference":"창세기 14:12","category":"$undefined"},{"id":"350","book":"창세기","book_name":"창세기","chapter":14,"verse":13,"text":"도망한 자가 와서 히브리 사람 아브람에게 고하니 때에 아브람이 아모리 족속 마므레의 상수리 수풀 근처에 거하였더라 마므레는 에스골의 형제요 또 아넬의 형제라 이들은 아브람과 동맹한 자더라","reference":"창세기 14:13","category":"$undefined"},{"id":"351","book":"창세기","book_name":"창세기","chapter":14,"verse":14,"text":"아브람이 그 조카의 사로 잡혔음을 듣고 집에서 길리고 연습한 자 삼백 십 팔인을 거느리고 단까지 쫓아가서","reference":"창세기 14:14","category":"$undefined"},{"id":"352","book":"창세기","book_name":"창세기","chapter":14,"verse":15,"text":"그 가신을 나누어 밤을 타서 그들을 쳐서 파하고 다메섹 좌편 호바까지 쫓아가서","reference":"창세기 14:15","category":"$undefined"},{"id":"353","book":"창세기","book_name":"창세기","chapter":14,"verse":16,"text":"모든 빼앗겼던 재물과 자기 조카 롯과 그 재물과 또 부녀와 인민을 다 찾아 왔더라","reference":"창세기 14:16","category":"$undefined"},{"id":"354","book":"창세기","book_name":"창세기","chapter":14,"verse":17,"text":"아브람이 그돌라오멜과 그와 함께 한 왕들을 파하고 돌아올때에 소돔 왕이 사웨 골짜기 곧 왕곡에 나와 그를 영접하였고","reference":"창세기 14:17","category":"$undefined"},{"id":"355","book":"창세기","book_name":"창세기","chapter":14,"verse":18,"text":"살렘 왕 멜기세덱이 떡과 포도주를 가지고 나왔으니 그는 지극히 높으신 하나님의 제사장이었더라","reference":"창세기 14:18","category":"$undefined"},{"id":"356","book":"창세기","book_name":"창세기","chapter":14,"verse":19,"text":"그가 아브람에게 축복하여 가로되 `천지의 주재시요, 지극히 높으신 하나님이여 아브람에게 복을 주옵소서 !","reference":"창세기 14:19","category":"$undefined"},{"id":"357","book":"창세기","book_name":"창세기","chapter":14,"verse":20,"text":"너희 대적을 네 손에 붙이신 지극히 높으신 하나님을 찬송할지로다 !' 하매 아브람이 그 얻은 것에서 십분 일을 멜기세덱에게 주었더라","reference":"창세기 14:20","category":"$undefined"},{"id":"358","book":"창세기","book_name":"창세기","chapter":14,"verse":21,"text":"소돔 왕이 아브람에게 이르되 `사람은 내게 보내고 물품은 네가 취하라'","reference":"창세기 14:21","category":"$undefined"},{"id":"359","book":"창세기","book_name":"창세기","chapter":14,"verse":22,"text":"아브람이 소돔 왕에게 이르되 `천지의 주재시요 지극히 높으신 하나님 여호와께 내가 손을 들어 맹세하노니","reference":"창세기 14:22","category":"$undefined"},{"id":"360","book":"창세기","book_name":"창세기","chapter":14,"verse":23,"text":"네 말이 내가 아브람으로 치부케 하였다 할까 하여 네게 속한 것은 무론 한 실이나 신들메라도 내가 취하지 아니하리라","reference":"창세기 14:23","category":"$undefined"},{"id":"361","book":"창세기","book_name":"창세기","chapter":14,"verse":24,"text":"오직 소년들의 먹은 것과 나와 동행한 아넬과 에스골과 마므레의 분깃을 제할지니 그들이 그 분깃을 취할 것이니라'","reference":"창세기 14:24","category":"$undefined"}],"bookSlug":"genesis"}]
