2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":16,"verses":[{"id":"383","book":"창세기","book_name":"창세기","chapter":16,"verse":1,"text":"아브람의 아내 사래는 생산치 못하였고 그에게 한 여종이 있으니 애굽 사람이요 이름은 하갈이라","reference":"창세기 16:1","category":"$undefined"},{"id":"384","book":"창세기","book_name":"창세기","chapter":16,"verse":2,"text":"사래가 아브람에게 이르되 `여호와께서 나의 생산을 허락지 아니하셨으니 원컨대 나의 여종과 동침하라 내가 혹 그로 말미암아 자녀를 얻을까 하노라' 하매 아브람이 사래의 말을 들으니라","reference":"창세기 16:2","category":"$undefined"},{"id":"385","book":"창세기","book_name":"창세기","chapter":16,"verse":3,"text":"아브람의 아내 사래가 그 여종 애굽 사람 하갈을 가져 그 남편 아브람에게 첩으로 준 때는 아브람이 가나안 땅에 거한지 십년 후이었더라","reference":"창세기 16:3","category":"$undefined"},{"id":"386","book":"창세기","book_name":"창세기","chapter":16,"verse":4,"text":"아브람이 하갈과 동침하였더니 하갈이 잉태하매 그가 자기의 잉태함을 깨닫고 그 여주인을 멸시한지라","reference":"창세기 16:4","category":"$undefined"},{"id":"387","book":"창세기","book_name":"창세기","chapter":16,"verse":5,"text":"사래가 아브람에게 이르되 `나의 받는 욕은 당신이 받아야 옳도다 내가 나의 여종을 당신의 품에 두었거늘 그가 자기의 잉태함을 깨닫고 나를 멸시하니 당신과 나 사이에 여호와께서 판단하시기를 원하노라'","reference":"창세기 16:5","category":"$undefined"},{"id":"388","book":"창세기","book_name":"창세기","chapter":16,"verse":6,"text":"아브람이 사래에게 이르되 `그대의 여종은 그대의 수중에 있으니 그대의 눈에 좋은대로 그에게 행하라' 하매 사래가 하갈을 학대하였더니 하갈이 사래의 앞에서 도망하였더라","reference":"창세기 16:6","category":"$undefined"},{"id":"389","book":"창세기","book_name":"창세기","chapter":16,"verse":7,"text":"여호와의 사자가 광야의 샘 곁 곧 술 길 샘물 곁에서 그를 만나","reference":"창세기 16:7","category":"$undefined"},{"id":"390","book":"창세기","book_name":"창세기","chapter":16,"verse":8,"text":"가로되 `사래의 여종 하갈아 네가 어디서 왔으며 어디로 가느냐 ?' 그가 가로되 `나는 나의 여주인 사래를 피하여 도망하나이다'","reference":"창세기 16:8","category":"$undefined"},{"id":"391","book":"창세기","book_name":"창세기","chapter":16,"verse":9,"text":"여호와의 사자가 그에게 이르되 네 여주인에게로 돌아가서 그 수하에 복종하라","reference":"창세기 16:9","category":"$undefined"},{"id":"392","book":"창세기","book_name":"창세기","chapter":16,"verse":10,"text":"여호와의 사자가 또 그에게 이르되 `내가 네 자손으로 크게 번성하여 그 수가 많아 셀 수 없게 하리라","reference":"창세기 16:10","category":"$undefined"},{"id":"393","book":"창세기","book_name":"창세기","chapter":16,"verse":11,"text":"여호와의 사자가 또 그에게 이르되 네가 잉태하였은즉 아들을 낳으리니 그 이름을 이스마엘이라 하라 이는 여호와께서 네 고통을 들으셨음이니라","reference":"창세기 16:11","category":"$undefined"},{"id":"394","book":"창세기","book_name":"창세기","chapter":16,"verse":12,"text":"그가 사람 중에 들나귀 같이 되리니 그 손이 모든 사람을 치겠고 모든 사람의 손이 그를 칠지며 그가 모든 형제의 동방에서 살리라' 하니라","reference":"창세기 16:12","category":"$undefined"},{"id":"395","book":"창세기","book_name":"창세기","chapter":16,"verse":13,"text":"하갈이 자기에게 이르신 여호와의 이름을 감찰하시는 하나님이라 하였으니 이는 `내가 어떻게 여기서 나를 감찰하시는 하나님을 뵈었는고' 함이라","reference":"창세기 16:13","category":"$undefined"},{"id":"396","book":"창세기","book_name":"창세기","chapter":16,"verse":14,"text":"이러므로 그 샘을 브엘라해로이라 불렀으며 그것이 가데스와 베렛 사이에 있더라","reference":"창세기 16:14","category":"$undefined"},{"id":"397","book":"창세기","book_name":"창세기","chapter":16,"verse":15,"text":"하갈이 아브람의 아들을 낳으매 아브람이 하갈의 낳은 그 아들을 이름하여 이스마엘이라 하였더라","reference":"창세기 16:15","category":"$undefined"},{"id":"398","book":"창세기","book_name":"창세기","chapter":16,"verse":16,"text":"하갈이 아브람에게 이스마엘을 낳을 때에 아브람이 팔십 육세이었더라","reference":"창세기 16:16","category":"$undefined"}],"bookSlug":"genesis"}]
