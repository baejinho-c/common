11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":24,"verses":[{"id":"593","book":"창세기","book_name":"창세기","chapter":24,"verse":1,"text":"아브라함이 나이 많아 늙었고 여호와께서 그의 범사에 복을 주셨더라","reference":"창세기 24:1","category":"$undefined"},{"id":"594","book":"창세기","book_name":"창세기","chapter":24,"verse":2,"text":"아브라함이 자기 집 모든 소유를 맡은 늙은 종에게 이르되 `청컨대 네 손을 내 환도뼈 밑에 넣으라","reference":"창세기 24:2","category":"$undefined"},{"id":"595","book":"창세기","book_name":"창세기","chapter":24,"verse":3,"text":"내가 너로 하늘의 하나님, 땅의 하나님이신 여호와를 가리켜 맹세하게 하노니 너는 나의 거하는 이 지방 가나안 족속의 딸 중에서 내 아들을 위하여 아내를 택하지 말고","reference":"창세기 24:3","category":"$undefined"},{"id":"596","book":"창세기","book_name":"창세기","chapter":24,"verse":4,"text":"내 고향 내 족속에게로 가서 내 아들 이삭을 위하여 아내를 택하라'","reference":"창세기 24:4","category":"$undefined"},{"id":"597","book":"창세기","book_name":"창세기","chapter":24,"verse":5,"text":"종이 가로되 `여자가 나를 좇아 이 땅으로 오고자 아니하거든 내가 주인의 아들을 주인의 나오신 땅으로 인도하여 돌아가리이까 ?'","reference":"창세기 24:5","category":"$undefined"},{"id":"598","book":"창세기","book_name":"창세기","chapter":24,"verse":6,"text":"아브라함이 그에게 이르되 `삼가 내 아들을 그리로 데리고 돌아가지 말라","reference":"창세기 24:6","category":"$undefined"},{"id":"599","book":"창세기","book_name":"창세기","chapter":24,"verse":7,"text":"하늘의 하나님 여호와께서 나를 내 아버지의 집과 내 본토에서 떠나게 하시고 내게 말씀하시며 내게 맹세하여 이르시기를 이 땅을 네 씨에게 주리라 하셨으니 그가 그 사자를 네 앞서 보내실지라 네가 거기서 내 아들을 위하여 아내를 택할지니라","reference":"창세기 24:7","category":"$undefined"},{"id":"600","book":"창세기","book_name":"창세기","chapter":24,"verse":8,"text":"만일 여자가 너를 좇아 오고자 아니하면 나의 이 맹세가 너와 상관이 없나니 오직 내 아들을 데리고 그리로 가지 말지니라'","reference":"창세기 24:8","category":"$undefined"},{"id":"601","book":"창세기","book_name":"창세기","chapter":24,"verse":9,"text":"종이 이에 주인 아브라함의 환도뼈 아래 손을 넣고 이 일에 대하여 그에게 맹세하였더라","reference":"창세기 24:9","category":"$undefined"},{"id":"602","book":"창세기","book_name":"창세기","chapter":24,"verse":10,"text":"이에 종이 그 주인의 약대 중 열 필을 취하고 떠났는데 곧 그 주인의 모든 좋은 것을 가지고 떠나 메소보다미아로 가서 나홀의 성에 이르러","reference":"창세기 24:10","category":"$undefined"},{"id":"603","book":"창세기","book_name":"창세기","chapter":24,"verse":11,"text":"그 약대를 성 밖 우물 곁에 꿇렸으니 저녁 때라 여인들이 물을 길러 나올 때이었더라","reference":"창세기 24:11","category":"$undefined"},{"id":"604","book":"창세기","book_name":"창세기","chapter":24,"verse":12,"text":"그가 가로되 `우리 주인 아브라함의 하나님 여호와여 ! 원컨대 오늘날 나로 순적히 만나게 하사 나의 주인 아브라함에게 은혜를 베푸시옵소서 !","reference":"창세기 24:12","category":"$undefined"},{"id":"605","book":"창세기","book_name":"창세기","chapter":24,"verse":13,"text":"성 중 사람의 딸들이 물 길러 나오겠사오니 내가 우물 곁에 섰다가","reference":"창세기 24:13","category":"$undefined"},{"id":"606","book":"창세기","book_name":"창세기","chapter":24,"verse":14,"text":"한 소녀에게 이르기를 청컨대 너는 물 항아리를 기울여 나로 마시게 하라 하리니 그의 대답이 마시라 내가 당신의 약대에게도 마시우리라 하면 그는 주께서 주의 종 이삭을 위하여 정하신 자라 이로 인하여 주께서 나의 주인에게 은혜 베푸심을 내가 알겠나이다'","reference":"창세기 24:14","category":"$undefined"},{"id":"607","book":"창세기","book_name":"창세기","chapter":24,"verse":15,"text":"말을 마치지 못하여서 리브가가 물 항아리를 어깨에 메고 나오니 그는 아브라함의 동생 나홀의 아내 밀가의 아들 브두엘의 소생이라","reference":"창세기 24:15","category":"$undefined"},{"id":"608","book":"창세기","book_name":"창세기","chapter":24,"verse":16,"text":"그 소녀는 보기에 심히 아리땁고 지금까지 남자가 가까이 하지 아니한 처녀더라 그가 우물에 내려가서 물을 그 물 항아리에 채워 가지고 올라오는지라","reference":"창세기 24:16","category":"$undefined"},{"id":"609","book":"창세기","book_name":"창세기","chapter":24,"verse":17,"text":"종이 마주 달려가서 가로되 `청컨대 네 물 항아리의 물을 내게 조금 마시우라'","reference":"창세기 24:17","category":"$undefined"},{"id":"610","book":"창세기","book_name":"창세기","chapter":24,"verse":18,"text":"그가 가로되 `주여, 마시소서' 하며 급히 그 물 항아리를 손에 내려 마시게 하고","reference":"창세기 24:18","category":"$undefined"},{"id":"611","book":"창세기","book_name":"창세기","chapter":24,"verse":19,"text":"마시우기를 다하고 가로되 `당신의 약대도 위하여 물을 길어 그것들로 배불리 마시게 하리이다' 하고","reference":"창세기 24:19","category":"$undefined"},{"id":"612","book":"창세기","book_name":"창세기","chapter":24,"verse":20,"text":"급히 물 항아리의 물을 구유에 붓고 다시 길으려고 우물로 달려가서 모든 약대를 위하여 긷는지라","reference":"창세기 24:20","category":"$undefined"},{"id":"613","book":"창세기","book_name":"창세기","chapter":24,"verse":21,"text":"그 사람이 그를 묵묵히 주목하며 여호와께서 과연 평탄한 길을 주신 여부를 알고자 하더니","reference":"창세기 24:21","category":"$undefined"},{"id":"614","book":"창세기","book_name":"창세기","chapter":24,"verse":22,"text":"약대가 마시기를 다하매 그가 반 세겔중 금고리 한개와, 열 세겔중 금 손목고리 한 쌍을 그에게 주며","reference":"창세기 24:22","category":"$undefined"},{"id":"615","book":"창세기","book_name":"창세기","chapter":24,"verse":23,"text":"가로되 `네가 뉘 딸이냐 ? 청컨대 내게 고하라 네 부친의 집에 우리 유숙할 곳이 있느냐 ?'","reference":"창세기 24:23","category":"$undefined"},{"id":"616","book":"창세기","book_name":"창세기","chapter":24,"verse":24,"text":"그 여자가 그에게 이르되 `나는 밀가가 나홀에게 낳은 아들 브두엘의 딸이니이다'","reference":"창세기 24:24","category":"$undefined"},{"id":"617","book":"창세기","book_name":"창세기","chapter":24,"verse":25,"text":"또 가로되 `우리에게 짚과 보리가 족하며 유숙할 곳도 있나이다'","reference":"창세기 24:25","category":"$undefined"},{"id":"618","book":"창세기","book_name":"창세기","chapter":24,"verse":26,"text":"이에 그 사람이 머리를 숙여 여호와께 경배하고","reference":"창세기 24:26","category":"$undefined"},{"id":"619","book":"창세기","book_name":"창세기","chapter":24,"verse":27,"text":"가로되 `나의 주인 아브라함의 하나님 여호와를 찬송하나이다 ! 나의 주인에게 주의 인자와 성실을 끊이지 아니하셨사오며 여호와께서 길에서 나를 인도하사 내 주인의 동생집에 이르게 하셨나이다' 하니라","reference":"창세기 24:27","category":"$undefined"},{"id":"620","book":"창세기","book_name":"창세기","chapter":24,"verse":28,"text":"소녀가 달려가서 이 일을 어미 집에 고하였더니","reference":"창세기 24:28","category":"$undefined"},{"id":"621","book":"창세기","book_name":"창세기","chapter":24,"verse":29,"text":"리브가에게 오라비가 있어 이름은 라반이라 그가 우물로 달려가 그 사람에게 이르니","reference":"창세기 24:29","category":"$undefined"},{"id":"622","book":"창세기","book_name":"창세기","chapter":24,"verse":30,"text":"그가 그 누이의 고리와 그 손의 손목고리를 보고 또 그 누이 리브가가 그 사람이 자기에게 이같이 말하더라 함을 듣고 그 사람에게로 나아감이라 때에 그가 우물가 약대 곁에 섰더라","reference":"창세기 24:30","category":"$undefined"},{"id":"623","book":"창세기","book_name":"창세기","chapter":24,"verse":31,"text":"라반이 가로되 `여호와께 복을 받은 자여 ! 들어오소서 어찌 밖에 섰나이까 ? 내가 방과 약대의 처소를 예비하였나이다'","reference":"창세기 24:31","category":"$undefined"},{"id":"624","book":"창세기","book_name":"창세기","chapter":24,"verse":32,"text":"그 사람이 집으로 들어가매 라반이 약대의 짐을 부리고 짚과 보리를 약대에게 주고 그 사람의 발과 그 종자의 발 씻을 물을 주고","reference":"창세기 24:32","category":"$undefined"},{"id":"625","book":"창세기","book_name":"창세기","chapter":24,"verse":33,"text":"그 앞에 식물을 베푸니 그 사람이 가로되 `내가 내 일을 진술하기 전에는 먹지 아니하겠나이다' 라반이 가로되 `말하소서'","reference":"창세기 24:33","category":"$undefined"},{"id":"626","book":"창세기","book_name":"창세기","chapter":24,"verse":34,"text":"그가 가로되 `나는 아브라함의 종이니이다","reference":"창세기 24:34","category":"$undefined"},{"id":"627","book":"창세기","book_name":"창세기","chapter":24,"verse":35,"text":"여호와께서 나의 주인에게 크게 복을 주어 창성케 하시되 우양과, 은,금과, 노비와, 약대와, 나귀를 그에게 주셨고","reference":"창세기 24:35","category":"$undefined"},{"id":"628","book":"창세기","book_name":"창세기","chapter":24,"verse":36,"text":"나의 주인의 부인 사라가 노년에 나의 주인에게 아들을 낳으매 주인이 그 모든 소유를 그 아들에게 주었나이다","reference":"창세기 24:36","category":"$undefined"},{"id":"629","book":"창세기","book_name":"창세기","chapter":24,"verse":37,"text":"나의 주인이 나로 맹세하게 하여 가로되 너는 내 아들을 위하여 나 사는 땅 가나안 족속의 딸 중에서 아내를 택하지 말고","reference":"창세기 24:37","category":"$undefined"},{"id":"630","book":"창세기","book_name":"창세기","chapter":24,"verse":38,"text":"내 아비 집 내 족속에게로 가서 내 아들을 위하여 아내를 택하라 하시기로","reference":"창세기 24:38","category":"$undefined"},{"id":"631","book":"창세기","book_name":"창세기","chapter":24,"verse":39,"text":"내가 내 주인에게 말씀하되 혹 여자가 나를 좇지 아니하면 어찌 하리이까 ? 한즉","reference":"창세기 24:39","category":"$undefined"},{"id":"632","book":"창세기","book_name":"창세기","chapter":24,"verse":40,"text":"주인이 내게 이르되 나의 섬기는 여호와께서 그 사자를 너와 함께 보내어 네게 평탄한 길을 주시리니 너는 내 족속 중 내 아비 집에서 내 아들을 위하여 아내를 택할 것이니라","reference":"창세기 24:40","category":"$undefined"},{"id":"633","book":"창세기","book_name":"창세기","chapter":24,"verse":41,"text":"네가 내 족속에게 이를 때에는 네가 내 맹세와 상관이 없으리라 설혹 그들이 네게 주지 아니할지라도 네가 내 맹세와 상관이 없으리라 하시기로","reference":"창세기 24:41","category":"$undefined"},{"id":"634","book":"창세기","book_name":"창세기","chapter":24,"verse":42,"text":"내가 오늘 우물에 이르러 말씀하기를 나의 주인 아브라함의 하나님 여호와여, 만일 나의 행하는 길에 형통함을 주실진대","reference":"창세기 24:42","category":"$undefined"},{"id":"635","book":"창세기","book_name":"창세기","chapter":24,"verse":43,"text":"내가 이 우물 곁에 섰다가 청년 여자가 물을 길러 오거든 내가 그에게 청하기를 너는 물 항아리의 물을 내게 조금 마시우라 하여","reference":"창세기 24:43","category":"$undefined"},{"id":"636","book":"창세기","book_name":"창세기","chapter":24,"verse":44,"text":"그의 대답이 당신은 마시라 내가 또 당신의 약대를 위하여도 길으리라 하면 그 여자는 여호와께서 나의 주인의 아들을 위하여 정하여 주신 자가 되리이다 하며","reference":"창세기 24:44","category":"$undefined"},{"id":"637","book":"창세기","book_name":"창세기","chapter":24,"verse":45,"text":"내가 묵도하기를 마치지 못하여 리브가가 물 항아리를 어깨에 메고 나와서 우물로 내려와 긷기로 내가 그에게 이르기를 청컨대 내게 마시우라 한즉","reference":"창세기 24:45","category":"$undefined"},{"id":"638","book":"창세기","book_name":"창세기","chapter":24,"verse":46,"text":"그가 급히 물 항아리를 어깨에서 내리며 가로되 마시라 내가 당신의 약대에게도 마시우리라 하기로 내가 마시매 그가 또 약대에게도 마시운지라","reference":"창세기 24:46","category":"$undefined"},{"id":"639","book":"창세기","book_name":"창세기","chapter":24,"verse":47,"text":"내가 그에게 묻기를 네가 뉘 딸이뇨? 한즉 가로되 밀가가 나홀에게 낳은 브두엘의 딸이라 하기로 내가 고리를 그 코에 꿰고 손목고리를 그 손에 끼우고","reference":"창세기 24:47","category":"$undefined"},{"id":"640","book":"창세기","book_name":"창세기","chapter":24,"verse":48,"text":"나의 주인 아브라함의 하나님 여호와께서 나를 바른 길로 인도하사 나의 주인의 동생의 딸을 그 아들을 위하여 택하게 하셨으므로 내가 머리를 숙여 그에게 경배하고 찬송하였나이다 !","reference":"창세기 24:48","category":"$undefined"},{"id":"641","book":"창세기","book_name":"창세기","chapter":24,"verse":49,"text":"이제 당신들이 인자와 진실로 나의 주인을 대접하려거든 내게 고하시고 그렇지 않을지라도 내게 고하여 나로 좌우간 행하게 하소서'","reference":"창세기 24:49","category":"$undefined"},{"id":"642","book":"창세기","book_name":"창세기","chapter":24,"verse":50,"text":"라반과 브두엘이 대답하여 가로되 `이 일이 여호와께로 말미암았으니 우리는 가부를 말할 수 없노라","reference":"창세기 24:50","category":"$undefined"},{"id":"643","book":"창세기","book_name":"창세기","chapter":24,"verse":51,"text":"리브가가 그대 앞에 있으니 데리고 가서 여호와의 명대로 그로 그대의 주인의 아들의 아내가 되게 하라'","reference":"창세기 24:51","category":"$undefined"},{"id":"644","book":"창세기","book_name":"창세기","chapter":24,"verse":52,"text":"아브라함의 종이 그들의 말을 듣고 땅에 엎드리어 여호와께 절하고","reference":"창세기 24:52","category":"$undefined"},{"id":"645","book":"창세기","book_name":"창세기","chapter":24,"verse":53,"text":"은,금 패물과 의복을 꺼내어 리브가에게 주고 그 오라비와 어미에게도 보물을 주니라","reference":"창세기 24:53","category":"$undefined"},{"id":"646","book":"창세기","book_name":"창세기","chapter":24,"verse":54,"text":"이에 그들 곧 종과 종자들이 먹고 마시고 유숙하고 아침에 일어나서 그가 가로되 `나를 보내어 내 주인에게로 돌아가게 하소서'","reference":"창세기 24:54","category":"$undefined"},{"id":"647","book":"창세기","book_name":"창세기","chapter":24,"verse":55,"text":"리브가의 오라비와 그 어미가 가로되 `소녀로 며칠을 적어도 열흘을 우리와 함께 있게 하라 그 후에 그가 갈 것이니라'","reference":"창세기 24:55","category":"$undefined"},{"id":"648","book":"창세기","book_name":"창세기","chapter":24,"verse":56,"text":"그 사람이 그들에게 이르되 `나를 만류치 마소서 여호와께서 내게 형통한 길을 주셨으니 나를 보내어 내 주인에게로 돌아가게 하소서'","reference":"창세기 24:56","category":"$undefined"},{"id":"649","book":"창세기","book_name":"창세기","chapter":24,"verse":57,"text":"그들이 가로되 `우리가 소녀를 불러 그에게 물으리라` 하고","reference":"창세기 24:57","category":"$undefined"},{"id":"650","book":"창세기","book_name":"창세기","chapter":24,"verse":58,"text":"리브가를 불러 그에게 이르되 `네가 이 사람과 함께 가려느냐 ?` 그가 대답하되 `가겠나이다'","reference":"창세기 24:58","category":"$undefined"},{"id":"651","book":"창세기","book_name":"창세기","chapter":24,"verse":59,"text":"그들이 그 누이 리브가와 그의 유모와 아브라함의 종과 종자들을 보내며","reference":"창세기 24:59","category":"$undefined"},{"id":"652","book":"창세기","book_name":"창세기","chapter":24,"verse":60,"text":"리브가에게 축복하여 가로되 `우리 누이여, 너는 천만인의 어미가 될지어다 ! 네 씨로 그 원수의 성문을 얻게 할지어다'","reference":"창세기 24:60","category":"$undefined"},{"id":"653","book":"창세기","book_name":"창세기","chapter":24,"verse":61,"text":"리브가가 일어나 비자와 함께 약대를 타고 그 사람을 따라가니 종이 리브가를 데리고 가니라","reference":"창세기 24:61","category":"$undefined"},{"id":"654","book":"창세기","book_name":"창세기","chapter":24,"verse":62,"text":"때에 이삭이 브엘 라해로이에서 왔으니 그가 남방에 거하였었음이라","reference":"창세기 24:62","category":"$undefined"},{"id":"655","book":"창세기","book_name":"창세기","chapter":24,"verse":63,"text":"이삭이 저물 때에 들에 나가 묵상하다가 눈을 들어 보매 약대들이 오더라","reference":"창세기 24:63","category":"$undefined"},{"id":"656","book":"창세기","book_name":"창세기","chapter":24,"verse":64,"text":"리브가가 눈을 들어 이삭을 바라보고 약대에서 내려","reference":"창세기 24:64","category":"$undefined"},{"id":"657","book":"창세기","book_name":"창세기","chapter":24,"verse":65,"text":"종에게 말하되 `들에서 배회하다가 우리에게로 마주 오는 자가 누구뇨 ?' 종이 가로되 `이는 내 주인이니이다' 리브가가 면박을 취하여 스스로 가리우더라","reference":"창세기 24:65","category":"$undefined"},{"id":"658","book":"창세기","book_name":"창세기","chapter":24,"verse":66,"text":"종이 그 행한 일을 다 이삭에게 고하매","reference":"창세기 24:66","category":"$undefined"},{"id":"659","book":"창세기","book_name":"창세기","chapter":24,"verse":67,"text":"이삭이 리브가를 인도하여 모친 사라의 장막으로 들이고 그를 취하여 아내를 삼고 사랑하였으니 이삭이 모친 상사 후에 위로를 얻었더라","reference":"창세기 24:67","category":"$undefined"}],"bookSlug":"genesis"}]
