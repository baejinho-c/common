2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":26,"verses":[{"id":"694","book":"창세기","book_name":"창세기","chapter":26,"verse":1,"text":"아브라함 때에 첫 흉년이 들었더니 그 땅에 또 흉년이 들매 이삭이 그랄로 가서 블레셋 왕 아비멜렉에게 이르렀더니","reference":"창세기 26:1","category":"$undefined"},{"id":"695","book":"창세기","book_name":"창세기","chapter":26,"verse":2,"text":"여호와께서 이삭에게 나타나 가라사대 애굽으로 내려가지 말고 내가 네게 지시하는 땅에 거하라","reference":"창세기 26:2","category":"$undefined"},{"id":"696","book":"창세기","book_name":"창세기","chapter":26,"verse":3,"text":"이 땅에 유하면 내가 너와 함께 있어 네게 주고 내가 이 모든 땅을 너와 네 자손에게 주리라 내가 네 아비 아브라함에게 맹세한 것을 이루어","reference":"창세기 26:3","category":"$undefined"},{"id":"697","book":"창세기","book_name":"창세기","chapter":26,"verse":4,"text":"네 자손을 하늘의 별과 같이 번성케 하며 이 모든 땅을 네 자손에게 주리니 네 자손을 인하여 천하 만민이 복을 받으리라","reference":"창세기 26:4","category":"$undefined"},{"id":"698","book":"창세기","book_name":"창세기","chapter":26,"verse":5,"text":"이는 아브라함이 내 말을 순종하고 내 명령과, 내 계명과, 내 율례와, 내 법도를 지켰음이니라 하시니라","reference":"창세기 26:5","category":"$undefined"},{"id":"699","book":"창세기","book_name":"창세기","chapter":26,"verse":6,"text":"이삭이 그랄에 거하였더니","reference":"창세기 26:6","category":"$undefined"},{"id":"700","book":"창세기","book_name":"창세기","chapter":26,"verse":7,"text":"그 곳 사람들이 그 아내를 물으매 그가 말하기를 그는 나의 누이라 하였으니 리브가는 보기에 아리따우므로 그 곳 백성이 리브가로 인하여 자기를 죽일까 하여 그는 나의 아내라 하기를 두려워 함이었더라","reference":"창세기 26:7","category":"$undefined"},{"id":"701","book":"창세기","book_name":"창세기","chapter":26,"verse":8,"text":"이삭이 거기 오래 거하였더니 이삭이 그 아내 리브가를 껴안은 것을 블레셋 왕 아비멜렉이 창으로 내다본지라","reference":"창세기 26:8","category":"$undefined"},{"id":"702","book":"창세기","book_name":"창세기","chapter":26,"verse":9,"text":"이에 아비멜렉이 이삭을 불러 이르되 `그가 정녕 네 아내여늘 어찌 네 누이라 하였느냐 ?' 이삭이 그에게 대답하되 `내 생각에 그를 인하여 내가 죽게 될까 두려워하였음이로라'","reference":"창세기 26:9","category":"$undefined"},{"id":"703","book":"창세기","book_name":"창세기","chapter":26,"verse":10,"text":"아비멜렉이 가로되 `네가 어찌 우리에게 이렇게 행하였느냐 ? 백성 중 하나가 네 아내와 동침하기 쉬웠을뻔 하였은즉 네가 죄를 우리에게 입혔으리라'","reference":"창세기 26:10","category":"$undefined"},{"id":"704","book":"창세기","book_name":"창세기","chapter":26,"verse":11,"text":"아비멜렉이 이에 모든 백성에게 명하여 가로되 `이 사람이나 그 아내에게 범하는 자는 죽이리라' 하였더라","reference":"창세기 26:11","category":"$undefined"},{"id":"705","book":"창세기","book_name":"창세기","chapter":26,"verse":12,"text":"이삭이 그 땅에서 농사하여 그 해에 백배나 얻었고 여호와께서 복을 주시므로","reference":"창세기 26:12","category":"$undefined"},{"id":"706","book":"창세기","book_name":"창세기","chapter":26,"verse":13,"text":"그 사람이 창대하고 왕성하여 마침내 거부가 되어","reference":"창세기 26:13","category":"$undefined"},{"id":"707","book":"창세기","book_name":"창세기","chapter":26,"verse":14,"text":"양과 소가 떼를 이루고 노복이 심히 많으므로 블레셋 사람이 그를 시기하여","reference":"창세기 26:14","category":"$undefined"},{"id":"708","book":"창세기","book_name":"창세기","chapter":26,"verse":15,"text":"그 아비 아브라함 때에 그 아비의 종들이 판 모든 우물을 막고 흙으로 메웠더라","reference":"창세기 26:15","category":"$undefined"},{"id":"709","book":"창세기","book_name":"창세기","chapter":26,"verse":16,"text":"아비멜렉이 이삭에게 이르되 `네가 우리보다 크게 강성한즉 우리를 떠나가라'","reference":"창세기 26:16","category":"$undefined"},{"id":"710","book":"창세기","book_name":"창세기","chapter":26,"verse":17,"text":"이삭이 그곳을 떠나 그랄 골짜기에 장막을 치고 거기 우거하며","reference":"창세기 26:17","category":"$undefined"},{"id":"711","book":"창세기","book_name":"창세기","chapter":26,"verse":18,"text":"그 아비 아브라함 때에 팠던 우물들을 다시 팠으니 이는 아브라함 죽은 후에 블레셋 사람이 그 우물들을 메웠음이라 이삭이 그 우물들의 이름을 그 아비의 부르던 이름으로 불렀더라","reference":"창세기 26:18","category":"$undefined"},{"id":"712","book":"창세기","book_name":"창세기","chapter":26,"verse":19,"text":"이삭의 종들이 골짜기에 파서 샘 근원을 얻었더니","reference":"창세기 26:19","category":"$undefined"},{"id":"713","book":"창세기","book_name":"창세기","chapter":26,"verse":20,"text":"그랄 목자들이 이삭의 목자와 다투어 가로되 `이 물은 우리의 것이라' 하매 이삭이 그 다툼을 인하여 그 우물 이름을 에섹이라 하였으며","reference":"창세기 26:20","category":"$undefined"},{"id":"714","book":"창세기","book_name":"창세기","chapter":26,"verse":21,"text":"또 다른 우물을 팠더니 그들이 또 다투는고로 그 이름을 싯나라 하였으며","reference":"창세기 26:21","category":"$undefined"},{"id":"715","book":"창세기","book_name":"창세기","chapter":26,"verse":22,"text":"이삭이 거기서 옮겨 다른 우물을 팠더니 그들이 다투지 아니하였으므로 그 이름을 르호봇이라 하여 가로되 `이제는 여호와께서 우리의 장소를 넓게 하셨으니 이 땅에서 우리가 번성하리로다' 하였더라","reference":"창세기 26:22","category":"$undefined"},{"id":"716","book":"창세기","book_name":"창세기","chapter":26,"verse":23,"text":"이삭이 거기서부터 브엘세바로 올라갔더니","reference":"창세기 26:23","category":"$undefined"},{"id":"717","book":"창세기","book_name":"창세기","chapter":26,"verse":24,"text":"그 밤에 여호와께서 그에게 나타나 가라사대 나는 네 아비 아브라함의 하나님이니 두려워 말라! 내 종 아브라함을 위하여 내가 너와 함께 있어 네게 복을 주어 네 자손으로 번성케 하리라 하신지라","reference":"창세기 26:24","category":"$undefined"},{"id":"718","book":"창세기","book_name":"창세기","chapter":26,"verse":25,"text":"이삭이 그 곳에 단을 쌓아 여호와의 이름을 부르고 거기 장막을 쳤더니 그 종들이 거기서도 우물을 팠더라","reference":"창세기 26:25","category":"$undefined"},{"id":"719","book":"창세기","book_name":"창세기","chapter":26,"verse":26,"text":"아비멜렉이 그 친구 아훗삿과 군대장관 비골로 더불어 그랄에서부터 이삭에게로 온지라","reference":"창세기 26:26","category":"$undefined"},{"id":"720","book":"창세기","book_name":"창세기","chapter":26,"verse":27,"text":"이삭이 그들에게 이르되 `너희가 나를 미워하여 나로 너희를 떠나가게 하였거늘 어찌하여 내게 왔느냐 ?'","reference":"창세기 26:27","category":"$undefined"},{"id":"721","book":"창세기","book_name":"창세기","chapter":26,"verse":28,"text":"그들이 가로되 `여호와께서 너와 함께 계심을 우리가 분명히 보았으므로 우리의 사이 곧 우리와 너의 사이에 맹세를 세워 너와 계약을 맺으리라 말하였노라","reference":"창세기 26:28","category":"$undefined"},{"id":"722","book":"창세기","book_name":"창세기","chapter":26,"verse":29,"text":"너는 우리를 해하지 말라 이는 우리가 너를 범하지 아니하고 선한 일만 네게 행하며 너로 평안히 가게 하였음이니라 이제 너는 여호와께 복을 받은 자니라 !'","reference":"창세기 26:29","category":"$undefined"},{"id":"723","book":"창세기","book_name":"창세기","chapter":26,"verse":30,"text":"이삭이 그들을 위하여 잔치를 베풀매 그들이 먹고 마시고","reference":"창세기 26:30","category":"$undefined"},{"id":"724","book":"창세기","book_name":"창세기","chapter":26,"verse":31,"text":"아침에 일찌기 일어나 서로 맹세한 후에 이삭이 그들을 보내매 그들이 평안히 갔더라","reference":"창세기 26:31","category":"$undefined"},{"id":"725","book":"창세기","book_name":"창세기","chapter":26,"verse":32,"text":"그 날에 이삭의 종들이 자기들의 판 우물에 대하여 이삭에게 와서 고하여 가로되 `우리가 물을 얻었나이다' 하매","reference":"창세기 26:32","category":"$undefined"},{"id":"726","book":"창세기","book_name":"창세기","chapter":26,"verse":33,"text":"그가 그 이름을 세바라 한지라 그러므로 그 성읍 이름이 오늘까지 브엘세바더라","reference":"창세기 26:33","category":"$undefined"},{"id":"727","book":"창세기","book_name":"창세기","chapter":26,"verse":34,"text":"에서가 사십세에 헷 족속 브에리의 딸 유딧과, 헷 족속 엘론의 딸 바스맛을 아내로 취하였더니","reference":"창세기 26:34","category":"$undefined"},{"id":"728","book":"창세기","book_name":"창세기","chapter":26,"verse":35,"text":"그들이 이삭과 리브가의 마음의 근심이 되었더라","reference":"창세기 26:35","category":"$undefined"}],"bookSlug":"genesis"}]
