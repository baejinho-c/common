2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":3,"verses":[{"id":"57","book":"창세기","book_name":"창세기","chapter":3,"verse":1,"text":"여호와 하나님의 지으신 들짐승 중에 뱀이 가장 간교하더라 뱀이 여자에게 물어 가로되 `하나님이 참으로 너희더러 동산 모든 나무의 실과를 먹지 말라 하시더냐 ?'","reference":"창세기 3:1","category":"$undefined"},{"id":"58","book":"창세기","book_name":"창세기","chapter":3,"verse":2,"text":"여자가 뱀에게 말하되 `동산 나무의 실과를 우리가 먹을 수 있으나","reference":"창세기 3:2","category":"$undefined"},{"id":"59","book":"창세기","book_name":"창세기","chapter":3,"verse":3,"text":"동산 중앙에 있는 나무의 실과는 하나님의 말씀에 너희는 먹지도 말고 만지지도 말라 너희가 죽을까 하노라 하셨느니라'","reference":"창세기 3:3","category":"$undefined"},{"id":"60","book":"창세기","book_name":"창세기","chapter":3,"verse":4,"text":"뱀이 여자에게 이르되 `너희가 결코 죽지 아니하리라","reference":"창세기 3:4","category":"$undefined"},{"id":"61","book":"창세기","book_name":"창세기","chapter":3,"verse":5,"text":"너희가 그것을 먹는 날에는 너희 눈이 밝아 하나님과 같이 되어 선악을 알 줄을 하나님이 아심이니라'","reference":"창세기 3:5","category":"$undefined"},{"id":"62","book":"창세기","book_name":"창세기","chapter":3,"verse":6,"text":"여자가 그 나무를 본즉 먹음직도 하고, 보암직도 하고, 지혜롭게 할 만큼 탐스럽기도 한 나무인지라 여자가 그 실과를 따먹고 자기와 함께 한 남편에게도 주매 그도 먹은지라","reference":"창세기 3:6","category":"$undefined"},{"id":"63","book":"창세기","book_name":"창세기","chapter":3,"verse":7,"text":"이에 그들의 눈이 밝아 자기들의 몸이 벗은 줄을 알고 무화과나무 잎을 엮어 치마를 하였더라","reference":"창세기 3:7","category":"$undefined"},{"id":"64","book":"창세기","book_name":"창세기","chapter":3,"verse":8,"text":"그들이 날이 서늘할 때에 동산에 거니시는 여호와 하나님의 음성을 듣고 아담과 그 아내가 여호와 하나님의 낯을 피하여 동산 나무 사이에 숨은지라","reference":"창세기 3:8","category":"$undefined"},{"id":"65","book":"창세기","book_name":"창세기","chapter":3,"verse":9,"text":"여호와 하나님이 아담을 부르시며 그에게 이르시되 네가 어디 있느냐 ?","reference":"창세기 3:9","category":"$undefined"},{"id":"66","book":"창세기","book_name":"창세기","chapter":3,"verse":10,"text":"가로되 `내가 동산에서 하나님의 소리를 듣고 내가 벗었으므로 두려워하여 숨었나이다'","reference":"창세기 3:10","category":"$undefined"},{"id":"67","book":"창세기","book_name":"창세기","chapter":3,"verse":11,"text":"가라사대 누가 너의 벗었음을 네게 고하였느냐 ? 내가 너더러 먹지 말라 명한 그 나무 실과를 네가 먹었느냐 ?","reference":"창세기 3:11","category":"$undefined"},{"id":"68","book":"창세기","book_name":"창세기","chapter":3,"verse":12,"text":"아담이 가로되 `하나님이 주셔서 나와 함께하게 하신 여자 그가 그 나무 실과를 내게 주므로 내가 먹었나이다'","reference":"창세기 3:12","category":"$undefined"},{"id":"69","book":"창세기","book_name":"창세기","chapter":3,"verse":13,"text":"여호와 하나님이 여자에게 이르시되 네가 어찌하여 이렇게 하였느냐 ? 여자가 가로되 `뱀이 나를 꾀므로 내가 먹었나이다'","reference":"창세기 3:13","category":"$undefined"},{"id":"70","book":"창세기","book_name":"창세기","chapter":3,"verse":14,"text":"여호와 하나님이 뱀에게 이르시되 네가 이렇게 하였으니 네가 모든 육축과 들의 모든 짐승보다 더욱 저주를 받아 배로 다니고 종신토록 흙을 먹을지니라","reference":"창세기 3:14","category":"$undefined"},{"id":"71","book":"창세기","book_name":"창세기","chapter":3,"verse":15,"text":"내가 너로 여자와 원수가 되게 하고 너의 후손도 여자의 후손과 원수가 되게 하리니 여자의 후손은 네 머리를 상하게 할 것이요 너는 그의 발꿈치를 상하게 할 것이니라 하시고","reference":"창세기 3:15","category":"$undefined"},{"id":"72","book":"창세기","book_name":"창세기","chapter":3,"verse":16,"text":"또 여자에게 이르시되 내가 네게 잉태하는 고통을 크게 더하리니 네가 수고하고 자식을 낳을 것이며 너는 남편을 사모하고 남편은 너를 다스릴 것이니라 하시고","reference":"창세기 3:16","category":"$undefined"},{"id":"73","book":"창세기","book_name":"창세기","chapter":3,"verse":17,"text":"아담에게 이르시되 네가 네 아내의 말을 듣고 내가 너더러 먹지 말라 한 나무 실과를 먹었은즉 땅은 너로 인하여 저주를 받고 너는 종신토록 수고하여야 그 소산을 먹으리라","reference":"창세기 3:17","category":"$undefined"},{"id":"74","book":"창세기","book_name":"창세기","chapter":3,"verse":18,"text":"땅이 네게 가시덤불과 엉겅퀴를 낼 것이라 너의 먹을 것은 밭의 채소인즉","reference":"창세기 3:18","category":"$undefined"},{"id":"75","book":"창세기","book_name":"창세기","chapter":3,"verse":19,"text":"네가 얼굴에 땀이 흘러야 식물을 먹고 필경은 흙으로 돌아가리니 그 속에서 네가 취함을 입었음이라 너는 흙이니 흙으로 돌아 갈 것이니라 하시니라","reference":"창세기 3:19","category":"$undefined"},{"id":"76","book":"창세기","book_name":"창세기","chapter":3,"verse":20,"text":"아담이 그 아내를 하와라 이름하였으니 그는 모든 산 자의 어미가 됨이더라","reference":"창세기 3:20","category":"$undefined"},{"id":"77","book":"창세기","book_name":"창세기","chapter":3,"verse":21,"text":"여호와 하나님이 아담과 그 아내를 위하여 가죽 옷을 지어 입히시니라","reference":"창세기 3:21","category":"$undefined"},{"id":"78","book":"창세기","book_name":"창세기","chapter":3,"verse":22,"text":"여호와 하나님이 가라사대 보라, 이 사람이 선악을 아는 일에 우리 중 하나같이 되었으니 그가 그 손을 들어 생명나무 실과도 먹고 영생할까 하노라 하시고","reference":"창세기 3:22","category":"$undefined"},{"id":"79","book":"창세기","book_name":"창세기","chapter":3,"verse":23,"text":"여호와 하나님이 에덴 동산에서 그 사람을 내어 보내어 그의 근본된 토지를 갈게 하시니라","reference":"창세기 3:23","category":"$undefined"},{"id":"80","book":"창세기","book_name":"창세기","chapter":3,"verse":24,"text":"이같이 하나님이 그 사람을 쫓아 내시고 에덴 동산 동편에 그룹들과 두루 도는 화염검을 두어 생명나무의 길을 지키게 하시니라","reference":"창세기 3:24","category":"$undefined"}],"bookSlug":"genesis"}]
