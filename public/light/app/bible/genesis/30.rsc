2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":30,"verses":[{"id":"832","book":"창세기","book_name":"창세기","chapter":30,"verse":1,"text":"라헬이 자기가 야곱에게 아들을 낳지 못함을 보고 그 형을 투기하여 야곱에게 이르되 `나로 자식을 낳게 하라 그렇지 아니하면 내가 죽겠노라'","reference":"창세기 30:1","category":"$undefined"},{"id":"833","book":"창세기","book_name":"창세기","chapter":30,"verse":2,"text":"야곱이 라헬에게 노를 발하여 가로되 `그대로 성태치 못하게 하시는 이는 하나님이시니 내가 하나님을 대신하겠느냐 ?'","reference":"창세기 30:2","category":"$undefined"},{"id":"834","book":"창세기","book_name":"창세기","chapter":30,"verse":3,"text":"라헬이 가로되 `나의 여종 빌하에게로 들어가라 그가 아들을 낳아 내 무릎에 두리니 그러면 나도 그를 인하여 자식을 얻겠노라' 하고","reference":"창세기 30:3","category":"$undefined"},{"id":"835","book":"창세기","book_name":"창세기","chapter":30,"verse":4,"text":"그 시녀 빌하를 남편에게 첩으로 주매 야곱이 그에게로 들어갔더니","reference":"창세기 30:4","category":"$undefined"},{"id":"836","book":"창세기","book_name":"창세기","chapter":30,"verse":5,"text":"빌하가 잉태하여 야곱에게 아들을 낳은지라","reference":"창세기 30:5","category":"$undefined"},{"id":"837","book":"창세기","book_name":"창세기","chapter":30,"verse":6,"text":"라헬이 가로되 `하나님이 내 억울함을 푸시려고 내 소리를 들으사 내게 아들을 주셨다' 하고 이로 인하여 그 이름을 단이라 하였으며","reference":"창세기 30:6","category":"$undefined"},{"id":"838","book":"창세기","book_name":"창세기","chapter":30,"verse":7,"text":"라헬의 시녀 빌하가 다시 잉태하여 둘째 아들을 야곱에게 낳으매","reference":"창세기 30:7","category":"$undefined"},{"id":"839","book":"창세기","book_name":"창세기","chapter":30,"verse":8,"text":"라헬이 가로되 `내가 형과 크게 경쟁하여 이기었다' 하고 그 이름을 납달리라 하였더라","reference":"창세기 30:8","category":"$undefined"},{"id":"840","book":"창세기","book_name":"창세기","chapter":30,"verse":9,"text":"레아가 자기의 생산이 멈춤을 보고 그 시녀 실바를 취하여 야곱에게 주어 첩을 삼게 하였더니","reference":"창세기 30:9","category":"$undefined"},{"id":"841","book":"창세기","book_name":"창세기","chapter":30,"verse":10,"text":"레아의 시녀 실바가 야곱에게 아들을 낳으매","reference":"창세기 30:10","category":"$undefined"},{"id":"842","book":"창세기","book_name":"창세기","chapter":30,"verse":11,"text":"레아가 가로되 `복되도다' 하고 그 이름을 갓이라 하였으며","reference":"창세기 30:11","category":"$undefined"},{"id":"843","book":"창세기","book_name":"창세기","chapter":30,"verse":12,"text":"레아의 시녀 실바가 둘째 아들을 야곱에게 낳으매","reference":"창세기 30:12","category":"$undefined"},{"id":"844","book":"창세기","book_name":"창세기","chapter":30,"verse":13,"text":"레아가 가로되 `기쁘도다 모든 딸들이 나를 기쁜 자라 하리로다' 하고 그 이름을 아셀이라 하였더라","reference":"창세기 30:13","category":"$undefined"},{"id":"845","book":"창세기","book_name":"창세기","chapter":30,"verse":14,"text":"맥추 때에 르우벤이 나가서 들에서 합환채를 얻어 어미 레아에게 드렸더니 라헬이 레아에게 이르되 `형의 아들의 합환채를 청구하노라'","reference":"창세기 30:14","category":"$undefined"},{"id":"846","book":"창세기","book_name":"창세기","chapter":30,"verse":15,"text":"레아가 그에게 이르되 `네가 내 남편을 빼앗은 것이 작은 일이냐 ? 네가 내 아들의 합환채도 빼앗고자 하느냐 ?' 라헬이 가로되 `그러면 형의 아들의 합환채 대신에 오늘밤에 내 남편이 형과 동침하리라' 하리라","reference":"창세기 30:15","category":"$undefined"},{"id":"847","book":"창세기","book_name":"창세기","chapter":30,"verse":16,"text":"저물 때에 야곱이 들에서 돌아오매 레아가 나와서 그를 영접하며 이르되 `내게로 들어오라 내가 내 아들의 합환채로 당신을 샀노라' 그 밤에 야곱이 그와 동침하였더라","reference":"창세기 30:16","category":"$undefined"},{"id":"848","book":"창세기","book_name":"창세기","chapter":30,"verse":17,"text":"하나님이 레아를 들으셨으므로 그가 잉태하여 다섯째 아들을 야곱에게 낳은지라","reference":"창세기 30:17","category":"$undefined"},{"id":"849","book":"창세기","book_name":"창세기","chapter":30,"verse":18,"text":"레아가 가로되 `내가 내 시녀를 남편에게 주었으므로 하나님이 내게 그 값을 주셨다' 하고 그 이름을 잇사갈이라 하였으며","reference":"창세기 30:18","category":"$undefined"},{"id":"850","book":"창세기","book_name":"창세기","chapter":30,"verse":19,"text":"레아가 다시 잉태하여 여섯째 아들을 야곱에게 낳은지라","reference":"창세기 30:19","category":"$undefined"},{"id":"851","book":"창세기","book_name":"창세기","chapter":30,"verse":20,"text":"레아가 가로되 `하나님이 네게 후한 선물을 주시도다 내가 남편에게 여섯 아들을 낳았으니 이제는 그가 나와 함께 거하리라' 하고 그 이름을 스불론이라 하였으며","reference":"창세기 30:20","category":"$undefined"},{"id":"852","book":"창세기","book_name":"창세기","chapter":30,"verse":21,"text":"그 후에 그가 딸을 낳고 그 이름을 디나라 하였더라","reference":"창세기 30:21","category":"$undefined"},{"id":"853","book":"창세기","book_name":"창세기","chapter":30,"verse":22,"text":"하나님이 라헬을 생각하신지라 하나님이 그를 들으시고 그 태를 여신고로","reference":"창세기 30:22","category":"$undefined"},{"id":"854","book":"창세기","book_name":"창세기","chapter":30,"verse":23,"text":"그가 잉태하여 아들을 낳고 가로되 `하나님이 나의 부끄러움을 씻으셨다' 하고","reference":"창세기 30:23","category":"$undefined"},{"id":"855","book":"창세기","book_name":"창세기","chapter":30,"verse":24,"text":"그 이름을 요셉이라 하니 여호와는 다시 다른 아들을 내게 더하시기를 원하노라 함이었더라","reference":"창세기 30:24","category":"$undefined"},{"id":"856","book":"창세기","book_name":"창세기","chapter":30,"verse":25,"text":"라헬이 요셉을 낳은 때에 야곱이 라반에게 이르되 `나를 보내어 내 고향 내 본토로 가게 하시되","reference":"창세기 30:25","category":"$undefined"},{"id":"857","book":"창세기","book_name":"창세기","chapter":30,"verse":26,"text":"내가 외삼촌에게서 일하고 얻은 처자를 내게 주어 나로 가게 하소서 내가 외삼촌께 한 일은 외삼촌이 아시나이다'","reference":"창세기 30:26","category":"$undefined"},{"id":"858","book":"창세기","book_name":"창세기","chapter":30,"verse":27,"text":"라반이 그에게 이르되 `여호와께서 너로 인하여 내게 복 주신줄을 내가 깨달았노니 네가 나를 사랑스럽게 여기거든 유하라'","reference":"창세기 30:27","category":"$undefined"},{"id":"859","book":"창세기","book_name":"창세기","chapter":30,"verse":28,"text":"또 가로되 `네 품삯을 정하라 내가 그것을 주리라'","reference":"창세기 30:28","category":"$undefined"},{"id":"860","book":"창세기","book_name":"창세기","chapter":30,"verse":29,"text":"야곱이 그에게 이르되 `내가 어떻게 외삼촌을 섬겼는지, 어떻게 외삼촌의 짐승을 쳤는지 외삼촌이 아시나이다","reference":"창세기 30:29","category":"$undefined"},{"id":"861","book":"창세기","book_name":"창세기","chapter":30,"verse":30,"text":"내가 오기 전에는 외삼촌의 소유가 적더니 번성하여 떼를 이루었나이다 나의 공력을 따라 여호와께서 외삼촌에게 복을 주셨나이다 그러나 나는 어느 때에나 내 집을 세우리이까 ?'","reference":"창세기 30:30","category":"$undefined"},{"id":"862","book":"창세기","book_name":"창세기","chapter":30,"verse":31,"text":"라반이 가로되 내가 무엇으로 네게 주랴 야곱이 가로되 외삼촌께서 아무 것도 내게 주실 것이 아니라 나를 위하여 이 일을 행하시면 내가 다시 외삼촌의 양떼를 먹이고 지키리이다","reference":"창세기 30:31","category":"$undefined"},{"id":"863","book":"창세기","book_name":"창세기","chapter":30,"verse":32,"text":"","reference":"창세기 30:32","category":"$undefined"},{"id":"864","book":"창세기","book_name":"창세기","chapter":30,"verse":33,"text":"","reference":"창세기 30:33","category":"$undefined"},{"id":"865","book":"창세기","book_name":"창세기","chapter":30,"verse":34,"text":"","reference":"창세기 30:34","category":"$undefined"},{"id":"866","book":"창세기","book_name":"창세기","chapter":30,"verse":35,"text":"","reference":"창세기 30:35","category":"$undefined"},{"id":"867","book":"창세기","book_name":"창세기","chapter":30,"verse":36,"text":"","reference":"창세기 30:36","category":"$undefined"},{"id":"868","book":"창세기","book_name":"창세기","chapter":30,"verse":37,"text":"","reference":"창세기 30:37","category":"$undefined"},{"id":"869","book":"창세기","book_name":"창세기","chapter":30,"verse":38,"text":"","reference":"창세기 30:38","category":"$undefined"},{"id":"870","book":"창세기","book_name":"창세기","chapter":30,"verse":39,"text":"","reference":"창세기 30:39","category":"$undefined"},{"id":"871","book":"창세기","book_name":"창세기","chapter":30,"verse":40,"text":"","reference":"창세기 30:40","category":"$undefined"},{"id":"872","book":"창세기","book_name":"창세기","chapter":30,"verse":41,"text":"","reference":"창세기 30:41","category":"$undefined"},{"id":"873","book":"창세기","book_name":"창세기","chapter":30,"verse":42,"text":"","reference":"창세기 30:42","category":"$undefined"},{"id":"874","book":"창세기","book_name":"창세기","chapter":30,"verse":43,"text":"","reference":"창세기 30:43","category":"$undefined"}],"bookSlug":"genesis"}]
