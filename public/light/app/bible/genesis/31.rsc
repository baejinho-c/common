2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":31,"verses":[{"id":"875","book":"창세기","book_name":"창세기","chapter":31,"verse":1,"text":"야곱이 들은즉 라반의 아들들의 말이 `야곱이 우리 아버지의 소유를 다 빼앗고 우리 아버지의 소유로 인하여 이같이 거부가 되었다' 하는지라","reference":"창세기 31:1","category":"$undefined"},{"id":"876","book":"창세기","book_name":"창세기","chapter":31,"verse":2,"text":"야곱이 라반의 안색을 본즉 자기에게 대하여 전과 같지 아니하더라","reference":"창세기 31:2","category":"$undefined"},{"id":"877","book":"창세기","book_name":"창세기","chapter":31,"verse":3,"text":"여호와께서 야곱에게 이르시되 네 조상의 땅, 네 족속에게로 돌아가라 내가 너와 함께 있으리라 하신지라","reference":"창세기 31:3","category":"$undefined"},{"id":"878","book":"창세기","book_name":"창세기","chapter":31,"verse":4,"text":"야곱이 보내어 라헬과 레아를 자기 양떼 있는 들로 불러다가","reference":"창세기 31:4","category":"$undefined"},{"id":"879","book":"창세기","book_name":"창세기","chapter":31,"verse":5,"text":"그들에게 이르되 `내가 그대들의 아버지의 안색을 본즉 내게 대하여 전과 같지 아니하도다 그러할지라도 내 아버지의 하나님은 나와 함께 계셨느니라","reference":"창세기 31:5","category":"$undefined"},{"id":"880","book":"창세기","book_name":"창세기","chapter":31,"verse":6,"text":"그대들도 알거니와 내가 힘을 다하여 그대들의 아버지를 섬겼거늘","reference":"창세기 31:6","category":"$undefined"},{"id":"881","book":"창세기","book_name":"창세기","chapter":31,"verse":7,"text":"그대들의 아버지가 나를 속여 품삯을 열번이나 변역하였느니라 그러나 하나님이 그를 금하사 나를 해치 못하게 하셨으며","reference":"창세기 31:7","category":"$undefined"},{"id":"882","book":"창세기","book_name":"창세기","chapter":31,"verse":8,"text":"그가 이르기를 점 있는 것이 네 삯이 되리라 하면 온 양떼의 낳은 것이 점 있는 것이요 또 얼룩무늬 있는 것이 네 삯이 되리라 하면 온 양떼의 낳은 것이 얼룩무늬 있는 것이니","reference":"창세기 31:8","category":"$undefined"},{"id":"883","book":"창세기","book_name":"창세기","chapter":31,"verse":9,"text":"하나님이 이같이 그대들의 아버지의 짐승을 빼앗아 내게 주셨으니라","reference":"창세기 31:9","category":"$undefined"},{"id":"884","book":"창세기","book_name":"창세기","chapter":31,"verse":10,"text":"그 양떼가 새끼 밸 때에 내가 꿈에 눈을 들어 보니 양떼를 탄 수양은 다 얼룩무늬 있는것, 점 있는 것, 아롱진 것이었더라","reference":"창세기 31:10","category":"$undefined"},{"id":"885","book":"창세기","book_name":"창세기","chapter":31,"verse":11,"text":"꿈에 하나님의 사자가 내게 말씀하시기를 야곱아 ! 하기로 내가 대답하기를 여기 있나이다 ! 하매","reference":"창세기 31:11","category":"$undefined"},{"id":"886","book":"창세기","book_name":"창세기","chapter":31,"verse":12,"text":"가라사대 네 눈을 들어 보라 ! 양떼를 탄 수양은 다 얼룩무늬 있는것, 점 있는 것, 아롱진 것이니라 라반이 네게 행한 모든 것을 내가 보았노라","reference":"창세기 31:12","category":"$undefined"},{"id":"887","book":"창세기","book_name":"창세기","chapter":31,"verse":13,"text":"나는 벧엘 하나님이라 ! 네가 거기서 기둥에 기름을 붓고 거기서 내게 서원하였으니 지금 일어나 이곳을 떠나서 네 출생지로 돌아가라 하셨느니라'","reference":"창세기 31:13","category":"$undefined"},{"id":"888","book":"창세기","book_name":"창세기","chapter":31,"verse":14,"text":"라헬과 레아가 그에게 대답하여 가로되 `우리가 우리 아버지 집에서 무슨 분깃이나 유업이나 있으리요","reference":"창세기 31:14","category":"$undefined"},{"id":"889","book":"창세기","book_name":"창세기","chapter":31,"verse":15,"text":"아버지가 우리를 팔고 우리의 돈을 다 먹었으니 아버지가 우리를 외인으로 여기는 것이 아닌가","reference":"창세기 31:15","category":"$undefined"},{"id":"890","book":"창세기","book_name":"창세기","chapter":31,"verse":16,"text":"하나님이 우리 아버지에게서 취하신 재물은 우리와 우리 자식의 것이니 이제 하나님이 당신에게 이르신 일을 다 준행하라'","reference":"창세기 31:16","category":"$undefined"},{"id":"891","book":"창세기","book_name":"창세기","chapter":31,"verse":17,"text":"야곱이 일어나 자식들과 아내들을 약대들에게 태우고","reference":"창세기 31:17","category":"$undefined"},{"id":"892","book":"창세기","book_name":"창세기","chapter":31,"verse":18,"text":"그 얻은 바 모든 짐승과 모든 소유물 곧 그가 밧단아람에서 얻은 짐승을 이끌고 가나안 땅에 있는 그 아비 이삭에게로 가려할새","reference":"창세기 31:18","category":"$undefined"},{"id":"893","book":"창세기","book_name":"창세기","chapter":31,"verse":19,"text":"때에 라반이 양털을 깎으러 갔으므로 라헬은 그 아비의 드라빔을 도적질하고","reference":"창세기 31:19","category":"$undefined"},{"id":"894","book":"창세기","book_name":"창세기","chapter":31,"verse":20,"text":"야곱은 그 거취를 아람 사람 라반에게 고하지 않고 가만히 떠났더라","reference":"창세기 31:20","category":"$undefined"},{"id":"895","book":"창세기","book_name":"창세기","chapter":31,"verse":21,"text":"그가 그 모든 소유를 이끌고 강을 건너 길르앗 산을 향하여 도망한지","reference":"창세기 31:21","category":"$undefined"},{"id":"896","book":"창세기","book_name":"창세기","chapter":31,"verse":22,"text":"삼일만에 야곱의 도망한 것이 라반에게 들린지라","reference":"창세기 31:22","category":"$undefined"},{"id":"897","book":"창세기","book_name":"창세기","chapter":31,"verse":23,"text":"라반이 그 형제를 거느리고 칠일 길을 쫓아가 길르앗산에서 그에게 미쳤더니","reference":"창세기 31:23","category":"$undefined"},{"id":"898","book":"창세기","book_name":"창세기","chapter":31,"verse":24,"text":"밤에 하나님이 아람 사람 라반에게 현몽하여 가라사대 너는 삼가 야곱에게 선악간 말하지 말라 하셨더라","reference":"창세기 31:24","category":"$undefined"},{"id":"899","book":"창세기","book_name":"창세기","chapter":31,"verse":25,"text":"라반이 야곱을 쫓아 미치니 야곱이 산에 장막을 쳤는지라 라반이 그 형제로 더불어 길르앗산에 장막을 치고","reference":"창세기 31:25","category":"$undefined"},{"id":"900","book":"창세기","book_name":"창세기","chapter":31,"verse":26,"text":"라반이 야곱에게 이르되 `네가 내게 알리지 아니하고 가만히 내 딸들을 칼로 잡은 자 같이 끌고 갔으니 어찌 이같이 하였느냐 ?","reference":"창세기 31:26","category":"$undefined"},{"id":"901","book":"창세기","book_name":"창세기","chapter":31,"verse":27,"text":"내가 즐거움과, 노래와, 북과, 수금으로 너를 보내겠거늘 어찌하여 네가 나를 속이고 가만히 도망하고 내게 고하지 아니하였으며","reference":"창세기 31:27","category":"$undefined"},{"id":"902","book":"창세기","book_name":"창세기","chapter":31,"verse":28,"text":"나로 내 손자들과 딸들에게 입맞추지 못하게 하였느냐 ? 네 소위가 실로 어리석도다","reference":"창세기 31:28","category":"$undefined"},{"id":"903","book":"창세기","book_name":"창세기","chapter":31,"verse":29,"text":"너를 해할만한 능력이 내 손에 있으나 너희 아버지의 하나님이 어제밤에 내게 말씀하시기를 너는 삼가 야곱에게 선악간 말하지 말라 하셨느니라","reference":"창세기 31:29","category":"$undefined"},{"id":"904","book":"창세기","book_name":"창세기","chapter":31,"verse":30,"text":"이제 네가 네 아비 집을 사모하여 돌아가려는 것은 가하거니와 어찌 내 신(神)을 도적질하였느냐 ?'","reference":"창세기 31:30","category":"$undefined"},{"id":"905","book":"창세기","book_name":"창세기","chapter":31,"verse":31,"text":"야곱이 라반에게 대답하여 가로되 `내가 말하기를 외삼촌이 외삼촌의 딸들을 내게서 억지로 빼앗으리라 하여 두려워하였음이니이다","reference":"창세기 31:31","category":"$undefined"},{"id":"906","book":"창세기","book_name":"창세기","chapter":31,"verse":32,"text":"외삼촌의 신은 뉘게서 찾든지 그는 살지 못할 것이요 우리 형제들 앞에서 무엇이든지 외삼촌의 것이 발견되거든 외삼촌에게로 하소서' 하니 야곱은 라헬이 그것을 도적질한 줄을 알지 못함이었더라","reference":"창세기 31:32","category":"$undefined"},{"id":"907","book":"창세기","book_name":"창세기","chapter":31,"verse":33,"text":"라반이 야곱의 장막에 들어가고 레아의 장막에 들어가고 두 여종의 장막에 들어갔으나 찾지 못하고 레아의 장막에서 나와 라헬의 장막에 들어가매","reference":"창세기 31:33","category":"$undefined"},{"id":"908","book":"창세기","book_name":"창세기","chapter":31,"verse":34,"text":"라헬이 그 드라빔을 가져 약대 안장 아래 넣고 그 위에 앉은지라 라반이 그 장막에서 찾다가 얻지 못하매","reference":"창세기 31:34","category":"$undefined"},{"id":"909","book":"창세기","book_name":"창세기","chapter":31,"verse":35,"text":"라헬이 그 아비에게 이르되 `마침 경수가 나므로 일어나서 영접할수 없사오니 내 주는 노하지 마소서' 하니라 라반이 그 드라빔을 두루 찾다가 얻지 못한지라","reference":"창세기 31:35","category":"$undefined"},{"id":"910","book":"창세기","book_name":"창세기","chapter":31,"verse":36,"text":"야곱이 노하여 라반을 책망할새 야곱이 라반에게 대척하여 가로되 나의 허물이 무엇이니이까 ? 무슨 죄가 있기에 외삼촌께서 나를 불같이 급히 쫓나이까 ?","reference":"창세기 31:36","category":"$undefined"},{"id":"911","book":"창세기","book_name":"창세기","chapter":31,"verse":37,"text":"외삼촌께서 내 물건을 다 뒤져 보셨으니 외삼촌의 가장집물 중에 무엇을 찾았나이까 ? 여기 나의 형제와 외삼촌의 형제 앞에 그것을 두고 우리 두 사이에 판단하게 하소서","reference":"창세기 31:37","category":"$undefined"},{"id":"912","book":"창세기","book_name":"창세기","chapter":31,"verse":38,"text":"내가 이 이십년에 외삼촌과 함께 하였거니와 외삼촌의 암양들이나 암염소들이 낙태하지 아니하였고 또 외삼촌의 양떼의 수양을 내가 먹지 아니하였으며","reference":"창세기 31:38","category":"$undefined"},{"id":"913","book":"창세기","book_name":"창세기","chapter":31,"verse":39,"text":"물려 찢긴 것은 내가 외삼촌에게로 가져가지 아니하고 스스로 그것을 보충하였으며 낮에 도적을 맞았든지, 밤에 도적을 맞았든지, 내가 외삼촌에게 물어 내었으며","reference":"창세기 31:39","category":"$undefined"},{"id":"914","book":"창세기","book_name":"창세기","chapter":31,"verse":40,"text":"내가 이와 같이 낮에는 더위를 무릅쓰고, 밤에는 추위를 당하며, 눈붙일 겨를도 없이 지내었나이다","reference":"창세기 31:40","category":"$undefined"},{"id":"915","book":"창세기","book_name":"창세기","chapter":31,"verse":41,"text":"내가 외삼촌의 집에 거한 이 이십년에 외삼촌의 두 딸을 위하여 십 사년, 외삼촌의 양떼를 위하여 육년을 외삼촌을 봉사하였거니와 외삼촌께서 내 품값을 열번이나 변역하셨으니","reference":"창세기 31:41","category":"$undefined"},{"id":"916","book":"창세기","book_name":"창세기","chapter":31,"verse":42,"text":"우리 아버지의 하나님, 아브라함의 하나님, 곧 이삭의 경외하는 이가 나와 함께 계시지 아니하셨더면 외삼촌께서 이제 나를 공수로 돌려 보내셨으리이다마는 하나님이 나의 고난과 내 손의 수고를 감찰하시고 어제밤에 외삼촌을 책망하셨나이다","reference":"창세기 31:42","category":"$undefined"},{"id":"917","book":"창세기","book_name":"창세기","chapter":31,"verse":43,"text":"라반이 야곱에게 대답하여 가로되 `딸들은 내 딸이요, 자식들은 내 자식이요, 양떼는 나의 양떼요, 네가 보는 것은 다 내 것이라 내가 오늘날 내 딸들과 그 낳은 자식들에게 어찌할 수 있으랴 ?","reference":"창세기 31:43","category":"$undefined"},{"id":"918","book":"창세기","book_name":"창세기","chapter":31,"verse":44,"text":"이제 오라 너와 내가 언약을 세워 그것으로 너와 나 사이에 증거를 삼을 것이니라'","reference":"창세기 31:44","category":"$undefined"},{"id":"919","book":"창세기","book_name":"창세기","chapter":31,"verse":45,"text":"이에 야곱이 돌을 가져 기둥으로 세우고","reference":"창세기 31:45","category":"$undefined"},{"id":"920","book":"창세기","book_name":"창세기","chapter":31,"verse":46,"text":"또 `그 형제들에게 돌을 모으라` 하니 그들이 돌을 취하여 무더기를 이루매 무리가 거기 무더기 곁에서 먹고","reference":"창세기 31:46","category":"$undefined"},{"id":"921","book":"창세기","book_name":"창세기","chapter":31,"verse":47,"text":"라반은 그것을 여갈사하두다라 칭하였고 야곱은 그것을 갈르엣이라 칭하였으니","reference":"창세기 31:47","category":"$undefined"},{"id":"922","book":"창세기","book_name":"창세기","chapter":31,"verse":48,"text":"라반의 말에 `오늘날 이 무더기가 너와 나 사이에 증거가 된다' 하였으므로 그 이름을 갈르엣이라 칭하였으며","reference":"창세기 31:48","category":"$undefined"},{"id":"923","book":"창세기","book_name":"창세기","chapter":31,"verse":49,"text":"또 미스바라 하였으니 이는 그의 말에 `우리 피차 떠나 있을 때에 여호와께서 너와 나 사이에 감찰하옵소서' 함이라","reference":"창세기 31:49","category":"$undefined"},{"id":"924","book":"창세기","book_name":"창세기","chapter":31,"verse":50,"text":"`네가 내 딸을 박대하거나 내 딸들 외에 다른 아내들을 취하면 사람은 우리와 함께 할 자가 없어도 보라, 하나님이 너와 나 사이에 증거하시느니라' 하였더라","reference":"창세기 31:50","category":"$undefined"},{"id":"925","book":"창세기","book_name":"창세기","chapter":31,"verse":51,"text":"라반이 또 야곱에게 이르되 `내가 너와 나 사이에 둔 이 무더기를 보라 또 이 기둥을 보라","reference":"창세기 31:51","category":"$undefined"},{"id":"926","book":"창세기","book_name":"창세기","chapter":31,"verse":52,"text":"이 무더기가 증거가 되고 이 기둥이 증거가 되나니 내가 이 무더기를 넘어 네게로 가서 해하지 않을 것이요, 네가 이 무더기, 이 기둥을 넘어 내게로 와서 해하지 않을 것이라","reference":"창세기 31:52","category":"$undefined"},{"id":"927","book":"창세기","book_name":"창세기","chapter":31,"verse":53,"text":"아브라함의 하나님, 나홀의 하나님, 그들의 조상의 하나님은 우리 사이에 판단하옵소서' 하매 야곱이 그 아비 이삭의 경외하는 이를 가리켜 맹세하고","reference":"창세기 31:53","category":"$undefined"},{"id":"928","book":"창세기","book_name":"창세기","chapter":31,"verse":54,"text":"야곱이 또 산에서 제사를 드리고 형제들을 불러 떡을 먹이니 그들이 떡을 먹고 산에서 경야하고","reference":"창세기 31:54","category":"$undefined"},{"id":"929","book":"창세기","book_name":"창세기","chapter":31,"verse":55,"text":"라반이 아침에 일찌기 일어나 손자들과 딸들에게 입맞추며 그들에게 축복하고 떠나 고향으로 돌아갔더라","reference":"창세기 31:55","category":"$undefined"}],"bookSlug":"genesis"}]
