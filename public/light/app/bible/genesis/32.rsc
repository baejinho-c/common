2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":32,"verses":[{"id":"930","book":"창세기","book_name":"창세기","chapter":32,"verse":1,"text":"야곱이 그 길을 진행하더니 하나님의 사자들이 그를 만난지라","reference":"창세기 32:1","category":"$undefined"},{"id":"931","book":"창세기","book_name":"창세기","chapter":32,"verse":2,"text":"야곱이 그들을 볼 때에 이르기를 `이는 하나님의 군대라' 하고 그 땅 이름을 마하나임이라 하였더라","reference":"창세기 32:2","category":"$undefined"},{"id":"932","book":"창세기","book_name":"창세기","chapter":32,"verse":3,"text":"야곱이 세일 땅 에돔 들에 있는 형 에서에게로 사자들을 자기보다 앞서 보내며","reference":"창세기 32:3","category":"$undefined"},{"id":"933","book":"창세기","book_name":"창세기","chapter":32,"verse":4,"text":"그들에게 부탁하여 가로되 `너희는 이같이 내 주 에서에게 고하라 주의 종 야곱이 말하기를 내가 라반에게 붙여서 지금까지 있었사오며","reference":"창세기 32:4","category":"$undefined"},{"id":"934","book":"창세기","book_name":"창세기","chapter":32,"verse":5,"text":"내게 소와, 나귀와, 양떼와, 노비가 있사오므로 사람을 보내어 내 주께 고하고 내 주께 은혜 받기를 원하나이다 하더라 하라' 하였더니","reference":"창세기 32:5","category":"$undefined"},{"id":"935","book":"창세기","book_name":"창세기","chapter":32,"verse":6,"text":"사자들이 야곱에게 돌아와 가로되 `우리가 주인의 형 에서에게 이른즉 그가 사백인을 거느리고 주인을 만나려고 오더이다'","reference":"창세기 32:6","category":"$undefined"},{"id":"936","book":"창세기","book_name":"창세기","chapter":32,"verse":7,"text":"야곱이 심히 두렵고 답답하여 자기와 함께 한 종자와 양과, 소와, 약대를 두 떼로 나누고","reference":"창세기 32:7","category":"$undefined"},{"id":"937","book":"창세기","book_name":"창세기","chapter":32,"verse":8,"text":"가로되 `에서가 와서 한 떼를 치면, 남은 한 떼는 피하리라' 하고","reference":"창세기 32:8","category":"$undefined"},{"id":"938","book":"창세기","book_name":"창세기","chapter":32,"verse":9,"text":"야곱이 또 가로되 `나의 조부 아브라함의 하나님, 나의 아버지 이삭의 하나님, 여호와여 ! 주께서 전에 내게 명하시기를 네 고향 네 족속에게로 돌아가라 내가 네게 은혜를 베풀리라 하셨나이다","reference":"창세기 32:9","category":"$undefined"},{"id":"939","book":"창세기","book_name":"창세기","chapter":32,"verse":10,"text":"나는 주께서 주의 종에게 베푸신 모든 은총과 모든 진리를 조금이라도 감당할 수 없사오나 내가 내 지팡이만 가지고 이 요단을 건넜더니 지금은 두 떼나 이루었나이다","reference":"창세기 32:10","category":"$undefined"},{"id":"940","book":"창세기","book_name":"창세기","chapter":32,"verse":11,"text":"내가 주께 간구하오니 내 형의 손에서 에서의 손에서 나를 건져내시옵소서 내가 그를 두려워하옴은 그가 와서 나와 내 처자들을 칠까 겁냄이니이다","reference":"창세기 32:11","category":"$undefined"},{"id":"941","book":"창세기","book_name":"창세기","chapter":32,"verse":12,"text":"주께서 말씀하시기를 내가 정녕 네게 은혜를 베풀어 네 씨로 바다의 셀 수 없는 모래와 같이 많게 하리라 하셨나이다'","reference":"창세기 32:12","category":"$undefined"},{"id":"942","book":"창세기","book_name":"창세기","chapter":32,"verse":13,"text":"야곱이 거기서 경야하고 그 소유 중에서 형 에서를 위하여 예물을 택하니","reference":"창세기 32:13","category":"$undefined"},{"id":"943","book":"창세기","book_name":"창세기","chapter":32,"verse":14,"text":"암염소가 이백이요, 수염소가 이십이요, 암양이 이백이요, 수양이 이십이요,","reference":"창세기 32:14","category":"$undefined"},{"id":"944","book":"창세기","book_name":"창세기","chapter":32,"verse":15,"text":"젖나는 약대 삼십과 그 새끼요, 암소가 사십이요, 황소가 열이요, 암나귀가 이십이요, 그 새끼나귀가 열이라,","reference":"창세기 32:15","category":"$undefined"},{"id":"945","book":"창세기","book_name":"창세기","chapter":32,"verse":16,"text":"그것을 각각 떼로 나눠 종들의 손에 맡기고 그 종들에게 이르되 나보다 앞서 건너가서 각 떼로 상거가 뜨게 하라 하고","reference":"창세기 32:16","category":"$undefined"},{"id":"946","book":"창세기","book_name":"창세기","chapter":32,"verse":17,"text":"그가 또 앞선 자에게 부탁하여 가로되 `내 형 에서가 너를 만나 묻기를 네가 뉘 사람이며 어디로 가느냐 ? 네 앞엣 것은 뉘 것이냐 ? 하거든","reference":"창세기 32:17","category":"$undefined"},{"id":"947","book":"창세기","book_name":"창세기","chapter":32,"verse":18,"text":"대답하기를 주의 종 야곱의 것이요, 자기 주 에서에게로 보내는 예물이오며 야곱도 우리 뒤에 있나이다 하라' 하고","reference":"창세기 32:18","category":"$undefined"},{"id":"948","book":"창세기","book_name":"창세기","chapter":32,"verse":19,"text":"그 둘째와 세째와 각 떼를 따라가는 자에게 부탁하여 가로되 `너희도 에서를 만나거든 곧 이같이 그에게 고하고","reference":"창세기 32:19","category":"$undefined"},{"id":"949","book":"창세기","book_name":"창세기","chapter":32,"verse":20,"text":"또 너희는 말하기를 주의 종 야곱이 우리 뒤에 있다 하라' 하니 이는 야곱의 생각에 `내가 내 앞에 보내는 예물로 형의 감정을 푼 후에 대면하면 형이 혹시 나를 받으리라' 함이었더라","reference":"창세기 32:20","category":"$undefined"},{"id":"950","book":"창세기","book_name":"창세기","chapter":32,"verse":21,"text":"그 예물은 그의 앞서 행하고 그는 무리 가운데서 경야하다가","reference":"창세기 32:21","category":"$undefined"},{"id":"951","book":"창세기","book_name":"창세기","chapter":32,"verse":22,"text":"밤에 일어나 두 아내와 두 여종과 열 한 아들을 인도하여 얍복 나루를 건널새","reference":"창세기 32:22","category":"$undefined"},{"id":"952","book":"창세기","book_name":"창세기","chapter":32,"verse":23,"text":"그들을 인도하여 시내를 건네며 그 소유도 건네고","reference":"창세기 32:23","category":"$undefined"},{"id":"953","book":"창세기","book_name":"창세기","chapter":32,"verse":24,"text":"야곱은 홀로 남았더니 어떤 사람이 날이 새도록 야곱과 씨름하다가","reference":"창세기 32:24","category":"$undefined"},{"id":"954","book":"창세기","book_name":"창세기","chapter":32,"verse":25,"text":"그 사람이 자기가 야곱을 이기지 못함을 보고 야곱의 환도뼈를 치매 야곱의 환도뼈가 그 사람과 씨름할 때에 위골되었더라","reference":"창세기 32:25","category":"$undefined"},{"id":"955","book":"창세기","book_name":"창세기","chapter":32,"verse":26,"text":"그 사람이 가로되 `날이 새려 하니 나로 가게 하라' 야곱이 가로되 `당신이 내게 축복하지 아니하면 가게 하지 아니하겠나이다 !'","reference":"창세기 32:26","category":"$undefined"},{"id":"956","book":"창세기","book_name":"창세기","chapter":32,"verse":27,"text":"그 사람이 그에게 이르되 `네 이름이 무엇이냐 ?' 그가 가로되 `야곱이니이다'","reference":"창세기 32:27","category":"$undefined"},{"id":"957","book":"창세기","book_name":"창세기","chapter":32,"verse":28,"text":"그 사람이 가로되 `네 이름을 다시는 야곱이라 부를 것이 아니요 이스라엘이라 부를 것이니 이는 네가 하나님과 사람으로 더불어 겨루어 이기었음이니라'","reference":"창세기 32:28","category":"$undefined"},{"id":"958","book":"창세기","book_name":"창세기","chapter":32,"verse":29,"text":"야곱이 청하여 가로되 `당신의 이름을 고하소서' 그 사람이 가로되 `어찌 내 이름을 묻느냐 ?' 하고 거기서 야곱에게 축복한지라","reference":"창세기 32:29","category":"$undefined"},{"id":"959","book":"창세기","book_name":"창세기","chapter":32,"verse":30,"text":"그러므로 야곱이 그곳 이름을 브니엘이라 하였으니 그가 이르기를 내가 하나님과 대면하여 보았으나 내 생명이 보전되었다' 함이더라","reference":"창세기 32:30","category":"$undefined"},{"id":"960","book":"창세기","book_name":"창세기","chapter":32,"verse":31,"text":"그가 브니엘을 지날 때에 해가 돋았고 그 환도뼈로 인하여 절었더라","reference":"창세기 32:31","category":"$undefined"},{"id":"961","book":"창세기","book_name":"창세기","chapter":32,"verse":32,"text":"그 사람이 야곱의 환도뼈 큰 힘줄을 친고로 이스라엘 사람들이 지금까지 환도뼈 큰 힘줄을 먹지 아니하더라","reference":"창세기 32:32","category":"$undefined"}],"bookSlug":"genesis"}]
