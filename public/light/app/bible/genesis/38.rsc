2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":38,"verses":[{"id":"1121","book":"창세기","book_name":"창세기","chapter":38,"verse":1,"text":"그 후에 유다가 자기 형제에게서 내려가서 아둘람 사람 히라에게로 나아가니라","reference":"창세기 38:1","category":"$undefined"},{"id":"1122","book":"창세기","book_name":"창세기","chapter":38,"verse":2,"text":"유다가 거기서 가나안 사람 수아라 하는 자의 딸을 보고 그를 취하여 동침하니","reference":"창세기 38:2","category":"$undefined"},{"id":"1123","book":"창세기","book_name":"창세기","chapter":38,"verse":3,"text":"그가 잉태하여 아들을 낳으매 유다가 그 이름을 엘이라 하니라","reference":"창세기 38:3","category":"$undefined"},{"id":"1124","book":"창세기","book_name":"창세기","chapter":38,"verse":4,"text":"그가 다시 잉태하여 아들을 낳고 그 이름을 오난이라 하고","reference":"창세기 38:4","category":"$undefined"},{"id":"1125","book":"창세기","book_name":"창세기","chapter":38,"verse":5,"text":"그가 또 다시 아들을 낳고 그 이름을 셀라라 하니라 그가 셀라를 낳을 때에 유다는 거십에 있었더라","reference":"창세기 38:5","category":"$undefined"},{"id":"1126","book":"창세기","book_name":"창세기","chapter":38,"verse":6,"text":"유다가 장자 엘을 위하여 아내를 취하니 그 이름은 다말이더라","reference":"창세기 38:6","category":"$undefined"},{"id":"1127","book":"창세기","book_name":"창세기","chapter":38,"verse":7,"text":"유다의 장자 엘이 여호와 목전에 악하므로 여호와께서 그를 죽이신지라","reference":"창세기 38:7","category":"$undefined"},{"id":"1128","book":"창세기","book_name":"창세기","chapter":38,"verse":8,"text":"유다가 오난에게 이르되 `네 형수에게로 들어가서 남편의 아우의 본분을 행하여 네 형을 취하여 씨가 있게 하라'","reference":"창세기 38:8","category":"$undefined"},{"id":"1129","book":"창세기","book_name":"창세기","chapter":38,"verse":9,"text":"오난이 그 씨가 자기 것이 되지 않을 줄 알므로 형수에게 들어갔을 때에 형에게 아들을 얻게 아니하려고 땅에 설정하매","reference":"창세기 38:9","category":"$undefined"},{"id":"1130","book":"창세기","book_name":"창세기","chapter":38,"verse":10,"text":"그 일이 여호와 목전에 악하므로 여호와께서 그도 죽이시니","reference":"창세기 38:10","category":"$undefined"},{"id":"1131","book":"창세기","book_name":"창세기","chapter":38,"verse":11,"text":"유다가 그 며느리 다말에게 이르되 `수절하고 네 아비 집에 있어서 내 아들 셀라가 장성하기를 기다리라' 하니 셀라도 그 형들 같이 죽을까 염려함이라 다말이 가서 그 아비 집에 있으니라","reference":"창세기 38:11","category":"$undefined"},{"id":"1132","book":"창세기","book_name":"창세기","chapter":38,"verse":12,"text":"얼마 후에 유다의 아내 수아의 딸이 죽은지라 유다가 위로를 받은 후에 그 친구 아둘람 사람 히라와 함께 딤나로 올라가서 자기 양털 깍는 자에게 이르렀더니","reference":"창세기 38:12","category":"$undefined"},{"id":"1133","book":"창세기","book_name":"창세기","chapter":38,"verse":13,"text":"혹이 다말에게 고하되 `네 시부가 자기 양털을 깎으려고 딤나에 올라왔다' 한지라","reference":"창세기 38:13","category":"$undefined"},{"id":"1134","book":"창세기","book_name":"창세기","chapter":38,"verse":14,"text":"그가 그 과부의 의복을 벗고 면박으로 얼굴을 가리고 몸을 휩싸고 딤나 길 곁 에나임 문에 앉으니 이는 셀라가 장성함을 보았어도 자기를 그의 아내로 주지 않음을 인함이라","reference":"창세기 38:14","category":"$undefined"},{"id":"1135","book":"창세기","book_name":"창세기","chapter":38,"verse":15,"text":"그가 얼굴을 가리웠으므로 유다가 그를 보고 창녀로 여겨","reference":"창세기 38:15","category":"$undefined"},{"id":"1136","book":"창세기","book_name":"창세기","chapter":38,"verse":16,"text":"길곁으로 그에게 나아가 가로되 `청컨대 나로 네게 들어가게 하라' 하니 그 자부인줄 알지 못하였음이라 그가 가로되 `당신이 무엇을 주고 내게 들어 오려느냐 ?'","reference":"창세기 38:16","category":"$undefined"},{"id":"1137","book":"창세기","book_name":"창세기","chapter":38,"verse":17,"text":"유다가 가로되 내가 내 떼에서 염소 새끼를 주리라 그가 가로되 당신이 그것을 줄 때까지 약조물을 주겠느냐 ?","reference":"창세기 38:17","category":"$undefined"},{"id":"1138","book":"창세기","book_name":"창세기","chapter":38,"verse":18,"text":"유다가 가로되 `무슨 약조물을 네게 주랴 ?' 그가 가로되 `당신의 도장과 그 끈과 당신의 손에 있는 지팡이로 하라' 유다가 그것들을 그에게 주고 그에게로 들어갔더니 그가 유다로 말미암아 잉태하였더라","reference":"창세기 38:18","category":"$undefined"},{"id":"1139","book":"창세기","book_name":"창세기","chapter":38,"verse":19,"text":"그가 일어나 떠나가서 그 면박을 벗고 과부의 의복을 도로 입으니라","reference":"창세기 38:19","category":"$undefined"},{"id":"1140","book":"창세기","book_name":"창세기","chapter":38,"verse":20,"text":"유다가 그 친구 아둘람 사람의 손에 부탁하여 염소 새끼를 보내고 그 여인의 손에서 약조물을 찾으려 하였으나 그가 그 여인을 찾지 못한지라","reference":"창세기 38:20","category":"$undefined"},{"id":"1141","book":"창세기","book_name":"창세기","chapter":38,"verse":21,"text":"그가 그 곳 사람에게 물어 가로되 `길 곁 에나임에 있던 창녀가 어디 있느냐 ?` 그들이 가로되 `여기는 창녀가 없느니라'","reference":"창세기 38:21","category":"$undefined"},{"id":"1142","book":"창세기","book_name":"창세기","chapter":38,"verse":22,"text":"그가 유다에게로 돌아와 가로되 `내가 그를 찾지 못하고 그 곳 사람도 이르기를 여기는 창녀가 없다 하더라`","reference":"창세기 38:22","category":"$undefined"},{"id":"1143","book":"창세기","book_name":"창세기","chapter":38,"verse":23,"text":"유다가 가로되 `그로 그것을 가지게 두라 우리가 부끄러움을 당할까 하노라 내가 이 염소 새끼를 보내었으나 그대가 그를 찾지 못하였느니라'","reference":"창세기 38:23","category":"$undefined"},{"id":"1144","book":"창세기","book_name":"창세기","chapter":38,"verse":24,"text":"석달쯤 후에 혹이 유다에게 고하여 가로되 `네 며느리 다말이 행음하였고 그 행음함을 인하여 잉태하였느니라' 유다가 가로되 `그를 끌어 내어 불사르라'","reference":"창세기 38:24","category":"$undefined"},{"id":"1145","book":"창세기","book_name":"창세기","chapter":38,"verse":25,"text":"여인이 끌려 나갈 때에 보내어 시부에게 이르되 `이 물건 임자로 말미암아 잉태하였나이다 청컨대 보소서, 이 도장과 그 끈과 지팡이가 뉘 것이니이까 ?' 한지라","reference":"창세기 38:25","category":"$undefined"},{"id":"1146","book":"창세기","book_name":"창세기","chapter":38,"verse":26,"text":"유다가 그것들을 알아보고 가로되 `그는 나보다 옳도다 내가 그를 내 아들 셀라에게 주지 아니하였음이로다' 하고 다시는 그를 가까이 하지 아니하였더라","reference":"창세기 38:26","category":"$undefined"},{"id":"1147","book":"창세기","book_name":"창세기","chapter":38,"verse":27,"text":"임산하여 보니 쌍태라","reference":"창세기 38:27","category":"$undefined"},{"id":"1148","book":"창세기","book_name":"창세기","chapter":38,"verse":28,"text":"해산할 때에 손이 나오는지라 산파가 가로되 `이는 먼저 나온자라' 하고 홍사를 가져 그 손에 매었더니","reference":"창세기 38:28","category":"$undefined"},{"id":"1149","book":"창세기","book_name":"창세기","chapter":38,"verse":29,"text":"그 손을 도로 들이며 그 형제가 나오는지라 산파가 가로되 `네가 어찌하여 터치고 나오느냐 ?' 한고로 그 이름을 베레스라 불렀고","reference":"창세기 38:29","category":"$undefined"},{"id":"1150","book":"창세기","book_name":"창세기","chapter":38,"verse":30,"text":"그 형제 곧 손에 홍사 있는 자가 뒤에 나오니 그 이름을 세라라 불렀더라","reference":"창세기 38:30","category":"$undefined"}],"bookSlug":"genesis"}]
