2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":41,"verses":[{"id":"1197","book":"창세기","book_name":"창세기","chapter":41,"verse":1,"text":"만 이년 후에 바로가 꿈을 꾼즉 자기가 하숫가에 섰는데","reference":"창세기 41:1","category":"$undefined"},{"id":"1198","book":"창세기","book_name":"창세기","chapter":41,"verse":2,"text":"보니 아름답고 살진 일곱 암소가 하수에서 올라와 갈밭에서 뜯어먹고","reference":"창세기 41:2","category":"$undefined"},{"id":"1199","book":"창세기","book_name":"창세기","chapter":41,"verse":3,"text":"그 뒤에 또 흉악하고 파리한 다른 일곱 암소가 하수에서 올라와 그 소와 함께 하숫가에 섰더니","reference":"창세기 41:3","category":"$undefined"},{"id":"1200","book":"창세기","book_name":"창세기","chapter":41,"verse":4,"text":"그 흉악하고 파리한 소가 그 아름답고 살진 일곱 소를 먹은지라 바로가 곧 깨었다가","reference":"창세기 41:4","category":"$undefined"},{"id":"1201","book":"창세기","book_name":"창세기","chapter":41,"verse":5,"text":"다시 잠이 들어 꿈을 꾸니 한 줄기에 무성하고 충실한 일곱 이삭이 나오고","reference":"창세기 41:5","category":"$undefined"},{"id":"1202","book":"창세기","book_name":"창세기","chapter":41,"verse":6,"text":"그 후에 또 세약하고 동풍에 마른 일곱 이삭이 나오더니","reference":"창세기 41:6","category":"$undefined"},{"id":"1203","book":"창세기","book_name":"창세기","chapter":41,"verse":7,"text":"그 세약한 일곱 이삭이 무성하고 충실한 일곱 이삭을 삼킨지라 바로가 깬즉 꿈이라","reference":"창세기 41:7","category":"$undefined"},{"id":"1204","book":"창세기","book_name":"창세기","chapter":41,"verse":8,"text":"아침에 그 마음이 번민하여 보내어 애굽의 술객과 박사를 모두 불러 그들에게 그 꿈을 고하였으나 그것을 바로에게 해석하는 자가 없었더라","reference":"창세기 41:8","category":"$undefined"},{"id":"1205","book":"창세기","book_name":"창세기","chapter":41,"verse":9,"text":"술 맡은 관원장이 바로에게 고하여 가로되 `내가 오늘날 나의 허물을 추억하나이다","reference":"창세기 41:9","category":"$undefined"},{"id":"1206","book":"창세기","book_name":"창세기","chapter":41,"verse":10,"text":"바로께서 종들에게 노하사 나와 떡 굽는 관원장을 시위대장의 집에 가두셨을 때에","reference":"창세기 41:10","category":"$undefined"},{"id":"1207","book":"창세기","book_name":"창세기","chapter":41,"verse":11,"text":"나와 그가 하룻밤에 꿈을 꾼즉 각기 징조가 있는 꿈이라","reference":"창세기 41:11","category":"$undefined"},{"id":"1208","book":"창세기","book_name":"창세기","chapter":41,"verse":12,"text":"그 곳에 시위대장의 종된 히브리 소년이 우리와 함께 있기로 우리가 그에게 고하매 그가 우리의 꿈을 풀되 그 꿈대로 각인에게 해석하더니","reference":"창세기 41:12","category":"$undefined"},{"id":"1209","book":"창세기","book_name":"창세기","chapter":41,"verse":13,"text":"그 해석 한대로 되어 나는 복직하고 그는 매여 달렸나이다'","reference":"창세기 41:13","category":"$undefined"},{"id":"1210","book":"창세기","book_name":"창세기","chapter":41,"verse":14,"text":"이에 바로가 보내어 요셉을 부르매 그들이 급히 그를 옥에서 낸지라 요셉이 곧 수염을 깎고 그 옷을 갈아 입고 바로에게 들어오니","reference":"창세기 41:14","category":"$undefined"},{"id":"1211","book":"창세기","book_name":"창세기","chapter":41,"verse":15,"text":"바로가 요셉에게 이르되 `내가 한 꿈을 꾸었으나 그것을 해석하는 자가 없더니 들은즉 너는 꿈을 들으면 능히 푼다더라`","reference":"창세기 41:15","category":"$undefined"},{"id":"1212","book":"창세기","book_name":"창세기","chapter":41,"verse":16,"text":"요셉이 바로에게 대답하여 가로되 `이는 내게 있는 것이 아니라 하나님이 바로에게 평안한 대답을 하시리이다'","reference":"창세기 41:16","category":"$undefined"},{"id":"1213","book":"창세기","book_name":"창세기","chapter":41,"verse":17,"text":"바로가 요셉에게 이르되 `내가 꿈에 하숫가에 서서","reference":"창세기 41:17","category":"$undefined"},{"id":"1214","book":"창세기","book_name":"창세기","chapter":41,"verse":18,"text":"보니 살지고 아름다운 일곱 암소가 하숫가에 올라와 갈밭에서 뜯어 먹고","reference":"창세기 41:18","category":"$undefined"},{"id":"1215","book":"창세기","book_name":"창세기","chapter":41,"verse":19,"text":"그 뒤에 또 약하고 심히 흉악하고 파리한 일곱 암소가 올라오니 그같이 흉악한 것들은 애굽 땅에서 내가 아직 보지 못한 것이라","reference":"창세기 41:19","category":"$undefined"},{"id":"1216","book":"창세기","book_name":"창세기","chapter":41,"verse":20,"text":"그 파리하고 흉악한 소가 처음의 일곱 살진 소를 먹었으며","reference":"창세기 41:20","category":"$undefined"},{"id":"1217","book":"창세기","book_name":"창세기","chapter":41,"verse":21,"text":"먹었으나 먹은듯하지 아니하여 여전히 흉악하더라 내가 곧 깨었다가","reference":"창세기 41:21","category":"$undefined"},{"id":"1218","book":"창세기","book_name":"창세기","chapter":41,"verse":22,"text":"다시 꿈에 보니 한 줄기에 무성하고 충실한 일곱 이삭이 나오고","reference":"창세기 41:22","category":"$undefined"},{"id":"1219","book":"창세기","book_name":"창세기","chapter":41,"verse":23,"text":"그 후에 또 세약하고 동풍에 마른 일곱 이삭이 나더니","reference":"창세기 41:23","category":"$undefined"},{"id":"1220","book":"창세기","book_name":"창세기","chapter":41,"verse":24,"text":"그 세약한 이삭이 좋은 일곱 이삭을 삼키더라 내가 그 꿈을 술객에게 말하였으나 그것을 내게 보이는 자가 없느니라'","reference":"창세기 41:24","category":"$undefined"},{"id":"1221","book":"창세기","book_name":"창세기","chapter":41,"verse":25,"text":"요셉이 바로에게 고하되 `바로의 꿈은 하나이라 하나님이 그 하실 일을 바로에게 보이심이니이다","reference":"창세기 41:25","category":"$undefined"},{"id":"1222","book":"창세기","book_name":"창세기","chapter":41,"verse":26,"text":"일곱 좋은 암소는 일곱해요, 일곱 좋은 이삭도 일곱해니, 그 꿈은 하나이라","reference":"창세기 41:26","category":"$undefined"},{"id":"1223","book":"창세기","book_name":"창세기","chapter":41,"verse":27,"text":"그 후에 올라온 파리하고 흉악한 일곱 소는 칠년이요, 동풍에 말라 속이 빈 일곱 이삭도 일곱해 흉년이니","reference":"창세기 41:27","category":"$undefined"},{"id":"1224","book":"창세기","book_name":"창세기","chapter":41,"verse":28,"text":"내가 바로에게 고하기를 하나님이 그 하실 일로 바로에게 보이신다 함이 이것이라","reference":"창세기 41:28","category":"$undefined"},{"id":"1225","book":"창세기","book_name":"창세기","chapter":41,"verse":29,"text":"온 애굽 땅에 일곱해 큰 풍년이 있겠고","reference":"창세기 41:29","category":"$undefined"},{"id":"1226","book":"창세기","book_name":"창세기","chapter":41,"verse":30,"text":"후에 일곱해 흉년이 들므로 애굽 땅에 있던 풍년을 다 잊어버리게 되고 이 땅이 기근으로 멸망되리니","reference":"창세기 41:30","category":"$undefined"},{"id":"1227","book":"창세기","book_name":"창세기","chapter":41,"verse":31,"text":"후에 든 그 흉년이 너무 심하므로 이전 풍년을 이 땅에서 기억하지 못하게 되리이다","reference":"창세기 41:31","category":"$undefined"},{"id":"1228","book":"창세기","book_name":"창세기","chapter":41,"verse":32,"text":"바로께서 꿈을 두번 겹쳐 꾸신 것은 하나님이 이 일을 정하셨음이라 속히 행하시리니","reference":"창세기 41:32","category":"$undefined"},{"id":"1229","book":"창세기","book_name":"창세기","chapter":41,"verse":33,"text":"이제 바로께서는 명철하고 지혜있는 사람을 택하여 애굽 땅을 치리하게 하시고","reference":"창세기 41:33","category":"$undefined"},{"id":"1230","book":"창세기","book_name":"창세기","chapter":41,"verse":34,"text":"바로께서는 또 이같이 행하사 국중에 여러 관리를 두어 그 일곱해 풍년에 애굽 땅의 오분의 일을 거두되","reference":"창세기 41:34","category":"$undefined"},{"id":"1231","book":"창세기","book_name":"창세기","chapter":41,"verse":35,"text":"그 관리로 장차 올 풍년의 모든 곡물을 거두고 그 곡물을 바로의 손에 돌려 양식을 위하여 각 성에 적치하게 하소서","reference":"창세기 41:35","category":"$undefined"},{"id":"1232","book":"창세기","book_name":"창세기","chapter":41,"verse":36,"text":"이와 같이 그 곡물을 이 땅에 저장하여 애굽 땅에 임할 일곱해 흉년을 예비하시면 땅이 이 흉년을 인하여 멸망치 아니하리이다'","reference":"창세기 41:36","category":"$undefined"},{"id":"1233","book":"창세기","book_name":"창세기","chapter":41,"verse":37,"text":"바로와 그 모든 신하가 이 일을 좋게 여긴지라","reference":"창세기 41:37","category":"$undefined"},{"id":"1234","book":"창세기","book_name":"창세기","chapter":41,"verse":38,"text":"바로가 그 신하들에게 이르되 `이와 같이 하나님의 신이 감동한 사람을 우리가 어찌 얻을 수 있으리요' 하고","reference":"창세기 41:38","category":"$undefined"},{"id":"1235","book":"창세기","book_name":"창세기","chapter":41,"verse":39,"text":"요셉에게 이르되 `하나님이 이 모든 것을 네게 보이셨으니 너와 같이 명철하고 지혜있는 자가 없도다","reference":"창세기 41:39","category":"$undefined"},{"id":"1236","book":"창세기","book_name":"창세기","chapter":41,"verse":40,"text":"너는 내 집을 치리하라 내 백성이 다 네 명을 복종하리니 나는 너보다 높음이 보좌 뿐이니라'","reference":"창세기 41:40","category":"$undefined"},{"id":"1237","book":"창세기","book_name":"창세기","chapter":41,"verse":41,"text":"바로가 또 요셉에게 이르되 `내가 너로 애굽 온 땅을 총리하게 하노라' 하고","reference":"창세기 41:41","category":"$undefined"},{"id":"1238","book":"창세기","book_name":"창세기","chapter":41,"verse":42,"text":"자기의 인장 반지를 빼어 요셉의 손에 끼우고 그에게 세마포 옷을 입히고 금사슬을 목에 걸고","reference":"창세기 41:42","category":"$undefined"},{"id":"1239","book":"창세기","book_name":"창세기","chapter":41,"verse":43,"text":"자기에게 있는 버금 수레에 그를 태우매 무리가 그 앞에서 소리 지르기를 `엎드리라' 하더라 바로가 그로 애굽 전국을 총리하게 하였더라","reference":"창세기 41:43","category":"$undefined"},{"id":"1240","book":"창세기","book_name":"창세기","chapter":41,"verse":44,"text":"바로가 요셉에게 이르되 `나는 바로라 애굽 온 땅에서 네 허락없이는 수족을 놀릴 자가 없으리라' 하고","reference":"창세기 41:44","category":"$undefined"},{"id":"1241","book":"창세기","book_name":"창세기","chapter":41,"verse":45,"text":"그가 요셉의 이름을 사브낫바네아라 하고 또 온 제사장 보디베라의 딸 아스낫을 그에게 주어 아내를 삼게 하니라 요셉이 나가 애굽 온 땅을 순찰하니라","reference":"창세기 41:45","category":"$undefined"},{"id":"1242","book":"창세기","book_name":"창세기","chapter":41,"verse":46,"text":"요셉이 애굽 왕 바로 앞에 설 때에 삼십세라 그가 바로 앞을 떠나 애굽 온 땅을 순찰하니","reference":"창세기 41:46","category":"$undefined"},{"id":"1243","book":"창세기","book_name":"창세기","chapter":41,"verse":47,"text":"일곱해 풍년에 토지 소출이 심히 많은지라","reference":"창세기 41:47","category":"$undefined"},{"id":"1244","book":"창세기","book_name":"창세기","chapter":41,"verse":48,"text":"요셉이 애굽 땅에 있는 그 칠년 곡물을 거두어 각 성에 저축하되 각 성주위의 밭의 곡물을 그 성중에 저장하매","reference":"창세기 41:48","category":"$undefined"},{"id":"1245","book":"창세기","book_name":"창세기","chapter":41,"verse":49,"text":"저장한 곡식이 바다 모래같이 심히 많아 세기를 그쳤으니 그 수가 한이 없음이었더라","reference":"창세기 41:49","category":"$undefined"},{"id":"1246","book":"창세기","book_name":"창세기","chapter":41,"verse":50,"text":"흉년이 들기 전에 요셉에게 두 아들을 낳되 곧 온 제사장 보디베라의 딸 아스낫이 그에게 낳은지라","reference":"창세기 41:50","category":"$undefined"},{"id":"1247","book":"창세기","book_name":"창세기","chapter":41,"verse":51,"text":"요셉이 그 장자의 이름을 므낫세라 하였으니 `하나님이 나로 나의 모든 고난과 나의 아비의 온 집 일을 잊어버리게 하셨다' 함이요","reference":"창세기 41:51","category":"$undefined"},{"id":"1248","book":"창세기","book_name":"창세기","chapter":41,"verse":52,"text":"차자의 이름을 에브라임이라 하였으니 `하나님이 나로 나의 수고한 땅에서 창성하게 하셨다' 함이었더라","reference":"창세기 41:52","category":"$undefined"},{"id":"1249","book":"창세기","book_name":"창세기","chapter":41,"verse":53,"text":"애굽 땅에 일곱해 풍년이 그치고","reference":"창세기 41:53","category":"$undefined"},{"id":"1250","book":"창세기","book_name":"창세기","chapter":41,"verse":54,"text":"요셉의 말과 같이 일곱해 흉년이 들기 시작하매 각국에는 기근이 있으나 애굽 온 땅에는 식물이 있더니","reference":"창세기 41:54","category":"$undefined"},{"id":"1251","book":"창세기","book_name":"창세기","chapter":41,"verse":55,"text":"애굽 온 땅이 주리매 백성이 바로에게 부르짖어 양식을 구하는지라 바로가 애굽 모든 백성에게 이르되 `요셉에게 가서 그가 너희에게 이르는 대로 하라' 하니라","reference":"창세기 41:55","category":"$undefined"},{"id":"1252","book":"창세기","book_name":"창세기","chapter":41,"verse":56,"text":"온 지면에 기근이 있으매 요셉이 모든 창고를 열고 애굽 백성에게 팔새 애굽 땅에 기근이 심하며","reference":"창세기 41:56","category":"$undefined"},{"id":"1253","book":"창세기","book_name":"창세기","chapter":41,"verse":57,"text":"각국 백성도 양식을 사려고 애굽으로 들어와 요셉에게 이르렀으니 기근이 온 세상에 심함이었더라","reference":"창세기 41:57","category":"$undefined"}],"bookSlug":"genesis"}]
