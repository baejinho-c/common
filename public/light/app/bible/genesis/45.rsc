2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":45,"verses":[{"id":"1360","book":"창세기","book_name":"창세기","chapter":45,"verse":1,"text":"요셉이 시종하는 자들 앞에서 그 정을 억제하지 못하여 소리질러 모든 사람을 자기에게서 물러가라 하고 그 형제에게 자기를 알리니 때에 그와 함께 한 자가 없었더라","reference":"창세기 45:1","category":"$undefined"},{"id":"1361","book":"창세기","book_name":"창세기","chapter":45,"verse":2,"text":"요셉이 방성대곡하니 애굽 사람에게 들리며 바로의 궁중에 들리더라","reference":"창세기 45:2","category":"$undefined"},{"id":"1362","book":"창세기","book_name":"창세기","chapter":45,"verse":3,"text":"요셉이 그 형들에게 이르되 `나는 요셉이라 내 아버지께서 아직 살아 계시니이까 ?' 형들이 그 앞에서 놀라서 능히 대답하지 못하는지라","reference":"창세기 45:3","category":"$undefined"},{"id":"1363","book":"창세기","book_name":"창세기","chapter":45,"verse":4,"text":"요셉이 형들에게 이르되 `내게로 가까이 오소서` 그들이 가까이 가니 가로되 `나는 당신들의 아우 요셉이니 당신들이 애굽에 판 자라","reference":"창세기 45:4","category":"$undefined"},{"id":"1364","book":"창세기","book_name":"창세기","chapter":45,"verse":5,"text":"당신들이 나를 이곳에 팔았으므로 근심하지 마소서 한탄하지 마소서 ! 하나님이 생명을 구원하시려고 나를 당신들 앞서 보내셨나이다","reference":"창세기 45:5","category":"$undefined"},{"id":"1365","book":"창세기","book_name":"창세기","chapter":45,"verse":6,"text":"이 땅에 이년 동안 흉년이 들었으나 아직 오년은 기경도 못하고 추수도 못할지라","reference":"창세기 45:6","category":"$undefined"},{"id":"1366","book":"창세기","book_name":"창세기","chapter":45,"verse":7,"text":"하나님이 큰 구원으로 당신들의 생명을 보존하고 당신들의 후손을 세상에 두시려고 나를 당신들 앞서 보내셨나니","reference":"창세기 45:7","category":"$undefined"},{"id":"1367","book":"창세기","book_name":"창세기","chapter":45,"verse":8,"text":"그런즉 나를 이리로 보낸 자는 당신들이 아니요 하나님이시라 하나님이 나로 바로의 아비를 삼으시며 그 온 집의 주를 삼으시며 애굽 온 땅의 치리자를 삼으셨나이다","reference":"창세기 45:8","category":"$undefined"},{"id":"1368","book":"창세기","book_name":"창세기","chapter":45,"verse":9,"text":"당신들은 속히 아버지께로 올라가서 고하기를 아버지의 아들 요셉의 말에 하나님이 나를 애굽 전국의 주로 세우셨으니 내게로 지체말고 내려오사","reference":"창세기 45:9","category":"$undefined"},{"id":"1369","book":"창세기","book_name":"창세기","chapter":45,"verse":10,"text":"아버지의 아들들과 아버지의 손자들과 아버지의 양과 소와 모든 소유가 고센 땅에 있어서 나와 가깝게 하소서","reference":"창세기 45:10","category":"$undefined"},{"id":"1370","book":"창세기","book_name":"창세기","chapter":45,"verse":11,"text":"흉년이 아직 다섯해가 있으니 내가 거기서 아버지를 봉양하리이다 아버지와 아버지의 가속과 아버지의 모든 소속이 결핍할까 하나이다 하더라 하소서","reference":"창세기 45:11","category":"$undefined"},{"id":"1371","book":"창세기","book_name":"창세기","chapter":45,"verse":12,"text":"당신들의 눈과 내 아우 베냐민의 눈이 보는바 당신들에게 이 말을 하는 것은 내 입이라","reference":"창세기 45:12","category":"$undefined"},{"id":"1372","book":"창세기","book_name":"창세기","chapter":45,"verse":13,"text":"당신들은 나의 애굽에서의 영화와 당신들의 본 모든 것을 다 내 아버지께 고하고 속히 모시고 내려오소서' 하며","reference":"창세기 45:13","category":"$undefined"},{"id":"1373","book":"창세기","book_name":"창세기","chapter":45,"verse":14,"text":"자기 아우 베냐민의 목을 안고 우니 베냐민도 요셉의 목을 안고 우니라","reference":"창세기 45:14","category":"$undefined"},{"id":"1374","book":"창세기","book_name":"창세기","chapter":45,"verse":15,"text":"요셉이 또 형들과 입맞추며 안고 우니 형들이 그제야 요셉과 말하니라","reference":"창세기 45:15","category":"$undefined"},{"id":"1375","book":"창세기","book_name":"창세기","chapter":45,"verse":16,"text":"요셉의 형들이 왔다는 소문이 바로의 궁에 들리매 바로와 그 신복이 기뻐하고","reference":"창세기 45:16","category":"$undefined"},{"id":"1376","book":"창세기","book_name":"창세기","chapter":45,"verse":17,"text":"바로는 요셉에게 이르되 `네 형들에게 명하기를 너희는 이렇게 하여 너희 양식을 싣고 가서 가나안 땅에 이르거든","reference":"창세기 45:17","category":"$undefined"},{"id":"1377","book":"창세기","book_name":"창세기","chapter":45,"verse":18,"text":"너희 아비와 너희 가속을 이끌고 내게로 오라 내가 너희에게 애굽 땅 아름다운 것을 주리니 너희가 나라의 기름진 것을 먹으리라","reference":"창세기 45:18","category":"$undefined"},{"id":"1378","book":"창세기","book_name":"창세기","chapter":45,"verse":19,"text":"이제 명을 받았으니 이렇게 하라 너희는 애굽 땅에서 수레를 가져다가 너희 자녀와 아내를 태우고 너희 아비를 데려오라","reference":"창세기 45:19","category":"$undefined"},{"id":"1379","book":"창세기","book_name":"창세기","chapter":45,"verse":20,"text":"또 너희의 기구를 아끼지 말라 온 애굽 땅의 좋은 것이 너희 것임이니라 하라`","reference":"창세기 45:20","category":"$undefined"},{"id":"1380","book":"창세기","book_name":"창세기","chapter":45,"verse":21,"text":"이스라엘의 아들들이 그대로 할새 요셉이 바로의 명대로 그들에게로 수레를 주고 길 양식을 주며","reference":"창세기 45:21","category":"$undefined"},{"id":"1381","book":"창세기","book_name":"창세기","chapter":45,"verse":22,"text":"또 그들에게 다 각기 옷 한벌씩 주되 베냐민에게는 은 삼백과 옷 다섯벌을 주고","reference":"창세기 45:22","category":"$undefined"},{"id":"1382","book":"창세기","book_name":"창세기","chapter":45,"verse":23,"text":"그가 또 이와 같이 그 아비에게 보내되 수나귀 열 필에 애굽의 아름다운 물품을 실리고 암나귀 열필에는 아비에게 길에서 공궤할 곡식과 떡과 양식을 실리고","reference":"창세기 45:23","category":"$undefined"},{"id":"1383","book":"창세기","book_name":"창세기","chapter":45,"verse":24,"text":"이에 형들을 돌려 보내며 그들에게 이르되 `당신들은 노중에서 다투지 말라' 하였더라","reference":"창세기 45:24","category":"$undefined"},{"id":"1384","book":"창세기","book_name":"창세기","chapter":45,"verse":25,"text":"그들이 애굽에서 올라와 가나안 땅으로 들어가서 아비 야곱에게 이르러","reference":"창세기 45:25","category":"$undefined"},{"id":"1385","book":"창세기","book_name":"창세기","chapter":45,"verse":26,"text":"고하여 가로되 `요셉이 지금까지 살아 있어 애굽 땅 총리가 되었더이다' 야곱이 그들을 믿지 아니하므로 기색하더니","reference":"창세기 45:26","category":"$undefined"},{"id":"1386","book":"창세기","book_name":"창세기","chapter":45,"verse":27,"text":"그들이 또 요셉이 자기들에게 부탁한 모든 말로 그 아비에게 고하매 그 아비 야곱이 요셉의 자기를 태우려고 보낸 수레를 보고야 기운이 소생한지라","reference":"창세기 45:27","category":"$undefined"},{"id":"1387","book":"창세기","book_name":"창세기","chapter":45,"verse":28,"text":"이스라엘이 가로되 `족하도다 내 아들 요셉이 지금까지 살았으니 내가 죽기 전에 가서 그를 보리라'","reference":"창세기 45:28","category":"$undefined"}],"bookSlug":"genesis"}]
