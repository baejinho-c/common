2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":46,"verses":[{"id":"1388","book":"창세기","book_name":"창세기","chapter":46,"verse":1,"text":"이스라엘이 모든 소유를 이끌고 발행하여 브엘세바에 이르러 그 아비 이삭의 하나님께 희생을 드리니","reference":"창세기 46:1","category":"$undefined"},{"id":"1389","book":"창세기","book_name":"창세기","chapter":46,"verse":2,"text":"밤에 하나님이 이상중에 이스라엘에게 나타나시고 불러 가라사대 야곱아 ! 야곱아 ! 하시는지라 야곱이 가로되 `내가 여기 있나이다` 하매","reference":"창세기 46:2","category":"$undefined"},{"id":"1390","book":"창세기","book_name":"창세기","chapter":46,"verse":3,"text":"하나님이 가라사대 나는 하나님이라 네 아비의 하나님이니 애굽으로 내려가기를 두려워 말라 내가 거기서 너로 큰 민족을 이루게 하리라","reference":"창세기 46:3","category":"$undefined"},{"id":"1391","book":"창세기","book_name":"창세기","chapter":46,"verse":4,"text":"내가 너와 함께 애굽으로 내려가겠고 정녕 너를 인도하여 다시 올라올 것이며 요셉이 그 손으로 네 눈을 감기리라 하셨더라","reference":"창세기 46:4","category":"$undefined"},{"id":"1392","book":"창세기","book_name":"창세기","chapter":46,"verse":5,"text":"야곱이 브엘세바에서 발행할새 이스라엘의 아들들이 바로의 태우려고 보낸 수레에 자기들의 아비 야곱과 자기들의 처자들을 태웠고","reference":"창세기 46:5","category":"$undefined"},{"id":"1393","book":"창세기","book_name":"창세기","chapter":46,"verse":6,"text":"그 생축과 가나안 땅에서 얻은 재물을 이끌었으며 야곱과 그 자손들이 다 함께 애굽으로 갔더라","reference":"창세기 46:6","category":"$undefined"},{"id":"1394","book":"창세기","book_name":"창세기","chapter":46,"verse":7,"text":"이와 같이 야곱이 그 아들들과 손자들과, 딸들과, 손녀들 곧 그 모든 자손을 데리고 애굽으로 갔더라","reference":"창세기 46:7","category":"$undefined"},{"id":"1395","book":"창세기","book_name":"창세기","chapter":46,"verse":8,"text":"애굽으로 내려간 이스라엘 가족의 이름이 이러하니 야곱과 그 아들들 곧 야곱의 맏아들 르우벤과","reference":"창세기 46:8","category":"$undefined"},{"id":"1396","book":"창세기","book_name":"창세기","chapter":46,"verse":9,"text":"르우벤의 아들 하녹과, 발루와, 헤스론과, 갈미요","reference":"창세기 46:9","category":"$undefined"},{"id":"1397","book":"창세기","book_name":"창세기","chapter":46,"verse":10,"text":"시므온의 아들 곧 여무엘과, 야민과, 오핫과, 야긴과, 스할과, 가나안 여인의 소생 사울이요","reference":"창세기 46:10","category":"$undefined"},{"id":"1398","book":"창세기","book_name":"창세기","chapter":46,"verse":11,"text":"레위의 아들 곧 게르손과, 그핫과, 므라리요","reference":"창세기 46:11","category":"$undefined"},{"id":"1399","book":"창세기","book_name":"창세기","chapter":46,"verse":12,"text":"유다의 아들 곧 엘과, 오난과, 셀라와, 베레스와, 세라니, 엘과 오난은 가나안 땅에서 죽었고 또 베레스의 아들 곧 헤스론과, 하물이요","reference":"창세기 46:12","category":"$undefined"},{"id":"1400","book":"창세기","book_name":"창세기","chapter":46,"verse":13,"text":"잇사갈의 아들 곧 돌라와, 부와와, 욥과, 시므론이요","reference":"창세기 46:13","category":"$undefined"},{"id":"1401","book":"창세기","book_name":"창세기","chapter":46,"verse":14,"text":"스불론의 아들 곧 세렛과, 엘론과, 얄르엘이니","reference":"창세기 46:14","category":"$undefined"},{"id":"1402","book":"창세기","book_name":"창세기","chapter":46,"verse":15,"text":"이들은 레아가 밧단아람에서 야곱에게 낳은 자손들이라 그 딸 디나를 합하여 남자와 여자가 삼십 삼명이며","reference":"창세기 46:15","category":"$undefined"},{"id":"1403","book":"창세기","book_name":"창세기","chapter":46,"verse":16,"text":"갓의 아들 곧 시뵨과, 학기와, 수니와, 에스본과, 에리와, 아로디와, 아렐리요","reference":"창세기 46:16","category":"$undefined"},{"id":"1404","book":"창세기","book_name":"창세기","chapter":46,"verse":17,"text":"아셀의 아들 곧 임나와, 이스와와, 이스위와, 브리아와 그들의 누이 세라며 또 브리아의 아들 곧 헤벨과, 말기엘이니","reference":"창세기 46:17","category":"$undefined"},{"id":"1405","book":"창세기","book_name":"창세기","chapter":46,"verse":18,"text":"이들은 라반이 그 딸 레아에게 준 실바가 야곱에게 낳은 자손들이라 합 십 륙명이요","reference":"창세기 46:18","category":"$undefined"},{"id":"1406","book":"창세기","book_name":"창세기","chapter":46,"verse":19,"text":"야곱의 아내 라헬의 아들 곧 요셉과, 베냐민이요","reference":"창세기 46:19","category":"$undefined"},{"id":"1407","book":"창세기","book_name":"창세기","chapter":46,"verse":20,"text":"애굽 땅에서 온 제사장 보디베라의 딸 아스낫이 요셉에게 낳은 므낫세와 에브라임이요","reference":"창세기 46:20","category":"$undefined"},{"id":"1408","book":"창세기","book_name":"창세기","chapter":46,"verse":21,"text":"베냐민의 아들 곧 벨라와, 베겔과, 아스벨과, 게라와, 나아만과, 에히와, 로스와, 뭅빔과, 훔빔과, 아릇이니","reference":"창세기 46:21","category":"$undefined"},{"id":"1409","book":"창세기","book_name":"창세기","chapter":46,"verse":22,"text":"이들은 라헬이 야곱에게 낳은 자손이라 합 십 사명이요","reference":"창세기 46:22","category":"$undefined"},{"id":"1410","book":"창세기","book_name":"창세기","chapter":46,"verse":23,"text":"단의 아들 후심이요","reference":"창세기 46:23","category":"$undefined"},{"id":"1411","book":"창세기","book_name":"창세기","chapter":46,"verse":24,"text":"납달리의 아들 곧 야스엘과, 구니와, 예셀과, 실렘이라","reference":"창세기 46:24","category":"$undefined"},{"id":"1412","book":"창세기","book_name":"창세기","chapter":46,"verse":25,"text":"이들은 라반이 그 딸 라헬에게 준 빌하가 야곱에게 낳은 자손이니 합이 칠명이라","reference":"창세기 46:25","category":"$undefined"},{"id":"1413","book":"창세기","book_name":"창세기","chapter":46,"verse":26,"text":"야곱과 함께 애굽에 이른 자는 야곱의 자부 외에 육십 륙명이니 이는 다 야곱의 몸에서 나온 자며","reference":"창세기 46:26","category":"$undefined"},{"id":"1414","book":"창세기","book_name":"창세기","chapter":46,"verse":27,"text":"애굽에서 요셉에게 낳은 아들이 두명이니 야곱의 집 사람으로 애굽에 이른 자의 도합이 칠십명이었더라","reference":"창세기 46:27","category":"$undefined"},{"id":"1415","book":"창세기","book_name":"창세기","chapter":46,"verse":28,"text":"야곱이 유다를 요셉에게 미리 보내어 자기를 고센으로 인도하게 하고 다 고센 땅에 이르니","reference":"창세기 46:28","category":"$undefined"},{"id":"1416","book":"창세기","book_name":"창세기","chapter":46,"verse":29,"text":"요셉이 수레를 갖추고 고센으로 올라가서 아비 이스라엘을 맞으며 그에게 보이고 그 목을 어긋맞겨 안고 얼마동안 울매","reference":"창세기 46:29","category":"$undefined"},{"id":"1417","book":"창세기","book_name":"창세기","chapter":46,"verse":30,"text":"이스라엘이 요셉에게 이르되 `네가 지금까지 살아 있고 내가 네 얼굴을 보았으니 지금 죽어도 가하도다'","reference":"창세기 46:30","category":"$undefined"},{"id":"1418","book":"창세기","book_name":"창세기","chapter":46,"verse":31,"text":"요셉이 그 형들과 아비의 권속에게 이르되 내가 올라가서 바로에게 고하여 이르기를 `가나안 땅에 있던 내 형들과 내 아비의 권속이 내게로 왔는데","reference":"창세기 46:31","category":"$undefined"},{"id":"1419","book":"창세기","book_name":"창세기","chapter":46,"verse":32,"text":"그들은 목자라 목축으로 업을 삼으므로 그 양과 소와 모든 소유를 이끌고 왔나이다 하리니","reference":"창세기 46:32","category":"$undefined"},{"id":"1420","book":"창세기","book_name":"창세기","chapter":46,"verse":33,"text":"바로가 당신들을 불러서 너희의 업이 무엇이냐 ? 묻거든","reference":"창세기 46:33","category":"$undefined"},{"id":"1421","book":"창세기","book_name":"창세기","chapter":46,"verse":34,"text":"당신들은 고하기를 주의 종들은 어렸을 때부터 지금까지 목축하는 자이온데 우리와 우리 선조가 다 그러하니이다 하소서 애굽 사람은 다 목축을 가증히 여기나니 당신들이 고센 땅에 거하게 되리이다`","reference":"창세기 46:34","category":"$undefined"}],"bookSlug":"genesis"}]
