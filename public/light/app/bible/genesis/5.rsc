2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":5,"verses":[{"id":"107","book":"창세기","book_name":"창세기","chapter":5,"verse":1,"text":"아담 자손의 계보가 이러하니라 하나님이 사람을 창조하실 때에 하나님의 형상대로 지으시되","reference":"창세기 5:1","category":"$undefined"},{"id":"108","book":"창세기","book_name":"창세기","chapter":5,"verse":2,"text":"남자와 여자를 창조하셨고 그들이 창조되던 날에 하나님이 그들에게 복을 주시고 그들의 이름을 사람이라 일컬으셨더라","reference":"창세기 5:2","category":"$undefined"},{"id":"109","book":"창세기","book_name":"창세기","chapter":5,"verse":3,"text":"아담이 일백 삼십세에 자기 모양 곧 자기 형상과 같은 아들을 낳아 이름을 셋이라 하였고","reference":"창세기 5:3","category":"$undefined"},{"id":"110","book":"창세기","book_name":"창세기","chapter":5,"verse":4,"text":"아담이 셋을 낳은 후 팔백년을 지내며 자녀를 낳았으며","reference":"창세기 5:4","category":"$undefined"},{"id":"111","book":"창세기","book_name":"창세기","chapter":5,"verse":5,"text":"그가 구백 삼십세를 향수하고 죽었더라","reference":"창세기 5:5","category":"$undefined"},{"id":"112","book":"창세기","book_name":"창세기","chapter":5,"verse":6,"text":"셋은 일백 오세에 에노스를 낳았고","reference":"창세기 5:6","category":"$undefined"},{"id":"113","book":"창세기","book_name":"창세기","chapter":5,"verse":7,"text":"에노스를 낳은 후 팔백 칠년을 지내며 자녀를 낳았으며","reference":"창세기 5:7","category":"$undefined"},{"id":"114","book":"창세기","book_name":"창세기","chapter":5,"verse":8,"text":"그가 구백 십이세를 향수하고 죽었더라","reference":"창세기 5:8","category":"$undefined"},{"id":"115","book":"창세기","book_name":"창세기","chapter":5,"verse":9,"text":"에노스는 구십세에 게난을 낳았고","reference":"창세기 5:9","category":"$undefined"},{"id":"116","book":"창세기","book_name":"창세기","chapter":5,"verse":10,"text":"게난을 낳은 후 팔백 십 오년을 지내며 자녀를 낳았으며","reference":"창세기 5:10","category":"$undefined"},{"id":"117","book":"창세기","book_name":"창세기","chapter":5,"verse":11,"text":"그가 구백 오세를 향수하고 죽었더라","reference":"창세기 5:11","category":"$undefined"},{"id":"118","book":"창세기","book_name":"창세기","chapter":5,"verse":12,"text":"게난은 칠십세에 마할랄렐을 낳았고","reference":"창세기 5:12","category":"$undefined"},{"id":"119","book":"창세기","book_name":"창세기","chapter":5,"verse":13,"text":"마할랄렐을 낳은 후 팔백 사십년을 지내며 자녀를 낳았으며","reference":"창세기 5:13","category":"$undefined"},{"id":"120","book":"창세기","book_name":"창세기","chapter":5,"verse":14,"text":"그가 구백 십세를 향수하고 죽었더라","reference":"창세기 5:14","category":"$undefined"},{"id":"121","book":"창세기","book_name":"창세기","chapter":5,"verse":15,"text":"마할랄렐은 육십 오세에 야렛을 낳았고","reference":"창세기 5:15","category":"$undefined"},{"id":"122","book":"창세기","book_name":"창세기","chapter":5,"verse":16,"text":"야렛을 낳은 후 팔백 삼십년을 지내며 자녀를 낳았으며","reference":"창세기 5:16","category":"$undefined"},{"id":"123","book":"창세기","book_name":"창세기","chapter":5,"verse":17,"text":"그가 팔백 구십 오세를 향수하고 죽었더라","reference":"창세기 5:17","category":"$undefined"},{"id":"124","book":"창세기","book_name":"창세기","chapter":5,"verse":18,"text":"야렛은 일백 육십 이세에 에녹을 낳았고","reference":"창세기 5:18","category":"$undefined"},{"id":"125","book":"창세기","book_name":"창세기","chapter":5,"verse":19,"text":"에녹을 낳은 후 팔백년을 지내며 자녀를 낳았으며","reference":"창세기 5:19","category":"$undefined"},{"id":"126","book":"창세기","book_name":"창세기","chapter":5,"verse":20,"text":"그가 구백 육십 이세를 향수하고 죽었더라","reference":"창세기 5:20","category":"$undefined"},{"id":"127","book":"창세기","book_name":"창세기","chapter":5,"verse":21,"text":"에녹은 육십 오세에 므두셀라를 낳았고","reference":"창세기 5:21","category":"$undefined"},{"id":"128","book":"창세기","book_name":"창세기","chapter":5,"verse":22,"text":"므두셀라를 낳은 후 삼백년을 하나님과 동행하며 자녀를 낳았으며","reference":"창세기 5:22","category":"$undefined"},{"id":"129","book":"창세기","book_name":"창세기","chapter":5,"verse":23,"text":"그가 삼백 육십 오세를 향수하였더라","reference":"창세기 5:23","category":"$undefined"},{"id":"130","book":"창세기","book_name":"창세기","chapter":5,"verse":24,"text":"에녹이 하나님과 동행하더니 하나님이 그를 데려 가시므로 세상에 있지 아니하였더라","reference":"창세기 5:24","category":"$undefined"},{"id":"131","book":"창세기","book_name":"창세기","chapter":5,"verse":25,"text":"므두셀라는 일백 팔십 칠세에 라멕을 낳았고","reference":"창세기 5:25","category":"$undefined"},{"id":"132","book":"창세기","book_name":"창세기","chapter":5,"verse":26,"text":"라멕을 낳은 후 칠백 팔십 이년을 지내며 자녀를 낳았으며","reference":"창세기 5:26","category":"$undefined"},{"id":"133","book":"창세기","book_name":"창세기","chapter":5,"verse":27,"text":"그는 구백 육십 구세를 향수하고 죽었더라","reference":"창세기 5:27","category":"$undefined"},{"id":"134","book":"창세기","book_name":"창세기","chapter":5,"verse":28,"text":"라멕은 일백 팔십 이세에 아들을 낳고","reference":"창세기 5:28","category":"$undefined"},{"id":"135","book":"창세기","book_name":"창세기","chapter":5,"verse":29,"text":"이름을 노아라 하여 가로되 `여호와께서 땅을 저주하시므로 수고로이 일하는 우리를 이 아들이 안위하리라' 하였더라","reference":"창세기 5:29","category":"$undefined"},{"id":"136","book":"창세기","book_name":"창세기","chapter":5,"verse":30,"text":"라멕이 노아를 낳은 후 오백 구십 오년을 지내며 자녀를 낳았으며","reference":"창세기 5:30","category":"$undefined"},{"id":"137","book":"창세기","book_name":"창세기","chapter":5,"verse":31,"text":"그는 칠백 칠십 칠세를 향수하고 죽었더라","reference":"창세기 5:31","category":"$undefined"},{"id":"138","book":"창세기","book_name":"창세기","chapter":5,"verse":32,"text":"노아가 오백세 된 후에 셈과, 함과, 야벳을 낳았더라","reference":"창세기 5:32","category":"$undefined"}],"bookSlug":"genesis"}]
