2:["$","$L11",null,{"book":{"id":"genesis","name":"창세기","chapters":50,"testament":"old"},"chapter":7,"verses":[{"id":"161","book":"창세기","book_name":"창세기","chapter":7,"verse":1,"text":"여호와께서 노아에게 이르시되 너와 네 온 집은 방주로 들어가라 네가 이 세대에 내 앞에서 의로움을 내가 보았음이니라 !","reference":"창세기 7:1","category":"$undefined"},{"id":"162","book":"창세기","book_name":"창세기","chapter":7,"verse":2,"text":"너는 모든 정결한 짐승은 암수 일곱씩 부정한 것은 암수 둘씩을 네게로 취하며","reference":"창세기 7:2","category":"$undefined"},{"id":"163","book":"창세기","book_name":"창세기","chapter":7,"verse":3,"text":"공중의 새도 암수 일곱씩을 취하여 그 씨를 온 지면에 유전케하라","reference":"창세기 7:3","category":"$undefined"},{"id":"164","book":"창세기","book_name":"창세기","chapter":7,"verse":4,"text":"지금부터 칠일이면 내가 사십 주야를 땅에 비를 내려 나의 지은 모든 생물을 지면에서 쓸어 버리리라","reference":"창세기 7:4","category":"$undefined"},{"id":"165","book":"창세기","book_name":"창세기","chapter":7,"verse":5,"text":"노아가 여호와께서 자기에게 명하신 대로 다 준행하였더라 !","reference":"창세기 7:5","category":"$undefined"},{"id":"166","book":"창세기","book_name":"창세기","chapter":7,"verse":6,"text":"홍수가 땅에 있을 때에 노아가 육백세라","reference":"창세기 7:6","category":"$undefined"},{"id":"167","book":"창세기","book_name":"창세기","chapter":7,"verse":7,"text":"노아가 아들들과 아내와 자부들과 함께 홍수를 피하여 방주에 들어갔고","reference":"창세기 7:7","category":"$undefined"},{"id":"168","book":"창세기","book_name":"창세기","chapter":7,"verse":8,"text":"정결한 짐승과 부정한 짐승과 새와 땅에 기는 모든 것이","reference":"창세기 7:8","category":"$undefined"},{"id":"169","book":"창세기","book_name":"창세기","chapter":7,"verse":9,"text":"하나님이 노아에게 명하신 대로 암수 둘씩 노아에게 나아와 방주로 들어갔더니","reference":"창세기 7:9","category":"$undefined"},{"id":"170","book":"창세기","book_name":"창세기","chapter":7,"verse":10,"text":"칠일 후에 홍수가 땅에 덮이니","reference":"창세기 7:10","category":"$undefined"},{"id":"171","book":"창세기","book_name":"창세기","chapter":7,"verse":11,"text":"노아 육백세 되던 해 이월 곧 그 달 십 칠일이라 그날에 큰 깊음의 샘들이 터지며 하늘의 창들이 열려","reference":"창세기 7:11","category":"$undefined"},{"id":"172","book":"창세기","book_name":"창세기","chapter":7,"verse":12,"text":"사십 주야를 비가 땅에 쏟아졌더라","reference":"창세기 7:12","category":"$undefined"},{"id":"173","book":"창세기","book_name":"창세기","chapter":7,"verse":13,"text":"곧 그 날에 노아와 그의 아들 셈, 함, 야벳과 노아의 처와 세 자부가 다 방주로 들어갔고","reference":"창세기 7:13","category":"$undefined"},{"id":"174","book":"창세기","book_name":"창세기","chapter":7,"verse":14,"text":"그들과 모든 들짐승이 그 종류대로, 모든 육축이 그 종류대로, 땅에 기는 모든 것이 그 종류대로, 모든 새 곧 각양의 새가 그 종류대로","reference":"창세기 7:14","category":"$undefined"},{"id":"175","book":"창세기","book_name":"창세기","chapter":7,"verse":15,"text":"무릇 기식이 있는 육체가 둘씩 노아에게 나아와 방주로 들어갔으니","reference":"창세기 7:15","category":"$undefined"},{"id":"176","book":"창세기","book_name":"창세기","chapter":7,"verse":16,"text":"들어간 것들은 모든 것의 암,수라 하나님이 그에게 명하신대로 들어가매 여호와께서 그를 닫아 넣으시니라","reference":"창세기 7:16","category":"$undefined"},{"id":"177","book":"창세기","book_name":"창세기","chapter":7,"verse":17,"text":"홍수가 땅에 사십일을 있었는지라 물이 많아져 방주가 땅에서 올랐고","reference":"창세기 7:17","category":"$undefined"},{"id":"178","book":"창세기","book_name":"창세기","chapter":7,"verse":18,"text":"물이 더 많아져 땅에 창일하매 방주가 물 위에 떠 다녔으며","reference":"창세기 7:18","category":"$undefined"},{"id":"179","book":"창세기","book_name":"창세기","chapter":7,"verse":19,"text":"물이 땅에 더욱 창일하매 천하에 높은 산이 다 덮였더니","reference":"창세기 7:19","category":"$undefined"},{"id":"180","book":"창세기","book_name":"창세기","chapter":7,"verse":20,"text":"물이 불어서 십오 규빗이 오르매 산들이 덮인지라","reference":"창세기 7:20","category":"$undefined"},{"id":"181","book":"창세기","book_name":"창세기","chapter":7,"verse":21,"text":"땅위에 움직이는 생물이 다 죽었으니 곧 새와 육축과 들짐승과 땅에 기는 모든 것과 모든 사람이라","reference":"창세기 7:21","category":"$undefined"},{"id":"182","book":"창세기","book_name":"창세기","chapter":7,"verse":22,"text":"육지에 있어 코로 생물의 기식을 호흡하는 것은 다 죽었더라","reference":"창세기 7:22","category":"$undefined"},{"id":"183","book":"창세기","book_name":"창세기","chapter":7,"verse":23,"text":"지면의 모든 생물을 쓸어버리시니 곧 사람과 짐승과 기는 것과 공중의 새까지라 이들은 땅에서 쓸어버림을 당하였으되 홀로 노아와 그와 함께 방주에 있던 자만 남았더라","reference":"창세기 7:23","category":"$undefined"},{"id":"184","book":"창세기","book_name":"창세기","chapter":7,"verse":24,"text":"물이 일백 오십일을 땅에 창일하였더라","reference":"창세기 7:24","category":"$undefined"}],"bookSlug":"genesis"}]
