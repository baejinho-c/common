2:["$","$L11",null,{"book":{"id":"habakkuk","name":"하박국","chapters":3,"testament":"old"},"chapter":1,"verses":[{"id":"22733","book":"하박국","book_name":"하박국","chapter":1,"verse":1,"text":"선지자 하박국의 묵시로 받은 경고라","reference":"하박국 1:1","category":"$undefined"},{"id":"22734","book":"하박국","book_name":"하박국","chapter":1,"verse":2,"text":"여호와여 ! 내가 부르짖어도 주께서 듣지 아니하시니 어느 때까지리이까 ? 내가 강포를 인하여 외쳐도 주께서 구원치 아니하시나이다","reference":"하박국 1:2","category":"$undefined"},{"id":"22735","book":"하박국","book_name":"하박국","chapter":1,"verse":3,"text":"어찌하여 나로 간악을 보게 하시며 패역을 목도하게 하시나이까 ? 대저 겁탈과 강포가 내 앞에 있고 변론과 분쟁이 일어났나이다","reference":"하박국 1:3","category":"$undefined"},{"id":"22736","book":"하박국","book_name":"하박국","chapter":1,"verse":4,"text":"이러므로 율법이 해이하고 공의가 아주 시행되지 못하오니 이는 악인이 의인을 에워쌌으므로 공의가 굽게 행함이니이다","reference":"하박국 1:4","category":"$undefined"},{"id":"22737","book":"하박국","book_name":"하박국","chapter":1,"verse":5,"text":"여호와께서 가라사대 너희는 열국을 보고 또 보고 놀라고 또 놀랄지어다 너희 생전에 내가 한 일을 행할 것이라 혹이 너희에게 고할지라도 너희가 믿지 아니하리라","reference":"하박국 1:5","category":"$undefined"},{"id":"22738","book":"하박국","book_name":"하박국","chapter":1,"verse":6,"text":"보라, 내가 사납고 성급한 백성 곧 땅의 넓은 곳으로 다니며 자기의 소유 아닌 거할 곳들을 점령하는 갈대아 사람을 일으켰나니","reference":"하박국 1:6","category":"$undefined"},{"id":"22739","book":"하박국","book_name":"하박국","chapter":1,"verse":7,"text":"그들은 두렵고 무서우며 심판과 위령이 자기로 말미암으며","reference":"하박국 1:7","category":"$undefined"},{"id":"22740","book":"하박국","book_name":"하박국","chapter":1,"verse":8,"text":"그 말은 표범보다 빠르고 저녁 이리보다 사나우며 그 기병은 원방에서부터 빨리 달려오는 기병이라 마치 식물을 움키려하는 독수리의 날음과 같으니라","reference":"하박국 1:8","category":"$undefined"},{"id":"22741","book":"하박국","book_name":"하박국","chapter":1,"verse":9,"text":"그들은 다 강포를 행하러 오는데 앞을 향하여 나아가며 사람을 사로잡아 모으기를 모래 같이 많이 할 것이요","reference":"하박국 1:9","category":"$undefined"},{"id":"22742","book":"하박국","book_name":"하박국","chapter":1,"verse":10,"text":"열왕을 멸시하며 방백을 치소하며 모든 견고한 성을 비웃고 흉벽을 쌓아 그것을 취할 것이라","reference":"하박국 1:10","category":"$undefined"},{"id":"22743","book":"하박국","book_name":"하박국","chapter":1,"verse":11,"text":"그들은 그 힘으로 자기 신을 삼는 자라 이에 바람 같이 급히 몰아 지나치게 행하여 득죄하리라","reference":"하박국 1:11","category":"$undefined"},{"id":"22744","book":"하박국","book_name":"하박국","chapter":1,"verse":12,"text":"선지자가 가로되 여호와 나의 하나님 나의 거룩한 자시여 주께서는 만세 전부터 계시지 아니하시니이까 ? 우리가 사망에 이르지 아니하리이다 여호와여 ! 주께서 심판하기 위하여 그를 두셨나이다 반석이시여 ! 주께서 경계하기 위하여 그를 세우셨나이다","reference":"하박국 1:12","category":"$undefined"},{"id":"22745","book":"하박국","book_name":"하박국","chapter":1,"verse":13,"text":"주께서는 눈이 정결하시므로 악을 참아 보지 못하시며 패역을 참아 보지 못하시거늘 어찌하여 궤휼한 자들을 방관하시며 악인이 자기보다 의로운 사람을 삼키되 잠잠하시나이까 ?","reference":"하박국 1:13","category":"$undefined"},{"id":"22746","book":"하박국","book_name":"하박국","chapter":1,"verse":14,"text":"주께서 어찌하여 사람으로 바다의 어족 같게 하시며 주권자 없는 곤충 같게 하시나이까 ?","reference":"하박국 1:14","category":"$undefined"},{"id":"22747","book":"하박국","book_name":"하박국","chapter":1,"verse":15,"text":"그가 낚시로 모두 취하며 그물로 잡으며 초망으로 모으고 인하여 기뻐하고 즐거워하여","reference":"하박국 1:15","category":"$undefined"},{"id":"22748","book":"하박국","book_name":"하박국","chapter":1,"verse":16,"text":"그물에 제사하며 초망 앞에 분향하오니 이는 그것을 힘입어 소득이 풍부하고 식물이 풍성케 됨이니이다","reference":"하박국 1:16","category":"$undefined"},{"id":"22749","book":"하박국","book_name":"하박국","chapter":1,"verse":17,"text":"그가 그물을 떨고는 연하여 늘 열국을 살륙함이 옳으니이까 ?","reference":"하박국 1:17","category":"$undefined"}],"bookSlug":"habakkuk"}]
