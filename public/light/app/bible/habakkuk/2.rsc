2:["$","$L11",null,{"book":{"id":"habakkuk","name":"하박국","chapters":3,"testament":"old"},"chapter":2,"verses":[{"id":"22750","book":"하박국","book_name":"하박국","chapter":2,"verse":1,"text":"내가 내 파수하는 곳에 서며 성루에 서리라 그가 내게 무엇이라 말씀하실는지 기다리고 바라보며 나의 질문에 대하여 어떻게 대답하실는지 보리라 그리하였더니","reference":"하박국 2:1","category":"$undefined"},{"id":"22751","book":"하박국","book_name":"하박국","chapter":2,"verse":2,"text":"여호와께서 내게 대답하여 가라사대 너는 이 묵시를 기록하여 판에 명백히 새기되 달려 가면서도 읽을 수 있게 하라","reference":"하박국 2:2","category":"$undefined"},{"id":"22752","book":"하박국","book_name":"하박국","chapter":2,"verse":3,"text":"이 묵시는 정한 때가 있나니 그 종말이 속히 이르겠고 결코 거짓되지 아니하리라 비록 더딜지라도 기다리라 지체되지 않고 정녕 응하리라","reference":"하박국 2:3","category":"$undefined"},{"id":"22753","book":"하박국","book_name":"하박국","chapter":2,"verse":4,"text":"보라, 그의 마음은 교만하며 그의 속에서 정직하지 못하니라 그러나 의인은 그 믿음으로 말미암아 살리라 !","reference":"하박국 2:4","category":"$undefined"},{"id":"22754","book":"하박국","book_name":"하박국","chapter":2,"verse":5,"text":"그는 술을 즐기며 궤휼하며 교만하여 가만히 있지 아니하고 그 욕심을 음부처럼 넓히며 또 그는 사망같아서 족한 줄을 모르고 자기에게로 만국을 모으며 만민을 모으나니","reference":"하박국 2:5","category":"$undefined"},{"id":"22755","book":"하박국","book_name":"하박국","chapter":2,"verse":6,"text":"그 무리가 다 속담으로 그를 평론하며 조롱하는 시로 그를 풍자하지 않겠느냐 ? 곧 이르기를 화 있을진저 ! 자기 소유 아닌 것을 모으는 자여 ! 언제까지 이르겠느냐 ? 볼모 잡은 것으로 무겁게 짐진 자여 !","reference":"하박국 2:6","category":"$undefined"},{"id":"22756","book":"하박국","book_name":"하박국","chapter":2,"verse":7,"text":"너를 물 자들이 홀연히 일어나지 않겠느냐 네가 그들에게 노략을 당하지 않겠느냐 ?","reference":"하박국 2:7","category":"$undefined"},{"id":"22757","book":"하박국","book_name":"하박국","chapter":2,"verse":8,"text":"네가 여러 나라를 노략하였으므로 그 모든 민족의 남은 자가 너를 노략하리니 이는 네가 사람의 피를 흘렸음이요 또 땅에 성읍에 그 안의 모든 거민에게 강포를 행하였음이니라 하리라","reference":"하박국 2:8","category":"$undefined"},{"id":"22758","book":"하박국","book_name":"하박국","chapter":2,"verse":9,"text":"재앙을 피하기 위하여 높은데 깃들이려 하며 자기 집을 위하여 불의의 이를 취하는 자에게 화 있을찐저 !","reference":"하박국 2:9","category":"$undefined"},{"id":"22759","book":"하박국","book_name":"하박국","chapter":2,"verse":10,"text":"네가 여러 민족을 멸한 것이 네 집에 욕을 부르며 너로 네 영혼에게 죄를 범하게 하는 것이 되었도다","reference":"하박국 2:10","category":"$undefined"},{"id":"22760","book":"하박국","book_name":"하박국","chapter":2,"verse":11,"text":"담에서 돌이 부르짖고 집에서 들보가 응답하리라","reference":"하박국 2:11","category":"$undefined"},{"id":"22761","book":"하박국","book_name":"하박국","chapter":2,"verse":12,"text":"피로 읍을 건설하며 불의로 성을 건축하는 자에게 화 있을진저 !","reference":"하박국 2:12","category":"$undefined"},{"id":"22762","book":"하박국","book_name":"하박국","chapter":2,"verse":13,"text":"민족들이 불탈 것으로 수고하는 것과 열국이 헛된 일로 곤비하게 되는 것이 만군의 여호와께로서 말미암음이 아니냐 ?","reference":"하박국 2:13","category":"$undefined"},{"id":"22763","book":"하박국","book_name":"하박국","chapter":2,"verse":14,"text":"대저 물이 바다를 덮음 같이 여호와의 영광을 인정하는 것이 세상에 가득하리라","reference":"하박국 2:14","category":"$undefined"},{"id":"22764","book":"하박국","book_name":"하박국","chapter":2,"verse":15,"text":"이웃에게 술을 마시우되 자기의 분노를 더하여 그로 취케 하고 그 하체를 드러 내려 하는 자에게 화 있을진저 !","reference":"하박국 2:15","category":"$undefined"},{"id":"22765","book":"하박국","book_name":"하박국","chapter":2,"verse":16,"text":"네게 영광이 아니요 수치가 가득한즉 너도 마시고 너의 할례 아니한 것을 드러내라 여호와의 오른손의 잔이 네게로 돌아올 것이라 더러운 욕이 네 영광을 가리우리라","reference":"하박국 2:16","category":"$undefined"},{"id":"22766","book":"하박국","book_name":"하박국","chapter":2,"verse":17,"text":"대저 네가 레바논에 강포를 행한 것과 짐승을 두렵게하여 잔해한 것 곧 사람의 피를 흘리며 땅과 성읍과 그 모든 거민에게 강포를 행한 것이 네게로 돌아오리라","reference":"하박국 2:17","category":"$undefined"},{"id":"22767","book":"하박국","book_name":"하박국","chapter":2,"verse":18,"text":"새긴 우상은 그 새겨 만든 자에게 무엇이 유익하겠느냐 ? 부어 만든 우상은 거짓 스승이라 만든 자가 이 말하지 못하는 우상을 의지하니 무엇이 유익하겠느냐 ?","reference":"하박국 2:18","category":"$undefined"},{"id":"22768","book":"하박국","book_name":"하박국","chapter":2,"verse":19,"text":"나무더러 깨라 하며 말하지 못하는 돌더러 일어나라 하는 자에게 화 있을진저 ! 그 이는 금과 은으로 입힌 것인즉 그 속에는 생기가 도무지 없느니라","reference":"하박국 2:19","category":"$undefined"},{"id":"22769","book":"하박국","book_name":"하박국","chapter":2,"verse":20,"text":"오직 여호와는 그 성전에 계시니 온 천하는 그 앞에서 잠잠할지니라 !","reference":"하박국 2:20","category":"$undefined"}],"bookSlug":"habakkuk"}]
