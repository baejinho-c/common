2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":1,"verses":[{"id":"22096","book":"호세아","book_name":"호세아","chapter":1,"verse":1,"text":"웃시야와 요담과 아하스와 히스기야가 이어 유다 왕이 된 시대 곧 요아스의 아들 여로보암이 이스라엘 왕이 된 시대에 브에리의 아들 호세아에게 임한 여호와의 말씀이라","reference":"호세아 1:1","category":"$undefined"},{"id":"22097","book":"호세아","book_name":"호세아","chapter":1,"verse":2,"text":"여호와께서 비로소 호세아로 말씀하시니라 여호와께서 호세아에게 이르시되 너는 가서 음란한 아내를 취하여 음란한 자식들을 낳으라 이 나라가 여호와를 떠나 크게 행음함이니라","reference":"호세아 1:2","category":"$undefined"},{"id":"22098","book":"호세아","book_name":"호세아","chapter":1,"verse":3,"text":"이에 저가 가서 디블라임의 딸 고멜을 취하였더니 저가 잉태하여 아들을 낳으매","reference":"호세아 1:3","category":"$undefined"},{"id":"22099","book":"호세아","book_name":"호세아","chapter":1,"verse":4,"text":"여호와께서 호세아에게 이르시되 그 이름을 이스르엘이라 하라 조금 후에 내가 이스르엘의 피를 예후의 집에 갚으며 이스라엘 족속의 나라를 폐할 것임이니라","reference":"호세아 1:4","category":"$undefined"},{"id":"22100","book":"호세아","book_name":"호세아","chapter":1,"verse":5,"text":"그 날에 내가 이스르엘 골짜기에서 이스라엘의 활을 꺾으리라 하시니라","reference":"호세아 1:5","category":"$undefined"},{"id":"22101","book":"호세아","book_name":"호세아","chapter":1,"verse":6,"text":"고멜이 또 잉태하여 딸을 낳으매 여호와께서 호세아에게 이르시되 그 이름을 로루하마라 하라 내가 다시는 이스라엘 족속을 긍휼히 여겨서 사하지 않을 것임이니라","reference":"호세아 1:6","category":"$undefined"},{"id":"22102","book":"호세아","book_name":"호세아","chapter":1,"verse":7,"text":"그러나 내가 유다 족속을 긍휼히 여겨 저희 하나님 여호와로 구원하겠고 활과 칼이나 전쟁이나 말과 마병으로 구원하지 아니하리라 하시니라","reference":"호세아 1:7","category":"$undefined"},{"id":"22103","book":"호세아","book_name":"호세아","chapter":1,"verse":8,"text":"고멜이 로루하마를 젖뗀 후에 또 잉태하여 아들을 낳으매","reference":"호세아 1:8","category":"$undefined"},{"id":"22104","book":"호세아","book_name":"호세아","chapter":1,"verse":9,"text":"여호와께서 이르시되 그 이름을 로암미라 하라 너희는 내 백성이 아니요 나는 너희 하나님이 되지 아니할 것임이니라","reference":"호세아 1:9","category":"$undefined"},{"id":"22105","book":"호세아","book_name":"호세아","chapter":1,"verse":10,"text":"그러나 이스라엘 자손의 수가 바닷가의 모래같이 되어서 측량할 수도 없고 셀 수도 없을 것이며 전에 저희에게 이르기를 너희는 내 백성이 아니라 한 그곳에서 저희에게 이르기를 너희는 사신 하나님의 자녀라 할 것이라","reference":"호세아 1:10","category":"$undefined"},{"id":"22106","book":"호세아","book_name":"호세아","chapter":1,"verse":11,"text":"이에 유다 자손과 이스라엘 자손이 함께 모여 한 두목을 세우고 그 땅에서부터 올라 오리니 이스르엘의 날이 클 것임이로다","reference":"호세아 1:11","category":"$undefined"}],"bookSlug":"hosea"}]
