2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":10,"verses":[{"id":"22227","book":"호세아","book_name":"호세아","chapter":10,"verse":1,"text":"이스라엘은 열매 맺는 무성한 포도 나무라 그 열매가 많을수록 제단을 많게 하며 그 땅이 아름다울수록 주상을 아름답게 하도다","reference":"호세아 10:1","category":"$undefined"},{"id":"22228","book":"호세아","book_name":"호세아","chapter":10,"verse":2,"text":"저희가 두 마음을 품었으니 이제 죄를 받을 것이라 하나님이 그 제단을 쳐서 깨치시며 그 주상을 헐으시리라","reference":"호세아 10:2","category":"$undefined"},{"id":"22229","book":"호세아","book_name":"호세아","chapter":10,"verse":3,"text":"저희가 이제 이르기를 우리가 여호와를 두려워 아니하므로 우리에게 왕이 없거니와 왕이 우리를 위하여 무엇을 하리요 하리로다","reference":"호세아 10:3","category":"$undefined"},{"id":"22230","book":"호세아","book_name":"호세아","chapter":10,"verse":4,"text":"저희가 헛된 말을 내며 거짓 맹세를 발하여 언약을 세우니 그 재판이 밭이랑에 돋는 독한 인진같으리로다","reference":"호세아 10:4","category":"$undefined"},{"id":"22231","book":"호세아","book_name":"호세아","chapter":10,"verse":5,"text":"사마리아 거민이 벧아웬의 송아지를 인하여 두려워할것이라 그 백성이 슬퍼하며 그것을 기뻐하던 제사장들도 슬퍼하리니 이는 그 영광이 떠나감이며","reference":"호세아 10:5","category":"$undefined"},{"id":"22232","book":"호세아","book_name":"호세아","chapter":10,"verse":6,"text":"그 송아지는 앗수르로 옮겨다가 예물로 야렙 왕에게 드리리니 에브라임은 수치를 받을 것이요 이스라엘은 자기들의 계의를 부끄러워할 것이며","reference":"호세아 10:6","category":"$undefined"},{"id":"22233","book":"호세아","book_name":"호세아","chapter":10,"verse":7,"text":"사마리아 왕은 물 위에 거품 같이 멸망할 것이며","reference":"호세아 10:7","category":"$undefined"},{"id":"22234","book":"호세아","book_name":"호세아","chapter":10,"verse":8,"text":"이스라엘의 죄 된 아웬의 산당은 패괴되어 가시와 찔레가 그 단위에 날것이니 그 때에 저희가 산더러 우리를 가리우라 할 것이요 작은 산더러 우리 위에 무너지라 하리라","reference":"호세아 10:8","category":"$undefined"},{"id":"22235","book":"호세아","book_name":"호세아","chapter":10,"verse":9,"text":"이스라엘아 네가 기브아에 서서 흉악한 족속을 치는 전쟁을 거기서 면하였도다","reference":"호세아 10:9","category":"$undefined"},{"id":"22236","book":"호세아","book_name":"호세아","chapter":10,"verse":10,"text":"내가 원하는 때에 저희를 징계하리니 저희가 두 가지 죄에 걸릴때에 만민이 모여서 저희를 치리라","reference":"호세아 10:10","category":"$undefined"},{"id":"22237","book":"호세아","book_name":"호세아","chapter":10,"verse":11,"text":"에브라임은 마치 길들인 암소같아서 곡식 밟기를 좋아하나 내가 그 아름다운 목에 멍에를 메우고 그의 위에 사람을 태우리니 유다가 밭을 갈고 야곱이 흙덩이를 깨뜨리리라","reference":"호세아 10:11","category":"$undefined"},{"id":"22238","book":"호세아","book_name":"호세아","chapter":10,"verse":12,"text":"너희가 자기를 위하여 의를 심고 긍휼을 거두라 지금이 곧 여호와를 찾을 때니 너희 묵은 땅을 기경하라 마침내 여호와께서 임하사 의를 비처럼 너희에게 내리시리라","reference":"호세아 10:12","category":"$undefined"},{"id":"22239","book":"호세아","book_name":"호세아","chapter":10,"verse":13,"text":"너희는 악을 밭갈아 죄를 거두고 거짓 열매를 먹었나니 이는 네가 네 길과 네 용사의 많음을 의뢰하였음이라","reference":"호세아 10:13","category":"$undefined"},{"id":"22240","book":"호세아","book_name":"호세아","chapter":10,"verse":14,"text":"그러므로 너희 백성 중에 요란함이 일어나며 네 산성들이 다 훼파되되 살만이 전쟁의 날에 벧아벨을 훼파한 것같이 될 것이라 그 때에 어미와 자식이 함께 부숴졌도다","reference":"호세아 10:14","category":"$undefined"},{"id":"22241","book":"호세아","book_name":"호세아","chapter":10,"verse":15,"text":"너희의 큰 악을 인하여 벧엘이 이같이 너희에게 행하리니 이스라엘 왕이 새벽에 멸절하리로다","reference":"호세아 10:15","category":"$undefined"}],"bookSlug":"hosea"}]
