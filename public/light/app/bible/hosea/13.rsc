2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":13,"verses":[{"id":"22268","book":"호세아","book_name":"호세아","chapter":13,"verse":1,"text":"에브라임이 말을 발하면 사람이 떨었도다 저가 이스라엘 중에서 자기를 높이더니 바알로 인하여 범죄하므로 망하였거늘","reference":"호세아 13:1","category":"$undefined"},{"id":"22269","book":"호세아","book_name":"호세아","chapter":13,"verse":2,"text":"이제도 저희가 더욱 범죄하여 그 은으로 자기를 위하여 우상을 부어 만들되 자기의 공교함을 따라 우상을 만들었으며 그것은 다 장색이 만든 것이어늘 저희가 그것에 대하여 말하기를 제사를 드리는 자는 송아지의 입을 맞출 것이라 하도다","reference":"호세아 13:2","category":"$undefined"},{"id":"22270","book":"호세아","book_name":"호세아","chapter":13,"verse":3,"text":"이러므로 저희는 아침 구름 같으며 쉽게 사라지는 이슬 같으며 타작 마당에서 광풍에 날리우는 쭉정이 같으며 굴뚝에서 나가는 연기 같으리라","reference":"호세아 13:3","category":"$undefined"},{"id":"22271","book":"호세아","book_name":"호세아","chapter":13,"verse":4,"text":"그러나 네가 애굽 땅에서 나옴으로부터 나는 네 하나님 여호와라 나 밖에 네가 다른 신을 알지 말 것이라 나 외에는 구원자가 없느니라","reference":"호세아 13:4","category":"$undefined"},{"id":"22272","book":"호세아","book_name":"호세아","chapter":13,"verse":5,"text":"내가 광야 마른 땅에서 너를 권고하였거늘","reference":"호세아 13:5","category":"$undefined"},{"id":"22273","book":"호세아","book_name":"호세아","chapter":13,"verse":6,"text":"저희가 먹이운 대로 배부르며 배부름으로 마음이 교만하며 이로 인하여 나를 잊었느니라","reference":"호세아 13:6","category":"$undefined"},{"id":"22274","book":"호세아","book_name":"호세아","chapter":13,"verse":7,"text":"그러므로 내가 저희에게 사자같고 길가에서 기다리는 표범 같으니라","reference":"호세아 13:7","category":"$undefined"},{"id":"22275","book":"호세아","book_name":"호세아","chapter":13,"verse":8,"text":"내가 새끼 잃은 곰같이 저희를 만나 그 염통 꺼풀을 찢고 거기서 암사자같이 저희를 삼키리라 들짐승이 저희를 찢으리라","reference":"호세아 13:8","category":"$undefined"},{"id":"22276","book":"호세아","book_name":"호세아","chapter":13,"verse":9,"text":"이스라엘아 네가 패망하였나니 이는 너를 도와주는 나를 대적함이니라","reference":"호세아 13:9","category":"$undefined"},{"id":"22277","book":"호세아","book_name":"호세아","chapter":13,"verse":10,"text":"전에 네가 이르기를 내게 왕과 방백들을 주소서 하였느니라 네 모든 성읍에서 너를 구원할 자 네 왕이 이제 어디 있으며 네 재판장들이 어디 있느냐 ?","reference":"호세아 13:10","category":"$undefined"},{"id":"22278","book":"호세아","book_name":"호세아","chapter":13,"verse":11,"text":"내가 분노하므로 네게 왕을 주고 진노하므로 폐하였노라","reference":"호세아 13:11","category":"$undefined"},{"id":"22279","book":"호세아","book_name":"호세아","chapter":13,"verse":12,"text":"에브라임의 불의가 봉함되었고 그 죄가 저장되었나니","reference":"호세아 13:12","category":"$undefined"},{"id":"22280","book":"호세아","book_name":"호세아","chapter":13,"verse":13,"text":"해산하는 여인의 어려움이 저에게 임하리라 저는 어리석은 자식이로다 때가 임하였나니 산문에서 지체할 것이 아니니라","reference":"호세아 13:13","category":"$undefined"},{"id":"22281","book":"호세아","book_name":"호세아","chapter":13,"verse":14,"text":"내가 저희를 음부의 권세에서 속량하며 사망에서 구속하리니 사망아 네 재앙이 어디 있느냐 ? 음부야 네 멸망이 어디 있느냐 ? 뉘우침이 내 목전에 숨으리라","reference":"호세아 13:14","category":"$undefined"},{"id":"22282","book":"호세아","book_name":"호세아","chapter":13,"verse":15,"text":"저가 비록 형제 중에서 결실하나 동풍이 오리니 곧 광야에서 일어나는 여호와의 바람이라 그 근원이 마르며 그 샘이 마르고 그 적축한바 모든 보배의 그릇이 약탈되리로다","reference":"호세아 13:15","category":"$undefined"},{"id":"22283","book":"호세아","book_name":"호세아","chapter":13,"verse":16,"text":"사마리아가 그 하나님을 배반하였으므로 형벌을 당하여 칼에 엎드러질 것이요 그 어린 아이는 부숴뜨리우며 그 아이 밴 여인은 배가 갈리우리라","reference":"호세아 13:16","category":"$undefined"}],"bookSlug":"hosea"}]
