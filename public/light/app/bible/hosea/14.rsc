2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":14,"verses":[{"id":"22284","book":"호세아","book_name":"호세아","chapter":14,"verse":1,"text":"이스라엘아 네 하나님 여호와께로 돌아 오라 네가 불의함을 인하여 엎드러졌느니라","reference":"호세아 14:1","category":"$undefined"},{"id":"22285","book":"호세아","book_name":"호세아","chapter":14,"verse":2,"text":"너는 말씀을 가지고 여호와께로 돌아와서 아뢰기를 모든 불의를 제하시고 선한바를 받으소서 우리가 입술로 수송아지를 대신하여 주께 드리리이다","reference":"호세아 14:2","category":"$undefined"},{"id":"22286","book":"호세아","book_name":"호세아","chapter":14,"verse":3,"text":"우리가 앗수르의 구원을 의지하지 아니하며 말을 타지 아니하며 다시는 우리의 손으로 지은 것을 향하여 너희는 우리 신이라 하지 아니하오리니 이는 고아가 주께로 말미암아 긍휼을 얻음이니이다 할지니라","reference":"호세아 14:3","category":"$undefined"},{"id":"22287","book":"호세아","book_name":"호세아","chapter":14,"verse":4,"text":"내가 저희의 패역을 고치고 즐거이 저희를 사랑하리니 나의 진노가 저에게서 떠났음이니라","reference":"호세아 14:4","category":"$undefined"},{"id":"22288","book":"호세아","book_name":"호세아","chapter":14,"verse":5,"text":"내가 이스라엘에게 이슬과 같으리니 저가 백합화같이 피겠고 레바논 백향목같이 뿌리가 박힐것이라","reference":"호세아 14:5","category":"$undefined"},{"id":"22289","book":"호세아","book_name":"호세아","chapter":14,"verse":6,"text":"그 가지는 퍼지며 그 아름다움은 감람나무와 같고 그 향기는 레바논 백향목 같으리니","reference":"호세아 14:6","category":"$undefined"},{"id":"22290","book":"호세아","book_name":"호세아","chapter":14,"verse":7,"text":"그 그늘 아래 거하는 자가 돌아올지라 저희는 곡식같이 소성할 것이며 포도나무같이 꽃이 필 것이며 그 향기는 레바논의 포도주같이 되리라","reference":"호세아 14:7","category":"$undefined"},{"id":"22291","book":"호세아","book_name":"호세아","chapter":14,"verse":8,"text":"에브라임의 말이 내가 다시 우상과 무슨 상관이 있으리요 할지라 내가 저를 돌아보아 대답하기를 나는 푸른 잣나무 같으니 네가 나로 말미암아 열매를 얻으리라 하리라","reference":"호세아 14:8","category":"$undefined"},{"id":"22292","book":"호세아","book_name":"호세아","chapter":14,"verse":9,"text":"누가 지혜가 있어 이런 일을 깨달으며 누가 총명이 있어 이런 일을 알겠느냐 ? 여호와의 도는 정직하니 의인이라야 그 도에 행하리라 그러나 죄인은 그 도에 거쳐 넘어지리라","reference":"호세아 14:9","category":"$undefined"}],"bookSlug":"hosea"}]
