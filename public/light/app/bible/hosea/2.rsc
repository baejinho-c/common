2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":2,"verses":[{"id":"22107","book":"호세아","book_name":"호세아","chapter":2,"verse":1,"text":"너희 형제에게는 암미라 하고 너희 자매에게는 루하마라 하라","reference":"호세아 2:1","category":"$undefined"},{"id":"22108","book":"호세아","book_name":"호세아","chapter":2,"verse":2,"text":"너희 어미와 쟁론하고 쟁론하라 저는 내 아내가 아니요 나는 저의 남편이 아니라 저로 그 얼굴에서 음란을 제하게 하고 그 유방사이에서 음행을 제하게 하라","reference":"호세아 2:2","category":"$undefined"},{"id":"22109","book":"호세아","book_name":"호세아","chapter":2,"verse":3,"text":"그렇지 아니하면 내가 저를 벌거벗겨서 그 나던 날과 같게 할 것이요 저로 광야 같이 되게 하며 마른 땅같이 되게 하여 목말라 죽게 할 것이며","reference":"호세아 2:3","category":"$undefined"},{"id":"22110","book":"호세아","book_name":"호세아","chapter":2,"verse":4,"text":"내가 그 자녀를 긍휼히 여기지 아니하리니 이는 저희가 음란한 자식들임이니라","reference":"호세아 2:4","category":"$undefined"},{"id":"22111","book":"호세아","book_name":"호세아","chapter":2,"verse":5,"text":"저희의 어미는 행음하였고 저희를 배었던 자가 부끄러운 일을 행하였나니 대저 저가 이르기를 나는 나를 연애하는 자들을 따르리니 저희가 내 떡과, 내 물과, 내 양털과, 내 삼과, 내 기름과, 내 술들을 내게 준다 하였느니라","reference":"호세아 2:5","category":"$undefined"},{"id":"22112","book":"호세아","book_name":"호세아","chapter":2,"verse":6,"text":"그러므로 내가 가시로 그 길을 막으며 담을 쌓아 저로 그 길을 찾지 못하게 하리니","reference":"호세아 2:6","category":"$undefined"},{"id":"22113","book":"호세아","book_name":"호세아","chapter":2,"verse":7,"text":"저가 그 연애하는 자를 따라 갈지라도 미치지 못하며 저희를 찾을지라도 만나지 못할 것이라 그제야 저가 이르기를 내가 본 남편에게로 돌아가리니 그 때의 내 형편이 지금보다 나았음이라 하리라","reference":"호세아 2:7","category":"$undefined"},{"id":"22114","book":"호세아","book_name":"호세아","chapter":2,"verse":8,"text":"곡식과 새 포도주와 기름은 내가 저에게 준 것이요 저희가 바알을 위하여 쓴 은과 금도 내가 저에게 더하여 준 것이어늘 저가 알지 못하도다","reference":"호세아 2:8","category":"$undefined"},{"id":"22115","book":"호세아","book_name":"호세아","chapter":2,"verse":9,"text":"그러므로 그 시절에 내가 내 곡식을 도로 찾으며 그 시기에 내가 내 새 포도주를 도로 찾으며 또 저희 벌거벗은 몸을 가리울 내 양털과 내 삼을 빼앗으리라","reference":"호세아 2:9","category":"$undefined"},{"id":"22116","book":"호세아","book_name":"호세아","chapter":2,"verse":10,"text":"이제 내가 그 수치를 그 연애하는 자의 눈앞에 드러내리니 저를 내 손에서 건져낼 사람이 없으리라","reference":"호세아 2:10","category":"$undefined"},{"id":"22117","book":"호세아","book_name":"호세아","chapter":2,"verse":11,"text":"내가 그 모든 희락과 절기와 월삭과 안식일과 모든 명절을 폐하겠고","reference":"호세아 2:11","category":"$undefined"},{"id":"22118","book":"호세아","book_name":"호세아","chapter":2,"verse":12,"text":"저가 전에 이르기를 이것은 나를 연애하는 자들이 내게 준 값이라 하던 그 포도나무와 무화과나무를 거칠게 하여 수풀이 되게 하며 들짐승들로 먹게 하리라","reference":"호세아 2:12","category":"$undefined"},{"id":"22119","book":"호세아","book_name":"호세아","chapter":2,"verse":13,"text":"저가 귀고리와 패물로 장식하고 그 연애하는 자를 따라가서 나를 잊어버리고 향을 살라 바알들을 섬긴 시일을 따라 내가 저에게 벌을 주리라 나 여호와의 말이니라","reference":"호세아 2:13","category":"$undefined"},{"id":"22120","book":"호세아","book_name":"호세아","chapter":2,"verse":14,"text":"그러므로 내가 저를 개유하여 거친 들로 데리고 가서 말로 위로하고","reference":"호세아 2:14","category":"$undefined"},{"id":"22121","book":"호세아","book_name":"호세아","chapter":2,"verse":15,"text":"거기서 비로소 저의 포도원을 저에게 주고 아골 골짜기로 소망의 문을 삼아 주리니 저가 거기서 응대하기를 어렸을 때와 애굽 땅에서 올라오던 날과 같이 하리라","reference":"호세아 2:15","category":"$undefined"},{"id":"22122","book":"호세아","book_name":"호세아","chapter":2,"verse":16,"text":"여호와께서 이르시되 그 날에 네가 나를 내 남편이라 일컫고 다시는 내 바알이라 일컫지 아니하리라","reference":"호세아 2:16","category":"$undefined"},{"id":"22123","book":"호세아","book_name":"호세아","chapter":2,"verse":17,"text":"내가 바알들의 이름을 저의 입에서 제하여 다시는 그 이름을 기억하여 일컬음이 없게 하리라","reference":"호세아 2:17","category":"$undefined"},{"id":"22124","book":"호세아","book_name":"호세아","chapter":2,"verse":18,"text":"그 날에는 내가 저희를 위하여 들짐승과 공중의 새와 땅의 곤충으로 더불어 언약을 세우며 또 이 땅에서 활과 칼을 꺾어 전쟁을 없이 하고 저희로 평안히 눕게 하리라","reference":"호세아 2:18","category":"$undefined"},{"id":"22125","book":"호세아","book_name":"호세아","chapter":2,"verse":19,"text":"내가 네게 장가들어 영원히 살되 의와 공변됨과 은총과 긍휼히 여김으로 네게 장가들며","reference":"호세아 2:19","category":"$undefined"},{"id":"22126","book":"호세아","book_name":"호세아","chapter":2,"verse":20,"text":"진실함으로 네게 장가들리니 네가 여호와를 알리라","reference":"호세아 2:20","category":"$undefined"},{"id":"22127","book":"호세아","book_name":"호세아","chapter":2,"verse":21,"text":"여호와께서 가라사대 그 날에 내가 응하리라 나는 하늘에 응하고 하늘은 땅에 응하고","reference":"호세아 2:21","category":"$undefined"},{"id":"22128","book":"호세아","book_name":"호세아","chapter":2,"verse":22,"text":"땅은 곡식과 포도주와 기름에 응하고 또 이것들은 이스르엘에 응하리라","reference":"호세아 2:22","category":"$undefined"},{"id":"22129","book":"호세아","book_name":"호세아","chapter":2,"verse":23,"text":"내가 나를 위하여 이 땅에 심고 긍휼히 여김을 받지 못하였던 자를 긍휼히 여기며 내 백성 아니었던 자에게 향하여 이르기를 너는 내 백성이라 하리니 저희는 이르기를 주는 내 하나님이시라 하리라","reference":"호세아 2:23","category":"$undefined"}],"bookSlug":"hosea"}]
