2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":4,"verses":[{"id":"22135","book":"호세아","book_name":"호세아","chapter":4,"verse":1,"text":"이스라엘 자손들아 여호와의 말씀을 들으라 여호와께서 이 땅 거민과 쟁변하시나니 이 땅에는 진실도 없고 인애도 없고 하나님을 아는 지식도 없고","reference":"호세아 4:1","category":"$undefined"},{"id":"22136","book":"호세아","book_name":"호세아","chapter":4,"verse":2,"text":"오직 저주와, 사위와, 살인과, 투절과, 간음 뿐이요 강포하여 피가 피를 뒤대임이라","reference":"호세아 4:2","category":"$undefined"},{"id":"22137","book":"호세아","book_name":"호세아","chapter":4,"verse":3,"text":"그러므로 이 땅이 슬퍼하며 무릇 거기 거하는 자와 들짐승과 공중에 나는 새가 다 쇠잔할 것이요 바다의 고기도 없어지리라","reference":"호세아 4:3","category":"$undefined"},{"id":"22138","book":"호세아","book_name":"호세아","chapter":4,"verse":4,"text":"그러나 아무 사람이든지 다투지도 말며 책망하지도 말라 네 백성들이 제사장과 다투는 자같이 되었음이니라","reference":"호세아 4:4","category":"$undefined"},{"id":"22139","book":"호세아","book_name":"호세아","chapter":4,"verse":5,"text":"너는 낮에 거치겠고 너와 함께 있는 선지자는 밤에 거치리라 내가 네 어미를 멸하리라","reference":"호세아 4:5","category":"$undefined"},{"id":"22140","book":"호세아","book_name":"호세아","chapter":4,"verse":6,"text":"내 백성이 지식이 없으므로 망하는도다 네가 지식을 버렸으니 나도 너를 버려 내 제사장이 되지 못하게 할 것이요 네가 네 하나님의 율법을 잊었으니 나도 네 자녀들을 잊어버리리라","reference":"호세아 4:6","category":"$undefined"},{"id":"22141","book":"호세아","book_name":"호세아","chapter":4,"verse":7,"text":"저희는 번성할수록 내게 범죄하니 내가 저희의 영화를 변하여 욕이 되게 하리라","reference":"호세아 4:7","category":"$undefined"},{"id":"22142","book":"호세아","book_name":"호세아","chapter":4,"verse":8,"text":"저희가 내 백성의 속죄 제물을 먹고 그 마음을 저희의 죄악에 두는도다","reference":"호세아 4:8","category":"$undefined"},{"id":"22143","book":"호세아","book_name":"호세아","chapter":4,"verse":9,"text":"장차는 백성이나 제사장이나 일반이라 내가 그 소행대로 벌하며 그 소위대로 갚으리라","reference":"호세아 4:9","category":"$undefined"},{"id":"22144","book":"호세아","book_name":"호세아","chapter":4,"verse":10,"text":"저희가 먹어도 배부르지 아니하며 행음하여도 수효가 더하지 못하니 이는 여호와 좇기를 그쳤음이니라","reference":"호세아 4:10","category":"$undefined"},{"id":"22145","book":"호세아","book_name":"호세아","chapter":4,"verse":11,"text":"음행과 묵은 포도주와 새 포도주가 마음을 빼앗느니라","reference":"호세아 4:11","category":"$undefined"},{"id":"22146","book":"호세아","book_name":"호세아","chapter":4,"verse":12,"text":"내 백성이 나무를 향하여 묻고 그 막대기는 저희에게 고하나니 이는 저희가 음란한 마음에 미혹되어 그 하나님의 수하를 음란하듯 떠났음이니라","reference":"호세아 4:12","category":"$undefined"},{"id":"22147","book":"호세아","book_name":"호세아","chapter":4,"verse":13,"text":"저희가 산 꼭대기에서 제사를 드리며 작은 산 위에서 분향하되 참나무와 버드나무와 상수리나무 아래서 하니 이는 그 나무 그늘이 아름다움이라 이러므로 너희 딸들이 행음하며 너희 며느리들이 간음을 행하는도다","reference":"호세아 4:13","category":"$undefined"},{"id":"22148","book":"호세아","book_name":"호세아","chapter":4,"verse":14,"text":"너희 딸들이 행음하며 너희 며느리들이 간음하여도 내가 벌하지 아니하리니 이는 남자들도 창기와 함께 나가며 음부와 함께 희생을 드림이니라 깨닫지 못하는 백성은 패망하리라","reference":"호세아 4:14","category":"$undefined"},{"id":"22149","book":"호세아","book_name":"호세아","chapter":4,"verse":15,"text":"이스라엘아 너는 행음하여도 유다는 죄를 범치 말아야 할 것이라 너희는 길갈로 가지 말며 벧아웬으로 올라가지 말며 여호와의 사심을 가리켜 맹세하지 말지어다","reference":"호세아 4:15","category":"$undefined"},{"id":"22150","book":"호세아","book_name":"호세아","chapter":4,"verse":16,"text":"이스라엘은 완강한 암소처럼 완강하니 이제 여호와께서 어린 양을 넓은 들에서 먹임같이 저희를 먹이시겠느냐 ?","reference":"호세아 4:16","category":"$undefined"},{"id":"22151","book":"호세아","book_name":"호세아","chapter":4,"verse":17,"text":"에브라임이 우상과 연합하였으니 버려두라","reference":"호세아 4:17","category":"$undefined"},{"id":"22152","book":"호세아","book_name":"호세아","chapter":4,"verse":18,"text":"저희가 마시기를 다 하고는 행음하기를 마지 아니하며 그 방백들은 수치를 기뻐하느니라","reference":"호세아 4:18","category":"$undefined"},{"id":"22153","book":"호세아","book_name":"호세아","chapter":4,"verse":19,"text":"바람이 그 날개로 저를 쌌나니 저희가 그 제물로 인하여 수치를 당하리라","reference":"호세아 4:19","category":"$undefined"}],"bookSlug":"hosea"}]
