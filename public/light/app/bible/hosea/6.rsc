2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":6,"verses":[{"id":"22169","book":"호세아","book_name":"호세아","chapter":6,"verse":1,"text":"오라 우리가 여호와께로 돌아가자 여호와께서 우리를 찢으셨으나 도로 낫게 하실 것이요 우리를 치셨으나 싸매어 주실 것임이라","reference":"호세아 6:1","category":"$undefined"},{"id":"22170","book":"호세아","book_name":"호세아","chapter":6,"verse":2,"text":"여호와께서 이틀 후에 우리를 살리시며 제 삼일에 우리를 일으키시리니 우리가 그 앞에서 살리라","reference":"호세아 6:2","category":"$undefined"},{"id":"22171","book":"호세아","book_name":"호세아","chapter":6,"verse":3,"text":"그러므로 우리가 여호와를 알자 힘써 여호와를 알자 그의 나오심은 새벽 빛같이 일정하니 비와 같이, 땅을 적시는 늦은 비와 같이 우리에게 임하시리라 하리라","reference":"호세아 6:3","category":"$undefined"},{"id":"22172","book":"호세아","book_name":"호세아","chapter":6,"verse":4,"text":"에브라임아 내가 네게 어떻게 하랴 유다야 내가 네게 어떻게 하랴 너희의 인애가 아침 구름이나 쉬 없어지는 이슬 같도다","reference":"호세아 6:4","category":"$undefined"},{"id":"22173","book":"호세아","book_name":"호세아","chapter":6,"verse":5,"text":"그러므로 내가 선지자들로 저희를 치고 내 입의 말로 저희를 죽였노니 내 심판은 발하는 빛과 같으니라","reference":"호세아 6:5","category":"$undefined"},{"id":"22174","book":"호세아","book_name":"호세아","chapter":6,"verse":6,"text":"나는 인애를 원하고 제사를 원치 아니하며 번제보다 하나님을 아는 것을 원하노라","reference":"호세아 6:6","category":"$undefined"},{"id":"22175","book":"호세아","book_name":"호세아","chapter":6,"verse":7,"text":"저희는 아담처럼 언약을 어기고 거기서 내게 패역을 행하였느니라","reference":"호세아 6:7","category":"$undefined"},{"id":"22176","book":"호세아","book_name":"호세아","chapter":6,"verse":8,"text":"길르앗은 행악자의 고을이라 피발자취가 편만하도다","reference":"호세아 6:8","category":"$undefined"},{"id":"22177","book":"호세아","book_name":"호세아","chapter":6,"verse":9,"text":"강도떼가 사람을 기다림같이 제사장의 무리가 세겜 길에서 살인하니 저희가 사악을 행하였느니라","reference":"호세아 6:9","category":"$undefined"},{"id":"22178","book":"호세아","book_name":"호세아","chapter":6,"verse":10,"text":"내가 이스라엘 집에서 가증한 일을 보았나니 거기서 에브라임은 행음하였고 이스라엘은 더럽혔느니라","reference":"호세아 6:10","category":"$undefined"},{"id":"22179","book":"호세아","book_name":"호세아","chapter":6,"verse":11,"text":"유다여 내가 내 백성의 사로잡힘을 돌이킬 때에 네게도 추수할 일을 정하였느니라","reference":"호세아 6:11","category":"$undefined"}],"bookSlug":"hosea"}]
