2:["$","$L11",null,{"book":{"id":"hosea","name":"호세아","chapters":14,"testament":"old"},"chapter":7,"verses":[{"id":"22180","book":"호세아","book_name":"호세아","chapter":7,"verse":1,"text":"내가 이스라엘을 치료하려 할 때에 에브라임의 죄와 사마리아의 악이 드러나도다 저희는 궤사를 행하며 안으로 들어가 도적질 하고 밖으로 떼 지어 노략질하며","reference":"호세아 7:1","category":"$undefined"},{"id":"22181","book":"호세아","book_name":"호세아","chapter":7,"verse":2,"text":"내가 그 여러 악을 기억하였음을 저희가 마음에 생각지 아니하거니와 이제 그 행위가 저희를 에워싸고 내 목전에 있도다","reference":"호세아 7:2","category":"$undefined"},{"id":"22182","book":"호세아","book_name":"호세아","chapter":7,"verse":3,"text":"저희가 그 악으로 왕을, 그 거짓말로 방백들을 기쁘게 하도다","reference":"호세아 7:3","category":"$undefined"},{"id":"22183","book":"호세아","book_name":"호세아","chapter":7,"verse":4,"text":"저희는 다 간음하는자라 빵 만드는 자에게 달궈진 화덕과 같도다 저가 반죽을 뭉침으로 발교되기까지만 불 일으키기를 그칠 뿐이니라","reference":"호세아 7:4","category":"$undefined"},{"id":"22184","book":"호세아","book_name":"호세아","chapter":7,"verse":5,"text":"우리 왕의 날에 방백들이 술의 뜨거움을 인하여 병이 나며 왕은 오만한 자들로 더불어 악수하는도다","reference":"호세아 7:5","category":"$undefined"},{"id":"22185","book":"호세아","book_name":"호세아","chapter":7,"verse":6,"text":"저희는 엎드리어 기다릴 때에 그 마음을 화덕 같이 예비하니 마치 빵 만드는 자가 밤새도록 자고 아침에 피우는 불의 일어나는 것 같도다","reference":"호세아 7:6","category":"$undefined"},{"id":"22186","book":"호세아","book_name":"호세아","chapter":7,"verse":7,"text":"저희가 다 화덕같이 뜨거워져서 그 재판장들을 삼키며 그 왕들을 다 엎드러지게 하며 저희 중에는 내게 부르짖는 자가 하나도 없도다","reference":"호세아 7:7","category":"$undefined"},{"id":"22187","book":"호세아","book_name":"호세아","chapter":7,"verse":8,"text":"에브라임이 열방에 혼잡되니 저는 곧 뒤집지 않은 전병이로다","reference":"호세아 7:8","category":"$undefined"},{"id":"22188","book":"호세아","book_name":"호세아","chapter":7,"verse":9,"text":"저는 이방인에게 그 힘이 삼키웠으나 알지 못하고 백발이 얼룩 얼룩할지라도 깨닫지 못하는도다","reference":"호세아 7:9","category":"$undefined"},{"id":"22189","book":"호세아","book_name":"호세아","chapter":7,"verse":10,"text":"이스라엘의 교만은 그 얼굴에 증거가 되나니 저희가 이 모든 일을 당하여도 그 하나님 여호와께로 돌아오지 아니하며 구하지 아니하도다","reference":"호세아 7:10","category":"$undefined"},{"id":"22190","book":"호세아","book_name":"호세아","chapter":7,"verse":11,"text":"에브라임은 어리석은 비둘기 같이 지혜가 없어서 애굽을 향하여 부르짖으며 앗수르로 가는도다","reference":"호세아 7:11","category":"$undefined"},{"id":"22191","book":"호세아","book_name":"호세아","chapter":7,"verse":12,"text":"저희가 갈 때에 내가 나의 그물을 그 위에 쳐서 공중의 새처럼 떨어뜨리고 전에 그 공회에 들려준 대로 저희를 징계하리라","reference":"호세아 7:12","category":"$undefined"},{"id":"22192","book":"호세아","book_name":"호세아","chapter":7,"verse":13,"text":"화 있을진저 저희가 나를 떠나 그릇 갔음이니라 패망할진저 저희가 내게 범죄하였음이니라 내가 저희를 구속하려 하나 저희가 나를 거스려 거짓을 말하고","reference":"호세아 7:13","category":"$undefined"},{"id":"22193","book":"호세아","book_name":"호세아","chapter":7,"verse":14,"text":"성심으로 나를 부르지 아니하였으며 오직 침상에서 슬피 부르짖으며 곡식과 새 포도주를 인하여 모이며 나를 거역하는도다","reference":"호세아 7:14","category":"$undefined"},{"id":"22194","book":"호세아","book_name":"호세아","chapter":7,"verse":15,"text":"내가 저희 팔을 연습시켜 강건케 하였으나 저희는 내게 대하여 악을 꾀하는도다","reference":"호세아 7:15","category":"$undefined"},{"id":"22195","book":"호세아","book_name":"호세아","chapter":7,"verse":16,"text":"저희가 돌아오나 높으신 자에게로 돌아 오지 아니하니 속이는 활과 같으며 그 방백들은 그 혀의 거친 말로 인하여 칼에 엎드러지리니 이것이 애굽 땅에서 조롱거리가 되리라","reference":"호세아 7:16","category":"$undefined"}],"bookSlug":"hosea"}]
