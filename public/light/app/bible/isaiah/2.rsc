2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":2,"verses":[{"id":"17687","book":"이사야","book_name":"이사야","chapter":2,"verse":1,"text":"아모스의 아들 이사야가 받은바 유다와 예루살렘에 관한 말씀이라","reference":"이사야 2:1","category":"$undefined"},{"id":"17688","book":"이사야","book_name":"이사야","chapter":2,"verse":2,"text":"말일에 여호와의 전의 산이 모든 산 꼭대기에 굳게 설 것이요 모든 작은 산 위에 뛰어나리니 만방이 그리로 모여들 것이라","reference":"이사야 2:2","category":"$undefined"},{"id":"17689","book":"이사야","book_name":"이사야","chapter":2,"verse":3,"text":"많은 백성이 가며 이르기를 오라 우리가 여호와의 산에 오르며 야곱의 하나님의 전에 이르자 그가 그 도로 우리에게 가르치실 것이라 우리가 그 길로 행하리라 하리니 이는 율법이 시온에서부터 나올 것이요 여호와의 말씀이 예루살렘에서부터 나올 것임이니라","reference":"이사야 2:3","category":"$undefined"},{"id":"17690","book":"이사야","book_name":"이사야","chapter":2,"verse":4,"text":"그가 열방 사이에 판단하시며 많은 백성을 판결하시리니 무리가 그 칼을 쳐서 보습을 만들고 그 창을 쳐서 낫을 만들 것이며 이 나라와 저 나라가 다시는 칼을 들고 서로 치지 아니하며 다시는 전쟁을 연습지 아니하리라","reference":"이사야 2:4","category":"$undefined"},{"id":"17691","book":"이사야","book_name":"이사야","chapter":2,"verse":5,"text":"야곱 족속아 오라 ! 우리가 여호와의 빛에 행하자","reference":"이사야 2:5","category":"$undefined"},{"id":"17692","book":"이사야","book_name":"이사야","chapter":2,"verse":6,"text":"주께서 주의 백성 야곱 족속을 버리셨음은 그들에게 동방 풍속이 가득하며 그들이 블레셋 사람같이 술객이 되며 이방인으로 더불어 손을 잡아 언약하였음이라","reference":"이사야 2:6","category":"$undefined"},{"id":"17693","book":"이사야","book_name":"이사야","chapter":2,"verse":7,"text":"그 땅에는 은금이 가득하고 보화가 무한하며 그 땅에는 마필이 가득하고 병거가 무수하며","reference":"이사야 2:7","category":"$undefined"},{"id":"17694","book":"이사야","book_name":"이사야","chapter":2,"verse":8,"text":"그 땅에는 우상도 가득하므로 그들이 자기 손으로 짓고 자기 손가락으로 만든 것을 공경하여","reference":"이사야 2:8","category":"$undefined"},{"id":"17695","book":"이사야","book_name":"이사야","chapter":2,"verse":9,"text":"천한 자도 절하며 귀한 자도 굴복하오니 그들을 용서하지 마옵소서","reference":"이사야 2:9","category":"$undefined"},{"id":"17696","book":"이사야","book_name":"이사야","chapter":2,"verse":10,"text":"너희는 바위 틈에 들어가며 진토에 숨어 여호와의 위엄과 그 광대하심의 영광을 피하라","reference":"이사야 2:10","category":"$undefined"},{"id":"17697","book":"이사야","book_name":"이사야","chapter":2,"verse":11,"text":"그 날에 눈이 높은 자가 낮아지며 교만한 자가 굴복되고 여호와께서 홀로 높임을 받으시리라","reference":"이사야 2:11","category":"$undefined"},{"id":"17698","book":"이사야","book_name":"이사야","chapter":2,"verse":12,"text":"대저 만군의 여호와의 한 날이 모든 교만자와 거만자와 자고한 자에게 임하여 그들로 낮아지게 하고","reference":"이사야 2:12","category":"$undefined"},{"id":"17699","book":"이사야","book_name":"이사야","chapter":2,"verse":13,"text":"또 레바논의 높고 높은 모든 백향목과 바산의 모든 상수리 나무와","reference":"이사야 2:13","category":"$undefined"},{"id":"17700","book":"이사야","book_name":"이사야","chapter":2,"verse":14,"text":"모든 높은 산과 모든 솟아오른 작은 산과","reference":"이사야 2:14","category":"$undefined"},{"id":"17701","book":"이사야","book_name":"이사야","chapter":2,"verse":15,"text":"모든 높은 망대와 견고한 성벽과","reference":"이사야 2:15","category":"$undefined"},{"id":"17702","book":"이사야","book_name":"이사야","chapter":2,"verse":16,"text":"다시스의 모든 배와 모든 아름다운 조각물에 임하리니","reference":"이사야 2:16","category":"$undefined"},{"id":"17703","book":"이사야","book_name":"이사야","chapter":2,"verse":17,"text":"그 날에 자고한 자는 굴복되며 교만한 자는 낮아지고 여호와께서 홀로 높임을 받으실 것이요","reference":"이사야 2:17","category":"$undefined"},{"id":"17704","book":"이사야","book_name":"이사야","chapter":2,"verse":18,"text":"우상들은 온전히 없어질 것이며","reference":"이사야 2:18","category":"$undefined"},{"id":"17705","book":"이사야","book_name":"이사야","chapter":2,"verse":19,"text":"사람들이 암혈과 토굴로 들어가서 여호와께서 일어나사 땅을 진동시키는 그의 위엄과 그 광대하심의 영광을 피할 것이라","reference":"이사야 2:19","category":"$undefined"},{"id":"17706","book":"이사야","book_name":"이사야","chapter":2,"verse":20,"text":"사람이 숭배하려고 만들었던 그 은 우상과 금 우상을 그 날에 두더쥐와 박쥐에게 던지고","reference":"이사야 2:20","category":"$undefined"},{"id":"17707","book":"이사야","book_name":"이사야","chapter":2,"verse":21,"text":"암혈과 험악한 바위틈에 들어가서 여호와께서 일어나사 땅을 진동시키시는 그의 위엄과 그 광대하심의 영광을 피하리라","reference":"이사야 2:21","category":"$undefined"},{"id":"17708","book":"이사야","book_name":"이사야","chapter":2,"verse":22,"text":"너희는 인생을 의지하지 말라 그의 호흡은 코에 있나니 수에 칠 가치가 어디 있느뇨","reference":"이사야 2:22","category":"$undefined"}],"bookSlug":"isaiah"}]
