2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":28,"verses":[{"id":"18166","book":"이사야","book_name":"이사야","chapter":28,"verse":1,"text":"취한 자 에브라임의 교만한 면류관이여 화 있을진저 술에 빠진 자의 성 곧 영화로운 관 같이 기름진 골짜기 꼭대기에 세운 성이여 쇠잔해가는 꽃 같으니 화 있을진저","reference":"이사야 28:1","category":"$undefined"},{"id":"18167","book":"이사야","book_name":"이사야","chapter":28,"verse":2,"text":"보라, 주께 있는 강하고 힘 있는 자가 쏟아지는 우박 같이 파괴하는 광풍 같이 큰 물의 창일함 같이 손으로 그 면류관을 땅에 던지리니","reference":"이사야 28:2","category":"$undefined"},{"id":"18168","book":"이사야","book_name":"이사야","chapter":28,"verse":3,"text":"에브라임의 취한 자의 교만한 면류관이 발에 밟힐 것이라","reference":"이사야 28:3","category":"$undefined"},{"id":"18169","book":"이사야","book_name":"이사야","chapter":28,"verse":4,"text":"그 기름진 골짜기 꼭대기에 있는 그 영화의 쇠잔해 가는 꽃이 여름 전에 처음 익은 무화과와 같으니 보는 자가 그것을 보고 얼른 따서 먹으리로다","reference":"이사야 28:4","category":"$undefined"},{"id":"18170","book":"이사야","book_name":"이사야","chapter":28,"verse":5,"text":"그 날에 만군의 여호와께서 그 남은 백성에게 영화로운 면류관이 되시며 아름다운 화관이 되실 것이라","reference":"이사야 28:5","category":"$undefined"},{"id":"18171","book":"이사야","book_name":"이사야","chapter":28,"verse":6,"text":"재판석에 앉은 자에게는 판결하는 신이 되시며 성문에서 싸움을 물리치는 자에게는 힘이 되시리로다 마는","reference":"이사야 28:6","category":"$undefined"},{"id":"18172","book":"이사야","book_name":"이사야","chapter":28,"verse":7,"text":"이 유다 사람들도 포도주로 인하여 옆걸음 치며 독주로 인하여 비틀거리며 제사장과 선지자도 독주로 인하여 옆걸음 치며 포도주에 빠지며 독주로 인하여 비틀거리며 이상을 그릇 풀며 재판할때에 실수하나니","reference":"이사야 28:7","category":"$undefined"},{"id":"18173","book":"이사야","book_name":"이사야","chapter":28,"verse":8,"text":"모든 상에는 토한 것 더러운 것이 가득하고 깨끗한 곳이 없도다","reference":"이사야 28:8","category":"$undefined"},{"id":"18174","book":"이사야","book_name":"이사야","chapter":28,"verse":9,"text":"그들이 이르기를 그가 뉘게 지식을 가르치며 뉘게 도를 전하여 깨닫게 하려는가 젖 떨어져 품을 떠난 자들에게 하려는가","reference":"이사야 28:9","category":"$undefined"},{"id":"18175","book":"이사야","book_name":"이사야","chapter":28,"verse":10,"text":"대저 경계에 경계를 더하며 경계에 경계를 더하며 교훈에 교훈을 더하며 교훈에 교훈을 더하되 여기서도 조금, 저기서도 조금하는구나 하는도다","reference":"이사야 28:10","category":"$undefined"},{"id":"18176","book":"이사야","book_name":"이사야","chapter":28,"verse":11,"text":"그러므로 생소한 입술과 다른 방언으로 이 백성에게 말씀하시리라","reference":"이사야 28:11","category":"$undefined"},{"id":"18177","book":"이사야","book_name":"이사야","chapter":28,"verse":12,"text":"전에 그들에게 이르시기를 이것이 너희 안식이요 이것이 너희 상쾌함이니 너희는 곤비한 자에게 안식을 주라 하셨으나 그들이 듣지 아니하였으므로","reference":"이사야 28:12","category":"$undefined"},{"id":"18178","book":"이사야","book_name":"이사야","chapter":28,"verse":13,"text":"여호와께서 그들에게 말씀하시되 경계에 경계를 더하며 경계에 경계를 더하며 교훈에 교훈을 더하며 교훈에 교훈을 더하고 여기서도 조금, 저기서도 조금 하사 그들로 가다가 뒤로 넘어져 부러지며 걸리며 잡히게 하시리라","reference":"이사야 28:13","category":"$undefined"},{"id":"18179","book":"이사야","book_name":"이사야","chapter":28,"verse":14,"text":"이러므로 예루살렘에 있는 이 백성을 치리하는 너희 경만한 자여 여호와의 말씀을 들을지어다","reference":"이사야 28:14","category":"$undefined"},{"id":"18180","book":"이사야","book_name":"이사야","chapter":28,"verse":15,"text":"너희 말이 우리는 사망과 언약하였고 음부와 맹약하였은즉 넘치는 재앙이 유행할지라도 우리에게 미치지 못하리니 우리는 거짓으로 우리 피난처를 삼았고 허위 아래 우리를 숨겼음이라 하는도다","reference":"이사야 28:15","category":"$undefined"},{"id":"18181","book":"이사야","book_name":"이사야","chapter":28,"verse":16,"text":"그러므로 주 여호와께서 가라사대 보라 내가 한 돌을 시온에 두어 기초를 삼았노니 곧 시험한 돌이요 귀하고 견고한 기초 돌이라 그것을 믿는 자는 급절하게 되지 아니하리로다","reference":"이사야 28:16","category":"$undefined"},{"id":"18182","book":"이사야","book_name":"이사야","chapter":28,"verse":17,"text":"나는 공평으로 줄을 삼고 의로 추를 삼으니 우박이 거짓의 피난처를 소탕하며 물이 그 숨는 곳에 넘칠 것인즉","reference":"이사야 28:17","category":"$undefined"},{"id":"18183","book":"이사야","book_name":"이사야","chapter":28,"verse":18,"text":"너희의 사망으로 더불어 세운 언약이 폐하며 음부로 더불어 맺은 맹약이 서지 못하여 넘치는 재앙이 유행할 때에 너희가 그것에게 밟힘을 당할 것이라","reference":"이사야 28:18","category":"$undefined"},{"id":"18184","book":"이사야","book_name":"이사야","chapter":28,"verse":19,"text":"그것이 유행할 때마다 너희를 잡을 것이니 아침마다 유행하고 주야로 유행한즉 그 전하는 도를 깨닫는 것이 오직 두려움이라","reference":"이사야 28:19","category":"$undefined"},{"id":"18185","book":"이사야","book_name":"이사야","chapter":28,"verse":20,"text":"침상이 짧아서 능히 몸을 펴지 못하며 이불이 좁아서 능히 몸을 싸지 못함 같으리라 하셨나니","reference":"이사야 28:20","category":"$undefined"},{"id":"18186","book":"이사야","book_name":"이사야","chapter":28,"verse":21,"text":"대저 여호와께서 브라심산에서와 같이 일어나시며 기브온 골짜기에서와 같이 진노하사 자기 일을 행하시리니 그 일이 비상할 것이며 자기 공을 이루시리니 그 공이 기이할 것임이라","reference":"이사야 28:21","category":"$undefined"},{"id":"18187","book":"이사야","book_name":"이사야","chapter":28,"verse":22,"text":"그러므로 너희는 경만한 자가 되지 말라 너희 결박이 우심할까 하노라 대저 온 땅을 멸망시키기로 작정하신 것을 내가 만군의 주 여호와께로서 들었느니라","reference":"이사야 28:22","category":"$undefined"},{"id":"18188","book":"이사야","book_name":"이사야","chapter":28,"verse":23,"text":"너희는 귀를 기울여 내 목소리를 들으라 자세히 내 말을 들으라","reference":"이사야 28:23","category":"$undefined"},{"id":"18189","book":"이사야","book_name":"이사야","chapter":28,"verse":24,"text":"파종하려고 가는 자가 어찌 끊이지 않고 갈기만 하겠느냐 그 땅을 개간하며 고르게만 하겠느냐","reference":"이사야 28:24","category":"$undefined"},{"id":"18190","book":"이사야","book_name":"이사야","chapter":28,"verse":25,"text":"지면을 이미 평평히 하였으면 소회향을 뿌리며 대회향을 뿌리며 소맥을 줄줄이 심으며 대맥을 정한 곳에 심으며 귀리를 그 가에 심지 않겠느냐","reference":"이사야 28:25","category":"$undefined"},{"id":"18191","book":"이사야","book_name":"이사야","chapter":28,"verse":26,"text":"이는 그의 하나님이 그에게 적당한 방법으로 보이사 가르치셨음이며","reference":"이사야 28:26","category":"$undefined"},{"id":"18192","book":"이사야","book_name":"이사야","chapter":28,"verse":27,"text":"소회향은 도리깨로 떨지 아니하며 대회향에는 수레 바퀴를 굴리지 아니하고 소회향은 작대기로 떨고 대회향은 막대기로 떨며","reference":"이사야 28:27","category":"$undefined"},{"id":"18193","book":"이사야","book_name":"이사야","chapter":28,"verse":28,"text":"곡식은 부수는가, 아니라 늘 떨기만 하지 아니하고 그것에 수레 바퀴를 굴리고 그것을 말굽으로 밟게 할지라도 부수지는 아니하나니","reference":"이사야 28:28","category":"$undefined"},{"id":"18194","book":"이사야","book_name":"이사야","chapter":28,"verse":29,"text":"이도 만군의 여호와께로서 난 것이라 그의 모략은 기묘하며 지혜는 광대하니라","reference":"이사야 28:29","category":"$undefined"}],"bookSlug":"isaiah"}]
