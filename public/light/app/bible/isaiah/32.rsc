2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":32,"verses":[{"id":"18261","book":"이사야","book_name":"이사야","chapter":32,"verse":1,"text":"보라 장차 한 왕이 의로 통치할 것이요 방백들이 공평으로 정사할 것이며","reference":"이사야 32:1","category":"$undefined"},{"id":"18262","book":"이사야","book_name":"이사야","chapter":32,"verse":2,"text":"또 그 사람은 광풍을 피하는 곳 폭우를 가리우는 곳 같을 것이며 마른 땅에 냇물 같을 것이며 곤비한 땅에 큰 바위 그늘 같으리니","reference":"이사야 32:2","category":"$undefined"},{"id":"18263","book":"이사야","book_name":"이사야","chapter":32,"verse":3,"text":"보는 자의 눈이 감기지 아니할 것이요 듣는 자의 귀가 기울어질 것이며","reference":"이사야 32:3","category":"$undefined"},{"id":"18264","book":"이사야","book_name":"이사야","chapter":32,"verse":4,"text":"조급한 자의 마음이 지식을 깨닫고 어눌한 자의 혀가 민첩하여 말을 분명히 할 것이라","reference":"이사야 32:4","category":"$undefined"},{"id":"18265","book":"이사야","book_name":"이사야","chapter":32,"verse":5,"text":"어리석은 자를 다시 존귀하다 칭하지 아니하겠고 궤휼한 자를 다시 정대하다 말하지 아니하리니","reference":"이사야 32:5","category":"$undefined"},{"id":"18266","book":"이사야","book_name":"이사야","chapter":32,"verse":6,"text":"이는 어리석은 자는 어리석은 것을 말하며 그 마음에 불의를 품어 간사를 행하며 패역한 말로 여호와를 거스리며 주린 자의 심령을 비게 하며 목마른 자의 마시는 것을 없어지게 함이며","reference":"이사야 32:6","category":"$undefined"},{"id":"18267","book":"이사야","book_name":"이사야","chapter":32,"verse":7,"text":"궤휼한 자는 그 그릇이 악하여 악한 계획을 베풀어 거짓말로 가련한 자를 멸하며 빈핍한 자가 말을 바르게 할지라도 그리함이어니와","reference":"이사야 32:7","category":"$undefined"},{"id":"18268","book":"이사야","book_name":"이사야","chapter":32,"verse":8,"text":"고명한 자는 고명한 일을 도모하나니 그는 항상 고명한 일에 서리라","reference":"이사야 32:8","category":"$undefined"},{"id":"18269","book":"이사야","book_name":"이사야","chapter":32,"verse":9,"text":"너희 안일한 부녀들아 일어나 내 목소리를 들을지어다 너희 염려없는 딸들아 내 말에 귀를 기울일지라","reference":"이사야 32:9","category":"$undefined"},{"id":"18270","book":"이사야","book_name":"이사야","chapter":32,"verse":10,"text":"너희 염려 없는 여자들아 일년 남짓이 지나면 너희가 당황하여 하리니 포도 수확이 없으며 열매 거두는 기한이 이르지 않을 것임이니라","reference":"이사야 32:10","category":"$undefined"},{"id":"18271","book":"이사야","book_name":"이사야","chapter":32,"verse":11,"text":"너희 안일한 여자들아 떨지어다 너희 염려 없는 자들아 당황하여 할지어다 옷을 벗어 몸을 드러내고 베로 허리를 동일지이다","reference":"이사야 32:11","category":"$undefined"},{"id":"18272","book":"이사야","book_name":"이사야","chapter":32,"verse":12,"text":"좋은 밭을 위하며 열매 많은 포도나무를 위하여 가슴을 치게 될것이니라","reference":"이사야 32:12","category":"$undefined"},{"id":"18273","book":"이사야","book_name":"이사야","chapter":32,"verse":13,"text":"형극과 질려가 내 백성의 땅에 나며 희락의 성읍, 기뻐하는 모든 집에 나리니","reference":"이사야 32:13","category":"$undefined"},{"id":"18274","book":"이사야","book_name":"이사야","chapter":32,"verse":14,"text":"필경은 위에서부터 성신을 우리에게 부어주시리니 광야가 아름다운 밭이 되며 아름다운 밭을 삼림으로 여기게 되리라","reference":"이사야 32:14","category":"$undefined"},{"id":"18275","book":"이사야","book_name":"이사야","chapter":32,"verse":15,"text":"그 때에 공평이 광야에 거하며 의가 아름다운 밭에 있으리니","reference":"이사야 32:15","category":"$undefined"},{"id":"18276","book":"이사야","book_name":"이사야","chapter":32,"verse":16,"text":"의의 공효는 화평이요 의의 결과는 영원한 평안과 안전이라","reference":"이사야 32:16","category":"$undefined"},{"id":"18277","book":"이사야","book_name":"이사야","chapter":32,"verse":17,"text":"내 백성이 화평한 집과 안전한 거처와 종용히 쉬는 곳에 있으려니와","reference":"이사야 32:17","category":"$undefined"},{"id":"18278","book":"이사야","book_name":"이사야","chapter":32,"verse":18,"text":"먼저 그 삼림은 우박에 상하고 성읍은 파괴되리라","reference":"이사야 32:18","category":"$undefined"},{"id":"18279","book":"이사야","book_name":"이사야","chapter":32,"verse":19,"text":"모든 물가에 씨를 뿌리고 소와 나귀를 그리로 모은 너희는 복이 있느니라","reference":"이사야 32:19","category":"$undefined"},{"id":"18280","book":"이사야","book_name":"이사야","chapter":32,"verse":20,"text":"","reference":"이사야 32:20","category":"$undefined"}],"bookSlug":"isaiah"}]
