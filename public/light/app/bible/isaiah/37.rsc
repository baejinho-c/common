11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":37,"verses":[{"id":"18354","book":"이사야","book_name":"이사야","chapter":37,"verse":1,"text":"히스기야 왕이 듣고 그 옷을 찢고 굵은 베를 입고 여호와의 전으로 갔고","reference":"이사야 37:1","category":"$undefined"},{"id":"18355","book":"이사야","book_name":"이사야","chapter":37,"verse":2,"text":"궁내대신 엘리아김과 서기관 셉나와 제사장 중 어른들도 굵은 베를 입으니라 왕이 그들을 아모스의 아들 선지자 이사야에게로 보내며","reference":"이사야 37:2","category":"$undefined"},{"id":"18356","book":"이사야","book_name":"이사야","chapter":37,"verse":3,"text":"그들이 이사야에게 이르되 히스기야의 말씀에 오늘은 환난과 책벌과 능욕의 날이라 아이를 낳으려 하나 해산할 힘이 없음 같도다","reference":"이사야 37:3","category":"$undefined"},{"id":"18357","book":"이사야","book_name":"이사야","chapter":37,"verse":4,"text":"당신의 하나님 여호와께서 랍사게의 말을 들으셨을 것이라 그가 그 주 앗수르 왕의 보냄을 받고 사시는 하나님을 훼방하였은즉 당신의 하나님 여호와께서 혹시 그 말에 견책하실까 하노라 그런즉 바라건대 당신은 이 남아 있는 자를 위하여 기도하라 하시더이다","reference":"이사야 37:4","category":"$undefined"},{"id":"18358","book":"이사야","book_name":"이사야","chapter":37,"verse":5,"text":"이와 같이 히스기야 왕의 신하들이 이사야에게 나아가매","reference":"이사야 37:5","category":"$undefined"},{"id":"18359","book":"이사야","book_name":"이사야","chapter":37,"verse":6,"text":"이사야가 그들에게 이르되 너희는 너희 주에게 이렇게 고하라 여호와께서 말씀하시되 너희의 들은바 앗수르 왕의 종들이 나를 능욕한 말을 인하여 두려워 말라","reference":"이사야 37:6","category":"$undefined"},{"id":"18360","book":"이사야","book_name":"이사야","chapter":37,"verse":7,"text":"보라, 내가 신을 그의 속에 두리니 그가 풍성을 듣고 그 고토로 돌아갈 것이며 또 내가 그를 그 고토에서 칼에 죽게 하리라 하셨느니라","reference":"이사야 37:7","category":"$undefined"},{"id":"18361","book":"이사야","book_name":"이사야","chapter":37,"verse":8,"text":"랍사게가 앗수르 왕이 라기스를 떠났다 함을 듣고 돌아가다가 그 왕이 립나 치는 것을 만나니라","reference":"이사야 37:8","category":"$undefined"},{"id":"18362","book":"이사야","book_name":"이사야","chapter":37,"verse":9,"text":"그 때에 앗수르 왕이 구스 왕 디르하가의 일에 대하여 들은즉 이르기를 그가 나와서 왕과 싸우려 한다 하는지라 이 말을 듣고 사자들을 히스기야에게 보내며 가로되","reference":"이사야 37:9","category":"$undefined"},{"id":"18363","book":"이사야","book_name":"이사야","chapter":37,"verse":10,"text":"앗수르 왕들이 모든 나라에 어떤 일을 행하였으며 그것을 어떻게 멸절시켰는지 네가 들었으리니 네가 건짐을 얻겠느냐","reference":"이사야 37:10","category":"$undefined"},{"id":"18364","book":"이사야","book_name":"이사야","chapter":37,"verse":11,"text":"나의 열조가 멸하신 열방 고산과 하란과 레셉과 및 들라살에 거하는 에덴 자손을 그 나라 신들이 건졌더냐","reference":"이사야 37:11","category":"$undefined"},{"id":"18365","book":"이사야","book_name":"이사야","chapter":37,"verse":12,"text":"하맛 왕과 아르밧 왕과 스발와임성(城)의 왕과 헤나 왕과 이와 왕이 어디 있느냐 하라 하였더라","reference":"이사야 37:12","category":"$undefined"},{"id":"18366","book":"이사야","book_name":"이사야","chapter":37,"verse":13,"text":"히스기야가 사자의 손에서 글을 받아 보고 여호와의 전에 올라가서 그 글을 여호와 앞에 펴놓고","reference":"이사야 37:13","category":"$undefined"},{"id":"18367","book":"이사야","book_name":"이사야","chapter":37,"verse":14,"text":"여호와께 기도하여 가로되","reference":"이사야 37:14","category":"$undefined"},{"id":"18368","book":"이사야","book_name":"이사야","chapter":37,"verse":15,"text":"그룹 사이에 계신 이스라엘 하나님 만군의 여호와여, 주는 천하 만국의 유일하신 하나님이시라 주께서 천지를 조성하셨나이다","reference":"이사야 37:15","category":"$undefined"},{"id":"18369","book":"이사야","book_name":"이사야","chapter":37,"verse":16,"text":"여호와여, 귀를 기울여 들으시옵소서 여호와여, 눈을 떠 보시옵소서 산헤립이 사자로 사시는 하나님을 훼방한 모든 말을 들으시옵소서","reference":"이사야 37:16","category":"$undefined"},{"id":"18370","book":"이사야","book_name":"이사야","chapter":37,"verse":17,"text":"여호와여, 앗수르 왕들이 과연 열국과 그 땅을 황폐케 하였고","reference":"이사야 37:17","category":"$undefined"},{"id":"18371","book":"이사야","book_name":"이사야","chapter":37,"verse":18,"text":"그들의 신(神)들을 불에 던졌사오나 이들은 참 신이 아니라 사람의 손으로 만든 것 뿐이요 나무와 돌이라 그러므로 멸망을 당하였나이다","reference":"이사야 37:18","category":"$undefined"},{"id":"18372","book":"이사야","book_name":"이사야","chapter":37,"verse":19,"text":"우리 하나님 여호와여 이제 우리를 그의 손에서 구원하사 천하 만국으로 주만 여호와이신 줄을 알게 하옵소서","reference":"이사야 37:19","category":"$undefined"},{"id":"18373","book":"이사야","book_name":"이사야","chapter":37,"verse":20,"text":"아모스의 아들 이사야가 보내어 히스기야에게 이르되 이스라엘의 하나님 여호와께서 말씀하시되 네가 앗수르 왕 산헤립의 일로 내게 기도하였도다 하시고","reference":"이사야 37:20","category":"$undefined"},{"id":"18374","book":"이사야","book_name":"이사야","chapter":37,"verse":21,"text":"여호와께서 그에 대하여 이같이 이르시되 처녀 딸 시온이 너를 멸시하며 조소하였고 딸 예루살렘이 너를 향하여 머리를 흔들었느니라","reference":"이사야 37:21","category":"$undefined"},{"id":"18375","book":"이사야","book_name":"이사야","chapter":37,"verse":22,"text":"네가 훼방하며 능욕한 것은 누구에게냐 네가 소리를 높이며 눈을 높이 들어 향한 것은 누구에게냐 곧 이스라엘의 거룩한 자에게니라","reference":"이사야 37:22","category":"$undefined"},{"id":"18376","book":"이사야","book_name":"이사야","chapter":37,"verse":23,"text":"네가 네 종으로 주를 훼방하여 이르기를 내가 나의 허다한 병거를 거느리고 산들의 꼭대기에 올라가며 레바논의 깊은 곳에 이르렀으니 높은 백향목과 아름다운 향나무를 베고 또 그 한계되는 높은 곳에 들어가며 살진 땅의 수풀에 이를 것이며","reference":"이사야 37:23","category":"$undefined"},{"id":"18377","book":"이사야","book_name":"이사야","chapter":37,"verse":24,"text":"내가 우물을 파서 물을 마셨으니 나의 발바닥으로 애굽의 모든 하수를 밟아 말리리라 하였도다","reference":"이사야 37:24","category":"$undefined"},{"id":"18378","book":"이사야","book_name":"이사야","chapter":37,"verse":25,"text":"네가 어찌 듣지 못하였겠느냐 ? 이 일들은 내가 태초부터 행한 바요 상고부터 정한 바로서 이제 내가 이루어 너로 견고한 성을 헐어 돌무더기가 되게 하였노라","reference":"이사야 37:25","category":"$undefined"},{"id":"18379","book":"이사야","book_name":"이사야","chapter":37,"verse":26,"text":"그러므로 그 거민들이 힘이 약하여 놀라며 수치를 당하여 들의 풀같이, 푸른 나물 같이, 지붕의 풀 같이, 자라지 못한 곡초 같았었느니라","reference":"이사야 37:26","category":"$undefined"},{"id":"18380","book":"이사야","book_name":"이사야","chapter":37,"verse":27,"text":"네 거처와 네 출입과 나를 거스려 분노함을 내가 아노라","reference":"이사야 37:27","category":"$undefined"},{"id":"18381","book":"이사야","book_name":"이사야","chapter":37,"verse":28,"text":"네가 나를 거스려 분노함과 네 오만함이 내 귀에 들렸으므로 내가 갈고리로 네 코를 꿰며 자갈을 네 입에 먹여 너를 오던 길로 돌아가게 하리라 하셨나이다","reference":"이사야 37:28","category":"$undefined"},{"id":"18382","book":"이사야","book_name":"이사야","chapter":37,"verse":29,"text":"왕이여 이것이 왕에게 징조가 되리니 금년에는 스스로 난 것을 먹을 것이요 제 이년에는 또 거기서 난 것을 먹을 것이요 제 삼년에는 심고 거두며 포도나무를 심고 그 열매를 먹을 것이니이다","reference":"이사야 37:29","category":"$undefined"},{"id":"18383","book":"이사야","book_name":"이사야","chapter":37,"verse":30,"text":"유다 족속 중에 피하여 남는 자는 다시 아래로 뿌리를 박고 위로 열매를 맺히리니","reference":"이사야 37:30","category":"$undefined"},{"id":"18384","book":"이사야","book_name":"이사야","chapter":37,"verse":31,"text":"이는 남는 자가 예루살렘에서 나오며 피하는 자가 시온에서 나올 것임이라 만군의 여호와의 열심이 이를 이루시리이다","reference":"이사야 37:31","category":"$undefined"},{"id":"18385","book":"이사야","book_name":"이사야","chapter":37,"verse":32,"text":"그가 오던 길 곧 그 길로 돌아가고 이 성에 이르지 못하리라 나 여호와의 말이니라","reference":"이사야 37:32","category":"$undefined"},{"id":"18386","book":"이사야","book_name":"이사야","chapter":37,"verse":33,"text":"대저 내가 나를 위하며 내 종 다윗을 위하여 이 성을 보호하며 구원하리라 하셨나이다","reference":"이사야 37:33","category":"$undefined"},{"id":"18387","book":"이사야","book_name":"이사야","chapter":37,"verse":34,"text":"여호와의 사자가 나가서 앗수르 진중에서 십 팔만 오천인을 쳤으므로 아침에 일찌기 일어나 본즉 시체 뿐이라","reference":"이사야 37:34","category":"$undefined"},{"id":"18388","book":"이사야","book_name":"이사야","chapter":37,"verse":35,"text":"이에 앗수르 왕 산헤립이 떠나 돌아가서 니느웨에 거하더니","reference":"이사야 37:35","category":"$undefined"},{"id":"18389","book":"이사야","book_name":"이사야","chapter":37,"verse":36,"text":"자기 신 니스록의 묘에서 경배할 때에 그 아들 아드람멜렉과 사레셀이 그를 칼로 죽이고 아라랏 땅으로 도망한고로 그 아들 에살핫돈이 이어 왕이 되니라","reference":"이사야 37:36","category":"$undefined"},{"id":"18390","book":"이사야","book_name":"이사야","chapter":37,"verse":37,"text":"","reference":"이사야 37:37","category":"$undefined"},{"id":"18391","book":"이사야","book_name":"이사야","chapter":37,"verse":38,"text":"","reference":"이사야 37:38","category":"$undefined"}],"bookSlug":"isaiah"}]
