2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":40,"verses":[{"id":"18422","book":"이사야","book_name":"이사야","chapter":40,"verse":1,"text":"너희 하나님이 가라사대 너희는 위로하라 내 백성을 위로하라","reference":"이사야 40:1","category":"$undefined"},{"id":"18423","book":"이사야","book_name":"이사야","chapter":40,"verse":2,"text":"너희는 정다이 예루살렘에 말하며 그것에게 외쳐 고하라 그 복역의 때가 끝났고 그 죄악의 사함을 입었느니라 그 모든 죄를 인하여 여호와의 손에서 배나 받았느니라 할지니라","reference":"이사야 40:2","category":"$undefined"},{"id":"18424","book":"이사야","book_name":"이사야","chapter":40,"verse":3,"text":"외치는 자의 소리여 가로되 너희는 광야에서 여호와의 길을 예비하라 사막에서 우리 하나님의 대로를 평탄케 하라","reference":"이사야 40:3","category":"$undefined"},{"id":"18425","book":"이사야","book_name":"이사야","chapter":40,"verse":4,"text":"골짜기마다 돋우어지며 산마다 작은 산마다 낮아지며 고르지 않은 곳이 평탄케 되며 험한 곳이 평지가 될 것이요","reference":"이사야 40:4","category":"$undefined"},{"id":"18426","book":"이사야","book_name":"이사야","chapter":40,"verse":5,"text":"여호와의 영광이 나타나고 모든 육체가 그것을 함께 보리라 대저 여호와의 입이 말씀하셨느니라","reference":"이사야 40:5","category":"$undefined"},{"id":"18427","book":"이사야","book_name":"이사야","chapter":40,"verse":6,"text":"말하는 자의 소리여 가로되 외치라 대답하되 내가 무엇이라 외치리이이까 ? 가로되 모든 육체는 풀이요 그 모든 아름다움은 들의 꽃 같으니","reference":"이사야 40:6","category":"$undefined"},{"id":"18428","book":"이사야","book_name":"이사야","chapter":40,"verse":7,"text":"풀은 마르고 꽃은 시듦은 여호와의 기운이 그 위에 붊이라 이 백성은 실로 풀이로다","reference":"이사야 40:7","category":"$undefined"},{"id":"18429","book":"이사야","book_name":"이사야","chapter":40,"verse":8,"text":"풀은 마르고 꽃은 시드나 우리 하나님의 말씀은 영영히 서리라 하라","reference":"이사야 40:8","category":"$undefined"},{"id":"18430","book":"이사야","book_name":"이사야","chapter":40,"verse":9,"text":"아름다운 소식을 시온에 전하는 자여 너는 높은 산에 오르라 아름다운 소식을 예루살렘에 전하는 자여 너는 힘써 소리를 높이라 두려워 말고 소리를 높여 유다의 성읍들에 이르기를 너희 하나님을 보라 하라","reference":"이사야 40:9","category":"$undefined"},{"id":"18431","book":"이사야","book_name":"이사야","chapter":40,"verse":10,"text":"보라, 주 여호와께서 장차 강한 자로 임하실 것이요 친히 그 팔로 다스리실 것이라 보라 상급이 그에게 있고 보응이 그 앞에 있으며","reference":"이사야 40:10","category":"$undefined"},{"id":"18432","book":"이사야","book_name":"이사야","chapter":40,"verse":11,"text":"그는 목자같이 양무리를 먹이시며 어린 양을 그 팔로 모아 품에 안으시며 젖먹이는 암컷들을 온순히 인도하시리로다","reference":"이사야 40:11","category":"$undefined"},{"id":"18433","book":"이사야","book_name":"이사야","chapter":40,"verse":12,"text":"누가 손바닥으로 바다 물을 헤아렸으며 뼘으로 하늘을 재었으며 땅의 티끌을 되에 담아 보았으며 명칭으로 산들을, 간칭으로 작은 산들을 달아 보았으랴","reference":"이사야 40:12","category":"$undefined"},{"id":"18434","book":"이사야","book_name":"이사야","chapter":40,"verse":13,"text":"누가 여호와의 신을 지도하였으며 그의 모사가 되어 그를 가르쳤으랴","reference":"이사야 40:13","category":"$undefined"},{"id":"18435","book":"이사야","book_name":"이사야","chapter":40,"verse":14,"text":"그가 누구로 더불어 의논하셨으며 누가 그를 교훈하였으며 그에게 공평의 도로 가르쳤으며 지식을 가르쳤으며 통달의 도를 보여주었느뇨","reference":"이사야 40:14","category":"$undefined"},{"id":"18436","book":"이사야","book_name":"이사야","chapter":40,"verse":15,"text":"보라, 그에게는 열방은 통의 한 방울 물 같고 저울의 적은 티끌 같으며 섬들은 떠오르는 먼지 같으니","reference":"이사야 40:15","category":"$undefined"},{"id":"18437","book":"이사야","book_name":"이사야","chapter":40,"verse":16,"text":"레바논 짐승들은 번제 소용에도 부족하겠고 그 삼림은 그 화목 소용에도 부족할 것이라","reference":"이사야 40:16","category":"$undefined"},{"id":"18438","book":"이사야","book_name":"이사야","chapter":40,"verse":17,"text":"그 앞에는 모든 열방이 아무 것도 아니라 그는 그들을 없는 것 같이,빈 것 같이 여기시느니라","reference":"이사야 40:17","category":"$undefined"},{"id":"18439","book":"이사야","book_name":"이사야","chapter":40,"verse":18,"text":"그런즉 너희가 하나님을 누구와 같다 하겠으며 무슨 형상에 비기겠느냐","reference":"이사야 40:18","category":"$undefined"},{"id":"18440","book":"이사야","book_name":"이사야","chapter":40,"verse":19,"text":"우상은 장인이 부어 만들었고 장색이 금으로 입혔고 또 위하여 은사슬을 만든 것이니라","reference":"이사야 40:19","category":"$undefined"},{"id":"18441","book":"이사야","book_name":"이사야","chapter":40,"verse":20,"text":"궁핍하여 이런 것을 드리지 못하는 자는 썩지 않는 나무를 택하고 공교한 장인을 구하여 우상을 만들어서 흔들리지 않도록 세우느니라","reference":"이사야 40:20","category":"$undefined"},{"id":"18442","book":"이사야","book_name":"이사야","chapter":40,"verse":21,"text":"너희가 알지 못하였느냐 ? 너희가 듣지 못하였느냐 ? 태초부터 너희에게 전하지 아니하였느냐 땅의 기초가 창조될 때부터 너희가 깨닫지 못하였느냐","reference":"이사야 40:21","category":"$undefined"},{"id":"18443","book":"이사야","book_name":"이사야","chapter":40,"verse":22,"text":"그는 땅 위 궁창에 앉으시나니 땅의 거민들은 메뚜기 같으니라 그가 하늘을 차일 같이 펴셨으며 거할 천막 같이 베푸셨고","reference":"이사야 40:22","category":"$undefined"},{"id":"18444","book":"이사야","book_name":"이사야","chapter":40,"verse":23,"text":"귀인들을 폐하시며 세상의 사사들을 헛되게 하시나니","reference":"이사야 40:23","category":"$undefined"},{"id":"18445","book":"이사야","book_name":"이사야","chapter":40,"verse":24,"text":"그들은 겨우 심기웠고 겨우 뿌리웠고 그 줄기가 겨우 땅에 뿌리를 박자 곧 하나님의 부심을 받고 말라 회리바람에 불려가는 초개 같도다","reference":"이사야 40:24","category":"$undefined"},{"id":"18446","book":"이사야","book_name":"이사야","chapter":40,"verse":25,"text":"거룩하신 자가 가라사대 그런즉 너희가 나를 누구에게 비기며 나로 그와 동등이 되게 하겠느냐 하시느니라","reference":"이사야 40:25","category":"$undefined"},{"id":"18447","book":"이사야","book_name":"이사야","chapter":40,"verse":26,"text":"너희는 눈을 높이 들어 누가 이 모든 것을 창조하였나보라 주께서는 수효대로 만상을 이끌어 내시고 각각 그 이름을 부르시나니 그의 권세가 크고 그의 능력이 강하므로 하나도 빠짐이 없느니라","reference":"이사야 40:26","category":"$undefined"},{"id":"18448","book":"이사야","book_name":"이사야","chapter":40,"verse":27,"text":"야곱아, 네가 어찌하여 말하며 이스라엘아 네가 어찌하여 이르기를 내 사정은 여호와께 숨겨졌으며 원통한 것은 내 하나님에게서 수리하심을 받지 못한다 하느냐","reference":"이사야 40:27","category":"$undefined"},{"id":"18449","book":"이사야","book_name":"이사야","chapter":40,"verse":28,"text":"너는 알지 못하였느냐 ? 듣지 못하였느냐 ? 영원하신 하나님 여호와 땅 끝까지 창조하신 자는 피곤치 아니하시며 곤비치 아니하시며 명철이 한이 없으시며","reference":"이사야 40:28","category":"$undefined"},{"id":"18450","book":"이사야","book_name":"이사야","chapter":40,"verse":29,"text":"피곤한 자에게는 능력을 주시며 무능한 자에게는 힘을 더하시나니","reference":"이사야 40:29","category":"$undefined"},{"id":"18451","book":"이사야","book_name":"이사야","chapter":40,"verse":30,"text":"소년이라도 피곤하며 곤비하며 장정이라도 넘어지며 자빠지되","reference":"이사야 40:30","category":"$undefined"},{"id":"18452","book":"이사야","book_name":"이사야","chapter":40,"verse":31,"text":"오직 여호와를 앙망하는 자는 새 힘을 얻으리니 독수리의 날개치며 올라감 같을 것이요 달음박질하여도 곤비치 아니하겠고 걸어가도 피곤치 아니하리로다","reference":"이사야 40:31","category":"$undefined"}],"bookSlug":"isaiah"}]
