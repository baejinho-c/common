11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":48,"verses":[{"id":"18616","book":"이사야","book_name":"이사야","chapter":48,"verse":1,"text":"야곱 집이여 이스라엘의 이름으로 일컬음을 받으며 유다의 근원에서 나왔으며 거룩한 성 백성이라 칭하며 그 이름이 만군의 여호와이신 이스라엘의 하나님을 의지하면서 성실치 아니하고 의로움이 없이 여호와의 이름으로 맹세하며 이스라엘의 하나님을 부르는 너희는 들을지어다","reference":"이사야 48:1","category":"$undefined"},{"id":"18617","book":"이사야","book_name":"이사야","chapter":48,"verse":2,"text":"(1절과 같음)","reference":"이사야 48:2","category":"$undefined"},{"id":"18618","book":"이사야","book_name":"이사야","chapter":48,"verse":3,"text":"여호와께서 가라사대 내가 옛적에 장래사를 고하였고 내 입에서 내어 보였고 내가 홀연히 그 일을 행하여 이루었느니라","reference":"이사야 48:3","category":"$undefined"},{"id":"18619","book":"이사야","book_name":"이사야","chapter":48,"verse":4,"text":"내가 알거니와 너는 완악하며 네 목의 힘줄은 무쇠요 네 이마는 놋이라","reference":"이사야 48:4","category":"$undefined"},{"id":"18620","book":"이사야","book_name":"이사야","chapter":48,"verse":5,"text":"그러므로 내가 이 일을 옛적부터 네게 고하였고 성사하기 전에 그것을 네게 보였느니라 그렇지 않았더면 네 말이 내 신의 행한 바요 내 새긴 신상과 부어만든 신상의 명한 바라 하였으리라","reference":"이사야 48:5","category":"$undefined"},{"id":"18621","book":"이사야","book_name":"이사야","chapter":48,"verse":6,"text":"네가 이미 들었으니 이것을 다 보라 너희가 선전치 아니하겠느뇨 이제부터 내가 새 일 곧 네가 알지 못하던 은비한 일을 네게 보이노니","reference":"이사야 48:6","category":"$undefined"},{"id":"18622","book":"이사야","book_name":"이사야","chapter":48,"verse":7,"text":"이 일들은 이제 창조된 것이요 옛적 것이 아니라 오늘 이전에는 네가 듣지 못하였느니라 그렇지 않았더면 네가 말하기를 내가 이미 알았노라 하였으리라","reference":"이사야 48:7","category":"$undefined"},{"id":"18623","book":"이사야","book_name":"이사야","chapter":48,"verse":8,"text":"네가 과연 듣지도 못하였고 알지도 못하였으며 네 귀가 옛적부터 열리지 못하였었나니 이는 네가 궤휼하고 궤휼하여 모태에서부터 패역한 자라 칭함을 입은 줄을 내가 알았음이라","reference":"이사야 48:8","category":"$undefined"},{"id":"18624","book":"이사야","book_name":"이사야","chapter":48,"verse":9,"text":"내 이름을 위하여 내가 노하기를 더디 할 것이며 내 영예를 위하여 내가 참고 너를 멸절하지 아니하리라","reference":"이사야 48:9","category":"$undefined"},{"id":"18625","book":"이사야","book_name":"이사야","chapter":48,"verse":10,"text":"보라, 내가 너를 연단하였으나 은처럼 하지 아니하고 너를 고난의 풀무에서 택하였노라","reference":"이사야 48:10","category":"$undefined"},{"id":"18626","book":"이사야","book_name":"이사야","chapter":48,"verse":11,"text":"내가 나를 위하며 내가 나를 위하여 이를 이룰 것이라 어찌 내 이름을 욕되게 하리요 내 영광을 다른 자에게 주지 아니하리라","reference":"이사야 48:11","category":"$undefined"},{"id":"18627","book":"이사야","book_name":"이사야","chapter":48,"verse":12,"text":"야곱아, 나의 부른 이스라엘아 나를 들으라 나는 그니 나는 처음이요 또 마지막이라","reference":"이사야 48:12","category":"$undefined"},{"id":"18628","book":"이사야","book_name":"이사야","chapter":48,"verse":13,"text":"과연 내 손이 땅의 기초를 정하였고 내 오른손이 하늘에 폈나니 내가 부르면 천지가 일제히 서느니라","reference":"이사야 48:13","category":"$undefined"},{"id":"18629","book":"이사야","book_name":"이사야","chapter":48,"verse":14,"text":"너희는 다 모여 들으라 나 여호와의 사랑하는 자가 나의 뜻을 바벨론에 행하리니 그의 팔이 갈대아인에게 임할 것이라 그들 중에 누가 이 일을 예언하였느뇨","reference":"이사야 48:14","category":"$undefined"},{"id":"18630","book":"이사야","book_name":"이사야","chapter":48,"verse":15,"text":"나 곧 내가 말하였고 또 내가 그를 부르며 그를 인도하였나니 그길이 형통하리라","reference":"이사야 48:15","category":"$undefined"},{"id":"18631","book":"이사야","book_name":"이사야","chapter":48,"verse":16,"text":"너희는 내게 가까이 나아와 이 말을 들으라 내가 처음부터 그것을 비밀히 말하지 아니하였나니 그 말이 있을 때부터 내가 거기 있었노라 하셨느니라 이제는 주 여호와께서 나와 그 신을 보내셨느니라","reference":"이사야 48:16","category":"$undefined"},{"id":"18632","book":"이사야","book_name":"이사야","chapter":48,"verse":17,"text":"너희의 구속자시요 이스라엘의 거룩하신 자이신 여호와께서 가라사대 나는 네게 유익하도록 가르치고 너를 마땅히 행할 길로 인도하는 너희 하나님 여호와라","reference":"이사야 48:17","category":"$undefined"},{"id":"18633","book":"이사야","book_name":"이사야","chapter":48,"verse":18,"text":"슬프다 네가 나의 명령을 듣지 아니하였도다 만일 들었더면 네 평강이 강과 같았겠고 네 의가 바다 물결 같았을 것이며","reference":"이사야 48:18","category":"$undefined"},{"id":"18634","book":"이사야","book_name":"이사야","chapter":48,"verse":19,"text":"네 자손이 모래 같았겠고 네 몸의 소생이 모래 알갱이 같아서 그 이름이 내 앞에서 끊어지지 아니하였겠고 없어지지 아니하였으리라 하셨느니라","reference":"이사야 48:19","category":"$undefined"},{"id":"18635","book":"이사야","book_name":"이사야","chapter":48,"verse":20,"text":"너희는 바벨론에서 나와서 갈대아인을 피하고 즐거운 소리로 이를 선파하여 들리며 땅 끝까지 반포하여 이르기를 여호와께서 그종 야곱을 구속하셨다 하라","reference":"이사야 48:20","category":"$undefined"},{"id":"18636","book":"이사야","book_name":"이사야","chapter":48,"verse":21,"text":"여호와께서 그들을 사막으로 통과하게 하시던 때에 그들로 목마르지 않게 하시되 그들을 위하여 바위에서 물이 흘러나게 하시며 바위를 쪼개사 물로 솟아나게 하셨느니라","reference":"이사야 48:21","category":"$undefined"},{"id":"18637","book":"이사야","book_name":"이사야","chapter":48,"verse":22,"text":"여호와께서 말씀하시되 악인에게는 평강이 없다 하셨느니라","reference":"이사야 48:22","category":"$undefined"}],"bookSlug":"isaiah"}]
