11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"isaiah","name":"이사야","chapters":66,"testament":"old"},"chapter":52,"verses":[{"id":"18698","book":"이사야","book_name":"이사야","chapter":52,"verse":1,"text":"시온이여, 깰지어다, 깰지어다, 네 힘을 입을지어다 ! 거룩한 성 예루살렘이여 네 아름다운 옷을 입을지어다 이제부터 할례받지 않은 자와 부정한 자가 다시는 네게로 들어옴이 없을 것임이니라","reference":"이사야 52:1","category":"$undefined"},{"id":"18699","book":"이사야","book_name":"이사야","chapter":52,"verse":2,"text":"너는 티끌을 떨어버릴지어다 예루살렘이여 ! 일어나 보좌에 앉을지어다 사로잡힌 딸 시온이여 네 목의 줄을 스스로 풀지어다","reference":"이사야 52:2","category":"$undefined"},{"id":"18700","book":"이사야","book_name":"이사야","chapter":52,"verse":3,"text":"여호와께서 이같이 말씀하시되 너희가 값 없이 팔렸으니 돈 없이 속량되리라","reference":"이사야 52:3","category":"$undefined"},{"id":"18701","book":"이사야","book_name":"이사야","chapter":52,"verse":4,"text":"주 여호와께서 이같이 말씀하시되 내 백성이 이왕에 애굽에 내려가서 거기 우거하였었고 앗수르인은 공연히 그들을 압박하였도다","reference":"이사야 52:4","category":"$undefined"},{"id":"18702","book":"이사야","book_name":"이사야","chapter":52,"verse":5,"text":"여호와께서 말씀하시되 내 백성이 까닭없이 잡혀갔으니 내가 여기서 어떻게 할꼬 여호와께서 말씀하시되 그들을 관할하는 자들이 떠들며 내 이름을 항상 종일 더럽히도다","reference":"이사야 52:5","category":"$undefined"},{"id":"18703","book":"이사야","book_name":"이사야","chapter":52,"verse":6,"text":"그러므로 내 백성은 내 이름을 알리라 그러므로 그 날에는 그들이 이 말을 하는 자가 나인 줄 알리라 곧 내니라","reference":"이사야 52:6","category":"$undefined"},{"id":"18704","book":"이사야","book_name":"이사야","chapter":52,"verse":7,"text":"좋은 소식을 가져오며 평화를 공포하며 복된 좋은 소식을 가져오며 구원을 공포하며 시온을 향하여 이르기를 네 하나님이 통치하신다 하는 자의 산을 넘는 발이 어찌 그리 아름다운고","reference":"이사야 52:7","category":"$undefined"},{"id":"18705","book":"이사야","book_name":"이사야","chapter":52,"verse":8,"text":"들을지어다 ! 너의 파숫군들의 소리로다 그들이 소리를 높여 일제히 노래하니 이는 여호와께서 시온으로 돌아오실 때에 그들의 눈이 마주 봄이로다","reference":"이사야 52:8","category":"$undefined"},{"id":"18706","book":"이사야","book_name":"이사야","chapter":52,"verse":9,"text":"너 예루살렘의 황폐한 곳들아 기쁜 소리를 발하여 함께 노래할지어다 이는 여호와께서 그 백성을 위로하셨고 예루살렘을 구속하셨음이라","reference":"이사야 52:9","category":"$undefined"},{"id":"18707","book":"이사야","book_name":"이사야","chapter":52,"verse":10,"text":"여호와께서 열방의 목전에서 그 거룩한 팔을 나타내셨으므로 모든 땅 끝까지도 우리 하나님의 구원을 보았도다","reference":"이사야 52:10","category":"$undefined"},{"id":"18708","book":"이사야","book_name":"이사야","chapter":52,"verse":11,"text":"너희는 떠날지어다 ! 떠날지어다 ! 거기서 나오고 부정한 것을 만지지 말지어다 그 가운데서 나올지어다 여호와의 기구를 메는 자여 스스로 정결케 할지어다","reference":"이사야 52:11","category":"$undefined"},{"id":"18709","book":"이사야","book_name":"이사야","chapter":52,"verse":12,"text":"여호와께서 너희 앞에 행하시며 이스라엘의 하나님이 너희 뒤에 호위하시리니 너희가 황급히 나오지 아니하며 도망하여 행하지 아니하리라","reference":"이사야 52:12","category":"$undefined"},{"id":"18710","book":"이사야","book_name":"이사야","chapter":52,"verse":13,"text":"여호와께서 가라사대 보라 ! 내 종이 형통하리니 받들어 높이 들려서 지극히 존귀하게 되리라","reference":"이사야 52:13","category":"$undefined"},{"id":"18711","book":"이사야","book_name":"이사야","chapter":52,"verse":14,"text":"이왕에는 그 얼굴이 타인보다 상하였고 그 모양이 인생보다 상하였으므로 무리가 그를 보고 놀랐거니와","reference":"이사야 52:14","category":"$undefined"},{"id":"18712","book":"이사야","book_name":"이사야","chapter":52,"verse":15,"text":"후에는 그가 열방을 놀랠 것이며 열왕은 그를 인하여 입을 봉하리니 이는 그들이 아직 전파되지 않은 것을 볼 것이요 아직 듣지 못한 것을 깨달을 것임이라 하시니라","reference":"이사야 52:15","category":"$undefined"}],"bookSlug":"isaiah"}]
