2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":1,"verses":[{"id":"18948","book":"예레미야","book_name":"예레미야","chapter":1,"verse":1,"text":"베냐민 땅 아나돗의 제사장 중 힐기야의 아들 예레미야의 말이라","reference":"예레미야 1:1","category":"$undefined"},{"id":"18949","book":"예레미야","book_name":"예레미야","chapter":1,"verse":2,"text":"아몬의 아들 유다 왕 요시야의 다스린지 십 삼년에 여호와의 말이라 이 예레미야에게 임하였고","reference":"예레미야 1:2","category":"$undefined"},{"id":"18950","book":"예레미야","book_name":"예레미야","chapter":1,"verse":3,"text":"요시야의 아들 유다 왕 여호야김 시대부터 요시야의 아들 유다 왕 시드기야의 제 십 일년 말까지 임하니라 이 해 오월에 예루살렘이 사로잡히니라","reference":"예레미야 1:3","category":"$undefined"},{"id":"18951","book":"예레미야","book_name":"예레미야","chapter":1,"verse":4,"text":"여호와의 말씀이 내게 임하니라 이르시되","reference":"예레미야 1:4","category":"$undefined"},{"id":"18952","book":"예레미야","book_name":"예레미야","chapter":1,"verse":5,"text":"내가 너를 복 중에 짓기 전에 너를 알았고 네가 태에서 나오기 전에 너를 구별하였고 너를 열방의 선지자로 세웠노라 하시기로","reference":"예레미야 1:5","category":"$undefined"},{"id":"18953","book":"예레미야","book_name":"예레미야","chapter":1,"verse":6,"text":"내가 가로되 `슬프도소이다 주 여호와여, 보소서 나는 아이라 말할 줄을 알지 못하나이다'","reference":"예레미야 1:6","category":"$undefined"},{"id":"18954","book":"예레미야","book_name":"예레미야","chapter":1,"verse":7,"text":"여호와께서 내게 이르시되 너는 아이라 하지 말고 내가 너를 누구에게 보내든지 너는 가며 내가 네게 무엇을 명하든지 너는 말할지니라","reference":"예레미야 1:7","category":"$undefined"},{"id":"18955","book":"예레미야","book_name":"예레미야","chapter":1,"verse":8,"text":"너는 그들을 인하여 두려워 말라 ! 내가 너와 함께 하여 너를 구원하리라 나 여호와의 말이니라 ! 하시고","reference":"예레미야 1:8","category":"$undefined"},{"id":"18956","book":"예레미야","book_name":"예레미야","chapter":1,"verse":9,"text":"여호와께서 그 손을 내밀어 내 입에 대시며 내게 이르시되 보라, 내가 내 말을 네 입에 두었노라","reference":"예레미야 1:9","category":"$undefined"},{"id":"18957","book":"예레미야","book_name":"예레미야","chapter":1,"verse":10,"text":"보라, 내가 오늘날 너를 열방 만국 위에 세우고 너를 뽑으며 파괴하며 파멸하며 넘어뜨리며 건설하며 심게 하였느니라","reference":"예레미야 1:10","category":"$undefined"},{"id":"18958","book":"예레미야","book_name":"예레미야","chapter":1,"verse":11,"text":"여호와의 말씀이 또 내게 임하니라 이르시되 예레미야야 ! 네가 무엇을 보느냐 ? 대답하되 `내가 살구나무 가지를 보나이다'","reference":"예레미야 1:11","category":"$undefined"},{"id":"18959","book":"예레미야","book_name":"예레미야","chapter":1,"verse":12,"text":"여호와께서 내게 이르시되 네가 잘 보았도다 이는 내가 내 말을 지켜 그대로 이루려 함이니라","reference":"예레미야 1:12","category":"$undefined"},{"id":"18960","book":"예레미야","book_name":"예레미야","chapter":1,"verse":13,"text":"여호와께서 내게 이르시되 재앙이 북방에서 일어나 이 땅의 모든 거민에게 임하리라","reference":"예레미야 1:13","category":"$undefined"},{"id":"18961","book":"예레미야","book_name":"예레미야","chapter":1,"verse":14,"text":"나 여호와가 말하노라 ! 내가 북방 모든 나라의 족속을 부를 것인즉 그들이 와서 예루살렘 성문 어귀에 각기 자리를 정하고 그 사면 성벽과 유다 모든 성읍을 치리라","reference":"예레미야 1:14","category":"$undefined"},{"id":"18962","book":"예레미야","book_name":"예레미야","chapter":1,"verse":15,"text":"무리가 나를 버리고 다른 신들에게 분향하며 자기 손으로 만든 것에 절하였은즉 내가 나의 심판을 베풀어 그들의 모든 죄악을 징계하리라","reference":"예레미야 1:15","category":"$undefined"},{"id":"18963","book":"예레미야","book_name":"예레미야","chapter":1,"verse":16,"text":"그러므로 너는 네 허리를 동이고 일어나 내가 네게 명한 바를 다 그들에게 고하라 그들을 인하여 두려워 말라 ! 두렵건대 내가 너로 그들 앞에서 두려움을 당하게 할까 하노라","reference":"예레미야 1:16","category":"$undefined"},{"id":"18964","book":"예레미야","book_name":"예레미야","chapter":1,"verse":17,"text":"보라, 내가 오늘날 너로 그 온 땅과 유다 왕들과 그 족장들과 그 제사장들과 그 땅 백성 앞에 견고한 성읍, 쇠기둥, 놋 성벽이 되게 하였은즉","reference":"예레미야 1:17","category":"$undefined"},{"id":"18965","book":"예레미야","book_name":"예레미야","chapter":1,"verse":18,"text":"그들이 너를 치나 이기지 못하리니 이는 내가 너와 함께 하여 너를 구원할 것임이니라 여호와의 말이니라","reference":"예레미야 1:18","category":"$undefined"},{"id":"18966","book":"예레미야","book_name":"예레미야","chapter":1,"verse":19,"text":"","reference":"예레미야 1:19","category":"$undefined"},{"id":"20312","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":1,"text":"슬프다 이 성이여 본래는 거민이 많더니 이제는 어찌 그리 적막히 앉았는고 본래는 열국 중에 크던 자가 이제는 과부 같고 본래는 열방중에 공주 되었던 자가 이제는 조공 드리는 자가 되었도다","reference":"예레미야 애가 1:1","category":"$undefined"},{"id":"20313","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":2,"text":"밤새도록 애곡하니 눈물이 뺨에 흐름이여 사랑하던 자 중에 위로 하는 자가 없고 친구도 다 배반하여 원수가 되었도다","reference":"예레미야 애가 1:2","category":"$undefined"},{"id":"20314","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":3,"text":"유다는 환난과 많은 수고로 인하여 사로잡혀 갔도다 저가 열방에 거하여 평강을 얻지 못함이여 그 모든 핍박하는 자가 저를 쫓아 협착한 곳에 미쳤도다","reference":"예레미야 애가 1:3","category":"$undefined"},{"id":"20315","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":4,"text":"시온의 도로가 처량함이여 절기에 나아가는 사람이 없음이로다 모든 성문이 황적하며 제사장들이 탄식하며 처녀들이 근심하며 저도 곤고를 받았도다","reference":"예레미야 애가 1:4","category":"$undefined"},{"id":"20316","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":5,"text":"저의 대적이 머리가 되고 저의 원수가 형통함은 저의 죄가 많으므로 여호와께서 곤고케 하셨음이라 어린 자녀들이 대적에게 사로잡혔도다","reference":"예레미야 애가 1:5","category":"$undefined"},{"id":"20317","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":6,"text":"처녀 시온의 모든 영광이 떠나감이여 저의 목백은 꼴을 찾지 못한 사슴이 쫓는 자 앞에서 힘없이 달림 같도다","reference":"예레미야 애가 1:6","category":"$undefined"},{"id":"20318","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":7,"text":"예루살렘이 환난과 군박을 당하는 날에 옛날의 모든 즐거움을 생각함이여 백성이 대적의 손에 빠지나 돕는 자가 없고 대적은 보고 그 황적함을 비웃도다","reference":"예레미야 애가 1:7","category":"$undefined"},{"id":"20319","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":8,"text":"예루살렘이 크게 범죄하므로 불결한 자 같이 되니 전에 높이던 모든 자가 그 적신을 보고 업신여김이여 저가 탄식하며 물러가도다","reference":"예레미야 애가 1:8","category":"$undefined"},{"id":"20320","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":9,"text":"저의 더러움이 그 치마에 있으나 결국을 생각지 아니함이여 그러므로 놀랍게 낮아져도 위로할 자가 없도다 여호와여, 원수가 스스로 큰 체하오니 나의 환난을 감찰하소서","reference":"예레미야 애가 1:9","category":"$undefined"},{"id":"20321","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":10,"text":"대적이 손을 펴서 보물을 빼앗았나이다 주께서 이미 이방인을 금하여 주의 공회에 들어오지 못하게 하셨사오나 저희가 성소에 들어간 것을 예루살렘이 보았나이다","reference":"예레미야 애가 1:10","category":"$undefined"},{"id":"20322","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":11,"text":"그 모든 백성이 생명을 소성시키려고 보물로 식물들을 바꾸었더니 지금도 탄식하며 양식을 구하나이다 나는 비천하오니 여호와여, 나를 권고하옵소서","reference":"예레미야 애가 1:11","category":"$undefined"},{"id":"20323","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":12,"text":"무릇 지나가는 자여 너희에게는 관계가 없는가 내게 임한 근심 같은 근심이 있는가,볼지어다 여호와께서 진노하신 날에 나를 괴롭게 하신 것이로다","reference":"예레미야 애가 1:12","category":"$undefined"},{"id":"20324","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":13,"text":"위에서부터 나의 골수에 불을 보내어 이기게 하시고 내 발 앞에 그물을 베푸사 나로 물러가게 하셨음이여 종일토록 고적하여 곤비케 하셨도다","reference":"예레미야 애가 1:13","category":"$undefined"},{"id":"20325","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":14,"text":"내 죄악의 멍에를 그 손으로 묶고 얽어 내 목에 올리사 내 힘을 피곤케 하셨음이여 내가 당할 수 없는 자의 손에 주께서 나를 붙이셨도다","reference":"예레미야 애가 1:14","category":"$undefined"},{"id":"20326","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":15,"text":"주께서 내 지경 안 모든 용사를 없는 것 같이 여기시고 성회를 모아 내 소년들을 부수심이여 처녀 유다를 술틀에 밟으셨도다","reference":"예레미야 애가 1:15","category":"$undefined"},{"id":"20327","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":16,"text":"이를 인하여 내가 우니 내 눈에 눈물이 물 같이 흐름이여, 나를 위로하여 내 영을 소성시킬 자가 멀리 떠났음이로다 원수들이 이기매 내 자녀들이 외롭도다","reference":"예레미야 애가 1:16","category":"$undefined"},{"id":"20328","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":17,"text":"시온이 두손을 폈으나 위로할 자가 없도다 여호와께서 야곱의 사면에 있는 자를 명하여 야곱의 대적이 되게 하셨으니 예루살렘은 저희 가운데 불결한 자 같도다","reference":"예레미야 애가 1:17","category":"$undefined"},{"id":"20329","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":18,"text":"여호와는 의로우시도다 내가 여호와의 명령을 거역하였도다 너희 모든 백성들아 내 말을 듣고 내 근심을 볼지어다 나의 처녀와 소년들이 사로잡혀 갔도다","reference":"예레미야 애가 1:18","category":"$undefined"},{"id":"20330","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":19,"text":"내가 내 사랑하는 자를 불렀으나 저희가 나를 속였으며 나의 제사장들과 장로들은 소성시킬 식물을 구하다가 성중에서 기절하였도다","reference":"예레미야 애가 1:19","category":"$undefined"},{"id":"20331","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":20,"text":"여호와여, 돌아보옵소서 내가 환난 중에서 마음이 괴롭고 마음이 번뇌하오니 나의 패역이 심히 큼이니이다 밖으로는 칼의 살륙이 있고 집에는 사망 같은 것이 있나이다","reference":"예레미야 애가 1:20","category":"$undefined"},{"id":"20332","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":21,"text":"저희가 나의 탄식을 들었으나 나를 위로하는 자가 없고 나의 모든 원수가 나의 재앙을 들었으나 주께서 이렇게 행하심을 기뻐하나이다 주께서 반포하신 날을 이르게 하시리니 저희가 나와 같이 되겠나이다","reference":"예레미야 애가 1:21","category":"$undefined"},{"id":"20333","book":"예레미야 애가","book_name":"예레미야 애가","chapter":1,"verse":22,"text":"저희 모든 악을 주 앞에 나타내시고 나의 모든 죄악을 인하여 내게 행하신 것같이 저희에게 행하옵소서 ! 나의 탄식이 많고 나의 마음이 곤비하니이다","reference":"예레미야 애가 1:22","category":"$undefined"}],"bookSlug":"jeremiah"}]
