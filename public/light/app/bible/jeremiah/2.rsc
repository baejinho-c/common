2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":2,"verses":[{"id":"18967","book":"예레미야","book_name":"예레미야","chapter":2,"verse":1,"text":"여호와의 말씀이 내게 임하니라 이르시되","reference":"예레미야 2:1","category":"$undefined"},{"id":"18968","book":"예레미야","book_name":"예레미야","chapter":2,"verse":2,"text":"가서 예루살렘 거민의 귀에 외쳐 말할지니라 여호와께서 이같이 말씀하시기를 네 소년 때의 우의와 네 결혼 때의 사랑 곧 씨 뿌리지 못하는 땅, 광야에서 어떻게 나를 좇았음을 내가 너를 위하여 기억하노라","reference":"예레미야 2:2","category":"$undefined"},{"id":"18969","book":"예레미야","book_name":"예레미야","chapter":2,"verse":3,"text":"그 때에 이스라엘은 나 여호와의 성물 곧 나의 소산 중 처음 열매가 되었나니 그를 삼키는 자면 다 벌을 받아 재앙을 만났으리라 여호와의 말이니라","reference":"예레미야 2:3","category":"$undefined"},{"id":"18970","book":"예레미야","book_name":"예레미야","chapter":2,"verse":4,"text":"야곱 집과 이스라엘 집 모든 가족아 ! 나 여호와의 말을 들으라","reference":"예레미야 2:4","category":"$undefined"},{"id":"18971","book":"예레미야","book_name":"예레미야","chapter":2,"verse":5,"text":"나 여호와가 이같이 말하노라 너희 열조가 내게서 무슨 불의함을 보았관대 나를 멀리하고 허탄한 것을 따라 헛되이 행하였느냐 ?","reference":"예레미야 2:5","category":"$undefined"},{"id":"18972","book":"예레미야","book_name":"예레미야","chapter":2,"verse":6,"text":"그들이 우리를 애굽 땅에서 인도하여 내시고 광야 곧 사막과 구덩이 땅,건조하고 사망의 음침한 땅,사람이 다니지 아니하고 거주하지 아니하는 땅을 통과케 하시던 여호와께서 어디 계시냐 말하지 아니하였도다","reference":"예레미야 2:6","category":"$undefined"},{"id":"18973","book":"예레미야","book_name":"예레미야","chapter":2,"verse":7,"text":"내가 너희를 인도하여 기름진 땅에 들여 그 과실과 그 아름다운 것을 먹게 하였거늘 너희가 이리로 들어와서는 내 땅을 더럽히고 내 기업을 가증히 만들었으며","reference":"예레미야 2:7","category":"$undefined"},{"id":"18974","book":"예레미야","book_name":"예레미야","chapter":2,"verse":8,"text":"제사장들은 여호와께서 어디 계시냐 하지 아니하며 법 잡은 자들은 나를 알지 못하며 관리들도 나를 항거하며 선지자들은 바알의 이름으로 예언하고 무익한 것을 좇았느니라","reference":"예레미야 2:8","category":"$undefined"},{"id":"18975","book":"예레미야","book_name":"예레미야","chapter":2,"verse":9,"text":"그러므로 내가 여전히 너희와 다투고 너희 후손과도 다투리라 여호와의 말이니라","reference":"예레미야 2:9","category":"$undefined"},{"id":"18976","book":"예레미야","book_name":"예레미야","chapter":2,"verse":10,"text":"너희는 깃딤 섬들에 건너가 보며 게달에도 사람을 보내어 이같은 일의 유무를 자세히 살펴보라","reference":"예레미야 2:10","category":"$undefined"},{"id":"18977","book":"예레미야","book_name":"예레미야","chapter":2,"verse":11,"text":"어느 나라가 그 신을 신 아닌 것과 바꾼일이 있느냐 ? 그러나 나의 백성은 그 영광을 무익한 것과 바꾸었도다","reference":"예레미야 2:11","category":"$undefined"},{"id":"18978","book":"예레미야","book_name":"예레미야","chapter":2,"verse":12,"text":"너 하늘아 이 일을 인하여 놀랄지어다 심히 떨지어다 두려워할지어다 여호와의 말이니라","reference":"예레미야 2:12","category":"$undefined"},{"id":"18979","book":"예레미야","book_name":"예레미야","chapter":2,"verse":13,"text":"내 백성이 두가지 악을 행하였나니 곧 생수의 근원되는 나를 버린 것과, 스스로 웅덩이를 판 것인데 그것은 물을 저축지 못할 터진 웅덩이니라","reference":"예레미야 2:13","category":"$undefined"},{"id":"18980","book":"예레미야","book_name":"예레미야","chapter":2,"verse":14,"text":"이스라엘이 종이냐 씨종이냐 ? 어찌하여 포로가 되었느냐 ?","reference":"예레미야 2:14","category":"$undefined"},{"id":"18981","book":"예레미야","book_name":"예레미야","chapter":2,"verse":15,"text":"어린 사자들이 너를 향하여 부르짖으며 소리를 날려 네 땅을 황무케 하였으며 네 성읍들은 불타서 거민이 없게 되었으며","reference":"예레미야 2:15","category":"$undefined"},{"id":"18982","book":"예레미야","book_name":"예레미야","chapter":2,"verse":16,"text":"놉과 다바네스의 자손도 네 정수리를 상하였으니","reference":"예레미야 2:16","category":"$undefined"},{"id":"18983","book":"예레미야","book_name":"예레미야","chapter":2,"verse":17,"text":"네 하나님 여호와가 너를 길로 인도할 때에 네가 나를 떠남으로 이를 자취함이 아니냐","reference":"예레미야 2:17","category":"$undefined"},{"id":"18984","book":"예레미야","book_name":"예레미야","chapter":2,"verse":18,"text":"네가 시홀의 물을 마시려고 애굽 길에 있음은 어찜이며 또 그 하수를 마시려고 앗수르 길에 있음은 어찜이요","reference":"예레미야 2:18","category":"$undefined"},{"id":"18985","book":"예레미야","book_name":"예레미야","chapter":2,"verse":19,"text":"네 악이 너를 징계하겠고 네 패역이 너를 책할 것이라 그런즉 네 하나님 여호와를 버림과 네 속에 나를 경외함이 없는 것이 악이요 고통인 줄 알라 주 만군의 여호와의 말이니라","reference":"예레미야 2:19","category":"$undefined"},{"id":"18986","book":"예레미야","book_name":"예레미야","chapter":2,"verse":20,"text":"네가 옛적부터 네 멍에를 꺾고 네 결박을 끊으며 말하기를 나는 순복지 아니하리라 하고 모든 높은 산 위와 모든 푸른 나무 아래서 몸을 굽혀 행음하도다","reference":"예레미야 2:20","category":"$undefined"},{"id":"18987","book":"예레미야","book_name":"예레미야","chapter":2,"verse":21,"text":"내가 너를 순전한 참 종자 곧 귀한 포도나무로 심었거늘 내게 대하여 이방 포도나무의 악한 가지가 됨은 어찜이뇨","reference":"예레미야 2:21","category":"$undefined"},{"id":"18988","book":"예레미야","book_name":"예레미야","chapter":2,"verse":22,"text":"주 여호와 내가 말하노라 ! 네가 잿물로 스스로 씻으며 수다한 비누를 쓸지라도 네 죄악이 오히려 내 앞에 그저 있으리니","reference":"예레미야 2:22","category":"$undefined"},{"id":"18989","book":"예레미야","book_name":"예레미야","chapter":2,"verse":23,"text":"네가 어찌 말하기를 나는 더럽히지 아니하였다 바알들을 좇지 아니하였다 하겠느냐 골짜기 속에 있는 네 길을 보라 네 행한 바를 알것이니라 너는 발이 빠른 젊은 암약대가 그 길에 어지러이 달림 같았으며","reference":"예레미야 2:23","category":"$undefined"},{"id":"18990","book":"예레미야","book_name":"예레미야","chapter":2,"verse":24,"text":"너는 광야에 익숙한 들 암나귀가 그 성욕이 동하므로 헐떡거림 같았도다 그 성욕의 때에 누가 그것을 막으리요 그것을 찾는 자들이 수고치 아니하고 그것의 달에 만나리라","reference":"예레미야 2:24","category":"$undefined"},{"id":"18991","book":"예레미야","book_name":"예레미야","chapter":2,"verse":25,"text":"내가 또 말하기를 네 발을 제어하여 벗은 발이 되게 말며 목을 갈하게 말라 하였으나 오직 너는 말하기를 아니라 이는 헛된 말이라 내가 이방 신을 사랑하였은즉 그를 따라 가겠노라 하도다","reference":"예레미야 2:25","category":"$undefined"},{"id":"18992","book":"예레미야","book_name":"예레미야","chapter":2,"verse":26,"text":"도적이 붙들리면 수치를 당함같이 이스라엘 집 곧 그 왕들과 족장들과 제사장들과 선지자들이 수치를 당하였느니라","reference":"예레미야 2:26","category":"$undefined"},{"id":"18993","book":"예레미야","book_name":"예레미야","chapter":2,"verse":27,"text":"그들이 나무를 향하여 너는 나의 아비라 하며 돌을 향하여 너는 나를 낳았다 하고 그 등을 내게로 향하고 그 얼굴은 내게로 향치 아니하다가 환난을 당할 때에는 이르기를 일어나 우리를 구원하소서 하리라","reference":"예레미야 2:27","category":"$undefined"},{"id":"18994","book":"예레미야","book_name":"예레미야","chapter":2,"verse":28,"text":"네가 만든 네 신들이 어디 있느뇨 ? 그들이 너의 환난을 당할 때에 구원할 수 있으면 일어날 것이니라 유다여, 너의 신들이 너의 성읍 수와 같도다","reference":"예레미야 2:28","category":"$undefined"},{"id":"18995","book":"예레미야","book_name":"예레미야","chapter":2,"verse":29,"text":"나 여호와가 말하노라 ! 너희가 나와 다툼은 어찜이뇨 너희가 다 내게 범과하였느니라","reference":"예레미야 2:29","category":"$undefined"},{"id":"18996","book":"예레미야","book_name":"예레미야","chapter":2,"verse":30,"text":"내가 너희 자녀를 때림도 무익함은 그들도 징책을 받지 아니함이라 너희 칼이 사나운 사자같이 너희 선지자들을 삼켰느니라","reference":"예레미야 2:30","category":"$undefined"},{"id":"18997","book":"예레미야","book_name":"예레미야","chapter":2,"verse":31,"text":"너희 이 세대여 여호와의 말을 들어 보라 내가 이스라엘에게 광야가 되었었느냐 흑암한 땅이 되었었느냐 무슨 연고로 내 백성이 말하기를 우리는 놓였으니 다시 주께로 가지 않겠다 하느냐","reference":"예레미야 2:31","category":"$undefined"},{"id":"18998","book":"예레미야","book_name":"예레미야","chapter":2,"verse":32,"text":"처녀가 어찌 그 패물을 잊겠느냐 ? 신부가 어찌 그 고운 옷을 잊겠느냐 ? 오직 내 백성은 나를 잊었나니 그 날 수는 계수할 수 없거늘","reference":"예레미야 2:32","category":"$undefined"},{"id":"18999","book":"예레미야","book_name":"예레미야","chapter":2,"verse":33,"text":"네가 어찌 사랑을 얻으려고 네 행위를 아름답게 꾸미느냐 ? 그러므로 네 행위를 악한 여자들에게까지 가르쳤으며","reference":"예레미야 2:33","category":"$undefined"},{"id":"19000","book":"예레미야","book_name":"예레미야","chapter":2,"verse":34,"text":"또 네 옷단에 죄 없는 가난한 자를 죽인 피가 묻었나니 그들이 담 구멍을 뚫음을 인함이 아니라 오직 이 모든 일로 너를 책망함을 인함이니라","reference":"예레미야 2:34","category":"$undefined"},{"id":"19001","book":"예레미야","book_name":"예레미야","chapter":2,"verse":35,"text":"그러나 너는 말하시기를 나는 무죄하니 그 진노가 참으로 내게서 떠났다 하거니와 보라 네 말이 나는 죄를 범치 아니하였다 함을 인하여 내가 너를 심판하리라","reference":"예레미야 2:35","category":"$undefined"},{"id":"19002","book":"예레미야","book_name":"예레미야","chapter":2,"verse":36,"text":"네가 어찌하여 네 길을 바꾸어 부지런히 돌아다니느뇨 네가 앗수르로 인하여 수치를 당함같이 애굽으로 인하여 수치를 당할 것이라","reference":"예레미야 2:36","category":"$undefined"},{"id":"19003","book":"예레미야","book_name":"예레미야","chapter":2,"verse":37,"text":"네가 두 손으로 네 머리를 싸고 거기서도 나가리니 이는 네가 의지하는 자들을 나 여호와가 버렸으므로 네가 그들을 인하여 형통치 못할 것임이니라","reference":"예레미야 2:37","category":"$undefined"},{"id":"20334","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":1,"text":"슬프다 주께서 어찌 그리 진노하사 처녀 시온을 구름으로 덮으셨는고 이스라엘의 아름다운 것을 하늘에서 땅에 던지셨음이여 진노하신 날에 그 발등상을 기억지 아니하셨도다","reference":"예레미야 애가 2:1","category":"$undefined"},{"id":"20335","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":2,"text":"주께서 야곱의 모든 거처를 삼키시고 긍휼히 여기지 아니하셨음이여 노하사 처녀 유다의 견고한 성을 헐어 땅에 엎으시고 나라와 방백으로 욕되게 하셨도다","reference":"예레미야 애가 2:2","category":"$undefined"},{"id":"20336","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":3,"text":"맹렬한 진노로 이스라엘 모든 뿔을 자르셨음이여 원수 앞에서 오른손을 거두시고 맹렬한 불이 사방으로 사름 같이 야곱을 사르셨도다","reference":"예레미야 애가 2:3","category":"$undefined"},{"id":"20337","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":4,"text":"원수 같이 활을 당기고 대적처럼 오른손을 들고 서서 눈에 아름다운 모든 자를 살륙하셨음이여 처녀 시온의 장막에 노를 불처럼 쏟으셨도다","reference":"예레미야 애가 2:4","category":"$undefined"},{"id":"20338","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":5,"text":"주께서 원수같이 되어 이스라엘을 삼키셨음이여 모든 궁을 삼키셨고 견고한 성들을 훼파하사 처녀 유다에 근심과 애통을 더하셨도다","reference":"예레미야 애가 2:5","category":"$undefined"},{"id":"20339","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":6,"text":"성막을 동산의 초막같이 헐어 버리시며 공회 처소를 훼파하셨도다 여호와께서 시온 가운데서 절기와 안식일을 잊어버리게 하시며 진노하사 왕과 제사장을 멸시하셨도다","reference":"예레미야 애가 2:6","category":"$undefined"},{"id":"20340","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":7,"text":"여호와께서 또 자기 제단을 버리시며 자기 성소를 미워하시며 궁장을 원수의 손에 붙이셨으매 저희가 여호와의 전에서 훤화하기를 절기 날과 같이 하였도다","reference":"예레미야 애가 2:7","category":"$undefined"},{"id":"20341","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":8,"text":"여호와께서 처녀 시온의 성을 헐기로 결심하시고 줄을 띠고 훼파함에서 손을 거두지 아니하사 성과 곽으로 통곡하게 하셨으매 저희가 함께 쇠하였도다","reference":"예레미야 애가 2:8","category":"$undefined"},{"id":"20342","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":9,"text":"성문이 땅에 묻히며 빗장이 꺾여 훼파되고 왕과 방백들이 율법없는 열방 가운데 있으며 그 선지자들은 여호와의 묵시를 받지 못하는도다","reference":"예레미야 애가 2:9","category":"$undefined"},{"id":"20343","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":10,"text":"처녀 시온의 장로들이 땅에 앉아 잠잠하고 티끌을 머리에 무릅쓰고 굵은 베를 허리에 둘렀음이여 예루살렘 처녀들은 머리를 땅에 숙였도다","reference":"예레미야 애가 2:10","category":"$undefined"},{"id":"20344","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":11,"text":"내 눈이 눈물에 상하며 내 창자가 끓으며 내 간이 땅에 쏟아졌으니 이는 처녀 내 백성이 패망하여 어린 자녀와 젖먹는 아이들이 성읍 길거리에 혼미함이로다","reference":"예레미야 애가 2:11","category":"$undefined"},{"id":"20345","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":12,"text":"저희가 성읍 길거리에서 상한 자처럼 혼미하여 그 어미의 품에서 혼이 떠날 때에 어미에게 이르기를 곡식과 포도주가 어디 있느뇨 ? 하도다","reference":"예레미야 애가 2:12","category":"$undefined"},{"id":"20346","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":13,"text":"처녀 예루살렘이여 내가 무엇으로 네게 증거하며 무엇으로 네게 비유할꼬 처녀 시온이여, 내가 무엇으로 네게 비교하여 너를 위로 할꼬 너의 파괴됨이 바다 같이 크니 누가 너를 고칠소냐","reference":"예레미야 애가 2:13","category":"$undefined"},{"id":"20347","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":14,"text":"네 선지자들이 네게 대하여 헛되고 어리석은 묵시를 보았으므로 네 죄악을 드러내어서 네 사로잡힌 것을 돌이키지 못하였도다 저희가 거짓 경고와 미혹케 할 것만 보았도다","reference":"예레미야 애가 2:14","category":"$undefined"},{"id":"20348","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":15,"text":"무릇 지나가는 자는 다 너를 향하여 박장하며 처녀 예루살렘을 향하여 비소하고 머리를 흔들며 말하기를 온전한 영광이라, 천하의 희락이라 일컫던 성이 이 성이냐 하며","reference":"예레미야 애가 2:15","category":"$undefined"},{"id":"20349","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":16,"text":"너의 모든 원수는 너를 향하여 입을 벌리며 비소하고 이를 갈며 말하기를 우리가 저를 삼켰도다 우리가 바라던 날이 과연 이 날이라 우리가 얻기도 하고 보기도 하였다 하도다","reference":"예레미야 애가 2:16","category":"$undefined"},{"id":"20350","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":17,"text":"여호와께서 이미 정하신 일을 행하시고 옛날에 명하신 말씀을 다 이루셨음이여 긍휼히 여기지 아니하시고 훼파하사 원수로 너를 인하여 즐거워하게 하며 너의 대적의 뿔로 높이 들리게 하셨도다","reference":"예레미야 애가 2:17","category":"$undefined"},{"id":"20351","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":18,"text":"저희 마음이 주를 향하여 부르짖기를 처녀 시온의 성곽아 너는 밤낮으로 눈물을 강처럼 흘릴지어다 스스로 쉬지 말고 네 눈동자로 쉬게 하지 말지어다","reference":"예레미야 애가 2:18","category":"$undefined"},{"id":"20352","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":19,"text":"밤 초경에 일어나 부르짖을지어다 네 마음을 주의 얼굴 앞에 물 쏟듯 할지어다 각 길머리에서 주려 혼미한 네 어린 자녀의 생명을 위하여 주를 향하여 손을 들지어다 하였도다","reference":"예레미야 애가 2:19","category":"$undefined"},{"id":"20353","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":20,"text":"여호와여, 감찰하소서 뉘게 이같이 행하셨는지요 여인들이 어찌 자기 열매 곧 손에 받든 아이를 먹으오며 제사장들과 선지자들이 어찌 주의 성소에서 살륙을 당하오리이까 ?","reference":"예레미야 애가 2:20","category":"$undefined"},{"id":"20354","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":21,"text":"노유는 다 길바닥에 엎드러졌사오며 내 처녀들과 소년들이 칼에 죽었나이다 주께서 진노하신 날에 죽이시되 긍휼히 여기지 아니하시고 살륙하셨나이다","reference":"예레미야 애가 2:21","category":"$undefined"},{"id":"20355","book":"예레미야 애가","book_name":"예레미야 애가","chapter":2,"verse":22,"text":"주께서 내 두려운 일을 사방에서 부르시기를 절기에 무리를 부름같이 하셨나이다 여호와께서 진노하신 날에 피하거나 남은 자가 없었나이다 내 손에 받들어 기르는 자를 내 원수가 다 멸하였나이다","reference":"예레미야 애가 2:22","category":"$undefined"}],"bookSlug":"jeremiah"}]
