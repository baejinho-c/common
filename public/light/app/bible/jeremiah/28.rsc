2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":28,"verses":[{"id":"19620","book":"예레미야","book_name":"예레미야","chapter":28,"verse":1,"text":"이 해 유다 왕 시드기야의 즉위한 지 오래지 않은 해 곧 사년 오월에 기브온 앗술의 아들 선지자 하나냐가 여호와의 집에서 제사장들과 모든 백성 앞에서 내게 말하여 가로되","reference":"예레미야 28:1","category":"$undefined"},{"id":"19621","book":"예레미야","book_name":"예레미야","chapter":28,"verse":2,"text":"만군의 여호와 이스라엘의 하나님이 이같이 말씀하여 가라사대 내가 바벨론 왕의 멍에를 꺾었느니라","reference":"예레미야 28:2","category":"$undefined"},{"id":"19622","book":"예레미야","book_name":"예레미야","chapter":28,"verse":3,"text":"내가 바벨론 왕 느부갓네살의 이 곳에서 바벨론으로 옮겨간 여호와의 집 모든 기구를 두 해가 차기 전에 다시 이 곳으로 가져오게 하겠고","reference":"예레미야 28:3","category":"$undefined"},{"id":"19623","book":"예레미야","book_name":"예레미야","chapter":28,"verse":4,"text":"내가 또 유다 왕 여호야김의 아들 여고니야와 바벨론으로 간 유다 모든 포로들 다시 이 곳으로 돌아오게 하리니 이는 내가 바벨론 왕의 멍에를 꺾을 것임이니라 여호와의 말이니라 하셨다 하는지라","reference":"예레미야 28:4","category":"$undefined"},{"id":"19624","book":"예레미야","book_name":"예레미야","chapter":28,"verse":5,"text":"선지자 예레미야가 여호와의 집에 선 제사장들의 앞과 모든 백성앞에서 선지자 하나냐에게 말할쌔","reference":"예레미야 28:5","category":"$undefined"},{"id":"19625","book":"예레미야","book_name":"예레미야","chapter":28,"verse":6,"text":"선지자 예레미야가 말하되 아멘, 여호와는 이같이 하옵소서 여호와께서 네 예언대로 이루사 여호와의 집 기구와 모든 포로를 바벨론에서 이 곳으로 다시 옮겨오시기를 원하노라","reference":"예레미야 28:6","category":"$undefined"},{"id":"19626","book":"예레미야","book_name":"예레미야","chapter":28,"verse":7,"text":"그러나 너는 이제 내가 네 귀와 모든 백성의 귀에 이르는 이 말을 들으라","reference":"예레미야 28:7","category":"$undefined"},{"id":"19627","book":"예레미야","book_name":"예레미야","chapter":28,"verse":8,"text":"나와 너 이전 선지자들이 자고로 여러 나라와 큰 국가들에 대하여 전쟁과 재앙과 염병을 예언하였느니라","reference":"예레미야 28:8","category":"$undefined"},{"id":"19628","book":"예레미야","book_name":"예레미야","chapter":28,"verse":9,"text":"평화를 예언하는 선지자는 그 예언자의 말이 응한 후에야 그는 진실로 여호와의 보내신 선지자로 알게 되리라","reference":"예레미야 28:9","category":"$undefined"},{"id":"19629","book":"예레미야","book_name":"예레미야","chapter":28,"verse":10,"text":"선지자 하나냐가 선지자 예레미야의 목에서 멍에를 취하여 꺾고","reference":"예레미야 28:10","category":"$undefined"},{"id":"19630","book":"예레미야","book_name":"예레미야","chapter":28,"verse":11,"text":"모든 백성 앞에서 말하여 가로되 여호와께서 이같이 말씀하시되 내가 두 해가 차기 전에 열방의 목에서 바벨론 왕 느부갓네살의 멍에를 이같이 꺾어 버리리라 하셨느니라 하매 선지자 예레미야가 자기 길을 가니라","reference":"예레미야 28:11","category":"$undefined"},{"id":"19631","book":"예레미야","book_name":"예레미야","chapter":28,"verse":12,"text":"선지자 하나냐가 선지자 예레미야의 목에서 멍에를 꺾어버린 후에 여호와의 말씀이 예레미야에게 임하니라 가라사대","reference":"예레미야 28:12","category":"$undefined"},{"id":"19632","book":"예레미야","book_name":"예레미야","chapter":28,"verse":13,"text":"너는 가서 하나냐에게 말하여 이르기를 여호와의 말씀에 네가 나무 멍에를 꺾었으나 그 대신 쇠 멍에를 만들었느니라","reference":"예레미야 28:13","category":"$undefined"},{"id":"19633","book":"예레미야","book_name":"예레미야","chapter":28,"verse":14,"text":"만군의 여호와 이스라엘의 하나님이 이같이 말하노라 내가 쇠 멍에로 이 모든 나라의 목에 메워 바벨론 왕 느부갓네살을 섬기게 하였으니 그들이 그를 섬기리라 내가 들짐승도 그에게 주었느니라 하신다 하라","reference":"예레미야 28:14","category":"$undefined"},{"id":"19634","book":"예레미야","book_name":"예레미야","chapter":28,"verse":15,"text":"선지자 예레미야가 선지자 하나냐에게 이르되 하나냐여 들으라 여호와께서 너를 보내지 아니하셨거늘 네가 이 백성으로 거짓을 믿게 하는도다","reference":"예레미야 28:15","category":"$undefined"},{"id":"19635","book":"예레미야","book_name":"예레미야","chapter":28,"verse":16,"text":"그러므로 여호와께서 말씀하시되 내가 너를 지면에서 제하리니 네가 여호와께 패역하는 말을 하였음이라 금년에 죽으리라 하셨느니라 하더니","reference":"예레미야 28:16","category":"$undefined"},{"id":"19636","book":"예레미야","book_name":"예레미야","chapter":28,"verse":17,"text":"선지자 하나냐가 그 해 칠 월에 죽었더라","reference":"예레미야 28:17","category":"$undefined"}],"bookSlug":"jeremiah"}]
