2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":3,"verses":[{"id":"19004","book":"예레미야","book_name":"예레미야","chapter":3,"verse":1,"text":"세상에서 말하기를 가령 사람이 그 아내를 버리므로 그가 떠나 타인의 아내가 된다 하자 본부가 그를 다시 받겠느냐 ? 그리하면 그 땅이 크게 더러워지지 않겠느냐 ? 하느니라 나 여호와가 말하노라 네가 많은 무리와 행음하고도 내게로 돌아오려느냐 ?","reference":"예레미야 3:1","category":"$undefined"},{"id":"19005","book":"예레미야","book_name":"예레미야","chapter":3,"verse":2,"text":"네 눈을 들어 자산을 보라 너의 행음치 아니한 곳이 어디 있느냐 ? 네가 길 가에 앉아 사람을 기다린 것이 광야에 있는 아라바 사람같아서 음란과 행악으로 이 땅을 더럽혔도다","reference":"예레미야 3:2","category":"$undefined"},{"id":"19006","book":"예레미야","book_name":"예레미야","chapter":3,"verse":3,"text":"그러므로 단 비가 그쳐졌고 늦은 비가 없어졌느니라 그럴지라도 네가 창녀의 낯을 가졌으므로 수치를 알지 못하느니라","reference":"예레미야 3:3","category":"$undefined"},{"id":"19007","book":"예레미야","book_name":"예레미야","chapter":3,"verse":4,"text":"네가 이제부터는 내게 부르짖기를 나의 아버지여, 아버지는 나의 소시의 애호자시오니","reference":"예레미야 3:4","category":"$undefined"},{"id":"19008","book":"예레미야","book_name":"예레미야","chapter":3,"verse":5,"text":"노를 한 없이 계속하시겠으며 끝까지 두시겠나이까 하지 않겠느냐 보라 네가 이같이 말하여도 악을 행하여 네 욕심을 이루었느니라 하시니라","reference":"예레미야 3:5","category":"$undefined"},{"id":"19009","book":"예레미야","book_name":"예레미야","chapter":3,"verse":6,"text":"요시야 왕 때에 여호와께서 또 내게 이르시되 네가 배역한 이스라엘의 행한 바를 보았느냐 그가 모든 높은 산에 오르며 모든 푸른나무 아래로 가서 거기서 행음하였도다","reference":"예레미야 3:6","category":"$undefined"},{"id":"19010","book":"예레미야","book_name":"예레미야","chapter":3,"verse":7,"text":"그가 이 모든 일을 행한 후에 내가 말하기를 그가 내게로 돌아오리라 하였으나 오히려 내게로 돌아오지 아니하였고 그 패역한 자매 유다는 그것을 보았느니라","reference":"예레미야 3:7","category":"$undefined"},{"id":"19011","book":"예레미야","book_name":"예레미야","chapter":3,"verse":8,"text":"내게 배역한 이스라엘이 간음을 행하였으므로 내가 그를 내어 쫓고 이혼서까지 주었으되 그 패역한 자매 유다가 두려워 아니하고 자기도 가서 행음함을 내가 보았노라","reference":"예레미야 3:8","category":"$undefined"},{"id":"19012","book":"예레미야","book_name":"예레미야","chapter":3,"verse":9,"text":"그가 돌과 나무로 더불어 행음함을 가볍게 여기고 행음하여 이 땅을 더럽혔거늘","reference":"예레미야 3:9","category":"$undefined"},{"id":"19013","book":"예레미야","book_name":"예레미야","chapter":3,"verse":10,"text":"이 모든 일이 있어도 그 패역한 자매 유다가 진심으로 내게 돌아오지 아니하고 거짓으로 할 뿐이니라 여호와의 말이니라 !","reference":"예레미야 3:10","category":"$undefined"},{"id":"19014","book":"예레미야","book_name":"예레미야","chapter":3,"verse":11,"text":"여호와께서 내게 이르시되 배역한 이스라엘은 패역한 유다보다 오히려 의로움이 나타났나니","reference":"예레미야 3:11","category":"$undefined"},{"id":"19015","book":"예레미야","book_name":"예레미야","chapter":3,"verse":12,"text":"너는 가서 북을 향하여 이 말을 선포하여 이르라 여호와께서 가라사대 배역한 이스라엘아 돌아오라 ! 나의 노한 얼굴을 너희에게로 향하지 아니하리라 나는 긍휼이 있는 자라 노를 한 없이 품지 아니하느니라 여호와의 말이니라","reference":"예레미야 3:12","category":"$undefined"},{"id":"19016","book":"예레미야","book_name":"예레미야","chapter":3,"verse":13,"text":"너는 오직 네 죄를 자복하라 ! 이는 네 하나님 여호와를 배반하고 네 길로 달려 모든 푸른 나무 아래서 이방 신에게 절하고 내 목 소리를 듣지 아니하였음이니라 여호와의 말이니라","reference":"예레미야 3:13","category":"$undefined"},{"id":"19017","book":"예레미야","book_name":"예레미야","chapter":3,"verse":14,"text":"나 여호와가 말하노라 배역한 자식들아 돌아오라 ! 나는 너희 남편임이니라 ! 내가 너희를 성읍에서 하나와 족속 중에서 둘을 택하여 시온으로 데려오겠고","reference":"예레미야 3:14","category":"$undefined"},{"id":"19018","book":"예레미야","book_name":"예레미야","chapter":3,"verse":15,"text":"내가 또 내 마음에 합하는 목자를 너희에게 주리니 그들이 지식과 명철로 너희를 양육하리라","reference":"예레미야 3:15","category":"$undefined"},{"id":"19019","book":"예레미야","book_name":"예레미야","chapter":3,"verse":16,"text":"나 여호와가 말하노라 너희가 이 땅에서 번성하여 많아질 때에는 사람 사람이 여호와의 언약궤를 다시는 말하지 아니할 것이요, 생각지 아니할 것이요, 기억지 아니할 것이요, 찾지 아니할 것이요, 만들지 아니할 것이며","reference":"예레미야 3:16","category":"$undefined"},{"id":"19020","book":"예레미야","book_name":"예레미야","chapter":3,"verse":17,"text":"그 때에 예루살렘이 여호와의 보좌라 일컬음이 되며 열방이 그리로 모이리니 곧 여호와의 이름으로 인하여 예루살렘에 모이고 다시는 그들의 악한 마음의 강퍅한 대로 행치 아니할 것이며","reference":"예레미야 3:17","category":"$undefined"},{"id":"19021","book":"예레미야","book_name":"예레미야","chapter":3,"verse":18,"text":"그 때에 유다 족속이 이스라엘 족속과 동행하여 북에서부터 나와서 내가 너희 열조에게 기업으로 준 땅에 함께 이르리라","reference":"예레미야 3:18","category":"$undefined"},{"id":"19022","book":"예레미야","book_name":"예레미야","chapter":3,"verse":19,"text":"내가 스스로 말하기를 내가 어떻게 하든지 너를 자녀 중에 두며 허다한 나라 중에 아름다운 산업인 이 낙토를 네게 주리라 하였고 내가 다시 말하기를 너희가 나를 나의 아버지라 하고 나를 떠나지 말것이니라 하였노라","reference":"예레미야 3:19","category":"$undefined"},{"id":"19023","book":"예레미야","book_name":"예레미야","chapter":3,"verse":20,"text":"그런데 이스라엘 족속아 ! 마치 아내가 그 남편을 속이고 떠남같이 너희가 정녕히 나를 속였느니라 여호와의 말이니라","reference":"예레미야 3:20","category":"$undefined"},{"id":"19024","book":"예레미야","book_name":"예레미야","chapter":3,"verse":21,"text":"소리가 자산 위에서 들리니 곧 이스라엘 자손의 애곡하며 간구하는 것이라 그들이 그 길을 굽게 하며 자기 하나님 여호와를 잊어버렸음이로다","reference":"예레미야 3:21","category":"$undefined"},{"id":"19025","book":"예레미야","book_name":"예레미야","chapter":3,"verse":22,"text":"배역한 자식들아 돌아오라 내가 너희의 배역함을 고치리라 보소서 ! 우리가 주께 왔사오니 주는 우리 하나님 여호와이심이니이다","reference":"예레미야 3:22","category":"$undefined"},{"id":"19026","book":"예레미야","book_name":"예레미야","chapter":3,"verse":23,"text":"작은 산들과 큰 산 위의 떠드는 무리에게 바라는 것은 참으로 허사라 이스라엘의 구원은 진실로 우리 하나님 여호와께 있나이다","reference":"예레미야 3:23","category":"$undefined"},{"id":"19027","book":"예레미야","book_name":"예레미야","chapter":3,"verse":24,"text":"부끄러운 그것이 우리의 어렸을 때로부터 우리 열조의 산업인 양떼와 소떼와 아들들과 딸들을 삼켰사온즉","reference":"예레미야 3:24","category":"$undefined"},{"id":"19028","book":"예레미야","book_name":"예레미야","chapter":3,"verse":25,"text":"우리는 수치 중에 눕겠고 우리는 수욕에 덮이울 것이니 이는 우리와 우리 열조가 어렸을 때로부터 오늘까지 우리 하나님 여호와께 범죄하여 우리 하나님 여호와의 목소리를 청종치 아니하였음이니이다","reference":"예레미야 3:25","category":"$undefined"},{"id":"20356","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":1,"text":"여호와의 노하신 매로 인하여 고난 당한 자는 내로다","reference":"예레미야 애가 3:1","category":"$undefined"},{"id":"20357","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":2,"text":"나를 이끌어 흑암에 행하고 광명에 행치 않게 하셨으며","reference":"예레미야 애가 3:2","category":"$undefined"},{"id":"20358","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":3,"text":"종일토록 손을 돌이켜 자주 자주 나를 치시도다","reference":"예레미야 애가 3:3","category":"$undefined"},{"id":"20359","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":4,"text":"나의 살과 가죽을 쇠하게 하시며 나의 뼈를 꺾으셨고","reference":"예레미야 애가 3:4","category":"$undefined"},{"id":"20360","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":5,"text":"담즙과 수고를 쌓아 나를 에우셨으며","reference":"예레미야 애가 3:5","category":"$undefined"},{"id":"20361","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":6,"text":"나로 흑암에 거하게 하시기를 죽은지 오랜 자 같게 하셨도다","reference":"예레미야 애가 3:6","category":"$undefined"},{"id":"20362","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":7,"text":"나를 둘러 싸서 나가지 못하게 하시고 나의 사슬을 무겁게 하셨으며","reference":"예레미야 애가 3:7","category":"$undefined"},{"id":"20363","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":8,"text":"내가 부르짖어 도움을 구하나 내 기도를 물리치시며","reference":"예레미야 애가 3:8","category":"$undefined"},{"id":"20364","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":9,"text":"다듬은 돌을 쌓아 내 길을 막으사 내 첩경을 굽게 하셨도다","reference":"예레미야 애가 3:9","category":"$undefined"},{"id":"20365","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":10,"text":"저는 내게 대하여 엎드리어 기다리는 곰과 은밀한 곳의 사자 같으사","reference":"예레미야 애가 3:10","category":"$undefined"},{"id":"20366","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":11,"text":"나의 길로 치우치게 하시며 내 몸을 찢으시며 나로 적막하게 하셨도다","reference":"예레미야 애가 3:11","category":"$undefined"},{"id":"20367","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":12,"text":"활을 당기고 나로 과녁을 삼으심이여","reference":"예레미야 애가 3:12","category":"$undefined"},{"id":"20368","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":13,"text":"전동의 살로 내 허리를 맞추셨도다","reference":"예레미야 애가 3:13","category":"$undefined"},{"id":"20369","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":14,"text":"나는 내 모든 백성에게 조롱거리 곧 종일토록 그들의 노랫거리가 되었도다","reference":"예레미야 애가 3:14","category":"$undefined"},{"id":"20370","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":15,"text":"나를 쓴 것으로 배불리시고 쑥으로 취하게 하셨으며","reference":"예레미야 애가 3:15","category":"$undefined"},{"id":"20371","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":16,"text":"조약돌로 내 이를 꺾으시고 재로 나를 덮으셨도다","reference":"예레미야 애가 3:16","category":"$undefined"},{"id":"20372","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":17,"text":"주께서 내 심령으로 평강을 멀리 떠나게 하시니 내가 복을 잊어버렸음이여","reference":"예레미야 애가 3:17","category":"$undefined"},{"id":"20373","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":18,"text":"스스로 이르기를 나의 힘과 여호와께 대한 내 소망이 끊어졌다 하였도다","reference":"예레미야 애가 3:18","category":"$undefined"},{"id":"20374","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":19,"text":"내 고초와 재난 곧 쑥과 담즙을 기억하소서 !","reference":"예레미야 애가 3:19","category":"$undefined"},{"id":"20375","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":20,"text":"내 심령이 그것을 기억하고 낙심이 되오나","reference":"예레미야 애가 3:20","category":"$undefined"},{"id":"20376","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":21,"text":"중심에 회상한즉 오히려 소망이 있사옴은","reference":"예레미야 애가 3:21","category":"$undefined"},{"id":"20377","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":22,"text":"여호와의 자비와 긍휼이 무궁하시므로 우리가 진멸되지 아니함이니이다","reference":"예레미야 애가 3:22","category":"$undefined"},{"id":"20378","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":23,"text":"이것이 아침마다 새로우니 주의 성실이 크도소이다","reference":"예레미야 애가 3:23","category":"$undefined"},{"id":"20379","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":24,"text":"내 심령에 이르기를 여호와는 나의 기업이시니 그러므로 내가 저를 바라리라 하도다","reference":"예레미야 애가 3:24","category":"$undefined"},{"id":"20380","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":25,"text":"무릇 기다리는 자에게나 구하는 영혼에게 여호와께서 선을 베푸시는 도다","reference":"예레미야 애가 3:25","category":"$undefined"},{"id":"20381","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":26,"text":"사람이 여호와의 구원을 바라고 잠잠히 기다림이 좋도다","reference":"예레미야 애가 3:26","category":"$undefined"},{"id":"20382","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":27,"text":"사람이 젊었을 때에 멍에를 메는 것이 좋으니","reference":"예레미야 애가 3:27","category":"$undefined"},{"id":"20383","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":28,"text":"혼자 앉아서 잠잠할 것은 주께서 그것을 메우셨음이라","reference":"예레미야 애가 3:28","category":"$undefined"},{"id":"20384","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":29,"text":"입을 티끌에 댈지어다 혹시 소망이 있을지로다","reference":"예레미야 애가 3:29","category":"$undefined"},{"id":"20385","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":30,"text":"때리는 자에게 뺨을 향하여 수욕으로 배불릴지어다","reference":"예레미야 애가 3:30","category":"$undefined"},{"id":"20386","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":31,"text":"이는 주께서 영원토록 버리지 않으실 것임이며","reference":"예레미야 애가 3:31","category":"$undefined"},{"id":"20387","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":32,"text":"저가 비록 근심케 하시나 그 풍부한 자비대로 긍휼히 여기실 것임이니라","reference":"예레미야 애가 3:32","category":"$undefined"},{"id":"20388","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":33,"text":"주께서 인생으로 고생하며 근심하게 하심이 본심이 아니시로다","reference":"예레미야 애가 3:33","category":"$undefined"},{"id":"20389","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":34,"text":"세상에 모든 갇힌 자를 발로 밟는 것과","reference":"예레미야 애가 3:34","category":"$undefined"},{"id":"20390","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":35,"text":"지극히 높으신 자의 얼굴 앞에서 사람의 재판을 굽게 하는 것과","reference":"예레미야 애가 3:35","category":"$undefined"},{"id":"20391","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":36,"text":"사람의 송사를 억울케 하는 것은 다 주의 기쁘게 보시는 것이 아니로다","reference":"예레미야 애가 3:36","category":"$undefined"},{"id":"20392","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":37,"text":"주의 명령이 아니면 누가 능히 말하여 이루게 하라","reference":"예레미야 애가 3:37","category":"$undefined"},{"id":"20393","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":38,"text":"화, 복이 지극히 높으신 자의 입으로 나오지 아니하느냐","reference":"예레미야 애가 3:38","category":"$undefined"},{"id":"20394","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":39,"text":"살아 있는 사람은 자기 죄로 벌을 받나니 어찌 원망하랴","reference":"예레미야 애가 3:39","category":"$undefined"},{"id":"20395","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":40,"text":"우리가 스스로 행위를 조사하고 여호와께로 돌아가자","reference":"예레미야 애가 3:40","category":"$undefined"},{"id":"20396","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":41,"text":"마음과 손을 아울러 하늘에 계신 하나님께 들자","reference":"예레미야 애가 3:41","category":"$undefined"},{"id":"20397","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":42,"text":"우리의 범죄함과 패역함을 주께서 사하지 아니하시고","reference":"예레미야 애가 3:42","category":"$undefined"},{"id":"20398","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":43,"text":"진노로 스스로 가리우시고 우리를 군축하시며 살륙하사 긍휼을 베풀지 아니하셨나이다","reference":"예레미야 애가 3:43","category":"$undefined"},{"id":"20399","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":44,"text":"주께서 구름으로 스스로 가리우사 기도로 상달치 못하게 하시고","reference":"예레미야 애가 3:44","category":"$undefined"},{"id":"20400","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":45,"text":"우리를 열방 가운데서 진개와 폐물을 삼으셨으므로","reference":"예레미야 애가 3:45","category":"$undefined"},{"id":"20401","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":46,"text":"우리의 모든 대적이 우리를 향하여 입을 크게 벌렸나이다","reference":"예레미야 애가 3:46","category":"$undefined"},{"id":"20402","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":47,"text":"두려움과 함정과 잔해와 멸망이 우리에게 임하였도다","reference":"예레미야 애가 3:47","category":"$undefined"},{"id":"20403","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":48,"text":"처녀 내 백성의 파멸을 인하여 내 눈에 눈물이 시내처럼 흐르도다","reference":"예레미야 애가 3:48","category":"$undefined"},{"id":"20404","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":49,"text":"내 눈의 흐르는 눈물이 그치지 아니하고 쉬지 아니함이여","reference":"예레미야 애가 3:49","category":"$undefined"},{"id":"20405","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":50,"text":"여호와께서 하늘에서 살피시고 돌아보시기를 기다리는도다","reference":"예레미야 애가 3:50","category":"$undefined"},{"id":"20406","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":51,"text":"나의 성읍의 모든 여자를 인하여 내 눈이 내 심령을 상하게 하는도다","reference":"예레미야 애가 3:51","category":"$undefined"},{"id":"20407","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":52,"text":"무고히 나의 대적이 된 자가 나를 새와 같이 심히 쫓도다","reference":"예레미야 애가 3:52","category":"$undefined"},{"id":"20408","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":53,"text":"저희가 내 생명을 끊으려고 나를 구덩이에 넣고 그 위에 돌을 던짐이여","reference":"예레미야 애가 3:53","category":"$undefined"},{"id":"20409","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":54,"text":"물이 내 머리에 넘치니 내가 스스로 이르기를 이제는 멸절되었다 하도다","reference":"예레미야 애가 3:54","category":"$undefined"},{"id":"20410","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":55,"text":"여호와여, 내가 심히 깊은 구덩이에서 주의 이름을 불렀나이다","reference":"예레미야 애가 3:55","category":"$undefined"},{"id":"20411","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":56,"text":"주께서 이미 나의 음성을 들으셨사오니 이제 나의 탄식과 부르짖음에 주의 귀를 가리우지 마옵소서","reference":"예레미야 애가 3:56","category":"$undefined"},{"id":"20412","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":57,"text":"내가 주께 아뢴 날에 주께서 내게 가까이 하여 가라사대 두려워 말라 하셨나이다","reference":"예레미야 애가 3:57","category":"$undefined"},{"id":"20413","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":58,"text":"주여, 주께서 내 심령의 원통을 펴셨고 내 생명을 속하셨나이다","reference":"예레미야 애가 3:58","category":"$undefined"},{"id":"20414","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":59,"text":"여호와여, 나의 억울을 감찰하셨사오니 나를 위하여 신원하옵소서","reference":"예레미야 애가 3:59","category":"$undefined"},{"id":"20415","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":60,"text":"저희가 내게 보수하며 나를 모해함을 주께서 다 감찰하셨나이다","reference":"예레미야 애가 3:60","category":"$undefined"},{"id":"20416","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":61,"text":"여호와여, 저희가 나를 훼파하며 나를 모해하는것","reference":"예레미야 애가 3:61","category":"$undefined"},{"id":"20417","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":62,"text":"곧 일어나 나를 치는 자의 입술에서 나오는 것과 종일 모해하는 것을 들으셨나이다","reference":"예레미야 애가 3:62","category":"$undefined"},{"id":"20418","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":63,"text":"저희가 앉든지 서든지 나를 노래하는 것을 주여, 보옵소서","reference":"예레미야 애가 3:63","category":"$undefined"},{"id":"20419","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":64,"text":"여호와여, 주께서 저의 손으로 행한 대로 보응하사","reference":"예레미야 애가 3:64","category":"$undefined"},{"id":"20420","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":65,"text":"그 마음을 강퍅하게 하시고 저주를 더하시며","reference":"예레미야 애가 3:65","category":"$undefined"},{"id":"20421","book":"예레미야 애가","book_name":"예레미야 애가","chapter":3,"verse":66,"text":"진노로 저희를 군축하사 여호와의 천하에서 멸하시리이다","reference":"예레미야 애가 3:66","category":"$undefined"}],"bookSlug":"jeremiah"}]
