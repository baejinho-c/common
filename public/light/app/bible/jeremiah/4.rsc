2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":4,"verses":[{"id":"19029","book":"예레미야","book_name":"예레미야","chapter":4,"verse":1,"text":"여호와께서 가라사대 이스라엘아 네가 돌아오려거든 내게로 돌아오라 네가 만일 나의 목전에서 가증한 것을 버리고 마음이 요동치 아니하며","reference":"예레미야 4:1","category":"$undefined"},{"id":"19030","book":"예레미야","book_name":"예레미야","chapter":4,"verse":2,"text":"진실과 공평과 정의로 여호와의 삶을 가리켜 맹세하면 열방이 나로 인하여 스스로 복을 빌며 나로 인하여 자랑하리라","reference":"예레미야 4:2","category":"$undefined"},{"id":"19031","book":"예레미야","book_name":"예레미야","chapter":4,"verse":3,"text":"나 여호와가 유다와 예루살렘 사람에게 이같이 이르노라 너희 묵은 땅을 갈고 가시덤불 속에 파종하지 말라","reference":"예레미야 4:3","category":"$undefined"},{"id":"19032","book":"예레미야","book_name":"예레미야","chapter":4,"verse":4,"text":"유다인과 예루살렘 거민들아 너희는 스스로 할례를 행하여 너희 마음 가죽을 베고 나 여호와께 속하라 그렇지 아니하면 너희 행악을 인하여 나의 분노가 불같이 발하여 사르리니 그것을 끌 자가 없으리라","reference":"예레미야 4:4","category":"$undefined"},{"id":"19033","book":"예레미야","book_name":"예레미야","chapter":4,"verse":5,"text":"너희는 유다에 선포하며 예루살렘에 공포하여 이르기를 이 땅에서 나팔을 불라 하며 또 크게 외쳐 이르기를 너희는 모이라 우리가 견고한 성으로 들어가자 하고","reference":"예레미야 4:5","category":"$undefined"},{"id":"19034","book":"예레미야","book_name":"예레미야","chapter":4,"verse":6,"text":"시온을 향하여 기호를 세우라, 도피하라, 지체하지 말라, 내가 북방에서 재앙과 큰 멸망으로 이르게 할 것임이니라","reference":"예레미야 4:6","category":"$undefined"},{"id":"19035","book":"예레미야","book_name":"예레미야","chapter":4,"verse":7,"text":"사자가 그 수풀에서 올라왔으며 열방을 멸하는 자가 나아왔으되 네 땅을 황폐케 하려고 이미 그 처소를 떠나 나왔은즉 네 성읍들이 황폐하여 거민이 없게 되리니","reference":"예레미야 4:7","category":"$undefined"},{"id":"19036","book":"예레미야","book_name":"예레미야","chapter":4,"verse":8,"text":"이를 인하여 너희는 굵은 베를 두르고 애곡하라 대저 여호와의 맹렬한 노가 아직 너희에게서 돌이키지 아니하였음이니라","reference":"예레미야 4:8","category":"$undefined"},{"id":"19037","book":"예레미야","book_name":"예레미야","chapter":4,"verse":9,"text":"나 여호와가 말하노라 그 날에 왕과 방백들은 실심할 것이며 제사장들은 놀랄 것이며 선지자들은 깜짝 놀라리라","reference":"예레미야 4:9","category":"$undefined"},{"id":"19038","book":"예레미야","book_name":"예레미야","chapter":4,"verse":10,"text":"내가 가로되 슬프도소이다 주 여호와여, 주께서 진실로 이 백성과 예루살렘을 크게 속이셨나이다 이르시기를 너희에게 평강이 있으리라 하시더니 칼이 생명에 미쳤나이다","reference":"예레미야 4:10","category":"$undefined"},{"id":"19039","book":"예레미야","book_name":"예레미야","chapter":4,"verse":11,"text":"그 때에 이 백성과 예루살렘에 이를 자 있어서 뜨거운 바람이 광야 자산에서 내 딸 백성에게 불어온다 하리라 이는 키질하기 위함도 아니요 정결케 하려 함도 아니며","reference":"예레미야 4:11","category":"$undefined"},{"id":"19040","book":"예레미야","book_name":"예레미야","chapter":4,"verse":12,"text":"이보다 더 강한 바람이 나를 위하여 오리니 이제 내가 그들에게 심판을 베풀 것이라","reference":"예레미야 4:12","category":"$undefined"},{"id":"19041","book":"예레미야","book_name":"예레미야","chapter":4,"verse":13,"text":"보라 그가 구름같이 올라오나니 그 병거는 회리바람 같고 그 말들은 독수리보다 빠르도다 우리에게 화 있도다 ! 우리는 멸망하도다 하리라","reference":"예레미야 4:13","category":"$undefined"},{"id":"19042","book":"예레미야","book_name":"예레미야","chapter":4,"verse":14,"text":"예루살렘아 네 마음의 악을 씻어 버리라 ! 그리하면 구원을 얻으리라 ! 네 악한 생각이 네 속에 얼마나 오래 머물겠느냐 ?","reference":"예레미야 4:14","category":"$undefined"},{"id":"19043","book":"예레미야","book_name":"예레미야","chapter":4,"verse":15,"text":"단에서 소리를 선포하며 에브라임 산에서 재앙을 공포하는도다","reference":"예레미야 4:15","category":"$undefined"},{"id":"19044","book":"예레미야","book_name":"예레미야","chapter":4,"verse":16,"text":"너희는 열방에 고하며 또 예루살렘에 알게 하기를 에워싸고 치는 자들이 먼 땅에서부터 와서 유다 성읍들을 향하여 소리를 지른다 하라","reference":"예레미야 4:16","category":"$undefined"},{"id":"19045","book":"예레미야","book_name":"예레미야","chapter":4,"verse":17,"text":"그들이 밭을 지키는 자 같이 예루살렘을 에워싸나니 이는 그가 나를 거역한 연고니라 여호와의 말이니라","reference":"예레미야 4:17","category":"$undefined"},{"id":"19046","book":"예레미야","book_name":"예레미야","chapter":4,"verse":18,"text":"네 길과 행사가 이 일들을 부르게 하였나니 이는 너의 악함이라 그 고통이 네 마음에까지 미치느니라","reference":"예레미야 4:18","category":"$undefined"},{"id":"19047","book":"예레미야","book_name":"예레미야","chapter":4,"verse":19,"text":"슬프고 아프다, 내 마음속이 아프고 내 마음이 답답하여 잠잠할 수 없으니 이는 나의 심령 네가 나팔소리와 전쟁의 경보를 들음이로다","reference":"예레미야 4:19","category":"$undefined"},{"id":"19048","book":"예레미야","book_name":"예레미야","chapter":4,"verse":20,"text":"패망에 패망이 연속하여 온 땅이 탈취를 당하니 나의 천막은 홀연히 파멸되며 나의 휘장은 잠시간에 열파되도다","reference":"예레미야 4:20","category":"$undefined"},{"id":"19049","book":"예레미야","book_name":"예레미야","chapter":4,"verse":21,"text":"내가 저 기호를 보며 나팔소리 듣기를 어느때까지 할꼬","reference":"예레미야 4:21","category":"$undefined"},{"id":"19050","book":"예레미야","book_name":"예레미야","chapter":4,"verse":22,"text":"내 백성은 나를 알지 못하는 우준한 자요 지각이 없는 미련한 자식이라 악을 행하기에는 지각이 있으나 선을 행하기에는 무지하도다","reference":"예레미야 4:22","category":"$undefined"},{"id":"19051","book":"예레미야","book_name":"예레미야","chapter":4,"verse":23,"text":"내가 땅을 본즉 혼돈하고 공허하며 하늘들을 우러른즉 거기 빛이 없으며","reference":"예레미야 4:23","category":"$undefined"},{"id":"19052","book":"예레미야","book_name":"예레미야","chapter":4,"verse":24,"text":"내가 산들을 본즉 다 진동하며 작은 산들도 요동하며","reference":"예레미야 4:24","category":"$undefined"},{"id":"19053","book":"예레미야","book_name":"예레미야","chapter":4,"verse":25,"text":"내가 본즉 사람이 없으며 공중의 새가 다 날아갔으며","reference":"예레미야 4:25","category":"$undefined"},{"id":"19054","book":"예레미야","book_name":"예레미야","chapter":4,"verse":26,"text":"내가 본즉 좋은 땅이 황무지가 되었으며 그 모든 성읍이 여호와의 앞 그 맹렬한 진노 앞에 무너졌으니","reference":"예레미야 4:26","category":"$undefined"},{"id":"19055","book":"예레미야","book_name":"예레미야","chapter":4,"verse":27,"text":"이는 여호와의 말씀에 이 온 땅이 황폐할 것이나 내가 진멸하지는 아니할 것이며","reference":"예레미야 4:27","category":"$undefined"},{"id":"19056","book":"예레미야","book_name":"예레미야","chapter":4,"verse":28,"text":"이로 인하여 땅이 슬퍼할 것이며 위의 하늘이 흑암할 것이라 내가 이미 말하였으며 작정하였고 후회하지 아니하였은즉 또한 돌이키지 아니하리라 하셨음이로다","reference":"예레미야 4:28","category":"$undefined"},{"id":"19057","book":"예레미야","book_name":"예레미야","chapter":4,"verse":29,"text":"기병과 활 쏘는 자의 훤화로 인하여 모든 성읍이 도망하여 수풀에 들어가고 바위에 기어오르며 각 성읍이 버림을 당하여 거기 거하는 사람이 없나니","reference":"예레미야 4:29","category":"$undefined"},{"id":"19058","book":"예레미야","book_name":"예레미야","chapter":4,"verse":30,"text":"멸망을 당한 자여, 네가 어떻게 하려느냐 ? 네가 붉은 옷을 입고 금장식으로 단장하고 눈을 그려 꾸밀지라도 너의 화장한 것이 헛된 일이라 연인들이 너를 멸시하여 네 생명을 찾느니라","reference":"예레미야 4:30","category":"$undefined"},{"id":"19059","book":"예레미야","book_name":"예레미야","chapter":4,"verse":31,"text":"내가 소리를 들은즉 여인의 해산하는 소리 같고 초산하는 자의 고통하는 소리 같으니 이는 딸 시온의 소리라 그가 헐떡이며 그 손을 펴고 이르기를 내게 화 있도다 ! 살륙하는 자를 인하여 나의 심령이 피곤하도다 하는도다","reference":"예레미야 4:31","category":"$undefined"},{"id":"20422","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":1,"text":"슬프다 어찌 그리 금이 빛을 잃고 정금이 변하였으며 성소의 돌이 각 거리 머리에 쏟아졌는고","reference":"예레미야 애가 4:1","category":"$undefined"},{"id":"20423","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":2,"text":"시온의 아들들이 보배로와 정금에 비할러니 어찌 그리 토기장이의 만든 질항아리 같이 여김이 되었는고","reference":"예레미야 애가 4:2","category":"$undefined"},{"id":"20424","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":3,"text":"들개는 오히려 젖을 내어 새끼를 먹이나 처녀 내 백성은 잔인하여 광야의 타조 같도다","reference":"예레미야 애가 4:3","category":"$undefined"},{"id":"20425","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":4,"text":"젖먹이가 목말라서 혀가 입천장에 붙음이여 어린 아이가 떡을 구하나 떼어 줄 사람이 없도다","reference":"예레미야 애가 4:4","category":"$undefined"},{"id":"20426","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":5,"text":"진수를 먹던 자가 거리에 외로움이여 전에는 붉은 옷을 입고 길리운 자가 이제는 거름더미를 안았도다","reference":"예레미야 애가 4:5","category":"$undefined"},{"id":"20427","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":6,"text":"전에 소돔이 사람의 손을 대지 않고 경각간에 무너지더니 이제 처녀 내 백성의 죄가 소돔의 죄악보다 중하도다","reference":"예레미야 애가 4:6","category":"$undefined"},{"id":"20428","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":7,"text":"전에는 존귀한 자의 몸이 눈보다 깨끗하고 젖보다 희며 산호보다 붉어 그 윤택함이 마광한 청옥 같더니","reference":"예레미야 애가 4:7","category":"$undefined"},{"id":"20429","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":8,"text":"이제는 그 얼굴이 숯보다 검고 그 가죽이 뼈에 붙어 막대기 같이 말랐으니 거리에서 알 사람이 없도다","reference":"예레미야 애가 4:8","category":"$undefined"},{"id":"20430","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":9,"text":"칼에 죽은 자가 주려 죽은 자보다 나음은 토지 소산이 끊어지므로 이들이 찔림 같이 점점 쇠약하여 감이로다","reference":"예레미야 애가 4:9","category":"$undefined"},{"id":"20431","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":10,"text":"처녀 내 백성의 멸망할 때에 자비한 부녀가 손으로 자기 자녀를 삶아 식물을 삼았도다","reference":"예레미야 애가 4:10","category":"$undefined"},{"id":"20432","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":11,"text":"여호와께서 분을 발하시며 맹렬한 노를 쏟으심이여 시온에 불을 피우사 그 지대를 사르셨도다","reference":"예레미야 애가 4:11","category":"$undefined"},{"id":"20433","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":12,"text":"대적과 원수가 예루살렘 성문으로 들어갈 줄은 세상 열왕과 천하 모든 백성이 믿지 못하였었도다","reference":"예레미야 애가 4:12","category":"$undefined"},{"id":"20434","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":13,"text":"그 선지자들의 죄와 제사장들의 죄악을 인함이니 저희가 성읍 중에서 의인의 피를 흘렀도다","reference":"예레미야 애가 4:13","category":"$undefined"},{"id":"20435","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":14,"text":"저희가 거리에서 소경 같이 방황함이여 그 옷이 피에 더러웠으므로 사람이 만질수 없도다","reference":"예레미야 애가 4:14","category":"$undefined"},{"id":"20436","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":15,"text":"사람이 저희에게 외쳐 이르기를 부정하다 가라,가라,가라,만지지 말라 하였음이여 저희가 도망하여 방황할 때에 이방인이 이르기를 저희가 다시는 여기 거하지 못하리라 하였도다","reference":"예레미야 애가 4:15","category":"$undefined"},{"id":"20437","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":16,"text":"여호와께서 노하여 흩으시고 다시 권고치 아니하시리니 저희가 제사장들을 높이지 아니하였으며 장로들을 대접지 아니하였음이로다","reference":"예레미야 애가 4:16","category":"$undefined"},{"id":"20438","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":17,"text":"우리가 헛되이 도움을 바라므로 우리 눈이 상함이여 우리를 구원치 못할 나라를 바라보고 바라보았도다","reference":"예레미야 애가 4:17","category":"$undefined"},{"id":"20439","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":18,"text":"저희가 우리 자취를 엿보니 우리가 거리에 행할 수 없음이여 우리의 끝이 가깝고 우리의 날이 다하였고 우리의 마지막이 이르렀도다","reference":"예레미야 애가 4:18","category":"$undefined"},{"id":"20440","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":19,"text":"우리를 쫓는 자가 공중의 독수리보다 빠름이여 산꼭대기에서도 쫓고 광야에도 매복하였도다","reference":"예레미야 애가 4:19","category":"$undefined"},{"id":"20441","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":20,"text":"우리의 콧김 곧 여호와의 기름 부으신 자가 저희 함정에 빠졌음이여 우리가 저를 가리키며 전에 이르기를 우리가 저의 그늘 아 래서 열국 중에 살겠다 하던 자로다","reference":"예레미야 애가 4:20","category":"$undefined"},{"id":"20442","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":21,"text":"우스 땅에 거하는 처녀 에돔아 즐거워하며 기뻐하려무나 잔이 네게도 이를지니 네가 취하여 벌거벗으리라","reference":"예레미야 애가 4:21","category":"$undefined"},{"id":"20443","book":"예레미야 애가","book_name":"예레미야 애가","chapter":4,"verse":22,"text":"처녀 시온아 네 죄악의 형벌이 다하였으니 주께서 다시는 너로 사로잡혀 가지 않게 하시리로다 처녀 에돔아 ! 주께서 네 죄악을 벌하시며 네 허물을 드러내시리로다","reference":"예레미야 애가 4:22","category":"$undefined"}],"bookSlug":"jeremiah"}]
