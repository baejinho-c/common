2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":5,"verses":[{"id":"19060","book":"예레미야","book_name":"예레미야","chapter":5,"verse":1,"text":"너희는 예루살렘 거리로 빨리 왕래하며 그 넓은 거리에서 찾아보고 알라 너희가 만일 공의를 행하며 진리를 구하는 자를 한 사람이라도 찾으면 내가 이 성을 사하리라","reference":"예레미야 5:1","category":"$undefined"},{"id":"19061","book":"예레미야","book_name":"예레미야","chapter":5,"verse":2,"text":"그들이 여호와의 사심으로 맹세할지라도 실상은 거짓 맹세니라","reference":"예레미야 5:2","category":"$undefined"},{"id":"19062","book":"예레미야","book_name":"예레미야","chapter":5,"verse":3,"text":"여호와여 주의 눈이 성실을 돌아보지 아니하시나이까 주께서 그들을 치셨을지라도 그들이 아픈줄을 알지 못하며 그들을 거진 멸하셨을지라도 그들이 징계를 받지 아니하고 그 얼굴을 반석보다 굳게하여 돌아오기를 싫어하므로","reference":"예레미야 5:3","category":"$undefined"},{"id":"19063","book":"예레미야","book_name":"예레미야","chapter":5,"verse":4,"text":"내가 말하기를 이 무리는 비천하고 우준한 것 뿐이라 여호와의 길, 자기 하나님의 법을 알지 못하니","reference":"예레미야 5:4","category":"$undefined"},{"id":"19064","book":"예레미야","book_name":"예레미야","chapter":5,"verse":5,"text":"내가 귀인들에게 가서 그들에게 말하리라 그들은 여호와의 길, 자기 하나님의 법을 안다 하였더니 그들도 일제히 그 멍에를 꺾고 결박을 끊은지라","reference":"예레미야 5:5","category":"$undefined"},{"id":"19065","book":"예레미야","book_name":"예레미야","chapter":5,"verse":6,"text":"그러므로 수풀에서 나오는 사자가 그들을 죽이며 사막의 이리가 그들을 멸하며 표범이 성읍들을 엿보온즉 그리로 나오는 자마다 찢기오리니 이는 그들의 허물이 많고 패역이 심함이니이다","reference":"예레미야 5:6","category":"$undefined"},{"id":"19066","book":"예레미야","book_name":"예레미야","chapter":5,"verse":7,"text":"내가 어찌 너를 사하겠느냐 네 자녀가 나를 버리고 신이 아닌 것들로 맹세하였으며 내가 그들을 배불리 먹인즉 그들이 행음하며 창기의 집에 허다히 모이며","reference":"예레미야 5:7","category":"$undefined"},{"id":"19067","book":"예레미야","book_name":"예레미야","chapter":5,"verse":8,"text":"그들은 살지고 두루 다니는 수 말 같이 각기 이웃의 아내를 따라 부르짖는도다","reference":"예레미야 5:8","category":"$undefined"},{"id":"19068","book":"예레미야","book_name":"예레미야","chapter":5,"verse":9,"text":"나 여호와가 이르노라 내가 어찌 이 일들을 인하여 벌하지 아니하겠으며 내 마음이 이런 나라에 보수하지 않겠느냐 ?","reference":"예레미야 5:9","category":"$undefined"},{"id":"19069","book":"예레미야","book_name":"예레미야","chapter":5,"verse":10,"text":"너희는 그 성벽에 올라가 훼파하되 다 훼파하지 말고 그 가지만 꺾어버리라 여호와의 것이 아님이니라","reference":"예레미야 5:10","category":"$undefined"},{"id":"19070","book":"예레미야","book_name":"예레미야","chapter":5,"verse":11,"text":"나 여호와가 말하노라 이스라엘 족속과 유다 족속이 내게 심히 패역하였느니라","reference":"예레미야 5:11","category":"$undefined"},{"id":"19071","book":"예레미야","book_name":"예레미야","chapter":5,"verse":12,"text":"그들이 여호와를 인정치 아니하며 말하기를 여호와는 계신 것이 아닌즉 재앙이 우리에게 임하지 않을 것이요 우리가 칼과 기근을 보지 아니할 것이며","reference":"예레미야 5:12","category":"$undefined"},{"id":"19072","book":"예레미야","book_name":"예레미야","chapter":5,"verse":13,"text":"선지자들은 바람이라 말씀이 그들의 속에 있지 아니한즉 그같이 그들이 당하리라 하느니라","reference":"예레미야 5:13","category":"$undefined"},{"id":"19073","book":"예레미야","book_name":"예레미야","chapter":5,"verse":14,"text":"그러므로 만군의 하나님 여호와가 이같이 말하노라 그들이 이말을 하였은즉 볼지어다 ! 내가 네 입에 있는 나의 말로 불이 되게 하고 이 백성으로 나무가 되게 하리니 그 불이 그들을 사르리라","reference":"예레미야 5:14","category":"$undefined"},{"id":"19074","book":"예레미야","book_name":"예레미야","chapter":5,"verse":15,"text":"나 여호와가 말하노라 이스라엘 족속아 ! 보라 내가 한 나라를 원방에서 너희에게로 오게 하리니 곧 강하고 오랜 나라이라 그 방언을 네가 알지 못하며 그 말을 네가 깨닫지 못하느니라","reference":"예레미야 5:15","category":"$undefined"},{"id":"19075","book":"예레미야","book_name":"예레미야","chapter":5,"verse":16,"text":"그 전통은 열림 묘실이요 그 사람들은 다 용사라","reference":"예레미야 5:16","category":"$undefined"},{"id":"19076","book":"예레미야","book_name":"예레미야","chapter":5,"verse":17,"text":"그들이 네 자녀들의 먹을 추수 곡물과 양식을 먹으며 네 양떼와 소떼를 먹으며 네 포도나무와 무화과나무 열매를 먹으며 네가 의뢰하는 견고한 성들을 칼로 파멸하리라","reference":"예레미야 5:17","category":"$undefined"},{"id":"19077","book":"예레미야","book_name":"예레미야","chapter":5,"verse":18,"text":"나 여호와가 말하노라 그 때에도 내가 너희를 진멸치는 아니하리라","reference":"예레미야 5:18","category":"$undefined"},{"id":"19078","book":"예레미야","book_name":"예레미야","chapter":5,"verse":19,"text":"그들이 만일 이르기를 우리 하나님 여호와께서 어찌하여 이 모든 일을 우리에게 행하셨느뇨 하거든 너는 그들에게 이르기를 너희가 여호와를 버리고 너희 땅에서 이방 신들을 섬겼은즉 이와 같이 너희 것이 아닌 땅에서 이방인들을 섬기리라 하라","reference":"예레미야 5:19","category":"$undefined"},{"id":"19079","book":"예레미야","book_name":"예레미야","chapter":5,"verse":20,"text":"너는 이를 야곱 집에 선포하며 유다에 공포하여 이르기를","reference":"예레미야 5:20","category":"$undefined"},{"id":"19080","book":"예레미야","book_name":"예레미야","chapter":5,"verse":21,"text":"우준하여 지각이 없으며 눈이 있어도 보지 못하며 귀가 있어도 듣지 못하는 백성이여, 이를 들을지어다","reference":"예레미야 5:21","category":"$undefined"},{"id":"19081","book":"예레미야","book_name":"예레미야","chapter":5,"verse":22,"text":"여호와께서 말씀하시되 너희가 나를 두려워 아니하느냐 ? 내 앞에서 떨지 아니하겠느냐 내가 모래를 두어 바다의 계한을 삼되 그것으로 영원한 계한을 삼고 지나치지 못하게 하였으므로 파도가 흉용하나 그것을 이기지 못하며 뛰노나 그것을 넘지 못하느니라","reference":"예레미야 5:22","category":"$undefined"},{"id":"19082","book":"예레미야","book_name":"예레미야","chapter":5,"verse":23,"text":"그러나 너희 백성은 배반하며 패역하는 마음이 있어서 이미 배반하고 갔으며","reference":"예레미야 5:23","category":"$undefined"},{"id":"19083","book":"예레미야","book_name":"예레미야","chapter":5,"verse":24,"text":"또 너희 마음으로 우리에게 이른 비와 늦은 비를 때를 따라 주시며 우리를 위하여 추수 기한을 정하시는 우리 하나님 여호와를 경외하자 말하지도 아니하니","reference":"예레미야 5:24","category":"$undefined"},{"id":"19084","book":"예레미야","book_name":"예레미야","chapter":5,"verse":25,"text":"너희 허물이 이러한 일들을 물리쳤고 너희 죄가 너희에게 오는 좋은것을 막았느니라","reference":"예레미야 5:25","category":"$undefined"},{"id":"19085","book":"예레미야","book_name":"예레미야","chapter":5,"verse":26,"text":"내 백성 너희 중에 악인이 있어서 새 사냥군의 매복함같이 지키며 덫을 놓아 사람을 잡으며","reference":"예레미야 5:26","category":"$undefined"},{"id":"19086","book":"예레미야","book_name":"예레미야","chapter":5,"verse":27,"text":"조롱에 새들이 가득함같이 너희 집들에 속임이 가득하도다 그러므로 너희가 창대하고 거부가 되어","reference":"예레미야 5:27","category":"$undefined"},{"id":"19087","book":"예레미야","book_name":"예레미야","chapter":5,"verse":28,"text":"살지고 윤택하며 또 행위가 심히 악하여 자기 이익을 얻으려고 송사 곧 고아의 송사를 공정히 하지 아니하며 빈민의 송사를 공평히 판결치 아니하니","reference":"예레미야 5:28","category":"$undefined"},{"id":"19088","book":"예레미야","book_name":"예레미야","chapter":5,"verse":29,"text":"내가 이 일들을 인하여 벌하지 아니하겠으며 내 마음이 이같은 나라에 보수하지 않겠느냐 여호와의 말이니라","reference":"예레미야 5:29","category":"$undefined"},{"id":"19089","book":"예레미야","book_name":"예레미야","chapter":5,"verse":30,"text":"이 땅에 기괴하고 놀라운 일이 있도다","reference":"예레미야 5:30","category":"$undefined"},{"id":"19090","book":"예레미야","book_name":"예레미야","chapter":5,"verse":31,"text":"선지자들은 거짓을 예언하며 제사장들은 자기 권력으로 다스리며 내 백성은 그것을 좋게 여기니 그 결국에는 너희가 어찌 하려느냐","reference":"예레미야 5:31","category":"$undefined"},{"id":"20444","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":1,"text":"여호와여, 우리의 당한 것을 기억하시고 우리의 수욕을 감찰하옵소서","reference":"예레미야 애가 5:1","category":"$undefined"},{"id":"20445","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":2,"text":"우리 기업이 외인에게, 우리 집들도 외인에게 돌아갔나이다","reference":"예레미야 애가 5:2","category":"$undefined"},{"id":"20446","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":3,"text":"우리는 아비 없는 외로운 자식이오며 우리 어미는 과부 같으니","reference":"예레미야 애가 5:3","category":"$undefined"},{"id":"20447","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":4,"text":"우리가 은을 주고 물을 마시며 값을 주고 섶을 얻으오며","reference":"예레미야 애가 5:4","category":"$undefined"},{"id":"20448","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":5,"text":"우리를 쫓는 자는 우리 목을 눌렀사오니 우리가 곤비하여 쉴 수 없나이다","reference":"예레미야 애가 5:5","category":"$undefined"},{"id":"20449","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":6,"text":"우리가 애굽 사람과 앗수르 사람과 악수하고 양식을 얻어 배불리고자 하였나이다","reference":"예레미야 애가 5:6","category":"$undefined"},{"id":"20450","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":7,"text":"우리 열조는 범죄하고 없어졌고 우리는 그 죄악을 담당하였나이다","reference":"예레미야 애가 5:7","category":"$undefined"},{"id":"20451","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":8,"text":"종들이 우리를 관할함이여 그 손에서 건져낼 자가 없나이다","reference":"예레미야 애가 5:8","category":"$undefined"},{"id":"20452","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":9,"text":"광야에는 칼이 있으므로 죽기를 무릅써야 양식을 얻사오니","reference":"예레미야 애가 5:9","category":"$undefined"},{"id":"20453","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":10,"text":"주림의 열기로 인하여 우리의 피부가 아궁이처럼 검으니이다","reference":"예레미야 애가 5:10","category":"$undefined"},{"id":"20454","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":11,"text":"대적이 시온에서 부녀들을, 유다 각 성에서 처녀들을 욕보였나이다","reference":"예레미야 애가 5:11","category":"$undefined"},{"id":"20455","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":12,"text":"방백들의 손이 매어달리며 장로들의 얼굴이 존경을 받지 못하나이다","reference":"예레미야 애가 5:12","category":"$undefined"},{"id":"20456","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":13,"text":"소년들이 맷돌을 지오며 아이들이 섶을 지다가 엎드러지오며","reference":"예레미야 애가 5:13","category":"$undefined"},{"id":"20457","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":14,"text":"노인은 다시 성문에 앉지 못하며 소년은 다시 노래하지 못하나이다","reference":"예레미야 애가 5:14","category":"$undefined"},{"id":"20458","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":15,"text":"우리 마음에 희락이 그쳤고 우리의 무도가 변하여 애통이 되었사오며","reference":"예레미야 애가 5:15","category":"$undefined"},{"id":"20459","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":16,"text":"우리 머리에서 면류관이 떨어졌사오니 오호라 ! 우리의 범죄함을 인함이니이다","reference":"예레미야 애가 5:16","category":"$undefined"},{"id":"20460","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":17,"text":"이러므로 우리 마음이 피곤하고 이러므로 우리 눈이 어두우며","reference":"예레미야 애가 5:17","category":"$undefined"},{"id":"20461","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":18,"text":"시온산이 황무하여 여우가 거기서 노나이다","reference":"예레미야 애가 5:18","category":"$undefined"},{"id":"20462","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":19,"text":"여호와여, 주는 영원히 계시오며 주의 보좌는 세세에 미치나이다","reference":"예레미야 애가 5:19","category":"$undefined"},{"id":"20463","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":20,"text":"주께서 어찌하여 우리를 영원히 잊으시오며 우리를 이같이 오래 버리시나이까 ?","reference":"예레미야 애가 5:20","category":"$undefined"},{"id":"20464","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":21,"text":"여호와여, 우리를 주께로 돌이키소서 그리하시면 우리가 주께로 돌아가겠사오니 우리의 날을 다시 새롭게 하사 옛적 같게 하옵소서","reference":"예레미야 애가 5:21","category":"$undefined"},{"id":"20465","book":"예레미야 애가","book_name":"예레미야 애가","chapter":5,"verse":22,"text":"주께서 우리를 아주 버리셨사오며 우리에게 진노하심이 특심하시니이다","reference":"예레미야 애가 5:22","category":"$undefined"}],"bookSlug":"jeremiah"}]
