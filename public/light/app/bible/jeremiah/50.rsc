2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":50,"verses":[{"id":"20168","book":"예레미야","book_name":"예레미야","chapter":50,"verse":1,"text":"여호와께서 선지자 예레미야로 바벨론과 갈대아인의 땅에 대하여 하신 말씀이라","reference":"예레미야 50:1","category":"$undefined"},{"id":"20169","book":"예레미야","book_name":"예레미야","chapter":50,"verse":2,"text":"너희는 열방 중에 광고하라 ! 공포하라 ! 기를 세우라 ! 숨김이 없이 공포하여 이르라 바벨론이 함락되고 벨이 수치를 당하며 므로닥이 부스러지며 그 신상들은 수치를 당하며 우상들은 부스러진다 하라","reference":"예레미야 50:2","category":"$undefined"},{"id":"20170","book":"예레미야","book_name":"예레미야","chapter":50,"verse":3,"text":"이는 한 나라가 북방에서 나와서 그를 쳐서 그 땅으로 황폐케 하여 그 중에 거하는 자가 없게 함이라 사람이나 짐승이 다 도망하여 가느니라","reference":"예레미야 50:3","category":"$undefined"},{"id":"20171","book":"예레미야","book_name":"예레미야","chapter":50,"verse":4,"text":"나 여호와가 말하노라 그 날 그 때에 이스라엘 자손이 돌아오며 그와 함께 유다 자손이 돌아오되 그들이 울며 그 길을 행하며 그 하나님 여호와께 구할 것이며","reference":"예레미야 50:4","category":"$undefined"},{"id":"20172","book":"예레미야","book_name":"예레미야","chapter":50,"verse":5,"text":"그들이 그 얼굴을 시온으로 향하여 그 길을 물으며 말하기를 너희는 오라 ! 잊어버리지 아니할 영영한 언약으로 여호와와 연합하자 하리라","reference":"예레미야 50:5","category":"$undefined"},{"id":"20173","book":"예레미야","book_name":"예레미야","chapter":50,"verse":6,"text":"내 백성은 잃어버린 양떼로다 그 목자들이 그들을 곁길로 가게 하여 산으로 돌이키게 하였으므로 그들이 산에서 작은 산으로 돌아다니며 쉴 곳을 잊었도다","reference":"예레미야 50:6","category":"$undefined"},{"id":"20174","book":"예레미야","book_name":"예레미야","chapter":50,"verse":7,"text":"그들을 만나는 자들은 그들을 삼키며 그 대적은 말하기를 그들은 여호와 곧 의로운 처소시며 그 열조의 소망이신 여호와께 범죄하였음인즉 우리는 무죄하다 하였느니라","reference":"예레미야 50:7","category":"$undefined"},{"id":"20175","book":"예레미야","book_name":"예레미야","chapter":50,"verse":8,"text":"너희는 바벨론 가운데서 도망하라 갈대아인의 땅에서 나오라 떼에 앞서가는 수염소같이 하라","reference":"예레미야 50:8","category":"$undefined"},{"id":"20176","book":"예레미야","book_name":"예레미야","chapter":50,"verse":9,"text":"보라, 내가 큰 연합국으로 북방에서 일어나 나와서 바벨론을 치게 하리니 그들이 항오를 벌이고 쳐서 취할 것이라 그들의 화살은 연숙한 용사의 화살 같아서 헛되이 돌아오지 아니하리로다","reference":"예레미야 50:9","category":"$undefined"},{"id":"20177","book":"예레미야","book_name":"예레미야","chapter":50,"verse":10,"text":"갈대아가 약탈을 당할 것이라 그를 약탈하는 자마다 만족하리라 여호와의 말이니라","reference":"예레미야 50:10","category":"$undefined"},{"id":"20178","book":"예레미야","book_name":"예레미야","chapter":50,"verse":11,"text":"나의 산업을 노략하는 자여, 너희가 즐거워하며 기뻐하며 곡식을 가는 송아지같이 뛰며 힘센 말같이 울도다","reference":"예레미야 50:11","category":"$undefined"},{"id":"20179","book":"예레미야","book_name":"예레미야","chapter":50,"verse":12,"text":"그러므로 너희의 어미가 온전히 수치를 당하리라 너희를 낳은 자가 치욕을 당하리라 보라, 그가 열방의 말째와 광야와 마른 땅과 사막이 될 것이며","reference":"예레미야 50:12","category":"$undefined"},{"id":"20180","book":"예레미야","book_name":"예레미야","chapter":50,"verse":13,"text":"여호와의 진노로 인하여 거민이 없는 온전한 황무지가 될 것이라 바벨론으로 지나는 자마다 그 모든 재앙을 놀라며 비웃으리로다","reference":"예레미야 50:13","category":"$undefined"},{"id":"20181","book":"예레미야","book_name":"예레미야","chapter":50,"verse":14,"text":"바벨론을 둘러 항오를 벌이고 활을 당기는 모든 자여, 화살을 아끼지 말고 쏘라 그가 여호와께 범죄하였음이니라","reference":"예레미야 50:14","category":"$undefined"},{"id":"20182","book":"예레미야","book_name":"예레미야","chapter":50,"verse":15,"text":"그 사면에서 소리질러 칠지어다 그가 항복하였고 그 보장은 무너졌고 그 성벽은 훼파되었으니 이는 여호와의 보수하시는 것이라 그의 행한대로 그에게 행하여 보수하라","reference":"예레미야 50:15","category":"$undefined"},{"id":"20183","book":"예레미야","book_name":"예레미야","chapter":50,"verse":16,"text":"파종하는 자와 추수 때에 낫을 잡은 자를 바벨론에서 끊어버리라 사람들이 그 압박하는 칼을 두려워하여 각기 동족에게로 돌아가며 고향으로 도망하리라","reference":"예레미야 50:16","category":"$undefined"},{"id":"20184","book":"예레미야","book_name":"예레미야","chapter":50,"verse":17,"text":"이스라엘은 흩어진 양이라 사자들이 그를 따르도다 처음에는 앗수르 왕이 먹었고 다음에는 바벨론 왕 느부갓네살이 그 뼈를 꺽도다","reference":"예레미야 50:17","category":"$undefined"},{"id":"20185","book":"예레미야","book_name":"예레미야","chapter":50,"verse":18,"text":"그러므로 나 만군의 여호와 이스라엘의 하나님이 이같이 말하노라 보라, 내가 앗수르 왕을 벌한 것같이 바벨론 왕과 그 땅을 벌하고","reference":"예레미야 50:18","category":"$undefined"},{"id":"20186","book":"예레미야","book_name":"예레미야","chapter":50,"verse":19,"text":"이스라엘을 다시 그 목장으로 돌아오게 하리니 그가 갈멜과 바산에서 먹을 것이며 그 마음이 에브라임과 길르앗산에서 만족하리라","reference":"예레미야 50:19","category":"$undefined"},{"id":"20187","book":"예레미야","book_name":"예레미야","chapter":50,"verse":20,"text":"나 여호와가 말하노라 그 날 그 때에는 이스라엘의 죄악을 찾을지라도 없겠고 유다의 죄를 찾을지라도 발견치 못하리니 이는 내가 나의 남긴 자를 사할 것임이니라","reference":"예레미야 50:20","category":"$undefined"},{"id":"20188","book":"예레미야","book_name":"예레미야","chapter":50,"verse":21,"text":"나 여호와가 말하노라 너희는 올라가서 므라다임의 땅을 치며 브곳의 거민을 쳐서 진멸하되 내가 너희에게 명한대로 다하라","reference":"예레미야 50:21","category":"$undefined"},{"id":"20189","book":"예레미야","book_name":"예레미야","chapter":50,"verse":22,"text":"그 땅에 싸움의 소리와 큰 파멸의 소리가 있으리라","reference":"예레미야 50:22","category":"$undefined"},{"id":"20190","book":"예레미야","book_name":"예레미야","chapter":50,"verse":23,"text":"온 세계의 방망이가 어찌 그리 꺽여 부숴졌는고 바벨론이 어찌 그리 열방 중에 황무지가 되었는고","reference":"예레미야 50:23","category":"$undefined"},{"id":"20191","book":"예레미야","book_name":"예레미야","chapter":50,"verse":24,"text":"바벨론아 내가 너를 잡으려고 올무를 놓았더니 네가 깨닫지 못하고 걸렷고 네가 나 여호와와 다투었으므로 만난 바 되어 잡혔도다","reference":"예레미야 50:24","category":"$undefined"},{"id":"20192","book":"예레미야","book_name":"예레미야","chapter":50,"verse":25,"text":"나 여호와가 그 병고를 열고 분노의 병기를 냄은 주 만군의 여호와 내가 갈대아인의 땅에 행할 일이 있음이라","reference":"예레미야 50:25","category":"$undefined"},{"id":"20193","book":"예레미야","book_name":"예레미야","chapter":50,"verse":26,"text":"먼데 있는 너희는 와서 그를 치고 그 곳간을 열고 그것을 쌓아 무더기 같게 하라 그를 진멸하고 남기지 말라","reference":"예레미야 50:26","category":"$undefined"},{"id":"20194","book":"예레미야","book_name":"예레미야","chapter":50,"verse":27,"text":"그 황소를 다 죽이라 도수장으로 내려가게 하라 그들에게 화 있도다 ! 그들의 날, 그 벌 받는 때가 이르렀음이로다","reference":"예레미야 50:27","category":"$undefined"},{"id":"20195","book":"예레미야","book_name":"예레미야","chapter":50,"verse":28,"text":"바벨론 땅에서 도피한 자의 소리여, 시온에서 우리 하나님 여호와의 보수하시는 것, 그 성전의 보수하시는 것을 선포하는 소리로다","reference":"예레미야 50:28","category":"$undefined"},{"id":"20196","book":"예레미야","book_name":"예레미야","chapter":50,"verse":29,"text":"활 쏘는 자를 바벨론에 소집하라 무릇 활을 당기는 자여, 그 사면으로 진을 치고 쳐서 피하는 자가 없게 하라 그 일한대로 갚고 그 행한대로 그에게 행하라 그가 이스라엘의 거룩한 자 여호와를 향하여 교만하였음이니라","reference":"예레미야 50:29","category":"$undefined"},{"id":"20197","book":"예레미야","book_name":"예레미야","chapter":50,"verse":30,"text":"그러므로 그 날에 청년들이 그 거리에 엎드러지겠고 군사들이 멸절되리라 여호와의 말이니라","reference":"예레미야 50:30","category":"$undefined"},{"id":"20198","book":"예레미야","book_name":"예레미야","chapter":50,"verse":31,"text":"주 만군의 여호와가 말하노라 교만한 자여, 보라, 내가 너를 대적하나니 네 날 곧 너를 벌할 때가 이르렀음이라","reference":"예레미야 50:31","category":"$undefined"},{"id":"20199","book":"예레미야","book_name":"예레미야","chapter":50,"verse":32,"text":"교만한 자가 걸려 넘어지겠고 그를 일으킬 자가 없을 것이며 내가 그 성읍들에 불을 놓으리니 그 사면에 있는 것이 다 살라지리라","reference":"예레미야 50:32","category":"$undefined"},{"id":"20200","book":"예레미야","book_name":"예레미야","chapter":50,"verse":33,"text":"나 만군의 여호와가 이같이 말하노라 이스라엘 자손과 유다 자손이 함께 학대를 받는도다 그들을 사로 잡는 자는 다 그들을 엄히 지켜 놓아주지 아니하거니와","reference":"예레미야 50:33","category":"$undefined"},{"id":"20201","book":"예레미야","book_name":"예레미야","chapter":50,"verse":34,"text":"그들의 구속자는 강하니 그 이름은 만군의 여호와라 결코 그들의 원을 펴서 그 땅에 평안함을 주고 바벨론 거민으로 불안케 하리라","reference":"예레미야 50:34","category":"$undefined"},{"id":"20202","book":"예레미야","book_name":"예레미야","chapter":50,"verse":35,"text":"나 여호와가 말하노라 칼이 갈대아인의 위에와 바벨론 거민의 위에와 그 방백들과 지혜로운 자의 위에 임하며","reference":"예레미야 50:35","category":"$undefined"},{"id":"20203","book":"예레미야","book_name":"예레미야","chapter":50,"verse":36,"text":"칼이 자긍하는 자의 위에 임하리니 그들이 어리석게 될 것이며 칼이 용사의 위에 임하리니 그들이 놀랄 것이며","reference":"예레미야 50:36","category":"$undefined"},{"id":"20204","book":"예레미야","book_name":"예레미야","chapter":50,"verse":37,"text":"칼이 그들의 말들과 병거들과 그들 중에 있는 잡족의 위에 임하리니 그들이 부녀같이 될 것이며 칼이 보물 위에 임하리니 그것이 노략될 것이요","reference":"예레미야 50:37","category":"$undefined"},{"id":"20205","book":"예레미야","book_name":"예레미야","chapter":50,"verse":38,"text":"가뭄이 물 위에 임하여 그것을 말리우리니 이는 그 땅이 조각한 신상의 땅이요 그들은 우상에 미쳤음이니라","reference":"예레미야 50:38","category":"$undefined"},{"id":"20206","book":"예레미야","book_name":"예레미야","chapter":50,"verse":39,"text":"그러므로 사막의 들짐승이 시랑과 함께 거기 거하겠고 타조도 그 중에 깃들일 것이요 영영히 거민이 없으며 대대에 거할 자가 없으리라","reference":"예레미야 50:39","category":"$undefined"},{"id":"20207","book":"예레미야","book_name":"예레미야","chapter":50,"verse":40,"text":"나 여호와가 말하노라 나 하나님이 소돔과 고모라와 그 이웃 성읍들을 무너지게 한 것같이 거기 거하는 사람이 없게 하며 그 중에 우거하는 아무 인자가 없게 하리라","reference":"예레미야 50:40","category":"$undefined"},{"id":"20208","book":"예레미야","book_name":"예레미야","chapter":50,"verse":41,"text":"보라, 한 족속이 북방에서 오고 큰 나라와 여러 왕이 격동을 받아 땅 끝에서 오나니","reference":"예레미야 50:41","category":"$undefined"},{"id":"20209","book":"예레미야","book_name":"예레미야","chapter":50,"verse":42,"text":"그들은 활과 창을 가진 자라 잔인하여 긍휼히 여기지 아니하며 그 목소리는 파도가 흉용함 같도다 딸 바벨론아 ! 그들이 말을 타고 무사같이 각기 항오를 벌여 너를 칠 것이라","reference":"예레미야 50:42","category":"$undefined"},{"id":"20210","book":"예레미야","book_name":"예레미야","chapter":50,"verse":43,"text":"바벨론 왕이 그 소문을 듣고 손이 약하여지며 고통에 잡혀 해산하는 여인의 구로함 같도다","reference":"예레미야 50:43","category":"$undefined"},{"id":"20211","book":"예레미야","book_name":"예레미야","chapter":50,"verse":44,"text":"보라, 사자가 요단의 수풀에서 올라오는 것같이 그가 와서 견고한 처소를 칠 것이라 내가 즉시 그들을 거기서 쫓아내고 택한 자를 내가 그 위에 세우리니 나와 같은 자 누구며 나로 더불어 다툴 자 누구며 내 앞에 설 목자가 누구뇨","reference":"예레미야 50:44","category":"$undefined"},{"id":"20212","book":"예레미야","book_name":"예레미야","chapter":50,"verse":45,"text":"그런즉 바벨론에 대한 나 여호와의 도모와 갈대아인의 땅에 대하여 경영한 나 여호와의 뜻을 들으라 양떼의 어린 것들을 그들이 반드시 끌어가고 그 처소로 황무케 하리니","reference":"예레미야 50:45","category":"$undefined"},{"id":"20213","book":"예레미야","book_name":"예레미야","chapter":50,"verse":46,"text":"바벨론의 함락하는 소리에 땅이 진동하며 그 부르짖음이 열방 중에 들리리라 하시도다","reference":"예레미야 50:46","category":"$undefined"}],"bookSlug":"jeremiah"}]
