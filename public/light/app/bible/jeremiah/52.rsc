2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":52,"verses":[{"id":"20278","book":"예레미야","book_name":"예레미야","chapter":52,"verse":1,"text":"시드기야가 위에 나아갈 때에 나이 이십 일세라 예루살렘에서 십 일년을 치리하니라 그 모친의 이름은 하무달이라 립나인 예레미야의 딸이더라","reference":"예레미야 52:1","category":"$undefined"},{"id":"20279","book":"예레미야","book_name":"예레미야","chapter":52,"verse":2,"text":"시드기야가 여호야김의 모든 행위를 본받아 여호와 보시기에 악을 행한지라","reference":"예레미야 52:2","category":"$undefined"},{"id":"20280","book":"예레미야","book_name":"예레미야","chapter":52,"verse":3,"text":"여호와께서 예루살렘과 유다를 진노하심이 그들을 그 앞에서 쫓아 내시기까지에 이르렀더라 시드기야가 바벨론 왕을 배반하매","reference":"예레미야 52:3","category":"$undefined"},{"id":"20281","book":"예레미야","book_name":"예레미야","chapter":52,"verse":4,"text":"시드기야 구년 시월 십일에 바벨론 왕 느부갓네살이 그 모든 군대를 거느리고 예루살렘을 치러 올라와서 그 성을 대하여 진을 치고 사면으로 흉벽을 쌓으매","reference":"예레미야 52:4","category":"$undefined"},{"id":"20282","book":"예레미야","book_name":"예레미야","chapter":52,"verse":5,"text":"성이 시드기야 왕 십 일년까지 에워 싸였더니","reference":"예레미야 52:5","category":"$undefined"},{"id":"20283","book":"예레미야","book_name":"예레미야","chapter":52,"verse":6,"text":"그 사월 구일에 성 중에 기근이 심하여 그 땅 백성의 식물이 진하였더라","reference":"예레미야 52:6","category":"$undefined"},{"id":"20284","book":"예레미야","book_name":"예레미야","chapter":52,"verse":7,"text":"갈대아인이 그 성읍을 에워쌌더니 성벽을 깨뜨리매 모든 군사가 밤중에 두 성벽 사이 왕의 동산 곁문 길로 도망하여 아라바 길로 가더니","reference":"예레미야 52:7","category":"$undefined"},{"id":"20285","book":"예레미야","book_name":"예레미야","chapter":52,"verse":8,"text":"갈대아인의 군대가 시드기야 왕을 쫓아가서 여리고 평지에서 미치매 왕의 모든 군대가 그를 떠나 흩어진지라","reference":"예레미야 52:8","category":"$undefined"},{"id":"20286","book":"예레미야","book_name":"예레미야","chapter":52,"verse":9,"text":"그들이 왕을 잡아가지고 하맛 땅 립나에 있는 바벨론 왕에게로 끌고 가매 그를 심문하니라","reference":"예레미야 52:9","category":"$undefined"},{"id":"20287","book":"예레미야","book_name":"예레미야","chapter":52,"verse":10,"text":"바벨론 왕이 시드기야의 아들들을 그의 목전에서 죽이고 또 립나에서 유다의 모든 방백을 죽이며","reference":"예레미야 52:10","category":"$undefined"},{"id":"20288","book":"예레미야","book_name":"예레미야","chapter":52,"verse":11,"text":"시드기야의 두 눈을 빼고 사슬로 결박하여 바벨론으로 끌어다가 그 죽는 날까지 옥에 두었더라","reference":"예레미야 52:11","category":"$undefined"},{"id":"20289","book":"예레미야","book_name":"예레미야","chapter":52,"verse":12,"text":"바벨론 왕 느부갓네살의 십 구년 오월 십일에 바벨론 왕의 어전 시위대 장관 느부사라단이 예루살렘에 이르러","reference":"예레미야 52:12","category":"$undefined"},{"id":"20290","book":"예레미야","book_name":"예레미야","chapter":52,"verse":13,"text":"여호와의 전과 왕궁을 불사르고 예루살렘의 모든 집을 귀인의 집까지 불살랐으며","reference":"예레미야 52:13","category":"$undefined"},{"id":"20291","book":"예레미야","book_name":"예레미야","chapter":52,"verse":14,"text":"시위대 장관을 좇는 갈대아인의 온 군대가 예루살렘 사면 성벽을 헐었으며","reference":"예레미야 52:14","category":"$undefined"},{"id":"20292","book":"예레미야","book_name":"예레미야","chapter":52,"verse":15,"text":"시위대 장관 느부사라단이 백성 중 빈한한 자와 성중에 남아 있는 백성과 바벨론 왕에게 항복한 자와 무리의 남은 자를 사로 잡아 옮겨가고","reference":"예레미야 52:15","category":"$undefined"},{"id":"20293","book":"예레미야","book_name":"예레미야","chapter":52,"verse":16,"text":"빈천한 국민을 남겨두어 포도원을 다스리는 자와 농부가 되게 하였더라","reference":"예레미야 52:16","category":"$undefined"},{"id":"20294","book":"예레미야","book_name":"예레미야","chapter":52,"verse":17,"text":"갈대아인이 또 여호와의 전의 두 놋기둥과 받침들과 여호와의 전의 놋바다를 깨뜨려 그 놋을 바벨론으로 가져갔고","reference":"예레미야 52:17","category":"$undefined"},{"id":"20295","book":"예레미야","book_name":"예레미야","chapter":52,"verse":18,"text":"또 가마들과 부삽들과 불집게들과 주발들과 숟가락들과 섬길 때에 쓰는 모든 놋그릇을 다 가져갔으며","reference":"예레미야 52:18","category":"$undefined"},{"id":"20296","book":"예레미야","book_name":"예레미야","chapter":52,"verse":19,"text":"시위대 장관이 또 잔들과 화로들과 주발들과 솥들과 촛대들과 숟가락들과 바리들 곧 금물의 금과 은물의 은을 가져갔는데","reference":"예레미야 52:19","category":"$undefined"},{"id":"20297","book":"예레미야","book_name":"예레미야","chapter":52,"verse":20,"text":"솔로몬 왕이 여호와의 전을 위하여 만든 두 기둥과 한 바다와 그 받침 아래 있는 열 두 놋소 곧 이 모든 기구의 놋 중수를 헤아릴 수 없었더라","reference":"예레미야 52:20","category":"$undefined"},{"id":"20298","book":"예레미야","book_name":"예레미야","chapter":52,"verse":21,"text":"그 기둥은 한 기둥의 고가 십 팔 규빗이요, 그 주위는 십 이 규빗이며 그 속이 비었고 그 두께는 사지놓이며","reference":"예레미야 52:21","category":"$undefined"},{"id":"20299","book":"예레미야","book_name":"예레미야","chapter":52,"verse":22,"text":"기둥 위에 놋머리가 있어 그 고가 다섯 규빗이요, 머리 사면으로 돌아가며 꾸민 그물과 석류가 다 놋이며 또 다른 기둥에도 이런 모든 것과 석류가 있었으며","reference":"예레미야 52:22","category":"$undefined"},{"id":"20300","book":"예레미야","book_name":"예레미야","chapter":52,"verse":23,"text":"그 사면에 있는 석류는 구십 륙이요 그 기둥에 둘린 그물위에 있는 석류는 도합이 일백이었더라","reference":"예레미야 52:23","category":"$undefined"},{"id":"20301","book":"예레미야","book_name":"예레미야","chapter":52,"verse":24,"text":"시위대 장관이 대제사장 스라야와 부제사장 스바냐와 전 문지기 세 사람을 잡고","reference":"예레미야 52:24","category":"$undefined"},{"id":"20302","book":"예레미야","book_name":"예레미야","chapter":52,"verse":25,"text":"또 성중에서 사람을 잡았으니 곧 군사를 거느린 장관 하나와 또 성중에서 만난바 왕의 시종 칠인과 국민을 초모하는 군대장관의 서기관 하나와 성중에서 만난바 국민 육십명이라","reference":"예레미야 52:25","category":"$undefined"},{"id":"20303","book":"예레미야","book_name":"예레미야","chapter":52,"verse":26,"text":"시위대 장관 느부사라단이 그들을 잡아가지고 립나 바벨론 왕에게 나아가매","reference":"예레미야 52:26","category":"$undefined"},{"id":"20304","book":"예레미야","book_name":"예레미야","chapter":52,"verse":27,"text":"느부갓네살이 사로잡아 옮긴 백성이 이러하니라 제 칠년에 유다인이 삼천 이십 삼이요","reference":"예레미야 52:27","category":"$undefined"},{"id":"20305","book":"예레미야","book_name":"예레미야","chapter":52,"verse":28,"text":"느부갓네살의 십 팔년에 예루살렘에서 사로잡아 옮긴 자가 팔백 삼십 이인이요","reference":"예레미야 52:28","category":"$undefined"},{"id":"20306","book":"예레미야","book_name":"예레미야","chapter":52,"verse":29,"text":"느부갓네살의 이십 삼년에 시위대 장관 느부사라단이 사로잡아 옮긴 유다인이 칠백 사십 오인이니 그 총수가 사천 육백인이었더라","reference":"예레미야 52:29","category":"$undefined"},{"id":"20307","book":"예레미야","book_name":"예레미야","chapter":52,"verse":30,"text":"유다 왕 여호야긴이 사로잡혀 간지 삼십 칠년 곧 바벨론 왕 에윌므로닥의 즉위 원년 십이월 이십 오일에 그가 유다 왕 여호야긴을 옥에서 내어놓아 그 머리를 들게 하고","reference":"예레미야 52:30","category":"$undefined"},{"id":"20308","book":"예레미야","book_name":"예레미야","chapter":52,"verse":31,"text":"그에게 선히 말하고 그의 위를 그와 함께 바벨론에 있는 왕들의 위보다 높이고","reference":"예레미야 52:31","category":"$undefined"},{"id":"20309","book":"예레미야","book_name":"예레미야","chapter":52,"verse":32,"text":"그 죄수의 의복을 바꾸게 하고 그 일평생에 항상 왕의 앞에서 먹게 하였으며","reference":"예레미야 52:32","category":"$undefined"},{"id":"20310","book":"예레미야","book_name":"예레미야","chapter":52,"verse":33,"text":"그의 쓸 것은 날마다 바벨론 왕에게서 받는 정수가 있어서 죽는 날까지 곧 종신토록 끊이지 아니하였더라","reference":"예레미야 52:33","category":"$undefined"},{"id":"20311","book":"예레미야","book_name":"예레미야","chapter":52,"verse":34,"text":"","reference":"예레미야 52:34","category":"$undefined"}],"bookSlug":"jeremiah"}]
