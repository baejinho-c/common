2:["$","$L11",null,{"book":{"id":"jeremiah","name":"예레미야","chapters":52,"testament":"old"},"chapter":7,"verses":[{"id":"19121","book":"예레미야","book_name":"예레미야","chapter":7,"verse":1,"text":"여호와께로서 예레미야에게 말씀이 임하니라 가라사대","reference":"예레미야 7:1","category":"$undefined"},{"id":"19122","book":"예레미야","book_name":"예레미야","chapter":7,"verse":2,"text":"너는 여호와의 집 문에 서서 이 말을 선포하여 이르기를 여호와께 경배하러 이 문으로 들어가는 유다인아 다 여호와의 말씀을 들으라","reference":"예레미야 7:2","category":"$undefined"},{"id":"19123","book":"예레미야","book_name":"예레미야","chapter":7,"verse":3,"text":"만군의 여호와 이스라엘의 하나님이 이같이 말씀하시되 너희 길과 행위를 바르게 하라 그리하면 내가 너희로 이 곳에 거하게 하 리라","reference":"예레미야 7:3","category":"$undefined"},{"id":"19124","book":"예레미야","book_name":"예레미야","chapter":7,"verse":4,"text":"너희는 이것이 여호와의 전이라, 여호와의 전이라, 여호와의 전이라 하는 거짓말을 믿지 말라","reference":"예레미야 7:4","category":"$undefined"},{"id":"19125","book":"예레미야","book_name":"예레미야","chapter":7,"verse":5,"text":"너희가 만일 길과 행위를 참으로 바르게 하여 이웃들 사이에 공의를 행하며","reference":"예레미야 7:5","category":"$undefined"},{"id":"19126","book":"예레미야","book_name":"예레미야","chapter":7,"verse":6,"text":"이방인과 고아와 과부를 압제하지 말며 무죄한 자의 피를 이 곳에서 흘리지 아니하며 다른 신들을 좇아 스스로 해하지 아니하면","reference":"예레미야 7:6","category":"$undefined"},{"id":"19127","book":"예레미야","book_name":"예레미야","chapter":7,"verse":7,"text":"내가 너희를 이 곳에 거하게 하리니 곧 너희 조상에게 영원 무궁히 준 이 땅에니라","reference":"예레미야 7:7","category":"$undefined"},{"id":"19128","book":"예레미야","book_name":"예레미야","chapter":7,"verse":8,"text":"너희가 무익한 거짓말을 의뢰하는도다","reference":"예레미야 7:8","category":"$undefined"},{"id":"19129","book":"예레미야","book_name":"예레미야","chapter":7,"verse":9,"text":"너희가 도적질 하며 살인하며 간음하며 거짓 맹세하며 바알에게 분향하며 너희의 알지 못하는 다른 신들을 좇으면서","reference":"예레미야 7:9","category":"$undefined"},{"id":"19130","book":"예레미야","book_name":"예레미야","chapter":7,"verse":10,"text":"내 이름으로 일컬음을 받는 이 집에 들어와서 내 앞에 서서 말하기를 우리가 구원을 얻었나이다 하느냐 이는 이 모든 가증한 일을 행하려 함이로다","reference":"예레미야 7:10","category":"$undefined"},{"id":"19131","book":"예레미야","book_name":"예레미야","chapter":7,"verse":11,"text":"내 이름으로 일컬음을 받는 이 집이 너희 눈에는 도적의 굴혈로 보이느냐 ? 보라 나 곧 내가 그것을 보았노라 여호와의 말이니라","reference":"예레미야 7:11","category":"$undefined"},{"id":"19132","book":"예레미야","book_name":"예레미야","chapter":7,"verse":12,"text":"너희는 내가 처음으로 내 이름을 둔 처소 실로에 가서 내 백성 이스라엘의 악을 인하여 내가 어떻게 행한 것을 보라","reference":"예레미야 7:12","category":"$undefined"},{"id":"19133","book":"예레미야","book_name":"예레미야","chapter":7,"verse":13,"text":"나 여호와가 말하노라 이제 너희가 그 모든 일을 행하였으며 내가 너희에게 말하되 새벽부터 부지런히 말하여도 듣지 아니하였고 너희를 불러도 대답지 아니하였느니라","reference":"예레미야 7:13","category":"$undefined"},{"id":"19134","book":"예레미야","book_name":"예레미야","chapter":7,"verse":14,"text":"그러므로 내가 실로에 행함 같이 너희가 의뢰하는 바 내 이름으로 일컬음을 받는 이 집 곧 너희와 너희 열조에게 준 이 곳에 행하겠고","reference":"예레미야 7:14","category":"$undefined"},{"id":"19135","book":"예레미야","book_name":"예레미야","chapter":7,"verse":15,"text":"내가 너희 모든 형제 곧 에브라임 온 자손을 쫓아냄같이 내 앞에서 너희를 쫓아내리라 하셨다 할지니라","reference":"예레미야 7:15","category":"$undefined"},{"id":"19136","book":"예레미야","book_name":"예레미야","chapter":7,"verse":16,"text":"그런즉 너는 이 백성을 위하여 기도하지 말라 그들을 위하여 부르짖어 구하지 말라 내게 간구하지 말라 내가 너를 듣지 아니하리라","reference":"예레미야 7:16","category":"$undefined"},{"id":"19137","book":"예레미야","book_name":"예레미야","chapter":7,"verse":17,"text":"너는 그들이 유다 성읍들과 예루살렘 거리에서 행하는 일을 보지 못하느냐 ?","reference":"예레미야 7:17","category":"$undefined"},{"id":"19138","book":"예레미야","book_name":"예레미야","chapter":7,"verse":18,"text":"자식들은 나무를 줍고 아비들은 불을 피우며 부녀들은 가루를 반죽하여 하늘 황후를 위하여 과자를 만들며 그들이 또 다른 신들에게 전제를 부음으로 나의 노를 격동하느니라","reference":"예레미야 7:18","category":"$undefined"},{"id":"19139","book":"예레미야","book_name":"예레미야","chapter":7,"verse":19,"text":"나 여호와가 말하노라 그들이 나를 격노케 함이냐 ? 어찌 자기 얼굴에 수욕을 자취함이 아니냐 ?","reference":"예레미야 7:19","category":"$undefined"},{"id":"19140","book":"예레미야","book_name":"예레미야","chapter":7,"verse":20,"text":"그러므로 주 여호와 내가 이같이 말하노라 보라 나의 진노와 분한을 이 곳에 붓되 사람과 짐승과 들나무와 땅의 소산에 부으리니 불같이 살라지고 꺼지지 아니하리라 하시니라","reference":"예레미야 7:20","category":"$undefined"},{"id":"19141","book":"예레미야","book_name":"예레미야","chapter":7,"verse":21,"text":"만군의 여호와 이스라엘의 하나님이 이같이 말씀하시되 너희 희생에 번제물을 아울러 그 고기를 먹으라","reference":"예레미야 7:21","category":"$undefined"},{"id":"19142","book":"예레미야","book_name":"예레미야","chapter":7,"verse":22,"text":"대저 내가 너희 열조를 애굽 땅에서 인도하여 낸 날에 번제나 희생에 대하여 말하지 아니하며 명하지 아니하고","reference":"예레미야 7:22","category":"$undefined"},{"id":"19143","book":"예레미야","book_name":"예레미야","chapter":7,"verse":23,"text":"오직 내가 이것으로 그들에게 명하여 이르기를 너희는 내 목소리를 들으라 ! 그리하면 나는 너희 하나님이 되겠고 너희는 내 백성이 되리라 너희는 나의 명한 모든 길로 행하라 그리하면 복을 받으리라 하였으나","reference":"예레미야 7:23","category":"$undefined"},{"id":"19144","book":"예레미야","book_name":"예레미야","chapter":7,"verse":24,"text":"그들이 청종치 아니하며 귀를 기울이지도 아니하고 자기의 악한 마음의 꾀와 강퍅한 대로 행하여 그 등을 내게로 향하고 그 얼굴을 향치 아니하였으며","reference":"예레미야 7:24","category":"$undefined"},{"id":"19145","book":"예레미야","book_name":"예레미야","chapter":7,"verse":25,"text":"너희 열조가 애굽 땅에서 나온 날 부터 오늘까지 내가 내 종 선지자들을 너희에게 보내었으되 부지런히 보내었으나","reference":"예레미야 7:25","category":"$undefined"},{"id":"19146","book":"예레미야","book_name":"예레미야","chapter":7,"verse":26,"text":"너희가 나를 청종치 아니하며 귀를 기울이지 아니하고 목을 굳게하여 너희 열조보다 악을 더 행하였느니라","reference":"예레미야 7:26","category":"$undefined"},{"id":"19147","book":"예레미야","book_name":"예레미야","chapter":7,"verse":27,"text":"네가 그들에게 이 모든 말을 할지라도 그들이 너를 청종치 아니할 것이요 네가 그들을 불러도 그들이 네게 대답지 아니하리니","reference":"예레미야 7:27","category":"$undefined"},{"id":"19148","book":"예레미야","book_name":"예레미야","chapter":7,"verse":28,"text":"너는 그들에게 말하기를 너희는 너희 하나님 여호와의 목소리를 청종치 아니하며 교훈을 받지 아니하는 국민이라 진실이 없어져 너희 입에서 끊어졌다 할지니라","reference":"예레미야 7:28","category":"$undefined"},{"id":"19149","book":"예레미야","book_name":"예레미야","chapter":7,"verse":29,"text":"예루살렘아, 너의 머리털을 베어 버리고 자산 위에서 호곡할지어다 여호와께서 그 노하신 바 이 세대를 끊어버리셨음이니라","reference":"예레미야 7:29","category":"$undefined"},{"id":"19150","book":"예레미야","book_name":"예레미야","chapter":7,"verse":30,"text":"여호와께서 말씀하시되 유다 자손이 나의 목전에 악을 행하여 내 이름으로 일컬음을 받는 집에 그들의 가증한 것을 두어 집을 더럽혔으며","reference":"예레미야 7:30","category":"$undefined"},{"id":"19151","book":"예레미야","book_name":"예레미야","chapter":7,"verse":31,"text":"힌놈의 아들 골짜기에 도벳 사당을 건축하고 그 자녀를 불에 살랐나니 내가 명하지 아니하였고 내 마음에 생각지도 아니한 일이니라","reference":"예레미야 7:31","category":"$undefined"},{"id":"19152","book":"예레미야","book_name":"예레미야","chapter":7,"verse":32,"text":"그러므로 나 여호와가 말하노라 날이 이르면 이 곳을 도벳이라 하거나 힌놈의 아들의 골짜기라 칭하지 아니하고 살륙의 골짜기라 칭하리니 매장할 자리가 없도록 도벳에 장사함을 인함이니라","reference":"예레미야 7:32","category":"$undefined"},{"id":"19153","book":"예레미야","book_name":"예레미야","chapter":7,"verse":33,"text":"이 백성의 시체가 공중의 새와 땅 짐승의 밥이 될 것이나 그것을 쫓을 자가 없을 것이라","reference":"예레미야 7:33","category":"$undefined"},{"id":"19154","book":"예레미야","book_name":"예레미야","chapter":7,"verse":34,"text":"그 때에 내가 유다 성읍들과 예루살렘 거리에 기뻐하는 소리, 즐기는 소리, 신랑의 소리, 신부의 소리가 끊쳐지게 하리니 땅이 황폐하리라","reference":"예레미야 7:34","category":"$undefined"}],"bookSlug":"jeremiah"}]
