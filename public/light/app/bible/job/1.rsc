2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":1,"verses":[{"id":"12871","book":"욥기","book_name":"욥기","chapter":1,"verse":1,"text":"우스 땅에 욥이라 이름하는 사람이 있었는데 그 사람은 순전하고 정직하여 하나님을 경외하며 악에서 떠난 자더라","reference":"욥기 1:1","category":"$undefined"},{"id":"12872","book":"욥기","book_name":"욥기","chapter":1,"verse":2,"text":"그 소생은 남자가 일곱이요, 여자가 셋이며","reference":"욥기 1:2","category":"$undefined"},{"id":"12873","book":"욥기","book_name":"욥기","chapter":1,"verse":3,"text":"그 소유물은 양이 칠천이요, 약대가 삼천이요, 소가 오백 겨리요, 암 나귀가 오백이며, 종도 많이 있었으니 이 사람은 동방 사람 중에 가장 큰 자라","reference":"욥기 1:3","category":"$undefined"},{"id":"12874","book":"욥기","book_name":"욥기","chapter":1,"verse":4,"text":"그 아들들이 자기 생일이면 각각 자기의 집에서 잔치를 베풀고 그 누이 셋도 청하여 함께 먹고 마시므로","reference":"욥기 1:4","category":"$undefined"},{"id":"12875","book":"욥기","book_name":"욥기","chapter":1,"verse":5,"text":"그 잔치 날이 지나면 욥이 그들을 불러다가 성결케 하되 아침에 일어나서 그들의 명수대로 번제를 드렸으니 이는 욥이 말하기를 `혹시 내 아들들이 죄를 범하여 마음으로 하나님을 배반하였을까' 함이라 욥의 행사가 항상 이러하였더라","reference":"욥기 1:5","category":"$undefined"},{"id":"12876","book":"욥기","book_name":"욥기","chapter":1,"verse":6,"text":"하루는 하나님의 아들들이 와서 여호와 앞에 섰고 사단도 그들 가운데 왔는지라","reference":"욥기 1:6","category":"$undefined"},{"id":"12877","book":"욥기","book_name":"욥기","chapter":1,"verse":7,"text":"여호와께서 사단에게 이르시되 네가 어디서 왔느냐 ? 사단이 여호와께 대답하여 가로되 `땅에 두루 돌아 여기 저기 다녀 왔나이다'","reference":"욥기 1:7","category":"$undefined"},{"id":"12878","book":"욥기","book_name":"욥기","chapter":1,"verse":8,"text":"여호와께서 사단에게 이르시되 네가 내 종 욥을 유의하여 보았느냐 ? 그와 같이 순전하고 정직하여 하나님을 경외하며 악에서 떠난 자가 세상에 없느니라","reference":"욥기 1:8","category":"$undefined"},{"id":"12879","book":"욥기","book_name":"욥기","chapter":1,"verse":9,"text":"사단이 여호와께 대답하여 가로되 `욥이 어찌 까닭 없이 하나님을 경외하리이까 ?","reference":"욥기 1:9","category":"$undefined"},{"id":"12880","book":"욥기","book_name":"욥기","chapter":1,"verse":10,"text":"그와 그 집과 그 모든 소유물을 산울로 두르심이 아니니이까 ? 주께서 그 손으로 하는 바를 복되게 하사 그 소유물로 땅에 널리게 하셨음이니이다","reference":"욥기 1:10","category":"$undefined"},{"id":"12881","book":"욥기","book_name":"욥기","chapter":1,"verse":11,"text":"이제 주의 손을 펴서 그의 모든 소유물을 치소서 그리하시면 정녕 대면하여 주를 욕하리이다'","reference":"욥기 1:11","category":"$undefined"},{"id":"12882","book":"욥기","book_name":"욥기","chapter":1,"verse":12,"text":"여호와께서 사단에게 이르시되 내가 그의 소유물을 다 네 손에 붙이노라 오직 그의 몸에는 네 손을 대지 말지니라 ! 사단이 곧 여호와 앞에서 물러가니라","reference":"욥기 1:12","category":"$undefined"},{"id":"12883","book":"욥기","book_name":"욥기","chapter":1,"verse":13,"text":"하루는 욥의 자녀들이 그 맏형의 집에서 식물을 먹으며 포도주를 마실 때에","reference":"욥기 1:13","category":"$undefined"},{"id":"12884","book":"욥기","book_name":"욥기","chapter":1,"verse":14,"text":"사자가 욥에게 와서 고하되 `소는 밭을 갈고 나귀는 그 곁에서 풀을 먹는데","reference":"욥기 1:14","category":"$undefined"},{"id":"12885","book":"욥기","book_name":"욥기","chapter":1,"verse":15,"text":"스바 사람이 갑자기 이르러 그것들을 빼앗고 칼로 종을 죽였나이다 나만 홀로 피한고로 주인께 고하러 왔나이다'","reference":"욥기 1:15","category":"$undefined"},{"id":"12886","book":"욥기","book_name":"욥기","chapter":1,"verse":16,"text":"그가 아직 말할 때에 또 한 사람이 와서 고하되 `하나님의 불이 하늘에서 내려와서 양과 종을 살라버렸나이다 나만 홀로 피한고로 주인께 고하러 왔나이다'","reference":"욥기 1:16","category":"$undefined"},{"id":"12887","book":"욥기","book_name":"욥기","chapter":1,"verse":17,"text":"그가 아직 말할 때에 또 한 사람이 와서 고하되 `갈대아 사람이 세 떼를 지어 갑자기 약대에게 달려들어 그것을 빼앗으며 칼로 종을 죽였나이다 나만 홀로 피한고로 주인께 고하러 왔나이다'","reference":"욥기 1:17","category":"$undefined"},{"id":"12888","book":"욥기","book_name":"욥기","chapter":1,"verse":18,"text":"그가 아직 말할 때에 또 한 사람이 와서 고하되 `주인의 자녀들이 그 맏형의 집에서 식물을 먹으며 포도주를 마시더니","reference":"욥기 1:18","category":"$undefined"},{"id":"12889","book":"욥기","book_name":"욥기","chapter":1,"verse":19,"text":"거친 들에서 대풍이 와서 집 네 모퉁이를 치매 그 소년들 위에 무너지므로 그들이 죽었나이다 나만 홀로 피한고로 주인께 고하러 왔나이다' 한지라","reference":"욥기 1:19","category":"$undefined"},{"id":"12890","book":"욥기","book_name":"욥기","chapter":1,"verse":20,"text":"욥이 일어나 겉옷을 찢고 머리털을 밀고 땅에 엎드려 경배하며","reference":"욥기 1:20","category":"$undefined"},{"id":"12891","book":"욥기","book_name":"욥기","chapter":1,"verse":21,"text":"가로되 `내가 모태에서 적신이 나왔사온즉 또한 적신이 그리로 돌아가올지라 주신 자도 여호와시요 취하신 자도 여호와시오니 여호와의 이름이 찬송을 받으실지니이다 !' 하고","reference":"욥기 1:21","category":"$undefined"},{"id":"12892","book":"욥기","book_name":"욥기","chapter":1,"verse":22,"text":"이 모든 일에 욥이 범죄하지 아니하고 하나님을 향하여 어리석게 원망 하지 아니하니라","reference":"욥기 1:22","category":"$undefined"}],"bookSlug":"job"}]
