2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":10,"verses":[{"id":"13088","book":"욥기","book_name":"욥기","chapter":10,"verse":1,"text":"내 영혼이 살기에 곤비하니 내 원통함을 발설하고 내 마음의 괴로운대로 말하리라","reference":"욥기 10:1","category":"$undefined"},{"id":"13089","book":"욥기","book_name":"욥기","chapter":10,"verse":2,"text":"내가 하나님께 아뢰오리니 나를 정죄하지 마옵시고 무슨 연고로 나로 더불어 쟁변하시는지 나로 알게 하옵소서","reference":"욥기 10:2","category":"$undefined"},{"id":"13090","book":"욥기","book_name":"욥기","chapter":10,"verse":3,"text":"주께서 주의 손으로 지으신 것을 학대하시며 멸시하시고 악인의 꾀에 빛을 비취시기를 선히 여기시나이까 ?","reference":"욥기 10:3","category":"$undefined"},{"id":"13091","book":"욥기","book_name":"욥기","chapter":10,"verse":4,"text":"주의 눈이 육신의 눈이니이까 ? 주께서 사람의 보는 것처럼 보시리이까 ?","reference":"욥기 10:4","category":"$undefined"},{"id":"13092","book":"욥기","book_name":"욥기","chapter":10,"verse":5,"text":"주의 날이 어찌 인생의 날과 같으며 주의 해가 어찌 인생의 날과 같기로","reference":"욥기 10:5","category":"$undefined"},{"id":"13093","book":"욥기","book_name":"욥기","chapter":10,"verse":6,"text":"나의 허물을 찾으시며 나의 죄를 사실하시나이까 ?","reference":"욥기 10:6","category":"$undefined"},{"id":"13094","book":"욥기","book_name":"욥기","chapter":10,"verse":7,"text":"주께서는 내가 악하지 않은 줄을 아시나이다 주의 손에서 나를 벗어나게 할 자도 없나이다","reference":"욥기 10:7","category":"$undefined"},{"id":"13095","book":"욥기","book_name":"욥기","chapter":10,"verse":8,"text":"주의 손으로 나를 만드사 백체를 이루셨거늘 이제 나를 멸하시나이다","reference":"욥기 10:8","category":"$undefined"},{"id":"13096","book":"욥기","book_name":"욥기","chapter":10,"verse":9,"text":"기억하옵소서 주께서 내 몸 지으시기를 흙을 뭉치듯 하셨거늘 다시 나를 티끌로 돌려 보내려 하시나이까 ?","reference":"욥기 10:9","category":"$undefined"},{"id":"13097","book":"욥기","book_name":"욥기","chapter":10,"verse":10,"text":"주께서 나를 젖과 같이 쏟으셨으며 엉긴 것처럼 엉기게 하지 아니하셨나이까 ?","reference":"욥기 10:10","category":"$undefined"},{"id":"13098","book":"욥기","book_name":"욥기","chapter":10,"verse":11,"text":"가죽과 살로 내게 입히시며 뼈와 힘줄로 나를 뭉치시고","reference":"욥기 10:11","category":"$undefined"},{"id":"13099","book":"욥기","book_name":"욥기","chapter":10,"verse":12,"text":"생명과 은혜를 내게 주시고 권고하심으로 내 영을 지키셨나이다","reference":"욥기 10:12","category":"$undefined"},{"id":"13100","book":"욥기","book_name":"욥기","chapter":10,"verse":13,"text":"그러한데 주께서 이것들을 마음에 품으셨나이다 이 뜻이 주께 있은 줄을 내가 아나이다","reference":"욥기 10:13","category":"$undefined"},{"id":"13101","book":"욥기","book_name":"욥기","chapter":10,"verse":14,"text":"내가 범죄하면 주께서 나를 죄인으로 인정하시고 내 죄악을 사유치 아니 하시나이다","reference":"욥기 10:14","category":"$undefined"},{"id":"13102","book":"욥기","book_name":"욥기","chapter":10,"verse":15,"text":"내가 악하면 화가 있을 것이오며 내가 의로울지라도 머리를 들지 못하올 것은 내 속에 부끄러움이 가득하고 내 환난을 목도함이니이다","reference":"욥기 10:15","category":"$undefined"},{"id":"13103","book":"욥기","book_name":"욥기","chapter":10,"verse":16,"text":"내가 머리를 높이 들면 주께서 사자처럼 나를 사냥하시며 내게 주의 기이한 능력을 다시 나타내시나이다","reference":"욥기 10:16","category":"$undefined"},{"id":"13104","book":"욥기","book_name":"욥기","chapter":10,"verse":17,"text":"주께서 자주자주 증거하는 자를 갈마들여 나를 치시며 나를 향하여 진노를 더하시니 군대가 갈마들어 치는 것 같으니이다","reference":"욥기 10:17","category":"$undefined"},{"id":"13105","book":"욥기","book_name":"욥기","chapter":10,"verse":18,"text":"주께서 나를 태에서 나오게 하셨음은 어찜이니이까 ? 그렇지 아니하였더면,내가 기운이 끊어져 아무 눈에도 보이지 아니하였을 것이라","reference":"욥기 10:18","category":"$undefined"},{"id":"13106","book":"욥기","book_name":"욥기","chapter":10,"verse":19,"text":"있어도 없던것 같이 되어서 태에서 바로 무덤으로 옮겼으리이다","reference":"욥기 10:19","category":"$undefined"},{"id":"13107","book":"욥기","book_name":"욥기","chapter":10,"verse":20,"text":"내 날은 적지 아니하니이까 ? 그런즉 그치시고 나를 버려두사 저으기 평안하게 하옵시되","reference":"욥기 10:20","category":"$undefined"},{"id":"13108","book":"욥기","book_name":"욥기","chapter":10,"verse":21,"text":"내가 돌아오지 못할 땅 곧 어둡고 죽음의 그늘진 땅으로 가기 전에 그리하옵소서","reference":"욥기 10:21","category":"$undefined"},{"id":"13109","book":"욥기","book_name":"욥기","chapter":10,"verse":22,"text":"이 땅은 어두워서 흑암 같고 죽음의 그늘이 져서 아무 구별이 없고 광명도 흑암 같으니이다","reference":"욥기 10:22","category":"$undefined"}],"bookSlug":"job"}]
