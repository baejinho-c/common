2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":11,"verses":[{"id":"13110","book":"욥기","book_name":"욥기","chapter":11,"verse":1,"text":"나아마 사람 소발이 대답하여 가로되","reference":"욥기 11:1","category":"$undefined"},{"id":"13111","book":"욥기","book_name":"욥기","chapter":11,"verse":2,"text":"말이 많으니 어찌 대답이 없으랴 입이 부푼 사람이 어찌 의롭다 함을 얻겠느냐 ?","reference":"욥기 11:2","category":"$undefined"},{"id":"13112","book":"욥기","book_name":"욥기","chapter":11,"verse":3,"text":"네 자랑하는 말이 어떻게 사람으로 잠잠하게 하겠으며 네가 비웃으면 어찌 너를 부끄럽게 할 사람이 없겠느냐 ?","reference":"욥기 11:3","category":"$undefined"},{"id":"13113","book":"욥기","book_name":"욥기","chapter":11,"verse":4,"text":"네 말이 내 도는 정결하고 나는 주의 목전에 깨끗하다 하는구나","reference":"욥기 11:4","category":"$undefined"},{"id":"13114","book":"욥기","book_name":"욥기","chapter":11,"verse":5,"text":"하나님은 말씀을 내시며 너를 향하여 입을 여시고","reference":"욥기 11:5","category":"$undefined"},{"id":"13115","book":"욥기","book_name":"욥기","chapter":11,"verse":6,"text":"지혜의 오묘로 네게 보이시기를 원하노니 이는 그의 지식이 광대 하심이라 너는 알라 하나님의 벌하심이 네 죄보다 경하니라","reference":"욥기 11:6","category":"$undefined"},{"id":"13116","book":"욥기","book_name":"욥기","chapter":11,"verse":7,"text":"네가 하나님의 오묘를 어찌 능히 측량하며 전능자를 어찌 능히 온전히 알겠느냐 ?","reference":"욥기 11:7","category":"$undefined"},{"id":"13117","book":"욥기","book_name":"욥기","chapter":11,"verse":8,"text":"하늘보다 높으시니 네가 어찌 하겠으며 음부보다 깊으시니 네가 어찌 알겠느냐 ?","reference":"욥기 11:8","category":"$undefined"},{"id":"13118","book":"욥기","book_name":"욥기","chapter":11,"verse":9,"text":"그 도량은 땅보다 크고 바다보다 넓으니라","reference":"욥기 11:9","category":"$undefined"},{"id":"13119","book":"욥기","book_name":"욥기","chapter":11,"verse":10,"text":"하나님이 두루 다니시며 사람을 잡아 가두시고 개정하시면 누가 능히 막을소냐 ?","reference":"욥기 11:10","category":"$undefined"},{"id":"13120","book":"욥기","book_name":"욥기","chapter":11,"verse":11,"text":"하나님은 허망한 사람을 아시나니 악한 일은 상관치 않으시는 듯하나 다 보시느니라","reference":"욥기 11:11","category":"$undefined"},{"id":"13121","book":"욥기","book_name":"욥기","chapter":11,"verse":12,"text":"허망한 사람은 지각이 없나니 그 출생함이 들나귀 새끼 같으니라","reference":"욥기 11:12","category":"$undefined"},{"id":"13122","book":"욥기","book_name":"욥기","chapter":11,"verse":13,"text":"만일 네가 마음을 바로 정하고 주를 향하여 손을 들 때에","reference":"욥기 11:13","category":"$undefined"},{"id":"13123","book":"욥기","book_name":"욥기","chapter":11,"verse":14,"text":"네 손에 죄악이 있거든 멀리 버리라 불의로 네 장막에 거하지 못하게 하라","reference":"욥기 11:14","category":"$undefined"},{"id":"13124","book":"욥기","book_name":"욥기","chapter":11,"verse":15,"text":"그리하면 네가 정녕 흠 없는 얼굴을 들게 되고 굳게 서서 두려움이 없으리니","reference":"욥기 11:15","category":"$undefined"},{"id":"13125","book":"욥기","book_name":"욥기","chapter":11,"verse":16,"text":"곧 네 환난을 잊을 것이라 네가 추억할지라도 물이 흘러감 같을 것이며","reference":"욥기 11:16","category":"$undefined"},{"id":"13126","book":"욥기","book_name":"욥기","chapter":11,"verse":17,"text":"네 생명의 날이 대낮보다 밝으리니 어두움이 있다 할지라도 아침과 같이 될 것이요","reference":"욥기 11:17","category":"$undefined"},{"id":"13127","book":"욥기","book_name":"욥기","chapter":11,"verse":18,"text":"네가 소망이 있으므로 든든할지며 두루 살펴보고 안전히 쉬리니","reference":"욥기 11:18","category":"$undefined"},{"id":"13128","book":"욥기","book_name":"욥기","chapter":11,"verse":19,"text":"네가 누워도 두렵게 할 자가 없겠고 많은 사람이 네게 첨을 드리리라","reference":"욥기 11:19","category":"$undefined"},{"id":"13129","book":"욥기","book_name":"욥기","chapter":11,"verse":20,"text":"그러나 악한 자는 눈이 어두워서 도망할 곳을 찾지 못하리니 그의 소망은 기운이 끊침이리라","reference":"욥기 11:20","category":"$undefined"}],"bookSlug":"job"}]
