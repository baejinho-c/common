2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":12,"verses":[{"id":"13130","book":"욥기","book_name":"욥기","chapter":12,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 12:1","category":"$undefined"},{"id":"13131","book":"욥기","book_name":"욥기","chapter":12,"verse":2,"text":"너희만 참으로 사람이로구나 너희가 죽으면 지혜도 죽겠구나","reference":"욥기 12:2","category":"$undefined"},{"id":"13132","book":"욥기","book_name":"욥기","chapter":12,"verse":3,"text":"나도 너희 같이 총명이 있어 너희만 못하지 아니하니 그같은 일을 누가 알지 못하겠느냐 ?","reference":"욥기 12:3","category":"$undefined"},{"id":"13133","book":"욥기","book_name":"욥기","chapter":12,"verse":4,"text":"하나님께 불러 아뢰어 들으심을 입은 내가 이웃에게 웃음 받는 자가 되었으니 의롭고 순전한 자가 조롱거리가 되었구나","reference":"욥기 12:4","category":"$undefined"},{"id":"13134","book":"욥기","book_name":"욥기","chapter":12,"verse":5,"text":"평안한 자의 마음은 재앙을 멸시하나 재앙이 실족하는 자를 기다리는구나","reference":"욥기 12:5","category":"$undefined"},{"id":"13135","book":"욥기","book_name":"욥기","chapter":12,"verse":6,"text":"강도의 장막은 형통하고 하나님을 진노케 하는 자가 평안하니 하나님이 그 손에 후히 주심이니라","reference":"욥기 12:6","category":"$undefined"},{"id":"13136","book":"욥기","book_name":"욥기","chapter":12,"verse":7,"text":"이제 모든 짐승에게 물어 보라 그것들이 네게 가르치리라 공중의 새에게 물어 보라 그것들이 또한 네게 고하리라","reference":"욥기 12:7","category":"$undefined"},{"id":"13137","book":"욥기","book_name":"욥기","chapter":12,"verse":8,"text":"땅에게 말하라 네게 가르치리라 바다의 고기도 네게 설명하리라","reference":"욥기 12:8","category":"$undefined"},{"id":"13138","book":"욥기","book_name":"욥기","chapter":12,"verse":9,"text":"이것들 중에 어느 것이 여호와의 손이 이를 행하신 줄을 알지 못하랴","reference":"욥기 12:9","category":"$undefined"},{"id":"13139","book":"욥기","book_name":"욥기","chapter":12,"verse":10,"text":"생물들의 혼과 인생들의 영이 다 그의 손에 있느니라","reference":"욥기 12:10","category":"$undefined"},{"id":"13140","book":"욥기","book_name":"욥기","chapter":12,"verse":11,"text":"입이 식물의 맛을 변별함 같이 귀가 말을 분변하지 아니하느냐 ?","reference":"욥기 12:11","category":"$undefined"},{"id":"13141","book":"욥기","book_name":"욥기","chapter":12,"verse":12,"text":"늙은 자에게는 지혜가 있고 장수하는 자에게는 명철이 있느니라","reference":"욥기 12:12","category":"$undefined"},{"id":"13142","book":"욥기","book_name":"욥기","chapter":12,"verse":13,"text":"지혜와 권능이 하나님께 있고 모략과 명철도 그에게 속하였나니","reference":"욥기 12:13","category":"$undefined"},{"id":"13143","book":"욥기","book_name":"욥기","chapter":12,"verse":14,"text":"그가 헐으신즉 다시 세울 수 없고 사람을 가두신즉 놓지 못하느니라","reference":"욥기 12:14","category":"$undefined"},{"id":"13144","book":"욥기","book_name":"욥기","chapter":12,"verse":15,"text":"그가 물을 그치게 하신즉 곧 마르고 물을 내신즉 곧 땅을 뒤집나니","reference":"욥기 12:15","category":"$undefined"},{"id":"13145","book":"욥기","book_name":"욥기","chapter":12,"verse":16,"text":"능력과 지혜가 그에게 있고 속은 자와 속이는 자가 다 그에게 속하였으므로","reference":"욥기 12:16","category":"$undefined"},{"id":"13146","book":"욥기","book_name":"욥기","chapter":12,"verse":17,"text":"모사를 벌거벗겨 끌어가시며 재판장으로 어리석은 자가 되게 하시며","reference":"욥기 12:17","category":"$undefined"},{"id":"13147","book":"욥기","book_name":"욥기","chapter":12,"verse":18,"text":"열왕의 맨 것을 풀어 그들의 허리를 동이시며","reference":"욥기 12:18","category":"$undefined"},{"id":"13148","book":"욥기","book_name":"욥기","chapter":12,"verse":19,"text":"제사장들을 벌거벗겨 끌어 가시고 권력이 있는 자를 넘어뜨리시며","reference":"욥기 12:19","category":"$undefined"},{"id":"13149","book":"욥기","book_name":"욥기","chapter":12,"verse":20,"text":"충성된 자의 말을 없이 하시며 늙은 자의 지식을 빼앗으시며","reference":"욥기 12:20","category":"$undefined"},{"id":"13150","book":"욥기","book_name":"욥기","chapter":12,"verse":21,"text":"방백들에게 멸시를 쏟으시며 강한 자의 띠를 푸시며","reference":"욥기 12:21","category":"$undefined"},{"id":"13151","book":"욥기","book_name":"욥기","chapter":12,"verse":22,"text":"어두운 가운데서 은밀한 것을 드러내시며 죽음의 그늘을 광명한데로 나오게 하시며","reference":"욥기 12:22","category":"$undefined"},{"id":"13152","book":"욥기","book_name":"욥기","chapter":12,"verse":23,"text":"만국을 커지게도 하시고 다시 멸하기도 하시며 열국으로 광대하게도 하시고 다시 사로잡히게도 하시며","reference":"욥기 12:23","category":"$undefined"},{"id":"13153","book":"욥기","book_name":"욥기","chapter":12,"verse":24,"text":"만민의 두목들의 총명을 빼앗으시고 그들을 길 없는 거친 들로 유리하게 하시며","reference":"욥기 12:24","category":"$undefined"},{"id":"13154","book":"욥기","book_name":"욥기","chapter":12,"verse":25,"text":"빛 없이 캄캄한 데를 더듬게 하시며 취한 사람 같이 비틀거리게 하시느니라","reference":"욥기 12:25","category":"$undefined"}],"bookSlug":"job"}]
