2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":13,"verses":[{"id":"13155","book":"욥기","book_name":"욥기","chapter":13,"verse":1,"text":"나의 눈이 이것을 다 보았고 나의 귀가 이것을 듣고 통달하였느니라","reference":"욥기 13:1","category":"$undefined"},{"id":"13156","book":"욥기","book_name":"욥기","chapter":13,"verse":2,"text":"너희 아는 것을 나도 아노니 너희만 못한 내가 아니니라","reference":"욥기 13:2","category":"$undefined"},{"id":"13157","book":"욥기","book_name":"욥기","chapter":13,"verse":3,"text":"참으로 나는 전능자에게 말씀하려 하며 하나님과 변론하려 하노라","reference":"욥기 13:3","category":"$undefined"},{"id":"13158","book":"욥기","book_name":"욥기","chapter":13,"verse":4,"text":"너희는 거짓말을 지어내는 자요 다 쓸데 없는 의원이니라","reference":"욥기 13:4","category":"$undefined"},{"id":"13159","book":"욥기","book_name":"욥기","chapter":13,"verse":5,"text":"너희가 잠잠하고 잠잠하기를 원하노라 이것이 너희의 지혜일 것이니라","reference":"욥기 13:5","category":"$undefined"},{"id":"13160","book":"욥기","book_name":"욥기","chapter":13,"verse":6,"text":"너희는 나의 변론을 들으며 내 입술의 변명을 들어 보라","reference":"욥기 13:6","category":"$undefined"},{"id":"13161","book":"욥기","book_name":"욥기","chapter":13,"verse":7,"text":"너희가 하나님을 위하여 불의를 말하려느냐 ? 그를 위하여 궤휼을 말하려느냐 ?","reference":"욥기 13:7","category":"$undefined"},{"id":"13162","book":"욥기","book_name":"욥기","chapter":13,"verse":8,"text":"너희가 하나님의 낯을 좇으려느냐 ? 그를 위하여 쟁론하려느냐 ?","reference":"욥기 13:8","category":"$undefined"},{"id":"13163","book":"욥기","book_name":"욥기","chapter":13,"verse":9,"text":"하나님이 너희를 감찰하시면 좋겠느냐 ? 너희가 사람을 속임 같이 그를 속이려느냐 ?","reference":"욥기 13:9","category":"$undefined"},{"id":"13164","book":"욥기","book_name":"욥기","chapter":13,"verse":10,"text":"만일 가만히 낯을 좇을진대 그가 정녕 너희를 책망하시리니","reference":"욥기 13:10","category":"$undefined"},{"id":"13165","book":"욥기","book_name":"욥기","chapter":13,"verse":11,"text":"그 존귀가 너희를 두렵게 하지 않겠으며 그 위엄이 너희에게 임하지 않겠느냐 ?","reference":"욥기 13:11","category":"$undefined"},{"id":"13166","book":"욥기","book_name":"욥기","chapter":13,"verse":12,"text":"너희 격언은 재 같은 속담이요 너희의 방어하는 것은 토성이니라","reference":"욥기 13:12","category":"$undefined"},{"id":"13167","book":"욥기","book_name":"욥기","chapter":13,"verse":13,"text":"너희는 잠잠하고 나를 버려두어 말하게 하라 무슨 일이 임하든지 내가 당하리라","reference":"욥기 13:13","category":"$undefined"},{"id":"13168","book":"욥기","book_name":"욥기","chapter":13,"verse":14,"text":"내가 어찌하여 내 살을 내 이로 물고 내 생명을 내 손에 두겠느냐 ?","reference":"욥기 13:14","category":"$undefined"},{"id":"13169","book":"욥기","book_name":"욥기","chapter":13,"verse":15,"text":"그가 나를 죽이시리니 내가 소망이 없노라 그러나 그의 앞에서 내 행위를 변백하리라","reference":"욥기 13:15","category":"$undefined"},{"id":"13170","book":"욥기","book_name":"욥기","chapter":13,"verse":16,"text":"사곡한 자는 그의 앞에 이르지 못하나니 이것이 나의 구원이 되리라","reference":"욥기 13:16","category":"$undefined"},{"id":"13171","book":"욥기","book_name":"욥기","chapter":13,"verse":17,"text":"너희는 들으라 내 말을 들으라 나의 설명을 너희 귀에 담을지니라","reference":"욥기 13:17","category":"$undefined"},{"id":"13172","book":"욥기","book_name":"욥기","chapter":13,"verse":18,"text":"보라 내가 내 사정을 진술하였거니와 내가 스스로 의로운 줄 아노라","reference":"욥기 13:18","category":"$undefined"},{"id":"13173","book":"욥기","book_name":"욥기","chapter":13,"verse":19,"text":"나와 변론할 자가 누구이랴 그러면 내가 잠잠하고 기운이 끊어지리라","reference":"욥기 13:19","category":"$undefined"},{"id":"13174","book":"욥기","book_name":"욥기","chapter":13,"verse":20,"text":"오직 내게 이 두 가지 일을 행하지 마옵소서 그리하시면 내가 주의 얼굴을 피하여 숨지 아니하오리니","reference":"욥기 13:20","category":"$undefined"},{"id":"13175","book":"욥기","book_name":"욥기","chapter":13,"verse":21,"text":"곧 주의 손을 내게 대지 마옵시며 주의 위엄으로 나를 두렵게 마옵실 것이니이다","reference":"욥기 13:21","category":"$undefined"},{"id":"13176","book":"욥기","book_name":"욥기","chapter":13,"verse":22,"text":"그리하시고 주는 나를 부르소서 내가 대답하리이다 혹 나로 말씀하게 하옵시고 주는 내게 대답하옵소서","reference":"욥기 13:22","category":"$undefined"},{"id":"13177","book":"욥기","book_name":"욥기","chapter":13,"verse":23,"text":"나의 불법과 죄가 얼마나 많으니이까 ? 나의 허물과 죄를 내게 알게 하옵소서","reference":"욥기 13:23","category":"$undefined"},{"id":"13178","book":"욥기","book_name":"욥기","chapter":13,"verse":24,"text":"주께서 어찌하여 얼굴을 가리우시고 나를 주의 대적으로 여기시나이까 ?","reference":"욥기 13:24","category":"$undefined"},{"id":"13179","book":"욥기","book_name":"욥기","chapter":13,"verse":25,"text":"주께서 어찌하여 날리는 낙엽을 놀래시며 마른 검불을 따르시나이까 ?","reference":"욥기 13:25","category":"$undefined"},{"id":"13180","book":"욥기","book_name":"욥기","chapter":13,"verse":26,"text":"주께서 나를 대적하사 괴로운 일들을 기록하시며 나로 나의 어렸을 때에 지은 죄를 받게 하시오며","reference":"욥기 13:26","category":"$undefined"},{"id":"13181","book":"욥기","book_name":"욥기","chapter":13,"verse":27,"text":"내 발을 착고에 채우시며 나의 모든 길을 살피사 내 발자취를 한정하시나이다","reference":"욥기 13:27","category":"$undefined"},{"id":"13182","book":"욥기","book_name":"욥기","chapter":13,"verse":28,"text":"나는 썩은 물건의 후패함 같으며 좀먹은 의복 같으니이다","reference":"욥기 13:28","category":"$undefined"}],"bookSlug":"job"}]
