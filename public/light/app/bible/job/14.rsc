2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":14,"verses":[{"id":"13183","book":"욥기","book_name":"욥기","chapter":14,"verse":1,"text":"여인에게서 난 사람은 사는 날이 적고 괴로움이 가득하며","reference":"욥기 14:1","category":"$undefined"},{"id":"13184","book":"욥기","book_name":"욥기","chapter":14,"verse":2,"text":"그 발생함이 꽃과 같아서 쇠하여지고 그림자 같이 신속하여서 머물지 아니하거늘","reference":"욥기 14:2","category":"$undefined"},{"id":"13185","book":"욥기","book_name":"욥기","chapter":14,"verse":3,"text":"이와 같은 자를 주께서 눈을 들어 살피시나이까 ? 나를 주의 앞으로 이끌어서 심문하시나이까 ?","reference":"욥기 14:3","category":"$undefined"},{"id":"13186","book":"욥기","book_name":"욥기","chapter":14,"verse":4,"text":"누가 깨끗한 것을 더러운 것 가운데서 낼 수 있으리이까 ? 하나도 없나이다","reference":"욥기 14:4","category":"$undefined"},{"id":"13187","book":"욥기","book_name":"욥기","chapter":14,"verse":5,"text":"그 날을 정하셨고 그 달 수도 주께 있으므로 그 제한을 정하여 넘어가지 못하게 하셨사온즉","reference":"욥기 14:5","category":"$undefined"},{"id":"13188","book":"욥기","book_name":"욥기","chapter":14,"verse":6,"text":"그에게서 눈을 돌이켜 그로 쉬게 하사 품군 같이 그 날을 마치게 하옵소서","reference":"욥기 14:6","category":"$undefined"},{"id":"13189","book":"욥기","book_name":"욥기","chapter":14,"verse":7,"text":"나무는 소망이 있나니 찍힐지라도 다시 움이 나서 연한 가지가 끊이지 아니하며","reference":"욥기 14:7","category":"$undefined"},{"id":"13190","book":"욥기","book_name":"욥기","chapter":14,"verse":8,"text":"그 뿌리가 땅에서 늙고 줄기가 흙에서 죽을지라도","reference":"욥기 14:8","category":"$undefined"},{"id":"13191","book":"욥기","book_name":"욥기","chapter":14,"verse":9,"text":"물 기운에 움이 돋고 가지가 발하여 새로 심은 것과 같거니와","reference":"욥기 14:9","category":"$undefined"},{"id":"13192","book":"욥기","book_name":"욥기","chapter":14,"verse":10,"text":"사람은 죽으면 소멸되나니 그 기운이 끊어진즉 그가 어디 있느뇨","reference":"욥기 14:10","category":"$undefined"},{"id":"13193","book":"욥기","book_name":"욥기","chapter":14,"verse":11,"text":"물이 바다에서 줄어지고 하수가 잦아서 마름 같이","reference":"욥기 14:11","category":"$undefined"},{"id":"13194","book":"욥기","book_name":"욥기","chapter":14,"verse":12,"text":"사람이 누우면 다시 일어나지 못하고 하늘이 없어지기까지 눈을 뜨지 못하며 잠을 깨지 못하느니라","reference":"욥기 14:12","category":"$undefined"},{"id":"13195","book":"욥기","book_name":"욥기","chapter":14,"verse":13,"text":"주는 나를 음부에 감추시며 주의 진노가 쉴 때까지 나를 숨기시고 나를 위하여 기한을 정하시고 나를 기억하옵소서","reference":"욥기 14:13","category":"$undefined"},{"id":"13196","book":"욥기","book_name":"욥기","chapter":14,"verse":14,"text":"사람이 죽으면 어찌 다시 살리이까 ? 나는 나의 싸우는 모든 날 동안을 참고 놓이기를 기다렸겠나이다","reference":"욥기 14:14","category":"$undefined"},{"id":"13197","book":"욥기","book_name":"욥기","chapter":14,"verse":15,"text":"주께서는 나를 부르셨겠고 나는 대답하였겠나이다 주께서는 주의 손으로 지으신 것을 아껴 보셨겠나이다","reference":"욥기 14:15","category":"$undefined"},{"id":"13198","book":"욥기","book_name":"욥기","chapter":14,"verse":16,"text":"그러하온데 이제 주께서 나의 걸음을 세시오니 나의 죄를 살피지 아니하시나이까 ?","reference":"욥기 14:16","category":"$undefined"},{"id":"13199","book":"욥기","book_name":"욥기","chapter":14,"verse":17,"text":"내 허물을 주머니에 봉하시고 내 죄악을 싸매시나이다","reference":"욥기 14:17","category":"$undefined"},{"id":"13200","book":"욥기","book_name":"욥기","chapter":14,"verse":18,"text":"무너지는 산은 정녕 흩어지고 바위는 그 자리에서 옮겨가고","reference":"욥기 14:18","category":"$undefined"},{"id":"13201","book":"욥기","book_name":"욥기","chapter":14,"verse":19,"text":"물은 돌을 닳게 하고 넘치는 물은 땅의 티끌을 씻어 버리나이다 이와 같이 주께서는 사람의 소망을 끊으시나이다","reference":"욥기 14:19","category":"$undefined"},{"id":"13202","book":"욥기","book_name":"욥기","chapter":14,"verse":20,"text":"주께서 사람을 영영히 이기셔서 떠나게 하시며 그의 얼굴 빛을 변하게 하시고 쫓아 보내시오니","reference":"욥기 14:20","category":"$undefined"},{"id":"13203","book":"욥기","book_name":"욥기","chapter":14,"verse":21,"text":"그 아들이 존귀하나 그가 알지 못하며 비천하나 그가 깨닫지 못하나이다","reference":"욥기 14:21","category":"$undefined"},{"id":"13204","book":"욥기","book_name":"욥기","chapter":14,"verse":22,"text":"오직 자기의 살이 아프고 자기의 마음이 슬플 뿐이니이다","reference":"욥기 14:22","category":"$undefined"}],"bookSlug":"job"}]
