2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":15,"verses":[{"id":"13205","book":"욥기","book_name":"욥기","chapter":15,"verse":1,"text":"데만 사람 엘리바스가 대답하여 가로되","reference":"욥기 15:1","category":"$undefined"},{"id":"13206","book":"욥기","book_name":"욥기","chapter":15,"verse":2,"text":"지혜로운 자가 어찌 헛된 지식으로 대답하겠느냐 ? 어찌 동풍으로 그 품에 채우겠느냐 ?","reference":"욥기 15:2","category":"$undefined"},{"id":"13207","book":"욥기","book_name":"욥기","chapter":15,"verse":3,"text":"어찌 유조치 아니한 이야기, 무익한 말로 변론하겠느냐 ?","reference":"욥기 15:3","category":"$undefined"},{"id":"13208","book":"욥기","book_name":"욥기","chapter":15,"verse":4,"text":"참으로 네가 하나님 경외하는 일을 폐하여 하나님 앞에 묵도하기를 그치게 하는구나","reference":"욥기 15:4","category":"$undefined"},{"id":"13209","book":"욥기","book_name":"욥기","chapter":15,"verse":5,"text":"네 죄악이 네 입을 가르치나니 네가 간사한 자의 혀를 택하였구나","reference":"욥기 15:5","category":"$undefined"},{"id":"13210","book":"욥기","book_name":"욥기","chapter":15,"verse":6,"text":"너를 정죄한 것은 내가 아니요 네 입이라 네 입술이 너를 쳐서 증거하느니라","reference":"욥기 15:6","category":"$undefined"},{"id":"13211","book":"욥기","book_name":"욥기","chapter":15,"verse":7,"text":"네가 제일 처음 난 사람이냐 ? 산들이 있기 전에 네가 출생하였느냐 ?","reference":"욥기 15:7","category":"$undefined"},{"id":"13212","book":"욥기","book_name":"욥기","chapter":15,"verse":8,"text":"하나님의 모의를 네가 들었느냐 ? 지혜를 홀로 가졌느냐 ?","reference":"욥기 15:8","category":"$undefined"},{"id":"13213","book":"욥기","book_name":"욥기","chapter":15,"verse":9,"text":"너의 아는 것이 무엇이기로 우리가 알지 못하겠느냐 ? 너의 깨달은 것이 무엇이기로 우리에게는 없겠느냐 ?","reference":"욥기 15:9","category":"$undefined"},{"id":"13214","book":"욥기","book_name":"욥기","chapter":15,"verse":10,"text":"우리 중에는 머리가 세기도 하고 연로하기도 하여 네 부친보다 나이 많은 자가 있느니라","reference":"욥기 15:10","category":"$undefined"},{"id":"13215","book":"욥기","book_name":"욥기","chapter":15,"verse":11,"text":"하나님의 위로와 네게 온유하게 하시는 말씀을 네가 어찌 작다 하느냐 ?","reference":"욥기 15:11","category":"$undefined"},{"id":"13216","book":"욥기","book_name":"욥기","chapter":15,"verse":12,"text":"어찌하여 네가 마음에 끌리며 네 눈을 번쩍여","reference":"욥기 15:12","category":"$undefined"},{"id":"13217","book":"욥기","book_name":"욥기","chapter":15,"verse":13,"text":"네 영으로 하나님을 반대하고 네 입으로 말들을 내느냐","reference":"욥기 15:13","category":"$undefined"},{"id":"13218","book":"욥기","book_name":"욥기","chapter":15,"verse":14,"text":"사람이 무엇이관대 깨끗하겠느냐 ? 여인에게서 난 자가 무엇이관대 의롭겠느냐 ?","reference":"욥기 15:14","category":"$undefined"},{"id":"13219","book":"욥기","book_name":"욥기","chapter":15,"verse":15,"text":"하나님은 그 거룩한 자들을 믿지 아니 하시나니 하늘이라도 그의 보시기에 부정하거든","reference":"욥기 15:15","category":"$undefined"},{"id":"13220","book":"욥기","book_name":"욥기","chapter":15,"verse":16,"text":"하물며 악을 짓기를 물 마심 같이 하는 가증하고 부패한 사람이겠느냐 ?","reference":"욥기 15:16","category":"$undefined"},{"id":"13221","book":"욥기","book_name":"욥기","chapter":15,"verse":17,"text":"내가 네게 보이리니 나를 들으라 내가 본 것을 설명하리라","reference":"욥기 15:17","category":"$undefined"},{"id":"13222","book":"욥기","book_name":"욥기","chapter":15,"verse":18,"text":"이는 곧 지혜로운 자들이 그 열조에게서 받아 숨기지 아니하고 전하여 온 것이라","reference":"욥기 15:18","category":"$undefined"},{"id":"13223","book":"욥기","book_name":"욥기","chapter":15,"verse":19,"text":"이 땅은 그들에게만 주셨으므로 외인은 그들 중에 왕래하지 못하였었느니라","reference":"욥기 15:19","category":"$undefined"},{"id":"13224","book":"욥기","book_name":"욥기","chapter":15,"verse":20,"text":"그 말에 이르기를 악인은 그 일평생에 고통을 당하며 강포자의 햇수는 작정되었으므로","reference":"욥기 15:20","category":"$undefined"},{"id":"13225","book":"욥기","book_name":"욥기","chapter":15,"verse":21,"text":"그 귀에는 놀라운 소리가 들리고 그 형통할 때에 멸망시키는 자가 그에게 임하리니","reference":"욥기 15:21","category":"$undefined"},{"id":"13226","book":"욥기","book_name":"욥기","chapter":15,"verse":22,"text":"그가 어두운 데서 나오기를 바라지 못하고 칼날의 기다림이 되느니라","reference":"욥기 15:22","category":"$undefined"},{"id":"13227","book":"욥기","book_name":"욥기","chapter":15,"verse":23,"text":"그는 유리하며 식물을 구하여 이르기를 어디 있느냐 ? 하며 흑암한 날이 가까운 줄을 스스로 아느니라","reference":"욥기 15:23","category":"$undefined"},{"id":"13228","book":"욥기","book_name":"욥기","chapter":15,"verse":24,"text":"환난과 고통이 그를 두렵게 하며 싸움을 준비한 왕처럼 그를 쳐서 이기리니","reference":"욥기 15:24","category":"$undefined"},{"id":"13229","book":"욥기","book_name":"욥기","chapter":15,"verse":25,"text":"이는 그 손을 들어 하나님을 대적하며 교만하여 전능자를 배반함이니라","reference":"욥기 15:25","category":"$undefined"},{"id":"13230","book":"욥기","book_name":"욥기","chapter":15,"verse":26,"text":"그는 목을 굳게 하고 두터운 방패로 하나님을 치려고 달려가나니","reference":"욥기 15:26","category":"$undefined"},{"id":"13231","book":"욥기","book_name":"욥기","chapter":15,"verse":27,"text":"그 얼굴에는 살이 찌고 허리에는 기름이 엉기었고","reference":"욥기 15:27","category":"$undefined"},{"id":"13232","book":"욥기","book_name":"욥기","chapter":15,"verse":28,"text":"그는 황무한 성읍, 사람이 살지 아니하는 집, 돌 무더기가 될 곳에 거하였음이니라","reference":"욥기 15:28","category":"$undefined"},{"id":"13233","book":"욥기","book_name":"욥기","chapter":15,"verse":29,"text":"그는 부요하지 못하고 재산이 항상 있지 못하며 그 산업이 땅에서 증식하지 못할 것이며","reference":"욥기 15:29","category":"$undefined"},{"id":"13234","book":"욥기","book_name":"욥기","chapter":15,"verse":30,"text":"흑암한 데를 떠나지 못하리니 불꽃이 그 가지를 말릴 것이라 하나님의 입김에 그가 떠나리라","reference":"욥기 15:30","category":"$undefined"},{"id":"13235","book":"욥기","book_name":"욥기","chapter":15,"verse":31,"text":"그는 스스로 속아 허망한 것을 믿지 말 것은 허망한 것이 그의 보응이 될 것임이라","reference":"욥기 15:31","category":"$undefined"},{"id":"13236","book":"욥기","book_name":"욥기","chapter":15,"verse":32,"text":"그의 날이 이르기 전에 그 일이 이룰 것인즉 그 가지가 푸르지 못하리니","reference":"욥기 15:32","category":"$undefined"},{"id":"13237","book":"욥기","book_name":"욥기","chapter":15,"verse":33,"text":"포도열매가 익기 전에 떨어짐 같고 감람 꽃이 곧 떨어짐 같으리라","reference":"욥기 15:33","category":"$undefined"},{"id":"13238","book":"욥기","book_name":"욥기","chapter":15,"verse":34,"text":"사곡한 무리는 결실이 없고 뇌물을 받는 자의 장막은 불탈 것이라","reference":"욥기 15:34","category":"$undefined"},{"id":"13239","book":"욥기","book_name":"욥기","chapter":15,"verse":35,"text":"그들은 악한 생각을 배고 불의를 낳으며 마음에 궤휼을 예비한다 하였느니라","reference":"욥기 15:35","category":"$undefined"}],"bookSlug":"job"}]
