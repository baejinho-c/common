2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":16,"verses":[{"id":"13240","book":"욥기","book_name":"욥기","chapter":16,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 16:1","category":"$undefined"},{"id":"13241","book":"욥기","book_name":"욥기","chapter":16,"verse":2,"text":"이런 말은 내가 많이 들었나니 너희는 다 번뇌케 하는 안위자로구나","reference":"욥기 16:2","category":"$undefined"},{"id":"13242","book":"욥기","book_name":"욥기","chapter":16,"verse":3,"text":"허망한 말이 어찌 끝이 있으랴 네가 무엇에 격동되어 이같이 대답하는고","reference":"욥기 16:3","category":"$undefined"},{"id":"13243","book":"욥기","book_name":"욥기","chapter":16,"verse":4,"text":"나도 너희처럼 말할 수 있나니 가령 너희 마음이 내 마음 자리에 있다 하자 나도 말을 지어 너희를 치며 너희를 향하여 머리를 흔들 수 있느니라","reference":"욥기 16:4","category":"$undefined"},{"id":"13244","book":"욥기","book_name":"욥기","chapter":16,"verse":5,"text":"그래도 입으로 너희를 강하게 하며 입술의 위로로 너희의 근심을 풀었으리라","reference":"욥기 16:5","category":"$undefined"},{"id":"13245","book":"욥기","book_name":"욥기","chapter":16,"verse":6,"text":"내가 말하여도 내 근심이 풀리지 아니하나니 잠잠한들 어찌 평안하랴","reference":"욥기 16:6","category":"$undefined"},{"id":"13246","book":"욥기","book_name":"욥기","chapter":16,"verse":7,"text":"이제 주께서 나를 곤고케 하시고 나의 무리를 패괴케 하셨나이다","reference":"욥기 16:7","category":"$undefined"},{"id":"13247","book":"욥기","book_name":"욥기","chapter":16,"verse":8,"text":"주께서 나를 시들게 하셨으니 이는 나를 향하여 증거를 삼으심이라 나의 파리한 모양이 일어나서 대면하여 나의 죄를 증거하나이다","reference":"욥기 16:8","category":"$undefined"},{"id":"13248","book":"욥기","book_name":"욥기","chapter":16,"verse":9,"text":"그는 진노하사 나를 찢고 군박하시며 나를 향하여 이를 갈고 대적이 되어 뾰족한 눈으로 나를 보시고","reference":"욥기 16:9","category":"$undefined"},{"id":"13249","book":"욥기","book_name":"욥기","chapter":16,"verse":10,"text":"무리들은 나를 향하여 입을 벌리며 나를 천대하여 뺨을 치며 함께 모여 나를 대적하는구나","reference":"욥기 16:10","category":"$undefined"},{"id":"13250","book":"욥기","book_name":"욥기","chapter":16,"verse":11,"text":"하나님이 나를 경건치 않은 자에게 붙이시며 악인의 손에 던지셨구나","reference":"욥기 16:11","category":"$undefined"},{"id":"13251","book":"욥기","book_name":"욥기","chapter":16,"verse":12,"text":"내가 평안하더니 그가 나를 꺾으시며 내 목을 잡아던져 나를 부숴뜨리시며 나를 세워 과녁을 삼으시고","reference":"욥기 16:12","category":"$undefined"},{"id":"13252","book":"욥기","book_name":"욥기","chapter":16,"verse":13,"text":"그 살로 나를 사방으로 쏘아 인정 없이 내 허리를 뚫고 내 쓸개로 땅에 흘러나오게 하시는구나","reference":"욥기 16:13","category":"$undefined"},{"id":"13253","book":"욥기","book_name":"욥기","chapter":16,"verse":14,"text":"그가 나를 꺾고 다시 꺾고 용사 같이 내게 달려드시니","reference":"욥기 16:14","category":"$undefined"},{"id":"13254","book":"욥기","book_name":"욥기","chapter":16,"verse":15,"text":"내가 굵은 베를 꿰어매어 내 피부에 덮고 내 뿔을 티끌에 더럽혔구나","reference":"욥기 16:15","category":"$undefined"},{"id":"13255","book":"욥기","book_name":"욥기","chapter":16,"verse":16,"text":"내 얼굴은 울음으로 붉었고 내 눈꺼풀에는 죽음의 그늘이 있구나","reference":"욥기 16:16","category":"$undefined"},{"id":"13256","book":"욥기","book_name":"욥기","chapter":16,"verse":17,"text":"그러나 내 손에는 포학이 없고 나의 기도는 정결하니라","reference":"욥기 16:17","category":"$undefined"},{"id":"13257","book":"욥기","book_name":"욥기","chapter":16,"verse":18,"text":"땅아 내 피를 가리우지 말라 나의 부르짖음으로 쉴 곳이 없게 되기를 원하노라","reference":"욥기 16:18","category":"$undefined"},{"id":"13258","book":"욥기","book_name":"욥기","chapter":16,"verse":19,"text":"지금 나의 증인이 하늘에 계시고 나의 보인이 높은데 계시니라","reference":"욥기 16:19","category":"$undefined"},{"id":"13259","book":"욥기","book_name":"욥기","chapter":16,"verse":20,"text":"나의 친구는 나를 조롱하나 내 눈은 하나님을 향하여 눈물을 흘리고","reference":"욥기 16:20","category":"$undefined"},{"id":"13260","book":"욥기","book_name":"욥기","chapter":16,"verse":21,"text":"사람과 하나님 사이에와 인자와 그 이웃 사이에 변백하시기를 원하노니","reference":"욥기 16:21","category":"$undefined"},{"id":"13261","book":"욥기","book_name":"욥기","chapter":16,"verse":22,"text":"수 년이 지나면 나는 돌아오지 못할 길로 갈 것임이니라","reference":"욥기 16:22","category":"$undefined"}],"bookSlug":"job"}]
