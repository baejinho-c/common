2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":17,"verses":[{"id":"13262","book":"욥기","book_name":"욥기","chapter":17,"verse":1,"text":"나의 기운이 쇠하였으며 나의 날이 다하였고 무덤이 나를 위하여 예비되었구나","reference":"욥기 17:1","category":"$undefined"},{"id":"13263","book":"욥기","book_name":"욥기","chapter":17,"verse":2,"text":"나를 조롱하는 자들이 오히려 나와 함께 있으므로 내 눈이 그들의 격동함을 항상 보는구나","reference":"욥기 17:2","category":"$undefined"},{"id":"13264","book":"욥기","book_name":"욥기","chapter":17,"verse":3,"text":"청컨대 보증물을 주시고 친히 나의 보주가 되옵소서 ! 주 외에 나로 더불어 손을 칠 자가 누구리이까 ?","reference":"욥기 17:3","category":"$undefined"},{"id":"13265","book":"욥기","book_name":"욥기","chapter":17,"verse":4,"text":"주께서 그들의 마음을 가리워 깨닫지 못하게 하셨사오니 그들을 높이지 아니 하시리이다","reference":"욥기 17:4","category":"$undefined"},{"id":"13266","book":"욥기","book_name":"욥기","chapter":17,"verse":5,"text":"친구를 지적하여 해를 받게 한 자의 자식들은 눈이 멀지니라","reference":"욥기 17:5","category":"$undefined"},{"id":"13267","book":"욥기","book_name":"욥기","chapter":17,"verse":6,"text":"하나님이 나로 백성의 이야기거리가 되게 하시니 그들이 내 얼굴에 침을 뱉는구나","reference":"욥기 17:6","category":"$undefined"},{"id":"13268","book":"욥기","book_name":"욥기","chapter":17,"verse":7,"text":"내 눈은 근심으로 하여 어두워지고 나의 온 지체는 그림자 같구나","reference":"욥기 17:7","category":"$undefined"},{"id":"13269","book":"욥기","book_name":"욥기","chapter":17,"verse":8,"text":"정직자는 이를 인하여 놀라고 무죄자는 사곡한 자를 인하여 분을 내나니","reference":"욥기 17:8","category":"$undefined"},{"id":"13270","book":"욥기","book_name":"욥기","chapter":17,"verse":9,"text":"그러므로 의인은 그 길을 독실히 행하고 손이 깨끗한 자는 점점 힘을 얻느니라 !","reference":"욥기 17:9","category":"$undefined"},{"id":"13271","book":"욥기","book_name":"욥기","chapter":17,"verse":10,"text":"너희는 다 다시 올지니라 내가 너희 중에서 지혜자를 찾을 수 없느니라","reference":"욥기 17:10","category":"$undefined"},{"id":"13272","book":"욥기","book_name":"욥기","chapter":17,"verse":11,"text":"나의 날이 지나갔고 내 경영 내 마음의 사모하는 바가 다 끊어졌구나","reference":"욥기 17:11","category":"$undefined"},{"id":"13273","book":"욥기","book_name":"욥기","chapter":17,"verse":12,"text":"그들은 밤으로 낮을 삼고 빛이 어두운데 가깝다 하는구나","reference":"욥기 17:12","category":"$undefined"},{"id":"13274","book":"욥기","book_name":"욥기","chapter":17,"verse":13,"text":"내 소망이 음부로 내 집을 삼음에 있어서 침상을 흑암에 베풀고","reference":"욥기 17:13","category":"$undefined"},{"id":"13275","book":"욥기","book_name":"욥기","chapter":17,"verse":14,"text":"무덤더러 너는 내 아비라 구더기더러 너는 내 어미, 내 자매라 할진대","reference":"욥기 17:14","category":"$undefined"},{"id":"13276","book":"욥기","book_name":"욥기","chapter":17,"verse":15,"text":"나의 소망이 어디 있으며 나의 소망을 누가 보겠느냐 ?","reference":"욥기 17:15","category":"$undefined"},{"id":"13277","book":"욥기","book_name":"욥기","chapter":17,"verse":16,"text":"흙 속에서 쉴 때에는 소망이 음부 문으로 내려갈 뿐이니라","reference":"욥기 17:16","category":"$undefined"}],"bookSlug":"job"}]
