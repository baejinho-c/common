2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":18,"verses":[{"id":"13278","book":"욥기","book_name":"욥기","chapter":18,"verse":1,"text":"수아 사람 빌닷이 대답하여 가로되","reference":"욥기 18:1","category":"$undefined"},{"id":"13279","book":"욥기","book_name":"욥기","chapter":18,"verse":2,"text":"너희가 어느 때까지 말을 찾겠느냐 깨달으라 그 후에야 우리가 말하리라","reference":"욥기 18:2","category":"$undefined"},{"id":"13280","book":"욥기","book_name":"욥기","chapter":18,"verse":3,"text":"어찌하여 우리를 짐승으로 여기며 부정하게 보느냐 ?","reference":"욥기 18:3","category":"$undefined"},{"id":"13281","book":"욥기","book_name":"욥기","chapter":18,"verse":4,"text":"너 분하여, 스스로 찢는 자야 ! 너를 위하여 땅이 버림을 당하겠느냐 ? 바위가 그 자리에서 옮기겠느냐 ?","reference":"욥기 18:4","category":"$undefined"},{"id":"13282","book":"욥기","book_name":"욥기","chapter":18,"verse":5,"text":"악인의 빛은 꺼지고 그 불꽃은 빛나지 않을 것이요","reference":"욥기 18:5","category":"$undefined"},{"id":"13283","book":"욥기","book_name":"욥기","chapter":18,"verse":6,"text":"그 장막 안의 빛은 어두워지고 그 위의 등불은 꺼질 것이요","reference":"욥기 18:6","category":"$undefined"},{"id":"13284","book":"욥기","book_name":"욥기","chapter":18,"verse":7,"text":"그 강한 걸음이 곤하여지고 그 베푼 꾀에 스스로 빠질 것이니","reference":"욥기 18:7","category":"$undefined"},{"id":"13285","book":"욥기","book_name":"욥기","chapter":18,"verse":8,"text":"이는 그 발이 스스로 그물에 들어가고 얽는 줄을 밟음이며","reference":"욥기 18:8","category":"$undefined"},{"id":"13286","book":"욥기","book_name":"욥기","chapter":18,"verse":9,"text":"그 발뒤꿈치는 창애에 치이고 그 몸은 올무에 얽힐 것이며","reference":"욥기 18:9","category":"$undefined"},{"id":"13287","book":"욥기","book_name":"욥기","chapter":18,"verse":10,"text":"그를 동일 줄이 땅에 숨겼고 그를 빠뜨릴 함정이 길에 베풀렸으며","reference":"욥기 18:10","category":"$undefined"},{"id":"13288","book":"욥기","book_name":"욥기","chapter":18,"verse":11,"text":"무서운 것이 사방에서 그를 놀래고 그 뒤를 쫓아올 것이며","reference":"욥기 18:11","category":"$undefined"},{"id":"13289","book":"욥기","book_name":"욥기","chapter":18,"verse":12,"text":"그 힘은 기근을 인하여 쇠하고 그 곁에는 재앙이 기다릴 것이며","reference":"욥기 18:12","category":"$undefined"},{"id":"13290","book":"욥기","book_name":"욥기","chapter":18,"verse":13,"text":"그의 백체가 먹히리니 곧 사망의 장자가 그 지체를 먹을 것이며","reference":"욥기 18:13","category":"$undefined"},{"id":"13291","book":"욥기","book_name":"욥기","chapter":18,"verse":14,"text":"그가 그 의뢰하던 장막에서 뽑혀서 무서움의 왕에게로 잡혀가고","reference":"욥기 18:14","category":"$undefined"},{"id":"13292","book":"욥기","book_name":"욥기","chapter":18,"verse":15,"text":"그에게 속하지 않은 자가 그 장막에 거하리니 유황이 그 처소에 뿌려질 것이며","reference":"욥기 18:15","category":"$undefined"},{"id":"13293","book":"욥기","book_name":"욥기","chapter":18,"verse":16,"text":"아래서는 그 뿌리가 마르고 위에서는 그 가지가 찍힐 것이며","reference":"욥기 18:16","category":"$undefined"},{"id":"13294","book":"욥기","book_name":"욥기","chapter":18,"verse":17,"text":"그의 기념이 땅에서 없어지고 그의 이름이 거리에서 전함이 없을 것이며","reference":"욥기 18:17","category":"$undefined"},{"id":"13295","book":"욥기","book_name":"욥기","chapter":18,"verse":18,"text":"그는 광명 중에서 흑암으로 몰려 들어가며 세상에서 쫓겨날 것이며","reference":"욥기 18:18","category":"$undefined"},{"id":"13296","book":"욥기","book_name":"욥기","chapter":18,"verse":19,"text":"그는 그 백성 가운데서 아들도 없고 손자도 없을 것이며 그의 거하던 곳에는 한 사람도 남은 자가 없을 것이라","reference":"욥기 18:19","category":"$undefined"},{"id":"13297","book":"욥기","book_name":"욥기","chapter":18,"verse":20,"text":"그의 날을 인하여 뒤에 오는 자가 앞선 자의 두려워 하던 것 같이 놀라리라","reference":"욥기 18:20","category":"$undefined"},{"id":"13298","book":"욥기","book_name":"욥기","chapter":18,"verse":21,"text":"불의한 자의 집이 이러하고 하나님을 알지 못하는 자의 처소도 그러하니라","reference":"욥기 18:21","category":"$undefined"}],"bookSlug":"job"}]
