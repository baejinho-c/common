2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":19,"verses":[{"id":"13299","book":"욥기","book_name":"욥기","chapter":19,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 19:1","category":"$undefined"},{"id":"13300","book":"욥기","book_name":"욥기","chapter":19,"verse":2,"text":"너희가 내 마음을 번뇌케 하며 말로 꺾기를 어느 때까지 하겠느냐 ?","reference":"욥기 19:2","category":"$undefined"},{"id":"13301","book":"욥기","book_name":"욥기","chapter":19,"verse":3,"text":"너희가 열 번이나 나를 꾸짖고 나를 학대하고도 부끄러워 아니하는구나","reference":"욥기 19:3","category":"$undefined"},{"id":"13302","book":"욥기","book_name":"욥기","chapter":19,"verse":4,"text":"내가 과연 허물이 있었다 할지라도 그 허물이 내게만 있는 것이니","reference":"욥기 19:4","category":"$undefined"},{"id":"13303","book":"욥기","book_name":"욥기","chapter":19,"verse":5,"text":"너희가 참으로 나를 향하여 자긍하며 내게 수치될 행위가 있다고 증명하려면 하려니와","reference":"욥기 19:5","category":"$undefined"},{"id":"13304","book":"욥기","book_name":"욥기","chapter":19,"verse":6,"text":"하나님이 나를 굴하게 하시고 자기 그물로 나를 에워싸신 줄은 알아야 할지니라","reference":"욥기 19:6","category":"$undefined"},{"id":"13305","book":"욥기","book_name":"욥기","chapter":19,"verse":7,"text":"내가 포학을 당한다고 부르짖으나 응답이 없고 간구할지라도 신원함이 없구나","reference":"욥기 19:7","category":"$undefined"},{"id":"13306","book":"욥기","book_name":"욥기","chapter":19,"verse":8,"text":"그가 내 길을 막아 지나지 못하게 하시고 내 첩경에 흑암을 두셨으며","reference":"욥기 19:8","category":"$undefined"},{"id":"13307","book":"욥기","book_name":"욥기","chapter":19,"verse":9,"text":"나의 영광을 벗기시며 나의 면류관을 머리에서 취하시고","reference":"욥기 19:9","category":"$undefined"},{"id":"13308","book":"욥기","book_name":"욥기","chapter":19,"verse":10,"text":"사면으로 나를 헐으시니 나는 죽었구나 내 소망을 나무 뽑듯 뽑으시고","reference":"욥기 19:10","category":"$undefined"},{"id":"13309","book":"욥기","book_name":"욥기","chapter":19,"verse":11,"text":"나를 향하여 진노하시고 원수같이 보시는구나","reference":"욥기 19:11","category":"$undefined"},{"id":"13310","book":"욥기","book_name":"욥기","chapter":19,"verse":12,"text":"그 군대가 일제히 나아와서 길을 수축하고 나를 치며 내 장막을 둘러 진 쳤구나","reference":"욥기 19:12","category":"$undefined"},{"id":"13311","book":"욥기","book_name":"욥기","chapter":19,"verse":13,"text":"나의 형제들로 나를 멀리 떠나게 하시니 나를 아는 모든 사람이 내게 외인이 되었구나","reference":"욥기 19:13","category":"$undefined"},{"id":"13312","book":"욥기","book_name":"욥기","chapter":19,"verse":14,"text":"내 친척은 나를 버리며 가까운 친구는 나를 잊었구나","reference":"욥기 19:14","category":"$undefined"},{"id":"13313","book":"욥기","book_name":"욥기","chapter":19,"verse":15,"text":"내 집에 우거한 자와 내 계집종들은 나를 외인으로 여기니 내가 그들 앞에서 타국 사람이 되었구나","reference":"욥기 19:15","category":"$undefined"},{"id":"13314","book":"욥기","book_name":"욥기","chapter":19,"verse":16,"text":"내가 내 종을 불러도 대답지 아니하니 내 입으로 그에게 청하여야 하겠구나","reference":"욥기 19:16","category":"$undefined"},{"id":"13315","book":"욥기","book_name":"욥기","chapter":19,"verse":17,"text":"내 숨을 내 아내가 싫어하며 내 동포들도 혐의하는구나","reference":"욥기 19:17","category":"$undefined"},{"id":"13316","book":"욥기","book_name":"욥기","chapter":19,"verse":18,"text":"어린 아이들이라도 나를 업신여기고 내가 일어나면 나를 조롱하는구나","reference":"욥기 19:18","category":"$undefined"},{"id":"13317","book":"욥기","book_name":"욥기","chapter":19,"verse":19,"text":"나의 가까운 친구들이 나를 미워하며 나의 사랑하는 사람들이 돌이켜 나의 대적이 되었구나","reference":"욥기 19:19","category":"$undefined"},{"id":"13318","book":"욥기","book_name":"욥기","chapter":19,"verse":20,"text":"내 피부와 살이 뼈에 붙었고 남은 것은 겨우 잇꺼풀 뿐이로구나","reference":"욥기 19:20","category":"$undefined"},{"id":"13319","book":"욥기","book_name":"욥기","chapter":19,"verse":21,"text":"나의 친구야 너희는 나를 불쌍히 여기라 나를 불쌍히 여기라 하나님의 손이 나를 치셨구나","reference":"욥기 19:21","category":"$undefined"},{"id":"13320","book":"욥기","book_name":"욥기","chapter":19,"verse":22,"text":"너희가 어찌하여 하나님처럼 나를 핍박하느냐 ? 내 살을 먹고도 부족하냐","reference":"욥기 19:22","category":"$undefined"},{"id":"13321","book":"욥기","book_name":"욥기","chapter":19,"verse":23,"text":"나의 말이 곧 기록되었으면, 책에 씌어졌으면,","reference":"욥기 19:23","category":"$undefined"},{"id":"13322","book":"욥기","book_name":"욥기","chapter":19,"verse":24,"text":"철필과 연으로 영영히 돌에 새겨졌으면 좋겠노라","reference":"욥기 19:24","category":"$undefined"},{"id":"13323","book":"욥기","book_name":"욥기","chapter":19,"verse":25,"text":"내가 알기에는 나의 구속자가 살아 계시니 후일에 그가 땅 위에 서실 것이라","reference":"욥기 19:25","category":"$undefined"},{"id":"13324","book":"욥기","book_name":"욥기","chapter":19,"verse":26,"text":"나의 이 가죽, 이것이 썩은 후에 내가 육체 밖에서 하나님을 보리라","reference":"욥기 19:26","category":"$undefined"},{"id":"13325","book":"욥기","book_name":"욥기","chapter":19,"verse":27,"text":"내가 친히 그를 보리니 내 눈으로 그를 보기를 외인처럼 하지 않을 것이라 내 마음이 초급하구나","reference":"욥기 19:27","category":"$undefined"},{"id":"13326","book":"욥기","book_name":"욥기","chapter":19,"verse":28,"text":"너희가 만일 이르기를 우리가 그를 어떻게 칠꼬 하며 또 이르기를 일의 뿌리가 그에게 있다 할진대","reference":"욥기 19:28","category":"$undefined"},{"id":"13327","book":"욥기","book_name":"욥기","chapter":19,"verse":29,"text":"너희는 칼을 두려워할지니라 분노는 칼의 형벌을 부르나니 너희가 심판이 있는 줄을 알게 되리라","reference":"욥기 19:29","category":"$undefined"}],"bookSlug":"job"}]
