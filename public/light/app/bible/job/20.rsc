2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":20,"verses":[{"id":"13328","book":"욥기","book_name":"욥기","chapter":20,"verse":1,"text":"나아마 사람 소발이 대답하여 가로되","reference":"욥기 20:1","category":"$undefined"},{"id":"13329","book":"욥기","book_name":"욥기","chapter":20,"verse":2,"text":"그러므로 내 생각이 내게 대답하나니 이는 내 중심이 초급함이니라","reference":"욥기 20:2","category":"$undefined"},{"id":"13330","book":"욥기","book_name":"욥기","chapter":20,"verse":3,"text":"내가 나를 부끄럽게 하는 책망을 들었으므로 나의 슬기로운 마음이 내게 대답하는구나","reference":"욥기 20:3","category":"$undefined"},{"id":"13331","book":"욥기","book_name":"욥기","chapter":20,"verse":4,"text":"네가 알지 못하느냐 ? 예로부터 사람이 이 세상에 있어 옴으로","reference":"욥기 20:4","category":"$undefined"},{"id":"13332","book":"욥기","book_name":"욥기","chapter":20,"verse":5,"text":"악인의 이기는 자랑도 잠시요, 사곡한 자의 즐거움도 잠간이니라","reference":"욥기 20:5","category":"$undefined"},{"id":"13333","book":"욥기","book_name":"욥기","chapter":20,"verse":6,"text":"그 높기가 하늘에 닿고 그 머리가 구름에 미칠지라도","reference":"욥기 20:6","category":"$undefined"},{"id":"13334","book":"욥기","book_name":"욥기","chapter":20,"verse":7,"text":"자기의 똥처럼 영원히 망할 것이라 그를 본 자가 이르기를 그가 어디 있느냐 ? 하리라","reference":"욥기 20:7","category":"$undefined"},{"id":"13335","book":"욥기","book_name":"욥기","chapter":20,"verse":8,"text":"그는 꿈 같이 지나가니 다시 찾을 수 없을 것이요 밤에 보이던 환상처럼 쫓겨가리니","reference":"욥기 20:8","category":"$undefined"},{"id":"13336","book":"욥기","book_name":"욥기","chapter":20,"verse":9,"text":"그를 본 눈이 다시 그를 보지 못할 것이요 그의 처소도 다시 그를 보지 못할 것이며","reference":"욥기 20:9","category":"$undefined"},{"id":"13337","book":"욥기","book_name":"욥기","chapter":20,"verse":10,"text":"그의 자녀들이 가난한 자에게 은혜를 구하겠고 그도 얻은 재물을 자기 손으로 도로 줄 것이며","reference":"욥기 20:10","category":"$undefined"},{"id":"13338","book":"욥기","book_name":"욥기","chapter":20,"verse":11,"text":"그 기골이 청년 같이 강장하나 그 기세가 그와 함께 흙에 누우리라","reference":"욥기 20:11","category":"$undefined"},{"id":"13339","book":"욥기","book_name":"욥기","chapter":20,"verse":12,"text":"그는 비록 악을 달게 여겨 혀 밑에 감추며","reference":"욥기 20:12","category":"$undefined"},{"id":"13340","book":"욥기","book_name":"욥기","chapter":20,"verse":13,"text":"아껴서 버리지 아니하고 입에 물고 있을지라도","reference":"욥기 20:13","category":"$undefined"},{"id":"13341","book":"욥기","book_name":"욥기","chapter":20,"verse":14,"text":"그 식물이 창자 속에서 변하며 뱃속에서 독사의 쓸개가 되느니라","reference":"욥기 20:14","category":"$undefined"},{"id":"13342","book":"욥기","book_name":"욥기","chapter":20,"verse":15,"text":"그가 재물을 삼켰을지라도 다시 토할 것은 하나님이 그 배에서 도로 나오게 하심이니","reference":"욥기 20:15","category":"$undefined"},{"id":"13343","book":"욥기","book_name":"욥기","chapter":20,"verse":16,"text":"그가 독사의 독을 빨며 뱀의 혀에 죽을 것이라","reference":"욥기 20:16","category":"$undefined"},{"id":"13344","book":"욥기","book_name":"욥기","chapter":20,"verse":17,"text":"그는 강 곧 꿀과 엉긴 젖이 흐르는 강을 보지 못할 것이요","reference":"욥기 20:17","category":"$undefined"},{"id":"13345","book":"욥기","book_name":"욥기","chapter":20,"verse":18,"text":"수고하여 얻은 것을 도로 주고 삼키지 못할 것이며 매매하여 얻은 재물로 즐거워하지 못하리니","reference":"욥기 20:18","category":"$undefined"},{"id":"13346","book":"욥기","book_name":"욥기","chapter":20,"verse":19,"text":"이는 그가 가난한 자를 학대하고 버림이요 자기가 세우지 않은 집을 빼앗음이니라","reference":"욥기 20:19","category":"$undefined"},{"id":"13347","book":"욥기","book_name":"욥기","chapter":20,"verse":20,"text":"그는 마음에 족한 줄을 알지 못하니 그 기뻐하는 것을 하나도 보존치 못하겠고","reference":"욥기 20:20","category":"$undefined"},{"id":"13348","book":"욥기","book_name":"욥기","chapter":20,"verse":21,"text":"남긴 것이 없이 몰수히 먹으니 그런즉 그 형통함이 오래지 못할 것이라","reference":"욥기 20:21","category":"$undefined"},{"id":"13349","book":"욥기","book_name":"욥기","chapter":20,"verse":22,"text":"풍족할 때에도 곤액이 이르리니 모든 고통하는 자의 손이 그에게 닿으리라","reference":"욥기 20:22","category":"$undefined"},{"id":"13350","book":"욥기","book_name":"욥기","chapter":20,"verse":23,"text":"그가 배를 불리려 할 때에 하나님이 맹렬한 진노를 내리시리니 밥 먹을 때에 그의 위에 비같이 쏟으시리라","reference":"욥기 20:23","category":"$undefined"},{"id":"13351","book":"욥기","book_name":"욥기","chapter":20,"verse":24,"text":"그가 철병기를 피할 때에는 놋활이 쏘아 꿸 것이요","reference":"욥기 20:24","category":"$undefined"},{"id":"13352","book":"욥기","book_name":"욥기","chapter":20,"verse":25,"text":"몸에서 그 살을 빼어 낸즉 번쩍번쩍하는 촉이 그 쓸개에서 나오고 큰 두려움이 그에게 임하느니라","reference":"욥기 20:25","category":"$undefined"},{"id":"13353","book":"욥기","book_name":"욥기","chapter":20,"verse":26,"text":"모든 캄캄한 것이 그의 보물을 위하여 쌓이고 사람이 피우지 않은 불이 그를 멸하며 그 장막에 남은 것을 사르리라","reference":"욥기 20:26","category":"$undefined"},{"id":"13354","book":"욥기","book_name":"욥기","chapter":20,"verse":27,"text":"하늘이 그의 죄악을 드러낼 것이요 땅이 일어나 그를 칠 것인즉","reference":"욥기 20:27","category":"$undefined"},{"id":"13355","book":"욥기","book_name":"욥기","chapter":20,"verse":28,"text":"그 가산이 패하여 하나님의 진노하시는 날에 흘러가리니","reference":"욥기 20:28","category":"$undefined"},{"id":"13356","book":"욥기","book_name":"욥기","chapter":20,"verse":29,"text":"이는 악인이 하나님께 받을 분깃이요 하나님이 그에게 정하신 산업이니라","reference":"욥기 20:29","category":"$undefined"}],"bookSlug":"job"}]
