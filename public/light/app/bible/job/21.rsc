2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":21,"verses":[{"id":"13357","book":"욥기","book_name":"욥기","chapter":21,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 21:1","category":"$undefined"},{"id":"13358","book":"욥기","book_name":"욥기","chapter":21,"verse":2,"text":"너희는 내 말을 자세히 들으라 이것이 너희의 위로가 될 것이니라","reference":"욥기 21:2","category":"$undefined"},{"id":"13359","book":"욥기","book_name":"욥기","chapter":21,"verse":3,"text":"나를 용납하여 말하게 하라 내가 말한 후에 또 조롱할지니라","reference":"욥기 21:3","category":"$undefined"},{"id":"13360","book":"욥기","book_name":"욥기","chapter":21,"verse":4,"text":"나의 원망이 사람을 향하여 하는 것이냐 ? 내가 어찌 초급하지 아니하겠느냐 ?","reference":"욥기 21:4","category":"$undefined"},{"id":"13361","book":"욥기","book_name":"욥기","chapter":21,"verse":5,"text":"너희는 나를 보아라, 놀라라, 손으로 입을 가리우라","reference":"욥기 21:5","category":"$undefined"},{"id":"13362","book":"욥기","book_name":"욥기","chapter":21,"verse":6,"text":"내가 추억하기만 하여도 답답하고 두려움이 내 몸을 잡는구나","reference":"욥기 21:6","category":"$undefined"},{"id":"13363","book":"욥기","book_name":"욥기","chapter":21,"verse":7,"text":"어찌하여 악인이 살고 수를 누리고 세력이 강하냐 ?","reference":"욥기 21:7","category":"$undefined"},{"id":"13364","book":"욥기","book_name":"욥기","chapter":21,"verse":8,"text":"씨가 그들의 앞에서 그들과 함께 굳게 서고 자손이 그들의 목전에서 그러하구나","reference":"욥기 21:8","category":"$undefined"},{"id":"13365","book":"욥기","book_name":"욥기","chapter":21,"verse":9,"text":"그 집이 평안하여 두려움이 없고 하나님의 매가 그 위에 임하지 아니하며","reference":"욥기 21:9","category":"$undefined"},{"id":"13366","book":"욥기","book_name":"욥기","chapter":21,"verse":10,"text":"그 수소는 영락없이 새끼를 배게 하고 그 암소는 새끼를 낳고 낙태하지 않는구나","reference":"욥기 21:10","category":"$undefined"},{"id":"13367","book":"욥기","book_name":"욥기","chapter":21,"verse":11,"text":"그들은 아이들을 내어보냄이 양 떼 같고 그 자녀들은 춤추는구나","reference":"욥기 21:11","category":"$undefined"},{"id":"13368","book":"욥기","book_name":"욥기","chapter":21,"verse":12,"text":"그들이 소고와 수금으로 노래하고 피리 불어 즐기며","reference":"욥기 21:12","category":"$undefined"},{"id":"13369","book":"욥기","book_name":"욥기","chapter":21,"verse":13,"text":"그날을 형통하게 지내다가 경각간에 음부에 내려가느니라","reference":"욥기 21:13","category":"$undefined"},{"id":"13370","book":"욥기","book_name":"욥기","chapter":21,"verse":14,"text":"그러할지라도 그들은 하나님께 말하기를 우리를 떠나소서 우리가 주의 도리 알기를 즐겨하지 아니하나이다","reference":"욥기 21:14","category":"$undefined"},{"id":"13371","book":"욥기","book_name":"욥기","chapter":21,"verse":15,"text":"전능자가 누구기에 우리가 섬기며 우리가 그에게 기도한들 무슨 이익을 얻으랴 하는구나","reference":"욥기 21:15","category":"$undefined"},{"id":"13372","book":"욥기","book_name":"욥기","chapter":21,"verse":16,"text":"그들의 복록이 그들의 손으로 말미암은 것이 아니니라 악인의 계획은 나와 판이하니라","reference":"욥기 21:16","category":"$undefined"},{"id":"13373","book":"욥기","book_name":"욥기","chapter":21,"verse":17,"text":"악인의 등불이 꺼짐이나 재앙이 그들에게 임함이나 하나님이 진노하사 그들을 곤고케 하심이나","reference":"욥기 21:17","category":"$undefined"},{"id":"13374","book":"욥기","book_name":"욥기","chapter":21,"verse":18,"text":"그들이 바람 앞에 검불 같이, 폭풍에 불려가는 겨 같이 되는 일이 몇번이나 있었느냐 ?","reference":"욥기 21:18","category":"$undefined"},{"id":"13375","book":"욥기","book_name":"욥기","chapter":21,"verse":19,"text":"하나님이 그의 죄악을 쌓아 두셨다가 그 자손에게 갚으신다 하거니와 그 몸에 갚으셔서 그로 깨닫게 하셔야 할 것이라","reference":"욥기 21:19","category":"$undefined"},{"id":"13376","book":"욥기","book_name":"욥기","chapter":21,"verse":20,"text":"자기의 멸망을 자기의 눈으로 보게 하시며 전능자의 진노를 마시게 하셔야 할 것이니라","reference":"욥기 21:20","category":"$undefined"},{"id":"13377","book":"욥기","book_name":"욥기","chapter":21,"verse":21,"text":"그의 달 수가 진하면 자기 집에 대하여 무슨 관계가 있겠느냐 ?","reference":"욥기 21:21","category":"$undefined"},{"id":"13378","book":"욥기","book_name":"욥기","chapter":21,"verse":22,"text":"그러나 하나님은 높은 자들을 심판하시나니 누가 능히 하나님께 지식을 가르치겠느냐 ?","reference":"욥기 21:22","category":"$undefined"},{"id":"13379","book":"욥기","book_name":"욥기","chapter":21,"verse":23,"text":"어떤 사람은 죽도록 기운이 충실하여 평강하며 안일하고","reference":"욥기 21:23","category":"$undefined"},{"id":"13380","book":"욥기","book_name":"욥기","chapter":21,"verse":24,"text":"그 그릇에는 젖이 가득하며 그 골수는 윤택하였고","reference":"욥기 21:24","category":"$undefined"},{"id":"13381","book":"욥기","book_name":"욥기","chapter":21,"verse":25,"text":"어떤 사람은 죽도록 마음에 고통하고 복을 맛보지 못하였어도","reference":"욥기 21:25","category":"$undefined"},{"id":"13382","book":"욥기","book_name":"욥기","chapter":21,"verse":26,"text":"이 둘이 일반으로 흙 속에 눕고 그 위에 구더기가 덮이는구나","reference":"욥기 21:26","category":"$undefined"},{"id":"13383","book":"욥기","book_name":"욥기","chapter":21,"verse":27,"text":"내가 너희의 생각을 알고 너희가 나를 해하려는 궤휼도 아노라","reference":"욥기 21:27","category":"$undefined"},{"id":"13384","book":"욥기","book_name":"욥기","chapter":21,"verse":28,"text":"너희의 말이 왕후의 집이 어디 있으며 악인의 거하던 장막이 어디 있느뇨 ? 하는구나","reference":"욥기 21:28","category":"$undefined"},{"id":"13385","book":"욥기","book_name":"욥기","chapter":21,"verse":29,"text":"너희가 길 가는 사람들에게 묻지 아니하였느냐 ? 그들의 증거를 알지 못하느냐 ?","reference":"욥기 21:29","category":"$undefined"},{"id":"13386","book":"욥기","book_name":"욥기","chapter":21,"verse":30,"text":"악인은 남기워서 멸망의 날을 기다리움이 되고 멸망의 날을 맞으러 끌려 나감이 된다 하느니라","reference":"욥기 21:30","category":"$undefined"},{"id":"13387","book":"욥기","book_name":"욥기","chapter":21,"verse":31,"text":"누가 능히 그의 행위를 면박하며 누가 능히 그의 소위를 보응하랴마는","reference":"욥기 21:31","category":"$undefined"},{"id":"13388","book":"욥기","book_name":"욥기","chapter":21,"verse":32,"text":"그를 무덤으로 메어 가고 사람이 그 무덤을 지키리라","reference":"욥기 21:32","category":"$undefined"},{"id":"13389","book":"욥기","book_name":"욥기","chapter":21,"verse":33,"text":"그는 골짜기의 흙덩이를 달게 여기고 그 앞선 자가 무수함 같이 모든 사람이 그 뒤를 좇으리라","reference":"욥기 21:33","category":"$undefined"},{"id":"13390","book":"욥기","book_name":"욥기","chapter":21,"verse":34,"text":"이러한즉 너희의 위로가 헛되지 아니하냐 너희의 대답은 거짓 뿐이니라","reference":"욥기 21:34","category":"$undefined"}],"bookSlug":"job"}]
