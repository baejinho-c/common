2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":22,"verses":[{"id":"13391","book":"욥기","book_name":"욥기","chapter":22,"verse":1,"text":"데만 사람 엘리바스가 대답하여 가로되","reference":"욥기 22:1","category":"$undefined"},{"id":"13392","book":"욥기","book_name":"욥기","chapter":22,"verse":2,"text":"사람이 어찌 하나님께 유익하게 하겠느냐 ? 지혜로운 자도 스스로 유익할 따름이니라","reference":"욥기 22:2","category":"$undefined"},{"id":"13393","book":"욥기","book_name":"욥기","chapter":22,"verse":3,"text":"네가 의로운들 전능자에게 무슨 기쁨이 있겠으며 네 행위가 온전한들 그에게 무슨 이익이 있겠느냐 ?","reference":"욥기 22:3","category":"$undefined"},{"id":"13394","book":"욥기","book_name":"욥기","chapter":22,"verse":4,"text":"하나님이 너를 책망하시며 너를 심문하심이 너의 경외함을 인함이냐","reference":"욥기 22:4","category":"$undefined"},{"id":"13395","book":"욥기","book_name":"욥기","chapter":22,"verse":5,"text":"네 악이 크지 아니하냐 네 죄악이 극하니라","reference":"욥기 22:5","category":"$undefined"},{"id":"13396","book":"욥기","book_name":"욥기","chapter":22,"verse":6,"text":"까닭 없이 형제의 물건을 볼모 잡으며 헐벗은 자의 의복을 벗기며","reference":"욥기 22:6","category":"$undefined"},{"id":"13397","book":"욥기","book_name":"욥기","chapter":22,"verse":7,"text":"갈한 자에게 물을 마시우지 아니하며 주린 자에게 식물을 주지 아니하였구나","reference":"욥기 22:7","category":"$undefined"},{"id":"13398","book":"욥기","book_name":"욥기","chapter":22,"verse":8,"text":"권세 있는 자가 토지를 얻고 존귀한 자가 거기서 사는구나","reference":"욥기 22:8","category":"$undefined"},{"id":"13399","book":"욥기","book_name":"욥기","chapter":22,"verse":9,"text":"네가 과부를 공수로 돌아가게 하며 고아의 팔을 꺾는구나","reference":"욥기 22:9","category":"$undefined"},{"id":"13400","book":"욥기","book_name":"욥기","chapter":22,"verse":10,"text":"이러므로 올무들이 너를 둘러있고 두려움이 홀연히 너를 침범하며","reference":"욥기 22:10","category":"$undefined"},{"id":"13401","book":"욥기","book_name":"욥기","chapter":22,"verse":11,"text":"어두움이 너로 보지 못하게 하고 창수가 너를 덮느니라","reference":"욥기 22:11","category":"$undefined"},{"id":"13402","book":"욥기","book_name":"욥기","chapter":22,"verse":12,"text":"하나님이 높은 하늘에 계시지 아니하냐 ? 보라 ! 별의 높음이 얼마나 높은가","reference":"욥기 22:12","category":"$undefined"},{"id":"13403","book":"욥기","book_name":"욥기","chapter":22,"verse":13,"text":"그러나 네 말은 하나님이 무엇을 아시며 흑암 중에서 어찌 심판하실 수 있으랴","reference":"욥기 22:13","category":"$undefined"},{"id":"13404","book":"욥기","book_name":"욥기","chapter":22,"verse":14,"text":"빽빽한 구름이 그를 가리운즉 그가 보지 못하시고 궁창으로 걸어다니실 뿐이라 하는구나","reference":"욥기 22:14","category":"$undefined"},{"id":"13405","book":"욥기","book_name":"욥기","chapter":22,"verse":15,"text":"네가 악인의 밟던 옛적 길을 지키려느냐 ?","reference":"욥기 22:15","category":"$undefined"},{"id":"13406","book":"욥기","book_name":"욥기","chapter":22,"verse":16,"text":"그들은 때가 이르기 전에 끊어버리웠고 그 터는 하수로 인하여 함몰되었느니라","reference":"욥기 22:16","category":"$undefined"},{"id":"13407","book":"욥기","book_name":"욥기","chapter":22,"verse":17,"text":"그들이 하나님께 말하기를 우리를 떠나소서 하며 또 말하기를 전능자가 우리를 위하여 무엇을 하실 수 있으랴 하였으나","reference":"욥기 22:17","category":"$undefined"},{"id":"13408","book":"욥기","book_name":"욥기","chapter":22,"verse":18,"text":"하나님이 좋은 것으로 그 집에 채우셨느니라 악인의 계획은 나와 판이하니라","reference":"욥기 22:18","category":"$undefined"},{"id":"13409","book":"욥기","book_name":"욥기","chapter":22,"verse":19,"text":"의인은 보고 기뻐하고 무죄자는 그들을 비웃기를","reference":"욥기 22:19","category":"$undefined"},{"id":"13410","book":"욥기","book_name":"욥기","chapter":22,"verse":20,"text":"우리의 대적이 끊어졌고 그 남은 것이 불사른 바 되었다 하느니라","reference":"욥기 22:20","category":"$undefined"},{"id":"13411","book":"욥기","book_name":"욥기","chapter":22,"verse":21,"text":"너는 하나님과 화목하고 평안하라 ! 그리하면 복이 네게 임하리라 !","reference":"욥기 22:21","category":"$undefined"},{"id":"13412","book":"욥기","book_name":"욥기","chapter":22,"verse":22,"text":"청컨대 너는 그 입에서 교훈을 받고 그 말씀을 네 마음에 두라","reference":"욥기 22:22","category":"$undefined"},{"id":"13413","book":"욥기","book_name":"욥기","chapter":22,"verse":23,"text":"네가 만일 전능자에게로 돌아가고 또 네 장막에서 불의를 멀리 버리면 다시 흥하리라","reference":"욥기 22:23","category":"$undefined"},{"id":"13414","book":"욥기","book_name":"욥기","chapter":22,"verse":24,"text":"네 보배를 진토에 버리고 오빌의 금을 강 가의 돌에 버리라","reference":"욥기 22:24","category":"$undefined"},{"id":"13415","book":"욥기","book_name":"욥기","chapter":22,"verse":25,"text":"그리하면 전능자가 네 보배가 되시며 네게 귀한 은이 되시리니","reference":"욥기 22:25","category":"$undefined"},{"id":"13416","book":"욥기","book_name":"욥기","chapter":22,"verse":26,"text":"이에 네가 전능자를 기뻐하여 하나님께로 얼굴을 들 것이라","reference":"욥기 22:26","category":"$undefined"},{"id":"13417","book":"욥기","book_name":"욥기","chapter":22,"verse":27,"text":"너는 그에게 기도하겠고 그는 들으실 것이며 너의 서원한 것을 네가 갚으리라","reference":"욥기 22:27","category":"$undefined"},{"id":"13418","book":"욥기","book_name":"욥기","chapter":22,"verse":28,"text":"네가 무엇을 경영하면 이루어질 것이요 네 길에 빛이 비취리라","reference":"욥기 22:28","category":"$undefined"},{"id":"13419","book":"욥기","book_name":"욥기","chapter":22,"verse":29,"text":"네가 낮춤을 받거든 높아지리라고 말하라 하나님은 겸손한 자를 구원하시느니라","reference":"욥기 22:29","category":"$undefined"},{"id":"13420","book":"욥기","book_name":"욥기","chapter":22,"verse":30,"text":"무죄한 자가 아니라도 건지시리니 네 손이 깨끗함을 인하여 그런 자가 건지심을 입으리라","reference":"욥기 22:30","category":"$undefined"}],"bookSlug":"job"}]
