2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":24,"verses":[{"id":"13438","book":"욥기","book_name":"욥기","chapter":24,"verse":1,"text":"어찌하여 전능자가 시기를 정하지 아니하셨는고 어찌하여 그를 아는 자들이 그의 날을 보지 못하는고","reference":"욥기 24:1","category":"$undefined"},{"id":"13439","book":"욥기","book_name":"욥기","chapter":24,"verse":2,"text":"어떤 사람은 지계표를 옮기며 양떼를 빼앗아 기르며","reference":"욥기 24:2","category":"$undefined"},{"id":"13440","book":"욥기","book_name":"욥기","chapter":24,"verse":3,"text":"고아의 나귀를 몰아 가며 과부의 소를 볼모 잡으며","reference":"욥기 24:3","category":"$undefined"},{"id":"13441","book":"욥기","book_name":"욥기","chapter":24,"verse":4,"text":"빈궁한 자를 길에서 몰아 내나니 세상에 가난한 자가 다 스스로 숨는구나","reference":"욥기 24:4","category":"$undefined"},{"id":"13442","book":"욥기","book_name":"욥기","chapter":24,"verse":5,"text":"그들은 거친 땅의 들나귀 같아서 나가서 일하며 먹을 것을 부지런히 구하니 광야가 그 자식을 위하여 그에게 식물을 내는구나","reference":"욥기 24:5","category":"$undefined"},{"id":"13443","book":"욥기","book_name":"욥기","chapter":24,"verse":6,"text":"밭에서 남의 곡식을 베며 악인의 남겨 둔 포도를 따며","reference":"욥기 24:6","category":"$undefined"},{"id":"13444","book":"욥기","book_name":"욥기","chapter":24,"verse":7,"text":"의복이 없어 벗은 몸으로 밤을 지내며 추위에 덮을 것이 없으며","reference":"욥기 24:7","category":"$undefined"},{"id":"13445","book":"욥기","book_name":"욥기","chapter":24,"verse":8,"text":"산 중 소나기에 젖으며 가리울 것이 없어 바위를 안고 있느니라","reference":"욥기 24:8","category":"$undefined"},{"id":"13446","book":"욥기","book_name":"욥기","chapter":24,"verse":9,"text":"어떤 사람은 고아를 어미 품에서 빼앗으며 가난한 자의 옷을 볼모 잡으므로","reference":"욥기 24:9","category":"$undefined"},{"id":"13447","book":"욥기","book_name":"욥기","chapter":24,"verse":10,"text":"그들이 옷이 없어 벌거벗고 다니며 주리면서 곡식 단을 메며","reference":"욥기 24:10","category":"$undefined"},{"id":"13448","book":"욥기","book_name":"욥기","chapter":24,"verse":11,"text":"그 사람의 담 안에서 기름을 짜며 목말라 하면서 술 틀을 밟느니라","reference":"욥기 24:11","category":"$undefined"},{"id":"13449","book":"욥기","book_name":"욥기","chapter":24,"verse":12,"text":"인구 많은 성 중에서 사람들이 신음하며 상한 자가 부르짖으나 하나님이 그 불의를 보지 아니하시느니라","reference":"욥기 24:12","category":"$undefined"},{"id":"13450","book":"욥기","book_name":"욥기","chapter":24,"verse":13,"text":"또 광명을 배반하는 사람들은 이러하니 그들은 광명의 길을 알지 못하며 그 첩경에 머물지 아니하는 자라","reference":"욥기 24:13","category":"$undefined"},{"id":"13451","book":"욥기","book_name":"욥기","chapter":24,"verse":14,"text":"사람을 죽이는 자는 새벽에 일어나서 가난한 자나 빈궁한 자를 죽이고 밤에는 도적 같이 되며","reference":"욥기 24:14","category":"$undefined"},{"id":"13452","book":"욥기","book_name":"욥기","chapter":24,"verse":15,"text":"간음하는 자의 눈은 저물기를 바라며 아무 눈도 나를 보지 못하리라 하고 얼굴을 변장하며","reference":"욥기 24:15","category":"$undefined"},{"id":"13453","book":"욥기","book_name":"욥기","chapter":24,"verse":16,"text":"밤에 집을 뚫는 자는 낮에는 문을 닫고 있은즉 광명을 알지 못하나니","reference":"욥기 24:16","category":"$undefined"},{"id":"13454","book":"욥기","book_name":"욥기","chapter":24,"verse":17,"text":"그들은 다 아침을 흑암 같이 여기니 흑암의 두려움을 앎이니라","reference":"욥기 24:17","category":"$undefined"},{"id":"13455","book":"욥기","book_name":"욥기","chapter":24,"verse":18,"text":"그들은 물 위에 빨리 흘러가고 그 산업은 세상에서 저주를 받나니 그들이 다시는 포도원 길로 행치 못할 것이라","reference":"욥기 24:18","category":"$undefined"},{"id":"13456","book":"욥기","book_name":"욥기","chapter":24,"verse":19,"text":"가뭄과 더위가 눈 녹은 물을 곧 말리나니 음부가 범죄자에게도 그와 같은 것인즉","reference":"욥기 24:19","category":"$undefined"},{"id":"13457","book":"욥기","book_name":"욥기","chapter":24,"verse":20,"text":"태가 그를 잊어버리고 구더기가 그를 달게 먹을 것이라 그는 기억함을 다시 얻지 못하나니 불의가 나무처럼 꺾이리라","reference":"욥기 24:20","category":"$undefined"},{"id":"13458","book":"욥기","book_name":"욥기","chapter":24,"verse":21,"text":"그는 잉태치 못하므로 해산치 못한 여인을 학대하며 과부를 선대치 아니하는 자니라","reference":"욥기 24:21","category":"$undefined"},{"id":"13459","book":"욥기","book_name":"욥기","chapter":24,"verse":22,"text":"그러나 하나님이 그 권능으로 강한 자들을 보존시키시니 살기를 바라지 못할 자도 일어나는구나","reference":"욥기 24:22","category":"$undefined"},{"id":"13460","book":"욥기","book_name":"욥기","chapter":24,"verse":23,"text":"하나님이 그들을 호위하사 평안케 하시나 그 눈은 그들의 길에 있구나","reference":"욥기 24:23","category":"$undefined"},{"id":"13461","book":"욥기","book_name":"욥기","chapter":24,"verse":24,"text":"그들은 높아져도 잠시간에 없어지나니 낮아져서 범인처럼 제함을 당하고 곡식 이삭같이 베임을 입느니라","reference":"욥기 24:24","category":"$undefined"},{"id":"13462","book":"욥기","book_name":"욥기","chapter":24,"verse":25,"text":"가령 그렇지 않을지라도 능히 내 말을 거짓되다 지적하거나 내 말이 헛되다 변박할 자 누구랴","reference":"욥기 24:25","category":"$undefined"}],"bookSlug":"job"}]
