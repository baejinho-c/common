2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":27,"verses":[{"id":"13483","book":"욥기","book_name":"욥기","chapter":27,"verse":1,"text":"욥이 또 비사를 들어 가로되","reference":"욥기 27:1","category":"$undefined"},{"id":"13484","book":"욥기","book_name":"욥기","chapter":27,"verse":2,"text":"나의 의를 빼앗으신 하나님 ! 나의 영혼을 괴롭게 하신 전능자의 사심을 가리켜 맹세하노니","reference":"욥기 27:2","category":"$undefined"},{"id":"13485","book":"욥기","book_name":"욥기","chapter":27,"verse":3,"text":"(나의 생명이 아직 내 속에 완전히 있고 하나님의 기운이 오히려 내 코에 있느니라)","reference":"욥기 27:3","category":"$undefined"},{"id":"13486","book":"욥기","book_name":"욥기","chapter":27,"verse":4,"text":"결코 내 입술이 불의를 말하지 아니하며 내 혀가 궤휼을 발하지 아니하리라","reference":"욥기 27:4","category":"$undefined"},{"id":"13487","book":"욥기","book_name":"욥기","chapter":27,"verse":5,"text":"나는 단정코 너희를 옳다 하지 아니하겠고 죽기 전에는 나의 순전함을 버리지 않을 것이라","reference":"욥기 27:5","category":"$undefined"},{"id":"13488","book":"욥기","book_name":"욥기","chapter":27,"verse":6,"text":"내가 내 의를 굳게 잡고 놓지 아니하리니 일평생 내 마음이 나를 책망치 아니하리라","reference":"욥기 27:6","category":"$undefined"},{"id":"13489","book":"욥기","book_name":"욥기","chapter":27,"verse":7,"text":"나의 대적은 악인 같이 되고 일어나 나를 치는 자는 불의한 자같이 되기를 원하노라","reference":"욥기 27:7","category":"$undefined"},{"id":"13490","book":"욥기","book_name":"욥기","chapter":27,"verse":8,"text":"사곡한 자가 이익을 얻었으나 하나님이 그 영혼을 취하실 때에는 무슨 소망이 있으랴","reference":"욥기 27:8","category":"$undefined"},{"id":"13491","book":"욥기","book_name":"욥기","chapter":27,"verse":9,"text":"환난이 그에게 임할 때에 하나님이 어찌 그 부르짖음을 들으시랴","reference":"욥기 27:9","category":"$undefined"},{"id":"13492","book":"욥기","book_name":"욥기","chapter":27,"verse":10,"text":"그가 어찌 전능자를 기뻐하겠느냐 항상 하나님께 불러 아뢰겠느냐 ?","reference":"욥기 27:10","category":"$undefined"},{"id":"13493","book":"욥기","book_name":"욥기","chapter":27,"verse":11,"text":"하나님의 하시는 일을 내가 너희에게 가르칠 것이요 전능자의 뜻을 내가 숨기지 아니하리라","reference":"욥기 27:11","category":"$undefined"},{"id":"13494","book":"욥기","book_name":"욥기","chapter":27,"verse":12,"text":"너희가 다 이것을 보았거늘 어찌하여 아주 허탄한 사람이 되었는고","reference":"욥기 27:12","category":"$undefined"},{"id":"13495","book":"욥기","book_name":"욥기","chapter":27,"verse":13,"text":"악인이 하나님께 얻을 분깃, 강포자가 전능자에게 받을 산업은 이것이라","reference":"욥기 27:13","category":"$undefined"},{"id":"13496","book":"욥기","book_name":"욥기","chapter":27,"verse":14,"text":"그 자손이 번성하여도 칼을 위함이요 그 후예는 식물에 배부르지 못할 것이며","reference":"욥기 27:14","category":"$undefined"},{"id":"13497","book":"욥기","book_name":"욥기","chapter":27,"verse":15,"text":"그 남은 자는 염병으로 묻히리니 그의 과부들이 울지 못할 것이며","reference":"욥기 27:15","category":"$undefined"},{"id":"13498","book":"욥기","book_name":"욥기","chapter":27,"verse":16,"text":"그가 비록 은을 티끌 같이 쌓고 의복을 진흙 같이 예비할지라도","reference":"욥기 27:16","category":"$undefined"},{"id":"13499","book":"욥기","book_name":"욥기","chapter":27,"verse":17,"text":"그 예비한 것을 의인이 입을 것이요 그 은은 무죄자가 나눌 것이며","reference":"욥기 27:17","category":"$undefined"},{"id":"13500","book":"욥기","book_name":"욥기","chapter":27,"verse":18,"text":"그 지은 집은 좀의 집 같고 상직군의 초막 같을 것이며","reference":"욥기 27:18","category":"$undefined"},{"id":"13501","book":"욥기","book_name":"욥기","chapter":27,"verse":19,"text":"부자로 누우나 그 조상에게로 돌아가지 못할 것이요 눈을 뜬즉 없어졌으리라","reference":"욥기 27:19","category":"$undefined"},{"id":"13502","book":"욥기","book_name":"욥기","chapter":27,"verse":20,"text":"두려움이 물 같이 그를 따라 미칠 것이요 폭풍이 밤에 그를 빼앗아갈 것이며","reference":"욥기 27:20","category":"$undefined"},{"id":"13503","book":"욥기","book_name":"욥기","chapter":27,"verse":21,"text":"동풍이 그를 날려 보내며 그 처소에서 몰아 내리라","reference":"욥기 27:21","category":"$undefined"},{"id":"13504","book":"욥기","book_name":"욥기","chapter":27,"verse":22,"text":"하나님이 그를 아끼지 아니하시고 쏘시나니 그가 그 손에서 피하려 하여도 못할 것이라","reference":"욥기 27:22","category":"$undefined"},{"id":"13505","book":"욥기","book_name":"욥기","chapter":27,"verse":23,"text":"사람들이 박장하며 비소하고 그 처소에서 몰아내리라","reference":"욥기 27:23","category":"$undefined"}],"bookSlug":"job"}]
