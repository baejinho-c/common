2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":28,"verses":[{"id":"13506","book":"욥기","book_name":"욥기","chapter":28,"verse":1,"text":"은은 나는 광이 있고 연단하는 금은 나는 곳이 있으며","reference":"욥기 28:1","category":"$undefined"},{"id":"13507","book":"욥기","book_name":"욥기","chapter":28,"verse":2,"text":"철은 흙에서 취하고 동은 돌에서 녹여 얻느니라","reference":"욥기 28:2","category":"$undefined"},{"id":"13508","book":"욥기","book_name":"욥기","chapter":28,"verse":3,"text":"사람이 흑암을 파하고 끝까지 궁구하여 음예와 유암 중의 광석을 구하되","reference":"욥기 28:3","category":"$undefined"},{"id":"13509","book":"욥기","book_name":"욥기","chapter":28,"verse":4,"text":"사람 사는 곳에서 멀리 떠나 구멍을 깊이 뚫고 발이 땅에 닿지 않게 달려 내리니 멀리 사람과 격절되고 흔들흔들 하느니라","reference":"욥기 28:4","category":"$undefined"},{"id":"13510","book":"욥기","book_name":"욥기","chapter":28,"verse":5,"text":"지면은 식물을 내나 지하는 불로 뒤집는 것 같고","reference":"욥기 28:5","category":"$undefined"},{"id":"13511","book":"욥기","book_name":"욥기","chapter":28,"verse":6,"text":"그 돌 가운데에는 남보석이 있고 사금도 있으며","reference":"욥기 28:6","category":"$undefined"},{"id":"13512","book":"욥기","book_name":"욥기","chapter":28,"verse":7,"text":"그 길은 솔개도 알지 못하고 매의 눈도 보지 못하며","reference":"욥기 28:7","category":"$undefined"},{"id":"13513","book":"욥기","book_name":"욥기","chapter":28,"verse":8,"text":"위엄스러운 짐승도 밟지 못하였고 사나운 사자도 그리로 지나가지 못하였느니라","reference":"욥기 28:8","category":"$undefined"},{"id":"13514","book":"욥기","book_name":"욥기","chapter":28,"verse":9,"text":"사람이 굳은 바위에 손을 대고 산을 뿌리까지 무너뜨리며","reference":"욥기 28:9","category":"$undefined"},{"id":"13515","book":"욥기","book_name":"욥기","chapter":28,"verse":10,"text":"돌 가운데로 도랑을 파서 각종 보물을 눈으로 발견하고","reference":"욥기 28:10","category":"$undefined"},{"id":"13516","book":"욥기","book_name":"욥기","chapter":28,"verse":11,"text":"시냇물을 막아 스미지 않게 하고 감취었던 것을 밝은 데로 내느니라","reference":"욥기 28:11","category":"$undefined"},{"id":"13517","book":"욥기","book_name":"욥기","chapter":28,"verse":12,"text":"그러나 지혜는 어디서 얻으며 명철의 곳은 어디인고","reference":"욥기 28:12","category":"$undefined"},{"id":"13518","book":"욥기","book_name":"욥기","chapter":28,"verse":13,"text":"그 값을 사람이 알지 못하나니 사람 사는 땅에서 찾을 수 없구나","reference":"욥기 28:13","category":"$undefined"},{"id":"13519","book":"욥기","book_name":"욥기","chapter":28,"verse":14,"text":"깊은 물이 이르기를 내 속에 있지 아니하다 하며 바다가 이르기를 나와 함께 있지 아니하다 하느니라","reference":"욥기 28:14","category":"$undefined"},{"id":"13520","book":"욥기","book_name":"욥기","chapter":28,"verse":15,"text":"정금으로도 바꿀 수 없고 은을 달아도 그 값을 당치 못하리니","reference":"욥기 28:15","category":"$undefined"},{"id":"13521","book":"욥기","book_name":"욥기","chapter":28,"verse":16,"text":"오빌의 금이나 귀한 수마노나 남보석으로도 그 값을 당치 못하겠고","reference":"욥기 28:16","category":"$undefined"},{"id":"13522","book":"욥기","book_name":"욥기","chapter":28,"verse":17,"text":"황금이나 유리라도 비교할 수 없고 정금 장식으로도 바꿀 수 없으며","reference":"욥기 28:17","category":"$undefined"},{"id":"13523","book":"욥기","book_name":"욥기","chapter":28,"verse":18,"text":"산호나 수정으로도 말할 수 없나니 지혜의 값은 홍보석보다 귀하구나","reference":"욥기 28:18","category":"$undefined"},{"id":"13524","book":"욥기","book_name":"욥기","chapter":28,"verse":19,"text":"구스의 황옥으로도 비교할 수 없고 순금으로도 그 값을 측량하지 못하리니","reference":"욥기 28:19","category":"$undefined"},{"id":"13525","book":"욥기","book_name":"욥기","chapter":28,"verse":20,"text":"그런즉 지혜는 어디서 오며 명철의 곳은 어디인고","reference":"욥기 28:20","category":"$undefined"},{"id":"13526","book":"욥기","book_name":"욥기","chapter":28,"verse":21,"text":"모든 생물의 눈에 숨겨졌고 공중의 새에게 가리워졌으며","reference":"욥기 28:21","category":"$undefined"},{"id":"13527","book":"욥기","book_name":"욥기","chapter":28,"verse":22,"text":"멸망과 사망도 이르기를 우리가 귀로 그 소문은 들었다 하느니라","reference":"욥기 28:22","category":"$undefined"},{"id":"13528","book":"욥기","book_name":"욥기","chapter":28,"verse":23,"text":"하나님이 그 길을 깨달으시며 있는 곳을 아시나니","reference":"욥기 28:23","category":"$undefined"},{"id":"13529","book":"욥기","book_name":"욥기","chapter":28,"verse":24,"text":"이는 그가 땅 끝까지 감찰하시며 온 천하를 두루 보시며","reference":"욥기 28:24","category":"$undefined"},{"id":"13530","book":"욥기","book_name":"욥기","chapter":28,"verse":25,"text":"바람의 경중을 정하시며 물을 되어 그 분량을 정하시며","reference":"욥기 28:25","category":"$undefined"},{"id":"13531","book":"욥기","book_name":"욥기","chapter":28,"verse":26,"text":"비를 위하여 명령하시고 우뢰의 번개를 위하여 길을 정하셨음이라","reference":"욥기 28:26","category":"$undefined"},{"id":"13532","book":"욥기","book_name":"욥기","chapter":28,"verse":27,"text":"그 때에 지혜를 보시고 선포하시며 굳게 세우시며 궁구하셨고","reference":"욥기 28:27","category":"$undefined"},{"id":"13533","book":"욥기","book_name":"욥기","chapter":28,"verse":28,"text":"또 사람에게 이르시기를 주를 경외함이 곧 지혜요, 악을 떠남이 명철이라 ! 하셨느니라","reference":"욥기 28:28","category":"$undefined"}],"bookSlug":"job"}]
