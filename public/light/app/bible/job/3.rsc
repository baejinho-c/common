2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":3,"verses":[{"id":"12906","book":"욥기","book_name":"욥기","chapter":3,"verse":1,"text":"그 후에 욥이 입을 열어 자기의 생일을 저주하니라","reference":"욥기 3:1","category":"$undefined"},{"id":"12907","book":"욥기","book_name":"욥기","chapter":3,"verse":2,"text":"욥이 말을 내어 가로되","reference":"욥기 3:2","category":"$undefined"},{"id":"12908","book":"욥기","book_name":"욥기","chapter":3,"verse":3,"text":"나의 난 날이 멸망하였었더라면, 남아를 배었다 하던 그 밤도 그러하였었더라면,","reference":"욥기 3:3","category":"$undefined"},{"id":"12909","book":"욥기","book_name":"욥기","chapter":3,"verse":4,"text":"그 날이 캄캄하였었더라면, 하나님이 위에서 돌아보지 마셨더라면, 빛도 그 날을 비취지 말았었더라면,","reference":"욥기 3:4","category":"$undefined"},{"id":"12910","book":"욥기","book_name":"욥기","chapter":3,"verse":5,"text":"유암과 사망의 그늘이 그 날을 자기 것이라 주장하였었더라면, 구름이 그 위에 덮였었더라면, 낮을 캄캄하게 하는 것이 그 날을 두렵게 하였었더라면","reference":"욥기 3:5","category":"$undefined"},{"id":"12911","book":"욥기","book_name":"욥기","chapter":3,"verse":6,"text":"그 밤이 심한 어두움에 잡혔었더라면, 해의 날 수 가운데 기쁨이 되지 말았었더라면, 달의 수에 들지 말았었더라면,","reference":"욥기 3:6","category":"$undefined"},{"id":"12912","book":"욥기","book_name":"욥기","chapter":3,"verse":7,"text":"그 밤이 적막하였었더라면, 그 가운데서 즐거운 소리가 일어나지 말았었더라면,","reference":"욥기 3:7","category":"$undefined"},{"id":"12913","book":"욥기","book_name":"욥기","chapter":3,"verse":8,"text":"날을 저주하는 자 곧 큰 악어를 격동시키기에 익숙한 자가 그 밤을 저주하였었더라면,","reference":"욥기 3:8","category":"$undefined"},{"id":"12914","book":"욥기","book_name":"욥기","chapter":3,"verse":9,"text":"그 밤에 새벽별들이 어두웠었더라면, 그 밤이 광명을 바랄지라도 얻지 못하며 동틈을 보지 못하였었더라면 좋았을 것을,","reference":"욥기 3:9","category":"$undefined"},{"id":"12915","book":"욥기","book_name":"욥기","chapter":3,"verse":10,"text":"이는 내 모태의 문을 닫지 아니하였고 내 눈으로 환난을 보지 않도록 하지 아니하였음이로구나","reference":"욥기 3:10","category":"$undefined"},{"id":"12916","book":"욥기","book_name":"욥기","chapter":3,"verse":11,"text":"어찌하여 내가 태에서 죽어 나오지 아니하였었던가 어찌하여 내 어미가 낳을 때에 내가 숨지지 아니하였던가","reference":"욥기 3:11","category":"$undefined"},{"id":"12917","book":"욥기","book_name":"욥기","chapter":3,"verse":12,"text":"어찌하여 무릎이 나를 받았던가 어찌하여 유방이 나로 빨게 하였던가","reference":"욥기 3:12","category":"$undefined"},{"id":"12918","book":"욥기","book_name":"욥기","chapter":3,"verse":13,"text":"그렇지 아니하였던들 이제는 내가 평안히 누워서 자고 쉬었을 것이니","reference":"욥기 3:13","category":"$undefined"},{"id":"12919","book":"욥기","book_name":"욥기","chapter":3,"verse":14,"text":"자기를 위하여 거친 터를 수축한 세상 임금들과 의사들과 함께 있었을 것이요","reference":"욥기 3:14","category":"$undefined"},{"id":"12920","book":"욥기","book_name":"욥기","chapter":3,"verse":15,"text":"혹시 금을 가지며 은으로 집에 채운 목백들과 함께 있었을 것이며","reference":"욥기 3:15","category":"$undefined"},{"id":"12921","book":"욥기","book_name":"욥기","chapter":3,"verse":16,"text":"또 부지중에 낙태한 아이 같아서 세상에 있지 않았겠고 빛을 보지 못한 아이들 같았었을 것이라","reference":"욥기 3:16","category":"$undefined"},{"id":"12922","book":"욥기","book_name":"욥기","chapter":3,"verse":17,"text":"거기서는 악한 자가 소요를 그치며 거기서는 곤비한 자가 평강을 얻으며","reference":"욥기 3:17","category":"$undefined"},{"id":"12923","book":"욥기","book_name":"욥기","chapter":3,"verse":18,"text":"거기서는 갇힌 자가 다 함께 평안히 있어 감독자의 소리를 듣지 아니하며","reference":"욥기 3:18","category":"$undefined"},{"id":"12924","book":"욥기","book_name":"욥기","chapter":3,"verse":19,"text":"거기서는 작은 자나 큰 자나 일반으로 있고 종이 상전에게서 놓이느니라","reference":"욥기 3:19","category":"$undefined"},{"id":"12925","book":"욥기","book_name":"욥기","chapter":3,"verse":20,"text":"어찌하여 곤고한 자에게 빛을 주셨으며 마음이 번뇌한 자에게 생명을 주셨는고","reference":"욥기 3:20","category":"$undefined"},{"id":"12926","book":"욥기","book_name":"욥기","chapter":3,"verse":21,"text":"이러한 자는 죽기를 바라도 오지 아니하니 그것을 구하기를 땅을 파고 숨긴 보배를 찾음보다 더하다가","reference":"욥기 3:21","category":"$undefined"},{"id":"12927","book":"욥기","book_name":"욥기","chapter":3,"verse":22,"text":"무덤을 찾아 얻으면 심히 기뻐하고 즐거워하나니","reference":"욥기 3:22","category":"$undefined"},{"id":"12928","book":"욥기","book_name":"욥기","chapter":3,"verse":23,"text":"하나님에게 둘러싸여 길이 아득한 사람에게 어찌하여 빛을 주셨는고","reference":"욥기 3:23","category":"$undefined"},{"id":"12929","book":"욥기","book_name":"욥기","chapter":3,"verse":24,"text":"나는 먹기 전에 탄식이 나며 나의 앓는 소리는 물이 쏟아지는 것 같구나","reference":"욥기 3:24","category":"$undefined"},{"id":"12930","book":"욥기","book_name":"욥기","chapter":3,"verse":25,"text":"나의 두려워하는 그것이 내게 임하고 나의 무서워하는 그것이 내 몸에 미쳤구나","reference":"욥기 3:25","category":"$undefined"},{"id":"12931","book":"욥기","book_name":"욥기","chapter":3,"verse":26,"text":"평강도 없고, 안온도 없고, 안식도 없고, 고난만 임하였구나","reference":"욥기 3:26","category":"$undefined"}],"bookSlug":"job"}]
