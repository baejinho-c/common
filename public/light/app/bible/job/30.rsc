2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":30,"verses":[{"id":"13559","book":"욥기","book_name":"욥기","chapter":30,"verse":1,"text":"그러나 이제는 나보다 젊은 자들이 나를 기롱하는구나 그들의 아비들은 나의 보기에 나의 양떼 지키는 개 중에도 둘만하지 못한 자니라","reference":"욥기 30:1","category":"$undefined"},{"id":"13560","book":"욥기","book_name":"욥기","chapter":30,"verse":2,"text":"그들은 장년의 기력이 쇠한 자니 그 손의 힘이 내게 무엇이 유익하랴","reference":"욥기 30:2","category":"$undefined"},{"id":"13561","book":"욥기","book_name":"욥기","chapter":30,"verse":3,"text":"그들은 곧 궁핍과 기근으로 파리하매 캄캄하고 거친 들에서 마른 흙을 씹으며","reference":"욥기 30:3","category":"$undefined"},{"id":"13562","book":"욥기","book_name":"욥기","chapter":30,"verse":4,"text":"떨기나무 가운데서 짠 나물도 꺾으며 대싸리 뿌리로 식물을 삼느니라","reference":"욥기 30:4","category":"$undefined"},{"id":"13563","book":"욥기","book_name":"욥기","chapter":30,"verse":5,"text":"무리는 도적을 외침 같이 그들에게 소리지름으로 그들은 사람 가운데서 쫓겨나서","reference":"욥기 30:5","category":"$undefined"},{"id":"13564","book":"욥기","book_name":"욥기","chapter":30,"verse":6,"text":"침침한 골짜기와 구덩이와 바위 구멍에서 살며","reference":"욥기 30:6","category":"$undefined"},{"id":"13565","book":"욥기","book_name":"욥기","chapter":30,"verse":7,"text":"떨기나무 가운데서 나귀처럼 부르짖으며 가시나무 아래 모여 있느니라","reference":"욥기 30:7","category":"$undefined"},{"id":"13566","book":"욥기","book_name":"욥기","chapter":30,"verse":8,"text":"그들은 본래 미련한 자의 자식이요 비천한 자의 자식으로서 고토에서 쫓겨난 자니라","reference":"욥기 30:8","category":"$undefined"},{"id":"13567","book":"욥기","book_name":"욥기","chapter":30,"verse":9,"text":"이제는 내가 그들의 노래가 되며 그들의 조롱거리가 되었고","reference":"욥기 30:9","category":"$undefined"},{"id":"13568","book":"욥기","book_name":"욥기","chapter":30,"verse":10,"text":"그들은 나를 미워하여 멀리하고 내 얼굴에 침 뱉기를 주저하지 아니하나니","reference":"욥기 30:10","category":"$undefined"},{"id":"13569","book":"욥기","book_name":"욥기","chapter":30,"verse":11,"text":"이는 하나님이 내 줄을 늘어지게 하시고 나를 곤고케 하시매 무리가 내 앞에서 굴레를 벗었음이니라","reference":"욥기 30:11","category":"$undefined"},{"id":"13570","book":"욥기","book_name":"욥기","chapter":30,"verse":12,"text":"그 낮은 무리가 내 우편에서 일어나 내 발을 밀뜨리고 나를 대적하여 멸망시킬 길을 쌓으며","reference":"욥기 30:12","category":"$undefined"},{"id":"13571","book":"욥기","book_name":"욥기","chapter":30,"verse":13,"text":"도울 자 없는 그들이 내 길을 헐고 내 재앙을 재촉하는구나","reference":"욥기 30:13","category":"$undefined"},{"id":"13572","book":"욥기","book_name":"욥기","chapter":30,"verse":14,"text":"성을 크게 파괴하고 그 파괴한 가운데로 몰려 들어 오는것 같이 그들이 내게로 달려드니","reference":"욥기 30:14","category":"$undefined"},{"id":"13573","book":"욥기","book_name":"욥기","chapter":30,"verse":15,"text":"놀람이 내게 임하는구나 그들이 내 영광을 바람 같이 모니 내 복록이 구름 같이 지나갔구나","reference":"욥기 30:15","category":"$undefined"},{"id":"13574","book":"욥기","book_name":"욥기","chapter":30,"verse":16,"text":"이제는 내 마음이 내 속에서 녹으니 환난날이 나를 잡음이라","reference":"욥기 30:16","category":"$undefined"},{"id":"13575","book":"욥기","book_name":"욥기","chapter":30,"verse":17,"text":"밤이 되면 내 뼈가 쑤시니 나의 몸에 아픔이 쉬지 아니하는구나","reference":"욥기 30:17","category":"$undefined"},{"id":"13576","book":"욥기","book_name":"욥기","chapter":30,"verse":18,"text":"하나님의 큰 능력으로 하여 옷이 추하여져서 옷깃처럼 내몸에 붙었구나","reference":"욥기 30:18","category":"$undefined"},{"id":"13577","book":"욥기","book_name":"욥기","chapter":30,"verse":19,"text":"하나님이 나를 진흙 가운데 던지셨고 나로 티끌과 재같게 하셨구나","reference":"욥기 30:19","category":"$undefined"},{"id":"13578","book":"욥기","book_name":"욥기","chapter":30,"verse":20,"text":"내가 주께 부르짖으오나 주께서 대답지 아니하시오며 내가 섰사오나 주께서 굽어보시기만 하시나이다","reference":"욥기 30:20","category":"$undefined"},{"id":"13579","book":"욥기","book_name":"욥기","chapter":30,"verse":21,"text":"주께서 돌이켜 내게 잔혹히 하시고 완력으로 나를 핍박하시오며","reference":"욥기 30:21","category":"$undefined"},{"id":"13580","book":"욥기","book_name":"욥기","chapter":30,"verse":22,"text":"나를 바람 위에 들어 얹어 불려가게 하시며 대풍 중에 소멸케 하시나이다","reference":"욥기 30:22","category":"$undefined"},{"id":"13581","book":"욥기","book_name":"욥기","chapter":30,"verse":23,"text":"내가 아나이다 주께서 나를 죽게 하사 모든 생물을 위하여 정한 집으로 끌어 가시리이다","reference":"욥기 30:23","category":"$undefined"},{"id":"13582","book":"욥기","book_name":"욥기","chapter":30,"verse":24,"text":"그러나 사람이 넘어질 때에 어찌 손을 펴지 아니하며 재앙을 당할때에 어찌 도움을 부르짖지 아니하겠는가","reference":"욥기 30:24","category":"$undefined"},{"id":"13583","book":"욥기","book_name":"욥기","chapter":30,"verse":25,"text":"고생의 날 보내는 자를 위하여 내가 울지 아니하였는가 빈궁한 자를 위하여 내 마음에 근심하지 아니하였는가","reference":"욥기 30:25","category":"$undefined"},{"id":"13584","book":"욥기","book_name":"욥기","chapter":30,"verse":26,"text":"내가 복을 바랐더니 화가 왔고 광명을 기다렸더니 흑암이 왔구나","reference":"욥기 30:26","category":"$undefined"},{"id":"13585","book":"욥기","book_name":"욥기","chapter":30,"verse":27,"text":"내 마음이 어지러워서 쉬지 못하는구나 환난 날이 내게 임하였구나","reference":"욥기 30:27","category":"$undefined"},{"id":"13586","book":"욥기","book_name":"욥기","chapter":30,"verse":28,"text":"나는 햇볕에 쬐지 않고 검어진 살을 가지고 걸으며 공회 중에 서서 도움을 부르짖고 있느니라","reference":"욥기 30:28","category":"$undefined"},{"id":"13587","book":"욥기","book_name":"욥기","chapter":30,"verse":29,"text":"나는 이리의 형제요 타조의 벗이로구나","reference":"욥기 30:29","category":"$undefined"},{"id":"13588","book":"욥기","book_name":"욥기","chapter":30,"verse":30,"text":"내 가죽은 검어져서 떨어졌고 내 뼈는 열기로 하여 탔구나","reference":"욥기 30:30","category":"$undefined"},{"id":"13589","book":"욥기","book_name":"욥기","chapter":30,"verse":31,"text":"내 수금은 애곡성이 되고 내 피리는 애통성이 되었구나","reference":"욥기 30:31","category":"$undefined"}],"bookSlug":"job"}]
