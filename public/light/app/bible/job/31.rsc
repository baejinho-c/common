2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":31,"verses":[{"id":"13590","book":"욥기","book_name":"욥기","chapter":31,"verse":1,"text":"내가 내 눈과 언약을 세웠나니 어찌 처녀에게 주목하랴","reference":"욥기 31:1","category":"$undefined"},{"id":"13591","book":"욥기","book_name":"욥기","chapter":31,"verse":2,"text":"그리하면 위에 계신 하나님의 내리시는 분깃이 무엇이겠으며 높은 곳에서 전능자의 주시는 산업이 무엇이겠느냐 ?","reference":"욥기 31:2","category":"$undefined"},{"id":"13592","book":"욥기","book_name":"욥기","chapter":31,"verse":3,"text":"불의자에게는 환난이 아니겠느냐 ? 행악자에게는 재앙이 아니겠느냐 ?","reference":"욥기 31:3","category":"$undefined"},{"id":"13593","book":"욥기","book_name":"욥기","chapter":31,"verse":4,"text":"그가 내 길을 감찰하지 아니하시느냐 ? 내 걸음을 다 세지 아니하시느냐 ?","reference":"욥기 31:4","category":"$undefined"},{"id":"13594","book":"욥기","book_name":"욥기","chapter":31,"verse":5,"text":"언제 나의 행위가 허탄하였으며 내 발이 궤휼에 빨랐던가","reference":"욥기 31:5","category":"$undefined"},{"id":"13595","book":"욥기","book_name":"욥기","chapter":31,"verse":6,"text":"그리하였으면 내가 공평한 저울에 달려서 하나님이 나의 정직함을 아시게 되기를 원하노라","reference":"욥기 31:6","category":"$undefined"},{"id":"13596","book":"욥기","book_name":"욥기","chapter":31,"verse":7,"text":"언제 내 걸음이 길에서 떠났던가, 내 마음이 내 눈을 따라갔던가, 내 손에 더러운 것이 묻었던가,","reference":"욥기 31:7","category":"$undefined"},{"id":"13597","book":"욥기","book_name":"욥기","chapter":31,"verse":8,"text":"그리하였으면 나의 심은 것을 타인이 먹으며 나의 소산이 뿌리까지 뽑히는 것이 마땅하니라","reference":"욥기 31:8","category":"$undefined"},{"id":"13598","book":"욥기","book_name":"욥기","chapter":31,"verse":9,"text":"언제 내 마음이 여인에게 유혹되어 이웃의 문을 엿보아 기다렸던가","reference":"욥기 31:9","category":"$undefined"},{"id":"13599","book":"욥기","book_name":"욥기","chapter":31,"verse":10,"text":"그리하였으면 내 처가 타인의 매를 돌리며 타인이 더불어 동침하는 것이 마땅하니라","reference":"욥기 31:10","category":"$undefined"},{"id":"13600","book":"욥기","book_name":"욥기","chapter":31,"verse":11,"text":"이는 중죄라 재판장에게 벌받을 악이요","reference":"욥기 31:11","category":"$undefined"},{"id":"13601","book":"욥기","book_name":"욥기","chapter":31,"verse":12,"text":"멸망하도록 사르는 불이라 나의 모든 소산을 뿌리까지 없이할 것이니라","reference":"욥기 31:12","category":"$undefined"},{"id":"13602","book":"욥기","book_name":"욥기","chapter":31,"verse":13,"text":"남종이나 여종이 나로 더불어 쟁변할 때에 내가 언제 그의 사정을 멸시하였던가","reference":"욥기 31:13","category":"$undefined"},{"id":"13603","book":"욥기","book_name":"욥기","chapter":31,"verse":14,"text":"그리하였으면 하나님이 일어나실 때에는 내가 어떻게 하겠느냐 ? 하나님이 국문하실 때에는 내가 무엇이라 대답하겠느냐 ?","reference":"욥기 31:14","category":"$undefined"},{"id":"13604","book":"욥기","book_name":"욥기","chapter":31,"verse":15,"text":"나를 태 속에 만드신 자가 그도 만들지 아니하셨느냐 ? 우리를 뱃속에 지으신 자가 하나가 아니시냐 ?","reference":"욥기 31:15","category":"$undefined"},{"id":"13605","book":"욥기","book_name":"욥기","chapter":31,"verse":16,"text":"내가 언제 가난한 자의 소원을 막았던가 과부의 눈으로 실망케 하였던가","reference":"욥기 31:16","category":"$undefined"},{"id":"13606","book":"욥기","book_name":"욥기","chapter":31,"verse":17,"text":"나만 홀로 식물을 먹고 고아에게 먹이지 아니하였던가","reference":"욥기 31:17","category":"$undefined"},{"id":"13607","book":"욥기","book_name":"욥기","chapter":31,"verse":18,"text":"실상은 내가 젊었을 때부터 고아를 기르기를 그의 아비처럼 하였으며 내가 모태에서 나온 후로 과부를 인도하였었노라","reference":"욥기 31:18","category":"$undefined"},{"id":"13608","book":"욥기","book_name":"욥기","chapter":31,"verse":19,"text":"내가 언제 사람이 의복이 없이 죽게 된 것이나 빈궁한 자가 덮을 것이 없는 것을 보고도","reference":"욥기 31:19","category":"$undefined"},{"id":"13609","book":"욥기","book_name":"욥기","chapter":31,"verse":20,"text":"나의 양털로 그 몸을 더웁게 입혀서 그로 나를 위하여 복을 빌게 하지 아니하였던가","reference":"욥기 31:20","category":"$undefined"},{"id":"13610","book":"욥기","book_name":"욥기","chapter":31,"verse":21,"text":"나를 도와 주는 자가 성문에 있음을 보고 내가 손을 들어 고아를 쳤던가","reference":"욥기 31:21","category":"$undefined"},{"id":"13611","book":"욥기","book_name":"욥기","chapter":31,"verse":22,"text":"그리하였으면 내 어깨가 어깨뼈에서 떨어지고 내 팔 뼈가 부러짐이 마땅하니라","reference":"욥기 31:22","category":"$undefined"},{"id":"13612","book":"욥기","book_name":"욥기","chapter":31,"verse":23,"text":"나는 하나님의 재앙을 심히 두려워하고 그 위엄을 인하여 아무 것도 할 수 없느니라","reference":"욥기 31:23","category":"$undefined"},{"id":"13613","book":"욥기","book_name":"욥기","chapter":31,"verse":24,"text":"내가 언제 금으로 내 소망을 삼고 정금더러 너는 내 의뢰하는 바라 하였던가","reference":"욥기 31:24","category":"$undefined"},{"id":"13614","book":"욥기","book_name":"욥기","chapter":31,"verse":25,"text":"언제 재물의 풍부함과 손으로 얻은 것이 많음으로 기뻐하였던가","reference":"욥기 31:25","category":"$undefined"},{"id":"13615","book":"욥기","book_name":"욥기","chapter":31,"verse":26,"text":"언제 태양의 빛남과 달의 명랑하게 운행되는 것을 보고","reference":"욥기 31:26","category":"$undefined"},{"id":"13616","book":"욥기","book_name":"욥기","chapter":31,"verse":27,"text":"내 마음이 가만히 유혹되어 손에 입맞추었던가","reference":"욥기 31:27","category":"$undefined"},{"id":"13617","book":"욥기","book_name":"욥기","chapter":31,"verse":28,"text":"이 역시 재판장에게 벌 받을 죄악이니 내가 그리하였으면 위에 계신 하나님을 배반한 것이니라","reference":"욥기 31:28","category":"$undefined"},{"id":"13618","book":"욥기","book_name":"욥기","chapter":31,"verse":29,"text":"내가 언제 나를 미워하는 자의 멸망을 기뻐하였으며 그의 재앙 만남을 인하여 기운을 뽐내었던가","reference":"욥기 31:29","category":"$undefined"},{"id":"13619","book":"욥기","book_name":"욥기","chapter":31,"verse":30,"text":"실상은 내가 그의 죽기를 구하는 말로 저주하여 내 입으로 범죄케 아니하였느니라","reference":"욥기 31:30","category":"$undefined"},{"id":"13620","book":"욥기","book_name":"욥기","chapter":31,"verse":31,"text":"내 장막 사람의 말이 주인의 고기에 배부르지 않은 자가 어디 있느뇨 하지 아니하였었는가","reference":"욥기 31:31","category":"$undefined"},{"id":"13621","book":"욥기","book_name":"욥기","chapter":31,"verse":32,"text":"나그네로 거리에서 자게 하지 아니하고 내가 행인에게 내 문을 열어 주었었노라","reference":"욥기 31:32","category":"$undefined"},{"id":"13622","book":"욥기","book_name":"욥기","chapter":31,"verse":33,"text":"내가 언제 큰 무리를 두려워하며 족속의 멸시를 무서워함으로 잠잠하고 문에 나가지 아니하여 타인처럼 내 죄악을 품에 숨겨 허물을 가리었었던가","reference":"욥기 31:33","category":"$undefined"},{"id":"13623","book":"욥기","book_name":"욥기","chapter":31,"verse":34,"text":"(33절과 같음)","reference":"욥기 31:34","category":"$undefined"},{"id":"13624","book":"욥기","book_name":"욥기","chapter":31,"verse":35,"text":"누구든지 나의 변백을 들을지니라 나의 서명이 여기 있으니 전능자가 내게 대답하시기를 원하노라 내 대적의 기록한 소송장이 내게 있으면","reference":"욥기 31:35","category":"$undefined"},{"id":"13625","book":"욥기","book_name":"욥기","chapter":31,"verse":36,"text":"내가 어깨에 메기도 하고 면류관처럼 머리에 쓰기도 하며","reference":"욥기 31:36","category":"$undefined"},{"id":"13626","book":"욥기","book_name":"욥기","chapter":31,"verse":37,"text":"내 걸음의 수효를 그에게 고하고 왕족처럼 그를 가까이 하였으리라","reference":"욥기 31:37","category":"$undefined"},{"id":"13627","book":"욥기","book_name":"욥기","chapter":31,"verse":38,"text":"언제 내 토지가 부르짖어 나를 책망하며 그 이랑이 일시에 울었던가","reference":"욥기 31:38","category":"$undefined"},{"id":"13628","book":"욥기","book_name":"욥기","chapter":31,"verse":39,"text":"언제 내가 값을 내지 않고 그 소산물을 먹고 그 소유주로 생명을 잃게 하였던가","reference":"욥기 31:39","category":"$undefined"},{"id":"13629","book":"욥기","book_name":"욥기","chapter":31,"verse":40,"text":"그리하였으면 말 대신에 찔레가 나고 보리 대신에 잡풀이 나는 것이 마땅하니라 하고 욥의 말이 그치니라","reference":"욥기 31:40","category":"$undefined"}],"bookSlug":"job"}]
