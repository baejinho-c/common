2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":32,"verses":[{"id":"13630","book":"욥기","book_name":"욥기","chapter":32,"verse":1,"text":"욥이 스스로 의롭게 여기므로 그 세 사람의 대답이 그치매","reference":"욥기 32:1","category":"$undefined"},{"id":"13631","book":"욥기","book_name":"욥기","chapter":32,"verse":2,"text":"람 족속 부스 사람 바라겔의 아들 엘리후가 노를 발하니 그가 욥에게 노를 발함은 욥이 하나님보다 자기가 의롭다 함이요","reference":"욥기 32:2","category":"$undefined"},{"id":"13632","book":"욥기","book_name":"욥기","chapter":32,"verse":3,"text":"또 세 친구에게 노를 발함은 그들이 능히 대답지는 못하여도 욥을 정죄함이라","reference":"욥기 32:3","category":"$undefined"},{"id":"13633","book":"욥기","book_name":"욥기","chapter":32,"verse":4,"text":"엘리후가 그들의 나이 자기보다 많으므로 욥에게 말하기를 참고있다가","reference":"욥기 32:4","category":"$undefined"},{"id":"13634","book":"욥기","book_name":"욥기","chapter":32,"verse":5,"text":"세 사람의 입에 대답이 없음을 보고 노를 발하니라","reference":"욥기 32:5","category":"$undefined"},{"id":"13635","book":"욥기","book_name":"욥기","chapter":32,"verse":6,"text":"부스 사람 바라겔의 아들 엘리후가 발언하여 가로되 나는 연소하고 당신들은 연로하므로 참고 나의 의견을 감히 진술치 못하였노라","reference":"욥기 32:6","category":"$undefined"},{"id":"13636","book":"욥기","book_name":"욥기","chapter":32,"verse":7,"text":"내가 말하기를 날이 많은 자가 말을 낼 것이요 해가 오랜 자가 지혜를 가르칠 것이라 하였으나","reference":"욥기 32:7","category":"$undefined"},{"id":"13637","book":"욥기","book_name":"욥기","chapter":32,"verse":8,"text":"사람의 속에는 심령이 있고 전능자의 기운이 사람에게 총명을 주시나니","reference":"욥기 32:8","category":"$undefined"},{"id":"13638","book":"욥기","book_name":"욥기","chapter":32,"verse":9,"text":"대인이라고 지혜로운 것이 아니요 노인이라고 공의를 깨닫는 것이 아니라","reference":"욥기 32:9","category":"$undefined"},{"id":"13639","book":"욥기","book_name":"욥기","chapter":32,"verse":10,"text":"그러므로 내가 말하노니 내 말을 들으라 나도 내 의견을 보이리라","reference":"욥기 32:10","category":"$undefined"},{"id":"13640","book":"욥기","book_name":"욥기","chapter":32,"verse":11,"text":"내가 당신들의 말을 기다렸고 당신들이 할 말을 합당하도록 하여 보는 동안에 그 변론에 내 귀를 기울였더니","reference":"욥기 32:11","category":"$undefined"},{"id":"13641","book":"욥기","book_name":"욥기","chapter":32,"verse":12,"text":"자세히 들은즉 당신들 가운데 욥을 꺾어 그 말을 대답하는 자가 없도다","reference":"욥기 32:12","category":"$undefined"},{"id":"13642","book":"욥기","book_name":"욥기","chapter":32,"verse":13,"text":"당신들이 혹시라도 말하기를 우리가 지혜를 깨달았었구나 그를 이길 자는 하나님이시요 사람이 아니라 하지 말지니라","reference":"욥기 32:13","category":"$undefined"},{"id":"13643","book":"욥기","book_name":"욥기","chapter":32,"verse":14,"text":"그가 내게 말을 내지 아니하였으니 나도 당신들의 말처럼 그에게 대답지 아니하리라","reference":"욥기 32:14","category":"$undefined"},{"id":"13644","book":"욥기","book_name":"욥기","chapter":32,"verse":15,"text":"그들이 놀라서 다시 대답하지 못하니 할 말이 없음이로구나","reference":"욥기 32:15","category":"$undefined"},{"id":"13645","book":"욥기","book_name":"욥기","chapter":32,"verse":16,"text":"그들이 말이 없이 가만히 서서 다시 대답지 아니한즉 내가 어찌 더 기다리랴","reference":"욥기 32:16","category":"$undefined"},{"id":"13646","book":"욥기","book_name":"욥기","chapter":32,"verse":17,"text":"나도 내 본분대로 대답하고 나도 내 의향을 보이리니","reference":"욥기 32:17","category":"$undefined"},{"id":"13647","book":"욥기","book_name":"욥기","chapter":32,"verse":18,"text":"내게 말이 가득하고 내 심령이 나를 강박함이니라","reference":"욥기 32:18","category":"$undefined"},{"id":"13648","book":"욥기","book_name":"욥기","chapter":32,"verse":19,"text":"보라 내 가슴은 봉한 포도주 같고 새 가죽 부대가 터지게 됨 같구나","reference":"욥기 32:19","category":"$undefined"},{"id":"13649","book":"욥기","book_name":"욥기","chapter":32,"verse":20,"text":"내가 말을 발하여야 시원할 것이라 내 입을 열어 대답하리라","reference":"욥기 32:20","category":"$undefined"},{"id":"13650","book":"욥기","book_name":"욥기","chapter":32,"verse":21,"text":"나는 결코 사람의 낯을 보지 아니하며 사람에게 아첨하지 아니하나니","reference":"욥기 32:21","category":"$undefined"},{"id":"13651","book":"욥기","book_name":"욥기","chapter":32,"verse":22,"text":"이는 아첨할 줄을 알지 못함이라 만일 그리하면 나를 지으신 자가 속히 나를 취하시리로다","reference":"욥기 32:22","category":"$undefined"}],"bookSlug":"job"}]
