2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":33,"verses":[{"id":"13652","book":"욥기","book_name":"욥기","chapter":33,"verse":1,"text":"그런즉 욥이여 ! 내 말을 들으며 나의 모든 말에 귀를 기울이기를 원하노라","reference":"욥기 33:1","category":"$undefined"},{"id":"13653","book":"욥기","book_name":"욥기","chapter":33,"verse":2,"text":"내가 입을 여니 내 혀가 입에서 동하는구나","reference":"욥기 33:2","category":"$undefined"},{"id":"13654","book":"욥기","book_name":"욥기","chapter":33,"verse":3,"text":"내 말이 내 마음의 정직함을 나타내고 내 입술이 아는 바를 진실히 말하리라","reference":"욥기 33:3","category":"$undefined"},{"id":"13655","book":"욥기","book_name":"욥기","chapter":33,"verse":4,"text":"하나님의 신이 나를 지으셨고 전능자의 기운이 나를 살리시느니라","reference":"욥기 33:4","category":"$undefined"},{"id":"13656","book":"욥기","book_name":"욥기","chapter":33,"verse":5,"text":"네가 할 수 있거든 일어서서 내게 대답하고 내 앞에 진술하라","reference":"욥기 33:5","category":"$undefined"},{"id":"13657","book":"욥기","book_name":"욥기","chapter":33,"verse":6,"text":"나와 네가 하나님 앞에서 일반이니 나도 흙으로 지으심을 입었은즉","reference":"욥기 33:6","category":"$undefined"},{"id":"13658","book":"욥기","book_name":"욥기","chapter":33,"verse":7,"text":"내 위엄으로는 너를 두렵게 하지 못하고 내 권세로는 너를 누르지 못하느니라","reference":"욥기 33:7","category":"$undefined"},{"id":"13659","book":"욥기","book_name":"욥기","chapter":33,"verse":8,"text":"네가 실로 나의 듣는데 말하였고 나는 네 말소리를 들었느니라 이르기를","reference":"욥기 33:8","category":"$undefined"},{"id":"13660","book":"욥기","book_name":"욥기","chapter":33,"verse":9,"text":"나는 깨끗하여 죄가 없고 허물이 없으며 불의도 없거늘","reference":"욥기 33:9","category":"$undefined"},{"id":"13661","book":"욥기","book_name":"욥기","chapter":33,"verse":10,"text":"하나님이 나를 칠 틈을 찾으시며 나를 대적으로 여기사","reference":"욥기 33:10","category":"$undefined"},{"id":"13662","book":"욥기","book_name":"욥기","chapter":33,"verse":11,"text":"내 발을 착고에 채우시고 나의 모든 길을 감시하신다 하였느니라","reference":"욥기 33:11","category":"$undefined"},{"id":"13663","book":"욥기","book_name":"욥기","chapter":33,"verse":12,"text":"내가 네게 대답하리라 이 말에 네가 의롭지 못하니 하나님은 사람보다 크심이니라","reference":"욥기 33:12","category":"$undefined"},{"id":"13664","book":"욥기","book_name":"욥기","chapter":33,"verse":13,"text":"하나님은 모든 행하시는 것을 스스로 진술치 아니하시나니 네가 하나님과 변쟁함은 어찜이뇨","reference":"욥기 33:13","category":"$undefined"},{"id":"13665","book":"욥기","book_name":"욥기","chapter":33,"verse":14,"text":"사람은 무관히 여겨도 하나님은 한번 말씀하시고 다시 말씀하시되","reference":"욥기 33:14","category":"$undefined"},{"id":"13666","book":"욥기","book_name":"욥기","chapter":33,"verse":15,"text":"사람이 침상에서 졸며 깊이 잠들 때에나 꿈에나 밤의 이상 중에","reference":"욥기 33:15","category":"$undefined"},{"id":"13667","book":"욥기","book_name":"욥기","chapter":33,"verse":16,"text":"사람의 귀를 여시고 인치듯 교훈하시나니","reference":"욥기 33:16","category":"$undefined"},{"id":"13668","book":"욥기","book_name":"욥기","chapter":33,"verse":17,"text":"이는 사람으로 그 꾀를 버리게 하려 하심이며 사람에게 교만을 막으려 하심이라","reference":"욥기 33:17","category":"$undefined"},{"id":"13669","book":"욥기","book_name":"욥기","chapter":33,"verse":18,"text":"그는 사람의 혼으로 구덩이에 빠지지 않게 하시며 그 생명으로 칼에 멸망치 않게 하시느니라","reference":"욥기 33:18","category":"$undefined"},{"id":"13670","book":"욥기","book_name":"욥기","chapter":33,"verse":19,"text":"혹시는 사람이 병상의 고통과 뼈가 늘 쑤심의 징계를 받나니","reference":"욥기 33:19","category":"$undefined"},{"id":"13671","book":"욥기","book_name":"욥기","chapter":33,"verse":20,"text":"그의 마음은 식물을 싫어하고 그의 혼은 별미를 싫어하며","reference":"욥기 33:20","category":"$undefined"},{"id":"13672","book":"욥기","book_name":"욥기","chapter":33,"verse":21,"text":"그의 살은 파리하여 보이지 아니하고 보이지 않던 뼈가 드러나서","reference":"욥기 33:21","category":"$undefined"},{"id":"13673","book":"욥기","book_name":"욥기","chapter":33,"verse":22,"text":"그의 혼이 구덩이에, 그의 생명이 멸하는 자에게 가까와지느니라","reference":"욥기 33:22","category":"$undefined"},{"id":"13674","book":"욥기","book_name":"욥기","chapter":33,"verse":23,"text":"그럴 때에 만일 일천 천사 가운데 하나가 그 사람의 해석자로 함께 있어서 그 정당히 행할 것을 보일진대","reference":"욥기 33:23","category":"$undefined"},{"id":"13675","book":"욥기","book_name":"욥기","chapter":33,"verse":24,"text":"하나님이 그 사람을 긍휼히 여기사 이르시기를 그를 건져서 구덩이에 내려가지 않게 하라 내가 대속물을 얻었다 하시리라","reference":"욥기 33:24","category":"$undefined"},{"id":"13676","book":"욥기","book_name":"욥기","chapter":33,"verse":25,"text":"그런즉 그 살이 어린 아이보다 연하여져서 소년 때를 회복할 것이요","reference":"욥기 33:25","category":"$undefined"},{"id":"13677","book":"욥기","book_name":"욥기","chapter":33,"verse":26,"text":"그는 하나님께 기도하므로 하나님이 은혜를 베푸사 그로 자기의 얼굴을 즐거이 보게 하시고 사람에게 그 의를 회복시키시느니라","reference":"욥기 33:26","category":"$undefined"},{"id":"13678","book":"욥기","book_name":"욥기","chapter":33,"verse":27,"text":"그가 사람 앞에서 노래하여 이르기를 내가 전에 범죄하여 시비를 바꾸었으나 내게 무익하였었구나","reference":"욥기 33:27","category":"$undefined"},{"id":"13679","book":"욥기","book_name":"욥기","chapter":33,"verse":28,"text":"하나님이 내 영혼을 건지사 구덩이에 내려가지 않게 하셨으니 내 생명이 빛을 보겠구나 하리라","reference":"욥기 33:28","category":"$undefined"},{"id":"13680","book":"욥기","book_name":"욥기","chapter":33,"verse":29,"text":"하나님이 사람에게 이 모든 일을 재삼 행하심은","reference":"욥기 33:29","category":"$undefined"},{"id":"13681","book":"욥기","book_name":"욥기","chapter":33,"verse":30,"text":"그 영혼을 구덩이에서 끌어 돌이키고 생명의 빛으로 그에게 비취려 하심이니라","reference":"욥기 33:30","category":"$undefined"},{"id":"13682","book":"욥기","book_name":"욥기","chapter":33,"verse":31,"text":"욥이여 ! 귀를 기울여 내게 들으라 잠잠하라 내가 말하리라","reference":"욥기 33:31","category":"$undefined"},{"id":"13683","book":"욥기","book_name":"욥기","chapter":33,"verse":32,"text":"만일 할 말이 있거든 대답하라 내가 너를 의롭게 하려 하노니 말하라","reference":"욥기 33:32","category":"$undefined"},{"id":"13684","book":"욥기","book_name":"욥기","chapter":33,"verse":33,"text":"만일 없으면 내 말을 들으라 잠잠하라 내가 지혜로 너를 가르치리라","reference":"욥기 33:33","category":"$undefined"}],"bookSlug":"job"}]
