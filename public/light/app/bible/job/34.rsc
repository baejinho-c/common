2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":34,"verses":[{"id":"13685","book":"욥기","book_name":"욥기","chapter":34,"verse":1,"text":"엘리후가 말을 이어 가로되","reference":"욥기 34:1","category":"$undefined"},{"id":"13686","book":"욥기","book_name":"욥기","chapter":34,"verse":2,"text":"지혜 있는 자들아 ! 내 말을 들으며 지식 있는 자들아 ! 내게 귀를 기울이라","reference":"욥기 34:2","category":"$undefined"},{"id":"13687","book":"욥기","book_name":"욥기","chapter":34,"verse":3,"text":"입이 식물의 맛을 변별함 같이 귀가 말을 분별하나니","reference":"욥기 34:3","category":"$undefined"},{"id":"13688","book":"욥기","book_name":"욥기","chapter":34,"verse":4,"text":"우리가 스스로 옳은 것은 택하고 무엇이 선한가 우리끼리 알아보자","reference":"욥기 34:4","category":"$undefined"},{"id":"13689","book":"욥기","book_name":"욥기","chapter":34,"verse":5,"text":"욥이 말하기를 내가 의로우나 하나님이 내 의를 제하셨고","reference":"욥기 34:5","category":"$undefined"},{"id":"13690","book":"욥기","book_name":"욥기","chapter":34,"verse":6,"text":"내가 정직하나 거짓말장이가 되었고 나는 허물이 없으나 내 상처가 낫지 못하게 되었노라 하니","reference":"욥기 34:6","category":"$undefined"},{"id":"13691","book":"욥기","book_name":"욥기","chapter":34,"verse":7,"text":"어느 사람이 욥과 같으랴 욥이 훼방하기를 물마시듯 하며","reference":"욥기 34:7","category":"$undefined"},{"id":"13692","book":"욥기","book_name":"욥기","chapter":34,"verse":8,"text":"악한 일을 하는 자들과 사귀며 악인과 함께 다니면서","reference":"욥기 34:8","category":"$undefined"},{"id":"13693","book":"욥기","book_name":"욥기","chapter":34,"verse":9,"text":"이르기를 사람이 하나님을 기뻐하나 무익하다 하는구나","reference":"욥기 34:9","category":"$undefined"},{"id":"13694","book":"욥기","book_name":"욥기","chapter":34,"verse":10,"text":"그러므로 너희 총명한 자들아 내 말을 들으라 하나님은 단정코 악을 행치 아니하시며 전능자는 단정코 불의를 행치 아니하시고","reference":"욥기 34:10","category":"$undefined"},{"id":"13695","book":"욥기","book_name":"욥기","chapter":34,"verse":11,"text":"사람의 일을 따라 보응하사 각각 그 행위대로 얻게 하시나니","reference":"욥기 34:11","category":"$undefined"},{"id":"13696","book":"욥기","book_name":"욥기","chapter":34,"verse":12,"text":"진실로 하나님은 악을 행치 아니하시며 전능자는 공의를 굽히지 아니하시느니라","reference":"욥기 34:12","category":"$undefined"},{"id":"13697","book":"욥기","book_name":"욥기","chapter":34,"verse":13,"text":"누가 땅을 그에게 맡겼느냐 누가 온 세계를 정하였느냐","reference":"욥기 34:13","category":"$undefined"},{"id":"13698","book":"욥기","book_name":"욥기","chapter":34,"verse":14,"text":"그가 만일 자기만 생각하시고 그 신과 기운을 거두실진대","reference":"욥기 34:14","category":"$undefined"},{"id":"13699","book":"욥기","book_name":"욥기","chapter":34,"verse":15,"text":"모든 혈기 있는 자가 일체로 망하고 사람도 진토로 돌아가리라","reference":"욥기 34:15","category":"$undefined"},{"id":"13700","book":"욥기","book_name":"욥기","chapter":34,"verse":16,"text":"만일 총명이 있거든 이것을 들으며 내 말소리에 귀를 기울이라","reference":"욥기 34:16","category":"$undefined"},{"id":"13701","book":"욥기","book_name":"욥기","chapter":34,"verse":17,"text":"공의를 미워하는 자시면 어찌 치리하시겠느냐 의롭고 전능하신 자를 네가 정죄하겠느냐","reference":"욥기 34:17","category":"$undefined"},{"id":"13702","book":"욥기","book_name":"욥기","chapter":34,"verse":18,"text":"그는 왕에게라도 비루하다 하시며 귀인들에게라도 악하다 하시며","reference":"욥기 34:18","category":"$undefined"},{"id":"13703","book":"욥기","book_name":"욥기","chapter":34,"verse":19,"text":"왕족을 외모로 취치 아니하시며 부자를 가난한 자보다 더 생각하지 아니하시나니 이는 그들이 다 그의 손으로 지으신 바가 됨이 니라","reference":"욥기 34:19","category":"$undefined"},{"id":"13704","book":"욥기","book_name":"욥기","chapter":34,"verse":20,"text":"그들은 밤중 순식간에 죽나니 백성은 떨며 없어지고 세력있는 자도 사람의 손을 대지 않고 제함을 당하느니라","reference":"욥기 34:20","category":"$undefined"},{"id":"13705","book":"욥기","book_name":"욥기","chapter":34,"verse":21,"text":"하나님은 사람의 길을 주목하시며 사람의 모든 걸음을 감찰하시나니","reference":"욥기 34:21","category":"$undefined"},{"id":"13706","book":"욥기","book_name":"욥기","chapter":34,"verse":22,"text":"악을 행한 자는 숨을 만한 흑암이나 어두운 그늘이 없느니라","reference":"욥기 34:22","category":"$undefined"},{"id":"13707","book":"욥기","book_name":"욥기","chapter":34,"verse":23,"text":"하나님은 사람을 심판하시기에 오래 생각하실 것이 없으시니","reference":"욥기 34:23","category":"$undefined"},{"id":"13708","book":"욥기","book_name":"욥기","chapter":34,"verse":24,"text":"세력 있는 자를 조사할 것 없이 꺾으시고 다른 사람을 세워 그를 대신하게 하시느니라","reference":"욥기 34:24","category":"$undefined"},{"id":"13709","book":"욥기","book_name":"욥기","chapter":34,"verse":25,"text":"이와 같이 그들의 행위를 아시고 그들을 밤 사이에 엎으신즉 멸망하나니","reference":"욥기 34:25","category":"$undefined"},{"id":"13710","book":"욥기","book_name":"욥기","chapter":34,"verse":26,"text":"그들을 악한 자로 여겨 사람의 목전에서 치심은","reference":"욥기 34:26","category":"$undefined"},{"id":"13711","book":"욥기","book_name":"욥기","chapter":34,"verse":27,"text":"그들이 그를 떠나고 그의 모든 길을 무관히 여김이라","reference":"욥기 34:27","category":"$undefined"},{"id":"13712","book":"욥기","book_name":"욥기","chapter":34,"verse":28,"text":"그들이 이와 같이 하여 가난한 자의 부르짖음이 그에게 상달케하며 환난 받는 자의 부르짖음이 그에게 들리게 하느니라","reference":"욥기 34:28","category":"$undefined"},{"id":"13713","book":"욥기","book_name":"욥기","chapter":34,"verse":29,"text":"주께서 사람에게 평강을 주실 때에 누가 감히 잘못하신다 하겠느냐 주께서 자기 얼굴을 가리우실 때에 누가 감히 뵈올 수 있으랴 나라에게나 사람에게나 일반이시니","reference":"욥기 34:29","category":"$undefined"},{"id":"13714","book":"욥기","book_name":"욥기","chapter":34,"verse":30,"text":"이는 사특한 자로 권세를 잡아 백성을 함해하지 못하게 하려 하심이니라","reference":"욥기 34:30","category":"$undefined"},{"id":"13715","book":"욥기","book_name":"욥기","chapter":34,"verse":31,"text":"누가 하나님께 아뢰기를 내가 징계를 받았사오니 다시는 범죄치 아니하겠나이다","reference":"욥기 34:31","category":"$undefined"},{"id":"13716","book":"욥기","book_name":"욥기","chapter":34,"verse":32,"text":"나의 깨닫지 못하는 것을 내게 가르치소서 내가 악을 행하였으면 다시는 아니하겠나이다 한 자가 있느냐","reference":"욥기 34:32","category":"$undefined"},{"id":"13717","book":"욥기","book_name":"욥기","chapter":34,"verse":33,"text":"하나님이 네 뜻대로 갚으셔야 하겠다고 네가 그것을 싫어하느냐 그러면 네가 스스로 택할 것이요 내가 할 것이 아니니 너는 아는대로 말하라","reference":"욥기 34:33","category":"$undefined"},{"id":"13718","book":"욥기","book_name":"욥기","chapter":34,"verse":34,"text":"총명한 자와 내 말을 듣는 모든 지혜 있는 자가 필연 내게 이르기를","reference":"욥기 34:34","category":"$undefined"},{"id":"13719","book":"욥기","book_name":"욥기","chapter":34,"verse":35,"text":"욥이 무식하게 말하니 그 말이 지혜 없다 하리라","reference":"욥기 34:35","category":"$undefined"},{"id":"13720","book":"욥기","book_name":"욥기","chapter":34,"verse":36,"text":"욥이 끝까지 시험받기를 내가 원하노니 이는 그 대답이 악인과 같음이라","reference":"욥기 34:36","category":"$undefined"},{"id":"13721","book":"욥기","book_name":"욥기","chapter":34,"verse":37,"text":"그가 그 죄 위에 패역을 더하며 우리 중에서 손뼉을 치며 하나님을 거역하는 말을 많이 하는구나","reference":"욥기 34:37","category":"$undefined"}],"bookSlug":"job"}]
