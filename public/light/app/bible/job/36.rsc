2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":36,"verses":[{"id":"13738","book":"욥기","book_name":"욥기","chapter":36,"verse":1,"text":"이로 인하여 내 마음이 떨며 자기 처소에서 떠나느니라","reference":"욥기 36:1","category":"$undefined"},{"id":"13739","book":"욥기","book_name":"욥기","chapter":36,"verse":2,"text":"하나님의 음성 곧 그 입에서 나오는 소리를 들으라 들으라","reference":"욥기 36:2","category":"$undefined"},{"id":"13740","book":"욥기","book_name":"욥기","chapter":36,"verse":3,"text":"그 소리를 천하에 퍼치시며 번개 빛으로 땅끝까지 이르게 하시고","reference":"욥기 36:3","category":"$undefined"},{"id":"13741","book":"욥기","book_name":"욥기","chapter":36,"verse":4,"text":"그 후에 음성을 발하시며 위엄의 울리는 음성을 내시고는 그 음성이 들릴 때에 번개 빛을 금치 아니하시느니라","reference":"욥기 36:4","category":"$undefined"},{"id":"13742","book":"욥기","book_name":"욥기","chapter":36,"verse":5,"text":"하나님이 기이하게 음성을 울리시며 우리의 헤아릴 수 없는 큰 일을 행하시느니라","reference":"욥기 36:5","category":"$undefined"},{"id":"13743","book":"욥기","book_name":"욥기","chapter":36,"verse":6,"text":"눈을 명하여 땅에 내리라 하시며 적은 비와 큰 비도 그 같이 내리게 하시느니라","reference":"욥기 36:6","category":"$undefined"},{"id":"13744","book":"욥기","book_name":"욥기","chapter":36,"verse":7,"text":"그가 각 사람의 손을 봉하시나니 이는 그 지으신 모든 사람으로 그것을 알게 하려 하심이니라","reference":"욥기 36:7","category":"$undefined"},{"id":"13745","book":"욥기","book_name":"욥기","chapter":36,"verse":8,"text":"짐승들은 숨는 곳으로 들어가서 그 굴에 머물며","reference":"욥기 36:8","category":"$undefined"},{"id":"13746","book":"욥기","book_name":"욥기","chapter":36,"verse":9,"text":"남방 밀실에서는 광풍이 이르고 북방에서는 찬 기운이 이르며","reference":"욥기 36:9","category":"$undefined"},{"id":"13747","book":"욥기","book_name":"욥기","chapter":36,"verse":10,"text":"하나님의 부시는 기운에 얼음이 얼고 물의 넓이가 줄어지느니라","reference":"욥기 36:10","category":"$undefined"},{"id":"13748","book":"욥기","book_name":"욥기","chapter":36,"verse":11,"text":"그가 습기로 빽빽한 구름 위에 실으시고 번개 빛의 구름을 널리펴신즉","reference":"욥기 36:11","category":"$undefined"},{"id":"13749","book":"욥기","book_name":"욥기","chapter":36,"verse":12,"text":"구름이 인도하시는대로 두루 행하나니 이는 무릇 그의 명하시는 것을 세계상에 이루려 함이라","reference":"욥기 36:12","category":"$undefined"},{"id":"13750","book":"욥기","book_name":"욥기","chapter":36,"verse":13,"text":"혹 징벌을 위하며, 혹 토지를 위하며, 혹 긍휼 베푸심을 위하여 구름으로 오게 하시느니라","reference":"욥기 36:13","category":"$undefined"},{"id":"13751","book":"욥기","book_name":"욥기","chapter":36,"verse":14,"text":"욥이여 이것을 듣고 가만히 서서 하나님의 기묘하신 일을 궁구하라","reference":"욥기 36:14","category":"$undefined"},{"id":"13752","book":"욥기","book_name":"욥기","chapter":36,"verse":15,"text":"하나님이 어떻게 이런 것들에게 명령하셔서 그 구름의 번개 빛으로 번쩍 번쩍하게 하시는지 네가 아느냐 ?","reference":"욥기 36:15","category":"$undefined"},{"id":"13753","book":"욥기","book_name":"욥기","chapter":36,"verse":16,"text":"구름의 평평하게 뜬 것과 지혜가 온전하신 자의 기묘한 일을 네가 아느냐 ?","reference":"욥기 36:16","category":"$undefined"},{"id":"13754","book":"욥기","book_name":"욥기","chapter":36,"verse":17,"text":"남풍으로 하여 땅이 고요할 때에 네 의복이 따뜻한 까닭을 네가 아느냐 ?","reference":"욥기 36:17","category":"$undefined"},{"id":"13755","book":"욥기","book_name":"욥기","chapter":36,"verse":18,"text":"네가 능히 그와 함께 하여 부은 거울 같은 견고한 궁창을 펼 수 있느냐 ?","reference":"욥기 36:18","category":"$undefined"},{"id":"13756","book":"욥기","book_name":"욥기","chapter":36,"verse":19,"text":"우리가 그에게 할 말을 너는 우리에게 가르치라 우리는 어두워서 진술하지 못하겠노라","reference":"욥기 36:19","category":"$undefined"},{"id":"13757","book":"욥기","book_name":"욥기","chapter":36,"verse":20,"text":"내가 말하고 싶은 것을 어찌 그에게 고할 수 있으랴 어찌 삼키우기를 바랄 자가 있으랴","reference":"욥기 36:20","category":"$undefined"},{"id":"13758","book":"욥기","book_name":"욥기","chapter":36,"verse":21,"text":"사람이 어떤 때는 궁창의 광명을 볼 수 없어도 바람이 지나가면 맑아지느니라","reference":"욥기 36:21","category":"$undefined"},{"id":"13759","book":"욥기","book_name":"욥기","chapter":36,"verse":22,"text":"북방에서는 금 빛이 나오나니 하나님께는 두려운 위엄이 있느니라","reference":"욥기 36:22","category":"$undefined"},{"id":"13760","book":"욥기","book_name":"욥기","chapter":36,"verse":23,"text":"전능자를 우리가 측량할 수 없나니 그는 권능이 지극히 크사 심판이나 무한한 공의를 굽히지 아니 하심이라","reference":"욥기 36:23","category":"$undefined"},{"id":"13761","book":"욥기","book_name":"욥기","chapter":36,"verse":24,"text":"그러므로 사람들은 그를 경외하고 그는 마음에 지혜롭다 하는 자를 돌아보지 아니하시느니라","reference":"욥기 36:24","category":"$undefined"},{"id":"13762","book":"욥기","book_name":"욥기","chapter":36,"verse":25,"text":"","reference":"욥기 36:25","category":"$undefined"},{"id":"13763","book":"욥기","book_name":"욥기","chapter":36,"verse":26,"text":"","reference":"욥기 36:26","category":"$undefined"},{"id":"13764","book":"욥기","book_name":"욥기","chapter":36,"verse":27,"text":"","reference":"욥기 36:27","category":"$undefined"},{"id":"13765","book":"욥기","book_name":"욥기","chapter":36,"verse":28,"text":"","reference":"욥기 36:28","category":"$undefined"},{"id":"13766","book":"욥기","book_name":"욥기","chapter":36,"verse":29,"text":"","reference":"욥기 36:29","category":"$undefined"},{"id":"13767","book":"욥기","book_name":"욥기","chapter":36,"verse":30,"text":"","reference":"욥기 36:30","category":"$undefined"},{"id":"13768","book":"욥기","book_name":"욥기","chapter":36,"verse":31,"text":"","reference":"욥기 36:31","category":"$undefined"},{"id":"13769","book":"욥기","book_name":"욥기","chapter":36,"verse":32,"text":"","reference":"욥기 36:32","category":"$undefined"},{"id":"13770","book":"욥기","book_name":"욥기","chapter":36,"verse":33,"text":"","reference":"욥기 36:33","category":"$undefined"}],"bookSlug":"job"}]
