2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":37,"verses":[{"id":"13771","book":"욥기","book_name":"욥기","chapter":37,"verse":1,"text":"때에 여호와께서 폭풍 가운데로서 욥에게 말씀하여 가라사대","reference":"욥기 37:1","category":"$undefined"},{"id":"13772","book":"욥기","book_name":"욥기","chapter":37,"verse":2,"text":"무지한 말로 이치를 어둡게 하는 자가 누구냐 ?","reference":"욥기 37:2","category":"$undefined"},{"id":"13773","book":"욥기","book_name":"욥기","chapter":37,"verse":3,"text":"너는 대장부처럼 허리를 묶고 내가 네게 묻는 것을 대답할지니라","reference":"욥기 37:3","category":"$undefined"},{"id":"13774","book":"욥기","book_name":"욥기","chapter":37,"verse":4,"text":"내가 땅의 기초를 놓을 때에 네가 어디 있었느냐 ? 네가 깨달아 알았거든 말할지니라","reference":"욥기 37:4","category":"$undefined"},{"id":"13775","book":"욥기","book_name":"욥기","chapter":37,"verse":5,"text":"누가 그 도량을 정하였었는지 누가 그 준승을 그 위에 띄웠었는지 네가 아느냐 ?","reference":"욥기 37:5","category":"$undefined"},{"id":"13776","book":"욥기","book_name":"욥기","chapter":37,"verse":6,"text":"그 주초는 무엇 위에 세웠으며 그 모퉁이 돌은 누가 놓았었느냐 ?","reference":"욥기 37:6","category":"$undefined"},{"id":"13777","book":"욥기","book_name":"욥기","chapter":37,"verse":7,"text":"그 때에 새벽 별들이 함께 노래하며 하나님의 아들들이 다 기쁘게 소리하였었느니라","reference":"욥기 37:7","category":"$undefined"},{"id":"13778","book":"욥기","book_name":"욥기","chapter":37,"verse":8,"text":"바닷물이 태에서 나옴 같이 넘쳐 흐를 때에 문으로 그것을 막은 자가 누구냐 ?","reference":"욥기 37:8","category":"$undefined"},{"id":"13779","book":"욥기","book_name":"욥기","chapter":37,"verse":9,"text":"그 때에 내가 구름으로 그 의복을 만들고 흑암으로 그 강보를 만들고","reference":"욥기 37:9","category":"$undefined"},{"id":"13780","book":"욥기","book_name":"욥기","chapter":37,"verse":10,"text":"계한을 정하여 문과 빗장을 베풀고","reference":"욥기 37:10","category":"$undefined"},{"id":"13781","book":"욥기","book_name":"욥기","chapter":37,"verse":11,"text":"이르기를 네가 여기까지 오고 넘어가지 못하리니 네 교만한 물결이 여기 그칠지니라 하였었노라","reference":"욥기 37:11","category":"$undefined"},{"id":"13782","book":"욥기","book_name":"욥기","chapter":37,"verse":12,"text":"네가 나던 날부터 아침을 명하였었느냐 ? 새벽으로 그 처소를 알게 하여","reference":"욥기 37:12","category":"$undefined"},{"id":"13783","book":"욥기","book_name":"욥기","chapter":37,"verse":13,"text":"그것으로 땅끝에 비취게 하고 악인을 그 가운데서 구축한 일이 있었느냐 ?","reference":"욥기 37:13","category":"$undefined"},{"id":"13784","book":"욥기","book_name":"욥기","chapter":37,"verse":14,"text":"땅이 변화하여 진흙에 인친 것 같고 만물이 옷 같이 나타나되","reference":"욥기 37:14","category":"$undefined"},{"id":"13785","book":"욥기","book_name":"욥기","chapter":37,"verse":15,"text":"악인에게는 그 빛이 금한바 되고 그들의 높이 든 팔이 꺽이느니라","reference":"욥기 37:15","category":"$undefined"},{"id":"13786","book":"욥기","book_name":"욥기","chapter":37,"verse":16,"text":"네가 바다 근원에 들어갔었느냐 ? 깊은 물밑으로 걸어 다녔었느냐 ?","reference":"욥기 37:16","category":"$undefined"},{"id":"13787","book":"욥기","book_name":"욥기","chapter":37,"verse":17,"text":"사망의 문이 네게 나타났었느냐 ? 사망의 그늘진 문을 네가 보았었느냐 ?","reference":"욥기 37:17","category":"$undefined"},{"id":"13788","book":"욥기","book_name":"욥기","chapter":37,"verse":18,"text":"땅의 넓이를 네가 측량하였었느냐 ? 다 알거든 말할지니라","reference":"욥기 37:18","category":"$undefined"},{"id":"13789","book":"욥기","book_name":"욥기","chapter":37,"verse":19,"text":"광명의 처소는 어느 길로 가며 흑암의 처소는 어디냐 ?","reference":"욥기 37:19","category":"$undefined"},{"id":"13790","book":"욥기","book_name":"욥기","chapter":37,"verse":20,"text":"네가 능히 그 지경으로 인도할 수 있느냐 ? 그 집의 길을 아느냐 ?","reference":"욥기 37:20","category":"$undefined"},{"id":"13791","book":"욥기","book_name":"욥기","chapter":37,"verse":21,"text":"네가 아마 알리라 네가 그 때에 났었나니 너의 년수가 많음이니라","reference":"욥기 37:21","category":"$undefined"},{"id":"13792","book":"욥기","book_name":"욥기","chapter":37,"verse":22,"text":"네가 눈 곳간에 들어갔었느냐 ? 우박 창고를 보았느냐 ?","reference":"욥기 37:22","category":"$undefined"},{"id":"13793","book":"욥기","book_name":"욥기","chapter":37,"verse":23,"text":"내가 환난 때와 전쟁과 격투의 날을 위하여 이것을 저축하였노라","reference":"욥기 37:23","category":"$undefined"},{"id":"13794","book":"욥기","book_name":"욥기","chapter":37,"verse":24,"text":"광명이 어느 길로 말미암아 뻗치며 동풍이 어느 길로 말미암아 땅에 흩어지느냐 ? [ (Job 37:25) 누가 폭우를 위하여 길을 내었으며 우뢰의 번개 길을 내었으며 ] [ (Job 37:26) 사람 없는 땅에, 사람 없는 광야에 비를 내리고 ] [ (Job 37:27) 황무하고 공허한 토지를 축축하게 하고 연한 풀이 나게 하였느냐 ? ] [ (Job 37:28) 비가 아비가 있느냐 ? 이슬 방울은 누가 낳았느냐 ? ] [ (Job 37:29) 얼음은 뉘 태에서 났느냐 ? 공중의 서리는 누가 낳았느냐 ? ] [ (Job 37:30) 물이 돌 같이 굳어지고 해면이 어느니라 ] [ (Job 37:31) 네가 묘성을 매어 떨기 되게 하겠느냐 ? 삼성의 띠를 풀겠느냐 ? ] [ (Job 37:32) 네가 열두 궁성을 때를 따라 이끌어 내겠느냐 ? 북두성과 그 속한 별들을 인도하겠느냐 ? ] [ (Job 37:33) 네가 하늘의 법도를 아느냐 ? 하늘로 그 권능을 땅에 베풀게 하겠느냐 ? ] [ (Job 37:34) 네 소리를 구름에 올려 큰 물로 네게 덮이게 하겠느냐 ? ] [ (Job 37:35) 네가 번개를 보내어 가게 하되 그것으로 네게 우리가 여기 있나이다 하게 하겠느냐 ? ] [ (Job 37:36) 가슴 속의 지혜는 누가 준 것이냐 ? 마음 속의 총명은 누가 준 것이냐 ? ] [ (Job 37:37) 누가 지혜로 구름을 계수하겠느냐 ? 누가 하늘의 병을 쏟아 ] [ (Job 37:38) 티끌로 진흙을 이루며 흙덩이로 서로 붙게 하겠느냐 ? ] [ (Job 37:39) 네가 암사자를 위하여 식물을 사냥하겠느냐 ? 젊은 사자의 식량을 채우겠느냐 ? ] [ (Job 37:40) 그것들이 굴에 엎드리며 삼림에 누워서 기다리는 때에니라 ] [ (Job 37:41) 까마귀 새끼가 하나님을 향하여 부르짖으며 먹을 것이 없어서 오락가락 할 때에 그것을 위하여 먹을 것을 예비하는 자가 누구냐 ? ]","reference":"욥기 37:24","category":"$undefined"}],"bookSlug":"job"}]
