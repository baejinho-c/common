2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":38,"verses":[{"id":"13795","book":"욥기","book_name":"욥기","chapter":38,"verse":1,"text":"산 염소가 새끼 치는 때를 네가 아느냐 ? 암사슴의 새끼 낳을 기한을 네가 알 수 있느냐 ?","reference":"욥기 38:1","category":"$undefined"},{"id":"13796","book":"욥기","book_name":"욥기","chapter":38,"verse":2,"text":"그것이 몇 달만에 만삭되는지 아느냐 ? 그 낳을 때를 아느냐 ?","reference":"욥기 38:2","category":"$undefined"},{"id":"13797","book":"욥기","book_name":"욥기","chapter":38,"verse":3,"text":"그것들은 몸을 구푸리고 새끼를 낳아 그 괴로움을 지내어 버리며","reference":"욥기 38:3","category":"$undefined"},{"id":"13798","book":"욥기","book_name":"욥기","chapter":38,"verse":4,"text":"그 새끼는 강하여져서 빈 들에서 길리우다가 나가고는 다시 돌아오지 아니하느니라","reference":"욥기 38:4","category":"$undefined"},{"id":"13799","book":"욥기","book_name":"욥기","chapter":38,"verse":5,"text":"누가 들나귀를 놓아 자유하게 하였느냐 ? 누가 빠른 나귀의 매인 것을 풀었느냐 ?","reference":"욥기 38:5","category":"$undefined"},{"id":"13800","book":"욥기","book_name":"욥기","chapter":38,"verse":6,"text":"내가 들로 그 집을, 짠 땅으로 그 사는 처소를 삼았느니라","reference":"욥기 38:6","category":"$undefined"},{"id":"13801","book":"욥기","book_name":"욥기","chapter":38,"verse":7,"text":"들나귀는 성읍의 지꺼리는 것을 업신여기니 어거하는 자의 지르는 소리가 그것에게 들리지 아니하며","reference":"욥기 38:7","category":"$undefined"},{"id":"13802","book":"욥기","book_name":"욥기","chapter":38,"verse":8,"text":"초장이 된 산으로 두루 다니며 여러 가지 푸른 것을 찾느니라","reference":"욥기 38:8","category":"$undefined"},{"id":"13803","book":"욥기","book_name":"욥기","chapter":38,"verse":9,"text":"들소가 어찌 즐겨 네게 복종하며 네 외양간에 머물겠느냐 ?","reference":"욥기 38:9","category":"$undefined"},{"id":"13804","book":"욥기","book_name":"욥기","chapter":38,"verse":10,"text":"네가 능히 줄로 들소를 매어 이랑을 갈게 하겠느냐 ? 그것이 어찌 골짜기에서 너를 따라 쓰레를 끌겠느냐 ?","reference":"욥기 38:10","category":"$undefined"},{"id":"13805","book":"욥기","book_name":"욥기","chapter":38,"verse":11,"text":"그것의 힘이 많다고 네가 그것을 의지하겠느냐 ? 네 수고하는 일을 그것에게 맡기겠느냐 ?","reference":"욥기 38:11","category":"$undefined"},{"id":"13806","book":"욥기","book_name":"욥기","chapter":38,"verse":12,"text":"그것이 네 곡식을 집으로 실어오며 네 타작 마당에 곡식 모으기를 그것에게 의탁하겠느냐 ?","reference":"욥기 38:12","category":"$undefined"},{"id":"13807","book":"욥기","book_name":"욥기","chapter":38,"verse":13,"text":"타조는 즐거이 그 날개를 친다마는 그 깃과 털이 인자를 베푸느냐 ?","reference":"욥기 38:13","category":"$undefined"},{"id":"13808","book":"욥기","book_name":"욥기","chapter":38,"verse":14,"text":"그것이 알을 땅에 버려두어 모래에서 더워지게 하고","reference":"욥기 38:14","category":"$undefined"},{"id":"13809","book":"욥기","book_name":"욥기","chapter":38,"verse":15,"text":"발에 깨어질 것이나 들짐승에게 밟힐 것을 생각지 아니하고","reference":"욥기 38:15","category":"$undefined"},{"id":"13810","book":"욥기","book_name":"욥기","chapter":38,"verse":16,"text":"그 새끼에게 무정함이 제 새끼가 아닌 것처럼 하며 그 구로한 것이 헛되게 될지라도 괘념치 아니하나니","reference":"욥기 38:16","category":"$undefined"},{"id":"13811","book":"욥기","book_name":"욥기","chapter":38,"verse":17,"text":"이는 하나님 내가 지혜를 품부하지 아니하고 총명을 주지 아니함이니라","reference":"욥기 38:17","category":"$undefined"},{"id":"13812","book":"욥기","book_name":"욥기","chapter":38,"verse":18,"text":"그러나 그 몸을 떨쳐 뛰어갈 때에는 말과 그 탄 자를 경히 여기느니라","reference":"욥기 38:18","category":"$undefined"},{"id":"13813","book":"욥기","book_name":"욥기","chapter":38,"verse":19,"text":"말의 힘을 네가 주었느냐 그 목에 흩날리는 갈기를 네가 입혔느냐 ?","reference":"욥기 38:19","category":"$undefined"},{"id":"13814","book":"욥기","book_name":"욥기","chapter":38,"verse":20,"text":"네가 그것으로 메뚜기처럼 뛰게 하였느냐 ? 그 위엄스러운 콧소리가 두려우니라","reference":"욥기 38:20","category":"$undefined"},{"id":"13815","book":"욥기","book_name":"욥기","chapter":38,"verse":21,"text":"그것이 골짜기에서 허위고 힘 있음을 기뻐하며 앞으로 나아가서 군사들을 맞되","reference":"욥기 38:21","category":"$undefined"},{"id":"13816","book":"욥기","book_name":"욥기","chapter":38,"verse":22,"text":"두려움을 비웃고 놀라지 아니하며 칼을 당할지라도 물러나지 아니하니","reference":"욥기 38:22","category":"$undefined"},{"id":"13817","book":"욥기","book_name":"욥기","chapter":38,"verse":23,"text":"그 위에서는 전동과 빛난 작은 창과 큰 창이 쟁쟁하며","reference":"욥기 38:23","category":"$undefined"},{"id":"13818","book":"욥기","book_name":"욥기","chapter":38,"verse":24,"text":"땅을 삼킬듯이 맹렬히 성내며 나팔 소리를 들으면 머물러 서지 아니하고","reference":"욥기 38:24","category":"$undefined"},{"id":"13819","book":"욥기","book_name":"욥기","chapter":38,"verse":25,"text":"나팔 소리 나는대로 소소히 울며 멀리서 싸움 냄새를 맡고 장관의 호령과 떠드는 소리를 듣느니라","reference":"욥기 38:25","category":"$undefined"},{"id":"13820","book":"욥기","book_name":"욥기","chapter":38,"verse":26,"text":"매가 떠올라서 날개를 펼쳐 남방으로 향하는 것이 어찌 네 지혜로 말미암음이냐 ?","reference":"욥기 38:26","category":"$undefined"},{"id":"13821","book":"욥기","book_name":"욥기","chapter":38,"verse":27,"text":"독수리가 공중에 떠서 높은 곳에 보금자리를 만드는 것이 어찌 네 명령을 의지함이냐 ?","reference":"욥기 38:27","category":"$undefined"},{"id":"13822","book":"욥기","book_name":"욥기","chapter":38,"verse":28,"text":"그것이 낭떠러지에 집을 지으며 뾰족한 바위 끝이나 험준한 데 거하며","reference":"욥기 38:28","category":"$undefined"},{"id":"13823","book":"욥기","book_name":"욥기","chapter":38,"verse":29,"text":"거기서 움킬만한 것을 살피나니 그 눈이 멀리 봄이며","reference":"욥기 38:29","category":"$undefined"},{"id":"13824","book":"욥기","book_name":"욥기","chapter":38,"verse":30,"text":"그 새끼들도 피를 빠나니 살륙 당한 자 있는 곳에는 그것도 거기 있느니라","reference":"욥기 38:30","category":"$undefined"},{"id":"13825","book":"욥기","book_name":"욥기","chapter":38,"verse":31,"text":"","reference":"욥기 38:31","category":"$undefined"},{"id":"13826","book":"욥기","book_name":"욥기","chapter":38,"verse":32,"text":"","reference":"욥기 38:32","category":"$undefined"},{"id":"13827","book":"욥기","book_name":"욥기","chapter":38,"verse":33,"text":"","reference":"욥기 38:33","category":"$undefined"},{"id":"13828","book":"욥기","book_name":"욥기","chapter":38,"verse":34,"text":"","reference":"욥기 38:34","category":"$undefined"},{"id":"13829","book":"욥기","book_name":"욥기","chapter":38,"verse":35,"text":"","reference":"욥기 38:35","category":"$undefined"},{"id":"13830","book":"욥기","book_name":"욥기","chapter":38,"verse":36,"text":"","reference":"욥기 38:36","category":"$undefined"},{"id":"13831","book":"욥기","book_name":"욥기","chapter":38,"verse":37,"text":"","reference":"욥기 38:37","category":"$undefined"},{"id":"13832","book":"욥기","book_name":"욥기","chapter":38,"verse":38,"text":"","reference":"욥기 38:38","category":"$undefined"},{"id":"13833","book":"욥기","book_name":"욥기","chapter":38,"verse":39,"text":"","reference":"욥기 38:39","category":"$undefined"},{"id":"13834","book":"욥기","book_name":"욥기","chapter":38,"verse":40,"text":"","reference":"욥기 38:40","category":"$undefined"},{"id":"13835","book":"욥기","book_name":"욥기","chapter":38,"verse":41,"text":"","reference":"욥기 38:41","category":"$undefined"}],"bookSlug":"job"}]
