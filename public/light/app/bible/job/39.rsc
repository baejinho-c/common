2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":39,"verses":[{"id":"13836","book":"욥기","book_name":"욥기","chapter":39,"verse":1,"text":"여호와께서 또 욥에게 말씀하여 가라사대","reference":"욥기 39:1","category":"$undefined"},{"id":"13837","book":"욥기","book_name":"욥기","chapter":39,"verse":2,"text":"변박하는 자가 전능자와 다투겠느냐 ? 하나님과 변론하는 자는 대답할지니라","reference":"욥기 39:2","category":"$undefined"},{"id":"13838","book":"욥기","book_name":"욥기","chapter":39,"verse":3,"text":"욥이 여호와께 대답하여 가로되","reference":"욥기 39:3","category":"$undefined"},{"id":"13839","book":"욥기","book_name":"욥기","chapter":39,"verse":4,"text":"나는 미천하오니 무엇이라 주께 대답하리이까 손으로 내 입을 가릴 뿐이로소이다","reference":"욥기 39:4","category":"$undefined"},{"id":"13840","book":"욥기","book_name":"욥기","chapter":39,"verse":5,"text":"내가 한두번 말하였사온즉 다시는 더하지도 아니하겠고 대답지도 아니하겠나이다","reference":"욥기 39:5","category":"$undefined"},{"id":"13841","book":"욥기","book_name":"욥기","chapter":39,"verse":6,"text":"여호와께서 폭풍 가운데서 욥에게 말씀하여 가라사대","reference":"욥기 39:6","category":"$undefined"},{"id":"13842","book":"욥기","book_name":"욥기","chapter":39,"verse":7,"text":"너는 대장부처럼 허리를 묶고 내가 네게 묻는 것을 대답할지니라","reference":"욥기 39:7","category":"$undefined"},{"id":"13843","book":"욥기","book_name":"욥기","chapter":39,"verse":8,"text":"네가 내 심판을 폐하려느냐 ? 스스로 의롭다 하려 하여 나를 불의하다 하느냐 ?","reference":"욥기 39:8","category":"$undefined"},{"id":"13844","book":"욥기","book_name":"욥기","chapter":39,"verse":9,"text":"네가 하나님처럼 팔이 있느냐 ? 하나님처럼 우렁차게 울리는 소리를 내겠느냐 ?","reference":"욥기 39:9","category":"$undefined"},{"id":"13845","book":"욥기","book_name":"욥기","chapter":39,"verse":10,"text":"너는 위엄과 존귀로 스스로 꾸미며 영광과 화미를 스스로 입을지니라","reference":"욥기 39:10","category":"$undefined"},{"id":"13846","book":"욥기","book_name":"욥기","chapter":39,"verse":11,"text":"너의 넘치는 노를 쏟아서 교만한 자를 발견하여 낱낱이 낮추되","reference":"욥기 39:11","category":"$undefined"},{"id":"13847","book":"욥기","book_name":"욥기","chapter":39,"verse":12,"text":"곧 모든 교만한 자를 발견하여 낮추며 악인을 그 처소에서 밟아서","reference":"욥기 39:12","category":"$undefined"},{"id":"13848","book":"욥기","book_name":"욥기","chapter":39,"verse":13,"text":"그들을 함께 진토에 묻고 그 얼굴을 싸서 어둑한 곳에 둘지니라","reference":"욥기 39:13","category":"$undefined"},{"id":"13849","book":"욥기","book_name":"욥기","chapter":39,"verse":14,"text":"그리하면 네 오른손이 너를 구원할 수 있다고 내가 인정하리라","reference":"욥기 39:14","category":"$undefined"},{"id":"13850","book":"욥기","book_name":"욥기","chapter":39,"verse":15,"text":"이제 소 같이 풀을 먹는 하마를 볼지어다 내가 너를 지은 것 같이 그것도 지었느니라","reference":"욥기 39:15","category":"$undefined"},{"id":"13851","book":"욥기","book_name":"욥기","chapter":39,"verse":16,"text":"그 힘은 허리에 있고 그 세력은 배의 힘줄에 있고","reference":"욥기 39:16","category":"$undefined"},{"id":"13852","book":"욥기","book_name":"욥기","chapter":39,"verse":17,"text":"그 꼬리 치는 것은 백향목이 흔들리는 것 같고 그 넓적다리 힘줄은 서로 연락되었으며","reference":"욥기 39:17","category":"$undefined"},{"id":"13853","book":"욥기","book_name":"욥기","chapter":39,"verse":18,"text":"그 뼈는 놋관 같고 그 가릿대는 철장 같으니","reference":"욥기 39:18","category":"$undefined"},{"id":"13854","book":"욥기","book_name":"욥기","chapter":39,"verse":19,"text":"그것은 하나님의 창조물 중에 으뜸이라 그것을 지은 자가 칼을 주었고","reference":"욥기 39:19","category":"$undefined"},{"id":"13855","book":"욥기","book_name":"욥기","chapter":39,"verse":20,"text":"모든 들 짐승의 노는 산은 그것을 위하여 식물을 내느니라","reference":"욥기 39:20","category":"$undefined"},{"id":"13856","book":"욥기","book_name":"욥기","chapter":39,"verse":21,"text":"그것이 연 줄기 아래나 갈 밭 가운데나 못속에 엎드리니","reference":"욥기 39:21","category":"$undefined"},{"id":"13857","book":"욥기","book_name":"욥기","chapter":39,"verse":22,"text":"연 그늘이 덮으며 시내 버들이 둘렀구나","reference":"욥기 39:22","category":"$undefined"},{"id":"13858","book":"욥기","book_name":"욥기","chapter":39,"verse":23,"text":"하수가 창일한다 할지라도 그것이 놀라지 않고 요단강이 불어 그 입에 미칠지라도 자약하니","reference":"욥기 39:23","category":"$undefined"},{"id":"13859","book":"욥기","book_name":"욥기","chapter":39,"verse":24,"text":"그것이 정신 차리고 있을 때에 누가 능히 잡을 수 있겠으며 갈고리로 그 코를 꿸 수 있겠느냐 ?","reference":"욥기 39:24","category":"$undefined"},{"id":"13860","book":"욥기","book_name":"욥기","chapter":39,"verse":25,"text":"","reference":"욥기 39:25","category":"$undefined"},{"id":"13861","book":"욥기","book_name":"욥기","chapter":39,"verse":26,"text":"","reference":"욥기 39:26","category":"$undefined"},{"id":"13862","book":"욥기","book_name":"욥기","chapter":39,"verse":27,"text":"","reference":"욥기 39:27","category":"$undefined"},{"id":"13863","book":"욥기","book_name":"욥기","chapter":39,"verse":28,"text":"","reference":"욥기 39:28","category":"$undefined"},{"id":"13864","book":"욥기","book_name":"욥기","chapter":39,"verse":29,"text":"","reference":"욥기 39:29","category":"$undefined"},{"id":"13865","book":"욥기","book_name":"욥기","chapter":39,"verse":30,"text":"","reference":"욥기 39:30","category":"$undefined"}],"bookSlug":"job"}]
