2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":4,"verses":[{"id":"12932","book":"욥기","book_name":"욥기","chapter":4,"verse":1,"text":"데만 사람 엘리바스가 대답하여 가로되","reference":"욥기 4:1","category":"$undefined"},{"id":"12933","book":"욥기","book_name":"욥기","chapter":4,"verse":2,"text":"누가 네게 말하면 네가 염증이 나겠느냐 ? 날지라도 누가 참고 말하지 아니하겠느냐 ?","reference":"욥기 4:2","category":"$undefined"},{"id":"12934","book":"욥기","book_name":"욥기","chapter":4,"verse":3,"text":"전에 네가 여러 사람을 교훈하였고 손이 늘어진 자면 강하게 하였고","reference":"욥기 4:3","category":"$undefined"},{"id":"12935","book":"욥기","book_name":"욥기","chapter":4,"verse":4,"text":"넘어져 가는 자를 말로 붙들어 주었고 무릎이 약한 자를 강하게 하였거늘","reference":"욥기 4:4","category":"$undefined"},{"id":"12936","book":"욥기","book_name":"욥기","chapter":4,"verse":5,"text":"이제 이 일이 네게 임하매 네가 답답하여 하고 이 일이 네게 당하매 네가 놀라는구나","reference":"욥기 4:5","category":"$undefined"},{"id":"12937","book":"욥기","book_name":"욥기","chapter":4,"verse":6,"text":"네 의뢰가 경외함에 있지 아니하냐 ? 네 소망이 네 행위를 완전히 함에 있지 아니하냐 ?","reference":"욥기 4:6","category":"$undefined"},{"id":"12938","book":"욥기","book_name":"욥기","chapter":4,"verse":7,"text":"생각하여 보라 ! 죄없이 망한 자가 누구인가 정직한 자의 끊어짐이 어디 있는가","reference":"욥기 4:7","category":"$undefined"},{"id":"12939","book":"욥기","book_name":"욥기","chapter":4,"verse":8,"text":"내가 보건대 악을 밭갈고 독을 뿌리는 자는 그대로 거두나니","reference":"욥기 4:8","category":"$undefined"},{"id":"12940","book":"욥기","book_name":"욥기","chapter":4,"verse":9,"text":"다 하나님의 입기운에 멸망하고 그 콧김에 사라지느니라","reference":"욥기 4:9","category":"$undefined"},{"id":"12941","book":"욥기","book_name":"욥기","chapter":4,"verse":10,"text":"사자의 우는 소리와 사나운 사자의 목소리가 그치고 젊은 사자의 이가 부러지며","reference":"욥기 4:10","category":"$undefined"},{"id":"12942","book":"욥기","book_name":"욥기","chapter":4,"verse":11,"text":"늙은 사자는 움킨 것이 없어 죽고 암사자의 새끼는 흩어지느니라","reference":"욥기 4:11","category":"$undefined"},{"id":"12943","book":"욥기","book_name":"욥기","chapter":4,"verse":12,"text":"무슨 말씀이 내게 가만히 임하고 그 가는 소리가 내 귀에 들렸었나니","reference":"욥기 4:12","category":"$undefined"},{"id":"12944","book":"욥기","book_name":"욥기","chapter":4,"verse":13,"text":"곧 사람이 깊이 잠들 때쯤 하여서니라 내가 그 밤의 이상으로 하여 생각이 번거로울 때에","reference":"욥기 4:13","category":"$undefined"},{"id":"12945","book":"욥기","book_name":"욥기","chapter":4,"verse":14,"text":"두려움과 떨림이 내게 이르러서 모든 골절이 흔들렸었느니라","reference":"욥기 4:14","category":"$undefined"},{"id":"12946","book":"욥기","book_name":"욥기","chapter":4,"verse":15,"text":"그 때에 영이 내 앞으로 지나매 내 몸에 털이 주뼛하였었느니라","reference":"욥기 4:15","category":"$undefined"},{"id":"12947","book":"욥기","book_name":"욥기","chapter":4,"verse":16,"text":"그 영이 서는데 그 형상을 분변치는 못하여도 오직 한 형상이 내 눈 앞에 있었느니라 그 때 내가 종용한 중에 목소리를 들으니 이르기를","reference":"욥기 4:16","category":"$undefined"},{"id":"12948","book":"욥기","book_name":"욥기","chapter":4,"verse":17,"text":"인생이 어찌 하나님보다 의롭겠느냐 ? 사람이 어찌 그 창조하신 이보다 성결하겠느냐 ?","reference":"욥기 4:17","category":"$undefined"},{"id":"12949","book":"욥기","book_name":"욥기","chapter":4,"verse":18,"text":"하나님은 그 종이라도 오히려 믿지 아니하시며 그 사자라도 미련하다 하시나니","reference":"욥기 4:18","category":"$undefined"},{"id":"12950","book":"욥기","book_name":"욥기","chapter":4,"verse":19,"text":"하물며 흙 집에 살며 티끌로 터를 삼고 하루살이에게라도 눌려 죽을 자이겠느냐 ?","reference":"욥기 4:19","category":"$undefined"},{"id":"12951","book":"욥기","book_name":"욥기","chapter":4,"verse":20,"text":"조석 사이에 멸한 바 되며 영원히 망하되 생각하는 자가 없으리라","reference":"욥기 4:20","category":"$undefined"},{"id":"12952","book":"욥기","book_name":"욥기","chapter":4,"verse":21,"text":"장막 줄을 그들에게서 뽑지 아니하겠느냐 ? 그들이 죽나니 지혜가 있느니라","reference":"욥기 4:21","category":"$undefined"}],"bookSlug":"job"}]
