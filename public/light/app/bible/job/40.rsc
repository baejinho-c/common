2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":40,"verses":[{"id":"13866","book":"욥기","book_name":"욥기","chapter":40,"verse":1,"text":"네가 능히 낚시로 악어를 낚을 수 있겠느냐 ? 노끈으로 그 혀를 맬수 있겠느냐 ?","reference":"욥기 40:1","category":"$undefined"},{"id":"13867","book":"욥기","book_name":"욥기","chapter":40,"verse":2,"text":"줄로 그 코를 꿸 수 있겠느냐 ? 갈고리로 그 아가미를 꿸 수 있겠느냐 ?","reference":"욥기 40:2","category":"$undefined"},{"id":"13868","book":"욥기","book_name":"욥기","chapter":40,"verse":3,"text":"그것이 어찌 네게 연속 간구하겠느냐 ? 유순한 말로 네게 이야기하겠느냐 ?","reference":"욥기 40:3","category":"$undefined"},{"id":"13869","book":"욥기","book_name":"욥기","chapter":40,"verse":4,"text":"어찌 너와 계약하고 영영히 네 종이 되겠느냐 ?","reference":"욥기 40:4","category":"$undefined"},{"id":"13870","book":"욥기","book_name":"욥기","chapter":40,"verse":5,"text":"네가 어찌 새를 놀리는 것 같이 그것을 놀리겠으며 네 소녀들을 위하여 그것을 매어 두겠느냐 ?","reference":"욥기 40:5","category":"$undefined"},{"id":"13871","book":"욥기","book_name":"욥기","chapter":40,"verse":6,"text":"어찌 어부의 떼가 그것으로 상품을 삼아 상고들 가운데 나눌 수 있겠느냐 ?","reference":"욥기 40:6","category":"$undefined"},{"id":"13872","book":"욥기","book_name":"욥기","chapter":40,"verse":7,"text":"네가 능히 창으로 그 가죽을 찌르거나 작살로 그 머리를 찌를 수 있겠느냐 ?","reference":"욥기 40:7","category":"$undefined"},{"id":"13873","book":"욥기","book_name":"욥기","chapter":40,"verse":8,"text":"손을 그것에게 좀 대어 보라 싸울 일이 생각나서 다시는 아니하리라","reference":"욥기 40:8","category":"$undefined"},{"id":"13874","book":"욥기","book_name":"욥기","chapter":40,"verse":9,"text":"잡으려는 소망은 헛것이라 그것을 보기만 하여도 낙담하지 않겠느냐 ?","reference":"욥기 40:9","category":"$undefined"},{"id":"13875","book":"욥기","book_name":"욥기","chapter":40,"verse":10,"text":"아무도 그것을 격동시킬 용맹이 없거든 능히 나를 당할 자가 누구냐 ?","reference":"욥기 40:10","category":"$undefined"},{"id":"13876","book":"욥기","book_name":"욥기","chapter":40,"verse":11,"text":"누가 먼저 내게 주고 나로 갚게 하였느냐 ? 온 천하에 있는 것이 다 내 것이니라","reference":"욥기 40:11","category":"$undefined"},{"id":"13877","book":"욥기","book_name":"욥기","chapter":40,"verse":12,"text":"내가 악어의 지체와 큰 힘과 훌륭한 구조에 대하여 잠잠치 아니하리라","reference":"욥기 40:12","category":"$undefined"},{"id":"13878","book":"욥기","book_name":"욥기","chapter":40,"verse":13,"text":"누가 그 가죽을 벗기겠으며 그 아가미 사이로 들어가겠는고","reference":"욥기 40:13","category":"$undefined"},{"id":"13879","book":"욥기","book_name":"욥기","chapter":40,"verse":14,"text":"누가 그 얼굴의 문을 열 수 있을까 그 두루 있는 이가 두렵구나","reference":"욥기 40:14","category":"$undefined"},{"id":"13880","book":"욥기","book_name":"욥기","chapter":40,"verse":15,"text":"견고한 비늘은 그의 자랑이라 서로 연함이 봉한 것 같구나","reference":"욥기 40:15","category":"$undefined"},{"id":"13881","book":"욥기","book_name":"욥기","chapter":40,"verse":16,"text":"이것 저것이 한데 붙었으니 바람도 그 사이로 들어가지 못하겠고","reference":"욥기 40:16","category":"$undefined"},{"id":"13882","book":"욥기","book_name":"욥기","chapter":40,"verse":17,"text":"서로 연하여 붙었으니 능히 나눌 수도 없구나","reference":"욥기 40:17","category":"$undefined"},{"id":"13883","book":"욥기","book_name":"욥기","chapter":40,"verse":18,"text":"그것이 재채기를 한즉 광채가 발하고 그 눈은 새벽 눈꺼풀이 열림 같으며","reference":"욥기 40:18","category":"$undefined"},{"id":"13884","book":"욥기","book_name":"욥기","chapter":40,"verse":19,"text":"그 입에서는 횃불이 나오고 불똥이 뛰어나며","reference":"욥기 40:19","category":"$undefined"},{"id":"13885","book":"욥기","book_name":"욥기","chapter":40,"verse":20,"text":"그 콧구멍에서는 연기가 나오니 마치 솥이 끓는 것과 갈대의 타는 것 같구나","reference":"욥기 40:20","category":"$undefined"},{"id":"13886","book":"욥기","book_name":"욥기","chapter":40,"verse":21,"text":"그 숨이 능히 숯불을 피우니 불꽃이 그 입에서 나오며","reference":"욥기 40:21","category":"$undefined"},{"id":"13887","book":"욥기","book_name":"욥기","chapter":40,"verse":22,"text":"힘이 그 목에 뭉키었고 두려움이 그 앞에서 뛰는구나","reference":"욥기 40:22","category":"$undefined"},{"id":"13888","book":"욥기","book_name":"욥기","chapter":40,"verse":23,"text":"그 살의 조각들이 서로 연하고 그 몸에 견고하여 움직이지 아니하며","reference":"욥기 40:23","category":"$undefined"},{"id":"13889","book":"욥기","book_name":"욥기","chapter":40,"verse":24,"text":"그 마음이 돌 같이 단단하니 그 단단함이 맷돌 아랫짝 같구나 [ (Job 40:25) 그것이 일어나면 용사라도 두려워하며 경겁하여 창황하며 ] [ (Job 40:26) 칼로 칠지라도 쓸데없고 창이나 살이나 작살도 소용이 없구나 ] [ (Job 40:27) 그것이 철을 초개 같이, 놋을 썩은 나무 같이 여기니 ] [ (Job 40:28) 살이라도 그것으로 도망하게 못하겠고 물매돌도 그것에게는 겨같이 여기우는구나 ] [ (Job 40:29) 몽둥이도 검불 같이 보고 창을 던짐을 우습게 여기며 ] [ (Job 40:30) 그 배 아래는 날카로운 와륵 같으니 진흙 위에 타작 기계 같이 자취를 내는구나 ] [ (Job 40:31) 깊은 물로 솥의 물이 끓음 같게 하며 바다로 젖는 향기름 같게 하고 ] [ (Job 40:32) 자기 뒤에 광채나는 길을 내니 사람의 보기에 바닷물이 백발 같구나 ] [ (Job 40:33) 땅 위에는 그것 같은 것이 없나니 두려움 없게 지음을 받았음이라 ] [ (Job 40:34) 모든 높은 것을 낮게 보고 모든 교만한 것의 왕이 되느니라 ]","reference":"욥기 40:24","category":"$undefined"}],"bookSlug":"job"}]
