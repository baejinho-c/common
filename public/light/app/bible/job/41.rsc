2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":41,"verses":[{"id":"13890","book":"욥기","book_name":"욥기","chapter":41,"verse":1,"text":"욥이 여호와께 대답하여 가로되","reference":"욥기 41:1","category":"$undefined"},{"id":"13891","book":"욥기","book_name":"욥기","chapter":41,"verse":2,"text":"주께서는 무소불능하시오며 무슨 경영이든지 못 이루실 것이 없는 줄 아오니","reference":"욥기 41:2","category":"$undefined"},{"id":"13892","book":"욥기","book_name":"욥기","chapter":41,"verse":3,"text":"무지한 말로 이치를 가리우는 자가 누구니이까 내가 스스로 깨달을 수 없는 일을 말하였고 스스로 알 수 없고 헤아리기 어려운 일을 말하였나이다","reference":"욥기 41:3","category":"$undefined"},{"id":"13893","book":"욥기","book_name":"욥기","chapter":41,"verse":4,"text":"내가 말하겠사오니 주여 ! 들으시고 내가 주께 묻겠사오니 주여 ! 내게 알게 하옵소서","reference":"욥기 41:4","category":"$undefined"},{"id":"13894","book":"욥기","book_name":"욥기","chapter":41,"verse":5,"text":"내가 주께 대하여 귀로 듣기만 하였삽더니 이제는 눈으로 주를 뵈옵나이다 !","reference":"욥기 41:5","category":"$undefined"},{"id":"13895","book":"욥기","book_name":"욥기","chapter":41,"verse":6,"text":"그러므로 내가 스스로 한하고 티끌과 재 가운데서 회개하나이다 !","reference":"욥기 41:6","category":"$undefined"},{"id":"13896","book":"욥기","book_name":"욥기","chapter":41,"verse":7,"text":"여호와께서 욥에게 이 말씀을 하신 후에 데만 사람 엘리바스에게 이르시되 내가 너와 네 두 친구에게 노하나니 이는 너희가 나를 가리켜 말한 것이 내 종 욥의 말 같이 정당하지 못함이니라","reference":"욥기 41:7","category":"$undefined"},{"id":"13897","book":"욥기","book_name":"욥기","chapter":41,"verse":8,"text":"그런즉 너희는 수송아지 일곱과 수양 일곱을 취하여 내 종 욥에게 가서 너희를 위하여 번제를 드리라 내 종 욥이 너희를 위하여기도할 것인즉 내가 그를 기쁘게 받으리니 너희의 우매한대로 너희에게 갚지 아니하리라 이는 너희가 나를 가리켜 말한 것이 내 종 욥의 말 같이 정당하지 못함이니라","reference":"욥기 41:8","category":"$undefined"},{"id":"13898","book":"욥기","book_name":"욥기","chapter":41,"verse":9,"text":"이에 데만 사람 엘리바스와 수아 사람 빌닷과 나아마 사람 소발이 가서 여호와께서 자기들에게 명하신 대로 행하니라 여호와께서 욥을 기쁘게 받으셨더라","reference":"욥기 41:9","category":"$undefined"},{"id":"13899","book":"욥기","book_name":"욥기","chapter":41,"verse":10,"text":"욥이 그 벗들을 위하여 빌매 여호와께서 욥의 곤경을 돌이키시고 욥에게 그전 소유보다 갑절이나 주신지라","reference":"욥기 41:10","category":"$undefined"},{"id":"13900","book":"욥기","book_name":"욥기","chapter":41,"verse":11,"text":"이에 그의 모든 형제와 자매와 및 전에 알던 자들이 다 와서 그 집에서 그와 함께 식물을 먹고 여호와께서 그에게 내리신 모든 재앙에 대하여 그를 위하여 슬퍼하며 위로하고 각각 금 한 조각과 금고리 하나씩 주었더라","reference":"욥기 41:11","category":"$undefined"},{"id":"13901","book":"욥기","book_name":"욥기","chapter":41,"verse":12,"text":"여호와께서 욥의 모년에 복을 주사 처음 복보다 더 하게 하시니 그가 양 일만 사천과 약대 육천과 소 일천 겨리와 암나귀 일천을 두었고","reference":"욥기 41:12","category":"$undefined"},{"id":"13902","book":"욥기","book_name":"욥기","chapter":41,"verse":13,"text":"또 아들 일곱과 딸 셋을 낳았으며","reference":"욥기 41:13","category":"$undefined"},{"id":"13903","book":"욥기","book_name":"욥기","chapter":41,"verse":14,"text":"그가 첫째 딸은 여미마라 이름하였고 둘째 딸은 긋시아라 이름하였고 세째 딸은 게렌합북이라 이름하였으며","reference":"욥기 41:14","category":"$undefined"},{"id":"13904","book":"욥기","book_name":"욥기","chapter":41,"verse":15,"text":"전국 중에 욥의 딸들처럼 아리따운 여자가 없었더라 그 아비가 그들에게 그 오라비처럼 산업을 주었더라","reference":"욥기 41:15","category":"$undefined"},{"id":"13905","book":"욥기","book_name":"욥기","chapter":41,"verse":16,"text":"그 후에 욥이 일백 사십년을 살며 아들과 손자 사대를 보았고","reference":"욥기 41:16","category":"$undefined"},{"id":"13906","book":"욥기","book_name":"욥기","chapter":41,"verse":17,"text":"나이 늙고 기한이 차서 죽었더라","reference":"욥기 41:17","category":"$undefined"},{"id":"13907","book":"욥기","book_name":"욥기","chapter":41,"verse":18,"text":"","reference":"욥기 41:18","category":"$undefined"},{"id":"13908","book":"욥기","book_name":"욥기","chapter":41,"verse":19,"text":"","reference":"욥기 41:19","category":"$undefined"},{"id":"13909","book":"욥기","book_name":"욥기","chapter":41,"verse":20,"text":"","reference":"욥기 41:20","category":"$undefined"},{"id":"13910","book":"욥기","book_name":"욥기","chapter":41,"verse":21,"text":"","reference":"욥기 41:21","category":"$undefined"},{"id":"13911","book":"욥기","book_name":"욥기","chapter":41,"verse":22,"text":"","reference":"욥기 41:22","category":"$undefined"},{"id":"13912","book":"욥기","book_name":"욥기","chapter":41,"verse":23,"text":"","reference":"욥기 41:23","category":"$undefined"},{"id":"13913","book":"욥기","book_name":"욥기","chapter":41,"verse":24,"text":"","reference":"욥기 41:24","category":"$undefined"},{"id":"13914","book":"욥기","book_name":"욥기","chapter":41,"verse":25,"text":"","reference":"욥기 41:25","category":"$undefined"},{"id":"13915","book":"욥기","book_name":"욥기","chapter":41,"verse":26,"text":"","reference":"욥기 41:26","category":"$undefined"},{"id":"13916","book":"욥기","book_name":"욥기","chapter":41,"verse":27,"text":"","reference":"욥기 41:27","category":"$undefined"},{"id":"13917","book":"욥기","book_name":"욥기","chapter":41,"verse":28,"text":"","reference":"욥기 41:28","category":"$undefined"},{"id":"13918","book":"욥기","book_name":"욥기","chapter":41,"verse":29,"text":"","reference":"욥기 41:29","category":"$undefined"},{"id":"13919","book":"욥기","book_name":"욥기","chapter":41,"verse":30,"text":"","reference":"욥기 41:30","category":"$undefined"},{"id":"13920","book":"욥기","book_name":"욥기","chapter":41,"verse":31,"text":"","reference":"욥기 41:31","category":"$undefined"},{"id":"13921","book":"욥기","book_name":"욥기","chapter":41,"verse":32,"text":"","reference":"욥기 41:32","category":"$undefined"},{"id":"13922","book":"욥기","book_name":"욥기","chapter":41,"verse":33,"text":"","reference":"욥기 41:33","category":"$undefined"},{"id":"13923","book":"욥기","book_name":"욥기","chapter":41,"verse":34,"text":"","reference":"욥기 41:34","category":"$undefined"}],"bookSlug":"job"}]
