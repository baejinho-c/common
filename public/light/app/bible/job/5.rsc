2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":5,"verses":[{"id":"12953","book":"욥기","book_name":"욥기","chapter":5,"verse":1,"text":"부르짖어 보아라 ! 네게 응답할 자가 있겠느냐 ? 거룩한 자 중에 네가 누구에게로 향하겠느냐 ?","reference":"욥기 5:1","category":"$undefined"},{"id":"12954","book":"욥기","book_name":"욥기","chapter":5,"verse":2,"text":"분노가 미련한 자를 죽이고 시기가 어리석은 자를 멸하느니라","reference":"욥기 5:2","category":"$undefined"},{"id":"12955","book":"욥기","book_name":"욥기","chapter":5,"verse":3,"text":"내가 미련한 자의 뿌리 박는 것을 보고 그 집을 당장에 저주하였노라","reference":"욥기 5:3","category":"$undefined"},{"id":"12956","book":"욥기","book_name":"욥기","chapter":5,"verse":4,"text":"그 자식들은 평안한 데서 멀리 떠나고 성문에서 눌리나 구하는 자가 없으며","reference":"욥기 5:4","category":"$undefined"},{"id":"12957","book":"욥기","book_name":"욥기","chapter":5,"verse":5,"text":"그 추수한 것은 주린 자가 먹되 가시나무 가운데 있는 것도 빼앗으며 올무가 그의 재산을 향하여 입을 벌리느니라","reference":"욥기 5:5","category":"$undefined"},{"id":"12958","book":"욥기","book_name":"욥기","chapter":5,"verse":6,"text":"재앙은 티끌에서 일어나는 것이 아니요 고난은 흙에서 나는 것이 아니라","reference":"욥기 5:6","category":"$undefined"},{"id":"12959","book":"욥기","book_name":"욥기","chapter":5,"verse":7,"text":"인생은 고난을 위하여 났나니 불티가 위로 날음 같으니라","reference":"욥기 5:7","category":"$undefined"},{"id":"12960","book":"욥기","book_name":"욥기","chapter":5,"verse":8,"text":"나 같으면 하나님께 구하고 내 일을 하나님께 의탁하리라 !","reference":"욥기 5:8","category":"$undefined"},{"id":"12961","book":"욥기","book_name":"욥기","chapter":5,"verse":9,"text":"하나님은 크고 측량할 수 없는 일을 행하시며 기이한 일을 셀 수 없이 행하시나니","reference":"욥기 5:9","category":"$undefined"},{"id":"12962","book":"욥기","book_name":"욥기","chapter":5,"verse":10,"text":"비를 땅에 내리시고 물을 밭에 보내시며","reference":"욥기 5:10","category":"$undefined"},{"id":"12963","book":"욥기","book_name":"욥기","chapter":5,"verse":11,"text":"낮은 자를 높이 드시고 슬퍼하는 자를 흥기시켜 안전한 곳에 있게 하시느니라","reference":"욥기 5:11","category":"$undefined"},{"id":"12964","book":"욥기","book_name":"욥기","chapter":5,"verse":12,"text":"하나님은 궤휼한 자의 계교를 파하사 그 손으로 하는 일을 이루지 못하게 하시며","reference":"욥기 5:12","category":"$undefined"},{"id":"12965","book":"욥기","book_name":"욥기","chapter":5,"verse":13,"text":"간교한 자로 자기 궤휼에 빠지게 하시며 사특한 자의 계교를 패하게 하시며","reference":"욥기 5:13","category":"$undefined"},{"id":"12966","book":"욥기","book_name":"욥기","chapter":5,"verse":14,"text":"그들은 낮에도 캄캄함을 만나고 대낮에도 더듬기를 밤과 같이 하느니라","reference":"욥기 5:14","category":"$undefined"},{"id":"12967","book":"욥기","book_name":"욥기","chapter":5,"verse":15,"text":"하나님은 곤비한 자를 그들의 입의 칼에서, 강한 자의 손에서 면하게 하시나니","reference":"욥기 5:15","category":"$undefined"},{"id":"12968","book":"욥기","book_name":"욥기","chapter":5,"verse":16,"text":"그러므로 가난한 자가 소망이 있고 불의가 스스로 입을 막느니라","reference":"욥기 5:16","category":"$undefined"},{"id":"12969","book":"욥기","book_name":"욥기","chapter":5,"verse":17,"text":"볼지어다 ! 하나님께 징계받는 자에게는 복이 있나니 그런즉 너는 전능자의 경책을 업신여기지 말지니라 !","reference":"욥기 5:17","category":"$undefined"},{"id":"12970","book":"욥기","book_name":"욥기","chapter":5,"verse":18,"text":"하나님은 아프게 하시다가 싸매시며, 상하게 하시다가 그 손으로 고치시나니","reference":"욥기 5:18","category":"$undefined"},{"id":"12971","book":"욥기","book_name":"욥기","chapter":5,"verse":19,"text":"여섯가지 환난에서 너를 구원하시며 일곱가지 환난이라도 그 재앙이 네게 미치지 않게 하시며","reference":"욥기 5:19","category":"$undefined"},{"id":"12972","book":"욥기","book_name":"욥기","chapter":5,"verse":20,"text":"기근 때에 죽음에서, 전쟁 때에 칼 권세에서 너를 구속하실 터인즉","reference":"욥기 5:20","category":"$undefined"},{"id":"12973","book":"욥기","book_name":"욥기","chapter":5,"verse":21,"text":"네가 혀의 채찍을 피하여 숨을 수가 있고 멸망이 올 때에도 두려워 아니할 것이라","reference":"욥기 5:21","category":"$undefined"},{"id":"12974","book":"욥기","book_name":"욥기","chapter":5,"verse":22,"text":"네가 멸망과 기근을 비웃으며 들짐승을 두려워 아니할 것은","reference":"욥기 5:22","category":"$undefined"},{"id":"12975","book":"욥기","book_name":"욥기","chapter":5,"verse":23,"text":"밭에 돌이 너와 언약을 맺겠고 들짐승이 너와 화친할 것임이라","reference":"욥기 5:23","category":"$undefined"},{"id":"12976","book":"욥기","book_name":"욥기","chapter":5,"verse":24,"text":"네가 네 장막의 평안함을 알고 네 우리를 살펴도 잃은 것이 없을 것이며","reference":"욥기 5:24","category":"$undefined"},{"id":"12977","book":"욥기","book_name":"욥기","chapter":5,"verse":25,"text":"네 자손이 많아지며 네 후예가 땅에 풀 같을 줄을 네가 알것이라","reference":"욥기 5:25","category":"$undefined"},{"id":"12978","book":"욥기","book_name":"욥기","chapter":5,"verse":26,"text":"네가 장수하다가 무덤에 이르리니 곡식단이 그 기한에 운반되어 올리움 같으리라","reference":"욥기 5:26","category":"$undefined"},{"id":"12979","book":"욥기","book_name":"욥기","chapter":5,"verse":27,"text":"볼지어다 ! 우리의 연구한 바가 이같으니 너는 듣고 네게 유익된 줄 알지니라","reference":"욥기 5:27","category":"$undefined"}],"bookSlug":"job"}]
