2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":6,"verses":[{"id":"12980","book":"욥기","book_name":"욥기","chapter":6,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 6:1","category":"$undefined"},{"id":"12981","book":"욥기","book_name":"욥기","chapter":6,"verse":2,"text":"나의 분한을 달아 보며 나의 모든 재앙을 저울에 둘 수 있으면","reference":"욥기 6:2","category":"$undefined"},{"id":"12982","book":"욥기","book_name":"욥기","chapter":6,"verse":3,"text":"바다 모래보다도 무거울 것이라 그럼으로 하여 나의 말이 경솔하였구나","reference":"욥기 6:3","category":"$undefined"},{"id":"12983","book":"욥기","book_name":"욥기","chapter":6,"verse":4,"text":"전능자의 살이 내 몸에 박히매 나의 영이 그 독을 마셨나니 하나님의 두려움이 나를 엄습하여 치는구나","reference":"욥기 6:4","category":"$undefined"},{"id":"12984","book":"욥기","book_name":"욥기","chapter":6,"verse":5,"text":"들 나귀가 풀이 있으면 어찌 울겠으며 소가 꼴이 있으면 어찌 울겠느냐 ?","reference":"욥기 6:5","category":"$undefined"},{"id":"12985","book":"욥기","book_name":"욥기","chapter":6,"verse":6,"text":"싱거운 것이 소금 없이 먹히겠느냐 ? 닭의 알 흰자위가 맛이 있겠느냐 ?","reference":"욥기 6:6","category":"$undefined"},{"id":"12986","book":"욥기","book_name":"욥기","chapter":6,"verse":7,"text":"이런 것을 만지기도 내 마음이 싫어하나니 못된 식물 같이 여김이니라","reference":"욥기 6:7","category":"$undefined"},{"id":"12987","book":"욥기","book_name":"욥기","chapter":6,"verse":8,"text":"하나님이 나의 구하는 것을 얻게 하시며 나의 사모하는 것 주시기를 내가 원하나니","reference":"욥기 6:8","category":"$undefined"},{"id":"12988","book":"욥기","book_name":"욥기","chapter":6,"verse":9,"text":"이는 곧 나를 멸하시기를 기뻐하사 그 손을 들어 나를 끊으실 것이라","reference":"욥기 6:9","category":"$undefined"},{"id":"12989","book":"욥기","book_name":"욥기","chapter":6,"verse":10,"text":"그러할지라도 내가 오히려 위로를 받고 무정한 고통 가운데서도 기뻐할 것은 내가 거룩하신 이의 말씀을 거역지 아니하였음이니라","reference":"욥기 6:10","category":"$undefined"},{"id":"12990","book":"욥기","book_name":"욥기","chapter":6,"verse":11,"text":"내가 무슨 기력이 있관대 기다리겠느냐 ? 내 마지막이 어떠하겠관대 오히려 참겠느냐 ?","reference":"욥기 6:11","category":"$undefined"},{"id":"12991","book":"욥기","book_name":"욥기","chapter":6,"verse":12,"text":"나의 기력이 어찌 돌의 기력이겠느냐 ? 나의 살이 어찌 놋쇠겠느냐 ?","reference":"욥기 6:12","category":"$undefined"},{"id":"12992","book":"욥기","book_name":"욥기","chapter":6,"verse":13,"text":"나의 도움이 내 속에 없지 아니하냐 ? 나의 지혜가 내게서 쫓겨나지 아니하였느냐 ?","reference":"욥기 6:13","category":"$undefined"},{"id":"12993","book":"욥기","book_name":"욥기","chapter":6,"verse":14,"text":"피곤한 자 곧 전능자 경외하는 일을 폐한 자를 그 벗이 불쌍히 여길 것이어늘","reference":"욥기 6:14","category":"$undefined"},{"id":"12994","book":"욥기","book_name":"욥기","chapter":6,"verse":15,"text":"나의 형제는 내게 성실치 아니함이 시냇물의 마름 같고 개울의 잦음 같구나","reference":"욥기 6:15","category":"$undefined"},{"id":"12995","book":"욥기","book_name":"욥기","chapter":6,"verse":16,"text":"얼음이 녹으면 물이 검어지며 눈이 그 속에 감취었을지라도","reference":"욥기 6:16","category":"$undefined"},{"id":"12996","book":"욥기","book_name":"욥기","chapter":6,"verse":17,"text":"따뜻하면 마르고 더우면 그 자리에서 아주 없어지나니","reference":"욥기 6:17","category":"$undefined"},{"id":"12997","book":"욥기","book_name":"욥기","chapter":6,"verse":18,"text":"떼를 지은 객들이 시냇가로 다니다가 돌이켜 광야로 가서 죽고","reference":"욥기 6:18","category":"$undefined"},{"id":"12998","book":"욥기","book_name":"욥기","chapter":6,"verse":19,"text":"데마의 떼들이 그것을 바라보고 스바의 행인들도 그것을 사모하다가","reference":"욥기 6:19","category":"$undefined"},{"id":"12999","book":"욥기","book_name":"욥기","chapter":6,"verse":20,"text":"거기 와서는 바라던 것을 부끄리고 낙심하느니라","reference":"욥기 6:20","category":"$undefined"},{"id":"13000","book":"욥기","book_name":"욥기","chapter":6,"verse":21,"text":"너희도 허망한 자라 너희가 두려운 일을 본즉 겁내는구나","reference":"욥기 6:21","category":"$undefined"},{"id":"13001","book":"욥기","book_name":"욥기","chapter":6,"verse":22,"text":"내가 언제 너희에게 나를 공급하라 하더냐 ? 언제 나를 위하여 너희 재물로 예물을 달라더냐 ?","reference":"욥기 6:22","category":"$undefined"},{"id":"13002","book":"욥기","book_name":"욥기","chapter":6,"verse":23,"text":"내가 언제 말하기를 대적의 손에서 나를 구원하라 하더냐 ? 포악한 자의 손에서 나를 구속하라 하더냐 ?","reference":"욥기 6:23","category":"$undefined"},{"id":"13003","book":"욥기","book_name":"욥기","chapter":6,"verse":24,"text":"내게 가르쳐서 나의 허물된 것을 깨닫게 하라 내가 잠잠하리라","reference":"욥기 6:24","category":"$undefined"},{"id":"13004","book":"욥기","book_name":"욥기","chapter":6,"verse":25,"text":"옳은 말은 어찌 그리 유력한지, 그렇지만 너희의 책망은 무엇을 책망함이뇨","reference":"욥기 6:25","category":"$undefined"},{"id":"13005","book":"욥기","book_name":"욥기","chapter":6,"verse":26,"text":"너희가 말을 책망하려느냐 ? 소망이 끊어진 자의 말은 바람 같으니라","reference":"욥기 6:26","category":"$undefined"},{"id":"13006","book":"욥기","book_name":"욥기","chapter":6,"verse":27,"text":"너희는 고아를 제비 뽑으며 너희 벗을 매매할 자로구나","reference":"욥기 6:27","category":"$undefined"},{"id":"13007","book":"욥기","book_name":"욥기","chapter":6,"verse":28,"text":"이제 너희가 나를 향하여 보기를 원하노라 내가 너희를 대면하여 결코 거짓말하지 아니하리라","reference":"욥기 6:28","category":"$undefined"},{"id":"13008","book":"욥기","book_name":"욥기","chapter":6,"verse":29,"text":"너희는 돌이켜 불의한 것이 없게 하기를 원하노라 너희는 돌이키라 내 일이 의로우니라","reference":"욥기 6:29","category":"$undefined"},{"id":"13009","book":"욥기","book_name":"욥기","chapter":6,"verse":30,"text":"내 혀에 어찌 불의한 것이 있으랴 내 미각이 어찌 궤휼을 분변치 못하랴","reference":"욥기 6:30","category":"$undefined"}],"bookSlug":"job"}]
