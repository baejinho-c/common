11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":7,"verses":[{"id":"13010","book":"욥기","book_name":"욥기","chapter":7,"verse":1,"text":"세상에 있는 인생에게 전쟁이 있지 아니하냐 ? 그 날이 품군의 날과 같지 아니하냐 ?","reference":"욥기 7:1","category":"$undefined"},{"id":"13011","book":"욥기","book_name":"욥기","chapter":7,"verse":2,"text":"종은 저물기를 심히 기다리고 품군은 그 삯을 바라나니","reference":"욥기 7:2","category":"$undefined"},{"id":"13012","book":"욥기","book_name":"욥기","chapter":7,"verse":3,"text":"이와 같이 내가 여러 달째 곤고를 받으니 수고로운 밤이 내게 작정되었구나","reference":"욥기 7:3","category":"$undefined"},{"id":"13013","book":"욥기","book_name":"욥기","chapter":7,"verse":4,"text":"내가 누울 때면 말하기를 언제나 일어날꼬 언제나 밤이 갈꼬 하며 새벽까지 이리 뒤척, 저리 뒤척 하는구나","reference":"욥기 7:4","category":"$undefined"},{"id":"13014","book":"욥기","book_name":"욥기","chapter":7,"verse":5,"text":"내 살에는 구더기와 흙 조각이 의복처럼 입혔고 내 가죽은 합창 되었다가 터지는구나","reference":"욥기 7:5","category":"$undefined"},{"id":"13015","book":"욥기","book_name":"욥기","chapter":7,"verse":6,"text":"나의 날은 베틀의 북보다 빠르니 소망없이 보내는구나","reference":"욥기 7:6","category":"$undefined"},{"id":"13016","book":"욥기","book_name":"욥기","chapter":7,"verse":7,"text":"내 생명이 한 호흡 같음을 생각하옵소서 ! 나의 눈이 다시 복된 것을 보지 못하리이다","reference":"욥기 7:7","category":"$undefined"},{"id":"13017","book":"욥기","book_name":"욥기","chapter":7,"verse":8,"text":"나를 본 자의 눈이 다시는 나를 보지 못할 것이고 주의 눈이 나를 향하실지라도 내가 있지 아니하리이다","reference":"욥기 7:8","category":"$undefined"},{"id":"13018","book":"욥기","book_name":"욥기","chapter":7,"verse":9,"text":"구름이 사라져 없어짐 같이 음부로 내려가는 자는 다시 올라오지 못할 것이오니","reference":"욥기 7:9","category":"$undefined"},{"id":"13019","book":"욥기","book_name":"욥기","chapter":7,"verse":10,"text":"그는 다시 자기 집으로 돌아가지 못하겠고 자기 처소도 다시 그를 알지 못하리이다","reference":"욥기 7:10","category":"$undefined"},{"id":"13020","book":"욥기","book_name":"욥기","chapter":7,"verse":11,"text":"그런즉 내가 내 입을 금하지 아니하고 내 마음의 아픔을 인하여 말하며 내 영혼의 괴로움을 인하여 원망하리이다","reference":"욥기 7:11","category":"$undefined"},{"id":"13021","book":"욥기","book_name":"욥기","chapter":7,"verse":12,"text":"내가 바다니이까 ? 용이니이까 ? 주께서 어찌하여 나를 지키시나이까 ?","reference":"욥기 7:12","category":"$undefined"},{"id":"13022","book":"욥기","book_name":"욥기","chapter":7,"verse":13,"text":"혹시 내가 말하기를 내 자리가 나를 위로하고 내 침상이 내 수심을 풀리라 할 때에","reference":"욥기 7:13","category":"$undefined"},{"id":"13023","book":"욥기","book_name":"욥기","chapter":7,"verse":14,"text":"주께서 꿈으로 나를 놀래시고 이상으로 나를 두렵게 하시나이다","reference":"욥기 7:14","category":"$undefined"},{"id":"13024","book":"욥기","book_name":"욥기","chapter":7,"verse":15,"text":"이러므로 내 마음에 숨이 막히기를 원하오니 뼈보다도 죽는 것이 나으니이다","reference":"욥기 7:15","category":"$undefined"},{"id":"13025","book":"욥기","book_name":"욥기","chapter":7,"verse":16,"text":"내가 생명을 싫어하고 항상 살기를 원치 아니하오니 나를 놓으소서 내 날은 헛 것이니이다","reference":"욥기 7:16","category":"$undefined"},{"id":"13026","book":"욥기","book_name":"욥기","chapter":7,"verse":17,"text":"사람이 무엇이관대 주께서 크게 여기사 그에게 마음을 두시고","reference":"욥기 7:17","category":"$undefined"},{"id":"13027","book":"욥기","book_name":"욥기","chapter":7,"verse":18,"text":"아침마다 권징하시며 분초마다 시험하시나이까 ?","reference":"욥기 7:18","category":"$undefined"},{"id":"13028","book":"욥기","book_name":"욥기","chapter":7,"verse":19,"text":"주께서 내게서 눈을 돌이키지 아니하시며 나의 침 삼킬 동안도 나를 놓지 아니하시기를 어느 때까지 하시리이까 ?","reference":"욥기 7:19","category":"$undefined"},{"id":"13029","book":"욥기","book_name":"욥기","chapter":7,"verse":20,"text":"사람을 감찰하시는 자여 ! 내가 범죄하였은들 주께 무슨 해가 되오리이까 ? 어찌하여 나로 과녁을 삼으셔서 스스로 무거운 짐이 되게 하셨나이까 ?","reference":"욥기 7:20","category":"$undefined"},{"id":"13030","book":"욥기","book_name":"욥기","chapter":7,"verse":21,"text":"주께서 어찌하여 내 허물을 사하여 주지 아니하시며 내 죄악을 제하여 버리지 아니 하시나이까 ? 내가 이제 흙에 누우리니 주께서 나를 부지런히 찾으실지라도 내가 있지 아니하리이다","reference":"욥기 7:21","category":"$undefined"}],"bookSlug":"job"}]
