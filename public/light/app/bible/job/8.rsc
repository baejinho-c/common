2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":8,"verses":[{"id":"13031","book":"욥기","book_name":"욥기","chapter":8,"verse":1,"text":"수아 사람 빌닷이 대답하여 가로되","reference":"욥기 8:1","category":"$undefined"},{"id":"13032","book":"욥기","book_name":"욥기","chapter":8,"verse":2,"text":"네가 어느 때까지 이런 말을 하겠으며 어느 때까지 네 입의 말이 광풍과 같겠는가","reference":"욥기 8:2","category":"$undefined"},{"id":"13033","book":"욥기","book_name":"욥기","chapter":8,"verse":3,"text":"하나님이 어찌 심판을 굽게 하시겠으며 전능하신 이가 어찌 공의를 굽게 하시겠는가","reference":"욥기 8:3","category":"$undefined"},{"id":"13034","book":"욥기","book_name":"욥기","chapter":8,"verse":4,"text":"네 자녀들이 주께 득죄하였으므로 주께서 그들을 그 죄에 붙이셨나니","reference":"욥기 8:4","category":"$undefined"},{"id":"13035","book":"욥기","book_name":"욥기","chapter":8,"verse":5,"text":"네가 만일 하나님을 부지런히 구하며 전능하신 이에게 빌고","reference":"욥기 8:5","category":"$undefined"},{"id":"13036","book":"욥기","book_name":"욥기","chapter":8,"verse":6,"text":"또 청결하고 정직하면 정녕 너를 돌아보시고 네 의로운 집으로 형통하게 하실 것이라","reference":"욥기 8:6","category":"$undefined"},{"id":"13037","book":"욥기","book_name":"욥기","chapter":8,"verse":7,"text":"네 시작은 미약하였으나 네 나중은 심히 창대하리라 !","reference":"욥기 8:7","category":"$undefined"},{"id":"13038","book":"욥기","book_name":"욥기","chapter":8,"verse":8,"text":"청컨대 너는 옛시대 사람에게 물으며 열조의 터득한 일을 배울지어다","reference":"욥기 8:8","category":"$undefined"},{"id":"13039","book":"욥기","book_name":"욥기","chapter":8,"verse":9,"text":"(우리는 어제부터 있었을 뿐이라 지식이 망매하니 세상에 있는 날이 그림자와 같으니라)","reference":"욥기 8:9","category":"$undefined"},{"id":"13040","book":"욥기","book_name":"욥기","chapter":8,"verse":10,"text":"그들이 네게 가르쳐 이르지 아니하겠느냐 ? 그 마음에서 나는 말을 발하지 아니하겠느냐 ?","reference":"욥기 8:10","category":"$undefined"},{"id":"13041","book":"욥기","book_name":"욥기","chapter":8,"verse":11,"text":"왕골이 진펄이 아니고 나겠으며 갈대가 물 없이 자라겠느냐 ?","reference":"욥기 8:11","category":"$undefined"},{"id":"13042","book":"욥기","book_name":"욥기","chapter":8,"verse":12,"text":"이런 것은 푸르러도 아직 벨 때 되기 전에 다른 풀보다 일찌기 마르느니라","reference":"욥기 8:12","category":"$undefined"},{"id":"13043","book":"욥기","book_name":"욥기","chapter":8,"verse":13,"text":"하나님을 잊어버리는 자의 길은 다 이와 같고 사곡한 자의 소망은 없어지리니","reference":"욥기 8:13","category":"$undefined"},{"id":"13044","book":"욥기","book_name":"욥기","chapter":8,"verse":14,"text":"그 믿는 것이 끊어지고 그 의지하는 것이 거미줄 같은즉","reference":"욥기 8:14","category":"$undefined"},{"id":"13045","book":"욥기","book_name":"욥기","chapter":8,"verse":15,"text":"그 집을 의지할지라도 집이 서지 못하고 굳게 잡아도 집이 보존되지 못하리라","reference":"욥기 8:15","category":"$undefined"},{"id":"13046","book":"욥기","book_name":"욥기","chapter":8,"verse":16,"text":"식물이 일광을 받고 푸르러서 그 가지가 동산에 벋어가며","reference":"욥기 8:16","category":"$undefined"},{"id":"13047","book":"욥기","book_name":"욥기","chapter":8,"verse":17,"text":"그 뿌리가 돌 무더기에 서리어서 돌 가운데로 들어 갔을지라도","reference":"욥기 8:17","category":"$undefined"},{"id":"13048","book":"욥기","book_name":"욥기","chapter":8,"verse":18,"text":"그 곳에서 뽑히면 그 자리도 모르는 체하고 이르기를 내가 너를 보지 못하였다 하리니","reference":"욥기 8:18","category":"$undefined"},{"id":"13049","book":"욥기","book_name":"욥기","chapter":8,"verse":19,"text":"그 길의 희락은 이와 같고 그 후에 다른 것이 흙에서 나리라","reference":"욥기 8:19","category":"$undefined"},{"id":"13050","book":"욥기","book_name":"욥기","chapter":8,"verse":20,"text":"하나님은 순전한 사람을 버리지 아니하시고 악한 자를 붙들어 주지 아니하신즉","reference":"욥기 8:20","category":"$undefined"},{"id":"13051","book":"욥기","book_name":"욥기","chapter":8,"verse":21,"text":"웃음으로 네 입에, 즐거운 소리로 네 입술에 채우시리니","reference":"욥기 8:21","category":"$undefined"},{"id":"13052","book":"욥기","book_name":"욥기","chapter":8,"verse":22,"text":"너를 미워하는 자는 부끄러움을 입을 것이라 악인의 장막은 없어지리라","reference":"욥기 8:22","category":"$undefined"}],"bookSlug":"job"}]
