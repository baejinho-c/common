2:["$","$L11",null,{"book":{"id":"job","name":"욥기","chapters":42,"testament":"old"},"chapter":9,"verses":[{"id":"13053","book":"욥기","book_name":"욥기","chapter":9,"verse":1,"text":"욥이 대답하여 가로되","reference":"욥기 9:1","category":"$undefined"},{"id":"13054","book":"욥기","book_name":"욥기","chapter":9,"verse":2,"text":"내가 진실로 그 일이 그런 줄을 알거니와 인생이 어찌 하나님 앞에 의로우랴","reference":"욥기 9:2","category":"$undefined"},{"id":"13055","book":"욥기","book_name":"욥기","chapter":9,"verse":3,"text":"사람이 하나님과 쟁변하려 할지라도 천 마디에 한 마디도 대답하지 못하리라","reference":"욥기 9:3","category":"$undefined"},{"id":"13056","book":"욥기","book_name":"욥기","chapter":9,"verse":4,"text":"하나님은 마음이 지혜로우시고 힘이 강하시니 스스로 강퍅히 하여 그를 거역하고 형통한 자가 누구이랴","reference":"욥기 9:4","category":"$undefined"},{"id":"13057","book":"욥기","book_name":"욥기","chapter":9,"verse":5,"text":"그가 진노하심으로 산을 무너뜨리시며 옮기실지라도 산이 깨닫지 못하며","reference":"욥기 9:5","category":"$undefined"},{"id":"13058","book":"욥기","book_name":"욥기","chapter":9,"verse":6,"text":"그가 땅을 움직여 그 자리에서 미신즉 그 기둥이 흔들리며","reference":"욥기 9:6","category":"$undefined"},{"id":"13059","book":"욥기","book_name":"욥기","chapter":9,"verse":7,"text":"그가 해를 명하여 뜨지 못하게 하시며 별들을 봉하시며","reference":"욥기 9:7","category":"$undefined"},{"id":"13060","book":"욥기","book_name":"욥기","chapter":9,"verse":8,"text":"그가 홀로 하늘을 펴시며 바다 물결을 밟으시며","reference":"욥기 9:8","category":"$undefined"},{"id":"13061","book":"욥기","book_name":"욥기","chapter":9,"verse":9,"text":"북두성과 삼성과 묘성과 남방의 밀실을 만드셨으며","reference":"욥기 9:9","category":"$undefined"},{"id":"13062","book":"욥기","book_name":"욥기","chapter":9,"verse":10,"text":"측량할 수 없는 큰 일을, 셀 수 없는 기이한 일을 행하시느니라","reference":"욥기 9:10","category":"$undefined"},{"id":"13063","book":"욥기","book_name":"욥기","chapter":9,"verse":11,"text":"그가 내 앞으로 지나시나 내가 보지 못하며 그가 내 앞에서 나아 가시나 내가 깨닫지 못하느니라","reference":"욥기 9:11","category":"$undefined"},{"id":"13064","book":"욥기","book_name":"욥기","chapter":9,"verse":12,"text":"하나님이 빼앗으시면 누가 막을 수 있으며 무엇을 하시나이까 ? 누가 물을 수 있으랴","reference":"욥기 9:12","category":"$undefined"},{"id":"13065","book":"욥기","book_name":"욥기","chapter":9,"verse":13,"text":"하나님이 진노를 돌이키지 아니하시나니 라합을 돕는 자들이 그 아래 굴복하겠거든","reference":"욥기 9:13","category":"$undefined"},{"id":"13066","book":"욥기","book_name":"욥기","chapter":9,"verse":14,"text":"하물며 내가 감히 대답하겠으며 무슨 말을 택하여 더불어 변론하랴","reference":"욥기 9:14","category":"$undefined"},{"id":"13067","book":"욥기","book_name":"욥기","chapter":9,"verse":15,"text":"가령 내가 의로울지라도 감히 대답하지 못하고 나를 심판하실 그에게 간구하였을 뿐이며","reference":"욥기 9:15","category":"$undefined"},{"id":"13068","book":"욥기","book_name":"욥기","chapter":9,"verse":16,"text":"가령 내가 그를 부르므로 그가 내게 대답하셨을지라도 내 음성을 들으셨다고는 내가 믿지 아니하리라","reference":"욥기 9:16","category":"$undefined"},{"id":"13069","book":"욥기","book_name":"욥기","chapter":9,"verse":17,"text":"그가 폭풍으로 나를 꺾으시고 까닭없이 내 상처를 많게 하시며","reference":"욥기 9:17","category":"$undefined"},{"id":"13070","book":"욥기","book_name":"욥기","chapter":9,"verse":18,"text":"나로 숨을 쉬지 못하게 하시며 괴로움으로 내게 채우시는구나","reference":"욥기 9:18","category":"$undefined"},{"id":"13071","book":"욥기","book_name":"욥기","chapter":9,"verse":19,"text":"힘으로 말하면 그가 강하시고 심판으로 말하면 누가 그를 호출 하겠느냐 ?","reference":"욥기 9:19","category":"$undefined"},{"id":"13072","book":"욥기","book_name":"욥기","chapter":9,"verse":20,"text":"가령 내가 의로울지라도 내 입이 나를 정죄하리니 가령 내가 순전할지라도 나의 패괴함을 증거하리라","reference":"욥기 9:20","category":"$undefined"},{"id":"13073","book":"욥기","book_name":"욥기","chapter":9,"verse":21,"text":"나는 순전하다마는 내가 나를 돌아보지 아니하고 내 생명을 천히 여기는구나","reference":"욥기 9:21","category":"$undefined"},{"id":"13074","book":"욥기","book_name":"욥기","chapter":9,"verse":22,"text":"일이 다 일반이라 그러므로 나는 말하기를 하나님이 순전한 자나 악한 자나 멸망시키신다 하나니","reference":"욥기 9:22","category":"$undefined"},{"id":"13075","book":"욥기","book_name":"욥기","chapter":9,"verse":23,"text":"홀연히 재앙이 내려 도륙될 때에 무죄한 자의 고난을 그가 비웃으시리라","reference":"욥기 9:23","category":"$undefined"},{"id":"13076","book":"욥기","book_name":"욥기","chapter":9,"verse":24,"text":"세상이 악인의 손에 붙이웠고 재판관의 얼굴도 가리워졌나니 그렇게 되게 한 이가 그가 아니시면 누구이뇨 ?","reference":"욥기 9:24","category":"$undefined"},{"id":"13077","book":"욥기","book_name":"욥기","chapter":9,"verse":25,"text":"나의 날이 체부보다 빠르니 달려가므로 복을 볼 수 없구나","reference":"욥기 9:25","category":"$undefined"},{"id":"13078","book":"욥기","book_name":"욥기","chapter":9,"verse":26,"text":"그 지나가는 것이 빠른 배 같고 움킬 것에 날아 내리는 독수리와도 같구나","reference":"욥기 9:26","category":"$undefined"},{"id":"13079","book":"욥기","book_name":"욥기","chapter":9,"verse":27,"text":"가령 내가 말하기를 내 원통함을 잊고 얼굴 빛을 고쳐 즐거운 모양을 하자 할지라도","reference":"욥기 9:27","category":"$undefined"},{"id":"13080","book":"욥기","book_name":"욥기","chapter":9,"verse":28,"text":"오히려 내 모든 고통을 두려워하오니 주께서 나를 무죄히 여기지 않으실 줄을 아나이다","reference":"욥기 9:28","category":"$undefined"},{"id":"13081","book":"욥기","book_name":"욥기","chapter":9,"verse":29,"text":"내가 정죄하심을 입을진대 어찌 헛되이 수고하리이까 ?","reference":"욥기 9:29","category":"$undefined"},{"id":"13082","book":"욥기","book_name":"욥기","chapter":9,"verse":30,"text":"내가 눈녹은 물로 몸을 씻고 잿물로 손을 깨끗이 할지라도","reference":"욥기 9:30","category":"$undefined"},{"id":"13083","book":"욥기","book_name":"욥기","chapter":9,"verse":31,"text":"주께서 나를 개천에 빠지게 하시리니 내 옷이라도 나를 싫어하리이다","reference":"욥기 9:31","category":"$undefined"},{"id":"13084","book":"욥기","book_name":"욥기","chapter":9,"verse":32,"text":"하나님은 나처럼 사람이 아니신즉 내가 그에게 대답함도 불가하고 대질하여 재판할 수도 없고","reference":"욥기 9:32","category":"$undefined"},{"id":"13085","book":"욥기","book_name":"욥기","chapter":9,"verse":33,"text":"양척 사이에 손을 얹을 판결자도 없구나","reference":"욥기 9:33","category":"$undefined"},{"id":"13086","book":"욥기","book_name":"욥기","chapter":9,"verse":34,"text":"주께서 그 막대기를 내게서 떠나게 하시고 그 위엄으로 나를 두렵게 하지 아니하시기를 원하노라","reference":"욥기 9:34","category":"$undefined"},{"id":"13087","book":"욥기","book_name":"욥기","chapter":9,"verse":35,"text":"그리하시면 내가 두려움 없이 말하리라 나는 본래 그런 자가 아니니라","reference":"욥기 9:35","category":"$undefined"}],"bookSlug":"job"}]
