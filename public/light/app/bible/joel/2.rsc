11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"joel","name":"요엘","chapters":3,"testament":"old"},"chapter":2,"verses":[{"id":"22313","book":"요엘","book_name":"요엘","chapter":2,"verse":1,"text":"시온에서 나팔을 불며 나의 성산에서 호각을 불어 이 땅 거민으로 다 떨게 할찌니 이는 여호와의 날이 이르게 됨이니라 이제 임박하였으나","reference":"요엘 2:1","category":"$undefined"},{"id":"22314","book":"요엘","book_name":"요엘","chapter":2,"verse":2,"text":"곧 어둡고 캄캄한 날이요 빽빽한 구름이 끼인 날이라 새벽 빛이 산꼭대기에 덮인 것과 같으니 이는 많고 강한 백성이 이르렀음이라 이같은 것이 자고 이래로 없었고 이후 세세에 없으리로다","reference":"요엘 2:2","category":"$undefined"},{"id":"22315","book":"요엘","book_name":"요엘","chapter":2,"verse":3,"text":"불이 그들의 앞을 사르며 불꽃이 그들의 뒤를 태우니 그 전의 땅은 에덴동산 같았으나 그 후의 땅은 황무한 들 같으니 그들을 피한 자가 없도다","reference":"요엘 2:3","category":"$undefined"},{"id":"22316","book":"요엘","book_name":"요엘","chapter":2,"verse":4,"text":"그 모양은 말 같고 그 달리는 것은 기병 같으며","reference":"요엘 2:4","category":"$undefined"},{"id":"22317","book":"요엘","book_name":"요엘","chapter":2,"verse":5,"text":"그들의 산 꼭대기에서 뛰는 소리가 병거 소리와도 같고 불꽃이 초개를 사르는 소리와도 같으며 강한 군사가 항오를 벌이고 싸우는 것같으니","reference":"요엘 2:5","category":"$undefined"},{"id":"22318","book":"요엘","book_name":"요엘","chapter":2,"verse":6,"text":"그 앞에서 만민이 송구하여 하며 무리의 낯빛이 하얘졌도다","reference":"요엘 2:6","category":"$undefined"},{"id":"22319","book":"요엘","book_name":"요엘","chapter":2,"verse":7,"text":"그들이 용사같이 달리며 무사 같이 성을 더위잡고 오르며 각기 자기의 길로 행하되 그 항오를 어기지 아니하며","reference":"요엘 2:7","category":"$undefined"},{"id":"22320","book":"요엘","book_name":"요엘","chapter":2,"verse":8,"text":"피차에 부딪히지 아니하고 각기 자기의 길로 행하며 병기를 충돌하고 나아가나 상치 아니하며","reference":"요엘 2:8","category":"$undefined"},{"id":"22321","book":"요엘","book_name":"요엘","chapter":2,"verse":9,"text":"성중에 뛰어 들어가며 성위에 달리며 집에 더위잡고 오르며 도적같이 창으로 들어가니","reference":"요엘 2:9","category":"$undefined"},{"id":"22322","book":"요엘","book_name":"요엘","chapter":2,"verse":10,"text":"그 앞에서 땅이 진동하며 하늘이 떨며 일월이 캄캄하며 별들이 빛을 거두도다","reference":"요엘 2:10","category":"$undefined"},{"id":"22323","book":"요엘","book_name":"요엘","chapter":2,"verse":11,"text":"여호와께서 그 군대 앞에서 소리를 발하시고 그 진은 심히 크고 그 명령을 행하는 자는 강하니 여호와의 날이 크고 심히 두렵도다 당할 자가 누구이랴","reference":"요엘 2:11","category":"$undefined"},{"id":"22324","book":"요엘","book_name":"요엘","chapter":2,"verse":12,"text":"여호와의 말씀에 너희는 이제라도 금식하며 울며 애통하고 마음을 다하여 내게로 돌아오라 하셨나니","reference":"요엘 2:12","category":"$undefined"},{"id":"22325","book":"요엘","book_name":"요엘","chapter":2,"verse":13,"text":"너희는 옷을 찢지 말고 마음을 찢고 너희 하나님 여호와께로 돌아올지어다 ! 그는 은혜로우시며, 자비로우시며, 노하기를 더디하시며, 인애가 크시사 뜻을 돌이켜 재앙을 내리지 아니하시나니","reference":"요엘 2:13","category":"$undefined"},{"id":"22326","book":"요엘","book_name":"요엘","chapter":2,"verse":14,"text":"주께서 혹시 마음과 뜻을 돌이키시고 그 뒤에 복을 끼치사 너희 하나님 여호와께 소제와 전제를 드리게 하지 아니하실는지 누가 알겠느냐","reference":"요엘 2:14","category":"$undefined"},{"id":"22327","book":"요엘","book_name":"요엘","chapter":2,"verse":15,"text":"너희는 시온에서 나팔을 불어 거룩한 금식일을 정하고 성회를 선고하고","reference":"요엘 2:15","category":"$undefined"},{"id":"22328","book":"요엘","book_name":"요엘","chapter":2,"verse":16,"text":"백성을 모아 그 회를 거룩케 하고 장로를 모으며 소아와 젖먹는 자를 모으며 신랑을 그 방에서 나오게 하며 신부도 그 골방에서 나오게 하고","reference":"요엘 2:16","category":"$undefined"},{"id":"22329","book":"요엘","book_name":"요엘","chapter":2,"verse":17,"text":"여호와께 수종드는 제사장들은 낭실과 단 사이에서 울며 이르기를 여호와여 주의 백성을 긍휼히 여기소서 주의 기업으로 욕되게 하여 열국들로 그들을 관할하지 못하게 하옵소서 어찌하여 이방인으로 그들의 하나님이 어디 있느뇨 말하게 하겠나이까 할지어다","reference":"요엘 2:17","category":"$undefined"},{"id":"22330","book":"요엘","book_name":"요엘","chapter":2,"verse":18,"text":"그 때에 여호와께서 자기 땅을 위하여 중심이 뜨거우시며 그 백성을 긍휼히 여기실 것이라","reference":"요엘 2:18","category":"$undefined"},{"id":"22331","book":"요엘","book_name":"요엘","chapter":2,"verse":19,"text":"여호와께서 그들에게 응답하여 이르시기를 내가 너희에게 곡식과 새 포도주와 기름을 주리니 너희가 이로 인하여 흡족하리라 내가 다시는 너희로 열국 중에서 욕을 당하지 않게 할 것이며","reference":"요엘 2:19","category":"$undefined"},{"id":"22332","book":"요엘","book_name":"요엘","chapter":2,"verse":20,"text":"내가 북편 군대를 너희에게서 멀리 떠나게 하여 메마르고 적막한 땅으로 쫓아내리니 그 전군은 동해로 그 후군은 서해로 들어갈 것이라 상한 냄새가 일어나고 악취가 오르리니 이는 큰 일을 행하였음이니라 하시리라","reference":"요엘 2:20","category":"$undefined"},{"id":"22333","book":"요엘","book_name":"요엘","chapter":2,"verse":21,"text":"땅이여 ! 두려워 말고 기뻐하며 즐거워할지어다 여호와께서 큰 일을 행하셨음이로다","reference":"요엘 2:21","category":"$undefined"},{"id":"22334","book":"요엘","book_name":"요엘","chapter":2,"verse":22,"text":"들짐승들아, 두려워 말지어다 ! 들의 풀이 싹이 나며 나무가 열매를 맺으며 무화과 나무와 포도 나무가 다 힘을 내는도다","reference":"요엘 2:22","category":"$undefined"},{"id":"22335","book":"요엘","book_name":"요엘","chapter":2,"verse":23,"text":"시온의 자녀들아 너희는 너희 하나님 여호와로 인하여 기뻐하며 즐거워할지어다 그가 너희를 위하여 비를 내리시되 이른 비를 너희에게 적당하게 주시리니 이른 비와 늦은 비가 전과 같을 것이라","reference":"요엘 2:23","category":"$undefined"},{"id":"22336","book":"요엘","book_name":"요엘","chapter":2,"verse":24,"text":"마당에는 밀이 가득하고 독에는 새 포도주와 기름이 넘치리로다","reference":"요엘 2:24","category":"$undefined"},{"id":"22337","book":"요엘","book_name":"요엘","chapter":2,"verse":25,"text":"내가 전에 너희에게 보낸 큰 군대 곧 메뚜기와 늣과 황충과 팟종이의 먹은 햇수대로 너희에게 갚아주리니","reference":"요엘 2:25","category":"$undefined"},{"id":"22338","book":"요엘","book_name":"요엘","chapter":2,"verse":26,"text":"너희는 먹되 풍족히 먹고 너희를 기이히 대접한 너희 하나님 여호와의 이름을 찬송할 것이라 내 백성이 영영히 수치를 당치 아니하리로다","reference":"요엘 2:26","category":"$undefined"},{"id":"22339","book":"요엘","book_name":"요엘","chapter":2,"verse":27,"text":"그런즉 내가 이스라엘 가운데 있어 너희 하나님 여호와가 되고 다른 이가 없는 줄을 너희가 알 것이라 내 백성이 영영히 수치를 당치 아니하리로다","reference":"요엘 2:27","category":"$undefined"},{"id":"22340","book":"요엘","book_name":"요엘","chapter":2,"verse":28,"text":"그 후에 내가 내 신을 만민에게 부어 주리니 너희 자녀들이 장래일을 말할 것이며 너희 늙은이는 꿈을 꾸며 너희 젊은이는 이상을 볼 것이며","reference":"요엘 2:28","category":"$undefined"},{"id":"22341","book":"요엘","book_name":"요엘","chapter":2,"verse":29,"text":"그 때에 내가 또 내 신으로 남종과 여종에게 부어 줄 것이며","reference":"요엘 2:29","category":"$undefined"},{"id":"22342","book":"요엘","book_name":"요엘","chapter":2,"verse":30,"text":"내가 이적을 하늘과 땅에 베풀리니 곧 피와 불과 연기 기둥이라","reference":"요엘 2:30","category":"$undefined"},{"id":"22343","book":"요엘","book_name":"요엘","chapter":2,"verse":31,"text":"여호와의 크고 두려운 날이 이르기 전에 해가 어두워지고 달이 핏빛 같이 변하려니와","reference":"요엘 2:31","category":"$undefined"},{"id":"22344","book":"요엘","book_name":"요엘","chapter":2,"verse":32,"text":"누구든지 여호와의 이름을 부르는 자는 구원을 얻으리니 이는 나 여호와의 말대로 시온산과 예루살렘에서 피할 자가 있을 것임이요 남은 자 중에 나 여호와의 부름을 받을 자가 있을 것임이니라","reference":"요엘 2:32","category":"$undefined"}],"bookSlug":"joel"}]
