2:["$","$L11",null,{"book":{"id":"joel","name":"요엘","chapters":3,"testament":"old"},"chapter":3,"verses":[{"id":"22345","book":"요엘","book_name":"요엘","chapter":3,"verse":1,"text":"그 날 곧 내가 유다와 예루살렘의 사로잡힌 자를 돌아오게 할 그때에","reference":"요엘 3:1","category":"$undefined"},{"id":"22346","book":"요엘","book_name":"요엘","chapter":3,"verse":2,"text":"내가 만국을 모아 데리고 여호사밧 골짜기에 내려가서 내 백성 곧 내 기업된 이스라엘을 위하여 거기서 그들을 국문하리니 이는 그들이 이스라엘을 열국 중에 흩고 나의 땅을 나누었음이며","reference":"요엘 3:2","category":"$undefined"},{"id":"22347","book":"요엘","book_name":"요엘","chapter":3,"verse":3,"text":"또 제비 뽑아 내 백성을 취하고 동남으로 기생을 바꾸며 마셨음이니라","reference":"요엘 3:3","category":"$undefined"},{"id":"22348","book":"요엘","book_name":"요엘","chapter":3,"verse":4,"text":"두로와 시돈과 블레셋 사방아 너희가 나와 무슨 상관이 있느냐 ? 너희가 내게 보복하겠느냐 ? 만일 내게 보복하면 너희의 보복하는 것을 내가 속속히 너희 머리에 돌리리니","reference":"요엘 3:4","category":"$undefined"},{"id":"22349","book":"요엘","book_name":"요엘","chapter":3,"verse":5,"text":"곧 너희가 내 은과 금을 취하고 나의 진기한 보물을 너희 신궁으로 가져갔으며","reference":"요엘 3:5","category":"$undefined"},{"id":"22350","book":"요엘","book_name":"요엘","chapter":3,"verse":6,"text":"또 유다 자손과 예루살렘 자손들을 헬라 족속에게 팔아서 본 지경에서 멀리 떠나게 하였음이니라","reference":"요엘 3:6","category":"$undefined"},{"id":"22351","book":"요엘","book_name":"요엘","chapter":3,"verse":7,"text":"보라 내가 그들을 너희가 팔아 이르게 한 곳에서 일으켜 나오게 하고 너희의 행한 것을 너희 머리에 돌려서","reference":"요엘 3:7","category":"$undefined"},{"id":"22352","book":"요엘","book_name":"요엘","chapter":3,"verse":8,"text":"너희 자녀를 유다 자손의 손에 팔리니 그들은 다시 먼 나라 스바 사람에게 팔리라 나 여호와가 말하였느니라","reference":"요엘 3:8","category":"$undefined"},{"id":"22353","book":"요엘","book_name":"요엘","chapter":3,"verse":9,"text":"너희는 열국에 이렇게 광포할지어다 너희는 전쟁을 준비하고 용사를 격려하고 무사로 다 가까이 나아와서 올라오게 할지어다","reference":"요엘 3:9","category":"$undefined"},{"id":"22354","book":"요엘","book_name":"요엘","chapter":3,"verse":10,"text":"너희는 보습을 쳐서 칼을 만들지어다 낫을 쳐서 창을 만들지어다 약한 자도 이르기를 나는 강하다 할지어다","reference":"요엘 3:10","category":"$undefined"},{"id":"22355","book":"요엘","book_name":"요엘","chapter":3,"verse":11,"text":"사면의 열국아 너희는 속히 와서 모일지어다 여호와여 ! 주의 용사들로 그리로 내려오게 하옵소서","reference":"요엘 3:11","category":"$undefined"},{"id":"22356","book":"요엘","book_name":"요엘","chapter":3,"verse":12,"text":"열국은 동하여 여호사밧 골짜기로 올라올지어다 내가 거기 앉아서 사면의 열국을 다 심판하리로다","reference":"요엘 3:12","category":"$undefined"},{"id":"22357","book":"요엘","book_name":"요엘","chapter":3,"verse":13,"text":"너희는 낫을 쓰라 곡식이 익었도다 와서 밟을지어다 포도주 틀이 가득히 차고 포도주 독이 넘치니 그들의 악이 큼이로다","reference":"요엘 3:13","category":"$undefined"},{"id":"22358","book":"요엘","book_name":"요엘","chapter":3,"verse":14,"text":"사람이 많음이여 판결 골짜기에 사람이 많음이여 판결 골짜기에 여호와의 날이 가까움이로다","reference":"요엘 3:14","category":"$undefined"},{"id":"22359","book":"요엘","book_name":"요엘","chapter":3,"verse":15,"text":"해와 달이 캄캄하며 별들이 그 빛을 거두도다","reference":"요엘 3:15","category":"$undefined"},{"id":"22360","book":"요엘","book_name":"요엘","chapter":3,"verse":16,"text":"나 여호와가 시온에서 부르짖고 예루살렘에서 목소리를 발하리니 하늘과 땅이 진동되리로다 그러나 나는 내 백성의 피난처 이스라엘 자손의 산성이 되리로다","reference":"요엘 3:16","category":"$undefined"},{"id":"22361","book":"요엘","book_name":"요엘","chapter":3,"verse":17,"text":"그런즉 너희가 나는 내 성산 시온에 거하는 너희 하나님 여호와인 줄 알 것이라 예루살렘이 거룩하리니 다시는 이방 사람이 그 가운데로 통행하지 못하리로다","reference":"요엘 3:17","category":"$undefined"},{"id":"22362","book":"요엘","book_name":"요엘","chapter":3,"verse":18,"text":"그 날에 산들이 단 포도주를 떨어뜨릴 것이며 작은 산들이 젖을 흘릴 것이며 유다 모든 시내가 물을 흘릴 것이며 여호와의 전에서 샘이 흘러 나와서 싯딤 골짜기에 대리라","reference":"요엘 3:18","category":"$undefined"},{"id":"22363","book":"요엘","book_name":"요엘","chapter":3,"verse":19,"text":"그러나 애굽은 황무지가 되겠고 에돔은 황무한 들이 되리니 이는 그들이 유다 자손에게 강포를 행하여 무죄한 피를 그 땅에서 흘렸음이니라","reference":"요엘 3:19","category":"$undefined"},{"id":"22364","book":"요엘","book_name":"요엘","chapter":3,"verse":20,"text":"유다는 영원히 있겠고 예루살렘은 대대로 있으리라","reference":"요엘 3:20","category":"$undefined"},{"id":"22365","book":"요엘","book_name":"요엘","chapter":3,"verse":21,"text":"내가 전에는 그들의 피흘림 당한 것을 갚아주지 아니하였거니와 이제는 갚아주리니 이는 나 여호와가 시온에 거함이니라","reference":"요엘 3:21","category":"$undefined"}],"bookSlug":"joel"}]
