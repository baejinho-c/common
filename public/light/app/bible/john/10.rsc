2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":10,"verses":[{"id":"26483","book":"요한복음","book_name":"요한복음","chapter":10,"verse":1,"text":"내가 진실로 진실로 너희에게 이르노니 양의 우리에 문으로 들어가지 아니하고 다른데로 넘어가는 자는 절도며 강도요","reference":"요한복음 10:1","category":"$undefined"},{"id":"26484","book":"요한복음","book_name":"요한복음","chapter":10,"verse":2,"text":"문으로 들어가는 이가 양의 목자라","reference":"요한복음 10:2","category":"$undefined"},{"id":"26485","book":"요한복음","book_name":"요한복음","chapter":10,"verse":3,"text":"문지기는 그를 위하여 문을 열고 양은 그의 음성을 듣나니 그가 자기 양의 이름을 각각 불러 인도하여 내느니라","reference":"요한복음 10:3","category":"$undefined"},{"id":"26486","book":"요한복음","book_name":"요한복음","chapter":10,"verse":4,"text":"자기 양을 다 내어 놓은 후에 앞서 가면 양들이 그의 음성을 아는고로 따라 오되","reference":"요한복음 10:4","category":"$undefined"},{"id":"26487","book":"요한복음","book_name":"요한복음","chapter":10,"verse":5,"text":"타인의 음성은 알지 못하는고로 타인을 따르지 아니하고 도리어 도망하느니라'","reference":"요한복음 10:5","category":"$undefined"},{"id":"26488","book":"요한복음","book_name":"요한복음","chapter":10,"verse":6,"text":"예수께서 이 비유로 저희에게 말씀하셨으나 저희는 그 하신 말씀이 무엇인지 알지 못하니라","reference":"요한복음 10:6","category":"$undefined"},{"id":"26489","book":"요한복음","book_name":"요한복음","chapter":10,"verse":7,"text":"그러므로 예수께서 다시 이르시되 `내가 진실로 진실로 너희에게 말하노니 나는 양의 문이라","reference":"요한복음 10:7","category":"$undefined"},{"id":"26490","book":"요한복음","book_name":"요한복음","chapter":10,"verse":8,"text":"나보다 먼저 온 자는 다 절도요 강도니 양들이 듣지 아니하였느니라","reference":"요한복음 10:8","category":"$undefined"},{"id":"26491","book":"요한복음","book_name":"요한복음","chapter":10,"verse":9,"text":"내가 문이니 누구든지 나로 말미암아 들어가면 구원을 얻고 또는 들어가며 나오며 꼴을 얻으리라","reference":"요한복음 10:9","category":"$undefined"},{"id":"26492","book":"요한복음","book_name":"요한복음","chapter":10,"verse":10,"text":"도적이 오는 것은 도적질하고 죽이고 멸망시키려는 것뿐이요 내가 온 것은 양으로 생명을 얻게 하고 더 풍성히 얻게 하려는 것이라","reference":"요한복음 10:10","category":"$undefined"},{"id":"26493","book":"요한복음","book_name":"요한복음","chapter":10,"verse":11,"text":"나는 선한 목자라 ! 선한 목자는 양들을 위하여 목숨을 버리거니와","reference":"요한복음 10:11","category":"$undefined"},{"id":"26494","book":"요한복음","book_name":"요한복음","chapter":10,"verse":12,"text":"삯군은 목자도 아니요 양도 제 양이 아니라 이리가 오는 것을 보면 양을 버리고 달아나나니 이리가 양을 늑탈하고 또 헤치느니라","reference":"요한복음 10:12","category":"$undefined"},{"id":"26495","book":"요한복음","book_name":"요한복음","chapter":10,"verse":13,"text":"달아나는 것은 저가 삯군인 까닭에 양을 돌아보지 아니함이나","reference":"요한복음 10:13","category":"$undefined"},{"id":"26496","book":"요한복음","book_name":"요한복음","chapter":10,"verse":14,"text":"나는 선한 목자라 ! 내가 내 양을 알고 양도 나를 아는 것이","reference":"요한복음 10:14","category":"$undefined"},{"id":"26497","book":"요한복음","book_name":"요한복음","chapter":10,"verse":15,"text":"아버지께서 나를 아시고 내가 아버지를 아는 것 같으니 나는 양을 위하여 목숨을 버리노라","reference":"요한복음 10:15","category":"$undefined"},{"id":"26498","book":"요한복음","book_name":"요한복음","chapter":10,"verse":16,"text":"또 이 우리에 들지 아니한 다른 양들이 내게 있어 내가 인도하여야 할 터이니 저희도 내 음성을 듣고 한 무리가 되어 한 목자에게 있으리라","reference":"요한복음 10:16","category":"$undefined"},{"id":"26499","book":"요한복음","book_name":"요한복음","chapter":10,"verse":17,"text":"아버지께서 나를 사랑하시는 것은 내가 다시 목숨을 얻기 위하여 목숨을 버림이라","reference":"요한복음 10:17","category":"$undefined"},{"id":"26500","book":"요한복음","book_name":"요한복음","chapter":10,"verse":18,"text":"이를 내게서 빼앗는 자가 있는 것이 아니라 내가 스스로 버리노라 나는 버릴 권세도 있고 다시 얻을 권세도 있으니 이 계명은 내 아버지에게서 받았노라' 하시니라","reference":"요한복음 10:18","category":"$undefined"},{"id":"26501","book":"요한복음","book_name":"요한복음","chapter":10,"verse":19,"text":"이 말씀을 인하여 유대인 중에 다시 분쟁이 일어나니","reference":"요한복음 10:19","category":"$undefined"},{"id":"26502","book":"요한복음","book_name":"요한복음","chapter":10,"verse":20,"text":"그 중에 많은 사람이 말하되 `저가 귀신 들려 미쳤거늘 어찌하여 그 말을 듣느냐 ?' 하며","reference":"요한복음 10:20","category":"$undefined"},{"id":"26503","book":"요한복음","book_name":"요한복음","chapter":10,"verse":21,"text":"혹은 말하되 `이 말은 귀신들린 자의 말이 아니라 귀신이 소경의 눈을 뜨게 할 수 있느냐 ?' 하더라","reference":"요한복음 10:21","category":"$undefined"},{"id":"26504","book":"요한복음","book_name":"요한복음","chapter":10,"verse":22,"text":"예루살렘에 수전절이 이르니 때는 겨울이라","reference":"요한복음 10:22","category":"$undefined"},{"id":"26505","book":"요한복음","book_name":"요한복음","chapter":10,"verse":23,"text":"예수께서 성전 안 솔로몬 행각에서 다니시니","reference":"요한복음 10:23","category":"$undefined"},{"id":"26506","book":"요한복음","book_name":"요한복음","chapter":10,"verse":24,"text":"유대인들이 에워싸고 가로되 `당신이 언제까지나 우리 마음을 의혹케 하려나이까 ? 그리스도여든 밝히 말하시오' 하니","reference":"요한복음 10:24","category":"$undefined"},{"id":"26507","book":"요한복음","book_name":"요한복음","chapter":10,"verse":25,"text":"예수께서 대답하시되 `내가 너희에게 말하였으되 믿지 아니하는도다 내가 내 아버지의 이름으로 행하는 일들이 나를 증거하는 것이어늘","reference":"요한복음 10:25","category":"$undefined"},{"id":"26508","book":"요한복음","book_name":"요한복음","chapter":10,"verse":26,"text":"너희가 내 양이 아니므로 믿지 아니하는도다","reference":"요한복음 10:26","category":"$undefined"},{"id":"26509","book":"요한복음","book_name":"요한복음","chapter":10,"verse":27,"text":"내 양은 내 음성을 들으며 나는 저희를 알며 저희는 나를 따르느니라","reference":"요한복음 10:27","category":"$undefined"},{"id":"26510","book":"요한복음","book_name":"요한복음","chapter":10,"verse":28,"text":"내가 저희에게 영생을 주노니 영원히 멸망치 아니할 터이요 또 저희를 내 손에서 빼앗을 자가 없느니라","reference":"요한복음 10:28","category":"$undefined"},{"id":"26511","book":"요한복음","book_name":"요한복음","chapter":10,"verse":29,"text":"저희를 주신 내 아버지는 만유보다 크시매 아무도 아버지 손에서 빼앗을 수 없느니라 !","reference":"요한복음 10:29","category":"$undefined"},{"id":"26512","book":"요한복음","book_name":"요한복음","chapter":10,"verse":30,"text":"나와 아버지는 하나이니라' 하신대","reference":"요한복음 10:30","category":"$undefined"},{"id":"26513","book":"요한복음","book_name":"요한복음","chapter":10,"verse":31,"text":"유대인들이 다시 돌을 들어 치려 하거늘","reference":"요한복음 10:31","category":"$undefined"},{"id":"26514","book":"요한복음","book_name":"요한복음","chapter":10,"verse":32,"text":"예수께서 대답하시되 `내가 아버지께로 말미암아 여러 가지 선한 일을 너희에게 보였거늘 그 중에 어떤 일로 나를 돌로 치려 하느냐 ?'","reference":"요한복음 10:32","category":"$undefined"},{"id":"26515","book":"요한복음","book_name":"요한복음","chapter":10,"verse":33,"text":"유대인들이 대답하되 `선한 일을 인하여 우리가 너를 돌로 치려는 것이 아니라 참람함을 인함이니 네가 사람이 되어 자칭 하나님이라 함이로라'","reference":"요한복음 10:33","category":"$undefined"},{"id":"26516","book":"요한복음","book_name":"요한복음","chapter":10,"verse":34,"text":"예수께서 가라사대 `너희 율법에 기록한바 내가 너희를 신이라 하였노라 하지 아니하였느냐","reference":"요한복음 10:34","category":"$undefined"},{"id":"26517","book":"요한복음","book_name":"요한복음","chapter":10,"verse":35,"text":"성경은 폐하지 못하나니 하나님의 말씀을 받은 사람들을 신이라 하셨거든","reference":"요한복음 10:35","category":"$undefined"},{"id":"26518","book":"요한복음","book_name":"요한복음","chapter":10,"verse":36,"text":"하물며 아버지께서 거룩하게 하사 세상에 보내신 자가 나는 하나님 아들이라 하는 것으로 너희가 어찌 참람하다 하느냐 ?","reference":"요한복음 10:36","category":"$undefined"},{"id":"26519","book":"요한복음","book_name":"요한복음","chapter":10,"verse":37,"text":"만일 내가 내 아버지의 일을 행치 아니하거든 나를 믿지 말려니와","reference":"요한복음 10:37","category":"$undefined"},{"id":"26520","book":"요한복음","book_name":"요한복음","chapter":10,"verse":38,"text":"내가 행하거든 나를 믿지 아니할지라도 그 일은 믿으라 ! 그러면 너희가 아버지께서 내 안에 계시고 내가 아버지 안에 있음을 깨달아 알리라' 하신대","reference":"요한복음 10:38","category":"$undefined"},{"id":"26521","book":"요한복음","book_name":"요한복음","chapter":10,"verse":39,"text":"저희가 다시 예수를 잡고자 하였으나 그 손에서 벗어나 나가시니라","reference":"요한복음 10:39","category":"$undefined"},{"id":"26522","book":"요한복음","book_name":"요한복음","chapter":10,"verse":40,"text":"다시 요단강 저편 요한이 처음으로 세례 주던 곳에 가사 거기 거하시니","reference":"요한복음 10:40","category":"$undefined"},{"id":"26523","book":"요한복음","book_name":"요한복음","chapter":10,"verse":41,"text":"많은 사람이 왔다가 말하되 `요한은 아무 표적도 행치 아니하였으나 요한이 이 사람을 가리켜 말한 것은 참이라' 하더라","reference":"요한복음 10:41","category":"$undefined"},{"id":"26524","book":"요한복음","book_name":"요한복음","chapter":10,"verse":42,"text":"그리하여 거기서 많은 사람이 예수를 믿으니라","reference":"요한복음 10:42","category":"$undefined"}],"bookSlug":"john"}]
