2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":15,"verses":[{"id":"26701","book":"요한복음","book_name":"요한복음","chapter":15,"verse":1,"text":"내가 참 포도나무요 내 아버지는 그 농부라","reference":"요한복음 15:1","category":"$undefined"},{"id":"26702","book":"요한복음","book_name":"요한복음","chapter":15,"verse":2,"text":"무릇 내게 있어 과실을 맺지 아니하는 가지는 아버지께서 이를 제해버리시고 무릇 과실을 맺는 가지는 더 과실을 맺게 하려 하여 이를 깨끗케 하시느니라","reference":"요한복음 15:2","category":"$undefined"},{"id":"26703","book":"요한복음","book_name":"요한복음","chapter":15,"verse":3,"text":"너희는 내가 일러 준 말로 이미 깨끗하였으니","reference":"요한복음 15:3","category":"$undefined"},{"id":"26704","book":"요한복음","book_name":"요한복음","chapter":15,"verse":4,"text":"내 안에 거하라 나도 너희 안에 거하리라 가지가 포도나무에 붙어 있지 아니하면 절로 과실을 맺을 수 없음 같이 너희도 내 안에 있지 아니하면 그러하리라","reference":"요한복음 15:4","category":"$undefined"},{"id":"26705","book":"요한복음","book_name":"요한복음","chapter":15,"verse":5,"text":"나는 포도나무요 너희는 가지니 저가 내 안에 내가 저 안에 있으면 이 사람은 과실을 많이 맺나니 나를 떠나서는 너희가 아무 것도 할 수 없음이라","reference":"요한복음 15:5","category":"$undefined"},{"id":"26706","book":"요한복음","book_name":"요한복음","chapter":15,"verse":6,"text":"사람이 내 안에 거하지 아니하면 가지처럼 밖에 버리워 말라지나니 사람들이 이것을 모아다가 불에 던져 사르느니라","reference":"요한복음 15:6","category":"$undefined"},{"id":"26707","book":"요한복음","book_name":"요한복음","chapter":15,"verse":7,"text":"너희가 내 안에 거하고 내 말이 너희 안에 거하면 무엇이든지 원하는 대로 구하라 그리하면 이루리라","reference":"요한복음 15:7","category":"$undefined"},{"id":"26708","book":"요한복음","book_name":"요한복음","chapter":15,"verse":8,"text":"너희가 과실을 많이 맺으면 내 아버지께서 영광을 받으실 것이요 너희가 내 제자가 되리라","reference":"요한복음 15:8","category":"$undefined"},{"id":"26709","book":"요한복음","book_name":"요한복음","chapter":15,"verse":9,"text":"아버지께서 나를 사랑하신 것같이 나도 너희를 사랑하였으니 나의 사랑 안에 거하라","reference":"요한복음 15:9","category":"$undefined"},{"id":"26710","book":"요한복음","book_name":"요한복음","chapter":15,"verse":10,"text":"내가 아버지의 계명을 지켜 그의 사랑 안에 거하는 것같이 너희도 내 계명을 지키면 내 사랑 안에 거하리라","reference":"요한복음 15:10","category":"$undefined"},{"id":"26711","book":"요한복음","book_name":"요한복음","chapter":15,"verse":11,"text":"내가 이것을 너희에게 이름은 내 기쁨이 너희 안에 있어 너희 기쁨을 충만하게 하려 함이니라","reference":"요한복음 15:11","category":"$undefined"},{"id":"26712","book":"요한복음","book_name":"요한복음","chapter":15,"verse":12,"text":"내 계명은 곧 내가 너희를 사랑한 것같이 너희도 서로 사랑하라 하는 이것이니라","reference":"요한복음 15:12","category":"$undefined"},{"id":"26713","book":"요한복음","book_name":"요한복음","chapter":15,"verse":13,"text":"사람이 친구를 위하여 자기 목숨을 버리면 이에서 더 큰 사랑이 없나니","reference":"요한복음 15:13","category":"$undefined"},{"id":"26714","book":"요한복음","book_name":"요한복음","chapter":15,"verse":14,"text":"너희가 나의 명하는 대로 행하면 곧 나의 친구라","reference":"요한복음 15:14","category":"$undefined"},{"id":"26715","book":"요한복음","book_name":"요한복음","chapter":15,"verse":15,"text":"이제부터는 너희를 종이라 하지 아니하리니 종은 주인의 하는 것을 알지 못함이라 너희를 친구라 하였노니 내가 내 아버지께 들은 것을 다 너희에게 알게 하였음이니라","reference":"요한복음 15:15","category":"$undefined"},{"id":"26716","book":"요한복음","book_name":"요한복음","chapter":15,"verse":16,"text":"너희가 나를 택한 것이 아니요 내가 너희를 택하여 세웠나니 이는 너희로 가서 과실을 맺게 하고 또 너희 과실이 항상 있게 하여 내 이름으로 아버지께 무엇을 구하든지 다 받게 하려 함이니라","reference":"요한복음 15:16","category":"$undefined"},{"id":"26717","book":"요한복음","book_name":"요한복음","chapter":15,"verse":17,"text":"내가 이것을 너희에게 명함은 너희로 서로 사랑하게 하려 함이로라","reference":"요한복음 15:17","category":"$undefined"},{"id":"26718","book":"요한복음","book_name":"요한복음","chapter":15,"verse":18,"text":"세상이 너희를 미워하면 너희보다 먼저 나를 미워한 줄을 알라","reference":"요한복음 15:18","category":"$undefined"},{"id":"26719","book":"요한복음","book_name":"요한복음","chapter":15,"verse":19,"text":"너희가 세상에 속하였으면 세상이 자기의 것을 사랑할 터이나 너희는 세상에 속한 자가 아니요 도리어 세상에서 나의 택함을 입은 자인고로 세상이 너희를 미워하느니라","reference":"요한복음 15:19","category":"$undefined"},{"id":"26720","book":"요한복음","book_name":"요한복음","chapter":15,"verse":20,"text":"내가 너희더러 종이 주인보다 더 크지 못하다 한 말을 기억하라 사람들이 나를 핍박하였은즉 너희도 핍박할 터이요 내 말을 지켰은즉 너희 말도 지킬 터이라","reference":"요한복음 15:20","category":"$undefined"},{"id":"26721","book":"요한복음","book_name":"요한복음","chapter":15,"verse":21,"text":"그러나 사람들이 내 이름을 인하여 이 모든 일을 너희에게 하리니 이는 나 보내신 이를 알지 못함이니라","reference":"요한복음 15:21","category":"$undefined"},{"id":"26722","book":"요한복음","book_name":"요한복음","chapter":15,"verse":22,"text":"내가 와서 저희에게 말하지 아니하였더면 죄가 없었으려니와 지금은 그 죄를 핑계할 수 없느니라","reference":"요한복음 15:22","category":"$undefined"},{"id":"26723","book":"요한복음","book_name":"요한복음","chapter":15,"verse":23,"text":"나를 미워하는 자는 또 내 아버지를 미워하느니라","reference":"요한복음 15:23","category":"$undefined"},{"id":"26724","book":"요한복음","book_name":"요한복음","chapter":15,"verse":24,"text":"내가 아무도 못한 일을 저희 중에서 하지 아니하였더면 저희가 죄가 없었으려니와 지금은 저희가 나와 및 내 아버지를 보았고 또 미워하였도다","reference":"요한복음 15:24","category":"$undefined"},{"id":"26725","book":"요한복음","book_name":"요한복음","chapter":15,"verse":25,"text":"그러나 이는 저희 율법에 기록된 바 저희가 연고 없이 나를 미워하였다 한 말을 응하게 하려 함이니라","reference":"요한복음 15:25","category":"$undefined"},{"id":"26726","book":"요한복음","book_name":"요한복음","chapter":15,"verse":26,"text":"내가 아버지께로서 너희에게 보낼 보혜사 곧 아버지께로서 나오시는 진리의 성령이 오실때에 그가 나를 증거하실 것이요","reference":"요한복음 15:26","category":"$undefined"},{"id":"26727","book":"요한복음","book_name":"요한복음","chapter":15,"verse":27,"text":"너희도 처음부터 나와 함께 있었으므로 증거하느니라","reference":"요한복음 15:27","category":"$undefined"}],"bookSlug":"john"}]
