2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":18,"verses":[{"id":"26787","book":"요한복음","book_name":"요한복음","chapter":18,"verse":1,"text":"예수께서 이 말씀을 하시고 제자들과 함께 기드론 시내 저편으로 나가시니 거기 동산이 있는데 제자들과 함께 들어가시다","reference":"요한복음 18:1","category":"$undefined"},{"id":"26788","book":"요한복음","book_name":"요한복음","chapter":18,"verse":2,"text":"거기는 예수께서 제자들과 가끔 모이시는 곳이므로 예수를 파는 유다도 그 곳을 알더라","reference":"요한복음 18:2","category":"$undefined"},{"id":"26789","book":"요한복음","book_name":"요한복음","chapter":18,"verse":3,"text":"유다가 군대와 및 대제사장들과 바리새인들에게서 얻은 하속들을 데리고 등과 홰와 병기를 가지고 그리로 오는지라","reference":"요한복음 18:3","category":"$undefined"},{"id":"26790","book":"요한복음","book_name":"요한복음","chapter":18,"verse":4,"text":"예수께서 그 당할 일을 다 아시고 나아가 가라사대 `너희가 누구를 찾느냐 ?'","reference":"요한복음 18:4","category":"$undefined"},{"id":"26791","book":"요한복음","book_name":"요한복음","chapter":18,"verse":5,"text":"대답하되 `나사렛 예수라' 하거늘 가라사대 `내로라 !' 하시니라 그를 파는 유다도 저희와 함께 섰더라","reference":"요한복음 18:5","category":"$undefined"},{"id":"26792","book":"요한복음","book_name":"요한복음","chapter":18,"verse":6,"text":"예수께서 저희에게 내로라 하실때에 저희가 물러가서 땅에 엎드러지는지라","reference":"요한복음 18:6","category":"$undefined"},{"id":"26793","book":"요한복음","book_name":"요한복음","chapter":18,"verse":7,"text":"이에 다시 `누구를 찾느냐 ?'고 물으신대 저희가 말하되 `나사렛 예수라' 하거늘","reference":"요한복음 18:7","category":"$undefined"},{"id":"26794","book":"요한복음","book_name":"요한복음","chapter":18,"verse":8,"text":"예수께서 대답하시되 `너희에게 내로라 하였으니 나를 찾거든 이 사람들의 가는 것을 용납하라' 하시니","reference":"요한복음 18:8","category":"$undefined"},{"id":"26795","book":"요한복음","book_name":"요한복음","chapter":18,"verse":9,"text":"이는 아버지께서 내게 주신 자 중에서 하나도 잃지 아니하였삽나이다 하신 말씀을 응하게 하려 함이러라","reference":"요한복음 18:9","category":"$undefined"},{"id":"26796","book":"요한복음","book_name":"요한복음","chapter":18,"verse":10,"text":"이에 시몬 베드로가 검을 가졌는데 이것을 빼어 대제사장의 종을 쳐서 오른편 귀를 베어버리니 그 종의 이름은 말고라","reference":"요한복음 18:10","category":"$undefined"},{"id":"26797","book":"요한복음","book_name":"요한복음","chapter":18,"verse":11,"text":"예수께서 베드로더러 이르시되 `검을 집에 꽃으라 아버지께서 주신 잔을 내가 마시지 아니하겠느냐 ?' 하시니라","reference":"요한복음 18:11","category":"$undefined"},{"id":"26798","book":"요한복음","book_name":"요한복음","chapter":18,"verse":12,"text":"이에 군대와 천부장과 유대인의 하속들이 예수를 잡아 결박하여","reference":"요한복음 18:12","category":"$undefined"},{"id":"26799","book":"요한복음","book_name":"요한복음","chapter":18,"verse":13,"text":"먼저 안나스에게로 끌고 가니 안나스는 그 해의 대제사장인 가야바의 장인이라","reference":"요한복음 18:13","category":"$undefined"},{"id":"26800","book":"요한복음","book_name":"요한복음","chapter":18,"verse":14,"text":"가야바는 유대인들에게 한 사람이 백성을 위하여 죽는 것이 유익하다 권고하던 자러라","reference":"요한복음 18:14","category":"$undefined"},{"id":"26801","book":"요한복음","book_name":"요한복음","chapter":18,"verse":15,"text":"시몬 베드로와 또 다른 제자 하나가 예수를 따르니 이 제자는 대제사장과 아는 사람이라 예수와 함께 대제사장의 집 뜰에 들어가고","reference":"요한복음 18:15","category":"$undefined"},{"id":"26802","book":"요한복음","book_name":"요한복음","chapter":18,"verse":16,"text":"베드로는 문 밖에 섰는지라 대제사장과 아는 그 다른 제자가 나가서 문지키는 여자에게 말하여 베드로를 데리고 들어왔더니","reference":"요한복음 18:16","category":"$undefined"},{"id":"26803","book":"요한복음","book_name":"요한복음","chapter":18,"verse":17,"text":"문 지키는 여종이 베드로에게 말하되 `너도 이 사람의 제자 중 하나가 아니냐 ?' 하니 그가 말하되 `나는 아니라' 하고","reference":"요한복음 18:17","category":"$undefined"},{"id":"26804","book":"요한복음","book_name":"요한복음","chapter":18,"verse":18,"text":"그 때가 추운고로 종과 하속들이 숯불을 피우고 서서 쬐니 베드로도 함께 서서 쬐더라","reference":"요한복음 18:18","category":"$undefined"},{"id":"26805","book":"요한복음","book_name":"요한복음","chapter":18,"verse":19,"text":"대제사장이 예수에게 그의 제자들과 그의 교훈에 대하여 물으니","reference":"요한복음 18:19","category":"$undefined"},{"id":"26806","book":"요한복음","book_name":"요한복음","chapter":18,"verse":20,"text":"예수께서 대답하시되 `내가 드러내어 놓고 세상에 말하였노라 모든 유대인들의 모이는 회당과 성전에서 항상 가르쳤고 은밀히는 아무 것도 말하지 아니하였거늘","reference":"요한복음 18:20","category":"$undefined"},{"id":"26807","book":"요한복음","book_name":"요한복음","chapter":18,"verse":21,"text":"어찌하여 내게 묻느냐 ? 내가 무슨 말을 하였는지 들은 자들에게 물어보라 저희가 나의 하던 말을 아느니라'","reference":"요한복음 18:21","category":"$undefined"},{"id":"26808","book":"요한복음","book_name":"요한복음","chapter":18,"verse":22,"text":"이 말씀을 하시매 곁에 섰는 하속 하나가 손으로 예수를 쳐 가로되 네가 대제사장에게 이같이 대답하느냐 ? 하니","reference":"요한복음 18:22","category":"$undefined"},{"id":"26809","book":"요한복음","book_name":"요한복음","chapter":18,"verse":23,"text":"예수께서 대답하시되 `내가 말을 잘못하였으면 그 잘못한 것을 증거하라 잘하였으면 네가 어찌하여 나를 치느냐 ?' 하시더라","reference":"요한복음 18:23","category":"$undefined"},{"id":"26810","book":"요한복음","book_name":"요한복음","chapter":18,"verse":24,"text":"안나스가 예수를 결박한 그대로 대제사장 가야바에게 보내니라","reference":"요한복음 18:24","category":"$undefined"},{"id":"26811","book":"요한복음","book_name":"요한복음","chapter":18,"verse":25,"text":"시몬 베드로가 서서 불을 쬐더니 사람들이 묻되 `너도 그 제자 중 하나가 아니냐 ?' 베드로가 부인하여 가로되 `나는 아니라' 하니","reference":"요한복음 18:25","category":"$undefined"},{"id":"26812","book":"요한복음","book_name":"요한복음","chapter":18,"verse":26,"text":"대제사장의 종 하나는 베드로에게 귀를 베어 버리운 사람의 일가라 가로되 `네가 그 사람과 함께 동산에 있던 것을 내가 보지 아니하였느냐 ?'","reference":"요한복음 18:26","category":"$undefined"},{"id":"26813","book":"요한복음","book_name":"요한복음","chapter":18,"verse":27,"text":"이에 베드로가 또 부인하니 곧 닭이 울더라","reference":"요한복음 18:27","category":"$undefined"},{"id":"26814","book":"요한복음","book_name":"요한복음","chapter":18,"verse":28,"text":"저희가 예수를 가야바에게서 관정으로 끌고 가니 새벽이라 저희는 더럽힘을 받지 아니하고 유월절 잔치를 먹고자 하여 관정에 들어가지 아니하더라","reference":"요한복음 18:28","category":"$undefined"},{"id":"26815","book":"요한복음","book_name":"요한복음","chapter":18,"verse":29,"text":"그러므로 빌라도가 밖으로 저희에게 나가서 말하되 `너희가 무슨 일로 이 사람을 고소하느냐 ?'","reference":"요한복음 18:29","category":"$undefined"},{"id":"26816","book":"요한복음","book_name":"요한복음","chapter":18,"verse":30,"text":"대답하여 가로되 `이 사람이 행악자가 아니었더면 우리가 당신에게 넘기지 아니하였겠나이다'","reference":"요한복음 18:30","category":"$undefined"},{"id":"26817","book":"요한복음","book_name":"요한복음","chapter":18,"verse":31,"text":"빌라도가 가로되 `너희가 저를 데려다가 너희 법대로 재판하라' 유대인들이 가로되 `우리에게는 사람을 죽이는 권이 없나이다' 하니","reference":"요한복음 18:31","category":"$undefined"},{"id":"26818","book":"요한복음","book_name":"요한복음","chapter":18,"verse":32,"text":"이는 예수께서 자기가 어떠한 죽음으로 죽을 것을 가리켜 하신 말씀을 응하게 하려 함이러라","reference":"요한복음 18:32","category":"$undefined"},{"id":"26819","book":"요한복음","book_name":"요한복음","chapter":18,"verse":33,"text":"이에 빌라도가 다시 관정에 들어가 예수를 불러 가로되 `네가 유대인의 왕이냐 ?'","reference":"요한복음 18:33","category":"$undefined"},{"id":"26820","book":"요한복음","book_name":"요한복음","chapter":18,"verse":34,"text":"예수께서 대답하시되 `이는 네가 스스로 하는 말이뇨 ? 다른 사람들이 나를 대하여 네게 한 말이뇨 ?'","reference":"요한복음 18:34","category":"$undefined"},{"id":"26821","book":"요한복음","book_name":"요한복음","chapter":18,"verse":35,"text":"빌라도가 대답하되 `내가 유대인이냐 ? 네 나라 사람과 대제사장들이 너를 내게 넘겼으니 네가 무엇을 하였느냐 ?'","reference":"요한복음 18:35","category":"$undefined"},{"id":"26822","book":"요한복음","book_name":"요한복음","chapter":18,"verse":36,"text":"예수께서 대답하시되 `내 나라는 이 세상에 속한 것이 아니라 만일 내 나라가 이 세상에 속한 것이었더면 내 종들이 싸워 나로 유대인들에게 넘기우지 않게 하였으리라 이제 내 나라는 여기에 속한 것이 아니니라'","reference":"요한복음 18:36","category":"$undefined"},{"id":"26823","book":"요한복음","book_name":"요한복음","chapter":18,"verse":37,"text":"빌라도가 가로되 그러면 네가 왕이 아니냐 ? 예수께서 대답하시되 네 말과 같이 내가 왕이니라 ! 내가 이를 위하여 났으며 이를 위하여 세상에 왔나니 곧 진리에 대하여 증거하려 함이로다 무릇 진리에 속한 자는 내 소리를 듣느니라 하신대","reference":"요한복음 18:37","category":"$undefined"},{"id":"26824","book":"요한복음","book_name":"요한복음","chapter":18,"verse":38,"text":"빌라도가 가로되 `진리가 무엇이냐 ?' 하더라 이 말을 하고 다시 유대인들에게 나가서 이르되 `나는 그에게서 아무 죄도 찾지 못하노라","reference":"요한복음 18:38","category":"$undefined"},{"id":"26825","book":"요한복음","book_name":"요한복음","chapter":18,"verse":39,"text":"유월절이면 내가 너희에게 한사람을 놓아 주는 전례가 있으니 그러면 너희는 내가 유대인의 왕을 너희에게 놓아 주기를 원하느냐 ?'하니","reference":"요한복음 18:39","category":"$undefined"},{"id":"26826","book":"요한복음","book_name":"요한복음","chapter":18,"verse":40,"text":"저희가 또 소리 질러 가로되 `이 사람이 아니라 바라바라' 하니 바라바는 강도러라","reference":"요한복음 18:40","category":"$undefined"}],"bookSlug":"john"}]
