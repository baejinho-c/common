2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":19,"verses":[{"id":"26827","book":"요한복음","book_name":"요한복음","chapter":19,"verse":1,"text":"이에 빌라도가 예수를 데려다가 채찍질하더라","reference":"요한복음 19:1","category":"$undefined"},{"id":"26828","book":"요한복음","book_name":"요한복음","chapter":19,"verse":2,"text":"군병들이 가시로 면류관을 엮어 그의 머리에 씌우고 자색 옷을 입히고","reference":"요한복음 19:2","category":"$undefined"},{"id":"26829","book":"요한복음","book_name":"요한복음","chapter":19,"verse":3,"text":"앞에 와서 가로되 `유대인의 왕이여 평안할지어다' 하며 손바닥으로 때리더라","reference":"요한복음 19:3","category":"$undefined"},{"id":"26830","book":"요한복음","book_name":"요한복음","chapter":19,"verse":4,"text":"빌라도가 다시 밖에 나가 말하되 `보라 이 사람을 데리고 너희에게 나오나니 이는 내가 그에게서 아무 죄도 찾지 못한 것을 너희로 알게 하려 함이로다' 하더라","reference":"요한복음 19:4","category":"$undefined"},{"id":"26831","book":"요한복음","book_name":"요한복음","chapter":19,"verse":5,"text":"이에 예수께서 가시 면류관을 쓰고 자색 옷을 입고 나오시니 빌라도가 저희에게 말하되 `보라, 이 사람이로다 !' 하매","reference":"요한복음 19:5","category":"$undefined"},{"id":"26832","book":"요한복음","book_name":"요한복음","chapter":19,"verse":6,"text":"대제사장들과 하속들이 예수를 보고 소리 질러 가로되 `십자가에 못 박게 하소서 ! 십자가에 못 박게 하소서 !' 하는지라 빌라도가 가로되 너희가 친히 데려다가 십자가에 못 박으라 나는 그에게서 죄를 찾지 못하노라","reference":"요한복음 19:6","category":"$undefined"},{"id":"26833","book":"요한복음","book_name":"요한복음","chapter":19,"verse":7,"text":"유대인들이 대답하되 `우리에게 법이 있으니 그 법대로 하면 저가 당연히 죽을 것은 저가 자기를 하나님 아들이라 함이니이다'","reference":"요한복음 19:7","category":"$undefined"},{"id":"26834","book":"요한복음","book_name":"요한복음","chapter":19,"verse":8,"text":"빌라도가 이 말을 듣고 더욱 두려워하여","reference":"요한복음 19:8","category":"$undefined"},{"id":"26835","book":"요한복음","book_name":"요한복음","chapter":19,"verse":9,"text":"다시 관정에 들어가서 예수께 말하되 `너는 어디로서냐 ?' 하되 예수께서 대답하여 주지 아니하시는지라","reference":"요한복음 19:9","category":"$undefined"},{"id":"26836","book":"요한복음","book_name":"요한복음","chapter":19,"verse":10,"text":"빌라도가 가로되 `내게 말하지 아니하느냐 ? 내가 너를 놓을 권세도 있고 십자가에 못 박을 권세도 있는 줄 알지 못하느냐 ?'","reference":"요한복음 19:10","category":"$undefined"},{"id":"26837","book":"요한복음","book_name":"요한복음","chapter":19,"verse":11,"text":"예수께서 대답하시되 `위에서 주지 아니하셨더면 나를 해할 권세가 없었으리니 그러므로 나를 네게 넘겨준 자의 죄는 더 크니라' 하시니","reference":"요한복음 19:11","category":"$undefined"},{"id":"26838","book":"요한복음","book_name":"요한복음","chapter":19,"verse":12,"text":"이러하므로 빌라도가 예수를 놓으려고 힘썼으나 유대인들이 소리질러 가로되 `이 사람을 놓으면 가이사의 충신이 아니니이다 무릇 자기를 왕이라 하는 자는 가이사를 반역하는 것이니이다'","reference":"요한복음 19:12","category":"$undefined"},{"id":"26839","book":"요한복음","book_name":"요한복음","chapter":19,"verse":13,"text":"빌라도가 이 말을 듣고 예수를 끌고 나와서 박석 히브리 말로 가바다 이란 곳에서 재판석에 앉았더라","reference":"요한복음 19:13","category":"$undefined"},{"id":"26840","book":"요한복음","book_name":"요한복음","chapter":19,"verse":14,"text":"이 날은 유월절의 예비일이요 때는 제 육시라 빌라도가 유대인들에게 이르되 보라 `너희 왕이로다'","reference":"요한복음 19:14","category":"$undefined"},{"id":"26841","book":"요한복음","book_name":"요한복음","chapter":19,"verse":15,"text":"저희가 소리지르되 `없이 하소서 ! 없이 하소서 ! 저를 십자가에 못 박게 하소서 !' 빌라도가 가로되 `내가 너희 왕을 십자가에 못 박으랴 ?' 대제사장들이 대답하되 `가이사 외에는 우리에게 왕이 없나이다' 하니","reference":"요한복음 19:15","category":"$undefined"},{"id":"26842","book":"요한복음","book_name":"요한복음","chapter":19,"verse":16,"text":"이에 예수를 십자가에 못 박히게 저희에게 넘겨주니라","reference":"요한복음 19:16","category":"$undefined"},{"id":"26843","book":"요한복음","book_name":"요한복음","chapter":19,"verse":17,"text":"저희가 예수를 맡으매 예수께서 자기의 십자가를 지시고 해골 (히브리 말로 골고다)이라 하는 곳에 나오시니","reference":"요한복음 19:17","category":"$undefined"},{"id":"26844","book":"요한복음","book_name":"요한복음","chapter":19,"verse":18,"text":"저희가 거기서 예수를 십자가에 못 박을새 다른 두 사람도 그와 함께 좌우편에 못 박으니 예수는 가운데 있더라","reference":"요한복음 19:18","category":"$undefined"},{"id":"26845","book":"요한복음","book_name":"요한복음","chapter":19,"verse":19,"text":"빌라도가 패를 써서 십자가 위에 붙이니 나사렛 예수 유대인의 왕이라 기록되었더라","reference":"요한복음 19:19","category":"$undefined"},{"id":"26846","book":"요한복음","book_name":"요한복음","chapter":19,"verse":20,"text":"예수의 못 박히신 곳이 성에서 가까운 고로 많은 유대인이 이 패를 읽는데 히브리와 로마와 헬라 말로 기록되었더라","reference":"요한복음 19:20","category":"$undefined"},{"id":"26847","book":"요한복음","book_name":"요한복음","chapter":19,"verse":21,"text":"유대인의 대제사장들이 빌라도에게 이르되 `유대인의 왕이라 말고 자칭 유대인의 왕이라 쓰라' 하니","reference":"요한복음 19:21","category":"$undefined"},{"id":"26848","book":"요한복음","book_name":"요한복음","chapter":19,"verse":22,"text":"빌라도가 대답하되 `나의 쓸 것을 썼다 !' 하니라","reference":"요한복음 19:22","category":"$undefined"},{"id":"26849","book":"요한복음","book_name":"요한복음","chapter":19,"verse":23,"text":"군병들이 예수를 십자가에 못 박히고 그의 옷을 취하여 네 깃에 나눠 각각 한 깃씩 얻고 속옷도 취하니 이 속옷은 호지 아니하고 위에서부터 통으로 짠 것이라","reference":"요한복음 19:23","category":"$undefined"},{"id":"26850","book":"요한복음","book_name":"요한복음","chapter":19,"verse":24,"text":"군병들이 서로 말하되 이것을 찢지 말고 누가 얻나 제비 뽑자 하니 이는 성경에 저희가 내 옷을 나누고 내 옷을 제비 뽑나이다 한 것을 응하게 하려 함이러라 군병들은 이런 일을 하고","reference":"요한복음 19:24","category":"$undefined"},{"id":"26851","book":"요한복음","book_name":"요한복음","chapter":19,"verse":25,"text":"예수의 십자가 곁에는 그 모친과 이모와 글로바의 아내 마리아와 막달라 마리아가 섰는지라","reference":"요한복음 19:25","category":"$undefined"},{"id":"26852","book":"요한복음","book_name":"요한복음","chapter":19,"verse":26,"text":"예수께서 그 모친과 사랑하시는 제자가 곁에 섰는 것을 보시고 그 모친께 말씀하시되 `여자여, 보소서 아들이니이다' 하시고","reference":"요한복음 19:26","category":"$undefined"},{"id":"26853","book":"요한복음","book_name":"요한복음","chapter":19,"verse":27,"text":"또 그 제자에게 이르시되 `보라, 네 어머니라' 하신대 그 때부터 그 제자가 자기 집에 모시니라","reference":"요한복음 19:27","category":"$undefined"},{"id":"26854","book":"요한복음","book_name":"요한복음","chapter":19,"verse":28,"text":"이 후에 예수께서 모든 일이 이미 이룬 줄 아시고 성경으로 응하게 하려 하사 가라사대 `내가 목마르다' 하시니","reference":"요한복음 19:28","category":"$undefined"},{"id":"26855","book":"요한복음","book_name":"요한복음","chapter":19,"verse":29,"text":"거기 신 포도주가 가득히 담긴 그릇이 있는지라 사람들이 신 포도주를 머금은 해융을 우슬초에 매어 예수의 입에 대니","reference":"요한복음 19:29","category":"$undefined"},{"id":"26856","book":"요한복음","book_name":"요한복음","chapter":19,"verse":30,"text":"예수께서 신 포도주를 받으신 후 가라사대 `다 이루었다 !' 하시고 머리를 숙이시고 영혼이 돌아가시니라","reference":"요한복음 19:30","category":"$undefined"},{"id":"26857","book":"요한복음","book_name":"요한복음","chapter":19,"verse":31,"text":"이 날은 예비일이라 유대인들은 그 안식일이 큰 날이므로 그 안식일에 시체들을 십자가에 두지 아니하려 하여 빌라도에게 그들의 다리를 꺾어 시체를 치워 달라 하니","reference":"요한복음 19:31","category":"$undefined"},{"id":"26858","book":"요한복음","book_name":"요한복음","chapter":19,"verse":32,"text":"군병들이 가서 예수와 함께 못박힌 첫째 사람과 또 다른 사람의 다리를 꺾고","reference":"요한복음 19:32","category":"$undefined"},{"id":"26859","book":"요한복음","book_name":"요한복음","chapter":19,"verse":33,"text":"예수께 이르러는 이미 죽은 것을 보고 다리를 꺾지 아니하고","reference":"요한복음 19:33","category":"$undefined"},{"id":"26860","book":"요한복음","book_name":"요한복음","chapter":19,"verse":34,"text":"그 중 한 군병이 창으로 옆구리를 찌르니 곧 피와 물이 나오더라","reference":"요한복음 19:34","category":"$undefined"},{"id":"26861","book":"요한복음","book_name":"요한복음","chapter":19,"verse":35,"text":"이를 본 자가 증거하였으니 그 증거가 참이라 저가 자기의 말하는 것이 참인 줄 알고 너희로 믿게 하려 함이니라","reference":"요한복음 19:35","category":"$undefined"},{"id":"26862","book":"요한복음","book_name":"요한복음","chapter":19,"verse":36,"text":"이 일이 이룬 것은 그 뼈가 하나도 꺾이우지 아니하리라 한 성경을 응하게 하려 함이라","reference":"요한복음 19:36","category":"$undefined"},{"id":"26863","book":"요한복음","book_name":"요한복음","chapter":19,"verse":37,"text":"또 다른 성경에 저희가 그 찌른 자를 보리라 하였느니라","reference":"요한복음 19:37","category":"$undefined"},{"id":"26864","book":"요한복음","book_name":"요한복음","chapter":19,"verse":38,"text":"아리마대 사람 요셉이 예수의 제자나 유대인을 두려워하여 은휘하더니 이 일 후에 빌라도더러 예수의 시체를 가져가기를 구하매 빌라도가 허락하는지라 이에 가서 예수의 시체를 가져가니라","reference":"요한복음 19:38","category":"$undefined"},{"id":"26865","book":"요한복음","book_name":"요한복음","chapter":19,"verse":39,"text":"일찍 예수께 밤에 나아왔던 니고데모도 몰약과 침향 섞은 것을 백 근쯤 가지고 온지라","reference":"요한복음 19:39","category":"$undefined"},{"id":"26866","book":"요한복음","book_name":"요한복음","chapter":19,"verse":40,"text":"이에 예수의 시체를 가져다가 유대인의 장례법대로 그 향품과 함께 세마포로 쌌더라","reference":"요한복음 19:40","category":"$undefined"},{"id":"26867","book":"요한복음","book_name":"요한복음","chapter":19,"verse":41,"text":"예수의 십자가에 못 박히신 곳에 동산이 있고 동산 안에 아직 사람을 장사한 일이 없는 새 무덤이 있는지라","reference":"요한복음 19:41","category":"$undefined"},{"id":"26868","book":"요한복음","book_name":"요한복음","chapter":19,"verse":42,"text":"이 날은 유대인의 예비일이요 또 무덤이 가까운 고로 예수를 거기 두니라","reference":"요한복음 19:42","category":"$undefined"}],"bookSlug":"john"}]
