2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":21,"verses":[{"id":"26900","book":"요한복음","book_name":"요한복음","chapter":21,"verse":1,"text":"그 후에 예수께서 디베랴 바다에서 또 제자들에게 자기를 나타내셨으니 나타내신 일이 이러하니라","reference":"요한복음 21:1","category":"$undefined"},{"id":"26901","book":"요한복음","book_name":"요한복음","chapter":21,"verse":2,"text":"시몬 베드로와 디두모라 하는 도마와 갈릴리 가나 사람 나다나엘과 세베대의 아들들과 또 다른 제자 둘이 함께 있더니","reference":"요한복음 21:2","category":"$undefined"},{"id":"26902","book":"요한복음","book_name":"요한복음","chapter":21,"verse":3,"text":"시몬 베드로가 `나는 물고기 잡으러 가노라' 하매 저희가 `우리도 함께 가겠다' 하고 나가서 배에 올랐으나 이 밤에 아무 것도 잡지 못하였더니","reference":"요한복음 21:3","category":"$undefined"},{"id":"26903","book":"요한복음","book_name":"요한복음","chapter":21,"verse":4,"text":"날이 새어갈 때에 예수께서 바닷가에 서셨으나 제자들이 예수신줄 알지 못하는지라","reference":"요한복음 21:4","category":"$undefined"},{"id":"26904","book":"요한복음","book_name":"요한복음","chapter":21,"verse":5,"text":"예수께서 이르시되 얘들아 너희에게 고기가 있느냐 ? 대답하되 없나이다","reference":"요한복음 21:5","category":"$undefined"},{"id":"26905","book":"요한복음","book_name":"요한복음","chapter":21,"verse":6,"text":"가라사대 `그물을 배 오른 편에 던지라 그리하면 얻으리라' 하신대 이에 던졌더니 고기가 많아 그물을 들 수 없더라","reference":"요한복음 21:6","category":"$undefined"},{"id":"26906","book":"요한복음","book_name":"요한복음","chapter":21,"verse":7,"text":"예수의 사랑하시는 그 제자가 베드로에게 이르되 `주시라 !' 하니 시몬 베드로가 벗고 있다가 주(主)라 하는 말을 듣고 겉옷을 두른 후에 바다로 뛰어 내리더라","reference":"요한복음 21:7","category":"$undefined"},{"id":"26907","book":"요한복음","book_name":"요한복음","chapter":21,"verse":8,"text":"다른 제자들은 육지에서 상거가 불과 한 오십 간쯤 되므로 작은 배를 타고 고기 든 그물을 끌고 와서","reference":"요한복음 21:8","category":"$undefined"},{"id":"26908","book":"요한복음","book_name":"요한복음","chapter":21,"verse":9,"text":"육지에 올라 보니 숯불이 있는데 그 위에 생선이 놓였고 떡도 있더라","reference":"요한복음 21:9","category":"$undefined"},{"id":"26909","book":"요한복음","book_name":"요한복음","chapter":21,"verse":10,"text":"예수께서 가라사대 `지금 잡은 생선을 좀 가져오라' 하신대","reference":"요한복음 21:10","category":"$undefined"},{"id":"26910","book":"요한복음","book_name":"요한복음","chapter":21,"verse":11,"text":"시몬 베드로가 올라가서 그물을 육지에 끌어 올리니 가득히 찬 큰 고기가 일백 쉰 세 마리라 이같이 많으나 그물이 찢어지지 아니하였더라","reference":"요한복음 21:11","category":"$undefined"},{"id":"26911","book":"요한복음","book_name":"요한복음","chapter":21,"verse":12,"text":"예수께서 가라사대 `와서 조반을 먹으라' 하시니 제자들이 주(主)신줄 아는 고로 당신이 누구냐 ? 감히 묻는 자가 없더라","reference":"요한복음 21:12","category":"$undefined"},{"id":"26912","book":"요한복음","book_name":"요한복음","chapter":21,"verse":13,"text":"예수께서 가셔서 떡을 가져다가 저희에게 주시고 생선도 그와 같이 하시니라","reference":"요한복음 21:13","category":"$undefined"},{"id":"26913","book":"요한복음","book_name":"요한복음","chapter":21,"verse":14,"text":"이것은 예수께서 죽은 자 가운데서 살아나신 후에 세 번째로 제자들에게 나타나신 것이라","reference":"요한복음 21:14","category":"$undefined"},{"id":"26914","book":"요한복음","book_name":"요한복음","chapter":21,"verse":15,"text":"저희가 조반 먹은 후에 예수께서 시몬 베드로에게 이르시되 `요한의 아들 시몬아, 네가 이 사람들보다 나를 더 사랑하느냐 ?' 하시니 가로되 `주여, 그러하외다 내가 주를 사랑하는 줄 주께서 아시나이다' 가라사대 `내 어린 양을 먹이라' 하시고","reference":"요한복음 21:15","category":"$undefined"},{"id":"26915","book":"요한복음","book_name":"요한복음","chapter":21,"verse":16,"text":"또 두 번째 가라사대 `요한의 아들 시몬아, 네가 나를 사랑하느냐 ?' 하시니 가로되 `주여, 그러하외다 내가 주를 사랑하는 줄 주께서 아시나이다' 가라사대 `내 양을 치라' 하시고","reference":"요한복음 21:16","category":"$undefined"},{"id":"26916","book":"요한복음","book_name":"요한복음","chapter":21,"verse":17,"text":"세 번째 가라사대 `요한의 아들 시몬아, 네가 나를 사랑하느냐 ?' 하시니 주께서 세 번째 네가 나를 사랑하느냐 ? 하시므로 베드로가 근심하여 가로되 `주여, 모든 것을 아시오매 내가 주를 사랑하는 줄을 주께서 아시나이다' 예수께서 가라사대 `내 양을 먹이라'","reference":"요한복음 21:17","category":"$undefined"},{"id":"26917","book":"요한복음","book_name":"요한복음","chapter":21,"verse":18,"text":"`내가 진실로 진실로 네게 이르노니 젊어서는 네가 스스로 띠 띠고 원하는 곳으로 다녔거니와 늙어서는 내 팔을 벌리리니 남이 네게 띠 띠우고 원치 아니하는 곳으로 데려가리라'","reference":"요한복음 21:18","category":"$undefined"},{"id":"26918","book":"요한복음","book_name":"요한복음","chapter":21,"verse":19,"text":"이 말씀을 하심은 베드로가 어떠한 죽음으로 하나님께 영광을 돌릴 것을 가리키심이러라 이 말씀을 하시고 베드로에게 이르시되 나를 따르라 하시니","reference":"요한복음 21:19","category":"$undefined"},{"id":"26919","book":"요한복음","book_name":"요한복음","chapter":21,"verse":20,"text":"베드로가 돌이켜 예수의 사랑하시는 그 제자가 따르는 것을 보니 그는 만찬석에서 예수의 품에 의지하여 `주여, 주를 파는 자가 누구오니이까 ?' 묻던 자러라","reference":"요한복음 21:20","category":"$undefined"},{"id":"26920","book":"요한복음","book_name":"요한복음","chapter":21,"verse":21,"text":"이에 베드로가 그를 보고 예수께 여짜오되 `주여, 이 사람은 어떻게 되겠삽나이까 ?'","reference":"요한복음 21:21","category":"$undefined"},{"id":"26921","book":"요한복음","book_name":"요한복음","chapter":21,"verse":22,"text":"예수께서 가라사대 `내가 올 때까지 그를 머물게 하고자 할지라도 네게 무슨 상관이냐 ? 너는 나를 따르라 !' 하시더라","reference":"요한복음 21:22","category":"$undefined"},{"id":"26922","book":"요한복음","book_name":"요한복음","chapter":21,"verse":23,"text":"이 말씀이 형제들에게 나가서 그 제자는 죽지 아니하겠다 하였으나 예수의 말씀은 그가 죽지 않겠다 하신 것이 아니라 내가 올 때까지 그를 머물게 하고자 할지라도 네게 무슨 상관이냐 ? 하신 것이러라","reference":"요한복음 21:23","category":"$undefined"},{"id":"26923","book":"요한복음","book_name":"요한복음","chapter":21,"verse":24,"text":"이 일을 증거하고 이 일을 기록한 제자가 이 사람이라 우리는 그의 증거가 참인 줄 아노라","reference":"요한복음 21:24","category":"$undefined"},{"id":"26924","book":"요한복음","book_name":"요한복음","chapter":21,"verse":25,"text":"예수의 행하신 일이 이 외에도 많으니 만일 낱낱이 기록된다면 이 세상이라도 이 기록된 책을 두기에 부족할 줄 아노라","reference":"요한복음 21:25","category":"$undefined"}],"bookSlug":"john"}]
