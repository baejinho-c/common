2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":4,"verses":[{"id":"26158","book":"요한복음","book_name":"요한복음","chapter":4,"verse":1,"text":"예수의 제자를 삼고 세례를 주는 것이 요한보다 많다 하는 말을 바리새인들이 들은 줄을 주께서 아신지라","reference":"요한복음 4:1","category":"$undefined"},{"id":"26159","book":"요한복음","book_name":"요한복음","chapter":4,"verse":2,"text":"(예수께서 친히 세례를 주신 것이 아니요 제자들이 준 것이라)","reference":"요한복음 4:2","category":"$undefined"},{"id":"26160","book":"요한복음","book_name":"요한복음","chapter":4,"verse":3,"text":"유대를 떠나사 다시 갈릴리로 가실새","reference":"요한복음 4:3","category":"$undefined"},{"id":"26161","book":"요한복음","book_name":"요한복음","chapter":4,"verse":4,"text":"사마리아로 통행하여야 하겠는지라","reference":"요한복음 4:4","category":"$undefined"},{"id":"26162","book":"요한복음","book_name":"요한복음","chapter":4,"verse":5,"text":"사마리아에 있는 수가라 하는 동네에 이르시니 야곱이 그 아들 요셉에게 준 땅이 가깝고","reference":"요한복음 4:5","category":"$undefined"},{"id":"26163","book":"요한복음","book_name":"요한복음","chapter":4,"verse":6,"text":"거기 또 야곱의 우물이 있더라 예수께서 행로에 곤하여 우물 곁에 그대로 앉으시니 때가 제 육시쯤 되었더라","reference":"요한복음 4:6","category":"$undefined"},{"id":"26164","book":"요한복음","book_name":"요한복음","chapter":4,"verse":7,"text":"사마리아 여자 하나가 물을 길러 왔으매 예수께서 물을 좀 달라 하시니","reference":"요한복음 4:7","category":"$undefined"},{"id":"26165","book":"요한복음","book_name":"요한복음","chapter":4,"verse":8,"text":"이는 제자들이 먹을 것을 사러 동네에 들어갔음이러라","reference":"요한복음 4:8","category":"$undefined"},{"id":"26166","book":"요한복음","book_name":"요한복음","chapter":4,"verse":9,"text":"사마리아 여자가 가로되 `당신은 유대인으로서 어찌하여 사마리아 여자 나에게 물을 달라 하나이까 ?' 하니 이는 유대인이 사마리아인과 상종치 아니함이러라","reference":"요한복음 4:9","category":"$undefined"},{"id":"26167","book":"요한복음","book_name":"요한복음","chapter":4,"verse":10,"text":"예수께서 대답하여 가라사대 `네가 만일 하나님의 선물과 또 네게 물좀 달라 하는 이가 누구인줄 알았더면 네가 그에게 구하였을 것이요 그가 생수를 네게 주었으리라'","reference":"요한복음 4:10","category":"$undefined"},{"id":"26168","book":"요한복음","book_name":"요한복음","chapter":4,"verse":11,"text":"여자가 가로되 `주여, 물 길을 그릇도 없고 이 우물은 깊은데 어디서 이 생수를 얻겠삽나이까 ?","reference":"요한복음 4:11","category":"$undefined"},{"id":"26169","book":"요한복음","book_name":"요한복음","chapter":4,"verse":12,"text":"우리 조상 야곱이 이 우물을 우리에게 주었고 또 여기서 자기와 자기 아들들과 짐승이 다 먹었으니 당신이 야곱보다 더 크니이까 ?'","reference":"요한복음 4:12","category":"$undefined"},{"id":"26170","book":"요한복음","book_name":"요한복음","chapter":4,"verse":13,"text":"예수께서 대답하여 가라사대 `이 물을 먹는 자마다 다시 목마르려니와","reference":"요한복음 4:13","category":"$undefined"},{"id":"26171","book":"요한복음","book_name":"요한복음","chapter":4,"verse":14,"text":"내가 주는 물을 먹는 자는 영원히 목마르지 아니하리니 나의 주는 물은 그 속에서 영생하도록 솟아나는 샘물이 되리라'","reference":"요한복음 4:14","category":"$undefined"},{"id":"26172","book":"요한복음","book_name":"요한복음","chapter":4,"verse":15,"text":"여자가 가로되 `주여, 이런 물을 내게 주사 목마르지도 않고 또 여기 물 길러 오지도 않게 하옵소서'","reference":"요한복음 4:15","category":"$undefined"},{"id":"26173","book":"요한복음","book_name":"요한복음","chapter":4,"verse":16,"text":"가라사대 `가서 네 남편을 불러오라'","reference":"요한복음 4:16","category":"$undefined"},{"id":"26174","book":"요한복음","book_name":"요한복음","chapter":4,"verse":17,"text":"여자가 대답하여 가로되 나는 남편이 없나이다 예수께서 가라사대 네가 남편이 없다 하는 말이 옳도다","reference":"요한복음 4:17","category":"$undefined"},{"id":"26175","book":"요한복음","book_name":"요한복음","chapter":4,"verse":18,"text":"네가 남편 다섯이 있었으나 지금 있는 자는 네 남편이 아니니 네 말이 참되도다","reference":"요한복음 4:18","category":"$undefined"},{"id":"26176","book":"요한복음","book_name":"요한복음","chapter":4,"verse":19,"text":"여자가 가로되 `주여, 내가 보니 선지자로소이다","reference":"요한복음 4:19","category":"$undefined"},{"id":"26177","book":"요한복음","book_name":"요한복음","chapter":4,"verse":20,"text":"우리 조상들은 이 산에서 예배하였는데 당신들의 말은 예배 할 곳이 예루살렘에 있다 하더이다'","reference":"요한복음 4:20","category":"$undefined"},{"id":"26178","book":"요한복음","book_name":"요한복음","chapter":4,"verse":21,"text":"예수께서 가라사대 `여자여, 내말을 믿으라 ! 이 산에서도 말고 예루살렘에서도 말고 너희가 아버지께 예배할 때가 이르리라","reference":"요한복음 4:21","category":"$undefined"},{"id":"26179","book":"요한복음","book_name":"요한복음","chapter":4,"verse":22,"text":"너희는 알지 못하는 것을 예배하고 우리는 아는 것을 예배하노니 이는 구원이 유대인에게서 남이니라","reference":"요한복음 4:22","category":"$undefined"},{"id":"26180","book":"요한복음","book_name":"요한복음","chapter":4,"verse":23,"text":"아버지께 참으로 예배하는 자들은 신령과 진정으로 예배할 때가 오나니 곧 이 때라 아버지께서는 이렇게 자기에게 예배하는 자들을 찾으시느니라","reference":"요한복음 4:23","category":"$undefined"},{"id":"26181","book":"요한복음","book_name":"요한복음","chapter":4,"verse":24,"text":"하나님은 영이시니 예배하는 자가 신령과 진정으로 예배할지니라'","reference":"요한복음 4:24","category":"$undefined"},{"id":"26182","book":"요한복음","book_name":"요한복음","chapter":4,"verse":25,"text":"여자가 가로되 `메시야 곧 그리스도라 하는 이가 오실 줄을 내가 아노니 그가 오시면 모든 것을 우리에게 고하시리이다'","reference":"요한복음 4:25","category":"$undefined"},{"id":"26183","book":"요한복음","book_name":"요한복음","chapter":4,"verse":26,"text":"예수께서 이르시되 `네게 말하는 내가 그로라 !' 하시니라","reference":"요한복음 4:26","category":"$undefined"},{"id":"26184","book":"요한복음","book_name":"요한복음","chapter":4,"verse":27,"text":"이 때에 제자들이 돌아와서 예수께서 여자와 말씀하시는 것을 이상히 여겼으나 무엇을 구하시나이까 ? 어찌하여 저와 말씀하시나이까 ? 묻는 이가 없더라","reference":"요한복음 4:27","category":"$undefined"},{"id":"26185","book":"요한복음","book_name":"요한복음","chapter":4,"verse":28,"text":"여자가 물동이를 버려두고 동네에 들어가서 사람들에게 이르되","reference":"요한복음 4:28","category":"$undefined"},{"id":"26186","book":"요한복음","book_name":"요한복음","chapter":4,"verse":29,"text":"`나의 행한 모든 일을 내게 말한 사람을 와 보라 ! 이는 그리스도가 아니냐 ?' 하니","reference":"요한복음 4:29","category":"$undefined"},{"id":"26187","book":"요한복음","book_name":"요한복음","chapter":4,"verse":30,"text":"저희가 동네에서 나와 예수께로 오더라","reference":"요한복음 4:30","category":"$undefined"},{"id":"26188","book":"요한복음","book_name":"요한복음","chapter":4,"verse":31,"text":"그 사이에 제자들이 청하여 가로되 `랍비여, 잡수소서'","reference":"요한복음 4:31","category":"$undefined"},{"id":"26189","book":"요한복음","book_name":"요한복음","chapter":4,"verse":32,"text":"가라사대 `내게는 너희가 알지 못하는 먹을 양식이 있느니라'","reference":"요한복음 4:32","category":"$undefined"},{"id":"26190","book":"요한복음","book_name":"요한복음","chapter":4,"verse":33,"text":"제자들이 서로 말하되 `누가 잡수실 것을 갖다 드렸는가' 한대","reference":"요한복음 4:33","category":"$undefined"},{"id":"26191","book":"요한복음","book_name":"요한복음","chapter":4,"verse":34,"text":"예수께서 이르시되 `나의 양식은 나를 보내신 이의 뜻을 행하며 그의 일을 온전히 이루는 이것이니라","reference":"요한복음 4:34","category":"$undefined"},{"id":"26192","book":"요한복음","book_name":"요한복음","chapter":4,"verse":35,"text":"너희가 넉 달이 지나야 추수할 때가 이르겠다 하지 아니하느냐 ? 내가 너희에게 이르노니 눈을 들어 밭을 보라 희어져 추수하게 되었도다","reference":"요한복음 4:35","category":"$undefined"},{"id":"26193","book":"요한복음","book_name":"요한복음","chapter":4,"verse":36,"text":"거두는 자가 이미 삯도 받고 영생에 이르는 열매를 모으나니 이는 뿌리는 자와 거두는 자가 함께 즐거워 하게 하려 함이니라","reference":"요한복음 4:36","category":"$undefined"},{"id":"26194","book":"요한복음","book_name":"요한복음","chapter":4,"verse":37,"text":"그런즉 한 사람이 심고 다른 사람이 거둔다 하는 말이 옳도다","reference":"요한복음 4:37","category":"$undefined"},{"id":"26195","book":"요한복음","book_name":"요한복음","chapter":4,"verse":38,"text":"내가 너희로 노력지 아니한 것을 거두러 보내었노니 다른 사람들은 노력하였고 너희는 그들의 노력한 것에 참예하였느니라'","reference":"요한복음 4:38","category":"$undefined"},{"id":"26196","book":"요한복음","book_name":"요한복음","chapter":4,"verse":39,"text":"여자의 말이 그가 나의 행한 모든 것을 내게 말하였다 증거하므로 그 동리 중에 많은 사마리아인이 예수를 믿는지라","reference":"요한복음 4:39","category":"$undefined"},{"id":"26197","book":"요한복음","book_name":"요한복음","chapter":4,"verse":40,"text":"사마리아인들이 예수께 와서 자기들과 함께 유하기를 청하니 거기서 이틀을 유하시매","reference":"요한복음 4:40","category":"$undefined"},{"id":"26198","book":"요한복음","book_name":"요한복음","chapter":4,"verse":41,"text":"예수의 말씀을 인하여 믿는 자가 더욱 많아","reference":"요한복음 4:41","category":"$undefined"},{"id":"26199","book":"요한복음","book_name":"요한복음","chapter":4,"verse":42,"text":"그 여자에게 말하되 `이제 우리가 믿는 것은 네 말을 인함이 아니니 이는 우리가 친히 듣고 그가 참으로 세상의 구주신 줄 앎이니라' 하였더라","reference":"요한복음 4:42","category":"$undefined"},{"id":"26200","book":"요한복음","book_name":"요한복음","chapter":4,"verse":43,"text":"이틀이 지나매 예수께서 거기를 떠나 갈릴리로 가시며","reference":"요한복음 4:43","category":"$undefined"},{"id":"26201","book":"요한복음","book_name":"요한복음","chapter":4,"verse":44,"text":"친히 증거하시기를 `선지자가 고향에서는 높임을 받지 못한다' 하시고","reference":"요한복음 4:44","category":"$undefined"},{"id":"26202","book":"요한복음","book_name":"요한복음","chapter":4,"verse":45,"text":"갈릴리에 이르시매 갈릴리인들이 그를 영접하니 이는 자기들도 명절에 갔다가 예수께서 명절 중 예루살렘에서 하신 모든 일을 보았음이더라","reference":"요한복음 4:45","category":"$undefined"},{"id":"26203","book":"요한복음","book_name":"요한복음","chapter":4,"verse":46,"text":"예수께서 다시 갈릴리 가나에 이르시니 전에 물로 포도주를 만드신 곳이라 왕의 신하가 있어 그 아들이 가버나움에서 병들었더니","reference":"요한복음 4:46","category":"$undefined"},{"id":"26204","book":"요한복음","book_name":"요한복음","chapter":4,"verse":47,"text":"그가 예수께서 유대로부터 갈릴리에 오심을 듣고 가서 청하되 내려오셔서 내 아들의 병을 고쳐 주소서 하니 저가 거의 죽게 되었음이라","reference":"요한복음 4:47","category":"$undefined"},{"id":"26205","book":"요한복음","book_name":"요한복음","chapter":4,"verse":48,"text":"예수께서 가라사대 `너희는 표적과 기사를 보지 못하면 도무지 믿지 아니하리라'","reference":"요한복음 4:48","category":"$undefined"},{"id":"26206","book":"요한복음","book_name":"요한복음","chapter":4,"verse":49,"text":"신하가 가로되 `주여, 내 아이가 죽기 전에 내려오소서'","reference":"요한복음 4:49","category":"$undefined"},{"id":"26207","book":"요한복음","book_name":"요한복음","chapter":4,"verse":50,"text":"예수께서 가라사대 `가라, 네 아들이 살았다' 하신대 그 사람이 예수의 하신 말씀을 믿고 가더니","reference":"요한복음 4:50","category":"$undefined"},{"id":"26208","book":"요한복음","book_name":"요한복음","chapter":4,"verse":51,"text":"내려가는 길에서 그 종들이 오다가 만나서 아이가 살았다 하거늘","reference":"요한복음 4:51","category":"$undefined"},{"id":"26209","book":"요한복음","book_name":"요한복음","chapter":4,"verse":52,"text":"그 낫기 시작한 때를 물은즉 어제 제 칠시에 열기가 떨어졌나이다 하는지라","reference":"요한복음 4:52","category":"$undefined"},{"id":"26210","book":"요한복음","book_name":"요한복음","chapter":4,"verse":53,"text":"아비가 예수께서 네 아들이 살았다 말씀하신 그 때인 줄 알고 자기와 그 온 집안이 다 믿으니라","reference":"요한복음 4:53","category":"$undefined"},{"id":"26211","book":"요한복음","book_name":"요한복음","chapter":4,"verse":54,"text":"이것은 예수께서 유대에서 갈릴리로 오신 후 행하신 두 번째 표적이니라","reference":"요한복음 4:54","category":"$undefined"}],"bookSlug":"john"}]
