2:["$","$L11",null,{"book":{"id":"john","name":"요한복음","chapters":21,"testament":"new"},"chapter":6,"verses":[{"id":"26259","book":"요한복음","book_name":"요한복음","chapter":6,"verse":1,"text":"그 후에 예수께서 갈릴리 바다 곧 디베랴 바다 건너편으로 가시매","reference":"요한복음 6:1","category":"$undefined"},{"id":"26260","book":"요한복음","book_name":"요한복음","chapter":6,"verse":2,"text":"큰 무리가 따르니 이는 병인들에게 행하시는 표적을 봄이러라","reference":"요한복음 6:2","category":"$undefined"},{"id":"26261","book":"요한복음","book_name":"요한복음","chapter":6,"verse":3,"text":"예수께서 산에 오르사 제자들과 함께 거기 앉으시니","reference":"요한복음 6:3","category":"$undefined"},{"id":"26262","book":"요한복음","book_name":"요한복음","chapter":6,"verse":4,"text":"마침 유대인의 명절인 유월절이 가까운지라","reference":"요한복음 6:4","category":"$undefined"},{"id":"26263","book":"요한복음","book_name":"요한복음","chapter":6,"verse":5,"text":"예수께서 눈을 들어 큰 무리가 자기에게로 오는 것을 보시고 빌립에게 이르시되 `우리가 어디서 떡을 사서 이 사람들로 먹게 하겠느냐 ?' 하시니","reference":"요한복음 6:5","category":"$undefined"},{"id":"26264","book":"요한복음","book_name":"요한복음","chapter":6,"verse":6,"text":"이렇게 말씀하심은 친히 어떻게 하실 것을 아시고 빌립을 시험코자 하심이라","reference":"요한복음 6:6","category":"$undefined"},{"id":"26265","book":"요한복음","book_name":"요한복음","chapter":6,"verse":7,"text":"빌립이 대답하되 `각 사람으로 조금씩 받게 할지라도 이백 데나리온의 떡이 부족하리이다'","reference":"요한복음 6:7","category":"$undefined"},{"id":"26266","book":"요한복음","book_name":"요한복음","chapter":6,"verse":8,"text":"제자 중 하나 곧 시몬 베드로의 형제 안드레가 예수께 여짜오되","reference":"요한복음 6:8","category":"$undefined"},{"id":"26267","book":"요한복음","book_name":"요한복음","chapter":6,"verse":9,"text":"`여기 한 아이가 있어 보리떡 다섯개와 물고기 두 마리를 가졌나이다 그러나 그것이 이 많은 사람에게 얼마나 되겠삽나이까 ?'","reference":"요한복음 6:9","category":"$undefined"},{"id":"26268","book":"요한복음","book_name":"요한복음","chapter":6,"verse":10,"text":"예수께서 가라사대 `이 사람들로 앉게 하라' 하신대 그 곳에 잔디가 많은지라 사람들이 앉으니 수효가 오천쯤 되더라","reference":"요한복음 6:10","category":"$undefined"},{"id":"26269","book":"요한복음","book_name":"요한복음","chapter":6,"verse":11,"text":"예수께서 떡을 가져 축사하신 후에 앉은 자들에게 나눠 주시고 고기도 그렇게 저희의 원대로 주시다","reference":"요한복음 6:11","category":"$undefined"},{"id":"26270","book":"요한복음","book_name":"요한복음","chapter":6,"verse":12,"text":"저희가 배부른 후에 예수께서 제자들에게 이르시되 `남은 조각을 거두고 버리는 것이 없게 하라' 하시므로","reference":"요한복음 6:12","category":"$undefined"},{"id":"26271","book":"요한복음","book_name":"요한복음","chapter":6,"verse":13,"text":"이에 거두니 보리떡 다섯개로 먹고 남은 조각이 열 두 바구니에 찼더라","reference":"요한복음 6:13","category":"$undefined"},{"id":"26272","book":"요한복음","book_name":"요한복음","chapter":6,"verse":14,"text":"그 사람들이 예수의 행하신 이 표적을 보고 말하되 `이는 참으로 세상에 오실 그 선지자라' 하더라","reference":"요한복음 6:14","category":"$undefined"},{"id":"26273","book":"요한복음","book_name":"요한복음","chapter":6,"verse":15,"text":"그러므로 예수께서 저희가 와서 자기를 억지로 잡아 임금 삼으려는 줄을 아시고 다시 혼자 산으로 떠나 가시니라","reference":"요한복음 6:15","category":"$undefined"},{"id":"26274","book":"요한복음","book_name":"요한복음","chapter":6,"verse":16,"text":"저물매 제자들이 바다에 내려가서","reference":"요한복음 6:16","category":"$undefined"},{"id":"26275","book":"요한복음","book_name":"요한복음","chapter":6,"verse":17,"text":"배를 타고 바다를 건너 가버나움으로 가는데 이미 어두웠고 예수는 아직 저희에게 오시지 아니하셨더니","reference":"요한복음 6:17","category":"$undefined"},{"id":"26276","book":"요한복음","book_name":"요한복음","chapter":6,"verse":18,"text":"큰 바람이 불어 파도가 일어나더라","reference":"요한복음 6:18","category":"$undefined"},{"id":"26277","book":"요한복음","book_name":"요한복음","chapter":6,"verse":19,"text":"제자들이 노를 저어 십여리쯤 가다가 예수께서 바다 위로 걸어 배에 가까이 오심을 보고 두려워하거늘","reference":"요한복음 6:19","category":"$undefined"},{"id":"26278","book":"요한복음","book_name":"요한복음","chapter":6,"verse":20,"text":"가라사대 `내니 두려워 말라 !' 하신대","reference":"요한복음 6:20","category":"$undefined"},{"id":"26279","book":"요한복음","book_name":"요한복음","chapter":6,"verse":21,"text":"이에 기뻐서 배로 영접하니 배는 곧 저희의 가려던 땅에 이르렀더라","reference":"요한복음 6:21","category":"$undefined"},{"id":"26280","book":"요한복음","book_name":"요한복음","chapter":6,"verse":22,"text":"이튿날 바다 건너편에 섰는 무리가 배 한 척밖에 다른 배가 거기 없는 것과 또 어제 예수께서 제자들과 함께 그 배에 오르지 아니하시고 제자들만 가는 것을 보았더니","reference":"요한복음 6:22","category":"$undefined"},{"id":"26281","book":"요한복음","book_name":"요한복음","chapter":6,"verse":23,"text":"(그러나 디베랴에서 배들이 주의 축사하신 후 여럿이 떡 먹던 그곳에 가까이 왔더라)","reference":"요한복음 6:23","category":"$undefined"},{"id":"26282","book":"요한복음","book_name":"요한복음","chapter":6,"verse":24,"text":"무리가 거기 예수도 없으시고 제자들도 없음을 보고 곧 배들을 타고 예수를 찾으러 가버나움으로 가서","reference":"요한복음 6:24","category":"$undefined"},{"id":"26283","book":"요한복음","book_name":"요한복음","chapter":6,"verse":25,"text":"바다 건너편에서 만나 `랍비여, 어느 때에 여기 오셨나이까 ?' 하니","reference":"요한복음 6:25","category":"$undefined"},{"id":"26284","book":"요한복음","book_name":"요한복음","chapter":6,"verse":26,"text":"예수께서 대답하여 가라사대 `내가 진실로 진실로 너희에게 이르노니 너희가 나를 찾는 것은 표적을 본 까닭이 아니요 떡을 먹고 배부른 까닭이로다","reference":"요한복음 6:26","category":"$undefined"},{"id":"26285","book":"요한복음","book_name":"요한복음","chapter":6,"verse":27,"text":"썩는 양식을 위하여 일하지 말고 영생하도록 있는 양식을 위하여 하라 이 양식은 인자가 너희에게 주리니 인자는 아버지 하나님의 인치신 자니라'","reference":"요한복음 6:27","category":"$undefined"},{"id":"26286","book":"요한복음","book_name":"요한복음","chapter":6,"verse":28,"text":"저희가 묻되 `우리가 어떻게 하여야 하나님의 일을 하오리이까 ?'","reference":"요한복음 6:28","category":"$undefined"},{"id":"26287","book":"요한복음","book_name":"요한복음","chapter":6,"verse":29,"text":"예수께서 대답하여 가라사대 `하나님의 보내신 자를 믿는 것이 하나님의 일이니라' 하시니","reference":"요한복음 6:29","category":"$undefined"},{"id":"26288","book":"요한복음","book_name":"요한복음","chapter":6,"verse":30,"text":"저희가 묻되 `그러면 우리로 보고 당신을 믿게 행하시는 표적이 무엇이니이까 ? 하시는 일이 무엇이니이까 ?","reference":"요한복음 6:30","category":"$undefined"},{"id":"26289","book":"요한복음","book_name":"요한복음","chapter":6,"verse":31,"text":"기록된 바 하늘에서 저희에게 떡을 주어 먹게 하였다 함과 같이 우리 조상들은 광야에서 만나를 먹었나이다'","reference":"요한복음 6:31","category":"$undefined"},{"id":"26290","book":"요한복음","book_name":"요한복음","chapter":6,"verse":32,"text":"예수께서 이르시되 `내가 진실로 진실로 너희에게 이르노니 하늘에서 내린 떡은 모세가 준 것이 아니라 오직 내 아버지가 하늘에서 내린 참떡을 너희에게 주시나니","reference":"요한복음 6:32","category":"$undefined"},{"id":"26291","book":"요한복음","book_name":"요한복음","chapter":6,"verse":33,"text":"하나님의 떡은 하늘에서 내려 세상에게 생명을 주는 것이니라'","reference":"요한복음 6:33","category":"$undefined"},{"id":"26292","book":"요한복음","book_name":"요한복음","chapter":6,"verse":34,"text":"저희가 가로되 `주여, 이 떡을 항상 우리에게 주소서 !'","reference":"요한복음 6:34","category":"$undefined"},{"id":"26293","book":"요한복음","book_name":"요한복음","chapter":6,"verse":35,"text":"예수께서 가라사대 `내가 곧 생명의 떡이니 내게 오는 자는 결코 주리지 아니할 터이요 나를 믿는 자는 영원히 목마르지 아니하리라","reference":"요한복음 6:35","category":"$undefined"},{"id":"26294","book":"요한복음","book_name":"요한복음","chapter":6,"verse":36,"text":"그러나 내가 너희더러 이르기를 너희는 나를 보고도 믿지 아니하는도다 하였느니라","reference":"요한복음 6:36","category":"$undefined"},{"id":"26295","book":"요한복음","book_name":"요한복음","chapter":6,"verse":37,"text":"아버지께서 내게 주시는 자는 다 내게로 올 것이요 내게 오는 자는 내가 결코 내어 쫓지 아니하리라","reference":"요한복음 6:37","category":"$undefined"},{"id":"26296","book":"요한복음","book_name":"요한복음","chapter":6,"verse":38,"text":"내가 하늘로서 내려온 것은 내 뜻을 행하려 함이 아니요","reference":"요한복음 6:38","category":"$undefined"},{"id":"26297","book":"요한복음","book_name":"요한복음","chapter":6,"verse":39,"text":"나를 보내신 이의 뜻을 행하려 함이니라 나를 보내신 이의 뜻은 내게 주신 자 중에 내가 하나도 잃어 버리지 아니하고 마지막 날에 다시 살리는 이것이니라","reference":"요한복음 6:39","category":"$undefined"},{"id":"26298","book":"요한복음","book_name":"요한복음","chapter":6,"verse":40,"text":"내 아버지의 뜻은 아들을 보고 믿는 자마다 영생을 얻는 이것이니 마지막 날에 내가 이를 다시 살리리라' 하시니라","reference":"요한복음 6:40","category":"$undefined"},{"id":"26299","book":"요한복음","book_name":"요한복음","chapter":6,"verse":41,"text":"자기가 하늘로서 내려온 떡이라 하시므로 유대인들이 예수께 대하여 수군거려","reference":"요한복음 6:41","category":"$undefined"},{"id":"26300","book":"요한복음","book_name":"요한복음","chapter":6,"verse":42,"text":"가로되 `이는 요셉의 아들 예수가 아니냐 그 부모를 우리가 아는데 제가 지금 어찌하여 하늘로서 내려왔다 하느냐 ?'","reference":"요한복음 6:42","category":"$undefined"},{"id":"26301","book":"요한복음","book_name":"요한복음","chapter":6,"verse":43,"text":"예수께서 대답하여 가라사대 `너희는 서로 수군거리지 말라","reference":"요한복음 6:43","category":"$undefined"},{"id":"26302","book":"요한복음","book_name":"요한복음","chapter":6,"verse":44,"text":"나를 보내신 아버지께서 이끌지 아니하면 아무라도 내게 올 수 없으니 오는 그를 내가 마지막 날에 다시 살리리라","reference":"요한복음 6:44","category":"$undefined"},{"id":"26303","book":"요한복음","book_name":"요한복음","chapter":6,"verse":45,"text":"선지자의 글에 저희가 다 하나님의 가르치심을 받으리라 기록되었은즉 아버지께 듣고 배운 사람마다 내게로 오느니라","reference":"요한복음 6:45","category":"$undefined"},{"id":"26304","book":"요한복음","book_name":"요한복음","chapter":6,"verse":46,"text":"이는 아버지를 본 자가 다 있는 것이 아니라 오직 하나님에게서 온 자만 아버지를 보았느니라","reference":"요한복음 6:46","category":"$undefined"},{"id":"26305","book":"요한복음","book_name":"요한복음","chapter":6,"verse":47,"text":"진실로 진실로 너희에게 이르노니 믿는 자는 영생을 가졌나니","reference":"요한복음 6:47","category":"$undefined"},{"id":"26306","book":"요한복음","book_name":"요한복음","chapter":6,"verse":48,"text":"내가 곧 생명의 떡이로다","reference":"요한복음 6:48","category":"$undefined"},{"id":"26307","book":"요한복음","book_name":"요한복음","chapter":6,"verse":49,"text":"너희 조상들은 광야에서 만나를 먹었어도 죽었거니와","reference":"요한복음 6:49","category":"$undefined"},{"id":"26308","book":"요한복음","book_name":"요한복음","chapter":6,"verse":50,"text":"이는 하늘로서 내려오는 떡이니 사람으로 하여금 먹고 죽지 아니하게 하는 것이니라","reference":"요한복음 6:50","category":"$undefined"},{"id":"26309","book":"요한복음","book_name":"요한복음","chapter":6,"verse":51,"text":"나는 하늘로서 내려온 산 떡이니 사람이 이 떡을 먹으면 영생하리라 나의 줄 떡은 곧 세상의 생명을 위한 내 살이로라' 하시니라","reference":"요한복음 6:51","category":"$undefined"},{"id":"26310","book":"요한복음","book_name":"요한복음","chapter":6,"verse":52,"text":"이러므로 유대인들이 서로 다투어 가로되 `이 사람이 어찌 능히 제 살을 우리에게 주어 먹게 하겠느냐 ?'","reference":"요한복음 6:52","category":"$undefined"},{"id":"26311","book":"요한복음","book_name":"요한복음","chapter":6,"verse":53,"text":"예수께서 이르시되 `내가 진실로 진실로 너희에게 이르노니 인자의 살을 먹지 아니하고 인자의 피를 마시지 아니하면 너희 속에 생명이 없느니라","reference":"요한복음 6:53","category":"$undefined"},{"id":"26312","book":"요한복음","book_name":"요한복음","chapter":6,"verse":54,"text":"내 살을 먹고 내 피를 마시는 자는 영생을 가졌고 마지막 날에 내가 그를 다시 살리리니","reference":"요한복음 6:54","category":"$undefined"},{"id":"26313","book":"요한복음","book_name":"요한복음","chapter":6,"verse":55,"text":"내 살은 참된 양식이요 내 피는 참된 음료로다","reference":"요한복음 6:55","category":"$undefined"},{"id":"26314","book":"요한복음","book_name":"요한복음","chapter":6,"verse":56,"text":"내 살을 먹고 내 피를 마시는 자는 내 안에 거하고 나도 그 안에 거하나니","reference":"요한복음 6:56","category":"$undefined"},{"id":"26315","book":"요한복음","book_name":"요한복음","chapter":6,"verse":57,"text":"살아 계신 아버지께서 나를 보내시매 내가 아버지로 인하여 사는 것같이 나를 먹는 그 사람도 나로 인하여 살리라","reference":"요한복음 6:57","category":"$undefined"},{"id":"26316","book":"요한복음","book_name":"요한복음","chapter":6,"verse":58,"text":"이것은 하늘로서 내려온 떡이니 조상들이 먹고도 죽은 그것과 같지 아니하여 이 떡을 먹는 자는 영원히 살리라'","reference":"요한복음 6:58","category":"$undefined"},{"id":"26317","book":"요한복음","book_name":"요한복음","chapter":6,"verse":59,"text":"이 말씀은 예수께서 가버나움 회당에서 가르치실 때에 하셨느니라","reference":"요한복음 6:59","category":"$undefined"},{"id":"26318","book":"요한복음","book_name":"요한복음","chapter":6,"verse":60,"text":"제자 중 여럿이 듣고 말하되 `이 말씀은 어렵도다 누가 들을 수 있느냐 ?' 한대","reference":"요한복음 6:60","category":"$undefined"},{"id":"26319","book":"요한복음","book_name":"요한복음","chapter":6,"verse":61,"text":"예수께서 스스로 제자들이 이 말씀에 대하여 수군거리는 줄 아시고 가라사대 `이 말이 너희에게 걸림이 되느냐 ?","reference":"요한복음 6:61","category":"$undefined"},{"id":"26320","book":"요한복음","book_name":"요한복음","chapter":6,"verse":62,"text":"그러면 너희가 인자의 이전 있던 곳으로 올라가는 것을 볼 것 같으면 어찌 하려느냐 ?","reference":"요한복음 6:62","category":"$undefined"},{"id":"26321","book":"요한복음","book_name":"요한복음","chapter":6,"verse":63,"text":"살리는 것은 영이니 육은 무익하니라 내가 너희에게 이른 말이 영이요 생명이라","reference":"요한복음 6:63","category":"$undefined"},{"id":"26322","book":"요한복음","book_name":"요한복음","chapter":6,"verse":64,"text":"그러나 너희 중에 믿지 아니하는 자들이 있느니라' 하시니 이는 예수께서 믿지 아니하는 자들이 누구며 자기를 팔 자가 누군지 처음부터 아심이러라","reference":"요한복음 6:64","category":"$undefined"},{"id":"26323","book":"요한복음","book_name":"요한복음","chapter":6,"verse":65,"text":"또 가라사대 `이러하므로 전에 너희에게 말하기를 내 아버지께서 오게 하여 주지 아니하시면 누구든지 내게 올 수 없다 하였노라' 하시니라","reference":"요한복음 6:65","category":"$undefined"},{"id":"26324","book":"요한복음","book_name":"요한복음","chapter":6,"verse":66,"text":"이러므로 제자 중에 많이 물러가고 다시 그와 함께 다니지 아니하더라","reference":"요한복음 6:66","category":"$undefined"},{"id":"26325","book":"요한복음","book_name":"요한복음","chapter":6,"verse":67,"text":"예수께서 열 두 제자에게 이르시되 `너희도 가려느냐 ?'","reference":"요한복음 6:67","category":"$undefined"},{"id":"26326","book":"요한복음","book_name":"요한복음","chapter":6,"verse":68,"text":"시몬 베드로가 대답하여 `주여, 영생의 말씀이 계시매 우리가 뉘게로 가오리이까 ?","reference":"요한복음 6:68","category":"$undefined"},{"id":"26327","book":"요한복음","book_name":"요한복음","chapter":6,"verse":69,"text":"우리가 주는 하나님의 거룩하신 자신줄 믿고 알았삽나이다'","reference":"요한복음 6:69","category":"$undefined"},{"id":"26328","book":"요한복음","book_name":"요한복음","chapter":6,"verse":70,"text":"예수께서 대답하시되 `내가 너희 열 둘을 택하지 아니하였느냐 ? 그러나 너희 중에 한 사람은 마귀니라' 하시니","reference":"요한복음 6:70","category":"$undefined"},{"id":"26329","book":"요한복음","book_name":"요한복음","chapter":6,"verse":71,"text":"이 말씀은 가룟 시몬의 아들 유다를 가리키심이라 저는 열 둘 중의 하나로 예수를 팔 자러라","reference":"요한복음 6:71","category":"$undefined"}],"bookSlug":"john"}]
