2:["$","$L11",null,{"book":{"id":"jonah","name":"요나","chapters":4,"testament":"old"},"chapter":1,"verses":[{"id":"22533","book":"요나","book_name":"요나","chapter":1,"verse":1,"text":"여호와의 말씀이 아밋대의 아들 요나에게 임하니라 이르시되","reference":"요나 1:1","category":"$undefined"},{"id":"22534","book":"요나","book_name":"요나","chapter":1,"verse":2,"text":"너는 일어나 저 큰 성읍 니느웨로 가서 그것을 쳐서 외치라 그 악독이 내 앞에 상달하였음이니라 하시니라","reference":"요나 1:2","category":"$undefined"},{"id":"22535","book":"요나","book_name":"요나","chapter":1,"verse":3,"text":"그러나 요나가 여호와의 낯을 피하려고 일어나 다시스로 도망하려 하여 욥바로 내려갔더니 마침 다시스로 가는 배를 만난지라 여호와의 낯을 피하여 함께 다시스로 가려고 선가를 주고 배에 올랐더라","reference":"요나 1:3","category":"$undefined"},{"id":"22536","book":"요나","book_name":"요나","chapter":1,"verse":4,"text":"여호와께서 대풍을 대작하여 배가 거의 깨어지게 된지라","reference":"요나 1:4","category":"$undefined"},{"id":"22537","book":"요나","book_name":"요나","chapter":1,"verse":5,"text":"사공이 두려워 하여 각각 자기의 신을 부르고 또 배를 가볍게 하려고 그 가운데 물건을 바다에 던지니라 그러나 요나는 배 밑층에 내려가서 누워 깊이 잠이 든지라","reference":"요나 1:5","category":"$undefined"},{"id":"22538","book":"요나","book_name":"요나","chapter":1,"verse":6,"text":"선장이 나아가서 그에게 이르되 `자는 자여 어찜이뇨 일어나서 네 하나님께 구하라 혹시 하나님이 우리를 생각하사 망하지 않게 하시리라' 하니라","reference":"요나 1:6","category":"$undefined"},{"id":"22539","book":"요나","book_name":"요나","chapter":1,"verse":7,"text":"그들이 서로 이르되 `자, 우리가 제비를 뽑아 이 재앙이 누구로 인하여 우리에게 임하였나 알자' 하고 곧 제비를 뽑으니 제비가 요나에게 당한지라","reference":"요나 1:7","category":"$undefined"},{"id":"22540","book":"요나","book_name":"요나","chapter":1,"verse":8,"text":"무리가 그에게 이르되 `청컨대 이 재앙이 무슨 연고로 우리에게 임하였는가 고하라 네 생업이 무엇이며 어디서 왔으며 고국이 어디며 어느 민족에 속하였느냐 ?'","reference":"요나 1:8","category":"$undefined"},{"id":"22541","book":"요나","book_name":"요나","chapter":1,"verse":9,"text":"그가 대답하되 `나는 히브리 사람이요 바다와 육지를 지으신 하늘의 하나님 여호와를 경외하는 자로라' 하고","reference":"요나 1:9","category":"$undefined"},{"id":"22542","book":"요나","book_name":"요나","chapter":1,"verse":10,"text":"자기가 여호와의 낯을 피함인줄을 그들에게 고하였으므로 무리가 알고 심히 두려워하여 이르되 `네가 어찌하여 이렇게 행하였느냐 ?' 하니라","reference":"요나 1:10","category":"$undefined"},{"id":"22543","book":"요나","book_name":"요나","chapter":1,"verse":11,"text":"바다가 점점 흉용한지라 무리가 그에게 이르되 `우리가 너를 어떻게 하여야 바다가 우리를 위하여 잔잔하겠느냐 ?'","reference":"요나 1:11","category":"$undefined"},{"id":"22544","book":"요나","book_name":"요나","chapter":1,"verse":12,"text":"그가 대답하되 `나를 들어 바다에 던지라 ! 그리하면 바다가 너희를 위하여 잔잔하리라 너희가 이 큰 폭풍을 만난 것이 나의 연고인 줄을 내가 아노라' 하니라","reference":"요나 1:12","category":"$undefined"},{"id":"22545","book":"요나","book_name":"요나","chapter":1,"verse":13,"text":"그러나 그 사람들이 힘써 노를 저어 배를 육지에 돌리고자 하다가 바다가 그들을 향하여 점점 더 흉용하므로 능히 못한지라","reference":"요나 1:13","category":"$undefined"},{"id":"22546","book":"요나","book_name":"요나","chapter":1,"verse":14,"text":"무리가 여호와께 부르짖어 가로되 `여호와여 ! 구하고 구하오니 이 사람의 생명 까닭에 우리를 멸망시키지 마옵소서 무죄한 피를 우리에게 돌리지 마옵소서 주 여호와께서는 주의 뜻대로 행하심이니이다' 하고","reference":"요나 1:14","category":"$undefined"},{"id":"22547","book":"요나","book_name":"요나","chapter":1,"verse":15,"text":"요나를 들어 바다에 던지매 바다의 뛰노는 것이 곧 그친지라","reference":"요나 1:15","category":"$undefined"},{"id":"22548","book":"요나","book_name":"요나","chapter":1,"verse":16,"text":"그 사람들이 여호와를 크게 두려워하여 여호와께 제물을 드리고 서원을 하였더라","reference":"요나 1:16","category":"$undefined"},{"id":"22549","book":"요나","book_name":"요나","chapter":1,"verse":17,"text":"여호와께서 이미 큰 물고기를 예비하사 요나를 삼키게 하셨으므로 요나가 삼일 삼야를 물고기 배에 있으니라","reference":"요나 1:17","category":"$undefined"}],"bookSlug":"jonah"}]
