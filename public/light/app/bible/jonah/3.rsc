2:["$","$L11",null,{"book":{"id":"jonah","name":"요나","chapters":4,"testament":"old"},"chapter":3,"verses":[{"id":"22560","book":"요나","book_name":"요나","chapter":3,"verse":1,"text":"여호와의 말씀이 두번째 요나에게 임하니라 이르시되","reference":"요나 3:1","category":"$undefined"},{"id":"22561","book":"요나","book_name":"요나","chapter":3,"verse":2,"text":"일어나 저 큰 성읍 니느웨로 가서 내가 네게 명한 바를 그들에게 선포하라 하신지라","reference":"요나 3:2","category":"$undefined"},{"id":"22562","book":"요나","book_name":"요나","chapter":3,"verse":3,"text":"요나가 여호와의 말씀대로 일어나서 니느웨로 가니라 니느웨는 극히 큰 성읍이므로 삼일길이라","reference":"요나 3:3","category":"$undefined"},{"id":"22563","book":"요나","book_name":"요나","chapter":3,"verse":4,"text":"요나가 그 성에 들어가며 곧 하룻길을 행하며 외쳐 가로되 사십일이 지나면 니느웨가 무너지리라 하였더니","reference":"요나 3:4","category":"$undefined"},{"id":"22564","book":"요나","book_name":"요나","chapter":3,"verse":5,"text":"니느웨 백성이 하나님을 믿고 금식을 선포하고 무론 대소하고 굵은 베를 입은지라","reference":"요나 3:5","category":"$undefined"},{"id":"22565","book":"요나","book_name":"요나","chapter":3,"verse":6,"text":"그 소문이 니느웨 왕에게 들리매 왕이 보좌에서 일어나 조복을 벗고 굵은 베를 입고 재에 앉으니라","reference":"요나 3:6","category":"$undefined"},{"id":"22566","book":"요나","book_name":"요나","chapter":3,"verse":7,"text":"왕이 그 대신으로 더불어 조서를 내려 니느웨에 선포하여 가로되 사람이나 짐승이나 소떼나 양떼나 아무 것도 입에 대지 말지니 곧 먹지도 말 것이요 물도 마시지 말 것이며","reference":"요나 3:7","category":"$undefined"},{"id":"22567","book":"요나","book_name":"요나","chapter":3,"verse":8,"text":"사람이든지 짐승이든지 다 굵은 베를 입을 것이요 힘써 여호와께 부르짖을 것이며 각기 악한 길과 손으로 행한 강포에서 떠날 것이라","reference":"요나 3:8","category":"$undefined"},{"id":"22568","book":"요나","book_name":"요나","chapter":3,"verse":9,"text":"하나님이 혹시 뜻을 돌이키시고 그 진노를 그치사 우리로 멸망치 않게 하시리라 그렇지 않을 줄을 누가 알겠느냐 ? 한지라","reference":"요나 3:9","category":"$undefined"},{"id":"22569","book":"요나","book_name":"요나","chapter":3,"verse":10,"text":"하나님이 그들의 행한 것 곧 그 악한 길에서 돌이켜 떠난 것을 감찰하시고 뜻을 돌이키사 그들에게 내리리라 말씀하신 재앙을 내리지 아니하시니라","reference":"요나 3:10","category":"$undefined"}],"bookSlug":"jonah"}]
