2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":1,"verses":[{"id":"5853","book":"여호수아","book_name":"여호수아","chapter":1,"verse":1,"text":"여호와의 종 모세가 죽은 후에 여호와께서 모세의 시종 눈의 아들 여호수아에게 일러 가라사대","reference":"여호수아 1:1","category":"$undefined"},{"id":"5854","book":"여호수아","book_name":"여호수아","chapter":1,"verse":2,"text":"내 종 모세가 죽었으니 이제 너는 이 모든 백성으로 더불어 일어나 이 요단을 건너 내가 그들 곧 이스라엘 자손에게 주는 땅으로 가라","reference":"여호수아 1:2","category":"$undefined"},{"id":"5855","book":"여호수아","book_name":"여호수아","chapter":1,"verse":3,"text":"내가 모세에게 말한 바와 같이 무릇 너희 발바닥으로 밟는 곳을 내가 다 너희에게 주었노니","reference":"여호수아 1:3","category":"$undefined"},{"id":"5856","book":"여호수아","book_name":"여호수아","chapter":1,"verse":4,"text":"곧 광야와 이 레바논에서부터 큰 하수 유브라데에 이르는 헷 족속의 온 땅과 또 해 지는 편 대해까지 너희 지경이 되리라","reference":"여호수아 1:4","category":"$undefined"},{"id":"5857","book":"여호수아","book_name":"여호수아","chapter":1,"verse":5,"text":"너의 평생에 너를 능히 당할 자 없으리니 내가 모세와 함께 있던 것 같이 너의 함께 있을 것임이라 내가 너를 떠나지 아니하며 버리지 아니하리니","reference":"여호수아 1:5","category":"$undefined"},{"id":"5858","book":"여호수아","book_name":"여호수아","chapter":1,"verse":6,"text":"마음을 강하게 하라 ! 담대히 하라 ! 너는 이 백성으로 내가 그 조상에게 맹세하여 주리라 한 땅을 얻게 하리라","reference":"여호수아 1:6","category":"$undefined"},{"id":"5859","book":"여호수아","book_name":"여호수아","chapter":1,"verse":7,"text":"오직 너는 마음을 강하게 하고 극히 담대히 하여 나의 종 모세가 네게 명한 율법을 다 지켜 행하고 좌로나 우로나 치우치지 말라 ! 그리하면 어디로 가든지 형통하리니","reference":"여호수아 1:7","category":"$undefined"},{"id":"5860","book":"여호수아","book_name":"여호수아","chapter":1,"verse":8,"text":"이 율법책을 네 입에서 떠나지 말게 하며 주야로 그것을 묵상하여 그 가운데 기록한대로 다 지켜 행하라 ! 그리하면 네 길이 평탄하게 될 것이라 네가 형통하리라 !","reference":"여호수아 1:8","category":"$undefined"},{"id":"5861","book":"여호수아","book_name":"여호수아","chapter":1,"verse":9,"text":"내가 네게 명한 것이 아니냐 ? 마음을 강하게 하고 담대히 하라 ! 두려워 말며 놀라지 말라 ! 네가 어디로 가든지 네 하나님 여호와가 너와 함께 하느니라 ! 하시니라","reference":"여호수아 1:9","category":"$undefined"},{"id":"5862","book":"여호수아","book_name":"여호수아","chapter":1,"verse":10,"text":"이에 여호수아가 백성의 유사들에게 명하여 가로되","reference":"여호수아 1:10","category":"$undefined"},{"id":"5863","book":"여호수아","book_name":"여호수아","chapter":1,"verse":11,"text":"`진 중에 두루 다니며 백성에게 명하여 이르기를 양식을 예비하라 삼일 안에 너희가 이 요단을 건너 너희 하나님 여호와께서 너희에게 주사 얻게 하시는 땅을 얻기 위하여 들어갈 것임이니라 하라'","reference":"여호수아 1:11","category":"$undefined"},{"id":"5864","book":"여호수아","book_name":"여호수아","chapter":1,"verse":12,"text":"여호수아가 또 르우벤 지파와, 갓 지파와","reference":"여호수아 1:12","category":"$undefined"},{"id":"5865","book":"여호수아","book_name":"여호수아","chapter":1,"verse":13,"text":"므낫세 반 지파에게 일러 가로되 `여호와의 종 모세가 너희에게 명하여 이르기를 너희 하나님 여호와께서 너희에게 안식을 주시며 이 땅을 너희에게 주시리라 하였나니 너희는 그 말을 기억하라","reference":"여호수아 1:13","category":"$undefined"},{"id":"5866","book":"여호수아","book_name":"여호수아","chapter":1,"verse":14,"text":"너희 처자와 가축은 모세가 너희에게 준 요단 이편 땅에 머무르려니와 너희 용사들은 무장하고 너희의 형제보다 앞서 건너가서 그들을 돕고","reference":"여호수아 1:14","category":"$undefined"},{"id":"5867","book":"여호수아","book_name":"여호수아","chapter":1,"verse":15,"text":"여호와께서 너희로 안식하게 하신 것 같이 너희 형제도 안식하게 되며 그들도 너희 하나님 여호와께서 주시는 땅을 얻게 되거든 너희는 너희 소유지 곧 여호와의 종 모세가 너희에게 준 요단 이편 해 돋는 편으로 돌아와서 그것을 차지할지니라'","reference":"여호수아 1:15","category":"$undefined"},{"id":"5868","book":"여호수아","book_name":"여호수아","chapter":1,"verse":16,"text":"그들이 여호수아에게 대답하여 가로되 `당신이 우리에게 명하신 것은 우리가 다 행할 것이요 당신이 우리를 보내시는 곳에는 우리가 가리이다","reference":"여호수아 1:16","category":"$undefined"},{"id":"5869","book":"여호수아","book_name":"여호수아","chapter":1,"verse":17,"text":"그들이 여호수아에게 대답하여 가로되 `당신이 우리에게 명하신 것은 우리가 다 행할 것이요 당신이 우리를 보내시는 곳에는 우리가 가리이다","reference":"여호수아 1:17","category":"$undefined"},{"id":"5870","book":"여호수아","book_name":"여호수아","chapter":1,"verse":18,"text":"우리는 범사에 모세를 청종한 것 같이 당신을 청종하려니와 오직 당신의 하나님 여호와께서 모세와 함께 계시던 것 같이 당신과 함께 계시기를 원하나이다 [ (Joshua 1:19) 누구든지 당신의 명령을 거역하며 무릇 당신의 시키는 말씀을 청종치 아니하는 자 그는 죽임을 당하리니 오직 당신은 마음을 강하게 하시며 담대히 하소서 !' ]","reference":"여호수아 1:18","category":"$undefined"}],"bookSlug":"joshua"}]
