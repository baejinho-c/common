2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":10,"verses":[{"id":"6066","book":"여호수아","book_name":"여호수아","chapter":10,"verse":1,"text":"여호수아가 아이를 취하여 진멸하되 여리고와 그 왕에게 행한 것같이 아이와 그 왕에게 행한 것과 또 기브온 거민이 이스라엘과 화친하여 그 중에 있다함을 예루살렘 왕 아도니세덱이 듣고","reference":"여호수아 10:1","category":"$undefined"},{"id":"6067","book":"여호수아","book_name":"여호수아","chapter":10,"verse":2,"text":"크게 두려워하였으니 이는 기브온은 왕도와 같은 큰 성임이요 아이보다 크고 그 사람들은 다 강함이라","reference":"여호수아 10:2","category":"$undefined"},{"id":"6068","book":"여호수아","book_name":"여호수아","chapter":10,"verse":3,"text":"예루살렘 왕 아도니세덱이 헤브론 왕 호함과 야르뭇 왕 비람과 라기스 왕 야비아와 에글론 왕 드빌에게 보내어 가로되","reference":"여호수아 10:3","category":"$undefined"},{"id":"6069","book":"여호수아","book_name":"여호수아","chapter":10,"verse":4,"text":"`내게로 올라와 나를 도우라 우리가 기브온을 치자 이는 기브온이 여호수아와 이스라엘 자손으로 더불어 화친하였음이니라' 하매","reference":"여호수아 10:4","category":"$undefined"},{"id":"6070","book":"여호수아","book_name":"여호수아","chapter":10,"verse":5,"text":"여호수아가 모든 군사와 용사로 더불어 길갈에서 올라가니라","reference":"여호수아 10:5","category":"$undefined"},{"id":"6071","book":"여호수아","book_name":"여호수아","chapter":10,"verse":6,"text":"때에 여호와께서 여호수아에게 이르시되 그들을 두려워 말라 ! 내가 그들을 네 손에 붙였으니 그들의 한 사람도 너를 당할 자 없 으리라 하신지라","reference":"여호수아 10:6","category":"$undefined"},{"id":"6072","book":"여호수아","book_name":"여호수아","chapter":10,"verse":7,"text":"여호수아가 길갈에서 밤새도록 올라가서 그들에게 갑자기 이르니","reference":"여호수아 10:7","category":"$undefined"},{"id":"6073","book":"여호수아","book_name":"여호수아","chapter":10,"verse":8,"text":"여호와께서 그들을 이스라엘 앞에서 패하게 하시므로 여호수아가 그들을 기브온에서 크게 도륙하고 벧호론에 올라가는 비탈에서 추격하여 아세가와 막게다까지 이르니라","reference":"여호수아 10:8","category":"$undefined"},{"id":"6074","book":"여호수아","book_name":"여호수아","chapter":10,"verse":9,"text":"그들이 이스라엘 앞에서 도망하여 벧호론의 비탈에서 내려갈 때에 여호와께서 하늘에서 큰 덩이 우박을 아세가에 이르기까지 내리우시매 그들이 죽었으니 이스라엘 자손의 칼에 죽은 자보다 우박에 죽은 자가 더욱 많았더라","reference":"여호수아 10:9","category":"$undefined"},{"id":"6075","book":"여호수아","book_name":"여호수아","chapter":10,"verse":10,"text":"여호와께서 아모리 사람을 이스라엘 자손에게 붙이시던 날에 여호수아가 여호와께 고하되 이스라엘 목전에서 가로되 '태양아 ! 너는 기브온 위에 머무르라 ! 달아 ! 너도 아얄론 골짜기에 그리할지어다 !' 하매","reference":"여호수아 10:10","category":"$undefined"},{"id":"6076","book":"여호수아","book_name":"여호수아","chapter":10,"verse":11,"text":"태양이 머물고 달이 그치기를 백성이 그 대적에게 원수를 갚도록 하였느니라 야살의 책에 기록되기를 태양이 중천에 머물러서 거의 종일토록 속히 내려가지 아니하였다 하지 아니하였느냐","reference":"여호수아 10:11","category":"$undefined"},{"id":"6077","book":"여호수아","book_name":"여호수아","chapter":10,"verse":12,"text":"여호와께서 사람의 목소리를 들으신 이 같은 날은 전에도 없었고 후에도 없었나니 이는 여호와께서 이스라엘을 위하여 싸우셨음이니라","reference":"여호수아 10:12","category":"$undefined"},{"id":"6078","book":"여호수아","book_name":"여호수아","chapter":10,"verse":13,"text":"여호수아가 온 이스라엘로 더불어 길갈 진으로 돌아왔더라","reference":"여호수아 10:13","category":"$undefined"},{"id":"6079","book":"여호수아","book_name":"여호수아","chapter":10,"verse":14,"text":"그 다섯 왕이 도망하여 막게다의 굴에 숨었더니","reference":"여호수아 10:14","category":"$undefined"},{"id":"6080","book":"여호수아","book_name":"여호수아","chapter":10,"verse":15,"text":"혹이 여호수아에게 고하여 가로되 `막게다의 굴에 그 다섯 왕의 숨은 것을 발견하였나이다'","reference":"여호수아 10:15","category":"$undefined"},{"id":"6081","book":"여호수아","book_name":"여호수아","chapter":10,"verse":16,"text":"여호수아가 가로되 `굴 어귀에 큰 돌을 굴려 막고 사람을 그 곁에 두어 그들을 지키게 하고","reference":"여호수아 10:16","category":"$undefined"},{"id":"6082","book":"여호수아","book_name":"여호수아","chapter":10,"verse":17,"text":"너희는 지체 말고 너희 대적의 뒤를 따라가 그 후군을 쳐서 그들로 자기들의 성읍에 들어가지 못하게 하라 너희 하나님 여호와께서 그들을 너희 손에 붙이셨느니라' 하고","reference":"여호수아 10:17","category":"$undefined"},{"id":"6083","book":"여호수아","book_name":"여호수아","chapter":10,"verse":18,"text":"여호수아와 이스라엘 자손이 그들을 크게 도륙하여 거의 진멸시켰고 그 남은 몇 사람은 견고한 성으로 들어가므로","reference":"여호수아 10:18","category":"$undefined"},{"id":"6084","book":"여호수아","book_name":"여호수아","chapter":10,"verse":19,"text":"모든 백성이 평안히 막게다 진으로 돌아와 여호수아에게 이르렀으나 혀를 놀려 이스라엘 자손을 대적하는 자가 없었더라","reference":"여호수아 10:19","category":"$undefined"},{"id":"6085","book":"여호수아","book_name":"여호수아","chapter":10,"verse":20,"text":"때에 여호수아가 가로되 `굴 어귀를 열고 그 굴에서 그 다섯 왕을 내게로 끌어내라' 하매","reference":"여호수아 10:20","category":"$undefined"},{"id":"6086","book":"여호수아","book_name":"여호수아","chapter":10,"verse":21,"text":"그들이 그대로 하여 그 다섯 왕 곧 예루살렘 왕과, 헤브론 왕과, 야르뭇 왕과, 라기스 왕과, 에글론 왕을 굴에서 그에게로 끌어내니라","reference":"여호수아 10:21","category":"$undefined"},{"id":"6087","book":"여호수아","book_name":"여호수아","chapter":10,"verse":22,"text":"그 왕들을 여호수아에게로 끌어내매 여호수아가 이스라엘 모든 사람을 부르고 자기와 함께 갔던 군장들에게 이르되 '가까이 와서 이 왕들의 목을 발로 밟으라' 가까이 와서 그들의 목을 밟으매","reference":"여호수아 10:22","category":"$undefined"},{"id":"6088","book":"여호수아","book_name":"여호수아","chapter":10,"verse":23,"text":"여호수아가 군장들에게 이르되 `두려워 말며 놀라지 말고 마음을 강하게 하고 담대히 하라 ! 너희가 더불어 싸우는 모든 대적에게 여호와께서 다 이와 같이 하시리라' 하고","reference":"여호수아 10:23","category":"$undefined"},{"id":"6089","book":"여호수아","book_name":"여호수아","chapter":10,"verse":24,"text":"그 후에 여호수아가 그 왕들을 쳐 죽여 다섯 나무에 매어 달고 석양까지 나무에 달린대로 두었다가","reference":"여호수아 10:24","category":"$undefined"},{"id":"6090","book":"여호수아","book_name":"여호수아","chapter":10,"verse":25,"text":"해 질 때에 여호수아가 명하매 그 시체를 나무에서 내리어 그들의 숨었던 굴에 들여 던지고 굴 어귀를 큰 돌로 막았더니 오늘날까지 있더라","reference":"여호수아 10:25","category":"$undefined"},{"id":"6091","book":"여호수아","book_name":"여호수아","chapter":10,"verse":26,"text":"그 날에 여호수아가 막게다를 취하고 칼날로 그 성읍과 왕을 쳐서 그 성읍과 그 중에 있는 모든 사람을 진멸하여 한 사람도 남기지 아니하였으니 막게다 왕에게 행한 것이 여리고 왕에게 행한 것과 일반이었더라","reference":"여호수아 10:26","category":"$undefined"},{"id":"6092","book":"여호수아","book_name":"여호수아","chapter":10,"verse":27,"text":"여호수아가 온 이스라엘로 더불어 막게다에서 립나로 나아가서 립나와 싸우매","reference":"여호수아 10:27","category":"$undefined"},{"id":"6093","book":"여호수아","book_name":"여호수아","chapter":10,"verse":28,"text":"여호와께서 또 그 성읍과 그 왕을 이스라엘의 손에 붙이신지라 칼날로 그 성읍과 그 중의 모든 사람을 쳐서 멸하여 한 사람도 남기지 아니하였으니 그 왕에게 행한 것이 여리고 왕에게 행한 것과 일반이었더라","reference":"여호수아 10:28","category":"$undefined"},{"id":"6094","book":"여호수아","book_name":"여호수아","chapter":10,"verse":29,"text":"여호수아가 또 온 이스라엘로 더불어 립나에서 라기스로 나아가서 대진하고 싸우더니","reference":"여호수아 10:29","category":"$undefined"},{"id":"6095","book":"여호수아","book_name":"여호수아","chapter":10,"verse":30,"text":"여호와께서 라기스를 이스라엘의 손에 붙이신지라 이튿날에 그 성읍을 취하고 칼날로 그것과 그 중의 모든 사람을 쳐서 멸하였으니 립나에 행한 것과 일반이었더라","reference":"여호수아 10:30","category":"$undefined"},{"id":"6096","book":"여호수아","book_name":"여호수아","chapter":10,"verse":31,"text":"때에 게셀 왕 호람이 라기스를 도우려고 올라오므로 여호수아가 그와 그 백성을 쳐서 한 사람도 남기지 아니하였더라","reference":"여호수아 10:31","category":"$undefined"},{"id":"6097","book":"여호수아","book_name":"여호수아","chapter":10,"verse":32,"text":"여호수아가 온 이스라엘로 더불어 라기스에서 에글론으로 나아가서 대진하고 싸워","reference":"여호수아 10:32","category":"$undefined"},{"id":"6098","book":"여호수아","book_name":"여호수아","chapter":10,"verse":33,"text":"그 날에 그 성읍을 취하고 칼날로 그것을 쳐서 그 중에 있는 모든 사람을 당일에 진멸하였으니 라기스에 행한 것과 일반이었더라","reference":"여호수아 10:33","category":"$undefined"},{"id":"6099","book":"여호수아","book_name":"여호수아","chapter":10,"verse":34,"text":"여호수아가 또 온 이스라엘로 더불어 에글론에서 헤브론으로 올라가서 싸워","reference":"여호수아 10:34","category":"$undefined"},{"id":"6100","book":"여호수아","book_name":"여호수아","chapter":10,"verse":35,"text":"그 성읍을 취하고 그것과 그 왕과 그 속한 성읍들과 그 중의 모든 사람을 칼날로 쳐서 하나도 남기지 아니하였으니 그 성읍과 그 중의 모든 사람을 진멸한 것이 에글론에 행한 것과 일반이었더라","reference":"여호수아 10:35","category":"$undefined"},{"id":"6101","book":"여호수아","book_name":"여호수아","chapter":10,"verse":36,"text":"여호수아가 온 이스라엘로 더불어 돌아와서 드빌에 이르러 싸워","reference":"여호수아 10:36","category":"$undefined"},{"id":"6102","book":"여호수아","book_name":"여호수아","chapter":10,"verse":37,"text":"그 성읍과 그 왕과 그 속한 성읍들을 취하고 칼날로 그 성읍을 쳐서 그 중의 모든 사람을 진멸하고 하나도 남기지 아니하였으니 드빌과 그 왕에게 행한 것이 헤브론에 행한 것과 일반이요 립나와 그 왕에게 행한 것과 일반이었더라","reference":"여호수아 10:37","category":"$undefined"},{"id":"6103","book":"여호수아","book_name":"여호수아","chapter":10,"verse":38,"text":"이와 같이 여호수아가 온 땅 곧 산지와 남방과 평지와 경사지와 그 모든 왕을 쳐서 하나도 남기지 아니하고 무릇 호흡이 있는 자는 진멸하였으니 이스라엘의 하나님 여호와의 명하신 것과 같았더라","reference":"여호수아 10:38","category":"$undefined"},{"id":"6104","book":"여호수아","book_name":"여호수아","chapter":10,"verse":39,"text":"여호수아가 또 가데스 바네아에서 가사까지와 온 고센 땅을 기브온에 이르기까지 치매","reference":"여호수아 10:39","category":"$undefined"},{"id":"6105","book":"여호수아","book_name":"여호수아","chapter":10,"verse":40,"text":"이스라엘의 하나님 여호와께서 이스라엘을 위하여 싸우신고로 여호수아가 이 모든 왕과 그 땅을 단번에 취하니라","reference":"여호수아 10:40","category":"$undefined"},{"id":"6106","book":"여호수아","book_name":"여호수아","chapter":10,"verse":41,"text":"여호수아가 온 이스라엘로 더불어 길갈 진으로 돌아왔더라","reference":"여호수아 10:41","category":"$undefined"},{"id":"6107","book":"여호수아","book_name":"여호수아","chapter":10,"verse":42,"text":"","reference":"여호수아 10:42","category":"$undefined"},{"id":"6108","book":"여호수아","book_name":"여호수아","chapter":10,"verse":43,"text":"","reference":"여호수아 10:43","category":"$undefined"}],"bookSlug":"joshua"}]
