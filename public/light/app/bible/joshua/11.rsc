2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":11,"verses":[{"id":"6109","book":"여호수아","book_name":"여호수아","chapter":11,"verse":1,"text":"하솔 왕 야빈이 이 소식을 듣고 마돈왕 요밥과, 시므론 왕과, 악삽 왕과,","reference":"여호수아 11:1","category":"$undefined"},{"id":"6110","book":"여호수아","book_name":"여호수아","chapter":11,"verse":2,"text":"및 북방 산지와, 긴네롯 남편 아라바와, 평지와, 서방 돌의 높은 곳에 있는 왕들과,","reference":"여호수아 11:2","category":"$undefined"},{"id":"6111","book":"여호수아","book_name":"여호수아","chapter":11,"verse":3,"text":"동서편 가나안 사람과, 아모리 사람과, 헷 사람과, 브리스 사람과, 산지의 여부스 사람과, 미스바 땅 헤르몬산 아래 히위 사람들에게 사람을 보내매","reference":"여호수아 11:3","category":"$undefined"},{"id":"6112","book":"여호수아","book_name":"여호수아","chapter":11,"verse":4,"text":"그들이 그 모든 군대를 거느리고 나왔으니 민중이 많아 해변의 수다한 모래 같고 말과 병거도 심히 많았으며","reference":"여호수아 11:4","category":"$undefined"},{"id":"6113","book":"여호수아","book_name":"여호수아","chapter":11,"verse":5,"text":"이 왕들이 모여 나아와서 이스라엘과 싸우려고 메롬 물가에 함께 진 쳤더라","reference":"여호수아 11:5","category":"$undefined"},{"id":"6114","book":"여호수아","book_name":"여호수아","chapter":11,"verse":6,"text":"여호와께서 여호수아에게 이르시되 그들을 인하여 두려워 말라 ! 내일 이맘 때에 내가 그들을 이스라엘 앞에 붙여 몰살시키리니 너는 그들의 말 뒷발의 힘줄을 끊고 불로 그 병거를 사르라","reference":"여호수아 11:6","category":"$undefined"},{"id":"6115","book":"여호수아","book_name":"여호수아","chapter":11,"verse":7,"text":"이에 여호수아가 모든 군사와 함께 메롬 물가로 가서 졸지에 습격할 때에","reference":"여호수아 11:7","category":"$undefined"},{"id":"6116","book":"여호수아","book_name":"여호수아","chapter":11,"verse":8,"text":"여호와께서 그들을 이스라엘의 손에 붙이신 고로 그들을 격파하고 큰 시돈과 미스르봇 마임까지 쫓고 동편에서는 미스바 골짜기까지 쫓아가서 한 사람도 남기지 아니하고 쳐 죽이고","reference":"여호수아 11:8","category":"$undefined"},{"id":"6117","book":"여호수아","book_name":"여호수아","chapter":11,"verse":9,"text":"여호수아가 여호와께서 자기에게 명하신 대로 행하여 그들의 말뒷발의 힘줄을 끊고 불로 그 병거를 살랐더라","reference":"여호수아 11:9","category":"$undefined"},{"id":"6118","book":"여호수아","book_name":"여호수아","chapter":11,"verse":10,"text":"하솔은 본래 그 모든 나라의 머리였더니 그 때에 여호수아가 돌아와서 하솔을 취하고 그 왕을 칼날로 쳐 죽이고","reference":"여호수아 11:10","category":"$undefined"},{"id":"6119","book":"여호수아","book_name":"여호수아","chapter":11,"verse":11,"text":"그 가운데 모든 사람을 칼날로 쳐서 진멸하여 호흡이 있는 자는 하나도 남기지 아니하였고 또 불로 하솔을 살랐으며","reference":"여호수아 11:11","category":"$undefined"},{"id":"6120","book":"여호수아","book_name":"여호수아","chapter":11,"verse":12,"text":"여호수아가 그 왕들의 모든 성읍과 그 모든 왕을 취하여 칼날로 쳐서 진멸하여 여호와의 종 모세의 명한 것과 같이 하였으되","reference":"여호수아 11:12","category":"$undefined"},{"id":"6121","book":"여호수아","book_name":"여호수아","chapter":11,"verse":13,"text":"여호수아가 하솔만 불살랐고 산 위에 건축된 성읍들은 이스라엘이 불사르지 아니하였으며","reference":"여호수아 11:13","category":"$undefined"},{"id":"6122","book":"여호수아","book_name":"여호수아","chapter":11,"verse":14,"text":"이 성읍들의 모든 재물과 가축은 이스라엘 자손들이 탈취하고 모든 사람은 칼날로 쳐서 진멸하여 호흡이 있는 자는 하나도 남기지 아니하였으니","reference":"여호수아 11:14","category":"$undefined"},{"id":"6123","book":"여호수아","book_name":"여호수아","chapter":11,"verse":15,"text":"여호와께서 그 종 모세에게 명하신 것을 모세는 여호수아에게 명하였고 여호수아는 그대로 행하여 여호와께서 무릇 모세에게 명하신 것을 하나도 행치 아니한 것이 없었더라","reference":"여호수아 11:15","category":"$undefined"},{"id":"6124","book":"여호수아","book_name":"여호수아","chapter":11,"verse":16,"text":"여호수아가 이같이 그 온 땅 곧 산지와 온 남방과 고센 온 땅과 평지와 아라바와 이스라엘의 산지와 그 평지를 취하였으니","reference":"여호수아 11:16","category":"$undefined"},{"id":"6125","book":"여호수아","book_name":"여호수아","chapter":11,"verse":17,"text":"곧 세일로 올라가는 할락산에서부터 헤르몬산 아래 레바논 골짜기의 바알갓까지라 그 모든 왕을 잡아 쳐죽였으며","reference":"여호수아 11:17","category":"$undefined"},{"id":"6126","book":"여호수아","book_name":"여호수아","chapter":11,"verse":18,"text":"여호수아가 그 모든 왕과 싸운 지는 여러 날이라","reference":"여호수아 11:18","category":"$undefined"},{"id":"6127","book":"여호수아","book_name":"여호수아","chapter":11,"verse":19,"text":"기브온 거민 히위 사람 외에는 이스라엘 자손과 화친한 성읍이 하나도 없고 다 이스라엘 자손에게 쳐서 취한 바 되었으니","reference":"여호수아 11:19","category":"$undefined"},{"id":"6128","book":"여호수아","book_name":"여호수아","chapter":11,"verse":20,"text":"그들의 마음이 강퍅하여 이스라엘을 대적하여 싸우러 온 것은 여호와께서 그리하게 하신 것이라 그들로 저주받은 자 되게 하여 은혜를 입지 못하게 하시고 여호와께서 모세에게 명하신 대로 진멸하려 하심이었더라","reference":"여호수아 11:20","category":"$undefined"},{"id":"6129","book":"여호수아","book_name":"여호수아","chapter":11,"verse":21,"text":"그 때에 여호수아가 가서 산지와 헤브론과 드빌과 아납과 유다 온 산지와 이스라엘의 온 산지에서 아낙 사람을 멸절하고 그가 또 그 성읍들을 진멸하였으므로","reference":"여호수아 11:21","category":"$undefined"},{"id":"6130","book":"여호수아","book_name":"여호수아","chapter":11,"verse":22,"text":"이스라엘 자손의 땅 안에는 아낙 사람이 하나도 남음이 없고 가사와 가드와 아스돗에만 약간 남았었더라","reference":"여호수아 11:22","category":"$undefined"},{"id":"6131","book":"여호수아","book_name":"여호수아","chapter":11,"verse":23,"text":"이와 같이 여호수아가 여호와께서 모세에게 이르신 말씀대로 그 온 땅을 취하여 이스라엘 지파의 구별을 따라 기업으로 주었더라 그 땅에 전쟁이 그쳤더라","reference":"여호수아 11:23","category":"$undefined"}],"bookSlug":"joshua"}]
