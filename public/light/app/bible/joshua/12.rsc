2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":12,"verses":[{"id":"6132","book":"여호수아","book_name":"여호수아","chapter":12,"verse":1,"text":"이스라엘 자손이 요단 저편 해 돋는 편 곧 아르논 골짜기에서 헤르몬산까지의 동방 온 아라바를 점령하고 그 땅에서 쳐 죽인 왕들은 이러하니라","reference":"여호수아 12:1","category":"$undefined"},{"id":"6133","book":"여호수아","book_name":"여호수아","chapter":12,"verse":2,"text":"헤스본에 거하던 아모리 사람의 왕 시혼이라 그 다스리던 땅은 아르논 골짜기 가에 있는 아로엘에서부터 골짜기 가운데 성읍과 길르앗 절반 곧 암몬 자손의 지경 얍복강까지며","reference":"여호수아 12:2","category":"$undefined"},{"id":"6134","book":"여호수아","book_name":"여호수아","chapter":12,"verse":3,"text":"또 동방 아라바 긴네롯 바다까지며 또 동방 아라바의 바다 곧 염해의 벧여시못으로 통한 길까지와 남편으로 비스가 산록까지며","reference":"여호수아 12:3","category":"$undefined"},{"id":"6135","book":"여호수아","book_name":"여호수아","chapter":12,"verse":4,"text":"또 르바의 남은 족속으로서 아스다롯과 에브레이에 거하던 바산 왕 옥이라","reference":"여호수아 12:4","category":"$undefined"},{"id":"6136","book":"여호수아","book_name":"여호수아","chapter":12,"verse":5,"text":"그 치리하던 땅은 헤르몬산과 살르가와 온 바산과 및 그술 사람과 마아가 사람의 지경까지의 길르앗 절반이니 헤스본 왕 시혼의 지경에 접한 것이라","reference":"여호수아 12:5","category":"$undefined"},{"id":"6137","book":"여호수아","book_name":"여호수아","chapter":12,"verse":6,"text":"여호와의 종 모세와 이스라엘 자손이 그들을 치고 여호와의 종 모세가 그 땅을 르우벤 사람과, 갓 사람과, 므낫세 반 지파에게 기업으로 주었더라","reference":"여호수아 12:6","category":"$undefined"},{"id":"6138","book":"여호수아","book_name":"여호수아","chapter":12,"verse":7,"text":"여호수아와 이스라엘 자손이 요단 이편 곧 서편 레바논 골짜기의 바알갓에서부터 세일로 올라가는 곳 할락산까지에서 쳐서 멸한 왕들은 이러하니 그 땅을 여호수아가 이스라엘의 구별을 따라 그 지파에게 기업으로 주었으니","reference":"여호수아 12:7","category":"$undefined"},{"id":"6139","book":"여호수아","book_name":"여호수아","chapter":12,"verse":8,"text":"곧 산지와, 평지와, 아라바와, 경사지와, 광야와, 남방 곧 헷 사람과, 아모리 사람과, 가나안 사람과, 브리스 사람과, 히위 사람과, 여부스사람의 땅이라)","reference":"여호수아 12:8","category":"$undefined"},{"id":"6140","book":"여호수아","book_name":"여호수아","chapter":12,"verse":9,"text":"하나는 여리고 왕이요, 하나는 벧엘 곁의 아이 왕이요","reference":"여호수아 12:9","category":"$undefined"},{"id":"6141","book":"여호수아","book_name":"여호수아","chapter":12,"verse":10,"text":"하나는 예루살렘 왕이요, 하나는 헤브론 왕이요, 하나는 야르뭇 왕이요","reference":"여호수아 12:10","category":"$undefined"},{"id":"6142","book":"여호수아","book_name":"여호수아","chapter":12,"verse":11,"text":"하나는 라기스 왕이요","reference":"여호수아 12:11","category":"$undefined"},{"id":"6143","book":"여호수아","book_name":"여호수아","chapter":12,"verse":12,"text":"하나는 에글론 왕이요, 하나는 게셀 왕이요","reference":"여호수아 12:12","category":"$undefined"},{"id":"6144","book":"여호수아","book_name":"여호수아","chapter":12,"verse":13,"text":"하나는 드빌 왕이요, 하나는 게델 왕이요","reference":"여호수아 12:13","category":"$undefined"},{"id":"6145","book":"여호수아","book_name":"여호수아","chapter":12,"verse":14,"text":"하나는 호르마 왕이요, 하나는 아랏 왕이요","reference":"여호수아 12:14","category":"$undefined"},{"id":"6146","book":"여호수아","book_name":"여호수아","chapter":12,"verse":15,"text":"하나는 립나 왕이요, 하나는 아둘람 왕이요","reference":"여호수아 12:15","category":"$undefined"},{"id":"6147","book":"여호수아","book_name":"여호수아","chapter":12,"verse":16,"text":"하나는 막게다 왕이요, 하나는 벧엘 왕이요","reference":"여호수아 12:16","category":"$undefined"},{"id":"6148","book":"여호수아","book_name":"여호수아","chapter":12,"verse":17,"text":"하나는 답부아 왕이요, 하나는 헤벨 왕이요","reference":"여호수아 12:17","category":"$undefined"},{"id":"6149","book":"여호수아","book_name":"여호수아","chapter":12,"verse":18,"text":"하나는 아벡 왕이요, 하나는 랏사론 왕이요","reference":"여호수아 12:18","category":"$undefined"},{"id":"6150","book":"여호수아","book_name":"여호수아","chapter":12,"verse":19,"text":"하나는 마돈 왕이요, 하나는 하솔 왕이요","reference":"여호수아 12:19","category":"$undefined"},{"id":"6151","book":"여호수아","book_name":"여호수아","chapter":12,"verse":20,"text":"하나는 시므론 므론 왕이요, 하나는 악삽 왕이요","reference":"여호수아 12:20","category":"$undefined"},{"id":"6152","book":"여호수아","book_name":"여호수아","chapter":12,"verse":21,"text":"하나는 다아낙 왕이요, 하나는 므깃도 왕이요","reference":"여호수아 12:21","category":"$undefined"},{"id":"6153","book":"여호수아","book_name":"여호수아","chapter":12,"verse":22,"text":"하나는 게데스 왕이요, 하나는 갈멜의 욕느암 왕이요","reference":"여호수아 12:22","category":"$undefined"},{"id":"6154","book":"여호수아","book_name":"여호수아","chapter":12,"verse":23,"text":"하나는 돌의 높은 곳의 돌 왕이요, 하나는 길갈의 고임 왕이요","reference":"여호수아 12:23","category":"$undefined"},{"id":"6155","book":"여호수아","book_name":"여호수아","chapter":12,"verse":24,"text":"하나는 디르사 왕이라 도합 삼십 일 왕이었더라","reference":"여호수아 12:24","category":"$undefined"}],"bookSlug":"joshua"}]
