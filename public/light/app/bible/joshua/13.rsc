2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":13,"verses":[{"id":"6156","book":"여호수아","book_name":"여호수아","chapter":13,"verse":1,"text":"여호수아가 나이 많아 늙으매 여호와께서 그에게 이르시되 너는 나이 많아 늙었고 얻을 땅의 남은 것은 매우 많도다","reference":"여호수아 13:1","category":"$undefined"},{"id":"6157","book":"여호수아","book_name":"여호수아","chapter":13,"verse":2,"text":"이 남은 땅은 이러하니 블레셋 사람의 온 지방과 그술 사람의 전경","reference":"여호수아 13:2","category":"$undefined"},{"id":"6158","book":"여호수아","book_name":"여호수아","chapter":13,"verse":3,"text":"곧 애굽 앞 시홀 시내에서부터 가나안 사람에게 속한 북방 에그론 지경까지와 블레셋 사람의 다섯 방백의 땅 곧 가사 사람과, 아스돗 사람과, 아스글론 사람과, 가드 사람과, 에그론 사람과, 또 남방 아위 사람의 땅과,","reference":"여호수아 13:3","category":"$undefined"},{"id":"6159","book":"여호수아","book_name":"여호수아","chapter":13,"verse":4,"text":"또 가나안 사람의 온 땅과, 시돈 사람에게 속한 므아라와, 아모리 사람의 지경 아벡까지와","reference":"여호수아 13:4","category":"$undefined"},{"id":"6160","book":"여호수아","book_name":"여호수아","chapter":13,"verse":5,"text":"또 그발 사람의 땅과 동편 온 레바논 곧 헤르몬 산 아래 바알갓에서부터 하맛에 들어가는 곳까지와","reference":"여호수아 13:5","category":"$undefined"},{"id":"6161","book":"여호수아","book_name":"여호수아","chapter":13,"verse":6,"text":"또 레바논에서부터 미스르봇마임까지의 산지 모든 거민 곧 모든 시돈 사람의 땅이라 내가 그들을 이스라엘 자손 앞에서 쫓아 내리니 너는 나의 명한 대로 그 땅을 이스라엘에게 분배하여 기업이 되게 하되","reference":"여호수아 13:6","category":"$undefined"},{"id":"6162","book":"여호수아","book_name":"여호수아","chapter":13,"verse":7,"text":"너는 이 땅을 아홉 지파와 므낫세 반 지파에게 나누어 기업이 되게 하라 하셨더라","reference":"여호수아 13:7","category":"$undefined"},{"id":"6163","book":"여호수아","book_name":"여호수아","chapter":13,"verse":8,"text":"므낫세 반 지파와 함께 르우벤 사람과 갓 사람은 요단 동편에서 그 기업을 모세에게 받았는데 여호와의 종 모세가 그들에게 준 것은 이러하니","reference":"여호수아 13:8","category":"$undefined"},{"id":"6164","book":"여호수아","book_name":"여호수아","chapter":13,"verse":9,"text":"곧 아르논 골짜기 가에 있는 아로엘에서부터 골짜기 가운데 있는 성읍과 디본까지 이르는 메드바 온 평지와","reference":"여호수아 13:9","category":"$undefined"},{"id":"6165","book":"여호수아","book_name":"여호수아","chapter":13,"verse":10,"text":"헤스본에 도읍하였던 아모리 사람의 왕 시혼의 모든 성읍 곧 암몬 자손의 지경까지와","reference":"여호수아 13:10","category":"$undefined"},{"id":"6166","book":"여호수아","book_name":"여호수아","chapter":13,"verse":11,"text":"길르앗과 및 그술 사람과 마아갓 사람의 지경과 온 헤르몬산과 살르가까지 이른 온 바산","reference":"여호수아 13:11","category":"$undefined"},{"id":"6167","book":"여호수아","book_name":"여호수아","chapter":13,"verse":12,"text":"곧 르바의 남은 족속으로서 아스다롯과 에드레이에 도읍하였던 바산 왕 옥의 온 나라라 모세가 이 땅의 사람들을 쳐서 쫓아내었어도","reference":"여호수아 13:12","category":"$undefined"},{"id":"6168","book":"여호수아","book_name":"여호수아","chapter":13,"verse":13,"text":"그술 사람과 마아갓 사람은 이스라엘 자손이 쫓아내지 아니하였으므로 그술과 마아갓이 오늘날까지 이스라엘 가운데 거하더라","reference":"여호수아 13:13","category":"$undefined"},{"id":"6169","book":"여호수아","book_name":"여호수아","chapter":13,"verse":14,"text":"오직 레위 지파에게는 여호수아가 기업으로 준 것이 없었으니 이는 이스라엘 하나님 여호와께 드리는 화제물이 그 기업이 됨이 그에게 이르신 말씀과 같음이었더라","reference":"여호수아 13:14","category":"$undefined"},{"id":"6170","book":"여호수아","book_name":"여호수아","chapter":13,"verse":15,"text":"모세가 르우벤 자손의 지파에게 그 가족을 따라서 주었으니","reference":"여호수아 13:15","category":"$undefined"},{"id":"6171","book":"여호수아","book_name":"여호수아","chapter":13,"verse":16,"text":"그 지경은 아르논 골짜기 가에 있는 아로엘에서부터 골짜기 가운데 있는 성읍과 메드바 곁에 있는 온 평지와","reference":"여호수아 13:16","category":"$undefined"},{"id":"6172","book":"여호수아","book_name":"여호수아","chapter":13,"verse":17,"text":"헤스본과 그 평지에 있는 모든 성읍 곧 디본과, 바못 바알과, 벧 바알 므온과,","reference":"여호수아 13:17","category":"$undefined"},{"id":"6173","book":"여호수아","book_name":"여호수아","chapter":13,"verse":18,"text":"야하스와, 그데못과, 메바앗과,","reference":"여호수아 13:18","category":"$undefined"},{"id":"6174","book":"여호수아","book_name":"여호수아","chapter":13,"verse":19,"text":"기랴다임과, 십마와, 골짜기 가운데 산에 있는 세렛 사할과,","reference":"여호수아 13:19","category":"$undefined"},{"id":"6175","book":"여호수아","book_name":"여호수아","chapter":13,"verse":20,"text":"벧브올과, 비스가 산록과, 벧여시못과,","reference":"여호수아 13:20","category":"$undefined"},{"id":"6176","book":"여호수아","book_name":"여호수아","chapter":13,"verse":21,"text":"평지 모든 성읍과, 헤스본에 도읍한 아모리 사람 시혼의 온 나라라 모세가 시혼을 그 땅에 거하는 시혼의 방백 곧 미디안의 귀족 에위와, 레겜과, 술과, 훌과, 레바와 함께 죽였으며","reference":"여호수아 13:21","category":"$undefined"},{"id":"6177","book":"여호수아","book_name":"여호수아","chapter":13,"verse":22,"text":"이스라엘 자손이 그들을 도륙하는 중에 브올의 아들 술사 발람도 칼날로 죽였었더라","reference":"여호수아 13:22","category":"$undefined"},{"id":"6178","book":"여호수아","book_name":"여호수아","chapter":13,"verse":23,"text":"르우벤 자손의 서편 경계는 요단과 그 강 가라 이상은 르우벤 자손의 기업으로 그 가족대로 받은 성읍과 촌락이니라","reference":"여호수아 13:23","category":"$undefined"},{"id":"6179","book":"여호수아","book_name":"여호수아","chapter":13,"verse":24,"text":"모세가 갓 지파 곧 갓 자손에게도 그 가족을 따라서 주었으니","reference":"여호수아 13:24","category":"$undefined"},{"id":"6180","book":"여호수아","book_name":"여호수아","chapter":13,"verse":25,"text":"그 지경은 야셀과 길르앗 모든 성읍과 암몬 자손의 땅 절반 곧 랍바 앞의 아로엘까지와","reference":"여호수아 13:25","category":"$undefined"},{"id":"6181","book":"여호수아","book_name":"여호수아","chapter":13,"verse":26,"text":"헤스본에서 라맛 미스베와 브도님까지와 마하나임에서 드빌 지경까지와","reference":"여호수아 13:26","category":"$undefined"},{"id":"6182","book":"여호수아","book_name":"여호수아","chapter":13,"verse":27,"text":"골짜기에 있는 벧 하람과, 벧니므라와, 숙곳과, 사본 곧 헤스본 왕 시혼의 나라의 남은 땅 요단과 그 강 가에서부터 요단 동편 긴네렛 바다의 끝까지라","reference":"여호수아 13:27","category":"$undefined"},{"id":"6183","book":"여호수아","book_name":"여호수아","chapter":13,"verse":28,"text":"이는 갓 자손의 기업으로 그 가족대로 받은 성읍과 촌락이니라","reference":"여호수아 13:28","category":"$undefined"},{"id":"6184","book":"여호수아","book_name":"여호수아","chapter":13,"verse":29,"text":"모세가 므낫세 반 지파에게 주었으되 므낫세 자손의 반 지파에게 그 가족대로 주었으니","reference":"여호수아 13:29","category":"$undefined"},{"id":"6185","book":"여호수아","book_name":"여호수아","chapter":13,"verse":30,"text":"그 지경은 마하나임에서부터 온 바산 곧 바산 왕 옥의 전국과 바산 경내 야일의 모든 고을 육십 성읍과","reference":"여호수아 13:30","category":"$undefined"},{"id":"6186","book":"여호수아","book_name":"여호수아","chapter":13,"verse":31,"text":"길르앗 절반과 바산 왕 옥의 나라 성읍 아스다롯과 에드레이라 이는 므낫세의 아들 마길의 자손에게 돌린 것이니 곧 마길 자손의 절반이 그 가족대로 받으니라","reference":"여호수아 13:31","category":"$undefined"},{"id":"6187","book":"여호수아","book_name":"여호수아","chapter":13,"verse":32,"text":"요단 동편 여리고 맞은편 모압 평지에서 모세가 분배한 기업이 이러하여도","reference":"여호수아 13:32","category":"$undefined"},{"id":"6188","book":"여호수아","book_name":"여호수아","chapter":13,"verse":33,"text":"오직 레위 지파에게는 모세가 기업을 주지 아니하였으니 이는 그들에게 말씀하심 같이 이스라엘 하나님 여호와께서 그 기업이 되심이었더라","reference":"여호수아 13:33","category":"$undefined"}],"bookSlug":"joshua"}]
