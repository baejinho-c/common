2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":14,"verses":[{"id":"6189","book":"여호수아","book_name":"여호수아","chapter":14,"verse":1,"text":"이스라엘 자손이 가나안 땅에서 취한 기업 곧 제사장 엘르아살과 눈의 아들 여호수아와 이스라엘 자손 지파의 족장들이 분배한 것이 아래와 같으니라","reference":"여호수아 14:1","category":"$undefined"},{"id":"6190","book":"여호수아","book_name":"여호수아","chapter":14,"verse":2,"text":"여호와께서 모세에게 명하신 대로 그들의 기업을 제비 뽑아 아홉지파와 반 지파에게 주었으니","reference":"여호수아 14:2","category":"$undefined"},{"id":"6191","book":"여호수아","book_name":"여호수아","chapter":14,"verse":3,"text":"두 지파와 반 지파의 기업은 모세가 요단 저편에서 주었음이요 레위 자손에게는 그들 가운데서 기업을 주지 아니하였으니","reference":"여호수아 14:3","category":"$undefined"},{"id":"6192","book":"여호수아","book_name":"여호수아","chapter":14,"verse":4,"text":"요셉 자손은 므낫세와 에브라임의 두 지파가 되었음이라 이 땅에서 레위 사람에게 아무 분깃도 주지 아니하고 오직 거할 성읍들과 가축과 재물을 둘 들만 줄 뿐으로","reference":"여호수아 14:4","category":"$undefined"},{"id":"6193","book":"여호수아","book_name":"여호수아","chapter":14,"verse":5,"text":"이스라엘 자손이 여호와께서 모세에게 명하신 것과 같이 행하여 그 땅을 나누었더라","reference":"여호수아 14:5","category":"$undefined"},{"id":"6194","book":"여호수아","book_name":"여호수아","chapter":14,"verse":6,"text":"때에 유다 자손이 길갈에 있는 여호수아에게 나아오고 그니스 사람 여분네의 아들 갈렙이 여호수아에게 말하되 '여호와께서 가데스 바네아에서 나와 당신에게 대하여 하나님의 사람 모세에게 이르신 일을 당신이 아시는 바라","reference":"여호수아 14:6","category":"$undefined"},{"id":"6195","book":"여호수아","book_name":"여호수아","chapter":14,"verse":7,"text":"내 나이 사십세에 여호와의 종 모세가 가데스바네아에서 나를 보내어 이 땅을 정탐케 하므로 내 마음에 성실한 대로 그에게 보고하였고","reference":"여호수아 14:7","category":"$undefined"},{"id":"6196","book":"여호수아","book_name":"여호수아","chapter":14,"verse":8,"text":"나와 함께 올라갔던 내 형제들은 백성의 간담을 녹게 하였으나 나는 나의 하나님 여호와를 온전히 좇았으므로","reference":"여호수아 14:8","category":"$undefined"},{"id":"6197","book":"여호수아","book_name":"여호수아","chapter":14,"verse":9,"text":"그 날에 모세가 맹세하여 가로되 네가 나의 하나님 여호와를 온전히 좇았은즉 네 발로 밟는 땅은 영영히 너와 네 자손의 기업이 되리라 하였나이다","reference":"여호수아 14:9","category":"$undefined"},{"id":"6198","book":"여호수아","book_name":"여호수아","chapter":14,"verse":10,"text":"이제 보소서 여호와께서 이 말씀을 모세에게 이르신 때로부터 이스라엘이 광야에 행한 이 사십 오년 동안을 여호와께서 말씀하신대로 나를 생존케 하셨나이다 오늘날 내가 팔십 오세로되","reference":"여호수아 14:10","category":"$undefined"},{"id":"6199","book":"여호수아","book_name":"여호수아","chapter":14,"verse":11,"text":"모세가 나를 보내던 날과 같이 오늘날 오히려 강건하니 나의 힘이 그때나 이제나 일반이라 싸움에나 출입에 감당할 수 있사온즉","reference":"여호수아 14:11","category":"$undefined"},{"id":"6200","book":"여호수아","book_name":"여호수아","chapter":14,"verse":12,"text":"그 날에 여호와께서 말씀하신 이 산지를 내게 주소서 당신도 그 날에 들으셨거니와 그 곳에는 아낙 사람이 있고 그 성읍들은 크고 견고할지라도 여호와께서 혹시 나와 함께 하시면 내가 필경 여호와의 말씀하신대로 그들을 쫓아내리이다'","reference":"여호수아 14:12","category":"$undefined"},{"id":"6201","book":"여호수아","book_name":"여호수아","chapter":14,"verse":13,"text":"여호수아가 여분네의 아들 갈렙을 위하여 축복하고 헤브론을 그에게 주어 기업을 삼게 하매","reference":"여호수아 14:13","category":"$undefined"},{"id":"6202","book":"여호수아","book_name":"여호수아","chapter":14,"verse":14,"text":"헤브론이 그니스 사람 여분네의 아들 갈렙의 기업이 되어 오늘날까지 이르렀으니 이는 그가 이스라엘의 하나님 여호와를 온전히 좇았음이며","reference":"여호수아 14:14","category":"$undefined"},{"id":"6203","book":"여호수아","book_name":"여호수아","chapter":14,"verse":15,"text":"헤브론의 옛 이름은 기럇 아르바라 아르바는 아낙 사람 가운데 가장 큰 사람이었더라 그 땅에 전쟁이 그쳤더라","reference":"여호수아 14:15","category":"$undefined"}],"bookSlug":"joshua"}]
