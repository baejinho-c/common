2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":15,"verses":[{"id":"6204","book":"여호수아","book_name":"여호수아","chapter":15,"verse":1,"text":"유다 자손의 지파가 그 가족대로 제비 뽑은 땅의 극남단은 에돔 지경에 이르고 또 남으로 신 광야까지라","reference":"여호수아 15:1","category":"$undefined"},{"id":"6205","book":"여호수아","book_name":"여호수아","chapter":15,"verse":2,"text":"그 남편 경계는 염해의 극단 곧 남향한 해만에서부터","reference":"여호수아 15:2","category":"$undefined"},{"id":"6206","book":"여호수아","book_name":"여호수아","chapter":15,"verse":3,"text":"아그랍빔 비탈 남편으로 지나 신에 이르고 가데스 바네아 남편으로 올라가서 헤스론을 지나며 앗달도 올라가서 돌이켜 갈가에 이르고","reference":"여호수아 15:3","category":"$undefined"},{"id":"6207","book":"여호수아","book_name":"여호수아","chapter":15,"verse":4,"text":"거기서 아스몬에 이르고 애굽 시내에 미치며 바다에 이르러 경계의 끝이 되나니 이것이 너희 남편 경계가 되리라","reference":"여호수아 15:4","category":"$undefined"},{"id":"6208","book":"여호수아","book_name":"여호수아","chapter":15,"verse":5,"text":"그 동편 경계는 염해니 요단 끝까지요 그 북편 경계는 요단 끝에 당한 해만에서부터","reference":"여호수아 15:5","category":"$undefined"},{"id":"6209","book":"여호수아","book_name":"여호수아","chapter":15,"verse":6,"text":"벧호글라로 올라가서 벧 아라바 북편을 지나 르우벤 자손 보한의 돌에 이르고","reference":"여호수아 15:6","category":"$undefined"},{"id":"6210","book":"여호수아","book_name":"여호수아","chapter":15,"verse":7,"text":"또 아골 골짜기에서부터 드빌을 지나 북으로 올라가서 강 남편에 있는 아둠빔 비탈 맞은편 길갈을 향하고 나아가 엔 세메스 물을 지나 엔로겔에 이르며","reference":"여호수아 15:7","category":"$undefined"},{"id":"6211","book":"여호수아","book_name":"여호수아","chapter":15,"verse":8,"text":"또 힌놈의 아들의 골짜기로 올라가서 여부스 곧 예루살렘 남편 어깨에 이르며 또 힌놈의 골짜기 앞 서편에 있는 산 꼭대기로 올라가나니 이 곳은 르바임 골짜기 북편 끝이며","reference":"여호수아 15:8","category":"$undefined"},{"id":"6212","book":"여호수아","book_name":"여호수아","chapter":15,"verse":9,"text":"또 이 산꼭대기에서부터 넵도아 샘물까지 이르러 에브론산 성읍들에 미치고 또 바알라 곧 기럇 여아림에 미치며","reference":"여호수아 15:9","category":"$undefined"},{"id":"6213","book":"여호수아","book_name":"여호수아","chapter":15,"verse":10,"text":"또 바알라에서부터 서편으로 돌이켜 세일산에 이르러 여아림산 곧 그살론 곁 북편에 이르고 또 벧 세메스로 내려가서 딤나로 지나고","reference":"여호수아 15:10","category":"$undefined"},{"id":"6214","book":"여호수아","book_name":"여호수아","chapter":15,"verse":11,"text":"또 에그론 북편으로 나아가 식그론에 이르러 바알라산에 미치고 얍느엘에 이르나니 그 끝은 바다며","reference":"여호수아 15:11","category":"$undefined"},{"id":"6215","book":"여호수아","book_name":"여호수아","chapter":15,"verse":12,"text":"서편 경계는 대해와 그 해변이니 유다 자손이 그 가족대로 얻은 사면 경계가 이러하니라","reference":"여호수아 15:12","category":"$undefined"},{"id":"6216","book":"여호수아","book_name":"여호수아","chapter":15,"verse":13,"text":"여호와께서 여호수아에게 명하신 대로 여호수아가 기럇 아르바 곧 헤브론 성을 유다 자손중에서 분깃으로 여분네의 아들 갈렙에게 주었으니 아르바는 아낙의 아비였더라","reference":"여호수아 15:13","category":"$undefined"},{"id":"6217","book":"여호수아","book_name":"여호수아","chapter":15,"verse":14,"text":"갈렙이 거기서 아낙의 소생 곧 그 세 아들 세새와 아히만과 달매를 쫓아내었고","reference":"여호수아 15:14","category":"$undefined"},{"id":"6218","book":"여호수아","book_name":"여호수아","chapter":15,"verse":15,"text":"거기서 올라가서 드빌 거민을 쳤는데 드빌의 본 이름은 기럇 세벨이라","reference":"여호수아 15:15","category":"$undefined"},{"id":"6219","book":"여호수아","book_name":"여호수아","chapter":15,"verse":16,"text":"갈렙의 아우요 그나스의 아들인 옷니엘이 그것을 취함으로 갈렙이 그 딸 악사를 그에게 아내로 주었더라","reference":"여호수아 15:16","category":"$undefined"},{"id":"6220","book":"여호수아","book_name":"여호수아","chapter":15,"verse":17,"text":"악사가 출가할 때에 그에게 청하여 `자기 아비에게 밭을 구하자' 하고 나귀에서 내리매 갈렙이 그에게 묻되 `네가 무엇을 원하느냐 ?'","reference":"여호수아 15:17","category":"$undefined"},{"id":"6221","book":"여호수아","book_name":"여호수아","chapter":15,"verse":18,"text":"가로되 `내게 복을 주소서 ! 아버지께서 나를 남방 땅으로 보내시오니 샘물도 내게 주소서' 하매 갈렙이 윗 샘과 아랫 샘을 그에게 주었더라","reference":"여호수아 15:18","category":"$undefined"},{"id":"6222","book":"여호수아","book_name":"여호수아","chapter":15,"verse":19,"text":"유다 자손의 지파가 그 가족대로 얻은 기업은 이러하니라","reference":"여호수아 15:19","category":"$undefined"},{"id":"6223","book":"여호수아","book_name":"여호수아","chapter":15,"verse":20,"text":"유다 자손의 지파의 남으로 에돔 경계에 접근한 성읍들은 갑스엘과, 에델과, 야굴과,","reference":"여호수아 15:20","category":"$undefined"},{"id":"6224","book":"여호수아","book_name":"여호수아","chapter":15,"verse":21,"text":"기나와, 디모나와, 아다다와,","reference":"여호수아 15:21","category":"$undefined"},{"id":"6225","book":"여호수아","book_name":"여호수아","chapter":15,"verse":22,"text":"게데스와, 하솔과, 잇난과,","reference":"여호수아 15:22","category":"$undefined"},{"id":"6226","book":"여호수아","book_name":"여호수아","chapter":15,"verse":23,"text":"십과, 델렘과, 브알롯과,","reference":"여호수아 15:23","category":"$undefined"},{"id":"6227","book":"여호수아","book_name":"여호수아","chapter":15,"verse":24,"text":"하솔 하닷다와, 그리욧 헤스론 곧 하솔과,","reference":"여호수아 15:24","category":"$undefined"},{"id":"6228","book":"여호수아","book_name":"여호수아","chapter":15,"verse":25,"text":"아맘과, 세마와, 몰라다와,","reference":"여호수아 15:25","category":"$undefined"},{"id":"6229","book":"여호수아","book_name":"여호수아","chapter":15,"verse":26,"text":"하살 갓다와, 헤스몬과, 벧 벨렛과,","reference":"여호수아 15:26","category":"$undefined"},{"id":"6230","book":"여호수아","book_name":"여호수아","chapter":15,"verse":27,"text":"하살 수알과, 브엘세바와, 비스요댜와,","reference":"여호수아 15:27","category":"$undefined"},{"id":"6231","book":"여호수아","book_name":"여호수아","chapter":15,"verse":28,"text":"바알라와, 이임과, 에셈과,","reference":"여호수아 15:28","category":"$undefined"},{"id":"6232","book":"여호수아","book_name":"여호수아","chapter":15,"verse":29,"text":"엘돌랏과, 그실과, 홀마와,","reference":"여호수아 15:29","category":"$undefined"},{"id":"6233","book":"여호수아","book_name":"여호수아","chapter":15,"verse":30,"text":"시글락과, 맛만나와, 산산나와, 르바옷과,","reference":"여호수아 15:30","category":"$undefined"},{"id":"6234","book":"여호수아","book_name":"여호수아","chapter":15,"verse":31,"text":"실힘과, 아인과, 림몬이니 모두 이십구 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:31","category":"$undefined"},{"id":"6235","book":"여호수아","book_name":"여호수아","chapter":15,"verse":32,"text":"평지에는 에스다올과, 소라와, 아스나와,","reference":"여호수아 15:32","category":"$undefined"},{"id":"6236","book":"여호수아","book_name":"여호수아","chapter":15,"verse":33,"text":"사노아와, 엔간님과, 답부아와, 에남과,","reference":"여호수아 15:33","category":"$undefined"},{"id":"6237","book":"여호수아","book_name":"여호수아","chapter":15,"verse":34,"text":"야르뭇과, 아둘람과, 소고와, 아세가와,","reference":"여호수아 15:34","category":"$undefined"},{"id":"6238","book":"여호수아","book_name":"여호수아","chapter":15,"verse":35,"text":"사아라임과, 아디다임과, 그데라와, 그데로다임이니 모두 십 사 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:35","category":"$undefined"},{"id":"6239","book":"여호수아","book_name":"여호수아","chapter":15,"verse":36,"text":"스난과, 하다사와, 믹달갓과,","reference":"여호수아 15:36","category":"$undefined"},{"id":"6240","book":"여호수아","book_name":"여호수아","chapter":15,"verse":37,"text":"딜르안과, 미스베와, 욕드엘과,","reference":"여호수아 15:37","category":"$undefined"},{"id":"6241","book":"여호수아","book_name":"여호수아","chapter":15,"verse":38,"text":"라기스와, 보스갓과, 에글론과,","reference":"여호수아 15:38","category":"$undefined"},{"id":"6242","book":"여호수아","book_name":"여호수아","chapter":15,"verse":39,"text":"갑본과, 라맘과, 기들리스와,","reference":"여호수아 15:39","category":"$undefined"},{"id":"6243","book":"여호수아","book_name":"여호수아","chapter":15,"verse":40,"text":"그데롯과, 벧다곤과, 나아마와, 막게다니 모두 십 육 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:40","category":"$undefined"},{"id":"6244","book":"여호수아","book_name":"여호수아","chapter":15,"verse":41,"text":"립나와, 에델과, 아산과,","reference":"여호수아 15:41","category":"$undefined"},{"id":"6245","book":"여호수아","book_name":"여호수아","chapter":15,"verse":42,"text":"입다와, 아스나와, 느십과,","reference":"여호수아 15:42","category":"$undefined"},{"id":"6246","book":"여호수아","book_name":"여호수아","chapter":15,"verse":43,"text":"그일라와, 악십과, 마레사니 모두 아홉 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:43","category":"$undefined"},{"id":"6247","book":"여호수아","book_name":"여호수아","chapter":15,"verse":44,"text":"에그론과, 그 향리와, 촌락과,","reference":"여호수아 15:44","category":"$undefined"},{"id":"6248","book":"여호수아","book_name":"여호수아","chapter":15,"verse":45,"text":"에그론에서부터 바다까지 아스돗 곁에 있는 모든 성읍과 그 촌락이었으며","reference":"여호수아 15:45","category":"$undefined"},{"id":"6249","book":"여호수아","book_name":"여호수아","chapter":15,"verse":46,"text":"아스돗과, 그 향리와, 촌락과, 가사와, 그 향리와, 촌락이니 애굽 시내와 대해 가에 이르기까지였으며","reference":"여호수아 15:46","category":"$undefined"},{"id":"6250","book":"여호수아","book_name":"여호수아","chapter":15,"verse":47,"text":"산지는 사밀과, 얏딜과, 소고와,","reference":"여호수아 15:47","category":"$undefined"},{"id":"6251","book":"여호수아","book_name":"여호수아","chapter":15,"verse":48,"text":"단나와, 기럇 산나 곧 드빌과,","reference":"여호수아 15:48","category":"$undefined"},{"id":"6252","book":"여호수아","book_name":"여호수아","chapter":15,"verse":49,"text":"아납과, 에스드모와, 아님과,","reference":"여호수아 15:49","category":"$undefined"},{"id":"6253","book":"여호수아","book_name":"여호수아","chapter":15,"verse":50,"text":"고센과, 홀론과, 길로니 모두 십 일 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:50","category":"$undefined"},{"id":"6254","book":"여호수아","book_name":"여호수아","chapter":15,"verse":51,"text":"아랍과, 두마와, 에산과,","reference":"여호수아 15:51","category":"$undefined"},{"id":"6255","book":"여호수아","book_name":"여호수아","chapter":15,"verse":52,"text":"야님과, 벧 답부아와, 아베가와,","reference":"여호수아 15:52","category":"$undefined"},{"id":"6256","book":"여호수아","book_name":"여호수아","chapter":15,"verse":53,"text":"훔다와, 기럇 아르바 곧 헤브론과 시올이니 모두 아홉 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:53","category":"$undefined"},{"id":"6257","book":"여호수아","book_name":"여호수아","chapter":15,"verse":54,"text":"마온과, 갈멜과, 십과, 윳다와,","reference":"여호수아 15:54","category":"$undefined"},{"id":"6258","book":"여호수아","book_name":"여호수아","chapter":15,"verse":55,"text":"이스르엘과, 욕드암과, 사노아와,","reference":"여호수아 15:55","category":"$undefined"},{"id":"6259","book":"여호수아","book_name":"여호수아","chapter":15,"verse":56,"text":"가인과, 기브아와, 딤나니 모두 열 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:56","category":"$undefined"},{"id":"6260","book":"여호수아","book_name":"여호수아","chapter":15,"verse":57,"text":"할훌과, 벧 술과, 그돌과,","reference":"여호수아 15:57","category":"$undefined"},{"id":"6261","book":"여호수아","book_name":"여호수아","chapter":15,"verse":58,"text":"마아랏과, 벧 아놋과, 엘드곤이니 모두 여섯 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:58","category":"$undefined"},{"id":"6262","book":"여호수아","book_name":"여호수아","chapter":15,"verse":59,"text":"기럇 바알 곧 기럇 여아림과, 라빠니 모두 두 성읍이요 또 그 촌락이었으며","reference":"여호수아 15:59","category":"$undefined"},{"id":"6263","book":"여호수아","book_name":"여호수아","chapter":15,"verse":60,"text":"광야에는 벧 아라바와, 밋딘과, 스가가와,","reference":"여호수아 15:60","category":"$undefined"},{"id":"6264","book":"여호수아","book_name":"여호수아","chapter":15,"verse":61,"text":"닙산과, 염성과, 엔 게디니 모두 여섯 성읍이요 또 그 촌락이었더라","reference":"여호수아 15:61","category":"$undefined"},{"id":"6265","book":"여호수아","book_name":"여호수아","chapter":15,"verse":62,"text":"예루살렘 거민 여부스 사람을 유다 자손이 쫓아내지 못하였으므로 여부스 사람이 오늘날까지 유다 자손과 함께 예루살렘에 거하니라","reference":"여호수아 15:62","category":"$undefined"},{"id":"6266","book":"여호수아","book_name":"여호수아","chapter":15,"verse":63,"text":"","reference":"여호수아 15:63","category":"$undefined"}],"bookSlug":"joshua"}]
