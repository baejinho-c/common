2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":18,"verses":[{"id":"6295","book":"여호수아","book_name":"여호수아","chapter":18,"verse":1,"text":"이스라엘 자손의 온 회중이 실로에 모여서 거기 회막을 세웠으니 그 땅이 이미 그들의 앞에 돌아와 복종하였음이나","reference":"여호수아 18:1","category":"$undefined"},{"id":"6296","book":"여호수아","book_name":"여호수아","chapter":18,"verse":2,"text":"이스라엘 자손 중에 그 기업의 분배를 얻지 못한 자가 오히려 일곱 지파라","reference":"여호수아 18:2","category":"$undefined"},{"id":"6297","book":"여호수아","book_name":"여호수아","chapter":18,"verse":3,"text":"여호수아가 이스라엘 자손에게 이르되 `너희가 너희 열조의 하나님 여호와께서 너희에게 주신 땅을 취하러 가기를 어느 때까지 지체하겠느냐 ?","reference":"여호수아 18:3","category":"$undefined"},{"id":"6298","book":"여호수아","book_name":"여호수아","chapter":18,"verse":4,"text":"너희는 매 지파에 삼인씩 선정하라 내가 그들을 보내리니 그들은 일어나서 그 땅에 두루 다니며 그 기업에 상당하게 그려 가지고 내게로 돌아올 것이라","reference":"여호수아 18:4","category":"$undefined"},{"id":"6299","book":"여호수아","book_name":"여호수아","chapter":18,"verse":5,"text":"그들이 그 땅을 일곱 부분에 나누되 유다는 남편 자기 경내에 거하고 요셉의 족속은 그 북편 자기 경내에 거한즉","reference":"여호수아 18:5","category":"$undefined"},{"id":"6300","book":"여호수아","book_name":"여호수아","chapter":18,"verse":6,"text":"그 남은 땅을 일곱 부분으로 그려서 이곳 내게로 가져올지니 내가 여기서 너희를 위하여 우리 하나님 여호와 앞에서 제비뽑으리라","reference":"여호수아 18:6","category":"$undefined"},{"id":"6301","book":"여호수아","book_name":"여호수아","chapter":18,"verse":7,"text":"레위 사람은 너희 중에 분깃이 없나니 여호와의 제사장 직분이 그들의 기업이 됨이며 갓과 르우벤과 므낫세 반 지파는 요단 저 편 동편에서 이미 기업을 받았나니 이는 여호와의 종 모세가 그들에게 준 것이니라'","reference":"여호수아 18:7","category":"$undefined"},{"id":"6302","book":"여호수아","book_name":"여호수아","chapter":18,"verse":8,"text":"그 사람들이 일어나 떠나니 여호수아가 땅을 그리러 가는 그들에게 명하여 가로되 '가서 그 땅으로 두루 다니며 그려 가지고 내게로 돌아오라 내가 여기 실로에서 여호와 앞에서 너희를 위하여 제비뽑으리라'","reference":"여호수아 18:8","category":"$undefined"},{"id":"6303","book":"여호수아","book_name":"여호수아","chapter":18,"verse":9,"text":"그 사람들이 가서 그 땅으로 두루 다니며 성읍들을 따라서 일곱 부분으로 책에 그리고 실로 진에 돌아와 여호수아에게 나아오니","reference":"여호수아 18:9","category":"$undefined"},{"id":"6304","book":"여호수아","book_name":"여호수아","chapter":18,"verse":10,"text":"여호수아가 그들을 위하여 실로 여호와 앞에서 제비 뽑고 그가 거기서 이스라엘 자손의 분파대로 땅을 분배하였더라","reference":"여호수아 18:10","category":"$undefined"},{"id":"6305","book":"여호수아","book_name":"여호수아","chapter":18,"verse":11,"text":"베냐민 자손 지파를 위하여 그 가족대로 제비를 뽑았으니 그 제비뽑은 땅의 경계는 유다 자손과 요셉 자손의 중간이라","reference":"여호수아 18:11","category":"$undefined"},{"id":"6306","book":"여호수아","book_name":"여호수아","chapter":18,"verse":12,"text":"그 북방 경계는 요단에서부터 여리고 북편으로 올라가서 서편 산지를 넘어서 또 올라가서 벧아웬 황무지에 이르며","reference":"여호수아 18:12","category":"$undefined"},{"id":"6307","book":"여호수아","book_name":"여호수아","chapter":18,"verse":13,"text":"또 그 경계가 거기서부터 루스로 나아가서 루스 남편에 이르나니루스는 곧 벧엘이며 또 그 경계가 아다롯 앗달로 내려가서 아래 벧 호론 남편 산 곁으로 지나고","reference":"여호수아 18:13","category":"$undefined"},{"id":"6308","book":"여호수아","book_name":"여호수아","chapter":18,"verse":14,"text":"벧 호론 앞 남편 산에서부터 서방으로 돌아 남편으로 향하여 유다 자손의 성읍 기럇바알 곧 기럇 여아림에 이르러 끝이 되나니 이는 서방 경계며","reference":"여호수아 18:14","category":"$undefined"},{"id":"6309","book":"여호수아","book_name":"여호수아","chapter":18,"verse":15,"text":"남방 경계는 기럇 여아림 끝에서부터 서편으로 나아가 넵도아 물 근원에 이르고","reference":"여호수아 18:15","category":"$undefined"},{"id":"6310","book":"여호수아","book_name":"여호수아","chapter":18,"verse":16,"text":"르바임 골짜기 북편 힌놈의 아들 골짜기 앞에 있는 산 끝으로 내려가고 또 힌놈의 골짜기로 내려가서 여부스 남편에 이르러 엔 로겔로 내려가고","reference":"여호수아 18:16","category":"$undefined"},{"id":"6311","book":"여호수아","book_name":"여호수아","chapter":18,"verse":17,"text":"또 북향하여 엔 세메스로 나아가서 아둠밈 비탈 맞은편 글릴롯으로 나아가서 르우벤 자손 보한의 돌까지 내려 가고","reference":"여호수아 18:17","category":"$undefined"},{"id":"6312","book":"여호수아","book_name":"여호수아","chapter":18,"verse":18,"text":"북으로 아라바 맞은편을 지나 아라바로 내려가고","reference":"여호수아 18:18","category":"$undefined"},{"id":"6313","book":"여호수아","book_name":"여호수아","chapter":18,"verse":19,"text":"또 북으로 벧 호글라 곁을 지나서 요단 남단에 당한 염해의 북편 해만이 그 경계의 끝이 되나니 이는 남편 경계며","reference":"여호수아 18:19","category":"$undefined"},{"id":"6314","book":"여호수아","book_name":"여호수아","chapter":18,"verse":20,"text":"동방 경계는 요단이니 이는 베냐민 자손이 그 가족대로 얻은 기업의 사면 경계이었더라","reference":"여호수아 18:20","category":"$undefined"},{"id":"6315","book":"여호수아","book_name":"여호수아","chapter":18,"verse":21,"text":"베냐민 자손의 지파가 그 가족대로 얻은 성읍들은 여리고와, 벧 호글라와, 에멕 그시스와,","reference":"여호수아 18:21","category":"$undefined"},{"id":"6316","book":"여호수아","book_name":"여호수아","chapter":18,"verse":22,"text":"벧 아라바와, 스마라임과, 벧엘과,","reference":"여호수아 18:22","category":"$undefined"},{"id":"6317","book":"여호수아","book_name":"여호수아","chapter":18,"verse":23,"text":"아윔과, 바라와, 오브라와,","reference":"여호수아 18:23","category":"$undefined"},{"id":"6318","book":"여호수아","book_name":"여호수아","chapter":18,"verse":24,"text":"그발 암모니와, 오브니와, 게바니 십 이 성읍이요 또 그 촌락이며","reference":"여호수아 18:24","category":"$undefined"},{"id":"6319","book":"여호수아","book_name":"여호수아","chapter":18,"verse":25,"text":"기브온과, 라마와, 브에롯과,","reference":"여호수아 18:25","category":"$undefined"},{"id":"6320","book":"여호수아","book_name":"여호수아","chapter":18,"verse":26,"text":"미스베와, 그비라와, 모사와,","reference":"여호수아 18:26","category":"$undefined"},{"id":"6321","book":"여호수아","book_name":"여호수아","chapter":18,"verse":27,"text":"레겜과, 이르브엘과, 다랄라와,","reference":"여호수아 18:27","category":"$undefined"},{"id":"6322","book":"여호수아","book_name":"여호수아","chapter":18,"verse":28,"text":"셀라와, 엘렙과, 여부스 곧 예루살렘과 기부앗과 기럇이니 십 사 성읍이요 또 그 촌락이라 이는 베냐민 자손이 그 가족대로 얻은 기업이었더라","reference":"여호수아 18:28","category":"$undefined"}],"bookSlug":"joshua"}]
