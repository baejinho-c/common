2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":19,"verses":[{"id":"6323","book":"여호수아","book_name":"여호수아","chapter":19,"verse":1,"text":"둘째로 시므온 곧 시므온 자손의 지파를 위하여 그 가족대로 제비를 뽑았으니 그 기업은 유다 자손의 기업 중에서라","reference":"여호수아 19:1","category":"$undefined"},{"id":"6324","book":"여호수아","book_name":"여호수아","chapter":19,"verse":2,"text":"그 얻은 기업은 브엘세바 곧 세바와, 몰라다와,","reference":"여호수아 19:2","category":"$undefined"},{"id":"6325","book":"여호수아","book_name":"여호수아","chapter":19,"verse":3,"text":"하살 수알과, 발라와, 에셈과,","reference":"여호수아 19:3","category":"$undefined"},{"id":"6326","book":"여호수아","book_name":"여호수아","chapter":19,"verse":4,"text":"엘돌랏과, 브둘과, 호르마와,","reference":"여호수아 19:4","category":"$undefined"},{"id":"6327","book":"여호수아","book_name":"여호수아","chapter":19,"verse":5,"text":"시글락과, 벧 말가봇과, 하살수사와,","reference":"여호수아 19:5","category":"$undefined"},{"id":"6328","book":"여호수아","book_name":"여호수아","chapter":19,"verse":6,"text":"벧 르바옷과, 사루헨이니 십 삼 성읍이요 또 그 촌락이며","reference":"여호수아 19:6","category":"$undefined"},{"id":"6329","book":"여호수아","book_name":"여호수아","chapter":19,"verse":7,"text":"또 아인과 림몬과, 에델과 아산이니 네 성읍이요 또 그 촌락이며","reference":"여호수아 19:7","category":"$undefined"},{"id":"6330","book":"여호수아","book_name":"여호수아","chapter":19,"verse":8,"text":"또 남방 라마 곧 바알랏 브엘까지 이 성들을 둘러 있는 모든 촌락이니 이는 시므온 자손의 지파가 그 가족대로 얻은 기업이라","reference":"여호수아 19:8","category":"$undefined"},{"id":"6331","book":"여호수아","book_name":"여호수아","chapter":19,"verse":9,"text":"시므온 자손의 이 기업은 유다 자손의 기업 중에서 취하였으니 이는 유다 자손의 분깃이 자기들에게 너무 많으므로 시므온 자손이 자기의 기업을 그들의 기업 중에서 얻음이었더라","reference":"여호수아 19:9","category":"$undefined"},{"id":"6332","book":"여호수아","book_name":"여호수아","chapter":19,"verse":10,"text":"세째로 스불론 자손을 위하여 그 가족대로 제비를 뽑았으니 그 기업의 경계는 사릿에 미치고","reference":"여호수아 19:10","category":"$undefined"},{"id":"6333","book":"여호수아","book_name":"여호수아","chapter":19,"verse":11,"text":"서편으로 올라가서 마랄라에 이르러 답베셋에 미치고 욕느암 앞 시내에 미치며","reference":"여호수아 19:11","category":"$undefined"},{"id":"6334","book":"여호수아","book_name":"여호수아","chapter":19,"verse":12,"text":"사릿에서부터 동편으로 돌아 해 뜨는 편을 향하고 기슬롯 다볼의 경계에 이르고 다브랏으로 나가서 야비아로 올라가고","reference":"여호수아 19:12","category":"$undefined"},{"id":"6335","book":"여호수아","book_name":"여호수아","chapter":19,"verse":13,"text":"또 거기서부터 동편으로 가드 헤벨을 지나 엣 가신에 이르고 네아까지 연한 림몬으로 나아가서","reference":"여호수아 19:13","category":"$undefined"},{"id":"6336","book":"여호수아","book_name":"여호수아","chapter":19,"verse":14,"text":"북으로 돌아 한나돈에 이르고 입다엘 골짜기에 이르러 끝이 되며","reference":"여호수아 19:14","category":"$undefined"},{"id":"6337","book":"여호수아","book_name":"여호수아","chapter":19,"verse":15,"text":"또 갓닷과, 나할랄과, 시므론과, 이달라와, 베들레헴이니 모두 십 이성읍이요 또 그 촌락이라","reference":"여호수아 19:15","category":"$undefined"},{"id":"6338","book":"여호수아","book_name":"여호수아","chapter":19,"verse":16,"text":"스불론 자손이 그 가족대로 얻은 기업은 이 성읍들과 그 촌락이었더라","reference":"여호수아 19:16","category":"$undefined"},{"id":"6339","book":"여호수아","book_name":"여호수아","chapter":19,"verse":17,"text":"네째로 잇사갈 곧 잇사갈 자손을 위하여 그 가족대로 제비를 뽑았으니","reference":"여호수아 19:17","category":"$undefined"},{"id":"6340","book":"여호수아","book_name":"여호수아","chapter":19,"verse":18,"text":"그 지경 안은 이스르엘과, 그술롯과, 수넴과,","reference":"여호수아 19:18","category":"$undefined"},{"id":"6341","book":"여호수아","book_name":"여호수아","chapter":19,"verse":19,"text":"하바라임과, 시온과, 아나하랏과,","reference":"여호수아 19:19","category":"$undefined"},{"id":"6342","book":"여호수아","book_name":"여호수아","chapter":19,"verse":20,"text":"랍빗과, 기시온과, 에베스와,","reference":"여호수아 19:20","category":"$undefined"},{"id":"6343","book":"여호수아","book_name":"여호수아","chapter":19,"verse":21,"text":"레멧과, 언간님과, 엔핫다와, 벧 바세스며,","reference":"여호수아 19:21","category":"$undefined"},{"id":"6344","book":"여호수아","book_name":"여호수아","chapter":19,"verse":22,"text":"그 경계는 다볼과 사하수마와 벧 세메스에 미치고 그 끝은 요단이니 모두 십 육 성읍이요 또 그 촌락이라","reference":"여호수아 19:22","category":"$undefined"},{"id":"6345","book":"여호수아","book_name":"여호수아","chapter":19,"verse":23,"text":"잇사갈 자손 지파가 그 가족대로 얻은 기업은 이 성읍들과 그 촌락이었더라","reference":"여호수아 19:23","category":"$undefined"},{"id":"6346","book":"여호수아","book_name":"여호수아","chapter":19,"verse":24,"text":"다섯째로 아셀 자손의 지파를 위하여 그 가족대로 제비를 뽑았으니","reference":"여호수아 19:24","category":"$undefined"},{"id":"6347","book":"여호수아","book_name":"여호수아","chapter":19,"verse":25,"text":"그 지경 안은 헬갓과, 할리와, 베덴과, 악삽과,","reference":"여호수아 19:25","category":"$undefined"},{"id":"6348","book":"여호수아","book_name":"여호수아","chapter":19,"verse":26,"text":"알람멜렉과, 아맛과, 미살이며 그 경계의 서편은 갈멜에 미치며 시홀 림낫에 미치고","reference":"여호수아 19:26","category":"$undefined"},{"id":"6349","book":"여호수아","book_name":"여호수아","chapter":19,"verse":27,"text":"꺾여 해 돋는 편을 향하여 벧 다곤에 이르며 스불론에 달하고 북편으로 입다 엘 골짜기에 미쳐서 벧에멕과 느이엘에 이르고 가불 좌편으로 나가서","reference":"여호수아 19:27","category":"$undefined"},{"id":"6350","book":"여호수아","book_name":"여호수아","chapter":19,"verse":28,"text":"에브론과, 르홉과, 함몬과, 가나를 지나 큰 시돈까지 이르고","reference":"여호수아 19:28","category":"$undefined"},{"id":"6351","book":"여호수아","book_name":"여호수아","chapter":19,"verse":29,"text":"돌아서 라마와 견고한 성읍 두로에 이르고 돌아서 호사에 이르고 악십 지방 곁 바다가 끝이 되며","reference":"여호수아 19:29","category":"$undefined"},{"id":"6352","book":"여호수아","book_name":"여호수아","chapter":19,"verse":30,"text":"또 움마와, 아벡과, 르홉이니 모두 이십 이 성읍과 그 촌락이라","reference":"여호수아 19:30","category":"$undefined"},{"id":"6353","book":"여호수아","book_name":"여호수아","chapter":19,"verse":31,"text":"아셀 자손의 지파가 그 가족대로 얻은 기업은 이 성읍들과 그 촌락이었더라","reference":"여호수아 19:31","category":"$undefined"},{"id":"6354","book":"여호수아","book_name":"여호수아","chapter":19,"verse":32,"text":"여섯째로 납달리 자손을 위하여 납달리 자손의 가족대로 제비를 뽑았으니","reference":"여호수아 19:32","category":"$undefined"},{"id":"6355","book":"여호수아","book_name":"여호수아","chapter":19,"verse":33,"text":"그 경계는 헬렙과 사아난님의 상수리나무에서부터 아다미 네겝과 얍느엘을 지나 락굼까지요 그 끝은 요단이며","reference":"여호수아 19:33","category":"$undefined"},{"id":"6356","book":"여호수아","book_name":"여호수아","chapter":19,"verse":34,"text":"서편으로 돌아 아스놋 다볼에 이르고 그 곳에서부터 나가 훅곡에 이르러는 남은 스불론에 접하였고 서는 아셀에 접하였으며 해 돋는 편은 유다에 달한 요단이며","reference":"여호수아 19:34","category":"$undefined"},{"id":"6357","book":"여호수아","book_name":"여호수아","chapter":19,"verse":35,"text":"그 견고한 성읍들은 싯딤과, 세르와, 함맛과, 락갓과, 긴네렛과,","reference":"여호수아 19:35","category":"$undefined"},{"id":"6358","book":"여호수아","book_name":"여호수아","chapter":19,"verse":36,"text":"아다마와, 라마와, 하솔과,","reference":"여호수아 19:36","category":"$undefined"},{"id":"6359","book":"여호수아","book_name":"여호수아","chapter":19,"verse":37,"text":"게데스와, 에드레이와, 엔 하솔과,","reference":"여호수아 19:37","category":"$undefined"},{"id":"6360","book":"여호수아","book_name":"여호수아","chapter":19,"verse":38,"text":"이론과, 믹다렐과, 호렘과, 벧 아낫과, 벧 세메스니 모두 십 구 성읍이요 또 그 촌락이라","reference":"여호수아 19:38","category":"$undefined"},{"id":"6361","book":"여호수아","book_name":"여호수아","chapter":19,"verse":39,"text":"납달리 자손의 지파가 그 가족대로 얻은 기업은 이 성읍들과 그 촌락이었더라","reference":"여호수아 19:39","category":"$undefined"},{"id":"6362","book":"여호수아","book_name":"여호수아","chapter":19,"verse":40,"text":"일곱째로 단 자손의 지파를 위하여 그 가족대로 제비를 뽑았으니","reference":"여호수아 19:40","category":"$undefined"},{"id":"6363","book":"여호수아","book_name":"여호수아","chapter":19,"verse":41,"text":"그 기업의 지경은 소라와, 에스다올과, 이르세메스와,","reference":"여호수아 19:41","category":"$undefined"},{"id":"6364","book":"여호수아","book_name":"여호수아","chapter":19,"verse":42,"text":"사알랍빈과, 아얄론과, 이들라와,","reference":"여호수아 19:42","category":"$undefined"},{"id":"6365","book":"여호수아","book_name":"여호수아","chapter":19,"verse":43,"text":"엘론과, 딤나와, 에그론과,","reference":"여호수아 19:43","category":"$undefined"},{"id":"6366","book":"여호수아","book_name":"여호수아","chapter":19,"verse":44,"text":"엘드게와, 깁브돈과, 바알랏과,","reference":"여호수아 19:44","category":"$undefined"},{"id":"6367","book":"여호수아","book_name":"여호수아","chapter":19,"verse":45,"text":"여훗과, 브네브락과, 가드 림몬과,","reference":"여호수아 19:45","category":"$undefined"},{"id":"6368","book":"여호수아","book_name":"여호수아","chapter":19,"verse":46,"text":"메얄곤과, 락곤과, 욥바 맞은편 경계까지라","reference":"여호수아 19:46","category":"$undefined"},{"id":"6369","book":"여호수아","book_name":"여호수아","chapter":19,"verse":47,"text":"그런데 단 자손의 지경이 더욱 확장되었으니 이는 단 자손이 올라가서 레센을 쳐서 취하여 칼날로 치고 그것을 얻어 거기 거하였음이라 그 조상 단의 이름을 따라서 레센을 단이라 하였더라","reference":"여호수아 19:47","category":"$undefined"},{"id":"6370","book":"여호수아","book_name":"여호수아","chapter":19,"verse":48,"text":"단 자손의 지파가 그 가족대로 얻은 기업은 이 성읍들과 그 촌락이었더라","reference":"여호수아 19:48","category":"$undefined"},{"id":"6371","book":"여호수아","book_name":"여호수아","chapter":19,"verse":49,"text":"이스라엘 자손이 그 경계를 따라서 기업의 땅 나누기를 마치고 자기들 중에서 눈의 아들 여호수아에게 기업을 주었으되","reference":"여호수아 19:49","category":"$undefined"},{"id":"6372","book":"여호수아","book_name":"여호수아","chapter":19,"verse":50,"text":"곧 여호와의 명령대로 여호수아의 구한 성읍 에브라임 산지 딤낫 세라를 주매 여호수아가 그 성읍을 중건하고 거기 거하였었더라","reference":"여호수아 19:50","category":"$undefined"},{"id":"6373","book":"여호수아","book_name":"여호수아","chapter":19,"verse":51,"text":"제사장 엘르아살과 눈의 아들 여호수아와 이스라엘 자손 지파의 족장들이 실로에서 회막문 여호와 앞에서 제비 뽑아 나눈 기업이 이러하니라 이에 땅 나누는 일이 마쳤더라","reference":"여호수아 19:51","category":"$undefined"}],"bookSlug":"joshua"}]
