2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":2,"verses":[{"id":"5871","book":"여호수아","book_name":"여호수아","chapter":2,"verse":1,"text":"눈의 아들 여호수아가 싯딤에서 두 사람을 정탐으로 가만히 보내며 그들에게 이르되 가서 그 땅과 여리고를 엿보라 하매 그들이 가서 라합이라 하는 기생의 집에 들어가 거기서 유숙하더니","reference":"여호수아 2:1","category":"$undefined"},{"id":"5872","book":"여호수아","book_name":"여호수아","chapter":2,"verse":2,"text":"혹이 여리고 왕에게 고하여 가로되 `보소서 이 밤에 이스라엘 자손 몇 사람이 땅을 탐지하러 이리로 들어 왔나이다'","reference":"여호수아 2:2","category":"$undefined"},{"id":"5873","book":"여호수아","book_name":"여호수아","chapter":2,"verse":3,"text":"여리고 왕이 라합에게 기별하여 가로되 `네게로 와서 네 집에 들어간 사람들을 끌어내라 그들은 이 온 땅을 탐지하러 왔느니라'","reference":"여호수아 2:3","category":"$undefined"},{"id":"5874","book":"여호수아","book_name":"여호수아","chapter":2,"verse":4,"text":"그 여인이 그 두 사람을 이미 숨긴지라 가로되 `과연 그 사람들이 내게 왔었으나 그들이 어디로서인지 나는 알지 못하였고","reference":"여호수아 2:4","category":"$undefined"},{"id":"5875","book":"여호수아","book_name":"여호수아","chapter":2,"verse":5,"text":"그 사람들이 어두워 성문을 닫을 때쯤 되어 나갔으니 어디로 갔는지 알지 못하되 급히 따라가라 그리하면 그들에게 미치리라' 하였으나","reference":"여호수아 2:5","category":"$undefined"},{"id":"5876","book":"여호수아","book_name":"여호수아","chapter":2,"verse":6,"text":"실상은 그가 이미 그들을 이끌고 지붕에 올라가서 그 지붕에 벌여놓은 삼대에 숨겼더라","reference":"여호수아 2:6","category":"$undefined"},{"id":"5877","book":"여호수아","book_name":"여호수아","chapter":2,"verse":7,"text":"그 사람들은 요단 길로 나루턱까지 따라갔고 그 따르는 자들이 나가자 곧 성문을 닫았더라","reference":"여호수아 2:7","category":"$undefined"},{"id":"5878","book":"여호수아","book_name":"여호수아","chapter":2,"verse":8,"text":"두 사람이 눕기 전에 라합이 지붕에 올라가서 그들에게 이르러","reference":"여호수아 2:8","category":"$undefined"},{"id":"5879","book":"여호수아","book_name":"여호수아","chapter":2,"verse":9,"text":"말하되 `여호와께서 이 땅을 너희에게 주신 줄을 내가 아노라 우리가 너희를 심히 두려워하고 이 땅 백성이 다 너희 앞에 간담이 녹나니","reference":"여호수아 2:9","category":"$undefined"},{"id":"5880","book":"여호수아","book_name":"여호수아","chapter":2,"verse":10,"text":"이는 너희가 애굽에서 나올 때에 여호와께서 너희 앞에서 홍해 물을 마르게 하신 일과 너희가 요단 저편에 있는 아모리 사람의 두 왕 시혼과 옥에게 행한 일 곧 그들을 전멸시킨 일을 우리가 들었음이라","reference":"여호수아 2:10","category":"$undefined"},{"id":"5881","book":"여호수아","book_name":"여호수아","chapter":2,"verse":11,"text":"우리가 듣자 곧 마음이 녹았고 너희의 연고로 사람이 정신을 잃었나니 너희 하나님 여호와는 상천 하지에 하나님이시니라 !","reference":"여호수아 2:11","category":"$undefined"},{"id":"5882","book":"여호수아","book_name":"여호수아","chapter":2,"verse":12,"text":"그러므로 청하노니 내가 너희를 선대하였은즉 너희도 내 아버지의 집을 선대하여 나의 부모와 남녀 형제와 무릇 그들에게 있는 모든 자를 살려주어 우리 생명을 죽는데서 건져내기로 이제 여호와로 맹세하고 내게 진실한 표를 내라'","reference":"여호수아 2:12","category":"$undefined"},{"id":"5883","book":"여호수아","book_name":"여호수아","chapter":2,"verse":13,"text":"(12절과 같음)","reference":"여호수아 2:13","category":"$undefined"},{"id":"5884","book":"여호수아","book_name":"여호수아","chapter":2,"verse":14,"text":"두 사람이 그에게 이르되 `네가 우리의 이 일을 누설치 아니하면 우리의 생명으로 너희를 대신이라도 할 것이요 여호와께서 우리에게 이 땅을 주실 때에는 인자하고 진실하게 너를 대우하리라'","reference":"여호수아 2:14","category":"$undefined"},{"id":"5885","book":"여호수아","book_name":"여호수아","chapter":2,"verse":15,"text":"라합이 그들을 창에서 줄로 달아내리우니 그 집이 성벽 위에 있으므로 그가 성벽 위에 거하였음이라","reference":"여호수아 2:15","category":"$undefined"},{"id":"5886","book":"여호수아","book_name":"여호수아","chapter":2,"verse":16,"text":"라합이 그들에게 이르되 `두렵건대 따르는 사람들이 너희를 만날까 하노니 너희는 산으로 가서 거기 사흘을 숨었다가 따르는 자들이 돌아간 후에 너희 길을 갈지니라'","reference":"여호수아 2:16","category":"$undefined"},{"id":"5887","book":"여호수아","book_name":"여호수아","chapter":2,"verse":17,"text":"두 사람이 그에게 이르되 `네가 우리로 서약케 한 이 맹세에 대하여 우리가 허물이 없게 하리니","reference":"여호수아 2:17","category":"$undefined"},{"id":"5888","book":"여호수아","book_name":"여호수아","chapter":2,"verse":18,"text":"우리가 이 땅에 들어올 때에 우리를 달아 내리운 창에 이 붉은 줄을 내고 네 부모와 형제와 네 아비의 가족을 다 네 집에 모으라","reference":"여호수아 2:18","category":"$undefined"},{"id":"5889","book":"여호수아","book_name":"여호수아","chapter":2,"verse":19,"text":"누구든지 네 집 문을 나서 거리로 가면 그 피가 그의 머리로 돌아갈 것이요 우리는 허물이 없으리라 그러나 누구든지 너와 함께 집에 있는 자에게 누가 손을 대면 그 피는 우리의 머리로 돌아오려니와","reference":"여호수아 2:19","category":"$undefined"},{"id":"5890","book":"여호수아","book_name":"여호수아","chapter":2,"verse":20,"text":"네가 우리의 이 일을 누설하면 네가 우리로 서약케 한 맹세에 대하여 우리에게 허물이 없으리라'","reference":"여호수아 2:20","category":"$undefined"},{"id":"5891","book":"여호수아","book_name":"여호수아","chapter":2,"verse":21,"text":"라합이 가로되 `너희의 말대로 할 것이라' 하고 그들을 보내어 가게 하고 붉은 줄을 창문에 매니라","reference":"여호수아 2:21","category":"$undefined"},{"id":"5892","book":"여호수아","book_name":"여호수아","chapter":2,"verse":22,"text":"그들이 가서 산에 이르러 따르는 자가 돌아가도록 사흘을 거기 유하매 따르는 자가 그들을 길에서 두루 찾다가 만나지 못하니라","reference":"여호수아 2:22","category":"$undefined"},{"id":"5893","book":"여호수아","book_name":"여호수아","chapter":2,"verse":23,"text":"그 두 사람이 돌이켜 산에서 내려와 강을 건너 눈의 아들 여호수아에게 나아와서 그 당한 모든 일을 고하고","reference":"여호수아 2:23","category":"$undefined"},{"id":"5894","book":"여호수아","book_name":"여호수아","chapter":2,"verse":24,"text":"또 여호수아에게 이르되 `진실로 여호와께서 그 온 땅을 우리 손에 붙이셨으므로 그 땅의 모든 거민이 우리 앞에서 간담이 녹더이다'","reference":"여호수아 2:24","category":"$undefined"}],"bookSlug":"joshua"}]
