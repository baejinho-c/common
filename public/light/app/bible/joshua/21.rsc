2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":21,"verses":[{"id":"6383","book":"여호수아","book_name":"여호수아","chapter":21,"verse":1,"text":"때에 레위 사람의 족장들이 제사장 엘르아살과 눈의 아들 여호수아와 이스라엘 자손의 지파 족장들에게 나아와","reference":"여호수아 21:1","category":"$undefined"},{"id":"6384","book":"여호수아","book_name":"여호수아","chapter":21,"verse":2,"text":"가나안 땅 실로에서 그들에게 말하여 가로되 '여호와께서 모세로 명하사 우리의 거할 성읍들과 우리의 가축 먹일 그 들을 우리에게 주라 하셨었나이다' 하매","reference":"여호수아 21:2","category":"$undefined"},{"id":"6385","book":"여호수아","book_name":"여호수아","chapter":21,"verse":3,"text":"이스라엘 자손이 여호와의 명을 따라 자기의 기업에서 이 아래 성읍들과 그 들을 레위 사람에게 주니라","reference":"여호수아 21:3","category":"$undefined"},{"id":"6386","book":"여호수아","book_name":"여호수아","chapter":21,"verse":4,"text":"그핫 가족을 위하여 제비를 뽑았는데 레위 사람 중 제사장 아론의 자손들은 유다 지파와 시므온 지파와 베냐민 지파 중에서 제비 대로 십 삼 성읍을 얻었고","reference":"여호수아 21:4","category":"$undefined"},{"id":"6387","book":"여호수아","book_name":"여호수아","chapter":21,"verse":5,"text":"그 남은 그핫 자손들은 에브라임 지파의 가족과 단 지파와 므낫세 반 지파 중에서 제비대로 열 성읍을 얻었으며","reference":"여호수아 21:5","category":"$undefined"},{"id":"6388","book":"여호수아","book_name":"여호수아","chapter":21,"verse":6,"text":"게르손 자손들은 잇사갈 지파의 가족들과 아셀 지파와 납달리 지파와 바산에 있는 므낫세 반 지파 중에서 제비대로 십삼 성읍을 얻었더라","reference":"여호수아 21:6","category":"$undefined"},{"id":"6389","book":"여호수아","book_name":"여호수아","chapter":21,"verse":7,"text":"므라리 자손들은 그 가족대로 르우벤 지파와 갓 지파와 스불론 지파 중에서 십 이 성읍을 얻었더라","reference":"여호수아 21:7","category":"$undefined"},{"id":"6390","book":"여호수아","book_name":"여호수아","chapter":21,"verse":8,"text":"여호와께서 모세로 명하신 대로 이스라엘 자손이 제비뽑아 레위 사람에게 준 성읍들과 그 들이 이러하니라","reference":"여호수아 21:8","category":"$undefined"},{"id":"6391","book":"여호수아","book_name":"여호수아","chapter":21,"verse":9,"text":"유다 자손의 지파와 시므온 자손의 지파 중에서는 이 아래 기명한 성읍들을 주었는데","reference":"여호수아 21:9","category":"$undefined"},{"id":"6392","book":"여호수아","book_name":"여호수아","chapter":21,"verse":10,"text":"레위 자손 중 그핫 가족들에 속한 아론 자손이 첫째로 제비뽑혔으므로","reference":"여호수아 21:10","category":"$undefined"},{"id":"6393","book":"여호수아","book_name":"여호수아","chapter":21,"verse":11,"text":"아낙의 아비 아르바의 성읍 유다 산지 기럇 아르바 곧 헤브론과 그 사면 들을 그들에게 주었고","reference":"여호수아 21:11","category":"$undefined"},{"id":"6394","book":"여호수아","book_name":"여호수아","chapter":21,"verse":12,"text":"오직 그 성읍의 밭과 촌락은 여분네의 아들 갈렙에게 주어 소유가 되게 하였더라","reference":"여호수아 21:12","category":"$undefined"},{"id":"6395","book":"여호수아","book_name":"여호수아","chapter":21,"verse":13,"text":"제사장 아론 자손에게 준 것은 살인자의 도피성 헤브론과 그 들이요, 또 립나와 그 들과,","reference":"여호수아 21:13","category":"$undefined"},{"id":"6396","book":"여호수아","book_name":"여호수아","chapter":21,"verse":14,"text":"얏딜과 그 들과, 에스드모아와 그 들과,","reference":"여호수아 21:14","category":"$undefined"},{"id":"6397","book":"여호수아","book_name":"여호수아","chapter":21,"verse":15,"text":"홀론과 그 들과, 드빌과 그 들과,","reference":"여호수아 21:15","category":"$undefined"},{"id":"6398","book":"여호수아","book_name":"여호수아","chapter":21,"verse":16,"text":"아인과 그 들과, 윳다와 그 들과, 벧 세메스와 그 들이니 이 두 지파에서 아홉 성읍을 내었고","reference":"여호수아 21:16","category":"$undefined"},{"id":"6399","book":"여호수아","book_name":"여호수아","chapter":21,"verse":17,"text":"또 베냐민 지파 중에서는 기브온과 그 들과, 게바와 그 들과,","reference":"여호수아 21:17","category":"$undefined"},{"id":"6400","book":"여호수아","book_name":"여호수아","chapter":21,"verse":18,"text":"아나돗과 그 들과, 알몬과 그 들 곧 네 성읍을 내었으니","reference":"여호수아 21:18","category":"$undefined"},{"id":"6401","book":"여호수아","book_name":"여호수아","chapter":21,"verse":19,"text":"제사장 아론 자손의 성읍이 모두 십 삼 성읍과 그 들이었더라","reference":"여호수아 21:19","category":"$undefined"},{"id":"6402","book":"여호수아","book_name":"여호수아","chapter":21,"verse":20,"text":"그 남은 레위 사람 그핫 자손의 가족 곧 그핫 자손에게는 제비 뽑아 에브라임 지파 중에서 그 성읍들을 주었으니","reference":"여호수아 21:20","category":"$undefined"},{"id":"6403","book":"여호수아","book_name":"여호수아","chapter":21,"verse":21,"text":"곧 살인자의 도피성 에브라임 산지 세겜과 그 들이요, 또 게셀과 그 들과,","reference":"여호수아 21:21","category":"$undefined"},{"id":"6404","book":"여호수아","book_name":"여호수아","chapter":21,"verse":22,"text":"깁사임과 그 들과, 벧 호론과 그 들이니 네 성읍이요","reference":"여호수아 21:22","category":"$undefined"},{"id":"6405","book":"여호수아","book_name":"여호수아","chapter":21,"verse":23,"text":"또 단 지파 중에서 준 것은 엘드게와 그 들과, 깁브돈과 그 들과,","reference":"여호수아 21:23","category":"$undefined"},{"id":"6406","book":"여호수아","book_name":"여호수아","chapter":21,"verse":24,"text":"아얄론과 그 들과, 가드 림몬과 그 들이니 네 성읍이요","reference":"여호수아 21:24","category":"$undefined"},{"id":"6407","book":"여호수아","book_name":"여호수아","chapter":21,"verse":25,"text":"또 므낫세 반 지파 중에서 준 것은 다아낙과 그 들과, 가드림몬과 그 들이니 두 성읍이라","reference":"여호수아 21:25","category":"$undefined"},{"id":"6408","book":"여호수아","book_name":"여호수아","chapter":21,"verse":26,"text":"그핫 자손의 남은 가족의 성읍이 모두 열과 그 들이었더라","reference":"여호수아 21:26","category":"$undefined"},{"id":"6409","book":"여호수아","book_name":"여호수아","chapter":21,"verse":27,"text":"레위 가족의 게르손 자손들에게는 므낫세 반 지파 중에서 살인자의 도피성 바산 골란과 그 들을 주었고 또 브에스드라와 그 들을 주었으니 두 성읍이요","reference":"여호수아 21:27","category":"$undefined"},{"id":"6410","book":"여호수아","book_name":"여호수아","chapter":21,"verse":28,"text":"잇사갈 지파 중에서는 기시온과 그들과, 다브랏과 그 들과,","reference":"여호수아 21:28","category":"$undefined"},{"id":"6411","book":"여호수아","book_name":"여호수아","chapter":21,"verse":29,"text":"야르뭇과 그 들과, 언 간님과 그 들을 주었으니 네 성읍이요","reference":"여호수아 21:29","category":"$undefined"},{"id":"6412","book":"여호수아","book_name":"여호수아","chapter":21,"verse":30,"text":"아셀 지파 중에서는 미살과 그 들과, 압돈과 그 들과,","reference":"여호수아 21:30","category":"$undefined"},{"id":"6413","book":"여호수아","book_name":"여호수아","chapter":21,"verse":31,"text":"헬갓과 그 들과, 르홉과 그 들을 주었으니 네 성읍이요","reference":"여호수아 21:31","category":"$undefined"},{"id":"6414","book":"여호수아","book_name":"여호수아","chapter":21,"verse":32,"text":"납달리 지파 중에서는 살인자의 도피성 갈릴리 게데스와 그 들을 주었고 또 함못 돌과 그 들과, 가르단과 그 들을 주었으니 세 성 읍이라","reference":"여호수아 21:32","category":"$undefined"},{"id":"6415","book":"여호수아","book_name":"여호수아","chapter":21,"verse":33,"text":"게르손 사람이 그 가족대로 얻은 성읍이 모두 열 세 성읍과 그 들이었더라","reference":"여호수아 21:33","category":"$undefined"},{"id":"6416","book":"여호수아","book_name":"여호수아","chapter":21,"verse":34,"text":"그 남은 레위 사람 므라리 자손의 가족들에게 준 것은 스불론 지파 중에서 욕느암과 그 들과, 가르다와 그 들과,","reference":"여호수아 21:34","category":"$undefined"},{"id":"6417","book":"여호수아","book_name":"여호수아","chapter":21,"verse":35,"text":"딤나와 그 들과, 나할랄과 그 들이니 네 성읍이요","reference":"여호수아 21:35","category":"$undefined"},{"id":"6418","book":"여호수아","book_name":"여호수아","chapter":21,"verse":36,"text":"르우벤 지파 중에서 준 것은 베셀과 그 들과, 야하스와 그 들과","reference":"여호수아 21:36","category":"$undefined"},{"id":"6419","book":"여호수아","book_name":"여호수아","chapter":21,"verse":37,"text":"그데못과 그 들과, 므바앗과 그 들이니 네 성읍이요","reference":"여호수아 21:37","category":"$undefined"},{"id":"6420","book":"여호수아","book_name":"여호수아","chapter":21,"verse":38,"text":"갓 지파 중에서 준 것은 살인자의 도피성 길르앗 라못과 그 들이요, 또 마하나임과 그 들과,","reference":"여호수아 21:38","category":"$undefined"},{"id":"6421","book":"여호수아","book_name":"여호수아","chapter":21,"verse":39,"text":"헤스본과 그 들과, 야셀과 그 들이니 모두 네 성읍이라","reference":"여호수아 21:39","category":"$undefined"},{"id":"6422","book":"여호수아","book_name":"여호수아","chapter":21,"verse":40,"text":"이는 레위 가족의 남은 자 곧 므라리 자손이 그 가족대로 얻은 성읍이니 그 제비뽑아 얻은 성읍이 십 이 성읍이었더라","reference":"여호수아 21:40","category":"$undefined"},{"id":"6423","book":"여호수아","book_name":"여호수아","chapter":21,"verse":41,"text":"레위 사람의 이스라엘 자손의 기업 중에서 얻은 성읍이 모두 사십 팔 성읍이요 또 그 들이라","reference":"여호수아 21:41","category":"$undefined"},{"id":"6424","book":"여호수아","book_name":"여호수아","chapter":21,"verse":42,"text":"이 각 성읍의 사면에 들이 있었고 모든 성읍이 다 그러하였더라","reference":"여호수아 21:42","category":"$undefined"},{"id":"6425","book":"여호수아","book_name":"여호수아","chapter":21,"verse":43,"text":"여호와께서 이스라엘의 열조에게 맹세하사 주마 하신 온 땅을 이와 같이 이스라엘에게 다 주셨으므로 그들이 그것을 얻어 거기 거하였으며","reference":"여호수아 21:43","category":"$undefined"},{"id":"6426","book":"여호수아","book_name":"여호수아","chapter":21,"verse":44,"text":"여호와께서 그들의 사방에 안식을 주셨으되 그 열조에게 맹세하신 대로 하셨으므로 그 모든 대적이 그들을 당한 자가 하나도 없었으니 이는 여호와께서 그들의 모든 대적을 그들의 손에 붙이셨음이라","reference":"여호수아 21:44","category":"$undefined"},{"id":"6427","book":"여호수아","book_name":"여호수아","chapter":21,"verse":45,"text":"여호와께서 이스라엘 족속에게 말씀하신 선한 일이 하나도 남음이 없이 다 응하였더라","reference":"여호수아 21:45","category":"$undefined"}],"bookSlug":"joshua"}]
