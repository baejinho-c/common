2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":22,"verses":[{"id":"6428","book":"여호수아","book_name":"여호수아","chapter":22,"verse":1,"text":"그 때에 여호수아가 르우벤 사람과 갓 사람과 므낫세 반 지파를 불러서","reference":"여호수아 22:1","category":"$undefined"},{"id":"6429","book":"여호수아","book_name":"여호수아","chapter":22,"verse":2,"text":"그들에게 이르되 `여호와의 종 모세가 너희에게 명한 것을 너희가 다 지키며 또 내가 너희에게 명한 모든 일에 내 말을 너희가 청종하여","reference":"여호수아 22:2","category":"$undefined"},{"id":"6430","book":"여호수아","book_name":"여호수아","chapter":22,"verse":3,"text":"오늘날까지 날이 오래도록 너희가 너희 형제를 떠나지 아니하고 오직 너희 하나님 여호와의 명하신 그 책임을 지키도다","reference":"여호수아 22:3","category":"$undefined"},{"id":"6431","book":"여호수아","book_name":"여호수아","chapter":22,"verse":4,"text":"이제는 너희 하나님 여호와꼐서 이미 말씀하신 대로 너희 형제에게 안식을 주셨으니 그런즉 이제 너희는 여호와의 종 모세가 요단 저편에서 너희에게 준 소유지로 가서 너희의 장막으로 돌아가되","reference":"여호수아 22:4","category":"$undefined"},{"id":"6432","book":"여호수아","book_name":"여호수아","chapter":22,"verse":5,"text":"크게 삼가 여호와의 종 모세가 너희에게 명한 명령과 율법을 행하여 너희 하나님 여호와를 사랑하고 그 모든 길로 행하며 그 계명을 지켜 그에게 친근히 하고 너희 마음을 다하며 성품을 다하여 그를 섬길지니라' 하고","reference":"여호수아 22:5","category":"$undefined"},{"id":"6433","book":"여호수아","book_name":"여호수아","chapter":22,"verse":6,"text":"여호수아가 그들에게 축복하여 보내매 그들이 자기 장막으로 갔더라","reference":"여호수아 22:6","category":"$undefined"},{"id":"6434","book":"여호수아","book_name":"여호수아","chapter":22,"verse":7,"text":"므낫세 반 지파에게는 모세가 바산에서 기업을 주었고 기타 반 지파에게는 여호수아가 요단 이편 서편에서 그 형제 중에서 기업을 준지라 여호수아가 그들을 그 장막으로 돌려보낼 때에 그들에게 축복하고","reference":"여호수아 22:7","category":"$undefined"},{"id":"6435","book":"여호수아","book_name":"여호수아","chapter":22,"verse":8,"text":"일러 가로되 `너희는 많은 재산과 심히 많은 가축과 은,금,동,철과 심히 많은 의복을 가지고 너희의 장막으로 돌아가서 너희 대적에게서 탈취한 것을 너희 형제와 나눌찌니라' 하매","reference":"여호수아 22:8","category":"$undefined"},{"id":"6436","book":"여호수아","book_name":"여호수아","chapter":22,"verse":9,"text":"르우벤 자손과 갓 자손과 므낫세 반 지파가 가나안 땅 실로에서 이스라엘 자손을 떠나 여호와께서 모세로 명하신 대로 얻은 땅 곧 그 소유지 길르앗으로 가니라","reference":"여호수아 22:9","category":"$undefined"},{"id":"6437","book":"여호수아","book_name":"여호수아","chapter":22,"verse":10,"text":"르우벤 자손과 므낫세 반 지파가 가나안 땅 요단 언덕 가에 이르자 거기서 요단 가에 단을 쌓았는데 볼 만한 큰 단이었더라","reference":"여호수아 22:10","category":"$undefined"},{"id":"6438","book":"여호수아","book_name":"여호수아","chapter":22,"verse":11,"text":"이스라엘 자손이 들은즉 이르기를 `르우벤 자손과 갓 자손과 므낫세 반 지파가 가나안 땅의 맨 앞편 요단 언덕 가 이스라엘 자손에게 속한 편에 단을 쌓았다' 하는지라","reference":"여호수아 22:11","category":"$undefined"},{"id":"6439","book":"여호수아","book_name":"여호수아","chapter":22,"verse":12,"text":"이스라엘 자손이 이를 듣자 곧 이스라엘 자손의 온 회중이 실로에 모여서 그들과 싸우러 가려하니라","reference":"여호수아 22:12","category":"$undefined"},{"id":"6440","book":"여호수아","book_name":"여호수아","chapter":22,"verse":13,"text":"이스라엘 자손이 제사장 엘르아살의 아들 비느하스를 길르앗 땅으로 보내어 르우벤 자손과 갓 자손과 므낫세 반 지파를 보게 하되","reference":"여호수아 22:13","category":"$undefined"},{"id":"6441","book":"여호수아","book_name":"여호수아","chapter":22,"verse":14,"text":"이스라엘 각 지파에서 한 방백씩 열 방백을 그와 함께 하게 하니 그들은 각기 이스라엘 천만인 중 족속의 두령이라","reference":"여호수아 22:14","category":"$undefined"},{"id":"6442","book":"여호수아","book_name":"여호수아","chapter":22,"verse":15,"text":"그들이 길르앗 땅에 이르러 르우벤 자손과 갓 자손과 므낫세 반 지파에게 나아가서 그들에게 말하여 가로되","reference":"여호수아 22:15","category":"$undefined"},{"id":"6443","book":"여호수아","book_name":"여호수아","chapter":22,"verse":16,"text":"여호와의 온 회중이 말하기를 `너희가 어찌하여 이스라엘 하나님께 범죄하여 오늘날 여호와를 좇는 데서 떠나서 자기를 위하여 단을 쌓아 여호와를 거역하고자 하느냐 ?","reference":"여호수아 22:16","category":"$undefined"},{"id":"6444","book":"여호수아","book_name":"여호수아","chapter":22,"verse":17,"text":"브올의 죄악으로 인하여 여호와의 회중에 재앙이 내렸으나 오늘날까지 우리가 그 죄에서 정결함을 얻지 못하였거늘 그 죄악이 우리에게 부족하여서","reference":"여호수아 22:17","category":"$undefined"},{"id":"6445","book":"여호수아","book_name":"여호수아","chapter":22,"verse":18,"text":"오늘날 너희가 돌이켜 여호와를 좇지 않고자 하느냐 ? 너희가 오늘날 여호와를 배역하면 내일은 그가 이스라엘 온 회중에게 진노하시리라","reference":"여호수아 22:18","category":"$undefined"},{"id":"6446","book":"여호수아","book_name":"여호수아","chapter":22,"verse":19,"text":"그런데 너희 소유지가 만일 깨끗지 아니하거든 여호와의 성막이 있는 여호와의 소유지로 건너와 우리 중에서 소유를 취할 것이니라 오직 우리 하나님 여호와의 단 외에 다른 단을 쌓음으로 여호와께 패역하지 말며 우리에게도 패역하지 말라","reference":"여호수아 22:19","category":"$undefined"},{"id":"6447","book":"여호수아","book_name":"여호수아","chapter":22,"verse":20,"text":"세라의 아들 아간이 바친 물건에 대하여 범죄하므로 이스라엘 온 회중에 진노가 임하지 아니하였었느냐 ? 그 죄악으로 망한 자가 그 사람 뿐이 아니었느니라'","reference":"여호수아 22:20","category":"$undefined"},{"id":"6448","book":"여호수아","book_name":"여호수아","chapter":22,"verse":21,"text":"르우벤 자손과 갓 자손과 므낫세 반 지파가 이스라엘 천만인의 두령에게 대답하여 가로되","reference":"여호수아 22:21","category":"$undefined"},{"id":"6449","book":"여호수아","book_name":"여호수아","chapter":22,"verse":22,"text":"'전능하신 자 하나님 여호와,전능하신 자 하나님 여호와께서 아시나니 이스라엘도 장차 알리라 이 일이 만일 여호와께 패역함이거나 범죄함이거든 주는 오늘날 우리를 구원치 마시옵소서","reference":"여호수아 22:22","category":"$undefined"},{"id":"6450","book":"여호수아","book_name":"여호수아","chapter":22,"verse":23,"text":"우리가 단을 쌓은 것이 돌이켜 여호와를 좇지 아니하려 함이거나 혹시 그 위에 번제나 소제를 드리려 함이거나 혹시 화목제물을 드리려 함이어든 여호와는 친히 벌하시옵소서","reference":"여호수아 22:23","category":"$undefined"},{"id":"6451","book":"여호수아","book_name":"여호수아","chapter":22,"verse":24,"text":"우리가 목적이 있어서 주의하고 이같이 하였노라 곧 생각하기를 후일에 너희 자손이 우리 자손에게 말하여 이르기를 너희가 이스라엘 하나님 여호와와 무슨 상관이 있느냐 ?","reference":"여호수아 22:24","category":"$undefined"},{"id":"6452","book":"여호수아","book_name":"여호수아","chapter":22,"verse":25,"text":"너희 르우벤 자손 갓 자손아 ! 여호와께서 우리와 너희 사이에 요단으로 경계를 삼으셨나니 너희는 여호와께 분의가 없느니라 하여 너희 자손이 우리 자손으로 여호와 경외하기를 그치게 할까 하여","reference":"여호수아 22:25","category":"$undefined"},{"id":"6453","book":"여호수아","book_name":"여호수아","chapter":22,"verse":26,"text":"우리가 말하기를 우리가 이제 한 단 쌓기를 예비하자 하였노니 이는 번제를 위함도 아니요 다른 제사를 위함도 아니라","reference":"여호수아 22:26","category":"$undefined"},{"id":"6454","book":"여호수아","book_name":"여호수아","chapter":22,"verse":27,"text":"우리가 여호와 앞에서 우리 번제와 우리 다른 제사와 우리 화목제로 섬기는 것을 우리와 너희 사이와 우리의 후대 사이에 증거가 되게 할 뿐으로서 너희 자손으로 후일에 우리 자손에게 이르기를 너희는 여호와께 분의가 없다 못하게 하려 함이로라","reference":"여호수아 22:27","category":"$undefined"},{"id":"6455","book":"여호수아","book_name":"여호수아","chapter":22,"verse":28,"text":"우리가 말하였거니와 만일 그들이 후일에 우리에게나 우리 후대에게 이같이 말하면 우리가 말하기를 우리 열조가 지은 여호와의단 모형을 보라 이는 번제를 위한 것도 아니요 다른 제사를 위한것도 아니라 오직 우리와 너희 사이에 증거만 되게 할뿐이라","reference":"여호수아 22:28","category":"$undefined"},{"id":"6456","book":"여호수아","book_name":"여호수아","chapter":22,"verse":29,"text":"우리가 번제나 소제나 다른 제사를 위하여 우리 하나님 여호와의 성막 앞에 있는 단 외에 단을 쌓음으로 여호와께 패역하고 오늘날 여호와를 좇음에서 떠나려 함은 결단코 아니니라' 하리라","reference":"여호수아 22:29","category":"$undefined"},{"id":"6457","book":"여호수아","book_name":"여호수아","chapter":22,"verse":30,"text":"제사장 비느하스와 그와 함께한 회중의 방백 곧 이스라엘 천만인의 두령들이 르우벤 자손과 갓 자손과 므낫세 자손의 말을 듣고 좋게 여긴지라","reference":"여호수아 22:30","category":"$undefined"},{"id":"6458","book":"여호수아","book_name":"여호수아","chapter":22,"verse":31,"text":"제사장 엘르아살의 아들 비느하스가 르우벤 자손과 갓 자손과 므낫세 자손에게 이르되 우리가 `오늘날 여호와께서 우리 중에 계신 줄을 아노니 이는 너희가 이 죄를 여호와께 범치 아니하였음이라 너희가 이제 이스라엘 자손을 여호와의 손에서 건져내었느니라' 하고","reference":"여호수아 22:31","category":"$undefined"},{"id":"6459","book":"여호수아","book_name":"여호수아","chapter":22,"verse":32,"text":"제사장 엘르아살의 아들 비느하스와 방백들이 르우벤 자손과 갓 자손을 떠나 길르앗 땅에서 가나안 땅에 돌아와 이스라엘 자손에게 이르러 회보하매","reference":"여호수아 22:32","category":"$undefined"},{"id":"6460","book":"여호수아","book_name":"여호수아","chapter":22,"verse":33,"text":"그 일이 이스라엘 자손을 즐겁게 한지라 이스라엘 자손이 하나님을 찬송하고 르우벤 자손과 갓 자손의 거하는 땅에 가서 싸워 그것을 멸하자 하는 말을 다시 하지 아니하였더라","reference":"여호수아 22:33","category":"$undefined"},{"id":"6461","book":"여호수아","book_name":"여호수아","chapter":22,"verse":34,"text":"르우벤 자손과 갓 자손이 그 단을 엣이라 칭하였으니 우리 사이에 이 단은 여호와께서 하나님이 되시는 증거라 함이었더라","reference":"여호수아 22:34","category":"$undefined"}],"bookSlug":"joshua"}]
