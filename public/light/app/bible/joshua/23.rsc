2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":23,"verses":[{"id":"6462","book":"여호수아","book_name":"여호수아","chapter":23,"verse":1,"text":"여호와께서 이스라엘의 사방 대적을 다 멸하시고 안식을 이스라엘에게 주신지 오랜 후에 여호수아가 나이 많아 늙은지라","reference":"여호수아 23:1","category":"$undefined"},{"id":"6463","book":"여호수아","book_name":"여호수아","chapter":23,"verse":2,"text":"여호수아가 온 이스라엘 곧 그 장로들과 두령들과 재판장들과 유사들을 불러다가 그들에게 이르되 '나는 나이 많아 늙었도다","reference":"여호수아 23:2","category":"$undefined"},{"id":"6464","book":"여호수아","book_name":"여호수아","chapter":23,"verse":3,"text":"너희 하나님 여호와께서 너희를 위하여 이 모든 나라에 행하신 일을 너희가 다 보았거니와 너희 하나님 여호와 그는 너희를 위하여 싸우신 자시니라","reference":"여호수아 23:3","category":"$undefined"},{"id":"6465","book":"여호수아","book_name":"여호수아","chapter":23,"verse":4,"text":"보라, 내가 요단에서부터 해 지는 편 대해까지의 남아있는 나라들과 이미 멸한 모든 나라를 내가 너희를 위하여 제비뽑아 너희 지파에게 기업이 되게 하였느니라","reference":"여호수아 23:4","category":"$undefined"},{"id":"6466","book":"여호수아","book_name":"여호수아","chapter":23,"verse":5,"text":"너희 하나님 여호와 그가 너희 앞에서 그들을 쫓으사 너희 목전에서 떠나게 하시리니 너희 하나님 여호와께서 너희에게 말씀하신 대로 너희가 그 땅을 차지할 것이라","reference":"여호수아 23:5","category":"$undefined"},{"id":"6467","book":"여호수아","book_name":"여호수아","chapter":23,"verse":6,"text":"그러므로 너희는 크게 힘써 모세의 율법책에 기록된 것을 다 지켜 행하라 ! 그것을 떠나 좌로나 우로나 치우치지 말라 !","reference":"여호수아 23:6","category":"$undefined"},{"id":"6468","book":"여호수아","book_name":"여호수아","chapter":23,"verse":7,"text":"너희 중에 남아 있는 이 나라들 중에 가지 말라 ! 그 신들의 이름을 부르지 말라 ! 그것을 가리켜 맹세하지 말라 ! 또 그것을 섬겨서 그것에게 절하지 말라 !","reference":"여호수아 23:7","category":"$undefined"},{"id":"6469","book":"여호수아","book_name":"여호수아","chapter":23,"verse":8,"text":"오직 너희 하나님 여호와를 친근히 하기를 오늘날까지 행한것 같이 하라","reference":"여호수아 23:8","category":"$undefined"},{"id":"6470","book":"여호수아","book_name":"여호수아","chapter":23,"verse":9,"text":"대저 여호와께서 강대한 나라들을 너희 앞에서 쫓아내셨으므로 오늘날까지 너희를 당한 자가 하나도 없었느니라","reference":"여호수아 23:9","category":"$undefined"},{"id":"6471","book":"여호수아","book_name":"여호수아","chapter":23,"verse":10,"text":"너희 중 한 사람이 천명을 쫓으리니 이는 너희 하나님 여호와 그가 너희에게 말씀하신 것 같이 너희를 위하여 싸우심이라","reference":"여호수아 23:10","category":"$undefined"},{"id":"6472","book":"여호수아","book_name":"여호수아","chapter":23,"verse":11,"text":"그러므로 스스로 조심하여 너희 하나님 여호와를 사랑하라 !","reference":"여호수아 23:11","category":"$undefined"},{"id":"6473","book":"여호수아","book_name":"여호수아","chapter":23,"verse":12,"text":"너희가 만일 퇴보하여 너희 중에 빠져 남아 있는 이 민족들을 친근히 하여 더불어 혼인하며 피차 왕래하면","reference":"여호수아 23:12","category":"$undefined"},{"id":"6474","book":"여호수아","book_name":"여호수아","chapter":23,"verse":13,"text":"정녕히 알라 너희 하나님 여호와께서 이 민족들을 너희 목전에서 다시는 쫓아내지 아니하시리니 그들이 너희에게 올무가 되며 덫이 되며 너희 옆구리에 채찍이 되며 너희 눈에 가시가 되어서 너희가 필경은 너희 하나님 여호와께서 너희에게 주신 이 아름다운 땅에서 멸절하리라","reference":"여호수아 23:13","category":"$undefined"},{"id":"6475","book":"여호수아","book_name":"여호수아","chapter":23,"verse":14,"text":"보라, 나는 오늘날 온 세상이 가는 길로 가려니와 너희 하나님 여호와께서 너희에게 대하여 말씀하신 모든 선한 일이 하나도 틀리지 아니하고 다 너희에게 응하여 그 중에 하나도 어김이 없음을 너희 모든 사람의 마음과 뜻에 아는 바라","reference":"여호수아 23:14","category":"$undefined"},{"id":"6476","book":"여호수아","book_name":"여호수아","chapter":23,"verse":15,"text":"너희 하나님 여호와께서 너희에게 말씀하신 모든 선한 일이 너희에게 임한 것 같이 여호와께서 모든 불길한 일도 너희에게 임하게 하사 너희 하나님 여호와께서 너희에게 주신 이 아름다운 땅에서 너희를 멸절하기까지 하실 것이라","reference":"여호수아 23:15","category":"$undefined"},{"id":"6477","book":"여호수아","book_name":"여호수아","chapter":23,"verse":16,"text":"만일 너희가 너희 하나님 여호와께서 너희에게 명하신 언약을 범하고 가서 다른 신들을 섬겨 그에게 절하면 여호와의 진노가 너희에게 미치리니 너희에게 주신 아름다운 땅에서 너희가 속히 망하리라'","reference":"여호수아 23:16","category":"$undefined"}],"bookSlug":"joshua"}]
