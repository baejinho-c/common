2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":24,"verses":[{"id":"6478","book":"여호수아","book_name":"여호수아","chapter":24,"verse":1,"text":"여호수아가 이스라엘 모든 지파를 세겜에 모으고 이스라엘 장로들과 그 두령들과 재판장들과 유사들을 부르매 그들이 하나님 앞에 보인지라","reference":"여호수아 24:1","category":"$undefined"},{"id":"6479","book":"여호수아","book_name":"여호수아","chapter":24,"verse":2,"text":"여호수아가 모든 백성에게 이르되 `이스라엘 하나님 여호와의 말씀에 옛적에 너희 조상들 곧 아브라함의 아비,나홀의 아비 데라가 강 저편에 거하여 다른 신들을 섬겼으나","reference":"여호수아 24:2","category":"$undefined"},{"id":"6480","book":"여호수아","book_name":"여호수아","chapter":24,"verse":3,"text":"내가 너희 조상 아브라함을 강 저편에서 이끌어내어 가나안으로 인도하여 온 땅을 두루 행하게 하고 그 씨를 번성케 하려고 그에게 이삭을 주었고","reference":"여호수아 24:3","category":"$undefined"},{"id":"6481","book":"여호수아","book_name":"여호수아","chapter":24,"verse":4,"text":"이삭에게는 야곱과 에서를 주었으며 에서에게는 세일산을 소유로 주었으나 야곱과 그 자손들은 애굽으로 내려갔으므로","reference":"여호수아 24:4","category":"$undefined"},{"id":"6482","book":"여호수아","book_name":"여호수아","chapter":24,"verse":5,"text":"내가 모세와 아론을 보내었고 또 애굽에 재앙을 내렸나니 곧 내가 그 가운데 행한 것과 같고 그 후에 너희를 인도하여 내었었노라","reference":"여호수아 24:5","category":"$undefined"},{"id":"6483","book":"여호수아","book_name":"여호수아","chapter":24,"verse":6,"text":"내가 너희 열조를 애굽에서 인도하여 내어 바다에 이르게 한즉 애굽 사람이 병거와 마병을 거느리고 너희 열조를 홍해까지 따르므로","reference":"여호수아 24:6","category":"$undefined"},{"id":"6484","book":"여호수아","book_name":"여호수아","chapter":24,"verse":7,"text":"너희 열조가 나 여호와께 부르짖기로 내가 너희와 애굽 사람 사이에 흑암을 두고 바다를 이끌어 그들을 덮었었나니 내가 애굽에서 행한 일을 너희가 목도하였으며 또 너희가 여러 날을 광야에 거하였었느니라","reference":"여호수아 24:7","category":"$undefined"},{"id":"6485","book":"여호수아","book_name":"여호수아","chapter":24,"verse":8,"text":"내가 또 너희를 인도하여 요단 저편에 거하는 아모리 사람의 땅으로 들어가게 하매 그들이 너희와 싸우기로 내가 그들을 너희 손에 붙이매 너희가 그 땅을 점령하였고 나는 그들을 너희 앞에서 멸절시켰으며","reference":"여호수아 24:8","category":"$undefined"},{"id":"6486","book":"여호수아","book_name":"여호수아","chapter":24,"verse":9,"text":"때에 모압 왕 십볼의 아들 발락이 일어나 이스라엘을 대적하여 사람을 보내어 브올의 아들 발람을 불러다가 너희를 저주케 하려 하였으나","reference":"여호수아 24:9","category":"$undefined"},{"id":"6487","book":"여호수아","book_name":"여호수아","chapter":24,"verse":10,"text":"내가 발람을 듣기를 원치 아니한 고로 그가 오히려 너희에게 축복하였고 나는 너희를 그 손에서 건져 내었으며","reference":"여호수아 24:10","category":"$undefined"},{"id":"6488","book":"여호수아","book_name":"여호수아","chapter":24,"verse":11,"text":"너희가 요단을 건너 여리고에 이른즉 여리고 사람과, 아모리 사람과, 브리스 사람과, 가나안 사람과, 헷 사람과, 기르가스 사람과, 히위 사람과, 여부스 사람들이 너희와 싸우기로 내가 그들을 너희의 손에 붙였으며","reference":"여호수아 24:11","category":"$undefined"},{"id":"6489","book":"여호수아","book_name":"여호수아","chapter":24,"verse":12,"text":"내가 왕벌을 너희 앞에 보내어 그 아모리 사람의 두 왕을 너희 앞에서 쫓아내게 하였나니 너희 칼로나 너희 활로나 이같이 한 것이 아니며","reference":"여호수아 24:12","category":"$undefined"},{"id":"6490","book":"여호수아","book_name":"여호수아","chapter":24,"verse":13,"text":"내가 또 너희의 수고하지 아니한 땅과 너희가 건축지 아니한 성읍을 너희에게 주었더니 너희가 그 가운데 거하며 너희가 또 자기의 심지 아니한 포도원과 감람원의 과실을 먹는다 하셨느니라","reference":"여호수아 24:13","category":"$undefined"},{"id":"6491","book":"여호수아","book_name":"여호수아","chapter":24,"verse":14,"text":"그러므로 이제는 여호와를 경외하며 성실과 진정으로 그를 섬길 것이라 너희의 열조가 강 저편과 애굽에서 섬기던 신들을 제하여 버리고 여호와만 섬기라 !","reference":"여호수아 24:14","category":"$undefined"},{"id":"6492","book":"여호수아","book_name":"여호수아","chapter":24,"verse":15,"text":"만일 여호와를 섬기는 것이 너희에게 좋지 않게 보이거든 너희 열조가 강 저편에서 섬기던 신이든지 혹 너희의 거하는 땅 아모리 사람의 신이든지 너희 섬길 자를 오늘날 택하라 ! 오직 나와 내 집은 여호와를 섬기겠노라 !'","reference":"여호수아 24:15","category":"$undefined"},{"id":"6493","book":"여호수아","book_name":"여호수아","chapter":24,"verse":16,"text":"백성이 대답하여 가로되 `여호와를 버리고 다른 신들 섬기는 일을 우리가 결단코 하지 아니하오리니","reference":"여호수아 24:16","category":"$undefined"},{"id":"6494","book":"여호수아","book_name":"여호수아","chapter":24,"verse":17,"text":"이는 우리 하나님 여호와 그가 우리와 우리 열조를 인도하여 애굽 땅 종 되었던 집에서 나오게 하시고 우리 목전에서 그 큰 이적들을 행하시고 우리가 행한 모든 길에서, 우리의 지난 모든 백성 중에서 우리를 보호하셨음이며","reference":"여호수아 24:17","category":"$undefined"},{"id":"6495","book":"여호수아","book_name":"여호수아","chapter":24,"verse":18,"text":"여호와께서 또 모든 백성 곧 이 땅에 거하던 아모리 사람을 우리 앞에서 쫓아내셨음이라 그러므로 우리도 여호와를 섬기리니 그는 우리 하나님이심이니이다 !'","reference":"여호수아 24:18","category":"$undefined"},{"id":"6496","book":"여호수아","book_name":"여호수아","chapter":24,"verse":19,"text":"여호수아가 백성에게 이르되 `너희가 여호와를 능히 섬기지 못할 것은 그는 거룩하신 하나님이시요 ! 질투하는 하나님이시니 너희 허물과 죄를 사하지 아니하실 것임이라","reference":"여호수아 24:19","category":"$undefined"},{"id":"6497","book":"여호수아","book_name":"여호수아","chapter":24,"verse":20,"text":"만일 너희가 여호와를 버리고 이방 신들을 섬기면 너희에게 복을 내리신 후에라도 돌이켜 너희에게 화를 내리시고 너희를 멸하시리라'","reference":"여호수아 24:20","category":"$undefined"},{"id":"6498","book":"여호수아","book_name":"여호수아","chapter":24,"verse":21,"text":"백성이 여호수아에게 말하되 `아니니이다 ! 우리가 정녕 여호와를 섬기겠나이다 !'","reference":"여호수아 24:21","category":"$undefined"},{"id":"6499","book":"여호수아","book_name":"여호수아","chapter":24,"verse":22,"text":"여호수아가 백성에게 이르되 `너희가 여호와를 택하고 그를 섬기리라 하였으니 스스로 증인이 되었느니라' 그들이 가로되 `우리가 증인이 되었나이다'","reference":"여호수아 24:22","category":"$undefined"},{"id":"6500","book":"여호수아","book_name":"여호수아","chapter":24,"verse":23,"text":"여호수아가 가로되 `그러면 이제 너희 중에 있는 이방 신들을 제하여 버리고 너희 마음을 이스라엘의 하나님 여호와께로 향하라 !'","reference":"여호수아 24:23","category":"$undefined"},{"id":"6501","book":"여호수아","book_name":"여호수아","chapter":24,"verse":24,"text":"백성이 여호수아에게 말하되 `우리 하나님 여호와를 우리가 섬기고 그 목소리를 우리가 청종하리이다 !' 한지라","reference":"여호수아 24:24","category":"$undefined"},{"id":"6502","book":"여호수아","book_name":"여호수아","chapter":24,"verse":25,"text":"그 날에 여호수아가 세겜에서 백성으로 더불어 언약을 세우고 그들을 위하여 율례와 법도를 베풀었더라","reference":"여호수아 24:25","category":"$undefined"},{"id":"6503","book":"여호수아","book_name":"여호수아","chapter":24,"verse":26,"text":"여호수아가 이 모든 말씀을 하나님의 율법책에 기록하고 큰 돌을 취하여 거기 여호와의 성소 곁에 있는 상수리나무 아래 세우고","reference":"여호수아 24:26","category":"$undefined"},{"id":"6504","book":"여호수아","book_name":"여호수아","chapter":24,"verse":27,"text":"모든 백성에게 이르되 `보라, 이 돌이 우리에게 증거가 되리니 이는 여호와께서 우리에게 하신 모든 말씀을 이 돌이 들었음이라 그런즉 너희로 너희 하나님을 배반치 않게 하도록 이 돌이 증거가 되리라' 하고","reference":"여호수아 24:27","category":"$undefined"},{"id":"6505","book":"여호수아","book_name":"여호수아","chapter":24,"verse":28,"text":"백성을 보내어 각기 기업으로 돌아가게 하였더라","reference":"여호수아 24:28","category":"$undefined"},{"id":"6506","book":"여호수아","book_name":"여호수아","chapter":24,"verse":29,"text":"이 일 후에 여호와의 종 눈의 아들 여호수아가 일백 십세에 죽으매","reference":"여호수아 24:29","category":"$undefined"},{"id":"6507","book":"여호수아","book_name":"여호수아","chapter":24,"verse":30,"text":"무리가 그를 그의 기업의 경내 딤낫 세라에 장사하였으니 딤낫 세라는 에브라임 산지 가아스산 북이었더라","reference":"여호수아 24:30","category":"$undefined"},{"id":"6508","book":"여호수아","book_name":"여호수아","chapter":24,"verse":31,"text":"이스라엘이 여호수아의 사는 날 동안과 여호수아 뒤에 생존한 장로들 곧 여호와께서 이스라엘을 위하여 행하신 모든 일을 아는 자의 사는 날 동안 여호와를 섬겼더라","reference":"여호수아 24:31","category":"$undefined"},{"id":"6509","book":"여호수아","book_name":"여호수아","chapter":24,"verse":32,"text":"이스라엘 자손이 애굽에서 이끌어 낸 요셉의 뼈를 세겜에 장사하였으니 이 곳은 야곱이 세겜의 아비 하몰의 자손에게 금 일백개를 주고 산 땅이라 그것이 요셉 자손의 기업이 되었더라","reference":"여호수아 24:32","category":"$undefined"},{"id":"6510","book":"여호수아","book_name":"여호수아","chapter":24,"verse":33,"text":"아론의 아들 엘르아살도 죽으매 무리가 그를 그 아들 비느하스가 에브라임 산지에서 받은 산에 장사하였더라","reference":"여호수아 24:33","category":"$undefined"}],"bookSlug":"joshua"}]
