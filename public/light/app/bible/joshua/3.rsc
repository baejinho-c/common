2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":3,"verses":[{"id":"5895","book":"여호수아","book_name":"여호수아","chapter":3,"verse":1,"text":"여호수아가 아침에 일찌기 일어나서 이스라엘 사람들로 더불어 싯딤에서 떠나 요단에 이르러서는 건너지 아니하고 거기서 유숙하니라","reference":"여호수아 3:1","category":"$undefined"},{"id":"5896","book":"여호수아","book_name":"여호수아","chapter":3,"verse":2,"text":"삼일 후에 유사들이 진중으로 두루 다니며","reference":"여호수아 3:2","category":"$undefined"},{"id":"5897","book":"여호수아","book_name":"여호수아","chapter":3,"verse":3,"text":"백성에게 명하여 가로되 `너희는 레위 사람 제사장들이 너희 하나님 여호와의 언약궤 메는 것을 보거든 너희 곳을 떠나 그 뒤를 좇으라","reference":"여호수아 3:3","category":"$undefined"},{"id":"5898","book":"여호수아","book_name":"여호수아","chapter":3,"verse":4,"text":"그러나 너희와 그 사이 상거가 이천 규빗쯤 되게 하고 그것에 가까이 하지는 말라 그리하면 너희 행할 길을 알리니 너희가 이전에 이 길을 지나보지 못하였음이니라'","reference":"여호수아 3:4","category":"$undefined"},{"id":"5899","book":"여호수아","book_name":"여호수아","chapter":3,"verse":5,"text":"여호수아가 또 백성에게 이르되 `너희는 스스로 성결케 하라 ! 여호와께서 내일 너희 가운데 기사를 행하시리라'","reference":"여호수아 3:5","category":"$undefined"},{"id":"5900","book":"여호수아","book_name":"여호수아","chapter":3,"verse":6,"text":"여호수아가 또 제사장들에게 일러 가로되 `언약궤를 메고 백성 앞서 건너라' 하매 곧 언약궤를 메고 백성 앞서 나아가니라","reference":"여호수아 3:6","category":"$undefined"},{"id":"5901","book":"여호수아","book_name":"여호수아","chapter":3,"verse":7,"text":"여호와께서 여호수아에게 이르시되 내가 오늘부터 시작하여 너를 온 이스라엘의 목전에서 크게 하여 내가 모세와 함께 있던 것 같이 너와 함께 있는 것을 그들로 알게 하리라","reference":"여호수아 3:7","category":"$undefined"},{"id":"5902","book":"여호수아","book_name":"여호수아","chapter":3,"verse":8,"text":"너는 언약궤를 멘 제사장들에게 명하여 이르기를 너희가 요단 물가에 이르거든 요단에 들어서라 하라","reference":"여호수아 3:8","category":"$undefined"},{"id":"5903","book":"여호수아","book_name":"여호수아","chapter":3,"verse":9,"text":"여호수아가 이스라엘 자손에게 이르되 `이리 와서 너희 하나님 여호와의 말씀을 들으라' 하고","reference":"여호수아 3:9","category":"$undefined"},{"id":"5904","book":"여호수아","book_name":"여호수아","chapter":3,"verse":10,"text":"또 말하되 `사시는 하나님이 너희 가운데 계시사 가나안 족속과, 헷 족속과, 히위 족속과, 브리스 족속과, 기르가스 족속과, 아모리 족속과, 여부스 족속을 너희 앞에서 정녕히 쫓아내실 줄을 이 일로 너희가 알리라","reference":"여호수아 3:10","category":"$undefined"},{"id":"5905","book":"여호수아","book_name":"여호수아","chapter":3,"verse":11,"text":"보라, 온 땅의 주의 언약궤가 너희 앞서 요단으로 들어가나니","reference":"여호수아 3:11","category":"$undefined"},{"id":"5906","book":"여호수아","book_name":"여호수아","chapter":3,"verse":12,"text":"이제 이스라엘 지파 중에서 매 지파에 한 사람씩 십 이명을 택하라","reference":"여호수아 3:12","category":"$undefined"},{"id":"5907","book":"여호수아","book_name":"여호수아","chapter":3,"verse":13,"text":"온 땅의 주 여호와의 궤를 멘 제사장들의 발바닥이 요단 물을 밟고 멈추면 요단 물 곧 위에서부터 흘러 내리던 물이 끊어지고 쌓여 서리라'","reference":"여호수아 3:13","category":"$undefined"},{"id":"5908","book":"여호수아","book_name":"여호수아","chapter":3,"verse":14,"text":"백성이 요단을 건너려고 자기들의 장막을 떠날때에 제사장들은 언약궤를 메고 백성 앞에서 행하니라","reference":"여호수아 3:14","category":"$undefined"},{"id":"5909","book":"여호수아","book_name":"여호수아","chapter":3,"verse":15,"text":"(요단이 모맥 거두는 시기에는 항상 언덕에 넘치더라) 궤를 멘 자들이 요단에 이르며 궤를 멘 제사장들의 발이 물가에 잠기자","reference":"여호수아 3:15","category":"$undefined"},{"id":"5910","book":"여호수아","book_name":"여호수아","chapter":3,"verse":16,"text":"곧 위에서부터 흘러 내리던 물이 그쳐서 심히 멀리 사르단에 가까운 아담 읍 변방에 일어나 쌓이고 아라바의 바다 염해로 향하여 흘러가는 물은 온전히 끊어지매 백성이 여리고 앞으로 바로 건널새","reference":"여호수아 3:16","category":"$undefined"},{"id":"5911","book":"여호수아","book_name":"여호수아","chapter":3,"verse":17,"text":"여호와의 언약궤를 멘 제사장들은 요단 가운데 마른 땅에 굳게 섰고 온 이스라엘 백성은 마른 땅으로 행하여 요단을 건너니라","reference":"여호수아 3:17","category":"$undefined"}],"bookSlug":"joshua"}]
