2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":4,"verses":[{"id":"5912","book":"여호수아","book_name":"여호수아","chapter":4,"verse":1,"text":"온 백성이 요단 건너기를 마치매 여호와께서 여호수아에게 일러 가라사대","reference":"여호수아 4:1","category":"$undefined"},{"id":"5913","book":"여호수아","book_name":"여호수아","chapter":4,"verse":2,"text":"백성의 매 지파에 한 사람씩 열 두 사람을 택하고","reference":"여호수아 4:2","category":"$undefined"},{"id":"5914","book":"여호수아","book_name":"여호수아","chapter":4,"verse":3,"text":"그들에게 명하여 이르기를 요단 가운데 제사장들의 발이 굳게 선 그곳에서 돌 열 둘을 취하고 그것을 가져다가 오늘밤 너희의 유숙할 그 곳에 두라 하라","reference":"여호수아 4:3","category":"$undefined"},{"id":"5915","book":"여호수아","book_name":"여호수아","chapter":4,"verse":4,"text":"여호수아가 이스라엘 자손 중에서 매 지파에 한 사람씩 예비한 그 열 두 사람을 불러서","reference":"여호수아 4:4","category":"$undefined"},{"id":"5916","book":"여호수아","book_name":"여호수아","chapter":4,"verse":5,"text":"그들에게 이르되 `요단 가운데 너희 하나님 여호와의 궤 앞으로 들어가서 이스라엘 자손들의 지파 수대로 각기 돌 한개씩 취하여 어깨에 메라","reference":"여호수아 4:5","category":"$undefined"},{"id":"5917","book":"여호수아","book_name":"여호수아","chapter":4,"verse":6,"text":"이것이 너희 중에 표징이 되리라 후일에 너희 자손이 물어 가로되 이 돌들은 무슨 뜻이뇨 ? 하거든","reference":"여호수아 4:6","category":"$undefined"},{"id":"5918","book":"여호수아","book_name":"여호수아","chapter":4,"verse":7,"text":"그들에게 이르기를 요단 물이 여호와의 언약궤 앞에서 끊어졌었나니 곧 언약궤가 요단을 건널 때에 요단 물이 끊어졌으므로 이 돌들이 이스라엘 자손에게 영영한 기념이 되리라' 하라","reference":"여호수아 4:7","category":"$undefined"},{"id":"5919","book":"여호수아","book_name":"여호수아","chapter":4,"verse":8,"text":"이스라엘 자손들이 여호수아의 명한 대로 행하되 여호와께서 여호수아에게 이르신 대로 이스라엘 자손들의 지파 수를 따라 요단 가운데서 돌 열 둘을 취하여 자기들의 유숙할 곳으로 가져다가 거기 두었더라","reference":"여호수아 4:8","category":"$undefined"},{"id":"5920","book":"여호수아","book_name":"여호수아","chapter":4,"verse":9,"text":"여호수아가 또 요단 가운데 곧 언약궤를 멘 제사장들의 발이 선곳에 돌 열 둘을 세웠더니 오늘까지 거기 있더라","reference":"여호수아 4:9","category":"$undefined"},{"id":"5921","book":"여호수아","book_name":"여호수아","chapter":4,"verse":10,"text":"궤를 멘 제사장들이 여호와께서 여호수아에게 명하사 백성에게 이르게 하신 일 곧 모세가 여호수아에게 명한 일이 다 마치기까지 요단 가운데 섰고 백성은 속히 건넜으며","reference":"여호수아 4:10","category":"$undefined"},{"id":"5922","book":"여호수아","book_name":"여호수아","chapter":4,"verse":11,"text":"모든 백성이 건너기를 마친 후에 여호와의 궤와 제사장들이 백성의 목전에서 건넜으며","reference":"여호수아 4:11","category":"$undefined"},{"id":"5923","book":"여호수아","book_name":"여호수아","chapter":4,"verse":12,"text":"르우벤 자손과 갓 자손과 므낫세 반 지파는 모세가 그들에게 이른 것 같이 무장하고 이스라엘 자손들보다 앞서 건너갔으니","reference":"여호수아 4:12","category":"$undefined"},{"id":"5924","book":"여호수아","book_name":"여호수아","chapter":4,"verse":13,"text":"사만명 가량이라 무장하고 여호와 앞에서 건너가서 싸우려고 여리고 평지에 이르니라","reference":"여호수아 4:13","category":"$undefined"},{"id":"5925","book":"여호수아","book_name":"여호수아","chapter":4,"verse":14,"text":"그 날에 여호와께서 모든 이스라엘의 목전에서 여호수아를 크게 하시매 그의 생존한 날 동안에 백성이 두려워하기를 모세를 두려워하던 것같이 하였더라","reference":"여호수아 4:14","category":"$undefined"},{"id":"5926","book":"여호수아","book_name":"여호수아","chapter":4,"verse":15,"text":"여호와께서 여호수아에게 일러 가라사대","reference":"여호수아 4:15","category":"$undefined"},{"id":"5927","book":"여호수아","book_name":"여호수아","chapter":4,"verse":16,"text":"증거궤를 멘 제사장들을 명하여 요단에서 올라오게 하라 하신지라","reference":"여호수아 4:16","category":"$undefined"},{"id":"5928","book":"여호수아","book_name":"여호수아","chapter":4,"verse":17,"text":"여호수아가 제사장들에게 명하여 `요단에서 올라오라' 하매","reference":"여호수아 4:17","category":"$undefined"},{"id":"5929","book":"여호수아","book_name":"여호수아","chapter":4,"verse":18,"text":"여호와의 언약궤를 멘 제사장들이 요단 가운데서 나오며 그 발바닥으로 육지를 밟는 동시에 요단 물이 본 곳으로 도로 흘러 여전히 언덕에 넘쳤더라","reference":"여호수아 4:18","category":"$undefined"},{"id":"5930","book":"여호수아","book_name":"여호수아","chapter":4,"verse":19,"text":"정월 십일에 백성이 요단에서 올라와서 여리고 동편 지경 길갈에 진 치매","reference":"여호수아 4:19","category":"$undefined"},{"id":"5931","book":"여호수아","book_name":"여호수아","chapter":4,"verse":20,"text":"여호수아가 그 요단에서 가져온 열 두 돌을 길갈에 세우고","reference":"여호수아 4:20","category":"$undefined"},{"id":"5932","book":"여호수아","book_name":"여호수아","chapter":4,"verse":21,"text":"이스라엘 자손들에게 일러 가로되 `후일에 너희 자손이 그 아비에게 묻기를 이 돌은 무슨 뜻이냐 ? 하거든","reference":"여호수아 4:21","category":"$undefined"},{"id":"5933","book":"여호수아","book_name":"여호수아","chapter":4,"verse":22,"text":"너희는 자손에게 알게 하여 이르기를 이스라엘이 마른 땅을 밟고 이 요단을 건넜음이라","reference":"여호수아 4:22","category":"$undefined"},{"id":"5934","book":"여호수아","book_name":"여호수아","chapter":4,"verse":23,"text":"너희 하나님 여호와께서 요단 물을 너희 앞에 마르게 하사 너희로 건너게 하신 것이 너희 하나님 여호와께서 우리 앞에 홍해를 말리시고 우리로 건너게 하심과 같았나니","reference":"여호수아 4:23","category":"$undefined"},{"id":"5935","book":"여호수아","book_name":"여호수아","chapter":4,"verse":24,"text":"이는 땅의 모든 백성으로 여호와의 손이 능하심을 알게 하며 너희로 너희 하나님 여호와를 영원토록 경외하게 하려 하심이라' 하라","reference":"여호수아 4:24","category":"$undefined"}],"bookSlug":"joshua"}]
