2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":5,"verses":[{"id":"5936","book":"여호수아","book_name":"여호수아","chapter":5,"verse":1,"text":"요단 서편의 아모리 사람의 모든 왕과 해변의 가나안 사람의 모든 왕이 여호와께서 요단 물을 이스라엘 자손들 앞에서 말리시고 우리를 건네셨음을 듣고 마음이 녹았고 이스라엘 자손들의 연고로 정신을 잃었더라","reference":"여호수아 5:1","category":"$undefined"},{"id":"5937","book":"여호수아","book_name":"여호수아","chapter":5,"verse":2,"text":"그 때에 여호와께서 여호수아에게 이르시되 너는 부싯돌로 칼을 만들어 이스라엘 자손들에게 다시 할례를 행하라 ! 하시매","reference":"여호수아 5:2","category":"$undefined"},{"id":"5938","book":"여호수아","book_name":"여호수아","chapter":5,"verse":3,"text":"여호수아가 부싯돌로 칼을 만들어 할례산에서 이스라엘 자손들에게 할례를 행하니라","reference":"여호수아 5:3","category":"$undefined"},{"id":"5939","book":"여호수아","book_name":"여호수아","chapter":5,"verse":4,"text":"여호수아가 할례를 시행한 까닭은 이것이니 애굽에서 나온 모든 백성 중 남자 곧 모든 군사는 애굽에서 나온 후 광야 노중에서 죽었는데","reference":"여호수아 5:4","category":"$undefined"},{"id":"5940","book":"여호수아","book_name":"여호수아","chapter":5,"verse":5,"text":"그 나온 백성은 다 할례를 받았으나 오직 애굽에서 나온 후 광야 노중에서 난 자는 할례를 받지 못하였음이라","reference":"여호수아 5:5","category":"$undefined"},{"id":"5941","book":"여호수아","book_name":"여호수아","chapter":5,"verse":6,"text":"이스라엘 자손들이 여호와의 말씀을 청종치 아니하므로 여호와께서 그들에게 대하여 맹세하사 그들의 열조에게 맹세하여 우리에게 주마 하신 땅 곧 젖과 꿀이 흐르는 땅을 그들로 보지 못하게 하리라 하시매 애굽에서 나온 족속 곧 군사들이 다 멸절하기까지 사십년 동안을 광야에 행하였더니","reference":"여호수아 5:6","category":"$undefined"},{"id":"5942","book":"여호수아","book_name":"여호수아","chapter":5,"verse":7,"text":"그들의 대를 잇게 하신 이 자손에게 여호수아가 할례를 행하였으니 길에서는 그들에게 할례를 행치 못하였으므로 할례 없는 자가 되었음이었더라","reference":"여호수아 5:7","category":"$undefined"},{"id":"5943","book":"여호수아","book_name":"여호수아","chapter":5,"verse":8,"text":"온 백성에게 할례 행하기를 필하매 백성이 진중 각 처소에 처하여 낫기를 기다릴 때에","reference":"여호수아 5:8","category":"$undefined"},{"id":"5944","book":"여호수아","book_name":"여호수아","chapter":5,"verse":9,"text":"여호와께서 여호수아에게 이르시되 내가 오늘날 애굽의 수치를 너희에게서 굴러가게 하였다 하셨으므로 그곳 이름을 오늘까지 길갈이라 하느니라","reference":"여호수아 5:9","category":"$undefined"},{"id":"5945","book":"여호수아","book_name":"여호수아","chapter":5,"verse":10,"text":"이스라엘 자손들이 길갈에 진 쳤고 그 달 십 사일 저녁에는 여리고 평지에서 유월절을 지켰고","reference":"여호수아 5:10","category":"$undefined"},{"id":"5946","book":"여호수아","book_name":"여호수아","chapter":5,"verse":11,"text":"유월절 이튿날에 그 땅 소산을 먹되 그 날에 무교병과 볶은 곡식을 먹었더니","reference":"여호수아 5:11","category":"$undefined"},{"id":"5947","book":"여호수아","book_name":"여호수아","chapter":5,"verse":12,"text":"그 땅 소산을 먹은 다음 날에 만나가 그쳤으니 이스라엘 사람들이 다시는 만나를 얻지 못하였고 그 해에 가나안 땅의 열매를 먹었더라","reference":"여호수아 5:12","category":"$undefined"},{"id":"5948","book":"여호수아","book_name":"여호수아","chapter":5,"verse":13,"text":"여호수아가 여리고에 가까왔을 때에 눈을 들어 본즉 한 사람이 칼을 빼어 손에 들고 마주 섰는지라 여호수아가 나아가서 그에게 묻되 '너는 우리를 위하느냐 ? 우리의 대적을 위하느냐 ?'","reference":"여호수아 5:13","category":"$undefined"},{"id":"5949","book":"여호수아","book_name":"여호수아","chapter":5,"verse":14,"text":"그가 가로되 `아니라 나는 여호와의 군대 장관으로 이제 왔느니라' 여호수아가 땅에 엎드려 절하고 가로되 '나의 주여 ! 종에게 무슨 말씀을 하려 하시나이까 ?'","reference":"여호수아 5:14","category":"$undefined"},{"id":"5950","book":"여호수아","book_name":"여호수아","chapter":5,"verse":15,"text":"여호와의 군대 장관이 여호수아에게 이르되 `네 발에서 신을 벗으라 ! 네가 선 곳은 거룩하니라' 여호수아가 그대로 행하니라","reference":"여호수아 5:15","category":"$undefined"}],"bookSlug":"joshua"}]
