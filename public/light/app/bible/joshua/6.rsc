2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":6,"verses":[{"id":"5951","book":"여호수아","book_name":"여호수아","chapter":6,"verse":1,"text":"이스라엘 자손들로 인하여 여리고는 굳게 닫혔고 출입하는 자 없더라","reference":"여호수아 6:1","category":"$undefined"},{"id":"5952","book":"여호수아","book_name":"여호수아","chapter":6,"verse":2,"text":"여호와께서 여호수아에게 이르시되 보라, 내가 여리고와 그 왕과 용사들을 네 손에 붙였으니","reference":"여호수아 6:2","category":"$undefined"},{"id":"5953","book":"여호수아","book_name":"여호수아","chapter":6,"verse":3,"text":"너희 모든 군사는 성을 둘러 성 주위를 매일 한번씩 돌되 엿새 동안을 그리하라","reference":"여호수아 6:3","category":"$undefined"},{"id":"5954","book":"여호수아","book_name":"여호수아","chapter":6,"verse":4,"text":"제사장 일곱은 일곱 양각나팔을 잡고 언약궤 앞에서 행할 것이요 제 칠일에는 성을 일곱번 돌며 제사장들은 나팔을 불 것이며","reference":"여호수아 6:4","category":"$undefined"},{"id":"5955","book":"여호수아","book_name":"여호수아","chapter":6,"verse":5,"text":"제사장들이 양각나팔을 길게 울려 불어서 그 나팔 소리가 너희에게 들릴 때에는 백성은 다 큰 소리로 외쳐 부를 것이라 그리하면 그 성벽이 무너져 내리리니 백성은 각기 앞으로 올라갈지니라 하시매","reference":"여호수아 6:5","category":"$undefined"},{"id":"5956","book":"여호수아","book_name":"여호수아","chapter":6,"verse":6,"text":"눈의 아들 여호수아가 제사장들을 불러서 그들에게 이르되 너희는 언약궤를 메고 일곱 제사장은 일곱 양각 나팔을 잡고 여호와의 궤 앞에서 행하라 하고","reference":"여호수아 6:6","category":"$undefined"},{"id":"5957","book":"여호수아","book_name":"여호수아","chapter":6,"verse":7,"text":"또 백성에게 이르되 나아가서 성을 돌되 무장한 자들이 여호와의 궤 앞에 행할지니라","reference":"여호수아 6:7","category":"$undefined"},{"id":"5958","book":"여호수아","book_name":"여호수아","chapter":6,"verse":8,"text":"여호수아가 백성에게 이르기를 마치매 제사장 일곱이 일곱 양각 나팔을 잡고 여호와 앞에서 진행하며 나팔을 불고 여호와의 언약궤는 그 뒤를 따르며","reference":"여호수아 6:8","category":"$undefined"},{"id":"5959","book":"여호수아","book_name":"여호수아","chapter":6,"verse":9,"text":"무장한 자들은 나팔 부는 제사장들 앞에서 진행하며 후군은 궤 뒤에 행하고 제사장들은 나팔을 불며 행하더라","reference":"여호수아 6:9","category":"$undefined"},{"id":"5960","book":"여호수아","book_name":"여호수아","chapter":6,"verse":10,"text":"여호수아가 백성에게 명하여 가로되 `너희는 외치지 말며 너희 음성을 들레지 말며 너희 입에서 아무 말도 내지 말라 그리하다가 내가 너희에게 명하여 외치라 하는 날에 외칠지니라' 하고","reference":"여호수아 6:10","category":"$undefined"},{"id":"5961","book":"여호수아","book_name":"여호수아","chapter":6,"verse":11,"text":"여호와의 궤로 성을 한번 돌게 하니라 무리가 진에 돌아와서 진에서 자니라","reference":"여호수아 6:11","category":"$undefined"},{"id":"5962","book":"여호수아","book_name":"여호수아","chapter":6,"verse":12,"text":"여호수아가 아침에 일찌기 일어나니라 제사장들이 여호와의 궤를 메고","reference":"여호수아 6:12","category":"$undefined"},{"id":"5963","book":"여호수아","book_name":"여호수아","chapter":6,"verse":13,"text":"일곱 제사장은 일곱 양각 나팔을 잡고 여호와의 궤 앞에서 계속 진행하며 나팔을 불고 무장한 자들은 그 앞에 행하며 후군은 여호와의 궤 뒤에 행하고 제사장들은 나팔을 불며 행하니라","reference":"여호수아 6:13","category":"$undefined"},{"id":"5964","book":"여호수아","book_name":"여호수아","chapter":6,"verse":14,"text":"그 제 이일에도 성을 한번 돌고 진에 돌아오니라 엿새 동안을 이같이 행하니라","reference":"여호수아 6:14","category":"$undefined"},{"id":"5965","book":"여호수아","book_name":"여호수아","chapter":6,"verse":15,"text":"제 칠일 새벽에 그들이 일찌기 일어나서 여전한 방식으로 성을 일곱번 도니 성을 일곱번 돌기는 그날 뿐이었더라","reference":"여호수아 6:15","category":"$undefined"},{"id":"5966","book":"여호수아","book_name":"여호수아","chapter":6,"verse":16,"text":"일곱번째에 제사장들이 나팔을 불 때에 여호수아가 백성에게 이르되 `외치라 ! 여호와께서 너희에게 이 성을 주셨느니라 !","reference":"여호수아 6:16","category":"$undefined"},{"id":"5967","book":"여호수아","book_name":"여호수아","chapter":6,"verse":17,"text":"이 성과 그 가운데 모든 물건은 여호와께 바치니 기생 라합과 무릇 그 집에 동거하는 자는 살리라 ! 이는 그가 우리의 보낸 사자를 숨겼음이니라","reference":"여호수아 6:17","category":"$undefined"},{"id":"5968","book":"여호수아","book_name":"여호수아","chapter":6,"verse":18,"text":"너희는 바칠 물건을 스스로 삼가라 너희가 그것을 바친 후에 그 바친 어느 것이든지 취하면 이스라엘 진으로 바침이 되어 화를 당케 할까 두려워 하노라","reference":"여호수아 6:18","category":"$undefined"},{"id":"5969","book":"여호수아","book_name":"여호수아","chapter":6,"verse":19,"text":"은,금과 동철 기구들은 다 여호와께 구별될 것이니 그것을 여호와의 곳간에 들일지니라'","reference":"여호수아 6:19","category":"$undefined"},{"id":"5970","book":"여호수아","book_name":"여호수아","chapter":6,"verse":20,"text":"이에 백성은 외치고 제사장들은 나팔을 불매 백성이 나팔 소리를 듣는 동시에 크게 소리질러 외치니 성벽이 무너져 내린지라 백성이 각기 앞으로 나아가 성에 들어가서 그 성을 취하고","reference":"여호수아 6:20","category":"$undefined"},{"id":"5971","book":"여호수아","book_name":"여호수아","chapter":6,"verse":21,"text":"성 중에 있는 것을 다 멸하되 남녀 노유와 우양과 나귀를 칼날로 멸하니라","reference":"여호수아 6:21","category":"$undefined"},{"id":"5972","book":"여호수아","book_name":"여호수아","chapter":6,"verse":22,"text":"여호수아가 그 땅을 정탐한 두 사람에게 이르되 `그 기생의 집에 들어 가서 너희가 그 여인에게 맹세한 대로 그와 그에게 속한 모든 것을 이끌어내라' 하매","reference":"여호수아 6:22","category":"$undefined"},{"id":"5973","book":"여호수아","book_name":"여호수아","chapter":6,"verse":23,"text":"정탐한 소년들이 들어가서 라합과 그 부모와 그 형제와 그에게 속한 모든 것을 이끌어 내고 또 그 친족도 다 이끌어 내어 그들을 이스라엘 진 밖에 두고","reference":"여호수아 6:23","category":"$undefined"},{"id":"5974","book":"여호수아","book_name":"여호수아","chapter":6,"verse":24,"text":"무리가 불로 성읍과 그 가운데 있는 모든 것을 사르고 은,금과 동철 기구는 여호와의 집 곳간에 두었더라","reference":"여호수아 6:24","category":"$undefined"},{"id":"5975","book":"여호수아","book_name":"여호수아","chapter":6,"verse":25,"text":"여호수아가 기생 라합과 그 아비의 가족과 그에게 속한 모든 것을 살렸으므로 그가 오늘날까지 이스라엘 중에 거하였으니 이는 여호수아가 여리고를 탐지하려고 보낸 사자를 숨겼음이었더라","reference":"여호수아 6:25","category":"$undefined"},{"id":"5976","book":"여호수아","book_name":"여호수아","chapter":6,"verse":26,"text":"여호수아가 그 때에 맹세로 무리를 경계하여 가로되 `이 여리고 성을 누구든지 일어나서 건축하는 자는 여호와 앞에서 저주를 받을 것이라 그 기초를 쌓을 때에 장자를 잃을 것이요 문을 세울 때에 계자를 잃으리라' 하였더라","reference":"여호수아 6:26","category":"$undefined"},{"id":"5977","book":"여호수아","book_name":"여호수아","chapter":6,"verse":27,"text":"여호와께서 여호수아와 함께 하시니 여호수아의 명성이 그 온 땅에 퍼지니라","reference":"여호수아 6:27","category":"$undefined"}],"bookSlug":"joshua"}]
