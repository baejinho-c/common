2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":7,"verses":[{"id":"5978","book":"여호수아","book_name":"여호수아","chapter":7,"verse":1,"text":"이스라엘 자손들이 바친 물건을 인하여 범죄하였으니 이는 유다 지파 세라의 증손 삽디의 손자 갈미의 아들 아간이 바친 물건을 취하였음이라 여호와께서 이스라엘 자손들에게 진노하시니라","reference":"여호수아 7:1","category":"$undefined"},{"id":"5979","book":"여호수아","book_name":"여호수아","chapter":7,"verse":2,"text":"여호수아가 여리고에서 사람을 벧엘 동편 벧아웬 곁에 있는 아이로 보내며 그들에게 일러 가로되 '올라가서 그 땅을 정탐하라' 하매 그 사람들이 올라가서 아이를 정탐하고","reference":"여호수아 7:2","category":"$undefined"},{"id":"5980","book":"여호수아","book_name":"여호수아","chapter":7,"verse":3,"text":"여호수아에게로 돌아와서 그에게 이르되 `백성을 다 올라가게 말고 이삼천명만 올라가서 아이를 치게 하소서 그들은 소수니 모든 백성을 그리로 보내어 수고롭게 마소서' 하므로","reference":"여호수아 7:3","category":"$undefined"},{"id":"5981","book":"여호수아","book_name":"여호수아","chapter":7,"verse":4,"text":"백성중 삼천명쯤 그리로 올라갔다가 아이 사람 앞에서 도망하니","reference":"여호수아 7:4","category":"$undefined"},{"id":"5982","book":"여호수아","book_name":"여호수아","chapter":7,"verse":5,"text":"아이 사람이 그들의 삼십 륙인쯤 죽이고 성문 앞에서부터 스바림까지 쫓아와서 내려가는 비탈에서 쳤으므로 백성의 마음이 녹아 물 같이 된지라","reference":"여호수아 7:5","category":"$undefined"},{"id":"5983","book":"여호수아","book_name":"여호수아","chapter":7,"verse":6,"text":"여호수아가 옷을 찢고 이스라엘 장로들과 함께 여호와의 궤 앞에서 땅에 엎드려 머리에 티끌을 무릅쓰고 저물도록 있다가","reference":"여호수아 7:6","category":"$undefined"},{"id":"5984","book":"여호수아","book_name":"여호수아","chapter":7,"verse":7,"text":"여호수아가 가로되 `슬프도소이다, 주 여호와여 ! 어찌하여 이 백성을 인도하여 요단을 건너게 하시고 우리를 아모리 사람의 손에 붙여 멸망시키려 하셨나이까 ? 우리가 요단 저 편을 족하게 여겨 거하였더면 좋을 뻔 하였나이다","reference":"여호수아 7:7","category":"$undefined"},{"id":"5985","book":"여호수아","book_name":"여호수아","chapter":7,"verse":8,"text":"주여 ! 이스라엘이 그 대적 앞에서 돌아섰으니 내가 무슨 말을 하오리이까 ?","reference":"여호수아 7:8","category":"$undefined"},{"id":"5986","book":"여호수아","book_name":"여호수아","chapter":7,"verse":9,"text":"가나안 사람과 이 땅 모든 거민이 이를 듣고 우리를 둘러싸고 우리 이름을 세상에서 끊으리니 주의 크신 이름을 위하여 어떻게 하시려나이까 ?'","reference":"여호수아 7:9","category":"$undefined"},{"id":"5987","book":"여호수아","book_name":"여호수아","chapter":7,"verse":10,"text":"여호와께서 여호수아에게 이르시되 일어나라 ! 어찌하여 이렇게 엎드렸느냐 ?","reference":"여호수아 7:10","category":"$undefined"},{"id":"5988","book":"여호수아","book_name":"여호수아","chapter":7,"verse":11,"text":"이스라엘이 범죄하여 내가 그들에게 명한 나의 언약을 어기었나니 곧 그들이 바친 물건을 취하고 도적하고 사기하여 자기 기구 가운데 두었느니라","reference":"여호수아 7:11","category":"$undefined"},{"id":"5989","book":"여호수아","book_name":"여호수아","chapter":7,"verse":12,"text":"그러므로 이스라엘 자손들이 자기 대적을 능히 당치 못하고 그 앞에서 돌아섰나니 이는 자기도 바친 것이 됨이라 그 바친 것을 너희 중에서 멸하지 아니하면 내가 다시는 너희와 함께 있지 아니하리라","reference":"여호수아 7:12","category":"$undefined"},{"id":"5990","book":"여호수아","book_name":"여호수아","chapter":7,"verse":13,"text":"너는 일어나서 백성을 성결케 하여 이르기를 너희는 스스로 성결케 하여 내일을 기다리라 이스라엘의 하나님 여호와의 말씀에 이스라엘아 ! 너의 중에 바친 물건이 있나니 네가 그 바친 물건을 너의 중에서 제하기 전에는 너의 대적을 당치 못하리라","reference":"여호수아 7:13","category":"$undefined"},{"id":"5991","book":"여호수아","book_name":"여호수아","chapter":7,"verse":14,"text":"아침에 너희는 너희 지파대로 가까이 나아오라 여호와께 뽑히는 지파는 그 족속대로 가까이 나아올 것이요 여호와께 뽑히는 족속은 그 가족대로 가까이 나아올 것이요 여호와께 뽑히는 가족은 각 남자대로 가까이 나아올 것이며","reference":"여호수아 7:14","category":"$undefined"},{"id":"5992","book":"여호수아","book_name":"여호수아","chapter":7,"verse":15,"text":"바친 물건을 가진 자로 뽑힌 자를 불사르되 그와 그 모든 소유를 그리하라 이는 여호와의 언약을 어기고 이스라엘 가운데서 망령 된 일을 행하였음이라 하셨다 하라","reference":"여호수아 7:15","category":"$undefined"},{"id":"5993","book":"여호수아","book_name":"여호수아","chapter":7,"verse":16,"text":"이에 여호수아가 아침 일찌기 일어나서 이스라엘을 그 지파대로 가까이 나아오게 하였더니 유다 지파가 뽑혔고","reference":"여호수아 7:16","category":"$undefined"},{"id":"5994","book":"여호수아","book_name":"여호수아","chapter":7,"verse":17,"text":"유다 족속을 가까이 나아오게 하였더니 세라 족속이 뽑혔고 세라족속의 각 남자를 가까이 나아오게 하였더니 삽디가 뽑혔고","reference":"여호수아 7:17","category":"$undefined"},{"id":"5995","book":"여호수아","book_name":"여호수아","chapter":7,"verse":18,"text":"삽디의 가족 각 남자를 가까이 나아오게 하였더니 유다 지파 세라의 증손이요 삽디의 손자요 갈미의 아들인 아간이 뽑혔더라","reference":"여호수아 7:18","category":"$undefined"},{"id":"5996","book":"여호수아","book_name":"여호수아","chapter":7,"verse":19,"text":"여호수아가 아간에게 이르되 `내 아들아 청하노라 이스라엘의 하나님 여호와께 영광을 돌려 그 앞에 자복하고 네 행한 일을 내게 고하라 그 일을 내게 숨기지 말라'","reference":"여호수아 7:19","category":"$undefined"},{"id":"5997","book":"여호수아","book_name":"여호수아","chapter":7,"verse":20,"text":"아간이 여호수아에게 대답하여 가로되 `참으로 나는 이스라엘 하나님 여호와께 범죄하여 여차 여차히 행하였나이다","reference":"여호수아 7:20","category":"$undefined"},{"id":"5998","book":"여호수아","book_name":"여호수아","chapter":7,"verse":21,"text":"내가 노략한 물건 중에 시날산의 아름다운 외투 한벌과 은 이백 세겔과 오십 세겔중의 금덩이 하나를 보고 탐내어 취하였나이다 보소서 ! 이제 그 물건들을 내 장막 가운데 땅 속에 감추었는데 은은 그 밑에 있나이다'","reference":"여호수아 7:21","category":"$undefined"},{"id":"5999","book":"여호수아","book_name":"여호수아","chapter":7,"verse":22,"text":"이에 여호수아가 사자를 보내매 그의 장막에 달려가 본즉 물건이 그의 장막 안에 감취었는데 은은 그 밑에 있는지라","reference":"여호수아 7:22","category":"$undefined"},{"id":"6000","book":"여호수아","book_name":"여호수아","chapter":7,"verse":23,"text":"그들이 그것을 장막 가운데서 취하여 여호수아와 이스라엘 모든 자손에게로 가져오매 그들이 그것을 여호와 앞에 놓으니라","reference":"여호수아 7:23","category":"$undefined"},{"id":"6001","book":"여호수아","book_name":"여호수아","chapter":7,"verse":24,"text":"여호수아가 이스라엘 모든 사람으로 더불어 세라의 아들 아간을 잡고 그 은과, 외투와, 금덩이와, 그 아들들과, 딸들과, 소들과, 나귀들과, 양들과, 장막과, 무릇 그에게 속한 모든 것을 이끌고 아골 골짜기로 가서","reference":"여호수아 7:24","category":"$undefined"},{"id":"6002","book":"여호수아","book_name":"여호수아","chapter":7,"verse":25,"text":"여호수아가 가로되 `네가 어찌하여 우리를 괴롭게 하였느뇨 ? 여호와께서 오늘날 너를 괴롭게 하시리라'하니 온 이스라엘이 그를 돌로 치고 그것들도 돌로 치고 불사르고","reference":"여호수아 7:25","category":"$undefined"},{"id":"6003","book":"여호수아","book_name":"여호수아","chapter":7,"verse":26,"text":"그 위에 돌 무더기를 크게 쌓았더니 오늘날까지 있더라 여호와께서 그 극렬한 분노를 그치시니 그러므로 그곳 이름을 오늘날까지 '아골 골짜기'라 부르더라","reference":"여호수아 7:26","category":"$undefined"}],"bookSlug":"joshua"}]
