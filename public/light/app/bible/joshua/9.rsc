2:["$","$L11",null,{"book":{"id":"joshua","name":"여호수아","chapters":24,"testament":"old"},"chapter":9,"verses":[{"id":"6039","book":"여호수아","book_name":"여호수아","chapter":9,"verse":1,"text":"요단 서편 산지와 평지와 레바논 앞 대 해변에 있는 헷 사람과, 아모리 사람과, 가나안 사람과, 브리스 사람과, 히위 사람과, 여부스 사람의 모든 왕이 이 일을 듣고","reference":"여호수아 9:1","category":"$undefined"},{"id":"6040","book":"여호수아","book_name":"여호수아","chapter":9,"verse":2,"text":"모여서 일심으로 여호수아와 이스라엘로 더불어 싸우려 하더라","reference":"여호수아 9:2","category":"$undefined"},{"id":"6041","book":"여호수아","book_name":"여호수아","chapter":9,"verse":3,"text":"기브온 거민들이 여호수아의 여리고와 아이에 행한 일을 듣고","reference":"여호수아 9:3","category":"$undefined"},{"id":"6042","book":"여호수아","book_name":"여호수아","chapter":9,"verse":4,"text":"꾀를 내어 사신의 모양을 꾸미되 해어진 전대와 해어지고 찢어져서 기운 가죽 포도주 부대를 나귀에 싣고","reference":"여호수아 9:4","category":"$undefined"},{"id":"6043","book":"여호수아","book_name":"여호수아","chapter":9,"verse":5,"text":"그 발에는 낡아 기운 신을 신고 낡은 옷을 입고 다 마르고 곰팡이 난 떡을 예비하고","reference":"여호수아 9:5","category":"$undefined"},{"id":"6044","book":"여호수아","book_name":"여호수아","chapter":9,"verse":6,"text":"그들이 길갈 진으로 와서 여호수아에게 이르러 그와 이스라엘 사람들에게 이르되 `우리는 원방에서 왔나이다 이제 우리와 약조하사이다'","reference":"여호수아 9:6","category":"$undefined"},{"id":"6045","book":"여호수아","book_name":"여호수아","chapter":9,"verse":7,"text":"이스라엘 사람들이 히위 사람들에게 이르되 `너희가 우리 중에 거하는 듯하니 우리가 어떻게 너희와 약조할 수 있으랴'","reference":"여호수아 9:7","category":"$undefined"},{"id":"6046","book":"여호수아","book_name":"여호수아","chapter":9,"verse":8,"text":"그들이 여호수아에게 이르되 `우리는 당신의 종이니이다' 여호수아가 그들에게 묻되 `너희는 누구며 어디서 왔느뇨 ?'","reference":"여호수아 9:8","category":"$undefined"},{"id":"6047","book":"여호수아","book_name":"여호수아","chapter":9,"verse":9,"text":"그들이 여호수아에게 대답하되 `종들은 당신의 하나님 여호와의 이름을 인하여 심히 먼 지방에서 왔사오니 이는 우리가 그의 명성과 그가 애굽에서 행하신 모든 일을 들으며","reference":"여호수아 9:9","category":"$undefined"},{"id":"6048","book":"여호수아","book_name":"여호수아","chapter":9,"verse":10,"text":"또 그가 요단 동편에 있는 아모리 사람의 두 왕 곧 헤스본 왕 시혼과 아스다롯에 있는 바산 왕 옥에게 행하신 모든 일을 들었음이니이다","reference":"여호수아 9:10","category":"$undefined"},{"id":"6049","book":"여호수아","book_name":"여호수아","chapter":9,"verse":11,"text":"그러므로 우리 장로들과 우리 나라의 모든 거민이 우리에게 일러 가로되 너희는 여행할 양식을 손에 가지고 가서 그들을 맞아서 그들에게 이르기를 우리는 당신들의 종이니 청컨대 이제 우리와 약조하사이다 하라 하였나이다","reference":"여호수아 9:11","category":"$undefined"},{"id":"6050","book":"여호수아","book_name":"여호수아","chapter":9,"verse":12,"text":"우리의 이 떡은 우리가 당신들에게로 오려고 떠나던 날에 우리들의 집에서 오히려 뜨거운 것을 양식으로 취하였더니 보소서 이제 말랐고 곰팡이 났으며","reference":"여호수아 9:12","category":"$undefined"},{"id":"6051","book":"여호수아","book_name":"여호수아","chapter":9,"verse":13,"text":"또 우리가 포도주를 담은 이 가죽 부대도 새 것이더니 찢어지게 되었으며 우리의 이 옷과 신도 여행이 심히 길므로 인하여 낡아졌나이다' 한지라","reference":"여호수아 9:13","category":"$undefined"},{"id":"6052","book":"여호수아","book_name":"여호수아","chapter":9,"verse":14,"text":"무리가 그들의 양식을 취하고 어떻게 할 것을 여호와께 묻지 아니하고","reference":"여호수아 9:14","category":"$undefined"},{"id":"6053","book":"여호수아","book_name":"여호수아","chapter":9,"verse":15,"text":"여호수아가 곧 그들과 화친하여 그들을 살리리라는 언약을 맺고 회중 족장들이 그들에게 맹세하였더라","reference":"여호수아 9:15","category":"$undefined"},{"id":"6054","book":"여호수아","book_name":"여호수아","chapter":9,"verse":16,"text":"그들과 언약을 맺은 후 삼일이 지나서야 그들은 근린에 있어 자기들 중에 거주하는 자라 함을 들으니라","reference":"여호수아 9:16","category":"$undefined"},{"id":"6055","book":"여호수아","book_name":"여호수아","chapter":9,"verse":17,"text":"이스라엘 자손이 진행하여 제 삼일에 그들의 여러 성읍에 이르렀으니 그 성읍은 기브온과, 그비라와, 브에롯과, 기럇여아림이라","reference":"여호수아 9:17","category":"$undefined"},{"id":"6056","book":"여호수아","book_name":"여호수아","chapter":9,"verse":18,"text":"그러나 회중 족장들이 이스라엘 하나님 여호와로 그들에게 맹세한 고로 이스라엘 자손이 그들을 치지 못한지라 그러므로 회중이 다 족장들을 원망하니","reference":"여호수아 9:18","category":"$undefined"},{"id":"6057","book":"여호수아","book_name":"여호수아","chapter":9,"verse":19,"text":"모든 족장이 온 회중에게 이르되 `우리가 이스라엘 하나님 여호와로 그들에게 맹세하였은즉 이제 그들을 건드리지 못하리라","reference":"여호수아 9:19","category":"$undefined"},{"id":"6058","book":"여호수아","book_name":"여호수아","chapter":9,"verse":20,"text":"우리가 그들에게 맹세한 맹약을 인하여 진노가 우리에게 임할까 하노니 이렇게 행하여 그들을 살리리라' 하고","reference":"여호수아 9:20","category":"$undefined"},{"id":"6059","book":"여호수아","book_name":"여호수아","chapter":9,"verse":21,"text":"무리에게 이르되 그들을 살리라 하니 족장들이 그들에게 이른대로 그들이 온 회중을 위하여 나무 패며 물 긷는 자가 되었더라","reference":"여호수아 9:21","category":"$undefined"},{"id":"6060","book":"여호수아","book_name":"여호수아","chapter":9,"verse":22,"text":"여호수아가 그들을 불러다가 일러 가로되 `너희가 우리 가운데 거주하거늘 어찌하여 우리는 너희에게서 심히 멀다 하여 우리를 속였느냐 ?","reference":"여호수아 9:22","category":"$undefined"},{"id":"6061","book":"여호수아","book_name":"여호수아","chapter":9,"verse":23,"text":"그러므로 너희가 저주를 받나니 너희가 영영히 종이 되어서 다 내 하나님의 집을 위하여 나무 패며 물 긷는 자가 되리라'","reference":"여호수아 9:23","category":"$undefined"},{"id":"6062","book":"여호수아","book_name":"여호수아","chapter":9,"verse":24,"text":"그들이 여호수아에게 대답하여 가로되 `당신의 하나님 여호와께서 그 종 모세에게 명하사 이 땅을 다 당신들에게 주고 이 땅 모든 거민을 당신들의 앞에서 멸하라 하신 것이 당신의 종에게 분명히 들리므로 당신들을 인하여 우리 생명을 잃을까 심히 두려워 하여 이같이 하였나이다","reference":"여호수아 9:24","category":"$undefined"},{"id":"6063","book":"여호수아","book_name":"여호수아","chapter":9,"verse":25,"text":"보소서 ! 이제 우리가 당신의 손에 있으니 당신의 의향에 좋고 옳은대로 우리에게 행하소서' 한지라","reference":"여호수아 9:25","category":"$undefined"},{"id":"6064","book":"여호수아","book_name":"여호수아","chapter":9,"verse":26,"text":"여호수아가 곧 그대로 그들에게 행하여 그들을 이스라엘 자손의 손에서 건져서 죽이지 못하게 하니라","reference":"여호수아 9:26","category":"$undefined"},{"id":"6065","book":"여호수아","book_name":"여호수아","chapter":9,"verse":27,"text":"그 날에 여호수아가 그들로 여호와의 택하신 곳에서 회중을 위하며 여호와의 단을 위하여 나무 패며 물 긷는 자를 삼았더니 오늘까지 이르니라","reference":"여호수아 9:27","category":"$undefined"}],"bookSlug":"joshua"}]
