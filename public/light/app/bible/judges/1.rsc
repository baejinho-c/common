2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":1,"verses":[{"id":"6511","book":"사사기","book_name":"사사기","chapter":1,"verse":1,"text":"여호수아가 죽은 후에 이스라엘 자손이 여호와께 묻자와 가로되 `우리 중 누가 먼저 올라가서 가나안 사람과 싸우리이까 ?'","reference":"사사기 1:1","category":"$undefined"},{"id":"6512","book":"사사기","book_name":"사사기","chapter":1,"verse":2,"text":"여호와께서 가라사대 유다가 올라갈지니라 보라 ! 내가 이 땅을 그 손에 붙였노라 하시니라","reference":"사사기 1:2","category":"$undefined"},{"id":"6513","book":"사사기","book_name":"사사기","chapter":1,"verse":3,"text":"유다가 그 형제 시므온에게 이르되 `나의 제비 뽑아 얻은 땅에 나와 함께 올라가서 가나안 사람과 싸우자 그리하면 나도 너의 제비 뽑아 얻은 땅에 함께 가리라' 이에 시므온이 그와 함께 가니라","reference":"사사기 1:3","category":"$undefined"},{"id":"6514","book":"사사기","book_name":"사사기","chapter":1,"verse":4,"text":"유다가 올라가매 여호와께서 가나안 사람과 브리스 사람을 그들의 손에 붙이신지라 그들이 베섹에서 일만명을 죽이고","reference":"사사기 1:4","category":"$undefined"},{"id":"6515","book":"사사기","book_name":"사사기","chapter":1,"verse":5,"text":"또 베섹에서 아도니 베섹을 만나서 그와 싸워 가나안 사람과 브리스 사람을 죽이니","reference":"사사기 1:5","category":"$undefined"},{"id":"6516","book":"사사기","book_name":"사사기","chapter":1,"verse":6,"text":"아도니 베섹이 도망하는지라 그를 쫓아가서 잡아 그 수족의 엄지 가락을 끊으매","reference":"사사기 1:6","category":"$undefined"},{"id":"6517","book":"사사기","book_name":"사사기","chapter":1,"verse":7,"text":"아도니 베섹이 가로되 `옛적에 칠십 왕이 그 수족의 엄지가락을 찍히고 내 상 아래서 먹을 것을 줍더니 하나님이 나의 행한 대로 내게 갚으심이로다' 하니라 무리가 그를 끌고 예루살렘에 이르렀더니 그가 거기서 죽었더라","reference":"사사기 1:7","category":"$undefined"},{"id":"6518","book":"사사기","book_name":"사사기","chapter":1,"verse":8,"text":"유다 자손이 예루살렘을 쳐서 취하여 칼날로 치고 성을 불살랐으며","reference":"사사기 1:8","category":"$undefined"},{"id":"6519","book":"사사기","book_name":"사사기","chapter":1,"verse":9,"text":"그 후에 유다 자손이 내려가서 산지와 남방과 평지에 거한 가나안 사람과 싸웠고","reference":"사사기 1:9","category":"$undefined"},{"id":"6520","book":"사사기","book_name":"사사기","chapter":1,"verse":10,"text":"유다가 또 가서 헤브론에 거한 가나안 사람을 쳐서 세새와 아히만과 달매를 죽였더라 헤브론의 본 이름은 기럇 아르바이었더라","reference":"사사기 1:10","category":"$undefined"},{"id":"6521","book":"사사기","book_name":"사사기","chapter":1,"verse":11,"text":"거기서 나아가서 드빌의 거민들을 쳤으니 드빌의 본 이름은 기럇세벨이라","reference":"사사기 1:11","category":"$undefined"},{"id":"6522","book":"사사기","book_name":"사사기","chapter":1,"verse":12,"text":"갈렙이 말하기를 `기럇 세벨을 쳐서 그것을 취하는 자에게는 내 딸 악사를 아내로 주리라' 하였더니","reference":"사사기 1:12","category":"$undefined"},{"id":"6523","book":"사사기","book_name":"사사기","chapter":1,"verse":13,"text":"갈렙의 아우요 그나스의 아들인 옷니엘이 그것을 취한 고로 갈렙이 그 딸 악사를 그에게 아내로 주었더라","reference":"사사기 1:13","category":"$undefined"},{"id":"6524","book":"사사기","book_name":"사사기","chapter":1,"verse":14,"text":"악사가 출가할 때에 그에게 청하여 `자기 아비에게 밭을 구하자' 하고 나귀에서 내리매 갈렙이 묻되 `네가 무엇을 원하느냐 ?'","reference":"사사기 1:14","category":"$undefined"},{"id":"6525","book":"사사기","book_name":"사사기","chapter":1,"verse":15,"text":"가로되 `내게 복을 주소서 ! 아버지께서 나를 남방으로 보내시니 샘물도 내게 주소서' 하매 갈렙이 윗샘과 아랫샘을 그에게 주었더라","reference":"사사기 1:15","category":"$undefined"},{"id":"6526","book":"사사기","book_name":"사사기","chapter":1,"verse":16,"text":"모세의 장인은 겐 사람이라 그 자손이 유다 자손과 함께 종려나무 성읍에서 올라가서 아랏 남방의 유다 황무지에 이르러 그 백성 중에 거하니라","reference":"사사기 1:16","category":"$undefined"},{"id":"6527","book":"사사기","book_name":"사사기","chapter":1,"verse":17,"text":"유다가 그 형제 시므온과 함께 가서 스밧에 거한 가나안 사람을 쳐서 그곳을 진멸하였으므로 그 성읍 이름을 호르마라 하니라","reference":"사사기 1:17","category":"$undefined"},{"id":"6528","book":"사사기","book_name":"사사기","chapter":1,"verse":18,"text":"유다가 또 가사와 그 경내와 아스글론과 그 경내와 에그론과 그 경내를 취하였고","reference":"사사기 1:18","category":"$undefined"},{"id":"6529","book":"사사기","book_name":"사사기","chapter":1,"verse":19,"text":"여호와께서 유다와 함께 하신 고로 그가 산지 거민을 쫓아내었으나 골짜기의 거민들은 철병거가 있으므로 그들을 쫓아내지 못하였으며","reference":"사사기 1:19","category":"$undefined"},{"id":"6530","book":"사사기","book_name":"사사기","chapter":1,"verse":20,"text":"무리가 모세의 명한 대로 헤브론을 갈렙에게 주었더니 그가 거기서 아낙의 세 아들을 쫓아내었고","reference":"사사기 1:20","category":"$undefined"},{"id":"6531","book":"사사기","book_name":"사사기","chapter":1,"verse":21,"text":"베냐민 자손은 예루살렘에 거한 여부스 사람을 쫓아내지 못하였으므로 여부스 사람이 베냐민 자손과 함께 오늘날까지 예루살렘에 거하더라","reference":"사사기 1:21","category":"$undefined"},{"id":"6532","book":"사사기","book_name":"사사기","chapter":1,"verse":22,"text":"요셉 족속도 벧엘을 치러 올라가니 여호와께서 그와 함께 하시니라","reference":"사사기 1:22","category":"$undefined"},{"id":"6533","book":"사사기","book_name":"사사기","chapter":1,"verse":23,"text":"요셉 족속이 벧엘을 정탐케 하였는데 그 성읍의 본 이름은 루스라","reference":"사사기 1:23","category":"$undefined"},{"id":"6534","book":"사사기","book_name":"사사기","chapter":1,"verse":24,"text":"탐정이 그 성읍에서 한 사람의 나오는 것을 보고 그에게 이르되 청하노니 이 성읍의 입구를 우리에게 가르치라 그리하면 너를 선대하리라 하매","reference":"사사기 1:24","category":"$undefined"},{"id":"6535","book":"사사기","book_name":"사사기","chapter":1,"verse":25,"text":"그 사람이 성읍의 입구를 가르친지라 이에 칼날로 그 성읍을 쳤으되 오직 그 사람과 그 가족을 놓아 보내매","reference":"사사기 1:25","category":"$undefined"},{"id":"6536","book":"사사기","book_name":"사사기","chapter":1,"verse":26,"text":"그 사람이 헷 사람의 땅에 가서 성읍을 건축하고 그 이름을 루스라 하였더니 오늘날까지 그 곳의 이름이더라","reference":"사사기 1:26","category":"$undefined"},{"id":"6537","book":"사사기","book_name":"사사기","chapter":1,"verse":27,"text":"므낫세가 벧스안과, 그 향리의 거민과, 다아낙과, 그 향리의 거민과, 돌과, 그 향리의 거민과, 이블르암과, 그 향리의 거민과, 므깃도와, 그 향리의 거민들을 쫓아내지 못하매 가나안 사람이 결심하고 그 땅에 거하였더니","reference":"사사기 1:27","category":"$undefined"},{"id":"6538","book":"사사기","book_name":"사사기","chapter":1,"verse":28,"text":"이스라엘이 강성한 후에야 가나안 사람에게 사역을 시켰고 다 쫓아내지 아니하였더라","reference":"사사기 1:28","category":"$undefined"},{"id":"6539","book":"사사기","book_name":"사사기","chapter":1,"verse":29,"text":"에브라임이 게셀에 거한 가나안 사람을 쫓아내지 못하매 가나안 사람이 게셀에서 그들 중에 거하였더라","reference":"사사기 1:29","category":"$undefined"},{"id":"6540","book":"사사기","book_name":"사사기","chapter":1,"verse":30,"text":"스불론은 기드론 거민과 나할롤 거민을 쫓아내지 못하였으나 가나안 사람이 그들 중에 거하여 사역을 하였더라","reference":"사사기 1:30","category":"$undefined"},{"id":"6541","book":"사사기","book_name":"사사기","chapter":1,"verse":31,"text":"아셀이 악고 거민과, 시돈 거민과, 알랍과, 악십과, 헬바와, 아빅과, 르홉 거민을 쫓아내지 못하고","reference":"사사기 1:31","category":"$undefined"},{"id":"6542","book":"사사기","book_name":"사사기","chapter":1,"verse":32,"text":"그 땅 거민 가나안 사람 가운데 거하였으니 이는 쫓아내지 못함이었더라","reference":"사사기 1:32","category":"$undefined"},{"id":"6543","book":"사사기","book_name":"사사기","chapter":1,"verse":33,"text":"납달리가 벧세메스 거민과 벧아낫 거민을 쫓아내지 못하고 그 땅 거민 가나안 사람 가운데 거하였으나 벧세메스와 벧아낫 거민들이 그들에게 사역을 하였더라","reference":"사사기 1:33","category":"$undefined"},{"id":"6544","book":"사사기","book_name":"사사기","chapter":1,"verse":34,"text":"아모리 사람이 단 자손을 산지로 쫓아들이고 골짜기에 내려오기를 용납지 아니하고","reference":"사사기 1:34","category":"$undefined"},{"id":"6545","book":"사사기","book_name":"사사기","chapter":1,"verse":35,"text":"결심하고 헤레스 산과 아얄론과 사알빔에 거하였더니 요셉 족속이 강성하매 아모리 사람이 필경은 사역을 하였으며","reference":"사사기 1:35","category":"$undefined"},{"id":"6546","book":"사사기","book_name":"사사기","chapter":1,"verse":36,"text":"아모리 사람의 지계는 아그랍빔 비탈의 바위부터 그 위였더라","reference":"사사기 1:36","category":"$undefined"}],"bookSlug":"judges"}]
