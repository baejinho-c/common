2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":10,"verses":[{"id":"6813","book":"사사기","book_name":"사사기","chapter":10,"verse":1,"text":"아비멜렉의 후에 잇사갈 사람 도도의 손자 부아의 아들 돌라가 일어나서 이스라엘을 구원하니라 그가 에브라임 산지 사밀에 거하여","reference":"사사기 10:1","category":"$undefined"},{"id":"6814","book":"사사기","book_name":"사사기","chapter":10,"verse":2,"text":"이스라엘의 사사가 된지 이십 삼년만에 죽으매 사밀에 장사되었더라","reference":"사사기 10:2","category":"$undefined"},{"id":"6815","book":"사사기","book_name":"사사기","chapter":10,"verse":3,"text":"그 후에 길르앗 사람 야일이 일어나서 이십 이년 동안 이스라엘의 사사가 되니라","reference":"사사기 10:3","category":"$undefined"},{"id":"6816","book":"사사기","book_name":"사사기","chapter":10,"verse":4,"text":"그에게 아들 삼십이 있어 어린 나귀 삼십을 탔고 성읍 삼십을 두었었는데 그 성들은 길르앗 땅에 있고 오늘까지 하봇야일이라 칭하더라","reference":"사사기 10:4","category":"$undefined"},{"id":"6817","book":"사사기","book_name":"사사기","chapter":10,"verse":5,"text":"야일이 죽으매 가몬에 장사되었더라","reference":"사사기 10:5","category":"$undefined"},{"id":"6818","book":"사사기","book_name":"사사기","chapter":10,"verse":6,"text":"이스라엘 자손이 다시 여호와의 목전에 악을 행하여 바알들과, 아스다롯과, 아람의 신들과, 시돈의 신들과, 모압의 신들과, 암몬 자손의 신들과, 블레셋 사람의 신들을 섬기고 여호와를 버려 그를 섬기지 아니하므로","reference":"사사기 10:6","category":"$undefined"},{"id":"6819","book":"사사기","book_name":"사사기","chapter":10,"verse":7,"text":"여호와께서 이스라엘에게 진노하사 블레셋 사람의 손과 암몬 자손의 손에 파시매","reference":"사사기 10:7","category":"$undefined"},{"id":"6820","book":"사사기","book_name":"사사기","chapter":10,"verse":8,"text":"그들이 그 해부터 이스라엘 자손을 학대하니 요단 저편 길르앗 아모리 사람의 땅에 거한 이스라엘 자손이 십팔년 동안 학대를 당하였고","reference":"사사기 10:8","category":"$undefined"},{"id":"6821","book":"사사기","book_name":"사사기","chapter":10,"verse":9,"text":"암몬 자손이 또 요단을 건너서 유다와 베냐민과 에브라임 족속을 치므로 이스라엘의 곤고가 심하였더라","reference":"사사기 10:9","category":"$undefined"},{"id":"6822","book":"사사기","book_name":"사사기","chapter":10,"verse":10,"text":"이스라엘 자손이 여호와께 부르짖어 가로되 `우리가 우리 하나님을 버리고 바알들을 섬김으로 주께 범죄하였나이다'","reference":"사사기 10:10","category":"$undefined"},{"id":"6823","book":"사사기","book_name":"사사기","chapter":10,"verse":11,"text":"여호와께서 이스라엘 자손에게 이르시되 내가 애굽 사람과, 아모리 사람과, 암몬 자손과, 블레셋 사람에게서 너희를 구원하지 아니하였느냐 ?","reference":"사사기 10:11","category":"$undefined"},{"id":"6824","book":"사사기","book_name":"사사기","chapter":10,"verse":12,"text":"또 시돈 사람과 아말렉 사람과 마온 사람이 너희를 압제할 때에 너희가 내게 부르짖으므로 내가 너희를 그들의 손에서 구원하였거늘","reference":"사사기 10:12","category":"$undefined"},{"id":"6825","book":"사사기","book_name":"사사기","chapter":10,"verse":13,"text":"너희가 나를 버리고 다른 신들을 섬기니 그러므로 내가 다시는 너희를 구원치 아니하리라","reference":"사사기 10:13","category":"$undefined"},{"id":"6826","book":"사사기","book_name":"사사기","chapter":10,"verse":14,"text":"가서 너희가 택한 신들에게 부르짖어서 환난 때에 그들로 너희를 구원하게 하라","reference":"사사기 10:14","category":"$undefined"},{"id":"6827","book":"사사기","book_name":"사사기","chapter":10,"verse":15,"text":"이스라엘 자손이 여호와께 여짜오되 `우리가 범죄하였사오니 주의 보시기에 좋은대로 우리에게 행하시려니와 오직 주께 구하옵나니 오늘날 우리를 건져 내옵소서 !' 하고","reference":"사사기 10:15","category":"$undefined"},{"id":"6828","book":"사사기","book_name":"사사기","chapter":10,"verse":16,"text":"자기 가운데서 이방 신들을 제하여 버리고 여호와를 섬기매 여호와께서 이스라엘의 곤고를 인하여 마음에 근심하시니라","reference":"사사기 10:16","category":"$undefined"},{"id":"6829","book":"사사기","book_name":"사사기","chapter":10,"verse":17,"text":"그 때에 암몬 자손이 모여서 길르앗에 진 쳤으므로 이스라엘 자손도 모여서 미스바에 진 치고","reference":"사사기 10:17","category":"$undefined"},{"id":"6830","book":"사사기","book_name":"사사기","chapter":10,"verse":18,"text":"길르앗 백성과 방백들이 서로 이르되 `누가 먼저 나가서 암몬 자손과 싸움을 시작할꼬 그가 길르앗 모든 거민의 머리가 되리라' 하니라","reference":"사사기 10:18","category":"$undefined"}],"bookSlug":"judges"}]
