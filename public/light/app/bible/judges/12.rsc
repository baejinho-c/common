2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":12,"verses":[{"id":"6871","book":"사사기","book_name":"사사기","chapter":12,"verse":1,"text":"에브라임 사람들이 모여 북으로 가서 입다에게 이르되 `네가 암몬 자손과 싸우러 건너 갈 때에 어찌하여 우리를 불러 너와 함께 가게 하지 아니하였느냐 ? 우리가 반드시 불로 너와 네 집을 사르리라'","reference":"사사기 12:1","category":"$undefined"},{"id":"6872","book":"사사기","book_name":"사사기","chapter":12,"verse":2,"text":"입다가 그들에게 이르되 `나와 나의 백성이 암몬 자손과 크게 다툴 때에 내가 너희를 부르되 너희가 나를 그들의 손에서 구원하지 아니하므로","reference":"사사기 12:2","category":"$undefined"},{"id":"6873","book":"사사기","book_name":"사사기","chapter":12,"verse":3,"text":"내가 너희의 구원치 아니하는 것을 보고 내 생명을 돌아보지 아니하고 건너가서 암몬 자손을 쳤더니 여호와께서 그들을 내 손에 붙이셨거늘 너희가 어찌하여 오늘날 내게 올라와서 나로 더불어 싸우고자 하느냐 ?' 하고","reference":"사사기 12:3","category":"$undefined"},{"id":"6874","book":"사사기","book_name":"사사기","chapter":12,"verse":4,"text":"입다가 길르앗 사람을 다 모으고 에브라임과 싸웠더니 길르앗 사람들이 에브라임을 쳐서 파하였으니 이는 에브라임의 말이 너희 길르앗 사람은 본래 에브라임에서 도망한 자로서 에브라임과 므낫세중에 있다 하였음이라","reference":"사사기 12:4","category":"$undefined"},{"id":"6875","book":"사사기","book_name":"사사기","chapter":12,"verse":5,"text":"길르앗 사람이 에브라임 사람 앞서 요단 나루턱을 잡아 지키고 에브라임 사람의 도망하는 자가 말하기를 `청컨대 나로 건너게 하라 하면 그에게 묻기를 네가 에브라임 사람이냐' 하여 그가 만일 `아니라' 하면","reference":"사사기 12:5","category":"$undefined"},{"id":"6876","book":"사사기","book_name":"사사기","chapter":12,"verse":6,"text":"그에게 이르기를 십볼렛이라 하라 하여 에브라임 사람이 능히 구음을 바로 하지 못하고 씹볼렛이라면 길르앗 사람이 곧 그를 잡아서 요단 나루턱에서 죽였더라 그 때에 에브라임 사람의 죽은 자가 사만 이천명이었더라","reference":"사사기 12:6","category":"$undefined"},{"id":"6877","book":"사사기","book_name":"사사기","chapter":12,"verse":7,"text":"입다가 이스라엘 사사가 된지 육년이라 길르앗 사람 입다가 죽으매 길르앗 한 성읍에 장사되었더라","reference":"사사기 12:7","category":"$undefined"},{"id":"6878","book":"사사기","book_name":"사사기","chapter":12,"verse":8,"text":"그의 뒤에는 베들레헴 입산이 이스라엘의 사사이었더라","reference":"사사기 12:8","category":"$undefined"},{"id":"6879","book":"사사기","book_name":"사사기","chapter":12,"verse":9,"text":"그가 아들 삼십과 딸 삼십을 두었더니 딸들은 타국으로 시집 보내었고 아들들을 위하여는 타국에서 여자 삼십을 데려왔더라 그가 이스라엘 사사가 된지 칠년이라","reference":"사사기 12:9","category":"$undefined"},{"id":"6880","book":"사사기","book_name":"사사기","chapter":12,"verse":10,"text":"입산이 죽으매 베들레헴에 장사되었더라","reference":"사사기 12:10","category":"$undefined"},{"id":"6881","book":"사사기","book_name":"사사기","chapter":12,"verse":11,"text":"그의 뒤에는 스불론 사람 엘론이 이스라엘의 사사가 되어 십년 동안 이스라엘을 다스렸더라","reference":"사사기 12:11","category":"$undefined"},{"id":"6882","book":"사사기","book_name":"사사기","chapter":12,"verse":12,"text":"스불론 사람 엘론이 죽으매 스불론 땅 아얄론에 장사되었더라","reference":"사사기 12:12","category":"$undefined"},{"id":"6883","book":"사사기","book_name":"사사기","chapter":12,"verse":13,"text":"그의 뒤에는 비라돈 사람 힐렐의 아들 압돈이 이스라엘의 사사이었더라","reference":"사사기 12:13","category":"$undefined"},{"id":"6884","book":"사사기","book_name":"사사기","chapter":12,"verse":14,"text":"그에게 아들 사십과 손자 삼십이 있어서 어린 나귀 칠십필을 탔었더라 압돈이 이스라엘의 사사가 된지 팔년이라","reference":"사사기 12:14","category":"$undefined"},{"id":"6885","book":"사사기","book_name":"사사기","chapter":12,"verse":15,"text":"비라돈 사람 힐렐의 아들 압돈이 죽으매 에브라임 땅 아말렉 사람의 산지 비라돈에 장사되었더라","reference":"사사기 12:15","category":"$undefined"}],"bookSlug":"judges"}]
