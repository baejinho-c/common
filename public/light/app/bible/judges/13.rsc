2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":13,"verses":[{"id":"6886","book":"사사기","book_name":"사사기","chapter":13,"verse":1,"text":"이스라엘 자손이 다시 여호와의 목전에 악을 행하였으므로 여호와께서 그들을 사십년 동안 블레셋 사람의 손에 붙이시니라","reference":"사사기 13:1","category":"$undefined"},{"id":"6887","book":"사사기","book_name":"사사기","chapter":13,"verse":2,"text":"소라 땅에 단 지파의 가족 중 마노아라 이름하는 자가 있더라 그 아내가 잉태하지 못하므로 생산치 못하더니","reference":"사사기 13:2","category":"$undefined"},{"id":"6888","book":"사사기","book_name":"사사기","chapter":13,"verse":3,"text":"여호와의 사자가 그 여인에게 나타나시고 그에게 이르시되 `보라 ! 네가 본래 잉태하지 못하므로 생산치 못하였으나 이제 잉태하여 아들을 낳으리니","reference":"사사기 13:3","category":"$undefined"},{"id":"6889","book":"사사기","book_name":"사사기","chapter":13,"verse":4,"text":"그러므로 너는 삼가서 포도주와 독주를 마시지 말지며 무릇 부정한 것을 먹지 말지니라","reference":"사사기 13:4","category":"$undefined"},{"id":"6890","book":"사사기","book_name":"사사기","chapter":13,"verse":5,"text":"보라 ! 네가 잉태하여 아들을 낳으리니 그 머리에 삭도를 대지 말라 이 아이는 태에서 나옴으로부터 하나님께 바치운 나실인이 됨이라 그가 블레셋 사람의 손에서 이스라엘을 구원하기 시작하리라'","reference":"사사기 13:5","category":"$undefined"},{"id":"6891","book":"사사기","book_name":"사사기","chapter":13,"verse":6,"text":"이에 그 여인이 가서 그 남편에게 고하여 가로되 `하나님의 사람이 내게 임하였는데 그 용모가 하나님의 사자의 용모 같아서 심히 두려우므로 어디서부터 온 것을 내가 묻지 못하였고 그도 자기 이름을 내게 이르지 아니하였으며","reference":"사사기 13:6","category":"$undefined"},{"id":"6892","book":"사사기","book_name":"사사기","chapter":13,"verse":7,"text":"그가 내게 이르기를 보라 네가 잉태하여 아들을 낳으리니 포도주와 독주를 마시지 말며 무릇 부정한 것을 먹지 말라 이 아이는 태에서 나옴으로부터 죽을 날까지 하나님께 바치운 나실인이 됨이라 하더이다'","reference":"사사기 13:7","category":"$undefined"},{"id":"6893","book":"사사기","book_name":"사사기","chapter":13,"verse":8,"text":"마노아가 여호와께 기도하여 가로되 `주여 구하옵나니 주의 보내셨던 하나님의 사람을 우리에게 다시 임하게 하사 그로 우리가 그 낳을 아이에게 어떻게 행할 것을 우리에게 가르치게 하소서 !'","reference":"사사기 13:8","category":"$undefined"},{"id":"6894","book":"사사기","book_name":"사사기","chapter":13,"verse":9,"text":"하나님이 마노아의 목소리를 들으시니라 여인이 밭에 앉았을 때에 하나님의 사자가 다시 그에게 임하셨으나 그 남편 마노아는 함께 있지 아니한지라","reference":"사사기 13:9","category":"$undefined"},{"id":"6895","book":"사사기","book_name":"사사기","chapter":13,"verse":10,"text":"여인이 급히 달려가서 그 남편에게 고하여 가로되 `보소서 ! 전일에 내게 임하였던 사람이 또 내게 나타났나이다'","reference":"사사기 13:10","category":"$undefined"},{"id":"6896","book":"사사기","book_name":"사사기","chapter":13,"verse":11,"text":"마노아가 일어나 아내를 따라가서 그 사람에게 이르러 그에게 묻되 당신이 이 여인에게 말씀하신 사람이니이까 ? 가라사대 그로라","reference":"사사기 13:11","category":"$undefined"},{"id":"6897","book":"사사기","book_name":"사사기","chapter":13,"verse":12,"text":"마노아가 가로되 `당신의 말씀대로 되기를 원하나이다 이 아이를 어떻게 기르오며 우리가 그에게 어떻게 행하오리이까 ?'","reference":"사사기 13:12","category":"$undefined"},{"id":"6898","book":"사사기","book_name":"사사기","chapter":13,"verse":13,"text":"여호와의 사자가 마노아에게 이르시되 `내가 여인에게 말한 것들을 그가 다 삼가서","reference":"사사기 13:13","category":"$undefined"},{"id":"6899","book":"사사기","book_name":"사사기","chapter":13,"verse":14,"text":"포도나무의 소산을 먹지 말며 포도주와 독주를 마시지 말며 무릇 부정한 것을 먹지 말아서 내가 그에게 명한 것은 다 지킬 것이니라'","reference":"사사기 13:14","category":"$undefined"},{"id":"6900","book":"사사기","book_name":"사사기","chapter":13,"verse":15,"text":"마노아가 여호와의 사자에게 말씀하되 `구하옵나니 당신은 우리에게 머물러서 우리가 당신을 위하여 염소 새끼 하나를 준비하게 하소서'","reference":"사사기 13:15","category":"$undefined"},{"id":"6901","book":"사사기","book_name":"사사기","chapter":13,"verse":16,"text":"여호와의 사자가 마노아에게 이르시되 `네가 비록 나를 머물리나 내가 너의 식물을 먹지 아니하리라 번제를 준비하려거든 마땅히 여호와께 드릴지니라' 하니 이는 마노아가 여호와의 사자인 줄 알지 못함을 인함이었더라","reference":"사사기 13:16","category":"$undefined"},{"id":"6902","book":"사사기","book_name":"사사기","chapter":13,"verse":17,"text":"마노아가 또 여호와의 사자에게 말씀하되 `당신의 이름이 무엇이니이까 ? 당신의 말씀이 이룰 때에 우리가 당신을 존숭하리이다'","reference":"사사기 13:17","category":"$undefined"},{"id":"6903","book":"사사기","book_name":"사사기","chapter":13,"verse":18,"text":"여호와의 사자가 그에게 이르시되 `어찌하여 이를 묻느냐 ? 내 이름은 기묘니라'","reference":"사사기 13:18","category":"$undefined"},{"id":"6904","book":"사사기","book_name":"사사기","chapter":13,"verse":19,"text":"이에 마노아가 염소 새끼 하나와 소제물을 취하여 반석 위에서 여호와께 드리매 사자가 이적을 행한지라 마노아와 그 아내가 본즉","reference":"사사기 13:19","category":"$undefined"},{"id":"6905","book":"사사기","book_name":"사사기","chapter":13,"verse":20,"text":"불꽃이 단에서부터 하늘로 올라가는 동시에 여호와의 사자가 단 불꽃 가운데로 좇아 올라간지라 마노아와 그 아내가 이것을 보고 얼굴을 땅에 대고 엎드리니라","reference":"사사기 13:20","category":"$undefined"},{"id":"6906","book":"사사기","book_name":"사사기","chapter":13,"verse":21,"text":"여호와의 사자가 마노아와 그 아내에게 다시 나타나지 아니하니 마노아가 이에 그가 여호와의 사자인 줄알고","reference":"사사기 13:21","category":"$undefined"},{"id":"6907","book":"사사기","book_name":"사사기","chapter":13,"verse":22,"text":"그 아내에게 이르되 `우리가 하나님을 보았으니 반드시 죽으리로다'","reference":"사사기 13:22","category":"$undefined"},{"id":"6908","book":"사사기","book_name":"사사기","chapter":13,"verse":23,"text":"그 아내가 그에게 이르되 `여호와께서 우리를 죽이려 하셨더면 우리 손에서 번제와 소제를 받지 아니하셨을 것이며 이제 이런 말씀도 우리에게 이르지 아니하셨으리이다' 하였더라","reference":"사사기 13:23","category":"$undefined"},{"id":"6909","book":"사사기","book_name":"사사기","chapter":13,"verse":24,"text":"여인이 아들을 낳으매 이름을 삼손이라 하니라 아이가 자라매 여호와께서 그에게 복을 주시더니","reference":"사사기 13:24","category":"$undefined"},{"id":"6910","book":"사사기","book_name":"사사기","chapter":13,"verse":25,"text":"소라와 에스다올 사이 마하네단에서 여호와의 신이 비로소 그에게 감동하시니라","reference":"사사기 13:25","category":"$undefined"}],"bookSlug":"judges"}]
