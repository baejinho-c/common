2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":14,"verses":[{"id":"6911","book":"사사기","book_name":"사사기","chapter":14,"verse":1,"text":"삼손이 딤나에 내려가서 거기서 블레셋 딸 중 한 여자를 보고","reference":"사사기 14:1","category":"$undefined"},{"id":"6912","book":"사사기","book_name":"사사기","chapter":14,"verse":2,"text":"도로 올라와서 자기 부모에게 말하여 가로되 `내가 딤나에서 블레셋 사람의 딸 중 한 여자를 보았사오니 이제 그를 취하여 내 아내를 삼게 하소서'","reference":"사사기 14:2","category":"$undefined"},{"id":"6913","book":"사사기","book_name":"사사기","chapter":14,"verse":3,"text":"부모가 그에게 이르되 `네 형제들의 딸 중에나 내 백성 중에 어찌 여자가 없어서 네가 할례받지 아니한 블레셋 사람에게 가서 아내를 취하려 하느냐 ?' 삼손이 아비에게 이르되 `내가 그 여자를 좋아 하오니 나를 위하여 그를 데려오소서' 하니","reference":"사사기 14:3","category":"$undefined"},{"id":"6914","book":"사사기","book_name":"사사기","chapter":14,"verse":4,"text":"이 때에 블레셋 사람이 이스라엘을 관할한고로 삼손이 틈을 타서 블레셋 사람을 치려 함이었으나 그 부모는 이 일이 여호와께서 나온 것인 줄은 알지 못하였더라","reference":"사사기 14:4","category":"$undefined"},{"id":"6915","book":"사사기","book_name":"사사기","chapter":14,"verse":5,"text":"삼손이 그 부모와 함께 딤나에 내려가서 딤나의 포도원에 이른즉 어린 사자가 그를 맞아 소리지르는지라","reference":"사사기 14:5","category":"$undefined"},{"id":"6916","book":"사사기","book_name":"사사기","chapter":14,"verse":6,"text":"삼손이 여호와의 신에게 크게 감동되어 손에 아무 것도 없어도 그 사자를 염소 새끼를 찢음 같이 찢었으나 그는 그 행한 일을 부모에게도 고하지 아니하였고","reference":"사사기 14:6","category":"$undefined"},{"id":"6917","book":"사사기","book_name":"사사기","chapter":14,"verse":7,"text":"그가 내려가서 그 여자와 말하며 그를 기뻐하였더라","reference":"사사기 14:7","category":"$undefined"},{"id":"6918","book":"사사기","book_name":"사사기","chapter":14,"verse":8,"text":"얼마 후에 삼손이 그 여자를 취하려고 다시 가더니 돌이켜 그 사자의 주검을 본즉 사자의 몸에 벌떼와 꿀이 있는지라","reference":"사사기 14:8","category":"$undefined"},{"id":"6919","book":"사사기","book_name":"사사기","chapter":14,"verse":9,"text":"손으로 그 꿀을 취하여 행하며 먹고 그 부모에게 이르러 그들에게 그것을 드려서 먹게 하였으나 그 꿀을 사자의 몸에서 취하였다고는 고하지 아니하였더라","reference":"사사기 14:9","category":"$undefined"},{"id":"6920","book":"사사기","book_name":"사사기","chapter":14,"verse":10,"text":"삼손의 아비가 여자에게로 내려가매 삼손이 거기서 잔치를 배설하였으니 소년은 이렇게 행하는 풍속이 있음이더라","reference":"사사기 14:10","category":"$undefined"},{"id":"6921","book":"사사기","book_name":"사사기","chapter":14,"verse":11,"text":"무리가 삼손을 보고 삼십명을 데려다가 동무를 삼아 그와 함께 하게 한지라","reference":"사사기 14:11","category":"$undefined"},{"id":"6922","book":"사사기","book_name":"사사기","chapter":14,"verse":12,"text":"삼손이 그들에게 이르되 `이제 내가 너희에게 수수께끼를 하리니 잔치하는 칠일 동안에 너희가 능히 그것을 풀어서 내게 고하면 내가 베옷 삼십 벌과 겉옷 삼십 벌을 너희에게 주리라","reference":"사사기 14:12","category":"$undefined"},{"id":"6923","book":"사사기","book_name":"사사기","chapter":14,"verse":13,"text":"그러나 그것을 능히 내게 고하지 못하면 너희가 내게 베옷 삼십벌과 겉옷 삼십 벌을 줄지니라' 그들이 이르되 `너는 수수께끼를 하여 우리로 듣게 하라'","reference":"사사기 14:13","category":"$undefined"},{"id":"6924","book":"사사기","book_name":"사사기","chapter":14,"verse":14,"text":"삼손이 그들에게 이르되 `먹는자에게서 먹는 것이 나오고 강한 자에게서 단 것이 나왔느니라' 그들이 삼일이 되도록 수수께끼를 풀지 못하였더라","reference":"사사기 14:14","category":"$undefined"},{"id":"6925","book":"사사기","book_name":"사사기","chapter":14,"verse":15,"text":"제 칠일에 이르러 그들이 삼손의 아내에게 이로되 `너는 네 남편을 꾀어 그 수수께끼를 우리에게 알리게 하라 그렇지 아니하면 너와 네 아비의 집을 불사르리라 너희가 우리의 소유를 취하고자하여 우리를 청하였느냐 ? 그렇지 아니하냐 ?'","reference":"사사기 14:15","category":"$undefined"},{"id":"6926","book":"사사기","book_name":"사사기","chapter":14,"verse":16,"text":"삼손의 아내가 그의 앞에서 울며 가로되 `당신이 나를 미워할 뿐이요 사랑치 아니하는도다 우리 민족에게 수수께끼를 말하고 그 뜻을 내게 풀어 이르지 아니하도다' 삼손이 그에게 대답하되 `보라 내가 그것을 나의 부모에게도 풀어 고하지 아니하였거든 어찌 그대에게 풀어 이르리요' 하였으나","reference":"사사기 14:16","category":"$undefined"},{"id":"6927","book":"사사기","book_name":"사사기","chapter":14,"verse":17,"text":"칠일 잔치할 동안에 그 아내가 앞에서 울며 강박함을 인하여 제 칠일에는 그가 그 아내에게 수수께끼를 풀어 이르매 그 아내가 그것을 그 민족에게 고하였더라","reference":"사사기 14:17","category":"$undefined"},{"id":"6928","book":"사사기","book_name":"사사기","chapter":14,"verse":18,"text":"제 칠일 해 지기 전에 성읍 사람들이 삼손에게 이르되 `무엇이 꿀보다 달겠으며 무엇이 사자보다 강하겠느냐 ?' 한지라 삼손이 그들에게 대답하되 `너희가 내 암송아지로 밭갈지 아니하였더면 나의 수수께끼를 능히 풀지 못하였으리라' 하니라","reference":"사사기 14:18","category":"$undefined"},{"id":"6929","book":"사사기","book_name":"사사기","chapter":14,"verse":19,"text":"여호와의 신이 삼손에게 크게 임하시매 삼손이 아스글론에 내려가서 그곳 사람 삼십명을 쳐 죽이고 노략하여 수수께끼 푼 자들 에게 옷을 주고 심히 노하여 아비 집으로 올라갔고","reference":"사사기 14:19","category":"$undefined"},{"id":"6930","book":"사사기","book_name":"사사기","chapter":14,"verse":20,"text":"삼손의 아내는 삼손의 친구되었던 그 동무에게 준바 되었더라","reference":"사사기 14:20","category":"$undefined"}],"bookSlug":"judges"}]
