2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":15,"verses":[{"id":"6931","book":"사사기","book_name":"사사기","chapter":15,"verse":1,"text":"얼마 후 밀 거둘 때에 삼손이 염소 새끼를 가지고 그 아내에게로 찾아 가서 가로되 `내가 침실에 들어가 아내를 보고자 하노라' 장인이 들어 오지 못하게 하고","reference":"사사기 15:1","category":"$undefined"},{"id":"6932","book":"사사기","book_name":"사사기","chapter":15,"verse":2,"text":"가로되 `네가 그를 심히 미워하는 줄로 내가 생각한 고로 그를 네 동무에게 주었노라 그 동생이 그보다 더욱 아름답지 아니하냐 ? 청하노니 너는 그의 대신에 이를 취하라'","reference":"사사기 15:2","category":"$undefined"},{"id":"6933","book":"사사기","book_name":"사사기","chapter":15,"verse":3,"text":"삼손이 그들에게 이르되 `이번은 내가 블레셋 사람을 해할지라도 그들에게 대하여 내게 허물이 없을 것이니라' 하고","reference":"사사기 15:3","category":"$undefined"},{"id":"6934","book":"사사기","book_name":"사사기","chapter":15,"verse":4,"text":"삼손이 가서 여우 삼백을 붙들어서 그 꼬리와 꼬리를 매고 홰를 취하고 그 두 꼬리 사이에 한 홰를 달고","reference":"사사기 15:4","category":"$undefined"},{"id":"6935","book":"사사기","book_name":"사사기","chapter":15,"verse":5,"text":"홰에 불을 켜고 그것을 블레셋 사람의 곡식 밭으로 몰아 들여서 곡식 단과 아직 베지 아니한 곡식과 감람원을 사른지라","reference":"사사기 15:5","category":"$undefined"},{"id":"6936","book":"사사기","book_name":"사사기","chapter":15,"verse":6,"text":"블레셋 사람이 가로되 누가 이일을 행하였느냐 ? 혹이 대답하되 딤나 사람의 사위 삼손이니 장인이 삼손의 아내를 취하여 그 동무 되었던 자에게 준 연고니라 블레셋 사람이 올라가서 그 여인과 그의 아비를 불사르니라","reference":"사사기 15:6","category":"$undefined"},{"id":"6937","book":"사사기","book_name":"사사기","chapter":15,"verse":7,"text":"삼손이 그들에게 이르되 `너희가 이같이 행하였은즉 내가 너희에게 원수를 갚은 후에야 말리라' 하고","reference":"사사기 15:7","category":"$undefined"},{"id":"6938","book":"사사기","book_name":"사사기","chapter":15,"verse":8,"text":"블레셋 사람을 크게 도륙하고 내려가서 에담 바위 틈에 거하니라","reference":"사사기 15:8","category":"$undefined"},{"id":"6939","book":"사사기","book_name":"사사기","chapter":15,"verse":9,"text":"이에 블레셋 사람이 올라와서 유다에 진을 치고 레히에 편만한지라","reference":"사사기 15:9","category":"$undefined"},{"id":"6940","book":"사사기","book_name":"사사기","chapter":15,"verse":10,"text":"유다 사람들이 가로되 `너희가 어찌하여 올라와서 우리를 치느냐 ?' 그들이 대답하되 `우리가 올라오기는 삼손을 결박하여 그가 우리에게 행한 대로 그에게 행하려 함이로라'","reference":"사사기 15:10","category":"$undefined"},{"id":"6941","book":"사사기","book_name":"사사기","chapter":15,"verse":11,"text":"유다 사람 삼천명이 에담 바위틈에 내려가서 삼손에게 이르되 `너는 블레셋 사람이 우리를 관할하는 줄을 알지 못하느냐 ? 네가 어찌하여 우리에게 이같이 행하였느냐 ?' 삼손이 그들에게 이르되 `그들이 내게 행한 대로 나도 그들에게 행하였노라'","reference":"사사기 15:11","category":"$undefined"},{"id":"6942","book":"사사기","book_name":"사사기","chapter":15,"verse":12,"text":"그들이 삼손에게 이르되 `우리가 너를 결박하여 블레셋 사람의 손에 붙이려고 이제 내려왔노라' 삼손이 그들에게 이르되 `너희는 친히 나를 치지 않겠다고 내게 맹세하라'","reference":"사사기 15:12","category":"$undefined"},{"id":"6943","book":"사사기","book_name":"사사기","chapter":15,"verse":13,"text":"그들이 삼손에게 일러 가로되 `아니라 우리가 다만 너를 단단히 결박하여 그들의 손에 붙일 뿐이요 우리가 결단코 너를 죽이지 아니하리라' 하고 새 줄 둘로 결박하고 바위틈에서 그를 끌어내니라","reference":"사사기 15:13","category":"$undefined"},{"id":"6944","book":"사사기","book_name":"사사기","chapter":15,"verse":14,"text":"삼손이 레히에 이르매 블레셋 사람이 그에게로 마주 나가며 소리지르는 동시에 여호와의 신의 권능이 삼손에게 임하매 그 팔 위의 줄이 불탄 삼과 같아서 그 결박되었던 손에서 떨어진지라","reference":"사사기 15:14","category":"$undefined"},{"id":"6945","book":"사사기","book_name":"사사기","chapter":15,"verse":15,"text":"삼손이 나귀의 새 턱뼈를 보고 손을 내밀어 취하고 그것으로 일천명을 죽이고","reference":"사사기 15:15","category":"$undefined"},{"id":"6946","book":"사사기","book_name":"사사기","chapter":15,"verse":16,"text":"가로되 `나귀의 턱뼈로 한더미 두더미를 쌓았음이여 나귀의 턱뼈로 내가 일천명을 죽였도다'","reference":"사사기 15:16","category":"$undefined"},{"id":"6947","book":"사사기","book_name":"사사기","chapter":15,"verse":17,"text":"말을 마치고 턱뼈를 그 손에서 내어던지고 그 곳을 라맛 레히라 이름하였더라","reference":"사사기 15:17","category":"$undefined"},{"id":"6948","book":"사사기","book_name":"사사기","chapter":15,"verse":18,"text":"삼손이 심히 목마르므로 여호와께 부르짖어 가로되 `주께서 종의 손으로 이 큰 구원을 베푸셨사오나 내가 이제 목말라 죽어서 할례 받지 못한 자의 손에 빠지겠나이다'","reference":"사사기 15:18","category":"$undefined"},{"id":"6949","book":"사사기","book_name":"사사기","chapter":15,"verse":19,"text":"하나님의 레히에 한 우묵한 곳을 터치시니 물이 거기서 솟아나오는지라 삼손이 그것을 마시고 정신이 회복되어 소생하니 그러므로 그 샘 이름은 엔학고레라 이샘이 레히에 오늘까지 있더라","reference":"사사기 15:19","category":"$undefined"},{"id":"6950","book":"사사기","book_name":"사사기","chapter":15,"verse":20,"text":"블레셋 사람의 때에 삼손이 이스라엘 사사로 이십년을 지내었더라","reference":"사사기 15:20","category":"$undefined"}],"bookSlug":"judges"}]
