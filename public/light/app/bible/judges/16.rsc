2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":16,"verses":[{"id":"6951","book":"사사기","book_name":"사사기","chapter":16,"verse":1,"text":"삼손이 가사에 가서 거기서 한 기생을 보고 그에게로 들어갔더니","reference":"사사기 16:1","category":"$undefined"},{"id":"6952","book":"사사기","book_name":"사사기","chapter":16,"verse":2,"text":"혹이 가사 사람에게 고하여 가로되 `삼손이 여기 왔다' 하매 곧 그를 에워싸고 밤새도록 성문에 매복하고 밤새도록 종용히 하며 이르기를 `새벽이 되거든 그를 죽이리라' 하였더라","reference":"사사기 16:2","category":"$undefined"},{"id":"6953","book":"사사기","book_name":"사사기","chapter":16,"verse":3,"text":"삼손이 밤 중까지 누웠다가 그 밤 중에 일어나 성문짝들과 두 설주와 빗장을 빼어 그것을 모두 어깨에 메고 헤브론 앞산 꼭대기로 가니라","reference":"사사기 16:3","category":"$undefined"},{"id":"6954","book":"사사기","book_name":"사사기","chapter":16,"verse":4,"text":"이 후에 삼손이 소렉 골짜기의 들릴라라 이름하는 여인을 사랑하매","reference":"사사기 16:4","category":"$undefined"},{"id":"6955","book":"사사기","book_name":"사사기","chapter":16,"verse":5,"text":"블레셋 사람의 방백들이 그 여인에게로 올라와서 그에게 이르되 삼손을 꾀어서 무엇으로 말미암아 그 큰 힘이 있는지 우리가 어떻게 하면 그를 이기어서 결박하여 곤고케 할수 있을는지 알아보라 그리하면 우리가 각각 은 일천 일백을 네게 주리라","reference":"사사기 16:5","category":"$undefined"},{"id":"6956","book":"사사기","book_name":"사사기","chapter":16,"verse":6,"text":"들릴라가 삼손에게 말하되 `청컨대 당신의 큰 힘이 무엇으로 말미암아 있으며 어떻게 하면 능히 당신을 결박하여 곤고케 할 수 있을는지 내게 말하라'","reference":"사사기 16:6","category":"$undefined"},{"id":"6957","book":"사사기","book_name":"사사기","chapter":16,"verse":7,"text":"삼손이 그에게 이르되 `만일 마르지 아니한 푸른 칡 일곱으로 나를 결박하면 내가 약하여져서 다른 사람과 같으리라'","reference":"사사기 16:7","category":"$undefined"},{"id":"6958","book":"사사기","book_name":"사사기","chapter":16,"verse":8,"text":"블레셋 사람의 방백들이 마르지 아니한 푸른 칡 일곱을 여인에게로 가져오매 그가 그것으로 삼손을 결박하고","reference":"사사기 16:8","category":"$undefined"},{"id":"6959","book":"사사기","book_name":"사사기","chapter":16,"verse":9,"text":"이미 사람을 내실에 매복시켰으므로 삼손에게 말하되 `삼손이여, 블레셋 사람이 당신에게 미쳤느니라'하니 삼손이 그 칡 끊기를 불탄 삼실을 끊음같이 하였고 그 힘의 근본은 여전히 알지 못하니라","reference":"사사기 16:9","category":"$undefined"},{"id":"6960","book":"사사기","book_name":"사사기","chapter":16,"verse":10,"text":"들릴라가 삼손에게 이르되 `보라 당신이 나를 희롱하여 내게 거짓말을 하였도다 청컨대 무엇으로 하면 당신을 결박할 수 있을는지 이제는 네게 말하라'","reference":"사사기 16:10","category":"$undefined"},{"id":"6961","book":"사사기","book_name":"사사기","chapter":16,"verse":11,"text":"삼손이 그에게 이르되 `만일 쓰지 아니한 새 줄로 나를 결박하면 내가 약하여져서 다른 사람과 같으리라'","reference":"사사기 16:11","category":"$undefined"},{"id":"6962","book":"사사기","book_name":"사사기","chapter":16,"verse":12,"text":"들릴라가 새 줄을 취하고 그것으로 그를 결박하고 그에게 이르되 삼손이여 블레셋 사람이 당신에게 미쳤느니라 하니 삼손이 팔 위의 줄 끊기를 실을 끊음같이 하였고 그 때에도 사람이 내실에 매복하였였더라","reference":"사사기 16:12","category":"$undefined"},{"id":"6963","book":"사사기","book_name":"사사기","chapter":16,"verse":13,"text":"들릴라가 삼손에게 이르되 `당신이 이때까지 나를 희롱하여 내게 거짓말을 하였도다 내가 무엇으로 하면 당신을 결박할 수 있을는지 내게 말하라' 삼손이 그에게 이르되 `그대가 만일 나의 머리털 일곱 가닥을 위선에 섞어 짜면 되리라'","reference":"사사기 16:13","category":"$undefined"},{"id":"6964","book":"사사기","book_name":"사사기","chapter":16,"verse":14,"text":"들릴라가 바디로 그 머리털을 단단히 짜고 그에게 이르되 `삼손이여, 블레셋 사람이 당신에게 미쳤느니라' 하니 삼손이 잠을 깨어 직조틀의 바디와 위선을 다 빼어내니라","reference":"사사기 16:14","category":"$undefined"},{"id":"6965","book":"사사기","book_name":"사사기","chapter":16,"verse":15,"text":"들릴라가 삼손에게 이르되 `당신의 마음이 내게 있지 아니하면서 당신이 어찌 나를 사랑한다 하느뇨 ? 당신이 이 세번 나를 희롱하고 당신 큰 힘이 무엇으로 말미암아 있는 것을 말하지 아니하였도다' 하며","reference":"사사기 16:15","category":"$undefined"},{"id":"6966","book":"사사기","book_name":"사사기","chapter":16,"verse":16,"text":"날마다 그 말로 그를 재촉하여 조르매 삼손의 마음이 번뇌하여 죽을 지경이라","reference":"사사기 16:16","category":"$undefined"},{"id":"6967","book":"사사기","book_name":"사사기","chapter":16,"verse":17,"text":"삼손이 진정을 토하여 그에게 이르되 `내 머리에는 삭도를 대지 아니하였나니 이는 내가 모태에서 하나님의 나실인이 되었음이라 만일 내 머리가 밀리우면 내 힘이 내게서 떠나고 나는 약하여져서 다른 사람과 같으리라'","reference":"사사기 16:17","category":"$undefined"},{"id":"6968","book":"사사기","book_name":"사사기","chapter":16,"verse":18,"text":"들릴라가 삼손의 진정을 다 토함을 보고 보내어 블레셋 사람의 방백들을 불러 가로되 `삼손이 내게 진정을 토하였으니 이제 한번만 올라오라' 블레셋 방백들이 손에 은을 가지고 여인에게로 올라오니라","reference":"사사기 16:18","category":"$undefined"},{"id":"6969","book":"사사기","book_name":"사사기","chapter":16,"verse":19,"text":"들릴라가 삼손으로 자기 무릎을 베고 자게 하고 사람을 불러 그 머리털 일곱 가닥을 밀고 괴롭게 하여 본즉 그 힘이 없어졌더라","reference":"사사기 16:19","category":"$undefined"},{"id":"6970","book":"사사기","book_name":"사사기","chapter":16,"verse":20,"text":"들릴라가 가로되 `삼손이여, 블레셋 사람이 당신에게 미쳤느니라' 하니 삼손이 잠을 깨며 이르기를 `내가 전과 같이 나가서 몸을 떨치리라' 하여도 여호와께서 이미 자기를 떠나신 줄을 깨닫지 못하였더라","reference":"사사기 16:20","category":"$undefined"},{"id":"6971","book":"사사기","book_name":"사사기","chapter":16,"verse":21,"text":"블레셋 사람이 그를 잡아 그 눈을 빼고 끌고 가사에 내려가 놋줄로 매고 그로 옥 중에서 맷돌을 돌리게 하였더라","reference":"사사기 16:21","category":"$undefined"},{"id":"6972","book":"사사기","book_name":"사사기","chapter":16,"verse":22,"text":"그의 머리털이 밀리운 후에 다시 자라기 시작하니라","reference":"사사기 16:22","category":"$undefined"},{"id":"6973","book":"사사기","book_name":"사사기","chapter":16,"verse":23,"text":"블레셋 사람의 방백이 가로되 `우리의 신이 우리 원수 삼손을 우리 손에 붙였다' 하고 다 모여 그 신 다곤에게 큰 제사를 드리고 즐거워하고","reference":"사사기 16:23","category":"$undefined"},{"id":"6974","book":"사사기","book_name":"사사기","chapter":16,"verse":24,"text":"백성들도 삼손을 보았으므로 가로되 `우리 토지를 헐고 우리 많은 사람을 죽인 원수를 우리의 신이 우리 손에 붙였다' 하고 자기 신을 찬송하며","reference":"사사기 16:24","category":"$undefined"},{"id":"6975","book":"사사기","book_name":"사사기","chapter":16,"verse":25,"text":"그들의 마음이 즐거울 때에 이르되 `삼손을 불러다가 우리를 위하여 재주를 부리게 하자' 하고 옥에서 삼손을 불러내매 삼손이 그들을 위하여 재주를 부리니라 그들이 삼손을 두 기둥 사이에 세웠더니","reference":"사사기 16:25","category":"$undefined"},{"id":"6976","book":"사사기","book_name":"사사기","chapter":16,"verse":26,"text":"삼손이 자기 손을 붙든 소년에게 이르되 `나로 이 집을 버틴 기둥을 찾아서 그것을 의지하게 하라' 하니라","reference":"사사기 16:26","category":"$undefined"},{"id":"6977","book":"사사기","book_name":"사사기","chapter":16,"verse":27,"text":"그 집에는 남녀가 가득하니 블레셋 모든 방백도 거기 있고 지붕에 있는 남녀도 삼천명 가량이라 다 삼손의 재주 부리는 것을 보더라","reference":"사사기 16:27","category":"$undefined"},{"id":"6978","book":"사사기","book_name":"사사기","chapter":16,"verse":28,"text":"삼손이 여호와께 부르짖어 가로되 `주 여호와여 구하옵나니 나를 생각하옵소서 하나님이여 구하옵나니 이번만 나로 강하게 하사 블레셋 사람이 나의 두 눈을 뺀 원수를 단번에 갚게 하옵소서 !' 하고","reference":"사사기 16:28","category":"$undefined"},{"id":"6979","book":"사사기","book_name":"사사기","chapter":16,"verse":29,"text":"집을 버틴 두 가운데 기둥을 하나는 왼손으로, 하나는 오른손으로 껴 의지하고","reference":"사사기 16:29","category":"$undefined"},{"id":"6980","book":"사사기","book_name":"사사기","chapter":16,"verse":30,"text":"가로되 `블레셋 사람과 함께 죽기를 원하노라' 하고 힘을 다하여 몸을 굽히매 그 집이 곧 무너져 그 안에 있는 모든 방백과 온 백성에게 덮이니 삼손이 죽을 때에 죽인 자가 살았을 때에 죽인 자보다 더욱 많았더라","reference":"사사기 16:30","category":"$undefined"},{"id":"6981","book":"사사기","book_name":"사사기","chapter":16,"verse":31,"text":"그의 형제와 아비의 온 집이 다 내려가서 그 시체를 취하여 가지고 올라와서 소라와 에스다올 사이 그 아비 마노아의 장지에 장사하니라 삼손이 이스라엘 사사로 이십년을 지내었더라","reference":"사사기 16:31","category":"$undefined"}],"bookSlug":"judges"}]
