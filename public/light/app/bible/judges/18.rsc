2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":18,"verses":[{"id":"6995","book":"사사기","book_name":"사사기","chapter":18,"verse":1,"text":"그 때에 이스라엘에 왕이 없었고 단 지파는 이때에 거할 기업의 땅을 구하는 중이었으니 이는 그들이 이스라엘 지파 중에서 이때까지 기업의 땅 분배함을 얻지 못하였음이라","reference":"사사기 18:1","category":"$undefined"},{"id":"6996","book":"사사기","book_name":"사사기","chapter":18,"verse":2,"text":"단 자손이 소라와 에스다올에서부터 자기 온 가족 중 용맹 있는 다섯 사람을 보내어 땅을 탐지하고 살피게 하며 그들에게 이르되 `너희는 가서 땅을 살펴보라' 하매 그들이 에브라임 산지에 가서 미가의 집에 이르러 거기서 유숙하니라","reference":"사사기 18:2","category":"$undefined"},{"id":"6997","book":"사사기","book_name":"사사기","chapter":18,"verse":3,"text":"그들이 미가의 집에 가까이 올 때에 레위 소년의 음성을 알아듣고 그리로 돌이켜 가서 그에게 이르되 `누가 너를 이리로 인도하였으며 네가 여기서 무엇을 하며 여기서 무엇을 얻었느냐 ?'","reference":"사사기 18:3","category":"$undefined"},{"id":"6998","book":"사사기","book_name":"사사기","chapter":18,"verse":4,"text":"그가 그들에게 이르되 `미가가 여차여차히 나를 대접하여 나를 고빙하여 나로 자기 제사장을 삼았느니라'","reference":"사사기 18:4","category":"$undefined"},{"id":"6999","book":"사사기","book_name":"사사기","chapter":18,"verse":5,"text":"그들이 그에게 이르되 `청컨대 우리를 위하여 하나님께 물어보아서 우리의 행하는 길이 형통할는지 우리에게 알게 하라'","reference":"사사기 18:5","category":"$undefined"},{"id":"7000","book":"사사기","book_name":"사사기","chapter":18,"verse":6,"text":"그 제사장이 그들에게 이르되 `평안히 가라 너희의 행하는 길은 여호와 앞에 있느니라'","reference":"사사기 18:6","category":"$undefined"},{"id":"7001","book":"사사기","book_name":"사사기","chapter":18,"verse":7,"text":"이에 다섯 사람이 떠나 라이스에 이르러 거기 있는 백성을 본즉 염려 없이 거하여 시돈 사람같이 한가하고 평안하니 그 땅에는 권세 잡은 자가 없어서 무슨 일에든지 괴롭게 함이 없고 시돈 사람과 상거가 멀며 아무 사람과도 상관하지 아니함이라","reference":"사사기 18:7","category":"$undefined"},{"id":"7002","book":"사사기","book_name":"사사기","chapter":18,"verse":8,"text":"그들이 소라와 에스다올에 돌아와서 그 형제에게 이르매 형제들이 그들에게 묻되 `너희 보기에 어떠하더뇨'","reference":"사사기 18:8","category":"$undefined"},{"id":"7003","book":"사사기","book_name":"사사기","chapter":18,"verse":9,"text":"가로되 `일어나서 그들을 치러 올라가자 우리가 그 땅을 본즉 매우 좋더라 너희는 가만히 있느냐 ? 나아가서 그 땅 얻기를 게을리 말라","reference":"사사기 18:9","category":"$undefined"},{"id":"7004","book":"사사기","book_name":"사사기","chapter":18,"verse":10,"text":"너희가 가면 평안한 백성을 만날 것이요 그 땅은 넓고 그 곳에는 세상에 있는 것이 하나도 부족함이 없느니라'","reference":"사사기 18:10","category":"$undefined"},{"id":"7005","book":"사사기","book_name":"사사기","chapter":18,"verse":11,"text":"단 지파 가족 중 육백명이 병기를 띠고 소라와 에스다올에서 출발하여","reference":"사사기 18:11","category":"$undefined"},{"id":"7006","book":"사사기","book_name":"사사기","chapter":18,"verse":12,"text":"올라가서 유다 기럇여아림에 진 치니 이러므로 그곳 이름이 오늘까지 마하네단이며 그 곳은 기럇여아림 뒤에 있더라","reference":"사사기 18:12","category":"$undefined"},{"id":"7007","book":"사사기","book_name":"사사기","chapter":18,"verse":13,"text":"무리가 거기서 떠나서 에브라임 산지 미가의 집에 이르니라","reference":"사사기 18:13","category":"$undefined"},{"id":"7008","book":"사사기","book_name":"사사기","chapter":18,"verse":14,"text":"전에 라이스 땅을 탐지하러 갔던 다섯 사람이 그 형제들에게 말하여 가로되 `이 집에 에봇과 드라빔과 새긴 신상과 부어만든 신상이 있는 줄을 너희가 아느냐 ? 그런즉 이제 너희는 마땅히 행할 것을 생각하라' 하고","reference":"사사기 18:14","category":"$undefined"},{"id":"7009","book":"사사기","book_name":"사사기","chapter":18,"verse":15,"text":"다섯 사람이 그 편으로 향하여 소년 레위 사람의 집 곧 미가의 집에 이르러 문안하고","reference":"사사기 18:15","category":"$undefined"},{"id":"7010","book":"사사기","book_name":"사사기","chapter":18,"verse":16,"text":"단 자손 육백명은 병기를 띠고 문 입구에 서니라","reference":"사사기 18:16","category":"$undefined"},{"id":"7011","book":"사사기","book_name":"사사기","chapter":18,"verse":17,"text":"땅을 탐지하러 갔던 다섯 사람이 그리로 들어가서 새긴 신상과 에봇과 드라빔과 부어 만든 신상을 취할 때에 제사장은 병기를 육백명과 함께 문 입구에 섰더니","reference":"사사기 18:17","category":"$undefined"},{"id":"7012","book":"사사기","book_name":"사사기","chapter":18,"verse":18,"text":"그 다섯 사람이 미가의 집에 들어가서 그 새긴 신상과 에봇과 드라빔과 부어 만든 신상을 취하여 내매 제사장이 그들에게 묻되 `너희가 무엇을 하느냐 ?'","reference":"사사기 18:18","category":"$undefined"},{"id":"7013","book":"사사기","book_name":"사사기","chapter":18,"verse":19,"text":"그들이 그에게 이르되 `잠잠하라 네 손을 입에 대라 우리와 함께 가서 우리의 아비와 제사장이 되라 네가 한 사람의 집의 제사장이 되는 것과 이스라엘 한 지파, 한 가족의 제사장이 되는 것이 어느 것이 낫겠느냐 ?'","reference":"사사기 18:19","category":"$undefined"},{"id":"7014","book":"사사기","book_name":"사사기","chapter":18,"verse":20,"text":"제사장이 마음에 기뻐하여 에봇과 드라빔과 새긴 우상을 취하고 그 백성 중으로 들어가니라","reference":"사사기 18:20","category":"$undefined"},{"id":"7015","book":"사사기","book_name":"사사기","chapter":18,"verse":21,"text":"그들이 돌이켜서 어린아이들과 가축과 물품을 앞에 두고 진행하더니","reference":"사사기 18:21","category":"$undefined"},{"id":"7016","book":"사사기","book_name":"사사기","chapter":18,"verse":22,"text":"미가의 집을 멀리 떠난 때에 미가의 이웃집 사람들이 모여서 단 자손을 따라 미쳐서는","reference":"사사기 18:22","category":"$undefined"},{"id":"7017","book":"사사기","book_name":"사사기","chapter":18,"verse":23,"text":"단 자손을 부르는지라 그들이 낯을 돌이켜 미가에게 이르되 `네가 무슨 일로 이같이 모아가지고 왔느냐 ?'","reference":"사사기 18:23","category":"$undefined"},{"id":"7018","book":"사사기","book_name":"사사기","chapter":18,"verse":24,"text":"미가가 가로되 `나의 지은 신들과 제사장을 취하여 갔으니 내게 오히려 있는 것이 무엇이냐 ? 너희가 어찌하여 나더러 무슨 일이냐 ? 하느냐'","reference":"사사기 18:24","category":"$undefined"},{"id":"7019","book":"사사기","book_name":"사사기","chapter":18,"verse":25,"text":"단 자손이 그에게 이르되 `네 목소리를 우리에게 들리게 말라 노한 자들이 너희를 쳐서 네 생명과 네 가족의 생명을 잃게 할까 하노라' 하고","reference":"사사기 18:25","category":"$undefined"},{"id":"7020","book":"사사기","book_name":"사사기","chapter":18,"verse":26,"text":"단 자손이 자기 길을 행한지라 미가가 단 자손이 자기보다 강한 것을 보고 돌이켜 집으로 돌아갔더라","reference":"사사기 18:26","category":"$undefined"},{"id":"7021","book":"사사기","book_name":"사사기","chapter":18,"verse":27,"text":"단 자손이 미가의 지은 것과 그 제사장을 취하고 라이스에 이르러 한가하고 평안한 백성을 만나 칼날로 그들을 치며 불로 그 성읍을 사르되","reference":"사사기 18:27","category":"$undefined"},{"id":"7022","book":"사사기","book_name":"사사기","chapter":18,"verse":28,"text":"그들을 구원할 자가 없었으니 그 성읍이 베드르홉 가까운 골짜기에 있어서 시돈과 상거가 멀고 상종하는 사람도 없음이었더라 단 자손이 성읍을 중건하고 거기 거하며","reference":"사사기 18:28","category":"$undefined"},{"id":"7023","book":"사사기","book_name":"사사기","chapter":18,"verse":29,"text":"이스라엘의 소생 그 조상 단의 이름을 따라 그 성읍을 단이라 하니라 그 성읍의 본 이름은 라이스더라","reference":"사사기 18:29","category":"$undefined"},{"id":"7024","book":"사사기","book_name":"사사기","chapter":18,"verse":30,"text":"단 자손이 자기를 위하여 그 새긴 신상을 세웠고 모세의 손자 게르손의 아들 요나단과 그 자손은 단 지파의 제사장이 되어 이 백성이 사로 잡히는 날까지 이르렀더라","reference":"사사기 18:30","category":"$undefined"},{"id":"7025","book":"사사기","book_name":"사사기","chapter":18,"verse":31,"text":"하나님의 집이 실로에 있을 동안에 미가의 지은 바 새긴 신상이 단 자손에게 있었더라","reference":"사사기 18:31","category":"$undefined"}],"bookSlug":"judges"}]
