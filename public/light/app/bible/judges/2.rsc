2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":2,"verses":[{"id":"6547","book":"사사기","book_name":"사사기","chapter":2,"verse":1,"text":"여호와의 사자가 길갈에서부터 보김에 이르러 가로되 `내가 너희로 애굽에서 나오게 하고 인도하여 너희 열조에게 맹세한 땅으로 이끌어 왔으며 또 내가 이르기를 내가 너희에게 세운 언약을 영원히 어기지 아니하리니","reference":"사사기 2:1","category":"$undefined"},{"id":"6548","book":"사사기","book_name":"사사기","chapter":2,"verse":2,"text":"너희는 이 땅 거민과 언약을 세우지 말며 그들의 단을 헐라 하였거늘 너희가 내 목소리를 청종치 아니하였도다 그리함은 어찜이뇨 ?'","reference":"사사기 2:2","category":"$undefined"},{"id":"6549","book":"사사기","book_name":"사사기","chapter":2,"verse":3,"text":"그러므로 내가 또 말하기를 `내가 그들을 너희 앞에서 쫓아내지 아니하리니 그들이 너희 옆구리에 가시가 될 것이며 그들의 신들이 너희에게 올무가 되리라' 하였노라","reference":"사사기 2:3","category":"$undefined"},{"id":"6550","book":"사사기","book_name":"사사기","chapter":2,"verse":4,"text":"여호와의 사자가 이스라엘 모든 자손에게 이말씀을 이르매 백성이 소리를 높여 운지라","reference":"사사기 2:4","category":"$undefined"},{"id":"6551","book":"사사기","book_name":"사사기","chapter":2,"verse":5,"text":"그러므로 그곳을 이름하여 보김이라 하니라 무리가 거기서 여호와께 제사를 드렸더라","reference":"사사기 2:5","category":"$undefined"},{"id":"6552","book":"사사기","book_name":"사사기","chapter":2,"verse":6,"text":"전에 여호수아가 백성을 보내매 이스라엘 자손이 각기 그 기업으로 가서 땅을 차지하였고","reference":"사사기 2:6","category":"$undefined"},{"id":"6553","book":"사사기","book_name":"사사기","chapter":2,"verse":7,"text":"백성이 여호수아의 사는 날 동안과 여호수아 뒤에 생존한 장로들 곧 여호와께서 이스라엘을 위하여 행하신 모든 큰 일을 본 자의 사는 날 동안에 여호아를 섬겼더라","reference":"사사기 2:7","category":"$undefined"},{"id":"6554","book":"사사기","book_name":"사사기","chapter":2,"verse":8,"text":"여호아의 종 눈의 아들 여호수아가 일백 십세에 죽으매","reference":"사사기 2:8","category":"$undefined"},{"id":"6555","book":"사사기","book_name":"사사기","chapter":2,"verse":9,"text":"무리가 그의 기업의 경내 에브라임 산지 가아스산 북 딤낫 헤레스에 장사하였고","reference":"사사기 2:9","category":"$undefined"},{"id":"6556","book":"사사기","book_name":"사사기","chapter":2,"verse":10,"text":"그 세대 사람도 다 그 열조에게로 돌아갔고 그 후에 일어난 다른 세대는 여호와를 알지 못하며 여호와께서 이스라엘을 위하여 행하신 일도 알지 못하였더라","reference":"사사기 2:10","category":"$undefined"},{"id":"6557","book":"사사기","book_name":"사사기","chapter":2,"verse":11,"text":"이스라엘 자손이 여호와의 목전에 악을 행하여 바알들을 섬기며","reference":"사사기 2:11","category":"$undefined"},{"id":"6558","book":"사사기","book_name":"사사기","chapter":2,"verse":12,"text":"애굽 땅에서 그들을 인도하여 내신 그 열조의 하나님 여호와를 버리고 다른 신 곧 그 사방에 있는 백성의 신들을 좇아 그들에게 절하여 여호와를 진노하시게 하였으되","reference":"사사기 2:12","category":"$undefined"},{"id":"6559","book":"사사기","book_name":"사사기","chapter":2,"verse":13,"text":"곧 그들이 여호와를 버리고 바알과 아스다롯을 섬겼으므로","reference":"사사기 2:13","category":"$undefined"},{"id":"6560","book":"사사기","book_name":"사사기","chapter":2,"verse":14,"text":"여호와께서 이스라엘에게 진노하사 노략하는 자의 손에 붙여 그들로 노략을 당케하시며 또 사방 모든 대적의 손에 파시매 그들이 다시는 대적을 당치 못하였으며","reference":"사사기 2:14","category":"$undefined"},{"id":"6561","book":"사사기","book_name":"사사기","chapter":2,"verse":15,"text":"그들이 어디를 가든지 여호와의 손이 그들에게 재앙을 내리시매 곧 여호와께서 말씀하신 것과 같고 여호와께서 그들에게 맹세하신 것과 같아서 그들의 괴로움이 심하였더라","reference":"사사기 2:15","category":"$undefined"},{"id":"6562","book":"사사기","book_name":"사사기","chapter":2,"verse":16,"text":"여호와께서 사사를 세우사 노략하는 자의 손에서 그들을 건져내게 하셨으나","reference":"사사기 2:16","category":"$undefined"},{"id":"6563","book":"사사기","book_name":"사사기","chapter":2,"verse":17,"text":"그들이 그 사사도 청종치 아니하고 돌이켜 다른 신들을 음란하듯 좇아 그들에게 절하고 여호와의 명령을 순종하던 그 열조의 행한 길을 속히 치우쳐 떠나서 그와 같이 행치 아니하였더라","reference":"사사기 2:17","category":"$undefined"},{"id":"6564","book":"사사기","book_name":"사사기","chapter":2,"verse":18,"text":"여호와께서 그들을 위하여 사사를 세우실 때에는 그 사사와 함께 하셨고 그 사사의 사는 날 동안에는 여호와께서 그들을 대적의 손에서 구원하셨으니 이는 그들이 대적에게 압박과 괴롭게 함을 받아 슬피 부르짖으므로 여호와께서 뜻을 돌이키셨음이어늘","reference":"사사기 2:18","category":"$undefined"},{"id":"6565","book":"사사기","book_name":"사사기","chapter":2,"verse":19,"text":"그 사사가 죽은 후에는 그들이 돌이켜 그 열조보다 더욱 패괴하여 다른 신들을 좇아 섬겨 그들에게 절하고 그 행위와 패역한 길을 그치지 아니하였으므로","reference":"사사기 2:19","category":"$undefined"},{"id":"6566","book":"사사기","book_name":"사사기","chapter":2,"verse":20,"text":"여호와께서 이스라엘에게 진노하여 이르시되 이 백성이 내가 그 열조와 세운 언약을 어기고 나의 목소리를 청종치 아니하였은즉","reference":"사사기 2:20","category":"$undefined"},{"id":"6567","book":"사사기","book_name":"사사기","chapter":2,"verse":21,"text":"나도 여호수아가 죽을 때에 남겨둔 열국을 다시는 그들의 앞에서 하나도 쫓아내지 아니하리니","reference":"사사기 2:21","category":"$undefined"},{"id":"6568","book":"사사기","book_name":"사사기","chapter":2,"verse":22,"text":"이는 이스라엘이 그 열조의 지킨 것같이 나 여호와의 도를 지켜 행하나 아니하나 그들로 시험하려 함이라 하시니라","reference":"사사기 2:22","category":"$undefined"},{"id":"6569","book":"사사기","book_name":"사사기","chapter":2,"verse":23,"text":"그 열국을 머물러두사 속히 쫓아내지 아니하시며 여호수아의 손에 붙이지 아니하셨음이 이를 인함이었더라","reference":"사사기 2:23","category":"$undefined"}],"bookSlug":"judges"}]
