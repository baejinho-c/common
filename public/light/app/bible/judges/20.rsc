2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":20,"verses":[{"id":"7056","book":"사사기","book_name":"사사기","chapter":20,"verse":1,"text":"이에 모든 이스라엘 자손이 단에서부터 브엘세바까지와 길르앗 땅에서 나왔는데 그 회중이 일제히 미스바에서 여호와 앞에 모였으니","reference":"사사기 20:1","category":"$undefined"},{"id":"7057","book":"사사기","book_name":"사사기","chapter":20,"verse":2,"text":"온 백성의 어른 곧 이스라엘 모든 지파의 어른들은 하나님 백성의 총회에 섰고 칼을 빼는 보병은 사십만이었으며","reference":"사사기 20:2","category":"$undefined"},{"id":"7058","book":"사사기","book_name":"사사기","chapter":20,"verse":3,"text":"이스라엘 자손의 미스바에 올라간 것을 베냐민 자손이 들었더라 이스라엘 자손이 가로되 `이 악한 일의 정형을 우리에게 고하라'","reference":"사사기 20:3","category":"$undefined"},{"id":"7059","book":"사사기","book_name":"사사기","chapter":20,"verse":4,"text":"레위 사람 곧 죽임을 당한 여인의 남편이 대답하여 가로되 `내가 내 첩으로 더불어 베냐민에 속한 기브아에 유숙하러 갔더니","reference":"사사기 20:4","category":"$undefined"},{"id":"7060","book":"사사기","book_name":"사사기","chapter":20,"verse":5,"text":"기브아 사람들이 나를 치러 일어나서 밤에 나의 우거한 집을 에워싸고 나를 죽이려 하고 내 첩을 욕보여서 그로 죽게 한지라","reference":"사사기 20:5","category":"$undefined"},{"id":"7061","book":"사사기","book_name":"사사기","chapter":20,"verse":6,"text":"내가 내 첩의 시체를 취하여 쪼개어 이스라엘 기업의 온 땅에 보내었노니 이는 그들이 이스라엘 중에서 음행과 망령된 일을 행하였음을 인함이로라","reference":"사사기 20:6","category":"$undefined"},{"id":"7062","book":"사사기","book_name":"사사기","chapter":20,"verse":7,"text":"이스라엘 자손들아 ! 너희가 다 여기 있은즉 너희의 의견과 방책을 낼지니라'","reference":"사사기 20:7","category":"$undefined"},{"id":"7063","book":"사사기","book_name":"사사기","chapter":20,"verse":8,"text":"모든 백성이 일제히 일어나며 가로되 `우리가 하나라도 자기 장막으로 돌아가지 아니하며 하나라도 자기 집으로 들어가지 아니하고","reference":"사사기 20:8","category":"$undefined"},{"id":"7064","book":"사사기","book_name":"사사기","chapter":20,"verse":9,"text":"우리가 기브아 사람에게 이렇게 행하리니 곧 제비뽑아서 그들을 치되","reference":"사사기 20:9","category":"$undefined"},{"id":"7065","book":"사사기","book_name":"사사기","chapter":20,"verse":10,"text":"우리가 이스라엘 모든 지파 중에서 백에 열, 천에 백, 만에 천을 취하고 그 백성을 위하여 양식을 예비하고 그들로 베냐민의 기브아에 가서 그 무리의 이스라엘 중에서 망령된 일을 행한 대로 징계하게 하리라' 하니라","reference":"사사기 20:10","category":"$undefined"},{"id":"7066","book":"사사기","book_name":"사사기","chapter":20,"verse":11,"text":"이와 같이 이스라엘 모든 사람이 하나 같이 합심하여 그 성읍을 치려고 모였더라","reference":"사사기 20:11","category":"$undefined"},{"id":"7067","book":"사사기","book_name":"사사기","chapter":20,"verse":12,"text":"이스라엘 지파들이 베냐민 온 지파에 사람들을 보내어 두루 행하며 이르기를 `너희 중에서 생긴 이 악이 어찜이뇨 ?","reference":"사사기 20:12","category":"$undefined"},{"id":"7068","book":"사사기","book_name":"사사기","chapter":20,"verse":13,"text":"그런즉 이제 기브아 사람 곧 그 비류를 우리에게 붙여서 우리로 죽여 이스라엘 중에 악을 제하여 버리게 하라' 하나 베냐민 자손이 그 형제 이스라엘 자손의 말을 듣지 아니하고","reference":"사사기 20:13","category":"$undefined"},{"id":"7069","book":"사사기","book_name":"사사기","chapter":20,"verse":14,"text":"도리어 각 성읍에서 기브아에 모이고 나가서 이스라엘 자손과 싸우고자 하니","reference":"사사기 20:14","category":"$undefined"},{"id":"7070","book":"사사기","book_name":"사사기","chapter":20,"verse":15,"text":"그 때에 성읍들에서 나온 베냐민 자손의 수는 칼을 빼는 자가 모두 이만 육천이요 그 외에 기브아 거민 중 택한 자가 칠백인데","reference":"사사기 20:15","category":"$undefined"},{"id":"7071","book":"사사기","book_name":"사사기","chapter":20,"verse":16,"text":"이 모든 백성 중에서 택한 칠 백명은 다 왼손잡이라 물매로 돌을 던지면 호리도 틀림이 없는 자더라","reference":"사사기 20:16","category":"$undefined"},{"id":"7072","book":"사사기","book_name":"사사기","chapter":20,"verse":17,"text":"베냐민 자손 외에 이스라엘 사람의 칼을 빼는 자의 수는 사십만명이니 다 전사라","reference":"사사기 20:17","category":"$undefined"},{"id":"7073","book":"사사기","book_name":"사사기","chapter":20,"verse":18,"text":"이스라엘 자손이 일어나 벧엘에 올라가서 하나님께 묻자와 가로되 우리 중에 누가 먼저 올라가서 베냐민 자손과 싸우리이까 ? 여호와께서 가라사대 유다가 먼저일지니라","reference":"사사기 20:18","category":"$undefined"},{"id":"7074","book":"사사기","book_name":"사사기","chapter":20,"verse":19,"text":"이스라엘 자손이 아침에 일어나 기브아를 대하여 진을 치니라","reference":"사사기 20:19","category":"$undefined"},{"id":"7075","book":"사사기","book_name":"사사기","chapter":20,"verse":20,"text":"이스라엘 사람들이 나가서 항오를 벌이고 거기서 그들과 싸우고자 하매","reference":"사사기 20:20","category":"$undefined"},{"id":"7076","book":"사사기","book_name":"사사기","chapter":20,"verse":21,"text":"베냐민 자손이 기브아에서 나와서 당일에 이스라엘 사람 이만 이천을 땅에 엎드러뜨렸으나","reference":"사사기 20:21","category":"$undefined"},{"id":"7077","book":"사사기","book_name":"사사기","chapter":20,"verse":22,"text":"이스라엘 사람들이 스스로 용기를 내어 첫날 항오를 벌였던 곳에 다시 항오를 벌이니라","reference":"사사기 20:22","category":"$undefined"},{"id":"7078","book":"사사기","book_name":"사사기","chapter":20,"verse":23,"text":"이스라엘 자손이 올라가서 여호와 앞에서 저물도록 울며 여호와께 묻자와 가로되 `내가 다시 나아가서 나의 형제 베냐민 자손과 싸우리이까 ?' 여호와께서 가라사대 올라가서 치라 하시니라","reference":"사사기 20:23","category":"$undefined"},{"id":"7079","book":"사사기","book_name":"사사기","chapter":20,"verse":24,"text":"그 이튿날에 이스라엘 자손이 베냐민 자손을 치러 나아가매","reference":"사사기 20:24","category":"$undefined"},{"id":"7080","book":"사사기","book_name":"사사기","chapter":20,"verse":25,"text":"베냐민도 그 이튿날에 기브아에서 그들을 치러 나와서 다시 이스라엘 자손 일만 팔천을 땅에 엎드러뜨렸으니 다 칼을 빼는 자였더라","reference":"사사기 20:25","category":"$undefined"},{"id":"7081","book":"사사기","book_name":"사사기","chapter":20,"verse":26,"text":"이에 온 이스라엘 자손 모든 백성이 올라가서 벧엘에 이르러 울며 거기서 여호와 앞에 앉고 그 날이 저물도록 금식하고 번제와 화목제를 여호와 앞에 드리고","reference":"사사기 20:26","category":"$undefined"},{"id":"7082","book":"사사기","book_name":"사사기","chapter":20,"verse":27,"text":"여호와께 물으니라 (그 때에는 하나님의 언약궤가 거기 있고","reference":"사사기 20:27","category":"$undefined"},{"id":"7083","book":"사사기","book_name":"사사기","chapter":20,"verse":28,"text":"아론의 손자 엘르아살의 아들 비느하스가 그 앞에 모셨더라) 이스라엘 자손이 묻자오되 `내가 다시 나가 나의 형제 베냐민 자손과 싸우리이까 말리이까' 여호와께서 가라사대 올라가라 내일은 내가 그를 네 손에 붙이리라","reference":"사사기 20:28","category":"$undefined"},{"id":"7084","book":"사사기","book_name":"사사기","chapter":20,"verse":29,"text":"이스라엘이 기브아 사면에 군사를 매복하니라","reference":"사사기 20:29","category":"$undefined"},{"id":"7085","book":"사사기","book_name":"사사기","chapter":20,"verse":30,"text":"이스라엘 자손이 제 삼일에 베냐민 자손에게로 치러 올라가서 전과 같이 기브아를 대하여 항오를 벌이매","reference":"사사기 20:30","category":"$undefined"},{"id":"7086","book":"사사기","book_name":"사사기","chapter":20,"verse":31,"text":"베냐민 자손이 나와서 백성을 맞더니 꾀임에 빠져 성읍을 떠났더라 그들이 큰 길 곧 한편은 벧엘로 올라가는 길이요 한편은 기브아의 들로 가는 길에서 백성을 쳐서 전과 같이 이스라엘 사람 삼십명 가량을 죽이기 시작하며","reference":"사사기 20:31","category":"$undefined"},{"id":"7087","book":"사사기","book_name":"사사기","chapter":20,"verse":32,"text":"스스로 이르기를 이들이 처음과 같이 우리 앞에서 패한다하나 이스라엘 자손은 이르기를 `우리가 도망하여 그들을 성읍에서 큰 길로 꾀어내자' 하고","reference":"사사기 20:32","category":"$undefined"},{"id":"7088","book":"사사기","book_name":"사사기","chapter":20,"verse":33,"text":"이스라엘 사람이 모두 그 처소에서 일어나서 바알다말에 항오를 벌였고 그 복병은 그 처소 곧 기브아 초장에서 쏟아져 나왔더라","reference":"사사기 20:33","category":"$undefined"},{"id":"7089","book":"사사기","book_name":"사사기","chapter":20,"verse":34,"text":"온 이스라엘 사람 중에서 택한 사람 일만이 기브아에 이르러 치매 싸움이 심히 맹렬하나 베냐민 사람은 화가 자기에게 미친 줄을 알지 못하였더라","reference":"사사기 20:34","category":"$undefined"},{"id":"7090","book":"사사기","book_name":"사사기","chapter":20,"verse":35,"text":"여호와께서 이스라엘 앞에서 베냐민을 쳐서 파하게 하시매 당일에 이스라엘 자손이 베냐민 사람 이만 오천 일백을 죽였으니 다 칼을 빼는 자이었더라","reference":"사사기 20:35","category":"$undefined"},{"id":"7091","book":"사사기","book_name":"사사기","chapter":20,"verse":36,"text":"이에 베냐민 자손이 자기가 패한 것을 깨달았으니 이는 이스라엘 사람이 기브아에 매복한 군사를 믿고 잠간 베냐민 사람 앞을 피하매","reference":"사사기 20:36","category":"$undefined"},{"id":"7092","book":"사사기","book_name":"사사기","chapter":20,"verse":37,"text":"복병이 급히 나와 기브아에 돌입하고 나아가며 칼날로 온 성읍을 쳤음이더라","reference":"사사기 20:37","category":"$undefined"},{"id":"7093","book":"사사기","book_name":"사사기","chapter":20,"verse":38,"text":"처음에 이스라엘 사람과 복병 사이에 상약하기를 `성읍에서 큰 연기가 치미는 것으로 군호를 삼자' 하고","reference":"사사기 20:38","category":"$undefined"},{"id":"7094","book":"사사기","book_name":"사사기","chapter":20,"verse":39,"text":"이스라엘 사람은 싸우다가 물러가고 베냐민 사람은 이스라엘 사람 삼십명 가량을 쳐 죽이기를 시작하며 이르기를 `이들이 정녕 처음 싸움같이 우리에게 패한다' 하다가","reference":"사사기 20:39","category":"$undefined"},{"id":"7095","book":"사사기","book_name":"사사기","chapter":20,"verse":40,"text":"연기 구름이 기둥 같이 성읍 가운데서 일어날 때에 베냐민 사람이 돌아보매 온 성읍에 연기가 하늘에 닿았고","reference":"사사기 20:40","category":"$undefined"},{"id":"7096","book":"사사기","book_name":"사사기","chapter":20,"verse":41,"text":"이스라엘 사람은 돌이키는지라 베냐민 사람이 화가 자기에게 미친 것을 보고 심히 놀라","reference":"사사기 20:41","category":"$undefined"},{"id":"7097","book":"사사기","book_name":"사사기","chapter":20,"verse":42,"text":"이스라엘 사람 앞에서 몸을 돌이켜 광야 길로 향하였으나 군사가 급히 추격하며 각 성읍에서 나온 자를 그 가운데서 진멸하니라","reference":"사사기 20:42","category":"$undefined"},{"id":"7098","book":"사사기","book_name":"사사기","chapter":20,"verse":43,"text":"그들이 베냐민 사람을 에워쌌더니 기브아 앞 동편까지 쫓으며 그 쉬는 곳에서 짓밟으매","reference":"사사기 20:43","category":"$undefined"},{"id":"7099","book":"사사기","book_name":"사사기","chapter":20,"verse":44,"text":"베냐민 중에서 엎드러진 자가 일만 팔천이니 다 용사더라","reference":"사사기 20:44","category":"$undefined"},{"id":"7100","book":"사사기","book_name":"사사기","chapter":20,"verse":45,"text":"그들이 몸을 돌이켜 광야로 도망하여 림몬 바위에 이르는 큰길에서 이스라엘이 또 오천명을 이삭 줍듯 하고 또 급히 따라 기돔에 이르러 또 이천명을 죽였으니","reference":"사사기 20:45","category":"$undefined"},{"id":"7101","book":"사사기","book_name":"사사기","chapter":20,"verse":46,"text":"이 날에 베냐민의 칼을 빼는 자의 엎드러진 것이 모두 이만 오천이니 다 용사더라","reference":"사사기 20:46","category":"$undefined"},{"id":"7102","book":"사사기","book_name":"사사기","chapter":20,"verse":47,"text":"베냐민 육백명이 돌이켜 광야로 도망하여 림몬 바위에 이르러 거기서 넉달을 지내었더라","reference":"사사기 20:47","category":"$undefined"},{"id":"7103","book":"사사기","book_name":"사사기","chapter":20,"verse":48,"text":"이스라엘 사람이 베냐민 자손에게로 돌아와서 온 성읍과 가축과 만나는 자를 다 칼날로 치고 닥치는 성읍마다 다 불살랐더라","reference":"사사기 20:48","category":"$undefined"}],"bookSlug":"judges"}]
