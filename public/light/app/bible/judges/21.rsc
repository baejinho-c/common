2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":21,"verses":[{"id":"7104","book":"사사기","book_name":"사사기","chapter":21,"verse":1,"text":"이스라엘 사람들이 미스바에서 맹세하여 이르기를 `우리 중에 누구든지 딸을 베냐민 사람에게 아내로 주지 아니하리라' 하였더라","reference":"사사기 21:1","category":"$undefined"},{"id":"7105","book":"사사기","book_name":"사사기","chapter":21,"verse":2,"text":"백성이 벧엘에 이르러 거기서 저녁까지 하나님 앞에 앉아서 대성 통곡하여","reference":"사사기 21:2","category":"$undefined"},{"id":"7106","book":"사사기","book_name":"사사기","chapter":21,"verse":3,"text":"가로되 `이스라엘의 하나님 여호와여 ! 오늘날 이스라엘 중에 어찌하여 한 지파가 이즈러졌나이까 ?' 하더니","reference":"사사기 21:3","category":"$undefined"},{"id":"7107","book":"사사기","book_name":"사사기","chapter":21,"verse":4,"text":"이튿날에 백성이 일찌기 일어나서 거기 한 단을 쌓고 번제와 화목제를 드렸더라","reference":"사사기 21:4","category":"$undefined"},{"id":"7108","book":"사사기","book_name":"사사기","chapter":21,"verse":5,"text":"이스라엘 자손이 가로되 `이스라엘 온 지파 중에 총회와 함께 하여 여호와 앞에 올라오지 아니한 자가 누구뇨? 하니 이는 그들이 크게 맹세하기를 미스바에 와서 여호와 앞에 이르지 아니하는 자는 반드시 죽일 것이라 하였음이라","reference":"사사기 21:5","category":"$undefined"},{"id":"7109","book":"사사기","book_name":"사사기","chapter":21,"verse":6,"text":"이스라엘 자손이 그 형제 베냐민을 위하여 뉘우쳐 가로되 `오늘날 이스라엘 중에 한 지파가 끊쳤도다","reference":"사사기 21:6","category":"$undefined"},{"id":"7110","book":"사사기","book_name":"사사기","chapter":21,"verse":7,"text":"그 남은 자들에게 우리가 어떻게 하면 아내를 얻게 하리요 우리가 전에 여호와로 맹세하여 우리 딸을 그들의 아내로 주지 아니하리라' 하였도다","reference":"사사기 21:7","category":"$undefined"},{"id":"7111","book":"사사기","book_name":"사사기","chapter":21,"verse":8,"text":"또 가로되 `이스라엘 지파 중 미스바에 올라와서 여호와께 이르지 아니한 자가 누구뇨 ?' 하고 본즉 야베스 길르앗에서는 한 사람도 진에 이르러 총회에 참여치 아니하였으니","reference":"사사기 21:8","category":"$undefined"},{"id":"7112","book":"사사기","book_name":"사사기","chapter":21,"verse":9,"text":"백성을 계수할 때에 야베스 길르앗 거민이 하나도 거기 없음을 보았음이라","reference":"사사기 21:9","category":"$undefined"},{"id":"7113","book":"사사기","book_name":"사사기","chapter":21,"verse":10,"text":"회중이 큰 용사 일만 이천을 그리로 보내며 그들에게 명하여 가로되 가서 야베스 길르앗 거민과 및 부녀와 어린 아이를 칼날로 치라","reference":"사사기 21:10","category":"$undefined"},{"id":"7114","book":"사사기","book_name":"사사기","chapter":21,"verse":11,"text":"너희의 행할 일은 모든 남자와 남자와 잔 여자를 진멸할 것이니라 하였더니","reference":"사사기 21:11","category":"$undefined"},{"id":"7115","book":"사사기","book_name":"사사기","chapter":21,"verse":12,"text":"그들이 야베스 길르앗 거민 중에서 젊은 처녀 사백인을 얻었으니 이는 아직 남자와 자지 아니하여서 남자를 알지 못하는 자라 그들이 실로 진으로 끌어 오니라 이는 가나안 땅이더라","reference":"사사기 21:12","category":"$undefined"},{"id":"7116","book":"사사기","book_name":"사사기","chapter":21,"verse":13,"text":"온 회중이 림몬 바위에 있는 베냐민 자손에게 보내어 평화를 공포하게 하였더니","reference":"사사기 21:13","category":"$undefined"},{"id":"7117","book":"사사기","book_name":"사사기","chapter":21,"verse":14,"text":"그 때에 베냐민이 돌아온지라 이에 이스라엘 사람이 야베스 길르앗 여인 중에서 살려둔 여자를 그들에게 주었으나 오히려 부족하므로","reference":"사사기 21:14","category":"$undefined"},{"id":"7118","book":"사사기","book_name":"사사기","chapter":21,"verse":15,"text":"백성들이 베냐민을 위하여 뉘우쳤으니 이는 여호와께서 이스라엘 지파들 중에 한 지파가 궐이 나게 하셨음이더라","reference":"사사기 21:15","category":"$undefined"},{"id":"7119","book":"사사기","book_name":"사사기","chapter":21,"verse":16,"text":"회중 장로들이 가로되 `베냐민의 여인이 다 멸절되었으니 이제 그 남은 자들에게 어떻게 하여야 아내를 얻게 할꼬 ?'","reference":"사사기 21:16","category":"$undefined"},{"id":"7120","book":"사사기","book_name":"사사기","chapter":21,"verse":17,"text":"또 가로되 `베냐민의 도망하여 면한 자에게 마땅히 기업이 있어야 하리니 그리하면 이스라엘 중에 한 지파가 사라짐이 없으리라","reference":"사사기 21:17","category":"$undefined"},{"id":"7121","book":"사사기","book_name":"사사기","chapter":21,"verse":18,"text":"그러나 우리가 우리의 딸을 그들의 아내로 주지 못하리니 이는 이스라엘 자손이 맹세하여 이르기를 딸을 베냐민에게 아내로 주는 자는 저주를 받으리라 하였음이로다'","reference":"사사기 21:18","category":"$undefined"},{"id":"7122","book":"사사기","book_name":"사사기","chapter":21,"verse":19,"text":"또 가로되 `보라, 벧엘 북편, 르보나 남편 벧엘에서 세겜으로 올라가는 큰길 동편 실로에 매년 여호와의 절기가 있도다' 하고","reference":"사사기 21:19","category":"$undefined"},{"id":"7123","book":"사사기","book_name":"사사기","chapter":21,"verse":20,"text":"베냐민 자손에게 명하여 가로되 `가서 포도원에 숨어","reference":"사사기 21:20","category":"$undefined"},{"id":"7124","book":"사사기","book_name":"사사기","chapter":21,"verse":21,"text":"보다가 실로의 여자들이 무도하러 나오거든 너희는 포도원에서 나와서 실로의 딸 중에서 각각 그 아내로 붙들어 가지고 베냐민 땅으로 돌아가라","reference":"사사기 21:21","category":"$undefined"},{"id":"7125","book":"사사기","book_name":"사사기","chapter":21,"verse":22,"text":"만일 그 아비나 형제가 와서 우리에게 쟁론하면 우리가 그에게 말하기를 청컨대 너희는 우리에게 은혜를 베풀어 그들을 우리에게 줄지니라 이는 우리가 전쟁할 때에 각 사람을 위하여 그 아내를 얻어 주지 못하였고 너희가 자의로 그들에게 준것이 아니니 너희에게 죄가 없을 것임이니라 하겠노라' 하매","reference":"사사기 21:22","category":"$undefined"},{"id":"7126","book":"사사기","book_name":"사사기","chapter":21,"verse":23,"text":"베냐민 자손이 그같이 행하여 춤추는 여자 중에서 자기들의 수효대로 아내로 붙들어 가지고 자기 기업에 돌아가서 성읍들을 중건하고 거기 거하니라","reference":"사사기 21:23","category":"$undefined"},{"id":"7127","book":"사사기","book_name":"사사기","chapter":21,"verse":24,"text":"그 때에 이스라엘 자손이 그곳을 떠나 각각 그 지파, 그 가족에게로 돌아가되 곧 각각 그곳에서 나와서 자기 기업으로 돌아갔더라","reference":"사사기 21:24","category":"$undefined"},{"id":"7128","book":"사사기","book_name":"사사기","chapter":21,"verse":25,"text":"그 때에 이스라엘에 왕이 없으므로 사람이 각각 그 소견에 옳은 대로 행하였더라","reference":"사사기 21:25","category":"$undefined"}],"bookSlug":"judges"}]
