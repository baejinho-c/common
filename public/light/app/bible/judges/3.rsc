2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":3,"verses":[{"id":"6570","book":"사사기","book_name":"사사기","chapter":3,"verse":1,"text":"여호와께서 가나안 전쟁을 알지 못한 이스라엘을 시험하려 하시며","reference":"사사기 3:1","category":"$undefined"},{"id":"6571","book":"사사기","book_name":"사사기","chapter":3,"verse":2,"text":"이스라엘 자손의 세대 중에 아직 전쟁을 알지 못하는 자에게 그것을 가르쳐 알게 하려하사 남겨 두신 열국은","reference":"사사기 3:2","category":"$undefined"},{"id":"6572","book":"사사기","book_name":"사사기","chapter":3,"verse":3,"text":"블레셋 다섯 방백과 가나안 모든 사람과 시돈 사람과 바알헤르몬 산에서부터 하맛 어구까지 레바논 산에 거하는 히위 사람이라","reference":"사사기 3:3","category":"$undefined"},{"id":"6573","book":"사사기","book_name":"사사기","chapter":3,"verse":4,"text":"남겨두신 이 열국으로 이스라엘을 시험하사 여호와께서 모세로 그들의 열조에게 명하신 명령들을 청종하나 알고자 하셨더라","reference":"사사기 3:4","category":"$undefined"},{"id":"6574","book":"사사기","book_name":"사사기","chapter":3,"verse":5,"text":"이스라엘 자손은 마침내 가나안 사람과, 헷 사람과, 아모리 사람과, 브리스 사람과, 히위 사람과, 여부스 사람 사이에 거하여","reference":"사사기 3:5","category":"$undefined"},{"id":"6575","book":"사사기","book_name":"사사기","chapter":3,"verse":6,"text":"그들의 딸들을 취하여 아내를 삼으며 자기 딸들을 그들의 아들에게 주며 또 그들의 신들을 섬겼더라","reference":"사사기 3:6","category":"$undefined"},{"id":"6576","book":"사사기","book_name":"사사기","chapter":3,"verse":7,"text":"이스라엘 자손이 여호와 목전에 악을 행하여 자기들의 하나님 여호와를 잊어버리고 바알들과 아세라들을 섬긴지라","reference":"사사기 3:7","category":"$undefined"},{"id":"6577","book":"사사기","book_name":"사사기","chapter":3,"verse":8,"text":"여호와께서 이스라엘에게 진노하사 그들을 메소보다미아 왕 구산리사다임의 손에 파셨으므로 이스라엘 자손이 구산 리사다임을 팔년을 섬겼더니","reference":"사사기 3:8","category":"$undefined"},{"id":"6578","book":"사사기","book_name":"사사기","chapter":3,"verse":9,"text":"이스라엘 자손이 여호와께 부르짖으매 여호와께서 그들을 위하여 한 구원자를 세워 구원하게 하시니 그는 곧 갈렙의 아우 그나스의 아들 옷니엘이라","reference":"사사기 3:9","category":"$undefined"},{"id":"6579","book":"사사기","book_name":"사사기","chapter":3,"verse":10,"text":"여호와의 신이 그에게 임하셨으므로 그가 이스라엘 사사가 되어 나가서 싸울 때에 여호와께서 메소보다미아 왕 구산 리사다임을 그 손에 붙이시매 옷니엘의 손이 구산 리사다임을 이기니라","reference":"사사기 3:10","category":"$undefined"},{"id":"6580","book":"사사기","book_name":"사사기","chapter":3,"verse":11,"text":"그 땅이 태평한 지 사십년에 그나스의 아들 옷니엘이 죽었더라","reference":"사사기 3:11","category":"$undefined"},{"id":"6581","book":"사사기","book_name":"사사기","chapter":3,"verse":12,"text":"이스라엘 자손이 또 여호와의 목전에 악을 행하니라 이스라엘 자손이 여호와의 목전에 악을 행하므로 여호와께서 모압 왕 에글론을 강성케 하사 그들을 대적하게 하시매","reference":"사사기 3:12","category":"$undefined"},{"id":"6582","book":"사사기","book_name":"사사기","chapter":3,"verse":13,"text":"에글론이 암몬과 아말렉 자손들을 모아가지고 와서 이스라엘을 쳐서 종려나무 성읍을 점령한지라","reference":"사사기 3:13","category":"$undefined"},{"id":"6583","book":"사사기","book_name":"사사기","chapter":3,"verse":14,"text":"이에 이스라엘 자손이 모압 왕 에글론을 십 팔년을 섬기니라","reference":"사사기 3:14","category":"$undefined"},{"id":"6584","book":"사사기","book_name":"사사기","chapter":3,"verse":15,"text":"이스라엘 자손이 여호와께 부르짖으매 여호와께서 그들을 위하여 한 구원자를 세우셨으니 그는 곧 베냐민 사람 게라의 아들 왼손 잡이 에훗이라 이스라엘 자손이 그를 의탁하여 모압 왕 에글론에게 공물을 바칠 때에","reference":"사사기 3:15","category":"$undefined"},{"id":"6585","book":"사사기","book_name":"사사기","chapter":3,"verse":16,"text":"에훗이 장이 한 규빗 되는 좌우에 날선 칼을 만들어 우편 다리 옷 속에 차고","reference":"사사기 3:16","category":"$undefined"},{"id":"6586","book":"사사기","book_name":"사사기","chapter":3,"verse":17,"text":"공물을 모압 왕 에글론에게 바쳤는데 에글론은 심히 비둔한 자이었더라","reference":"사사기 3:17","category":"$undefined"},{"id":"6587","book":"사사기","book_name":"사사기","chapter":3,"verse":18,"text":"에훗이 공물 바치기를 마친 후에 공물을 메고 온 자들을 보내고","reference":"사사기 3:18","category":"$undefined"},{"id":"6588","book":"사사기","book_name":"사사기","chapter":3,"verse":19,"text":"자기는 길갈 근처 돌 뜨는 곳에서부터 돌아와서 가로되 `왕이여, 내가 은밀한 일을 왕에게 고하려 하나이다' 왕이 명하여 `종용케 하라' 하매 모셔 선 자들이 다 물러간지라","reference":"사사기 3:19","category":"$undefined"},{"id":"6589","book":"사사기","book_name":"사사기","chapter":3,"verse":20,"text":"에훗이 왕의 앞으로 나아가니 왕은 서늘한 다락방에 홀로 앉아 있는 중이라 에훗이 가로되 `내가 하나님의 명을 받들어 왕에게 고할 일이 있나이다' 하매 왕이 그 좌석에서 일어나니","reference":"사사기 3:20","category":"$undefined"},{"id":"6590","book":"사사기","book_name":"사사기","chapter":3,"verse":21,"text":"에훗이 왼손으로 우편 다리에서 칼을 빼어 왕의 몸을 찌르매","reference":"사사기 3:21","category":"$undefined"},{"id":"6591","book":"사사기","book_name":"사사기","chapter":3,"verse":22,"text":"칼자루도 날을 따라 들어가서 그 끝이 등뒤까지 나갔고 그가 칼을 그 몸에서 빼어내지 아니하였으므로 기름이 칼날에 엉기었더라","reference":"사사기 3:22","category":"$undefined"},{"id":"6592","book":"사사기","book_name":"사사기","chapter":3,"verse":23,"text":"에훗이 현관에 나와서 다락문들을 닫아 잠그니라","reference":"사사기 3:23","category":"$undefined"},{"id":"6593","book":"사사기","book_name":"사사기","chapter":3,"verse":24,"text":"에훗이 나간 후에 왕의 신하들이 와서 다락문이 잠겼음을 보고 가로되 `왕이 필연 다락방에서 발을 가리우신다' 하고","reference":"사사기 3:24","category":"$undefined"},{"id":"6594","book":"사사기","book_name":"사사기","chapter":3,"verse":25,"text":"그들이 오래 기다려도 왕이 다락문을 열지 아니하는지라 열쇠를 취하여 열고 본즉 자기 주가 이미 죽어 땅에 엎드러졌더라","reference":"사사기 3:25","category":"$undefined"},{"id":"6595","book":"사사기","book_name":"사사기","chapter":3,"verse":26,"text":"그들의 기다리는 동안에 에훗이 피하여 돌 뜨는 곳을 지나 스이라로 도망하니라","reference":"사사기 3:26","category":"$undefined"},{"id":"6596","book":"사사기","book_name":"사사기","chapter":3,"verse":27,"text":"그가 이르러서는 에브라임 산지에서 나팔을 불매 이스라엘 자손이 산지에서 그를 따라 내려오니 에훗이 앞서 가며","reference":"사사기 3:27","category":"$undefined"},{"id":"6597","book":"사사기","book_name":"사사기","chapter":3,"verse":28,"text":"무리에게 이르되 `나를 따르라 ! 여호와께서 너희 대적 모압 사람을 너희의 손에 붙이셨느니라' 하매 무리가 에훗을 따라 내려가서 모압 맞은편 요단강 나루를 잡아 지켜 한 사람도 건너지 못하게 하였고","reference":"사사기 3:28","category":"$undefined"},{"id":"6598","book":"사사기","book_name":"사사기","chapter":3,"verse":29,"text":"그 때에 모압 사람 일만명 가량을 죽였으니 다 역사요 용사라 한 사람도 피하지 못하였더라","reference":"사사기 3:29","category":"$undefined"},{"id":"6599","book":"사사기","book_name":"사사기","chapter":3,"verse":30,"text":"그날에 모압 사람이 이스라엘의 수하에 항복하매 그 땅이 팔십년 동안 태평하였더라","reference":"사사기 3:30","category":"$undefined"},{"id":"6600","book":"사사기","book_name":"사사기","chapter":3,"verse":31,"text":"에훗의 후에 아낫의 아들 삼갈이 사사로 있어 소 모는 막대기로 블레셋 사람 육백명을 죽였고 그도 이스라엘을 구원하였더라","reference":"사사기 3:31","category":"$undefined"}],"bookSlug":"judges"}]
