2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":4,"verses":[{"id":"6601","book":"사사기","book_name":"사사기","chapter":4,"verse":1,"text":"에훗의 죽은 후에 이스라엘 자손이 또 여호와의 목전에 악을 행하매","reference":"사사기 4:1","category":"$undefined"},{"id":"6602","book":"사사기","book_name":"사사기","chapter":4,"verse":2,"text":"여호와께서 하솔에 도읍한 가나안 왕 야빈의 손에 그들을 파셨는데 그 군대 장관은 이방 하로셋에 거하는 시스라요","reference":"사사기 4:2","category":"$undefined"},{"id":"6603","book":"사사기","book_name":"사사기","chapter":4,"verse":3,"text":"야빈 왕은 철병거 구백승이 있어서 이십년 동안 이스라엘 자손을 심히 학대한 고로 이스라엘 자손이 여호와께 부르짖었더라","reference":"사사기 4:3","category":"$undefined"},{"id":"6604","book":"사사기","book_name":"사사기","chapter":4,"verse":4,"text":"그 때에 랍비돗의 아내 여선지 드보라가 이스라엘의 사사가 되었는데","reference":"사사기 4:4","category":"$undefined"},{"id":"6605","book":"사사기","book_name":"사사기","chapter":4,"verse":5,"text":"그는 에브라임 산지 라마와 벧엘 사이 드보라의 종려나무 아래 거하였고 이스라엘 자손은 그에게 나아가 재판을 받더라","reference":"사사기 4:5","category":"$undefined"},{"id":"6606","book":"사사기","book_name":"사사기","chapter":4,"verse":6,"text":"드보라가 보내어 아비노암의 아들 바락을 납달리 게데스에서 불러다가 그에게 이르되 `이스라엘 하나님 여호와께서 이같이 명하지 아니하셨느냐 ? 이르시기를 너는 납달리 자손과 스불론 자손 일만명을 거느리고 다볼 산으로 가라","reference":"사사기 4:6","category":"$undefined"},{"id":"6607","book":"사사기","book_name":"사사기","chapter":4,"verse":7,"text":"내가 야빈의 군대 장관 시스라와 그 병거들과 그 무리를 기손강으로 이끌어 네게 이르게 하고 그를 네 손에 붙이리라 하셨느니라'","reference":"사사기 4:7","category":"$undefined"},{"id":"6608","book":"사사기","book_name":"사사기","chapter":4,"verse":8,"text":"바락이 그에게 이르되 `당신이 나와 함께 가면 내가 가려니와 당신이 나와 함께 가지 아니하면 나는 가지 않겠노라'","reference":"사사기 4:8","category":"$undefined"},{"id":"6609","book":"사사기","book_name":"사사기","chapter":4,"verse":9,"text":"가로되 `내가 반드시 너와 함께 가리라 그러나 네가 이제 가는 일로는 영광을 얻지 못하리니 이는 여호와께서 시스라를 여인의 손에 파실 것임이니라' 하고 드보라가 일어나 바락과 함께 게데스로 가니라","reference":"사사기 4:9","category":"$undefined"},{"id":"6610","book":"사사기","book_name":"사사기","chapter":4,"verse":10,"text":"바락이 스불론과 납달리를 게데스로 부르니 일만인이 그를 따라 올라가고 드보라도 그와 함께 올라가니라","reference":"사사기 4:10","category":"$undefined"},{"id":"6611","book":"사사기","book_name":"사사기","chapter":4,"verse":11,"text":"모세의 장인 호밥의 자손중 겐 사람 헤벨이 자기 족속을 떠나 게데스에 가까운 사아난님 상수리나무 곁에 이르러 장막을 쳤더라","reference":"사사기 4:11","category":"$undefined"},{"id":"6612","book":"사사기","book_name":"사사기","chapter":4,"verse":12,"text":"아비노암의 아들 바락이 다볼산에 오른 것을 혹이 시스라에게 고하매","reference":"사사기 4:12","category":"$undefined"},{"id":"6613","book":"사사기","book_name":"사사기","chapter":4,"verse":13,"text":"시스라가 모든 병거 곧 철병거 구백승과 자기와 함께 있는 온 군사를 이방 하로셋에서부터 기손강으로 모은지라","reference":"사사기 4:13","category":"$undefined"},{"id":"6614","book":"사사기","book_name":"사사기","chapter":4,"verse":14,"text":"드보라가 바락에게 이르되 `일어나라 ! 이는 여호와께서 시스라를 네 손에 붙이신 날이라 여호와께서 너의 앞서 행하지 아니하시느냐 ?' 이에 바락이 일만명을 거느리고 다볼 산에서 내려가니","reference":"사사기 4:14","category":"$undefined"},{"id":"6615","book":"사사기","book_name":"사사기","chapter":4,"verse":15,"text":"여호와께서 바락의 앞에서 시스라와 그 모든 병거와 그 온 군대를 칼날로 쳐서 패하게 하시매 시스라가 병거에서 내려 도보로 도망한지라","reference":"사사기 4:15","category":"$undefined"},{"id":"6616","book":"사사기","book_name":"사사기","chapter":4,"verse":16,"text":"바락이 그 병거들과 군대를 추격하여 이방 하로셋에 이르니 시스라의 온 군대가 다 칼에 엎드러졌고 남은 자가 없었더라","reference":"사사기 4:16","category":"$undefined"},{"id":"6617","book":"사사기","book_name":"사사기","chapter":4,"verse":17,"text":"시스라가 도보로 도망하여 겐사람 헤벨의 아내 야엘의 장막에 이르렀으니 하솔 왕 야빈은 겐 사람 헤벨의 집과 화평이 있음이라","reference":"사사기 4:17","category":"$undefined"},{"id":"6618","book":"사사기","book_name":"사사기","chapter":4,"verse":18,"text":"야엘이 나가 시스라를 영접하며 그에게 말하되 `나의 주여 ! 들어오소서 내게로 들어오시고 두려워하지 마소서' 하매 그 장막에 들어가니 야엘이 이불로 덮으니라","reference":"사사기 4:18","category":"$undefined"},{"id":"6619","book":"사사기","book_name":"사사기","chapter":4,"verse":19,"text":"시스라가 그에게 말하되 `청하노니 내게 물을 조금 마시우라 내가 목이 마르도다` 하매 젖부대를 열어 그에게 마시우고 그를 덮으니","reference":"사사기 4:19","category":"$undefined"},{"id":"6620","book":"사사기","book_name":"사사기","chapter":4,"verse":20,"text":"그가 또 가로되 `장막문에 섰다가 만일 사람이 와서 네게 묻기를 여기 어떤 사람이 있느냐 ? 하거든 너는 없다 하라' 하고","reference":"사사기 4:20","category":"$undefined"},{"id":"6621","book":"사사기","book_name":"사사기","chapter":4,"verse":21,"text":"그가 곤비하여 깊이 잠든지라 헤벨의 아내 야엘이 장막 말뚝을 취하고 손에 방망이를 들고 그에게로 가만히 가서 말뚝을 그 살쩍에 박으매 말뚝이 꿰뚫고 땅에 박히니 시스라가 기절하여 죽으니라","reference":"사사기 4:21","category":"$undefined"},{"id":"6622","book":"사사기","book_name":"사사기","chapter":4,"verse":22,"text":"바락이 시스라를 따를 때에 야엘이 나가서 그를 맞아 가로되 `오라 내가 너의 찾는 사람을 네게 보이리라' 바락이 그에게 들어가 보니 시스라가 죽어 누웠고 말뚝은 그 살쩍에 박혔더라","reference":"사사기 4:22","category":"$undefined"},{"id":"6623","book":"사사기","book_name":"사사기","chapter":4,"verse":23,"text":"이와 같이 이 날에 하나님이 가나안 왕 야빈을 이스라엘 자손 앞에 패하게 하신지라","reference":"사사기 4:23","category":"$undefined"},{"id":"6624","book":"사사기","book_name":"사사기","chapter":4,"verse":24,"text":"이스라엘 자손의 손이 가나안 왕 야빈을 점점 더 이기어서 마침내 가나안 왕 야빈을 진멸하였더라","reference":"사사기 4:24","category":"$undefined"}],"bookSlug":"judges"}]
