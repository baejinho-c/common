2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":5,"verses":[{"id":"6625","book":"사사기","book_name":"사사기","chapter":5,"verse":1,"text":"이날에 드보라와 아비노암의 아들 바락이 노래하여 가로되","reference":"사사기 5:1","category":"$undefined"},{"id":"6626","book":"사사기","book_name":"사사기","chapter":5,"verse":2,"text":"이스라엘의 두령이 그를 영솔하였고 백성이 즐거이 헌신하였으니 여호와를 찬송하라 !","reference":"사사기 5:2","category":"$undefined"},{"id":"6627","book":"사사기","book_name":"사사기","chapter":5,"verse":3,"text":"너희 왕들아 들으라 ! 방백들아 귀를 기울이라 ! 나 곧 내가 여호와를 노래할 것이요 이스라엘의 하나님 여호와를 찬송하리로다 !","reference":"사사기 5:3","category":"$undefined"},{"id":"6628","book":"사사기","book_name":"사사기","chapter":5,"verse":4,"text":"여호와여 ! 주께서 세일에서부터 나오시고 에돔 들에서부터 진행하실 때에 땅이 진동하고 하늘도 새어서 구름이 물을 내렸나이다","reference":"사사기 5:4","category":"$undefined"},{"id":"6629","book":"사사기","book_name":"사사기","chapter":5,"verse":5,"text":"산들이 여호와 앞에서 진동하니 저 시내산도 이스라엘 하나님 여호와 앞에서 진동하였도다","reference":"사사기 5:5","category":"$undefined"},{"id":"6630","book":"사사기","book_name":"사사기","chapter":5,"verse":6,"text":"아낫의 아들 삼갈의 날에 또는 야엘의 날에는 대로가 비었고 행인들은 소로로 다녔도다","reference":"사사기 5:6","category":"$undefined"},{"id":"6631","book":"사사기","book_name":"사사기","chapter":5,"verse":7,"text":"이스라엘에 관원이 그치고 그쳤더니 나 드보라가 일어났고 내가 일어나서 이스라엘의 어미가 되었도다","reference":"사사기 5:7","category":"$undefined"},{"id":"6632","book":"사사기","book_name":"사사기","chapter":5,"verse":8,"text":"무리가 새 신들을 택하였으므로 그 때에 전쟁이 성문에 미쳤으나 이스라엘 사만명 중에 방패와 창이 보였던고","reference":"사사기 5:8","category":"$undefined"},{"id":"6633","book":"사사기","book_name":"사사기","chapter":5,"verse":9,"text":"내 마음이 이스라엘의 방백을 사모함은 그들이 백성 중에서 즐거이 헌신하였음이라 여호와를 찬송하라 !","reference":"사사기 5:9","category":"$undefined"},{"id":"6634","book":"사사기","book_name":"사사기","chapter":5,"verse":10,"text":"흰 나귀를 탄 자들, 귀한 화문석에 앉은 자들, 길에 행하는 자들아 선파할지어다 !","reference":"사사기 5:10","category":"$undefined"},{"id":"6635","book":"사사기","book_name":"사사기","chapter":5,"verse":11,"text":"활 쏘는 자의 지꺼림에서 멀리 떨어진 물 긷는 곳에서도 여호와의 의로우신 일을 칭술하라 그의 이스라엘을 다스리시는 의로우신 일을 칭술하라 그 때에 여호와의 백성이 성문에 내려갔도다","reference":"사사기 5:11","category":"$undefined"},{"id":"6636","book":"사사기","book_name":"사사기","chapter":5,"verse":12,"text":"깰지어다, 깰지어다, 드보라여, 깰지어다, 깰지어다 ! 너는 노래할지어다, 일어날지어다 ! 바락이여, 아비노암의 아들이여 네 사로 잡은 자를 끌고 갈지어다","reference":"사사기 5:12","category":"$undefined"},{"id":"6637","book":"사사기","book_name":"사사기","chapter":5,"verse":13,"text":"그 때에 남은 귀인과 백성이 내려왔고 여호와께서 나를 위하여 용사를 치시려고 강림하셨도다","reference":"사사기 5:13","category":"$undefined"},{"id":"6638","book":"사사기","book_name":"사사기","chapter":5,"verse":14,"text":"에브라임에게서 나온 자는 아말렉에 뿌리 박힌 자요 그 다음에 베냐민은 너희 백성 중에 섞였으며 마길에게서는 다스리는 자들이 내려왔고 스불론에게서는 대장군의 지팡이를 잡은 자가 내려 왔도다","reference":"사사기 5:14","category":"$undefined"},{"id":"6639","book":"사사기","book_name":"사사기","chapter":5,"verse":15,"text":"잇사갈의 방백들이 드보라와 함께 하니 잇사갈의 심사를 바락도 가졌도다 그 발을 좇아 골짜기로 달려 내려가니 르우벤 시냇가에 큰 결심이 있었도다","reference":"사사기 5:15","category":"$undefined"},{"id":"6640","book":"사사기","book_name":"사사기","chapter":5,"verse":16,"text":"네가 양의 우리 가운데 앉아서 목자의 저 부는 소리를 들음은 어찜이뇨 ? 르우벤 시냇가에서 마음에 크게 살핌이 있도다","reference":"사사기 5:16","category":"$undefined"},{"id":"6641","book":"사사기","book_name":"사사기","chapter":5,"verse":17,"text":"길르앗은 요단 저편에 거하거늘 단은 배에 머무름은 어찜이뇨 ? 아셀은 해빈에 앉고 자기 시냇가에 거하도다","reference":"사사기 5:17","category":"$undefined"},{"id":"6642","book":"사사기","book_name":"사사기","chapter":5,"verse":18,"text":"스불론은 죽음을 무릅쓰고 생명을 아끼지 아니한 백성이요 납달리도 들의 높은 곳에서 그러하도다","reference":"사사기 5:18","category":"$undefined"},{"id":"6643","book":"사사기","book_name":"사사기","chapter":5,"verse":19,"text":"열왕이 와서 싸울 때에 가나안 열왕이 므깃도 물가 다아낙에서 싸웠으나 돈을 탈취하지 못하였도다","reference":"사사기 5:19","category":"$undefined"},{"id":"6644","book":"사사기","book_name":"사사기","chapter":5,"verse":20,"text":"별들이 하늘에서부터 싸우되 그 다니는 길에서 시스라와 싸웠도다","reference":"사사기 5:20","category":"$undefined"},{"id":"6645","book":"사사기","book_name":"사사기","chapter":5,"verse":21,"text":"기손강은 그 무리를 표류시켰으니 이 기손강은 옛 강이라 내 영혼아 ! 네가 힘 있는 자를 밟았도다","reference":"사사기 5:21","category":"$undefined"},{"id":"6646","book":"사사기","book_name":"사사기","chapter":5,"verse":22,"text":"그 때에 군마가 빨리 달리니 말굽소리는 땅을 울리도다","reference":"사사기 5:22","category":"$undefined"},{"id":"6647","book":"사사기","book_name":"사사기","chapter":5,"verse":23,"text":"여호와의 사자의 말씀에 메로스를 저주하라 ! 너희가 거듭 거듭 그 거민을 저주할 것은 그들이 와서 여호와를 돕지 아니하며 여호와를 도와 용사를 치지 아니함이니라 하시도다","reference":"사사기 5:23","category":"$undefined"},{"id":"6648","book":"사사기","book_name":"사사기","chapter":5,"verse":24,"text":"겐 사람 헤벨의 아내 야엘은 다른 여인보다 복을 받을 것이니 장막에 거한 여인보다 더욱 복을 받을 것이로다","reference":"사사기 5:24","category":"$undefined"},{"id":"6649","book":"사사기","book_name":"사사기","chapter":5,"verse":25,"text":"시스라가 물을 구하매 우유를 주되 곧 엉긴 젖을 귀한 그릇에 담아주었고","reference":"사사기 5:25","category":"$undefined"},{"id":"6650","book":"사사기","book_name":"사사기","chapter":5,"verse":26,"text":"손으로 장막 말뚝을 잡으며 오른손에 장인의 방망이를 들고 그 방망이로 시스라를 쳐서 머리를 뚫되 곧 살쩍을 꿰뚫었도다","reference":"사사기 5:26","category":"$undefined"},{"id":"6651","book":"사사기","book_name":"사사기","chapter":5,"verse":27,"text":"그가 그의 발 앞에 꾸부러지며 엎드러지고 쓰러졌고 그의 발 앞에 꾸부러져 엎드러져서 그 꾸부러진 곳에 엎드러져 죽었도다","reference":"사사기 5:27","category":"$undefined"},{"id":"6652","book":"사사기","book_name":"사사기","chapter":5,"verse":28,"text":"시스라의 어미가 창문으로 바라보며 살창에서 부르짖기를 `그의 병거가 어찌하여 더디 오는고 그의 병거 바퀴가 어찌하여 더디 구는고' 하매","reference":"사사기 5:28","category":"$undefined"},{"id":"6653","book":"사사기","book_name":"사사기","chapter":5,"verse":29,"text":"그 지혜로운 시녀들이 대답하였겠고 그도 스스로 대답하기를","reference":"사사기 5:29","category":"$undefined"},{"id":"6654","book":"사사기","book_name":"사사기","chapter":5,"verse":30,"text":"`그들이 어찌 노략물을 얻지 못하였으랴 ? 그것을 나누지 못하였으랴 ? 사람마다 한 두 처녀를 얻었으리로다 시스라는 채색옷을 노략하였으리니 그것은 수놓은 채색옷이리로다 곧 양편에 수놓은 채 색옷이리니 노략한 자의 목에 꾸미리로다' 하였으리라","reference":"사사기 5:30","category":"$undefined"},{"id":"6655","book":"사사기","book_name":"사사기","chapter":5,"verse":31,"text":"여호와여 ! 주의 대적은 다 이와 같이 망하게 하시고 주를 사랑하는 자는 해가 힘있게 돋음 같게 하시옵소서 ! 하니라 그 땅이 사십 년동안 태평하였더라","reference":"사사기 5:31","category":"$undefined"}],"bookSlug":"judges"}]
