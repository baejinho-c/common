2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":6,"verses":[{"id":"6656","book":"사사기","book_name":"사사기","chapter":6,"verse":1,"text":"이스라엘 자손이 또 여호와의 목전에 악을 행하였으므로 여호와께서 칠년 동안 그들을 미디안의 손에 붙이시니","reference":"사사기 6:1","category":"$undefined"},{"id":"6657","book":"사사기","book_name":"사사기","chapter":6,"verse":2,"text":"미디안의 손이 이스라엘을 이긴지라 이스라엘 자손이 미디안을 인하여 산에서 구멍과 굴과 산성을 자기를 위하여 만들었으며","reference":"사사기 6:2","category":"$undefined"},{"id":"6658","book":"사사기","book_name":"사사기","chapter":6,"verse":3,"text":"이스라엘이 파종한 때면 미디안 사람, 아말렉 사람, 동방 사람이 치러 올라와서","reference":"사사기 6:3","category":"$undefined"},{"id":"6659","book":"사사기","book_name":"사사기","chapter":6,"verse":4,"text":"진을 치고 가사에 이르도록 토지 소산을 멸하여 이스라엘 가운데 식물을 남겨두지 아니하며 양이나 소나 나귀도 남기지 아니하니","reference":"사사기 6:4","category":"$undefined"},{"id":"6660","book":"사사기","book_name":"사사기","chapter":6,"verse":5,"text":"이는 그들이 그 짐승과 장막을 가지고 올라와서 메뚜기떼 같이 들어오니 그 사람과 약대가 무수함이라 그들이 그 땅에 들어와 멸하려 하니","reference":"사사기 6:5","category":"$undefined"},{"id":"6661","book":"사사기","book_name":"사사기","chapter":6,"verse":6,"text":"이스라엘이 미디안을 인하여 미약함이 심한지라 이에 이스라엘 자손이 여호와께 부르짖었더라","reference":"사사기 6:6","category":"$undefined"},{"id":"6662","book":"사사기","book_name":"사사기","chapter":6,"verse":7,"text":"이스라엘 자손이 미디안을 인하여 여호와께 부르짖은 고로","reference":"사사기 6:7","category":"$undefined"},{"id":"6663","book":"사사기","book_name":"사사기","chapter":6,"verse":8,"text":"여호와께서 이스라엘 자손에게 한 선지자를 보내사 그들에게 이르되 이스라엘 하나님 여호와의 말씀에 내가 너희를 애굽에서 인도하여 내며 너희를 그 종 되었던 집에서 나오게 하여","reference":"사사기 6:8","category":"$undefined"},{"id":"6664","book":"사사기","book_name":"사사기","chapter":6,"verse":9,"text":"애굽 사람의 손과 너희를 학대하는 모든 자의 손에서 너희를 건져 내고 그들을 너희 앞에서 쫓아내고 그 땅을 너희에게 주었으며","reference":"사사기 6:9","category":"$undefined"},{"id":"6665","book":"사사기","book_name":"사사기","chapter":6,"verse":10,"text":"내가 또 너희에게 이르기를 나는 너희 하나님 여호와니 너희의 거하는 아모리 사람의 땅의 신들을 두려워 말라 하였으나 너희가 내 목소리를 청종치 아니하였느니라 하셨다 하니라","reference":"사사기 6:10","category":"$undefined"},{"id":"6666","book":"사사기","book_name":"사사기","chapter":6,"verse":11,"text":"여호와의 사자가 아비에셀 사람 요아스에게 속한 오브라에 이르러 상수리나무 아래 앉으니라 마침 요아스의 아들 기드온이 미디안 사람에게 알리지 아니하려 하여 밀을 포도주 틀에서 타작하더니","reference":"사사기 6:11","category":"$undefined"},{"id":"6667","book":"사사기","book_name":"사사기","chapter":6,"verse":12,"text":"여호와의 사자가 기드온에게 나타나 이르되 `큰 용사여 ! 여호와께서 너와 함께 계시도다'","reference":"사사기 6:12","category":"$undefined"},{"id":"6668","book":"사사기","book_name":"사사기","chapter":6,"verse":13,"text":"기드온이 그에게 대답하되 `나의 주여 ! 여호와께서 우리와 함께 계시면 어찌하여 이 모든 일이 우리에게 미쳤나이까 또 우리 열조가 일찍 우리에게 이르기를 여호와께서 우리를 애굽에서 나오게 하신 것이 아니냐 한 그 모든 이적이 어디 있나이까 ? 이제 여호와께서 우리를 버리사 미디안의 손에 붙이셨나이다'","reference":"사사기 6:13","category":"$undefined"},{"id":"6669","book":"사사기","book_name":"사사기","chapter":6,"verse":14,"text":"여호와께서 그를 돌아보아 가라사대 너는 이 네 힘을 의지하고 가서 이스라엘을 미디안의 손에서 구원하라 내가 너를 보낸 것이 아니냐 ?","reference":"사사기 6:14","category":"$undefined"},{"id":"6670","book":"사사기","book_name":"사사기","chapter":6,"verse":15,"text":"기드온이 그에게 대답하되 `주여 ! 내가 무엇으로 이스라엘을 구원하리이까 ? 보소서 ! 나의 집은 므낫세 중에 극히 약하고 나는 내 아비 집에서 제일 작은 자니이다'","reference":"사사기 6:15","category":"$undefined"},{"id":"6671","book":"사사기","book_name":"사사기","chapter":6,"verse":16,"text":"여호와께서 그에게 이르시되 내가 반드시 너와 함께 하리니 네가 미디안 사람 치기를 한 사람을 치듯 하리라","reference":"사사기 6:16","category":"$undefined"},{"id":"6672","book":"사사기","book_name":"사사기","chapter":6,"verse":17,"text":"기드온이 그에게 대답하되 `내가 주께 은혜를 얻었사오면 나와 말씀하신 이가 주 되시는 표징을 내게 보이소서 !","reference":"사사기 6:17","category":"$undefined"},{"id":"6673","book":"사사기","book_name":"사사기","chapter":6,"verse":18,"text":"내가 예물을 가지고 다시 주께로 와서 그것을 주 앞에 드리기까지 이곳을 떠나지 마시기를 원하나이다' 그가 가로되 `내가 너 돌아오기를 기다리리라'","reference":"사사기 6:18","category":"$undefined"},{"id":"6674","book":"사사기","book_name":"사사기","chapter":6,"verse":19,"text":"기드온이 가서 염소 새끼 하나를 준비하고 가루 한 에바로 무교 전병을 만들고 고기를 소쿠리에 담고 국을 양푼에 담아서 상수리나무 아래 그에게로 가져다가 드리매","reference":"사사기 6:19","category":"$undefined"},{"id":"6675","book":"사사기","book_name":"사사기","chapter":6,"verse":20,"text":"하나님의 사자가 그에게 이르되 `고기와 무교전병을 가져 이 반석 위에 두고 그 위에 국을 쏟으라' 기드온이 그대로 하니","reference":"사사기 6:20","category":"$undefined"},{"id":"6676","book":"사사기","book_name":"사사기","chapter":6,"verse":21,"text":"여호와의 사자가 손에 잡은 지팡이 끝을 내밀어 고기와 무교전병에 대매 불이 반석에서 나와 고기와 무교전병을 살랐고 여호와의 사자는 떠나서 보이지 아니한지라","reference":"사사기 6:21","category":"$undefined"},{"id":"6677","book":"사사기","book_name":"사사기","chapter":6,"verse":22,"text":"기드온이 그가 여호와의 사자인줄 알고 가로되 `슬프도소이다 주 여호와여 ! 내가 여호와의 사자를 대면하여 보았나이다'","reference":"사사기 6:22","category":"$undefined"},{"id":"6678","book":"사사기","book_name":"사사기","chapter":6,"verse":23,"text":"여호와께서 그에게 이르시되 너는 안심하라 ! 두려워 말라 ! 죽지 아니하리라 ! 하시니라","reference":"사사기 6:23","category":"$undefined"},{"id":"6679","book":"사사기","book_name":"사사기","chapter":6,"verse":24,"text":"기드온이 여호와를 위하여 거기서 단을 쌓고 이름을 `여호와 살롬'이라 하였더라 그것이 오늘까지 아비에셀 사람에게 속한 오브라에 있더라","reference":"사사기 6:24","category":"$undefined"},{"id":"6680","book":"사사기","book_name":"사사기","chapter":6,"verse":25,"text":"이날 밤에 여호와께서 기드온에게 이르시되 네 아비의 수소 곧 칠년된 둘째 수소를 취하고 네 아비에게 있는 바알의 단을 헐며 단 곁의 아세라 상을 찍고","reference":"사사기 6:25","category":"$undefined"},{"id":"6681","book":"사사기","book_name":"사사기","chapter":6,"verse":26,"text":"또 이 견고한 성 위에 네 하나님 여호와를 위하여 규례대로 한 단을 쌓고 그 둘째 수소를 취하여 네가 찍은 아세라나무로 번제를 드릴지니라","reference":"사사기 6:26","category":"$undefined"},{"id":"6682","book":"사사기","book_name":"사사기","chapter":6,"verse":27,"text":"이에 기드온이 종 열을 데리고 여호와의 말씀하신 대로 행하되 아비의 가족과 그 성읍 사람들을 두려워하므로 이 일을 감히 백주에 행하지 못하고 밤에 행하니라","reference":"사사기 6:27","category":"$undefined"},{"id":"6683","book":"사사기","book_name":"사사기","chapter":6,"verse":28,"text":"성읍 사람들이 아침에 일찌기 일어나 본즉 바알의 단이 훼파되었으며 단 곁의 아세라가 찍혔고 새로 쌓은 단 위에 그 둘째 수소를 드렸는지라","reference":"사사기 6:28","category":"$undefined"},{"id":"6684","book":"사사기","book_name":"사사기","chapter":6,"verse":29,"text":"서로 물어 가로되 `이것이 누구의 소위인고' 하고 그들이 캐어 물은 후에 가로되 `요아스의 아들 기드온이 이를 행하였도다' 하고","reference":"사사기 6:29","category":"$undefined"},{"id":"6685","book":"사사기","book_name":"사사기","chapter":6,"verse":30,"text":"성읍 사람들이 요아스에게 이르되 `네 아들을 끌어내라 그는 당연히 죽을지니 이는 바알의 단을 훼파하고 단 곁의 아세라를 찍었음이니라'","reference":"사사기 6:30","category":"$undefined"},{"id":"6686","book":"사사기","book_name":"사사기","chapter":6,"verse":31,"text":"요아스가 자기를 둘러선 모든 자에게 이르되 `너희가 바알을 위하여 쟁론 하느냐 ? 너희가 바알을 구원 하겠느냐 ? 그를 위하여 쟁론하는 자는 이 아침에 죽음을 당하리라 바알이 과연 신(神)일진대 그 단을 훼파하였은즉 스스로 쟁론할 것이니라' 하니라","reference":"사사기 6:31","category":"$undefined"},{"id":"6687","book":"사사기","book_name":"사사기","chapter":6,"verse":32,"text":"그 날에 기드온을 여룹바알이라 하였으니 이는 그가 바알의 단을 훼파하였은즉 바알이 더불어 쟁론할 것이라 함이었더라","reference":"사사기 6:32","category":"$undefined"},{"id":"6688","book":"사사기","book_name":"사사기","chapter":6,"verse":33,"text":"때에 미디안 사람과 아말렉 사람과 동방 사람들이 다 모여 요단을 건너와서 이스르엘 골짜기에 진을 친지라","reference":"사사기 6:33","category":"$undefined"},{"id":"6689","book":"사사기","book_name":"사사기","chapter":6,"verse":34,"text":"여호와의 신이 기드온에게 강림하시니 기드온이 나팔을 불매 아비에셀 족속이 다 모여서 그를 좇고","reference":"사사기 6:34","category":"$undefined"},{"id":"6690","book":"사사기","book_name":"사사기","chapter":6,"verse":35,"text":"기드온이 또 사자를 온 므낫세에 두루 보내매 그들도 모여서 그를 좇고 또 사자를 아셀과 스불론과 납달리에 보내매 그 무리도 올라와서 그를 영접하더라","reference":"사사기 6:35","category":"$undefined"},{"id":"6691","book":"사사기","book_name":"사사기","chapter":6,"verse":36,"text":"기드온이 하나님께 여짜오되 `주께서 이미 말씀하심같이 내 손으로 이스라엘을 구원하려 하시거든","reference":"사사기 6:36","category":"$undefined"},{"id":"6692","book":"사사기","book_name":"사사기","chapter":6,"verse":37,"text":"보소서 ! 내가 양털 한 뭉치를 타작마당에 두리니 이슬이 양털에만 있고 사면 땅은 마르면 주께서 이미 말씀하심 같이 내 손으로 이스라엘을 구원하실 줄 내가 알겠나이다' 하였더니","reference":"사사기 6:37","category":"$undefined"},{"id":"6693","book":"사사기","book_name":"사사기","chapter":6,"verse":38,"text":"그대로 된지라 이튿날 기드온이 일찌기 일어나서 양털을 취하여 이슬을 짜니 물이 그릇에 가득하더라","reference":"사사기 6:38","category":"$undefined"},{"id":"6694","book":"사사기","book_name":"사사기","chapter":6,"verse":39,"text":"기드온이 또 하나님께 여짜오되 `주여, 내게 진노하지 마옵소서 ! 내가 이번만 말하리이다 구하옵나니 나로 다시 한번 양털로 시험하게 하소서 양털만 마르고 사면 땅에는 다 이슬이 있게 하옵소서' 하였더니","reference":"사사기 6:39","category":"$undefined"},{"id":"6695","book":"사사기","book_name":"사사기","chapter":6,"verse":40,"text":"이 밤에 하나님이 그대로 행하시니 곧 양털만 마르고 사면 땅에는 다 이슬이 있었더라","reference":"사사기 6:40","category":"$undefined"}],"bookSlug":"judges"}]
