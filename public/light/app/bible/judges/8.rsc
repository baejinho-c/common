2:["$","$L11",null,{"book":{"id":"judges","name":"사사기","chapters":21,"testament":"old"},"chapter":8,"verses":[{"id":"6721","book":"사사기","book_name":"사사기","chapter":8,"verse":1,"text":"에브라임 사람들이 기드온에게 이르되 `네가 미디안과 싸우러 갈때에 우리를 부르지 아니하였으니 우리를 이같이 대접함은 어찜이뇨 ?' 하고 크게 다투는지라","reference":"사사기 8:1","category":"$undefined"},{"id":"6722","book":"사사기","book_name":"사사기","chapter":8,"verse":2,"text":"기드온이 그들에게 이르되 `나의 이제 행한 일이 너희의 한 것에 비교 되겠느냐 ? 에브라임의 끝물 포도가 아비에셀의 맏물 포도보다 낫지 아니하냐 ?","reference":"사사기 8:2","category":"$undefined"},{"id":"6723","book":"사사기","book_name":"사사기","chapter":8,"verse":3,"text":"하나님이 미디안 방백 오렙과 스엡을 너희 손에 붙이셨으니 나의 한 일이 어찌 능히 너희의 한것에 비교 되겠느냐 ?` 기드온이 이말을 하매 그들의 노가 풀리니라","reference":"사사기 8:3","category":"$undefined"},{"id":"6724","book":"사사기","book_name":"사사기","chapter":8,"verse":4,"text":"기드온과 그 좇은 자 삼백명이 요단에 이르러 건너고 비록 피곤하나 따르며","reference":"사사기 8:4","category":"$undefined"},{"id":"6725","book":"사사기","book_name":"사사기","chapter":8,"verse":5,"text":"그가 숙곳 사람들에게 이르되 `나의 종자가 피곤하여 하니 청컨대 그들에게 떡덩이를 주라 나는 미디안 두 왕 세바와 살문나를 따르노라'","reference":"사사기 8:5","category":"$undefined"},{"id":"6726","book":"사사기","book_name":"사사기","chapter":8,"verse":6,"text":"숙곳 방백들이 가로되 `세바와 살문나의 손이 지금 어찌 네 손에 있관대 우리가 네 군대에게 떡을 주겠느냐 ?'","reference":"사사기 8:6","category":"$undefined"},{"id":"6727","book":"사사기","book_name":"사사기","chapter":8,"verse":7,"text":"기드온이 가로되 `그러면 여호와께서 세바와 살문나를 내 손에 붙이신 후에 내가 들가시와 찔레로 너희 살을 찢으리라' 하고","reference":"사사기 8:7","category":"$undefined"},{"id":"6728","book":"사사기","book_name":"사사기","chapter":8,"verse":8,"text":"거기서 브누엘에 올라가서 그들에게도 그같이 구한즉 브누엘 사람들의 대답도 숙곳 사람들의 대답과 같은지라","reference":"사사기 8:8","category":"$undefined"},{"id":"6729","book":"사사기","book_name":"사사기","chapter":8,"verse":9,"text":"기드온이 또 브누엘 사람들에게 일러 가로되 `내가 평안이 돌아올때에 이 망대를 헐리라' 하니라","reference":"사사기 8:9","category":"$undefined"},{"id":"6730","book":"사사기","book_name":"사사기","chapter":8,"verse":10,"text":"이 때에 세바와 살문나가 갈골에 있는데 동방 사람의 모든 군대중에 칼 든 자 십 이만명이 죽었고 그들을 좇아 거기 있더라","reference":"사사기 8:10","category":"$undefined"},{"id":"6731","book":"사사기","book_name":"사사기","chapter":8,"verse":11,"text":"적군이 안연히 있는 중에 기드온이 노바와 욕브하 동편 장막에 거한 자의 길로 올라가서 적군을 치니","reference":"사사기 8:11","category":"$undefined"},{"id":"6732","book":"사사기","book_name":"사사기","chapter":8,"verse":12,"text":"세바와 살문나가 도망하는지라 기드온이 추격하여 미디안 두 왕 세바와 살문나를 사로 잡고 그 온 군대를 파하니라","reference":"사사기 8:12","category":"$undefined"},{"id":"6733","book":"사사기","book_name":"사사기","chapter":8,"verse":13,"text":"요아스의 아들 기드온이 헤레스 비탈 전장에서 돌아오다가","reference":"사사기 8:13","category":"$undefined"},{"id":"6734","book":"사사기","book_name":"사사기","chapter":8,"verse":14,"text":"숙곳 사람 중 한 소년을 잡아 신문하매 숙곳 방백과 장로 칠십 칠인을 그를 위하여 기록한지라","reference":"사사기 8:14","category":"$undefined"},{"id":"6735","book":"사사기","book_name":"사사기","chapter":8,"verse":15,"text":"기드온이 숙곳 사람들에게 이르러 가로되 `너희가 전에 나를 기롱하여 이르기를 세바와 살문나의 손이 지금 어찌 네 손에 있관대 우리가 네 피곤한 사람에게 떡을 주겠느냐 ? 한 그 세바와 살문나를 보라'하고","reference":"사사기 8:15","category":"$undefined"},{"id":"6736","book":"사사기","book_name":"사사기","chapter":8,"verse":16,"text":"그 성읍 장로들을 잡고 들가시와 찔레로 숙곳 사람들을 징벌하고","reference":"사사기 8:16","category":"$undefined"},{"id":"6737","book":"사사기","book_name":"사사기","chapter":8,"verse":17,"text":"브누엘 망대를 헐며 그 성읍 사람들을 죽이니라","reference":"사사기 8:17","category":"$undefined"},{"id":"6738","book":"사사기","book_name":"사사기","chapter":8,"verse":18,"text":"이에 세바와 살문나에게 묻되 `너희가 다볼에서 죽인 자들은 어떠한 자이더뇨' 대답하되 `그들이 너와 같아서 모두 왕자 같더라'","reference":"사사기 8:18","category":"$undefined"},{"id":"6739","book":"사사기","book_name":"사사기","chapter":8,"verse":19,"text":"가로되 `그들은 내 형제 내 어머니의 아들이니라 내가 여호와의 사심으로 맹세하노니 너희가 만일 그들을 살렸더면 나도 너희를 죽이지 아니하였으리라'하고","reference":"사사기 8:19","category":"$undefined"},{"id":"6740","book":"사사기","book_name":"사사기","chapter":8,"verse":20,"text":"그 장자 여델에게 이르되 `일어나 그들을 죽이라` 하였으나 그 소년이 칼을 빼지 못하였으니 이는 아직 어려서 두려워함이었더라","reference":"사사기 8:20","category":"$undefined"},{"id":"6741","book":"사사기","book_name":"사사기","chapter":8,"verse":21,"text":"세바와 살문나가 가로되 `네가 일어나 우리를 치라 대저 사람이 어떠하면 그 힘도 그러하니라' 기드온이 일어나서 세바와 살문나를 죽이고 그 약대 목에 꾸몄던 새 달 형상의 장식을 취하니라","reference":"사사기 8:21","category":"$undefined"},{"id":"6742","book":"사사기","book_name":"사사기","chapter":8,"verse":22,"text":"때에 이스라엘 사람들이 기드온에게 이르되 `당신이 우리를 미디안의 손에서 구원하셨으니 당신과 당신의 아들과 당신의 손자가 우리를 다스리소서'","reference":"사사기 8:22","category":"$undefined"},{"id":"6743","book":"사사기","book_name":"사사기","chapter":8,"verse":23,"text":"기드온이 그들에게 이르되 `내가 너희를 다스리지 아니하겠고 나의 아들도 너희를 다스리지 아니할 것이요 여호와께서 너희를 다스리시리라'","reference":"사사기 8:23","category":"$undefined"},{"id":"6744","book":"사사기","book_name":"사사기","chapter":8,"verse":24,"text":"기드온이 또 그들에게 이르되 `내가 너희에게 한 일을 청구하노니 너희는 각기 탈취한 귀고리를 내게 줄지니라' 하니 그 대적은 이스마엘 사람이므로 금 귀고리가 있었음이라","reference":"사사기 8:24","category":"$undefined"},{"id":"6745","book":"사사기","book_name":"사사기","chapter":8,"verse":25,"text":"무리가 대답하되 `우리가 즐거이 드리리이다` 하고 겉옷을 펴고 각기 탈취한 귀고리를 그 가운데 던지니","reference":"사사기 8:25","category":"$undefined"},{"id":"6746","book":"사사기","book_name":"사사기","chapter":8,"verse":26,"text":"기드온의 청한 바 금 귀고리 중 수가 금 일천 칠백 세겔이요 그 외에 또 새 달 형상의 장식과 패물과 미디안 왕들의 입었던 자색 의복과 그 약대 목에 둘렀던 사슬이 있었더라","reference":"사사기 8:26","category":"$undefined"},{"id":"6747","book":"사사기","book_name":"사사기","chapter":8,"verse":27,"text":"기드온이 그 금으로 에봇 하나를 만들어서 자기의 성읍 오브라에 두었더니 온 이스라엘이 그것을 음란하게 위하므로 그것이 기드온과 그 집에 올무가 되니라","reference":"사사기 8:27","category":"$undefined"},{"id":"6748","book":"사사기","book_name":"사사기","chapter":8,"verse":28,"text":"미디안이 이스라엘 자손 앞에 복종하여 다시는 그 머리를 들지 못하였으므로 기드온의 사는 날 동안 사십년에 그 땅이 태평하였더라","reference":"사사기 8:28","category":"$undefined"},{"id":"6749","book":"사사기","book_name":"사사기","chapter":8,"verse":29,"text":"요아스의 아들 여룹바알이 돌아가서 자기 집에 거하였는데","reference":"사사기 8:29","category":"$undefined"},{"id":"6750","book":"사사기","book_name":"사사기","chapter":8,"verse":30,"text":"기드온이 아내가 많으므로 몸에서 낳은 아들이 칠십인이였고","reference":"사사기 8:30","category":"$undefined"},{"id":"6751","book":"사사기","book_name":"사사기","chapter":8,"verse":31,"text":"세겜에 있는 첩도 아들을 낳았으므로 그 이름을 아비멜렉이라 하였더라","reference":"사사기 8:31","category":"$undefined"},{"id":"6752","book":"사사기","book_name":"사사기","chapter":8,"verse":32,"text":"요아스의 아들 기드온이 나이 많아 죽으매 아비에셀 사람의 오브라에 있는 그의 아비 요아스의 묘실에 장사하였더라","reference":"사사기 8:32","category":"$undefined"},{"id":"6753","book":"사사기","book_name":"사사기","chapter":8,"verse":33,"text":"기드온이 이미 죽으매 이스라엘 자손이 돌이켜 바알들을 음란하게 위하고 또 바알브릿을 자기들의 신으로 삼고","reference":"사사기 8:33","category":"$undefined"},{"id":"6754","book":"사사기","book_name":"사사기","chapter":8,"verse":34,"text":"사면 모든 대적의 손에서 자기들을 건져내신 여호와 자기들의 하나님을 기억지 아니하며","reference":"사사기 8:34","category":"$undefined"},{"id":"6755","book":"사사기","book_name":"사사기","chapter":8,"verse":35,"text":"또 여룹바알이라 하는 기드온의 이스라엘에게 베푼 모든 은혜를 따라서 그의 집을 후대치도 아니하였더라","reference":"사사기 8:35","category":"$undefined"}],"bookSlug":"judges"}]
