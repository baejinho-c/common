2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":1,"verses":[{"id":"2747","book":"레위기","book_name":"레위기","chapter":1,"verse":1,"text":"여호와께서 회막에서 모세를 부르시고 그에게 일러 가라사대","reference":"레위기 1:1","category":"$undefined"},{"id":"2748","book":"레위기","book_name":"레위기","chapter":1,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 너희 중에 누구든지 여호와께 예물을 드리려거든 생축 중에서 소나 양으로 예물을 드릴지니라 !","reference":"레위기 1:2","category":"$undefined"},{"id":"2749","book":"레위기","book_name":"레위기","chapter":1,"verse":3,"text":"그 예물이 소의 번제이면 흠 없는 수컷으로 회막 문에서 여호와 앞에 열납하시도록 드릴지니라 !","reference":"레위기 1:3","category":"$undefined"},{"id":"2750","book":"레위기","book_name":"레위기","chapter":1,"verse":4,"text":"그가 번제물의 머리에 안수할지니 그리하면 열납되어 그를 위하여 속죄가 될 것이라","reference":"레위기 1:4","category":"$undefined"},{"id":"2751","book":"레위기","book_name":"레위기","chapter":1,"verse":5,"text":"그는 여호와 앞에서 그 수송아지를 잡을 것이요, 아론의 자손 제사장들은 그 피를 가져다가 회막 문 앞 단 사면에 뿌릴 것이며","reference":"레위기 1:5","category":"$undefined"},{"id":"2752","book":"레위기","book_name":"레위기","chapter":1,"verse":6,"text":"그는 또 그 번제 희생의 가죽을 벗기고 각을 뜰 것이요,","reference":"레위기 1:6","category":"$undefined"},{"id":"2753","book":"레위기","book_name":"레위기","chapter":1,"verse":7,"text":"제사장 아론의 자손들은 단 위에 불을 두고 불 위에 나무를 벌여 놓고","reference":"레위기 1:7","category":"$undefined"},{"id":"2754","book":"레위기","book_name":"레위기","chapter":1,"verse":8,"text":"아론의 자손 제사장들은 그 뜬 각과 머리와 기름을 단 윗불 위에 있는 나무에 벌여 놓을 것이며","reference":"레위기 1:8","category":"$undefined"},{"id":"2755","book":"레위기","book_name":"레위기","chapter":1,"verse":9,"text":"그 내장과 정갱이를 물로 씻을 것이요, 제사장은 그 전부를 단 위에 불살라 번제를 삼을지니 이는 화제라 여호와께 향기로운 냄새니라.","reference":"레위기 1:9","category":"$undefined"},{"id":"2756","book":"레위기","book_name":"레위기","chapter":1,"verse":10,"text":"만일 그 예물이 떼의 양이나 염소의 번제이면 흠없는 수컷으로 드릴지니","reference":"레위기 1:10","category":"$undefined"},{"id":"2757","book":"레위기","book_name":"레위기","chapter":1,"verse":11,"text":"그가 단 북편에서 여호와 앞에서 잡을 것이요,아론의 자손 제사장들은 그 피를 단 사면에 뿌릴 것이며","reference":"레위기 1:11","category":"$undefined"},{"id":"2758","book":"레위기","book_name":"레위기","chapter":1,"verse":12,"text":"그는 그것의 각을 뜨고 그 머리와 그 기름을 베어 낼 것이요, 제사장은 그것을 다 단 윗불 위에 있는 나무에 벌여 놓을 것이며","reference":"레위기 1:12","category":"$undefined"},{"id":"2759","book":"레위기","book_name":"레위기","chapter":1,"verse":13,"text":"그 내장과 정갱이를 물로 씻을 것이요, 제사장은 그 전부를 가져다가 단 위에 불살라 번제를 삼을지니 이는 화제라 여호와께 향기로운 냄새니라.","reference":"레위기 1:13","category":"$undefined"},{"id":"2760","book":"레위기","book_name":"레위기","chapter":1,"verse":14,"text":"만일 여호와께 드리는 예물이 새의 번제이면 산비둘기나 집비둘기 새끼로 예물을 삼을 것이요,","reference":"레위기 1:14","category":"$undefined"},{"id":"2761","book":"레위기","book_name":"레위기","chapter":1,"verse":15,"text":"제사장은 그것을 단으로 가져다가 그 머리를 비틀어 끊고 단 위에 불사르고 피는 단 곁에 흘릴 것이며","reference":"레위기 1:15","category":"$undefined"},{"id":"2762","book":"레위기","book_name":"레위기","chapter":1,"verse":16,"text":"멱통과 그 더러운 것은 제하여 단 동편 재 버리는 곳에 던지고","reference":"레위기 1:16","category":"$undefined"},{"id":"2763","book":"레위기","book_name":"레위기","chapter":1,"verse":17,"text":"또 그 날개 자리에서 그 몸을 찢되 아주 찢지 말고 제사장이 그것을 단 윗불 위의 나무 위에 살라 번제를 삼을지니 이는 화제라 여호와께 향기로운 냄새니라","reference":"레위기 1:17","category":"$undefined"}],"bookSlug":"leviticus"}]
