2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":10,"verses":[{"id":"2979","book":"레위기","book_name":"레위기","chapter":10,"verse":1,"text":"아론의 아들 나답과 아비후가 각기 향로를 가져다가 여호와의 명하시지 않은 다른 불을 담아 여호와 앞에 분향하였더니","reference":"레위기 10:1","category":"$undefined"},{"id":"2980","book":"레위기","book_name":"레위기","chapter":10,"verse":2,"text":"불이 여호와 앞에서 나와 그들을 삼키매 그들이 여호와 앞에서 죽은지라","reference":"레위기 10:2","category":"$undefined"},{"id":"2981","book":"레위기","book_name":"레위기","chapter":10,"verse":3,"text":"모세가 아론에게 이르되 `이는 여호와의 말씀이라 ! 이르시기를 나는 나를 가까이 하는 자 중에 내가 거룩하다 함을 얻겠고 온 백성 앞에 내가 영광을 얻으리라 하셨느니라' 아론이 잠잠하니","reference":"레위기 10:3","category":"$undefined"},{"id":"2982","book":"레위기","book_name":"레위기","chapter":10,"verse":4,"text":"모세가 아론의 아자비 웃시엘의 아들 미사엘과 엘사반을 불러 그들에게 이르되 '나아와 너희 형제들을 성소 앞에서 진 밖으로 메어 가라' 하매","reference":"레위기 10:4","category":"$undefined"},{"id":"2983","book":"레위기","book_name":"레위기","chapter":10,"verse":5,"text":"그들이 나아와 모세의 명대로 그들을 옷 입은 채 진 밖으로 메어내니","reference":"레위기 10:5","category":"$undefined"},{"id":"2984","book":"레위기","book_name":"레위기","chapter":10,"verse":6,"text":"모세가 아론과 그 아들 엘르아살과 이다말에게 이르되 `너희는 머리를 풀거나 옷을 찢지 말아서 너희 죽음을 면하고 여호와의 진노가 온 회중에게 미침을 면케 하라 오직 너희 형제 이스라엘 온 족속이 여호와의 치신 불로 인하여 슬퍼할 것이니라","reference":"레위기 10:6","category":"$undefined"},{"id":"2985","book":"레위기","book_name":"레위기","chapter":10,"verse":7,"text":"여호와의 관유가 너희에게 있은즉 너희는 회막 문에 나가지 말아서 죽음을 면할지니라' 그들이 모세의 명대로 하니라","reference":"레위기 10:7","category":"$undefined"},{"id":"2986","book":"레위기","book_name":"레위기","chapter":10,"verse":8,"text":"여호와께서 아론에게 일러 가라사대","reference":"레위기 10:8","category":"$undefined"},{"id":"2987","book":"레위기","book_name":"레위기","chapter":10,"verse":9,"text":"너나 네 자손들이 회막에 들어갈 때에는 포도주나 독주를 마시지 말아서 너희 사망을 면하라 ! 이는 너희 대대로 영영한 규례라","reference":"레위기 10:9","category":"$undefined"},{"id":"2988","book":"레위기","book_name":"레위기","chapter":10,"verse":10,"text":"그리하여야 너희가 거룩하고 속된 것을 분별하며 부정하고 정한 것을 분별하고","reference":"레위기 10:10","category":"$undefined"},{"id":"2989","book":"레위기","book_name":"레위기","chapter":10,"verse":11,"text":"또 여호와가 모세로 명한 모든 규례를 이스라엘 자손에게 가르치리라","reference":"레위기 10:11","category":"$undefined"},{"id":"2990","book":"레위기","book_name":"레위기","chapter":10,"verse":12,"text":"모세가 아론과 그 남은 아들 엘르아살에게와 이다말에게 이르되 여호와께 드린 화제중 소제의 남은 것은 지극히 거룩하니 너희는 그것을 취하여 누룩을 넣지 말고 단 곁에서 먹되","reference":"레위기 10:12","category":"$undefined"},{"id":"2991","book":"레위기","book_name":"레위기","chapter":10,"verse":13,"text":"이는 여호와의 화제 중 네 응식과 네 아들의 응식인즉 너희는 그것을 거룩한 곳에서 먹으라 ! 내가 명령을 받았느니라","reference":"레위기 10:13","category":"$undefined"},{"id":"2992","book":"레위기","book_name":"레위기","chapter":10,"verse":14,"text":"흔든 가슴과 든 뒷다리는 너와 네 자녀가 너와 함께 정결한 곳에서 먹을지니 이는 이스라엘 자손의 화목제 희생 중에서 네 응식과 네 자손의 응식으로 주신 것임이니라","reference":"레위기 10:14","category":"$undefined"},{"id":"2993","book":"레위기","book_name":"레위기","chapter":10,"verse":15,"text":"그 든 뒷다리와 흔든 가슴으로 화제의 기름과 함께 가져다가 여호와 앞에 흔들어 요제를 삼을지니 이는 여호와의 명령대로 너와 네 자손의 영원한 응식이니라'","reference":"레위기 10:15","category":"$undefined"},{"id":"2994","book":"레위기","book_name":"레위기","chapter":10,"verse":16,"text":"모세가 속죄제 드린 염소를 찾은즉 이미 불살랐는지라 그가 아론의 남은 아들 엘르아살과 이다말에게 노하여 가로되","reference":"레위기 10:16","category":"$undefined"},{"id":"2995","book":"레위기","book_name":"레위기","chapter":10,"verse":17,"text":"`이 속죄제 희생은 지극히 거룩하거늘 너희가 어찌하여 거룩한 곳에서 먹지 아니하였느뇨 ? 이는 너희로 회중의 죄를 담당하여 그들을 위하여 여호와 앞에 속하게 하려고 너희에게 주신 것이니라","reference":"레위기 10:17","category":"$undefined"},{"id":"2996","book":"레위기","book_name":"레위기","chapter":10,"verse":18,"text":"그 피를 성소에 들여오지 아니하였으니 그 제육은 너희가 나의 명한 대로 거룩한 곳에서 먹었어야 할 것이니라'","reference":"레위기 10:18","category":"$undefined"},{"id":"2997","book":"레위기","book_name":"레위기","chapter":10,"verse":19,"text":"아론이 모세에게 이르되 `오늘 그들이 그 속죄제와 번제를 여호와께 드렸어도 이런 일이 내게 임하였거늘 오늘 내가 속죄 제육을 먹었더면 여호와께서 어찌 선히 여기셨으리요'","reference":"레위기 10:19","category":"$undefined"},{"id":"2998","book":"레위기","book_name":"레위기","chapter":10,"verse":20,"text":"모세가 그 말을 듣고 좋게 여겼더라","reference":"레위기 10:20","category":"$undefined"}],"bookSlug":"leviticus"}]
