2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":11,"verses":[{"id":"2999","book":"레위기","book_name":"레위기","chapter":11,"verse":1,"text":"여호와께서 모세와 아론에게 고하여 그들에게 이르시되","reference":"레위기 11:1","category":"$undefined"},{"id":"3000","book":"레위기","book_name":"레위기","chapter":11,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 육지 모든 짐승 중 너희의 먹을만한 생물은 이러하니","reference":"레위기 11:2","category":"$undefined"},{"id":"3001","book":"레위기","book_name":"레위기","chapter":11,"verse":3,"text":"짐승중 무릇 굽이 갈라져 쪽발이 되고 새김질하는 것은 너희가 먹되","reference":"레위기 11:3","category":"$undefined"},{"id":"3002","book":"레위기","book_name":"레위기","chapter":11,"verse":4,"text":"새김질하는 것이나 굽이 갈라진 짐승 중에도 너희가 먹지 못할 것은 이러하니 약대는 새김질은 하되 굽이 갈라지지 아니하였으므로 너희에게 부정하고","reference":"레위기 11:4","category":"$undefined"},{"id":"3003","book":"레위기","book_name":"레위기","chapter":11,"verse":5,"text":"사반도 새김질은 하되 굽이 갈라지지 아니하였으므로 너희에게 부정하고","reference":"레위기 11:5","category":"$undefined"},{"id":"3004","book":"레위기","book_name":"레위기","chapter":11,"verse":6,"text":"토끼도 새김질은 하되 굽이 갈라지지 아니하였으므로 너희에게 부정하고","reference":"레위기 11:6","category":"$undefined"},{"id":"3005","book":"레위기","book_name":"레위기","chapter":11,"verse":7,"text":"돼지는 굽이 갈라져 쪽발이로되 새김질을 못하므로 너희에게 부정하니","reference":"레위기 11:7","category":"$undefined"},{"id":"3006","book":"레위기","book_name":"레위기","chapter":11,"verse":8,"text":"너희는 이 고기를 먹지 말고 그 주검도 만지지 말라 이것들은 너희에게 부정하니라","reference":"레위기 11:8","category":"$undefined"},{"id":"3007","book":"레위기","book_name":"레위기","chapter":11,"verse":9,"text":"물에 있는 모든 것 중 너희의 먹을 만한 것은 이것이니 무릇 강과 바다와 다른 물에 있는 것 중에 지느러미와 비늘 있는 것은 너희가 먹되","reference":"레위기 11:9","category":"$undefined"},{"id":"3008","book":"레위기","book_name":"레위기","chapter":11,"verse":10,"text":"무릇 물에서 동하는 것과, 무릇 물에서 사는 것 곧 무릇 강과, 바다에 있는 것으로서 지느러미와 비늘 없는 것은 너희에게 가증한 것이라","reference":"레위기 11:10","category":"$undefined"},{"id":"3009","book":"레위기","book_name":"레위기","chapter":11,"verse":11,"text":"이들은 너희에게 가증한 것이니 너희는 그 고기를 먹지 말고 그 주검을 가증히 여기라","reference":"레위기 11:11","category":"$undefined"},{"id":"3010","book":"레위기","book_name":"레위기","chapter":11,"verse":12,"text":"수중 생물에 지느러미와 비늘 없는 것은 너희에게 가증하니라","reference":"레위기 11:12","category":"$undefined"},{"id":"3011","book":"레위기","book_name":"레위기","chapter":11,"verse":13,"text":"새 중에 너희가 가증히 여길 것은 이것이라 이것들이 가증한즉 먹지 말지니 곧 독수리와, 솔개와, 어응과,","reference":"레위기 11:13","category":"$undefined"},{"id":"3012","book":"레위기","book_name":"레위기","chapter":11,"verse":14,"text":"매와, 매 종류와,","reference":"레위기 11:14","category":"$undefined"},{"id":"3013","book":"레위기","book_name":"레위기","chapter":11,"verse":15,"text":"까마귀 종류와","reference":"레위기 11:15","category":"$undefined"},{"id":"3014","book":"레위기","book_name":"레위기","chapter":11,"verse":16,"text":"타조와, 다호마스와, 갈매기와, 새매 종류와,","reference":"레위기 11:16","category":"$undefined"},{"id":"3015","book":"레위기","book_name":"레위기","chapter":11,"verse":17,"text":"올빼미와, 노자와, 부엉이와,","reference":"레위기 11:17","category":"$undefined"},{"id":"3016","book":"레위기","book_name":"레위기","chapter":11,"verse":18,"text":"따오기와, 당아와, 올응과,","reference":"레위기 11:18","category":"$undefined"},{"id":"3017","book":"레위기","book_name":"레위기","chapter":11,"verse":19,"text":"학과, 황새 종류와, 대승과, 박쥐니라","reference":"레위기 11:19","category":"$undefined"},{"id":"3018","book":"레위기","book_name":"레위기","chapter":11,"verse":20,"text":"날개가 있고 네 발로기어 다니는 곤충은 너희에게 가증하되","reference":"레위기 11:20","category":"$undefined"},{"id":"3019","book":"레위기","book_name":"레위기","chapter":11,"verse":21,"text":"오직 날개가 있고 네 발로 기어다니는 모든 곤충중에 그 발에 뛰는 다리가 있어서 땅에서 뛰는 것은 너희가 먹을지니","reference":"레위기 11:21","category":"$undefined"},{"id":"3020","book":"레위기","book_name":"레위기","chapter":11,"verse":22,"text":"곧 그 중에 메뚜기 종류와, 베짱이 종류와, 귀뚜라미 종류와, 팟종이 종류는 너희가 먹으려니와","reference":"레위기 11:22","category":"$undefined"},{"id":"3021","book":"레위기","book_name":"레위기","chapter":11,"verse":23,"text":"오직 날개가 있고 기어다니는 곤충은 다 너희에게 가증하니라","reference":"레위기 11:23","category":"$undefined"},{"id":"3022","book":"레위기","book_name":"레위기","chapter":11,"verse":24,"text":"이런 유는 너희를 부정케 하나니 누구든지 이것들의 주검을 만지면 저녁까지 부정할 것이며","reference":"레위기 11:24","category":"$undefined"},{"id":"3023","book":"레위기","book_name":"레위기","chapter":11,"verse":25,"text":"무릇 그 주검을 옮기는 자는 그 옷을 빨지니 저녁까지 부정하리라","reference":"레위기 11:25","category":"$undefined"},{"id":"3024","book":"레위기","book_name":"레위기","chapter":11,"verse":26,"text":"무릇 굽이 갈라진 짐승 중에 쪽발이 아닌 것이나 새김질 아니하는 것의 주검은 다 네게 부정하니 만지는 자는 부정할 것이요","reference":"레위기 11:26","category":"$undefined"},{"id":"3025","book":"레위기","book_name":"레위기","chapter":11,"verse":27,"text":"네 발로 다니는 모든 짐승 중 발바닥으로 다니는 것은 다 네게 부정하니 그 주검을 만지는 자는 저녁까지 부정할 것이며","reference":"레위기 11:27","category":"$undefined"},{"id":"3026","book":"레위기","book_name":"레위기","chapter":11,"verse":28,"text":"그 주검을 옮기는 자는 그 옷을 빨지니 저녁까지 부정하리라 그것들이 네게 부정하니라","reference":"레위기 11:28","category":"$undefined"},{"id":"3027","book":"레위기","book_name":"레위기","chapter":11,"verse":29,"text":"땅에 기는 바 기는 것 중에 네게 부정한 것은 이러하니 곧 쪽제비와, 쥐와, 도마뱀 종류와,","reference":"레위기 11:29","category":"$undefined"},{"id":"3028","book":"레위기","book_name":"레위기","chapter":11,"verse":30,"text":"합개와, 육지 악어와, 수궁과, 사막 도마뱀과, 칠면석척이라","reference":"레위기 11:30","category":"$undefined"},{"id":"3029","book":"레위기","book_name":"레위기","chapter":11,"verse":31,"text":"모든 기는 것 중 이것들은 네게 부정하니 무릇 그 주검을 만지는 자는 저녁까지 부정할 것이며","reference":"레위기 11:31","category":"$undefined"},{"id":"3030","book":"레위기","book_name":"레위기","chapter":11,"verse":32,"text":"이런 것 중 어떤 것의 주검이 목기에든지, 의복에든지, 가죽에든지, 부대에든지, 무론 무엇에 쓰는 그릇에든지 떨어지면 부정하여지리니 물에 담그라 저녁까지 부정하다가 정할 것이며","reference":"레위기 11:32","category":"$undefined"},{"id":"3031","book":"레위기","book_name":"레위기","chapter":11,"verse":33,"text":"그것 중 어떤 것이 어느 질그릇에 떨어지면 그 속에 있는 것이 다 부정하여지나니 너는 그 그릇을 깨뜨리라","reference":"레위기 11:33","category":"$undefined"},{"id":"3032","book":"레위기","book_name":"레위기","chapter":11,"verse":34,"text":"먹을 만한 축축한 식물이 거기 담겼으면 부정하여질 것이요, 그 같은 그릇의 마실 만한 마실 것도 부정할 것이며","reference":"레위기 11:34","category":"$undefined"},{"id":"3033","book":"레위기","book_name":"레위기","chapter":11,"verse":35,"text":"이런 것의 주검이 물건 위에 떨어지면 그것이 모두 부정하여지리니 화덕이든지, 질탕관이든지 깨뜨려 버리라 ! 이것이 부정하여져서 너희에게 부정한 것이 되리라","reference":"레위기 11:35","category":"$undefined"},{"id":"3034","book":"레위기","book_name":"레위기","chapter":11,"verse":36,"text":"샘물이나 방축물 웅덩이는 부정하여지지 아니하되 그 주검에 다닥치는 것만 부정하여 질 것이요","reference":"레위기 11:36","category":"$undefined"},{"id":"3035","book":"레위기","book_name":"레위기","chapter":11,"verse":37,"text":"이것들의 주검이 심을 종자에 떨어질지라도 그것이 정하거니와","reference":"레위기 11:37","category":"$undefined"},{"id":"3036","book":"레위기","book_name":"레위기","chapter":11,"verse":38,"text":"종자에 물을 더할 때에 그것이 그 위에 떨어지면 너희에게 부정하리라","reference":"레위기 11:38","category":"$undefined"},{"id":"3037","book":"레위기","book_name":"레위기","chapter":11,"verse":39,"text":"너희의 먹을 만한 짐승이 죽은 때에 그 사체를 만지는 자는 저녁까지 부정할 것이며","reference":"레위기 11:39","category":"$undefined"},{"id":"3038","book":"레위기","book_name":"레위기","chapter":11,"verse":40,"text":"그것을 먹는 자는 그 옷을 빨 것이요 저녁까지 부정할 것이며 그 주검을 옮기는 자도 그 옷을 빨것이요 저녁까지 부정하리라","reference":"레위기 11:40","category":"$undefined"},{"id":"3039","book":"레위기","book_name":"레위기","chapter":11,"verse":41,"text":"땅에 기어 다니는 모든 기는 것은 가증한즉 먹지 못할지니","reference":"레위기 11:41","category":"$undefined"},{"id":"3040","book":"레위기","book_name":"레위기","chapter":11,"verse":42,"text":"곧 땅에 기어다니는 모든 기는 것 중에 배로 밀어 다니는 것이나 네 발로 걷는 것이나 여러 발을 가진 것이라 너희가 먹지 말지니 이는 가증함이니라","reference":"레위기 11:42","category":"$undefined"},{"id":"3041","book":"레위기","book_name":"레위기","chapter":11,"verse":43,"text":"너희는 기는바 기어다니는 것을 인하여 자기로 가증하게 되게 말며 또한 그것을 인하여 스스로 더럽혀 부정하게 되게 말라","reference":"레위기 11:43","category":"$undefined"},{"id":"3042","book":"레위기","book_name":"레위기","chapter":11,"verse":44,"text":"나는 여호와 너희 하나님이라 ! 내가 거룩하니 너희도 몸을 구별하여 거룩하게 하고 땅에 기는바 기어다니는 것으로 인하여 스스로 더럽히지 말라","reference":"레위기 11:44","category":"$undefined"},{"id":"3043","book":"레위기","book_name":"레위기","chapter":11,"verse":45,"text":"나는 너희의 하나님이 되려고 너희를 애굽 땅에서 인도하여 낸 여호와라 내가 거룩하니 너희도 거룩할지어다 !","reference":"레위기 11:45","category":"$undefined"},{"id":"3044","book":"레위기","book_name":"레위기","chapter":11,"verse":46,"text":"이는 짐승과 새와 물에서 움직이는 모든 생물과 땅에 기는 모든 기어다니는 것에 대한 규례니","reference":"레위기 11:46","category":"$undefined"},{"id":"3045","book":"레위기","book_name":"레위기","chapter":11,"verse":47,"text":"부정하고 정한 것과 먹을 생물과 먹지 못할 생물을 분별한 것이니라","reference":"레위기 11:47","category":"$undefined"}],"bookSlug":"leviticus"}]
