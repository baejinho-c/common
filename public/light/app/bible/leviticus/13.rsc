2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":13,"verses":[{"id":"3054","book":"레위기","book_name":"레위기","chapter":13,"verse":1,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"레위기 13:1","category":"$undefined"},{"id":"3055","book":"레위기","book_name":"레위기","chapter":13,"verse":2,"text":"사람의 피부에 무엇이 돋거나 딱지가 앉거나 색점이 생겨서 그 피부에 문둥병같이 되거든 곧 제사장 아론에게나 그 자손중 한 제사장에게로 데리고 갈 것이요","reference":"레위기 13:2","category":"$undefined"},{"id":"3056","book":"레위기","book_name":"레위기","chapter":13,"verse":3,"text":"제사장은 그 피부의 병을 진찰할지니 환처의 털이 희어졌고 환처가 피부보다 우묵하여졌으면 이는 문둥병의 환처라 제사장이 진단하여 그를 부정하다 할 것이요","reference":"레위기 13:3","category":"$undefined"},{"id":"3057","book":"레위기","book_name":"레위기","chapter":13,"verse":4,"text":"피부에 색점이 희나 우묵하지 아니하고 그 털이 희지 아니하면 제사장은 그 환자를 칠일동안 금고할 것이며","reference":"레위기 13:4","category":"$undefined"},{"id":"3058","book":"레위기","book_name":"레위기","chapter":13,"verse":5,"text":"칠일만에 제사장이 그를 진찰할지니 그의 보기에 그 환처가 변하지 아니하고 병색이 피부에 퍼지지 아니하였으면 제사장이 그를 또 칠일 동안을 금고할 것이며","reference":"레위기 13:5","category":"$undefined"},{"id":"3059","book":"레위기","book_name":"레위기","chapter":13,"verse":6,"text":"칠일만에 제사장이 또 진찰할지니 그 환처가 엷어졌고 병색이 피부에 퍼지지 아니하였으면 피부병이라 제사장이 그를 정하다 할 것이요 그는 옷을 빨 것이라 그리하면 정하리라","reference":"레위기 13:6","category":"$undefined"},{"id":"3060","book":"레위기","book_name":"레위기","chapter":13,"verse":7,"text":"그러나 정결한 여부를 위하여 제사장에게 보인 후에 병이 피부에 퍼지면 제사장에게 다시 보일 것이요","reference":"레위기 13:7","category":"$undefined"},{"id":"3061","book":"레위기","book_name":"레위기","chapter":13,"verse":8,"text":"제사장은 진찰할지니 그 병이 피부에 퍼졌으면 그를 부정하다 진단할 것이라 이는 문둥병임이니라","reference":"레위기 13:8","category":"$undefined"},{"id":"3062","book":"레위기","book_name":"레위기","chapter":13,"verse":9,"text":"사람에게 문둥병이 들었거든 그를 제사장에게로 데려갈 것이요","reference":"레위기 13:9","category":"$undefined"},{"id":"3063","book":"레위기","book_name":"레위기","chapter":13,"verse":10,"text":"제사장은 진찰할지니 피부에 흰 점이 돋고 털이 희어지고 거기 난육이 생겼으면","reference":"레위기 13:10","category":"$undefined"},{"id":"3064","book":"레위기","book_name":"레위기","chapter":13,"verse":11,"text":"이는 그의 피부의 오랜 문둥병이라 제사장이 부정하다 진단할 것이요 그가 이미 부정하였은즉 금고하지는 않을 것이며","reference":"레위기 13:11","category":"$undefined"},{"id":"3065","book":"레위기","book_name":"레위기","chapter":13,"verse":12,"text":"제사장의 보기에 문둥병이 그 피부에 크게 발하였으되 그 환자의 머리부터 발까지 퍼졌거든","reference":"레위기 13:12","category":"$undefined"},{"id":"3066","book":"레위기","book_name":"레위기","chapter":13,"verse":13,"text":"그가 진찰할 것이요 문둥병이 과연 그 전신에 퍼졌으면 그 환자를 정하다 할지니 다 희어진 자인즉 정하거니와","reference":"레위기 13:13","category":"$undefined"},{"id":"3067","book":"레위기","book_name":"레위기","chapter":13,"verse":14,"text":"아무 때든지 그에게 난육이 발생하면 그는 부정한즉","reference":"레위기 13:14","category":"$undefined"},{"id":"3068","book":"레위기","book_name":"레위기","chapter":13,"verse":15,"text":"제사장이 난육을 보고 그를 부정하다 진단할지니 그 난육은 부정한 것인즉 이는 문둥병이며","reference":"레위기 13:15","category":"$undefined"},{"id":"3069","book":"레위기","book_name":"레위기","chapter":13,"verse":16,"text":"그 난육이 변하여 다시 희어지면 제사장에게로 갈 것이요","reference":"레위기 13:16","category":"$undefined"},{"id":"3070","book":"레위기","book_name":"레위기","chapter":13,"verse":17,"text":"제사장은 그를 진찰하여서 그 환처가 희어졌으면 환자를 정하다 할지니 그는 정하니라","reference":"레위기 13:17","category":"$undefined"},{"id":"3071","book":"레위기","book_name":"레위기","chapter":13,"verse":18,"text":"피부에 종기가 생겼다가 나았고","reference":"레위기 13:18","category":"$undefined"},{"id":"3072","book":"레위기","book_name":"레위기","chapter":13,"verse":19,"text":"그 종처에 흰 점이 돋거나 희고 불그스름한 색점이 생겼으면 제사장에게 보일 것이요","reference":"레위기 13:19","category":"$undefined"},{"id":"3073","book":"레위기","book_name":"레위기","chapter":13,"verse":20,"text":"그는 진찰하여 피부보다 얕고 그 털이 희면 그를 부정하다 진단할지니 이는 종기로 된 문둥병의 환처임이니라","reference":"레위기 13:20","category":"$undefined"},{"id":"3074","book":"레위기","book_name":"레위기","chapter":13,"verse":21,"text":"그러나 제사장의 보기에 거기 흰 털이 없고 피부보다 얕지 아니하고 빛이 엷으면 제사장은 그를 칠일 동안 금고할 것이며","reference":"레위기 13:21","category":"$undefined"},{"id":"3075","book":"레위기","book_name":"레위기","chapter":13,"verse":22,"text":"그 병이 크게 피부에 퍼졌으면 제사장은 그를 부정하다 진단할지니 이는 그 환처임이니라","reference":"레위기 13:22","category":"$undefined"},{"id":"3076","book":"레위기","book_name":"레위기","chapter":13,"verse":23,"text":"그러나 그 색점이 여전하고 퍼지지 아니하였으면 이는 종기 흔적이니 제사장은 그를 정하다 진단할지니라","reference":"레위기 13:23","category":"$undefined"},{"id":"3077","book":"레위기","book_name":"레위기","chapter":13,"verse":24,"text":"피부를 불에 데었는데 그 덴 곳에 불그스름하고 희거나 순전히 흰 색점이 생기면","reference":"레위기 13:24","category":"$undefined"},{"id":"3078","book":"레위기","book_name":"레위기","chapter":13,"verse":25,"text":"제사장은 진찰할지니 그 색점의 털이 희고 그 자리가 피부보다 우묵하면 이는 화상에서 발한 문둥병인즉 제사장은 그를 부정하다 할 것은 문둥병의 환처가 됨이니라","reference":"레위기 13:25","category":"$undefined"},{"id":"3079","book":"레위기","book_name":"레위기","chapter":13,"verse":26,"text":"그러나 제사장의 보기에 그 색점에 흰 털이 없으며 그 자리가 피부보다 얕지 아니하고 빛이 엷으면 그는 그를 칠일동안 금고할 것이며","reference":"레위기 13:26","category":"$undefined"},{"id":"3080","book":"레위기","book_name":"레위기","chapter":13,"verse":27,"text":"칠일만에 제사장이 그를 진찰할지니 만일 병이 크게 피부에 퍼졌으면 그는 그를 부정하다 진단할 것은 문둥병의 환처임이니라","reference":"레위기 13:27","category":"$undefined"},{"id":"3081","book":"레위기","book_name":"레위기","chapter":13,"verse":28,"text":"만일 색점이 여전하여 피부에 퍼지지 아니하고 빛이 엷으면 화상으로 부은 것이니 제사장은 그를 정하다 할 것은 이는 화상의 흔적임이니라","reference":"레위기 13:28","category":"$undefined"},{"id":"3082","book":"레위기","book_name":"레위기","chapter":13,"verse":29,"text":"남자나 여자의 머리에나 수염에 환처가 있으면","reference":"레위기 13:29","category":"$undefined"},{"id":"3083","book":"레위기","book_name":"레위기","chapter":13,"verse":30,"text":"제사장은 진찰할지니 환처가 피부보다 우묵하고 그 자리에 누르고 가는 털이 있으면 그는 그를 부정하다 할 것은 이는 옴이라 머리에나 수염에 발한 문둥병임이니라","reference":"레위기 13:30","category":"$undefined"},{"id":"3084","book":"레위기","book_name":"레위기","chapter":13,"verse":31,"text":"만일 제사장의 보기에 그 옴의 환처가 피부보다 우묵하지 아니하고 그 자리에 검은 털이 없으면 제사장은 그 옴 환자를 칠일 동안 금고할 것이며","reference":"레위기 13:31","category":"$undefined"},{"id":"3085","book":"레위기","book_name":"레위기","chapter":13,"verse":32,"text":"칠일만에 제사장은 그 환처를 진찰할지니 그 옴이 퍼지지 아니하고 그 자리에 누른 털이 없고 피부보다 우묵하지 아니하거든","reference":"레위기 13:32","category":"$undefined"},{"id":"3086","book":"레위기","book_name":"레위기","chapter":13,"verse":33,"text":"그는 모발을 밀되 환처는 밀지 말 것이요 제사장은 옴 환자를 또 칠일 동안 금고할 것이며","reference":"레위기 13:33","category":"$undefined"},{"id":"3087","book":"레위기","book_name":"레위기","chapter":13,"verse":34,"text":"칠일만에 제사장은 그 옴을 또 진찰할지니 그 옴이 피부에 퍼지지 아니하고 피부보다 우묵하지 아니하면 그는 그를 정하다 진단할 것이요 그는 그 옷을 빨지니 정하려니와","reference":"레위기 13:34","category":"$undefined"},{"id":"3088","book":"레위기","book_name":"레위기","chapter":13,"verse":35,"text":"깨끗한 후에라도 옴이 크게 피부에 퍼지면","reference":"레위기 13:35","category":"$undefined"},{"id":"3089","book":"레위기","book_name":"레위기","chapter":13,"verse":36,"text":"제사장은 그를 진찰할지니 과연 옴이 피부에 퍼졌으면 누른 털을 찾을 것 없이 그는 부정하니라","reference":"레위기 13:36","category":"$undefined"},{"id":"3090","book":"레위기","book_name":"레위기","chapter":13,"verse":37,"text":"그러나 제사장의 보기에 옴이 여전하고 그 자리에 검은 털이 났으면 그 옴은 나았고 그 사람은 정하니 제사장은 그를 정하다 진단할지니라","reference":"레위기 13:37","category":"$undefined"},{"id":"3091","book":"레위기","book_name":"레위기","chapter":13,"verse":38,"text":"남자나 여자의 피부에 색점 곧 흰 색점이 있으면","reference":"레위기 13:38","category":"$undefined"},{"id":"3092","book":"레위기","book_name":"레위기","chapter":13,"verse":39,"text":"제사장은 진찰할지니 그 피부의 색점이 부유스름하면 이는 피부에 발한 어루러기라 그는 정하니라","reference":"레위기 13:39","category":"$undefined"},{"id":"3093","book":"레위기","book_name":"레위기","chapter":13,"verse":40,"text":"누구든지 그 머리털이 빠지면 그는 대머리니 정하고","reference":"레위기 13:40","category":"$undefined"},{"id":"3094","book":"레위기","book_name":"레위기","chapter":13,"verse":41,"text":"앞머리가 빠져도 그는 이마 대머리니 정하니라","reference":"레위기 13:41","category":"$undefined"},{"id":"3095","book":"레위기","book_name":"레위기","chapter":13,"verse":42,"text":"그러나 대머리나 이마 대머리에 희고 불그스름한 색점이 있으면 이는 문둥병이 대머리에나 이마 대머리에 발함이라","reference":"레위기 13:42","category":"$undefined"},{"id":"3096","book":"레위기","book_name":"레위기","chapter":13,"verse":43,"text":"제사장은 그를 진찰할지니 그 대머리에나 이마 대머리에 돋은 색점이 희고 불그스름하여 피부에 발한 문둥병과 같으면","reference":"레위기 13:43","category":"$undefined"},{"id":"3097","book":"레위기","book_name":"레위기","chapter":13,"verse":44,"text":"이는 문둥 환자라 부정하니 제사장은 그를 부정하다 확실히 진단할 것은 그 환처가 그 머리에 있음이니라","reference":"레위기 13:44","category":"$undefined"},{"id":"3098","book":"레위기","book_name":"레위기","chapter":13,"verse":45,"text":"문둥 환자는 옷을 찢고 머리를 풀며 윗 입술을 가리우고 외치기를 부정하다 부정하다 할 것이요","reference":"레위기 13:45","category":"$undefined"},{"id":"3099","book":"레위기","book_name":"레위기","chapter":13,"verse":46,"text":"병 있는 날 동안은 늘 부정할 것이라 그가 부정한즉 혼자 살되 진 밖에 살지니라 !","reference":"레위기 13:46","category":"$undefined"},{"id":"3100","book":"레위기","book_name":"레위기","chapter":13,"verse":47,"text":"만일 의복에 문둥병 색점이 발하여 털옷에나, 베옷에나","reference":"레위기 13:47","category":"$undefined"},{"id":"3101","book":"레위기","book_name":"레위기","chapter":13,"verse":48,"text":"베나, 털의 날에나, 씨에나, 혹 가죽에나, 무릇 가죽으로 만든 것에 있되","reference":"레위기 13:48","category":"$undefined"},{"id":"3102","book":"레위기","book_name":"레위기","chapter":13,"verse":49,"text":"그 의복에나, 가죽에나, 그 날에나, 씨에나, 무릇 가죽으로 만든 것에 병색이 푸르거나 붉으면 이는 문둥병의 색점이라 제사장에게 보일 것이요","reference":"레위기 13:49","category":"$undefined"},{"id":"3103","book":"레위기","book_name":"레위기","chapter":13,"verse":50,"text":"제사장은 그 색점을 살피고 그것을 칠일 동안 간직하였다가","reference":"레위기 13:50","category":"$undefined"},{"id":"3104","book":"레위기","book_name":"레위기","chapter":13,"verse":51,"text":"칠일만에 그 색점을 살필지니 그 색점이 그 의복의 날에나, 씨에나, 가죽에나, 가죽으로 만든 것에 퍼졌으면 이는 악성 문둥병이라 그것이 부정하니","reference":"레위기 13:51","category":"$undefined"},{"id":"3105","book":"레위기","book_name":"레위기","chapter":13,"verse":52,"text":"그는 그 색점 있는 의복이나, 털이나, 베의 날이나, 씨나, 무릇 가죽으로 만든 것을 불사를지니 이는 악성 문둥병인즉 그것을 불사를지니라 !","reference":"레위기 13:52","category":"$undefined"},{"id":"3106","book":"레위기","book_name":"레위기","chapter":13,"verse":53,"text":"그러나 제사장의 보기에 그 색점이 그 의복의 날에나, 씨에나, 무릇 가죽으로 만든 것에 퍼지지 아니하였으면","reference":"레위기 13:53","category":"$undefined"},{"id":"3107","book":"레위기","book_name":"레위기","chapter":13,"verse":54,"text":"제사장은 명하여 그 색점 있는 것을 빨게하고 또 칠일 동안 간직하였다가","reference":"레위기 13:54","category":"$undefined"},{"id":"3108","book":"레위기","book_name":"레위기","chapter":13,"verse":55,"text":"그 빤 곳을 볼지니 그 색점의 빛이 변치 아니하고 그 색점이 퍼지지 아니하였으면 부정하니 너는 그것을 불사르라 이는 거죽에 있든지, 속에 있든지, 악성 문둥병이니라","reference":"레위기 13:55","category":"$undefined"},{"id":"3109","book":"레위기","book_name":"레위기","chapter":13,"verse":56,"text":"빤 후에 제사장의 보기에 그 색점이 엷으면 그 의복에서나, 가죽에서나, 그 날에서나, 씨에서나, 그 색점을 찢어 버릴 것이요","reference":"레위기 13:56","category":"$undefined"},{"id":"3110","book":"레위기","book_name":"레위기","chapter":13,"verse":57,"text":"그 의복의 날에나 씨에나 무릇 가죽으로 만든 것에 색점이 여전히 보이면 복발하는 것이니 너는 그 색점있는 것을 불사를지니라","reference":"레위기 13:57","category":"$undefined"},{"id":"3111","book":"레위기","book_name":"레위기","chapter":13,"verse":58,"text":"네가 빤 의복의 날에나, 씨에나, 무릇 가죽으로 만든 것에 그 색점이 벗어졌으면 그것을 다시 빨아야 정하리라","reference":"레위기 13:58","category":"$undefined"},{"id":"3112","book":"레위기","book_name":"레위기","chapter":13,"verse":59,"text":"이는 털옷에나, 베옷에나, 그 날에나, 씨에나, 무릇 가죽으로 만든 것에 발한 문둥병 색점의 정하고 부정한 것을 단정하는 규례니라","reference":"레위기 13:59","category":"$undefined"}],"bookSlug":"leviticus"}]
