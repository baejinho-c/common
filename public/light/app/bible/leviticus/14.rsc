2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":14,"verses":[{"id":"3113","book":"레위기","book_name":"레위기","chapter":14,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 14:1","category":"$undefined"},{"id":"3114","book":"레위기","book_name":"레위기","chapter":14,"verse":2,"text":"문둥 환자의 정결케 되는 날의 규례는 이러하니 곧 그 사람을 제사장에게로 데려갈 것이요","reference":"레위기 14:2","category":"$undefined"},{"id":"3115","book":"레위기","book_name":"레위기","chapter":14,"verse":3,"text":"제사장은 진에서 나가서 진찰할지니 그 환자에게 있던 문둥병 환처가 나았으면","reference":"레위기 14:3","category":"$undefined"},{"id":"3116","book":"레위기","book_name":"레위기","chapter":14,"verse":4,"text":"제사장은 그를 위하여 명하여 정한 산 새 두마리와, 백향목과, 홍색실과, 우슬초를 가져오게 하고","reference":"레위기 14:4","category":"$undefined"},{"id":"3117","book":"레위기","book_name":"레위기","chapter":14,"verse":5,"text":"제사장은 또 명하여 그 새 하나는 흐르는 물 위 질그릇 안에서 잡게 하고","reference":"레위기 14:5","category":"$undefined"},{"id":"3118","book":"레위기","book_name":"레위기","chapter":14,"verse":6,"text":"다른 새는 산대로 취하여 백향목과, 홍색실과, 우슬초와 함께 가져다가 흐르는 물 위에서 잡은 새 피를 찍어","reference":"레위기 14:6","category":"$undefined"},{"id":"3119","book":"레위기","book_name":"레위기","chapter":14,"verse":7,"text":"문둥병에서 정결함을 받을 자에게 일곱번 뿌려 정하다 하고 그 산 새는 들에 놓을지며","reference":"레위기 14:7","category":"$undefined"},{"id":"3120","book":"레위기","book_name":"레위기","chapter":14,"verse":8,"text":"정결함을 받는 자는 그 옷을 빨고 모든 털을 밀고 물로 몸을 씻을 것이라 그리하면 정하리니 그 후에 진에 들어올 것이나 자기 장막 밖에 칠일을 거할 것이요","reference":"레위기 14:8","category":"$undefined"},{"id":"3121","book":"레위기","book_name":"레위기","chapter":14,"verse":9,"text":"칠일만에 그 모든 털을 밀되 머리털과 수염과 눈썹을 다 밀고 그 옷을 빨고 몸을 물에 씻을 것이라 그리하면 정하리라","reference":"레위기 14:9","category":"$undefined"},{"id":"3122","book":"레위기","book_name":"레위기","chapter":14,"verse":10,"text":"제 팔일에 그는 흠 없는 어린 수양 둘과 일년 된 흠 없는 어린 암양 하나와 또 고운 가루 에바 십분 삼에 기름 섞은 소제물과 기름 한 록을 취할 것이요","reference":"레위기 14:10","category":"$undefined"},{"id":"3123","book":"레위기","book_name":"레위기","chapter":14,"verse":11,"text":"정결케 하는 제사장은 정결함을 받을 자와 그 물건들을 회막 문 여호와 앞에 두고","reference":"레위기 14:11","category":"$undefined"},{"id":"3124","book":"레위기","book_name":"레위기","chapter":14,"verse":12,"text":"어린 수양 하나를 취하여 기름 한 록과 아울러 속건제로 드리되 여호와 앞에 흔들어 요제를 삼고","reference":"레위기 14:12","category":"$undefined"},{"id":"3125","book":"레위기","book_name":"레위기","chapter":14,"verse":13,"text":"그 어린 수양은 거룩한 장소 곧 속죄제와 번제 희생 잡는 곳에서 잡을 것이며 속건 제물은 속죄 제물과 일례로 제사장에게 돌릴지니 이는 지극히 거룩한 것이니라","reference":"레위기 14:13","category":"$undefined"},{"id":"3126","book":"레위기","book_name":"레위기","chapter":14,"verse":14,"text":"제사장은 그 속건제 희생의 피를 취하여 정결함을 받을 자의 우편 귓부리와, 우편 손 엄지가락과, 우편 발 엄지가락에 바를 것이요","reference":"레위기 14:14","category":"$undefined"},{"id":"3127","book":"레위기","book_name":"레위기","chapter":14,"verse":15,"text":"제사장은 또 그 한 록의 기름을 취하여 자기 좌편 손바닥에 따르고","reference":"레위기 14:15","category":"$undefined"},{"id":"3128","book":"레위기","book_name":"레위기","chapter":14,"verse":16,"text":"우편 손가락으로 좌편 손의 기름을 찍어 그 손가락으로 그것을 여호와 앞에 일곱번 뿌릴 것이요","reference":"레위기 14:16","category":"$undefined"},{"id":"3129","book":"레위기","book_name":"레위기","chapter":14,"verse":17,"text":"손에 남은 기름은 제사장이 정결함을 받는 자의 우편 귓부리와, 우편 손 엄지가락과, 우편 발 엄지가락 곧 속건제 희생의 피 위에 바를 것이며","reference":"레위기 14:17","category":"$undefined"},{"id":"3130","book":"레위기","book_name":"레위기","chapter":14,"verse":18,"text":"오히려 그 손에 남은 기름은 제사장이 그 정결함을 받는 자의 머리에 바르고 여호와 앞에서 제사장은 그를 위하여 속죄하고","reference":"레위기 14:18","category":"$undefined"},{"id":"3131","book":"레위기","book_name":"레위기","chapter":14,"verse":19,"text":"또 제사장은 속죄제를 드려 그 부정함을 인하여 정결함을 받으려는 자를 위하여 속죄하고 그 후에 번제 희생을 잡을 것이요","reference":"레위기 14:19","category":"$undefined"},{"id":"3132","book":"레위기","book_name":"레위기","chapter":14,"verse":20,"text":"제사장은 그 번제와 소제를 단에 드려 그를 위하여 속죄할 것이라 그리하면 그가 정결하리라 !","reference":"레위기 14:20","category":"$undefined"},{"id":"3133","book":"레위기","book_name":"레위기","chapter":14,"verse":21,"text":"그가 가난하여 이에 힘이 미치지 못하면 그는 흔들어 자기를 속할 속건제를 위하여 어린 수양 하나와 소제를 위하여 고운 가루 에바 십분 일에 기름 섞은 것과 기름 한 록을 취하고","reference":"레위기 14:21","category":"$undefined"},{"id":"3134","book":"레위기","book_name":"레위기","chapter":14,"verse":22,"text":"그 힘이 미치는 대로 산비둘기 둘이나 집비둘기 새끼 둘을 취하되 하나는 속죄 제물로,하나는 번제물로 삼아","reference":"레위기 14:22","category":"$undefined"},{"id":"3135","book":"레위기","book_name":"레위기","chapter":14,"verse":23,"text":"제 팔일에 그 결례를 위하여 그것들을 회막 문 여호와 앞 제사장에게로 가져갈 것이요","reference":"레위기 14:23","category":"$undefined"},{"id":"3136","book":"레위기","book_name":"레위기","chapter":14,"verse":24,"text":"제사장은 속건제 어린 양과 기름 한 록을 취하여 여호와 앞에 흔들어 요제를 삼고","reference":"레위기 14:24","category":"$undefined"},{"id":"3137","book":"레위기","book_name":"레위기","chapter":14,"verse":25,"text":"속건제의 어린 양을 잡아서 제사장은 그 속건제 희생의 피를 취하여 정결함을 받을 자의 우편 손 엄지 가락과, 우편 발 엄지가락에 바를 것이요","reference":"레위기 14:25","category":"$undefined"},{"id":"3138","book":"레위기","book_name":"레위기","chapter":14,"verse":26,"text":"제사장은 그 기름을 자기 좌편 손바닥에 따르고","reference":"레위기 14:26","category":"$undefined"},{"id":"3139","book":"레위기","book_name":"레위기","chapter":14,"verse":27,"text":"우편 손가락으로 좌편 손의 기름을 조금 찍어 여호와 앞에 일곱번 뿌릴 것이요","reference":"레위기 14:27","category":"$undefined"},{"id":"3140","book":"레위기","book_name":"레위기","chapter":14,"verse":28,"text":"그 손의 기름은 제사장이 정결함을 받을 자의 우편 귓부리와, 우편 손 엄지가락과, 우편 발 엄지가락 곧 속건제 희생의 피를 바른 곳에 바를 것이며","reference":"레위기 14:28","category":"$undefined"},{"id":"3141","book":"레위기","book_name":"레위기","chapter":14,"verse":29,"text":"또 그 손에 남은 기름은 제사장이 그 정결함을 받는 자의 머리에 발라 여호와 앞에서 그를 위하여 속죄할 것이며","reference":"레위기 14:29","category":"$undefined"},{"id":"3142","book":"레위기","book_name":"레위기","chapter":14,"verse":30,"text":"그는 힘이 미치는 대로 산비둘기 하나나 집비둘기 새끼 하나를 드리되","reference":"레위기 14:30","category":"$undefined"},{"id":"3143","book":"레위기","book_name":"레위기","chapter":14,"verse":31,"text":"곧 그 힘이 미치는 것의 하나는 속죄제로, 나는 소제와 함께 번제로 드릴 것이요, 제사장은 정결함을 받을 자를 위하여 여호와 앞에 속죄할지니","reference":"레위기 14:31","category":"$undefined"},{"id":"3144","book":"레위기","book_name":"레위기","chapter":14,"verse":32,"text":"문둥병 환자로서 그 결례에 힘이 부족한 자의 규례가 이러하니라","reference":"레위기 14:32","category":"$undefined"},{"id":"3145","book":"레위기","book_name":"레위기","chapter":14,"verse":33,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"레위기 14:33","category":"$undefined"},{"id":"3146","book":"레위기","book_name":"레위기","chapter":14,"verse":34,"text":"내가 네게 기업으로 주는 가나안 땅에 너희가 이른 때에 내가 너희 기업의 땅에서 어느 집에 문둥병 색점을 발하게 하거든","reference":"레위기 14:34","category":"$undefined"},{"id":"3147","book":"레위기","book_name":"레위기","chapter":14,"verse":35,"text":"그 집 주인은 제사장에게 와서 고하기를 무슨 색점이 집에 생겼다 할 것이요","reference":"레위기 14:35","category":"$undefined"},{"id":"3148","book":"레위기","book_name":"레위기","chapter":14,"verse":36,"text":"제사장은 그 색점을 보러 가기 전에 그 가장 집물에 부정을 면케하기 위하여 명하여 그 집을 비게 한 후에 들어가서 그 집을 볼지니","reference":"레위기 14:36","category":"$undefined"},{"id":"3149","book":"레위기","book_name":"레위기","chapter":14,"verse":37,"text":"그 색점을 볼 때에 그 집 벽에 푸르거나 붉은 무늬의 색점이 있어 벽보다 우묵하면","reference":"레위기 14:37","category":"$undefined"},{"id":"3150","book":"레위기","book_name":"레위기","chapter":14,"verse":38,"text":"제사장은 그 집 문으로 나와 그 집을 칠일 동안 폐쇄하였다가","reference":"레위기 14:38","category":"$undefined"},{"id":"3151","book":"레위기","book_name":"레위기","chapter":14,"verse":39,"text":"칠일만에 또 와서 살펴볼 것이요 그 색점이 벽에 퍼졌으면","reference":"레위기 14:39","category":"$undefined"},{"id":"3152","book":"레위기","book_name":"레위기","chapter":14,"verse":40,"text":"그는 명하여 색점 있는 돌을 빼어 성 밖 부정한 곳에 버리게 하고","reference":"레위기 14:40","category":"$undefined"},{"id":"3153","book":"레위기","book_name":"레위기","chapter":14,"verse":41,"text":"또 집안 사면을 긁게 하고 그 긁은 흙을 성 밖 부정한 곳에 쏟아버리게 할 것이요","reference":"레위기 14:41","category":"$undefined"},{"id":"3154","book":"레위기","book_name":"레위기","chapter":14,"verse":42,"text":"그들은 다른 돌로 그 돌을 대신하며 다른 흙으로 집에 바를지니라","reference":"레위기 14:42","category":"$undefined"},{"id":"3155","book":"레위기","book_name":"레위기","chapter":14,"verse":43,"text":"돌을 빼며 집을 긁고 고쳐 바른 후에 색점이 집에 복발하거든","reference":"레위기 14:43","category":"$undefined"},{"id":"3156","book":"레위기","book_name":"레위기","chapter":14,"verse":44,"text":"제사장은 또 와서 살펴볼 것이요 그 색점이 만일 집에 퍼졌으면 악성 문둥병인즉 이는 부정하니","reference":"레위기 14:44","category":"$undefined"},{"id":"3157","book":"레위기","book_name":"레위기","chapter":14,"verse":45,"text":"그는 그 집을 헐고 돌과 그 재목과 그 집의 모든 흙을 성 밖 부정한 곳으로 내어갈 것이며","reference":"레위기 14:45","category":"$undefined"},{"id":"3158","book":"레위기","book_name":"레위기","chapter":14,"verse":46,"text":"그 집을 폐쇄한 날 동안에 들어가는 자는 저녁까지 부정할 것이요","reference":"레위기 14:46","category":"$undefined"},{"id":"3159","book":"레위기","book_name":"레위기","chapter":14,"verse":47,"text":"그 집에서 자는 자는 그 옷을 빨 것이요 그 집에서 먹는 자도 그 옷을 빨 것이니라","reference":"레위기 14:47","category":"$undefined"},{"id":"3160","book":"레위기","book_name":"레위기","chapter":14,"verse":48,"text":"그 집을 고쳐 바른 후에 제사장이 들어가 살펴 보아서 색점이 집에 퍼지지 아니하였으면 이는 색점이 나은 것이니 제사장은 그 집을 정하다 하고","reference":"레위기 14:48","category":"$undefined"},{"id":"3161","book":"레위기","book_name":"레위기","chapter":14,"verse":49,"text":"그는 그 집을 정결케 하기 위하여 새 두마리와, 백향목과, 홍색실과, 우슬초를 취하고","reference":"레위기 14:49","category":"$undefined"},{"id":"3162","book":"레위기","book_name":"레위기","chapter":14,"verse":50,"text":"그 새 하나를 흐르는 물 위 질그릇 안에서 잡고","reference":"레위기 14:50","category":"$undefined"},{"id":"3163","book":"레위기","book_name":"레위기","chapter":14,"verse":51,"text":"백향목과, 우슬초와, 홍색실과, 산새를 가져다가 잡은 새의 피와 흐르는 물을 찍어 그 집에 일곱번 뿌릴 것이요","reference":"레위기 14:51","category":"$undefined"},{"id":"3164","book":"레위기","book_name":"레위기","chapter":14,"verse":52,"text":"그는 새의 피와, 흐르는 물과, 산새와, 백향목과, 우슬초와, 홍색실로 집을 정결케 하고","reference":"레위기 14:52","category":"$undefined"},{"id":"3165","book":"레위기","book_name":"레위기","chapter":14,"verse":53,"text":"그 산새는 성 밖 들에 놓아 그 집을 위하여 속할 것이라 그리하면 정결하리라 !","reference":"레위기 14:53","category":"$undefined"},{"id":"3166","book":"레위기","book_name":"레위기","chapter":14,"verse":54,"text":"이는 각종 문둥병 환처에 대한 규례니 곧 옴과","reference":"레위기 14:54","category":"$undefined"},{"id":"3167","book":"레위기","book_name":"레위기","chapter":14,"verse":55,"text":"의복과 가옥의 문둥병과","reference":"레위기 14:55","category":"$undefined"},{"id":"3168","book":"레위기","book_name":"레위기","chapter":14,"verse":56,"text":"붓는 것과 피부병과 색점의","reference":"레위기 14:56","category":"$undefined"},{"id":"3169","book":"레위기","book_name":"레위기","chapter":14,"verse":57,"text":"언제는 부정하고 언제는 정함을 가르치는 것이니 문둥병의 규례가 이러하니라","reference":"레위기 14:57","category":"$undefined"}],"bookSlug":"leviticus"}]
