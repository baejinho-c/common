2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":15,"verses":[{"id":"3170","book":"레위기","book_name":"레위기","chapter":15,"verse":1,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"레위기 15:1","category":"$undefined"},{"id":"3171","book":"레위기","book_name":"레위기","chapter":15,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 누구든지 몸에 유출병이 있으면 그 유출병을 인하여 부정한 자라","reference":"레위기 15:2","category":"$undefined"},{"id":"3172","book":"레위기","book_name":"레위기","chapter":15,"verse":3,"text":"그 유출병으로 말미암아 부정함이 이러하니 곧 몸에서 흘러 나오든지 그것이 엉겼든지 부정한즉","reference":"레위기 15:3","category":"$undefined"},{"id":"3173","book":"레위기","book_name":"레위기","chapter":15,"verse":4,"text":"유출병 있는 자의 눕는 상은 다 부정하고 그의 앉았던 자리도 다 부정하니","reference":"레위기 15:4","category":"$undefined"},{"id":"3174","book":"레위기","book_name":"레위기","chapter":15,"verse":5,"text":"그 침상에 접촉하는 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:5","category":"$undefined"},{"id":"3175","book":"레위기","book_name":"레위기","chapter":15,"verse":6,"text":"유출병 있는 자의 앉았던 자리에 앉는 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:6","category":"$undefined"},{"id":"3176","book":"레위기","book_name":"레위기","chapter":15,"verse":7,"text":"유출병 있는 자의 몸에 접촉하는 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:7","category":"$undefined"},{"id":"3177","book":"레위기","book_name":"레위기","chapter":15,"verse":8,"text":"유출병 있는 자가 정한 자에게 침을 뱉으면 정한 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:8","category":"$undefined"},{"id":"3178","book":"레위기","book_name":"레위기","chapter":15,"verse":9,"text":"유출병 있는 자의 탔던 안장은 다 부정하며","reference":"레위기 15:9","category":"$undefined"},{"id":"3179","book":"레위기","book_name":"레위기","chapter":15,"verse":10,"text":"그 몸 아래 닿았던 것에 접촉한 자는 다 저녁까지 부정하며 그런 것을 옮기는 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:10","category":"$undefined"},{"id":"3180","book":"레위기","book_name":"레위기","chapter":15,"verse":11,"text":"유출병 있는 자가 물로 손을 씻지 아니하고 아무든지 만지면 그 자는 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:11","category":"$undefined"},{"id":"3181","book":"레위기","book_name":"레위기","chapter":15,"verse":12,"text":"유출병 있는 자의 만진 질그릇은 깨뜨리고 목기는 다 물로 씻을지니라","reference":"레위기 15:12","category":"$undefined"},{"id":"3182","book":"레위기","book_name":"레위기","chapter":15,"verse":13,"text":"유출병 있는 자는 그 유출이 깨끗하여지거든 그 몸이 정결하기 위하여 칠일을 계산하여 옷을 빨고 흐르는 물에 몸을 씻을 것이요 그리하면 정하리니","reference":"레위기 15:13","category":"$undefined"},{"id":"3183","book":"레위기","book_name":"레위기","chapter":15,"verse":14,"text":"제 팔일에 산비둘기 둘이나 집비둘기 새끼 둘을 자기를 위하여 취하고 회막 문 여호와 앞으로 가서 제사장에게 줄 것이요","reference":"레위기 15:14","category":"$undefined"},{"id":"3184","book":"레위기","book_name":"레위기","chapter":15,"verse":15,"text":"제사장은 그 하나는 속죄제로, 하나는 번제로 드려 그의 유출병을 인하여 여호와 앞에 속죄할지니라 !","reference":"레위기 15:15","category":"$undefined"},{"id":"3185","book":"레위기","book_name":"레위기","chapter":15,"verse":16,"text":"설정한 자는 전신을 물로 씻을 것이며 저녁까지 부정하리라","reference":"레위기 15:16","category":"$undefined"},{"id":"3186","book":"레위기","book_name":"레위기","chapter":15,"verse":17,"text":"무릇 정수가 묻은 옷이나 가죽은 물에 빨 것이며 저녁까지 부정하리라","reference":"레위기 15:17","category":"$undefined"},{"id":"3187","book":"레위기","book_name":"레위기","chapter":15,"verse":18,"text":"남녀가 동침하여 설정하였거든 둘 다 물로 몸을 씻을 것이며 저까지 부정하리라","reference":"레위기 15:18","category":"$undefined"},{"id":"3188","book":"레위기","book_name":"레위기","chapter":15,"verse":19,"text":"어떤 여인이 유출을 하되 그 유출이 피면 칠일 동안 불결하니 무릇 그를 만지는 자는 저녁까지 부정할 것이요","reference":"레위기 15:19","category":"$undefined"},{"id":"3189","book":"레위기","book_name":"레위기","chapter":15,"verse":20,"text":"그 불결할 동안에 그의 누웠던 자리는 다 부정하며 그의 앉았던 자리도 다 부정한즉","reference":"레위기 15:20","category":"$undefined"},{"id":"3190","book":"레위기","book_name":"레위기","chapter":15,"verse":21,"text":"그 침상을 만지는 자는 다 옷을 빨고 물로 몸을 씻을 것이요 저녁까지 부정할 것이며","reference":"레위기 15:21","category":"$undefined"},{"id":"3191","book":"레위기","book_name":"레위기","chapter":15,"verse":22,"text":"그 좌석을 만지는 자도 다 옷을 빨고 물로 몸을 씻을 것이요 저녁까지 부정할 것이며","reference":"레위기 15:22","category":"$undefined"},{"id":"3192","book":"레위기","book_name":"레위기","chapter":15,"verse":23,"text":"그의 침상과 무릇 그 좌석에 있는 것을 만지는 자도 저녁까지 부정할 것이며","reference":"레위기 15:23","category":"$undefined"},{"id":"3193","book":"레위기","book_name":"레위기","chapter":15,"verse":24,"text":"누구든지 이 여인과 동침하여 그 불결에 전염되면 칠일 동안 부정할 것이라 그의 눕는 상은 무릇 부정하니라","reference":"레위기 15:24","category":"$undefined"},{"id":"3194","book":"레위기","book_name":"레위기","chapter":15,"verse":25,"text":"여인의 피의 유출이 그 불결기 외에 있어서 여러 날이 간다든지 그 유출이 불결기를 지나든지 하면 그 부정을 유출하는 날 동안은 무릇 그 불결한 때와 같이 부정한즉","reference":"레위기 15:25","category":"$undefined"},{"id":"3195","book":"레위기","book_name":"레위기","chapter":15,"verse":26,"text":"무릇 그 유출이 있는 날 동안에 그의 눕는 침상은 그에게 불결한 때의 침상과 같고 무릇 그의 앉는 자리도 부정함이 불결의 부정 과 같으니","reference":"레위기 15:26","category":"$undefined"},{"id":"3196","book":"레위기","book_name":"레위기","chapter":15,"verse":27,"text":"이런 것을 만지는 자는 무릇 부정한즉 옷을 빨고 물로 몸을 씻을 것이며 저녁까지 부정할 것이요","reference":"레위기 15:27","category":"$undefined"},{"id":"3197","book":"레위기","book_name":"레위기","chapter":15,"verse":28,"text":"그의 유출이 그치면 칠일을 센 후에야 정하리니","reference":"레위기 15:28","category":"$undefined"},{"id":"3198","book":"레위기","book_name":"레위기","chapter":15,"verse":29,"text":"그는 제 팔일에 산비둘기 둘이나 집비둘기 새끼 둘을 자기를 위하여 취하여 회막 문 앞 제사장에게로 가져올 것이요","reference":"레위기 15:29","category":"$undefined"},{"id":"3199","book":"레위기","book_name":"레위기","chapter":15,"verse":30,"text":"제사장은 그 하나는 속죄제로, 하나는 번제로 드려 유출로 부정한 여인을 위하여 여호와 앞에 속할지니라","reference":"레위기 15:30","category":"$undefined"},{"id":"3200","book":"레위기","book_name":"레위기","chapter":15,"verse":31,"text":"너희는 이와 같이 이스라엘 자손으로 그 부정에서 떠나게하여 그들로 그 가운데 있는 내 장막을 더럽히고 그 부정한 중에서 죽음을 면케 할찌니라","reference":"레위기 15:31","category":"$undefined"},{"id":"3201","book":"레위기","book_name":"레위기","chapter":15,"verse":32,"text":"이 규례는 유출병이 있는 자와 설정함으로 부정을 입은 자와","reference":"레위기 15:32","category":"$undefined"},{"id":"3202","book":"레위기","book_name":"레위기","chapter":15,"verse":33,"text":"불결을 앓는 여인과 유출병이 있는 남녀와 불결한 여인과 동침한 자에게 관한 것이니라","reference":"레위기 15:33","category":"$undefined"}],"bookSlug":"leviticus"}]
