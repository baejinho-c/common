2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":16,"verses":[{"id":"3203","book":"레위기","book_name":"레위기","chapter":16,"verse":1,"text":"아론의 두 아들이 여호와 앞에 나아가다가 죽은 후에 여호와께서 모세에게 말씀하시니라","reference":"레위기 16:1","category":"$undefined"},{"id":"3204","book":"레위기","book_name":"레위기","chapter":16,"verse":2,"text":"여호와께서 모세에게 이르시되 네 형 아론에게 이르라 성소의 장안 법궤 위 속죄소 앞에 무시로 들어오지 말아서 사망을 면하라 내가 구름 가운데서 속죄소 위에 나타남이니라","reference":"레위기 16:2","category":"$undefined"},{"id":"3205","book":"레위기","book_name":"레위기","chapter":16,"verse":3,"text":"아론이 성소에 들어오려면 수송아지로 속죄 제물을 삼고 수양으로 번제물을 삼고","reference":"레위기 16:3","category":"$undefined"},{"id":"3206","book":"레위기","book_name":"레위기","chapter":16,"verse":4,"text":"거룩한 세마포 속옷을 입으며 세마포 고의를 살에 입고 세마포 띠를 띠며 세마포 관을 쓸지니 이것들은 거룩한 옷이라 물로 몸을 씻고 입을 것이며","reference":"레위기 16:4","category":"$undefined"},{"id":"3207","book":"레위기","book_name":"레위기","chapter":16,"verse":5,"text":"이스라엘 자손의 회중에게서 속죄 제물을 위하여 수염소 둘과 번제물을 위하여 수양 하나를 취할지니라","reference":"레위기 16:5","category":"$undefined"},{"id":"3208","book":"레위기","book_name":"레위기","chapter":16,"verse":6,"text":"아론은 자기를 위한 속죄제의 수송아지를 드리되 자기와 권속을 위하여 속죄하고","reference":"레위기 16:6","category":"$undefined"},{"id":"3209","book":"레위기","book_name":"레위기","chapter":16,"verse":7,"text":"또 그 두 염소를 취하여 회막 문 여호와 앞에 두고","reference":"레위기 16:7","category":"$undefined"},{"id":"3210","book":"레위기","book_name":"레위기","chapter":16,"verse":8,"text":"두 염소를 위하여 제비 뽑되 한 제비는 여호와를 위하고, 한 제비는 아사셀을 위하여 할지며","reference":"레위기 16:8","category":"$undefined"},{"id":"3211","book":"레위기","book_name":"레위기","chapter":16,"verse":9,"text":"아론은 여호와를 위하여 제비 뽑은 염소를 속죄제로 드리고","reference":"레위기 16:9","category":"$undefined"},{"id":"3212","book":"레위기","book_name":"레위기","chapter":16,"verse":10,"text":"아사셀을 위하여 제비 뽑은 염소는 산 대로 여호와 앞에 두었다가 그것으로 속죄하고 아사셀을 위하여 광야로 보낼지니라","reference":"레위기 16:10","category":"$undefined"},{"id":"3213","book":"레위기","book_name":"레위기","chapter":16,"verse":11,"text":"아론은 자기를 위한 속죄제의 수송아지를 드리되 자기와 권속을 위하여 속죄하고 자기를 위한 그 속죄제 수송아지를 잡고","reference":"레위기 16:11","category":"$undefined"},{"id":"3214","book":"레위기","book_name":"레위기","chapter":16,"verse":12,"text":"향로를 취하여 여호와 앞 단 위에서 피운 불을 그것에 채우고 또 두손에 곱게 간 향기로운 향을 채워 가지고 장 안에 들어가서","reference":"레위기 16:12","category":"$undefined"},{"id":"3215","book":"레위기","book_name":"레위기","chapter":16,"verse":13,"text":"여호와 앞에서 분향하여 향연으로 증거궤 위 속죄소를 가리우게 할지니 그리하면 그가 죽음을 면할 것이며","reference":"레위기 16:13","category":"$undefined"},{"id":"3216","book":"레위기","book_name":"레위기","chapter":16,"verse":14,"text":"그는 또 수송아지의 피를 취하여 손가락으로 속죄소 동편에 뿌리고 또 손가락으로 그 피를 속죄소 앞에 일곱번 뿌릴 것이며","reference":"레위기 16:14","category":"$undefined"},{"id":"3217","book":"레위기","book_name":"레위기","chapter":16,"verse":15,"text":"또 백성을 위한 속죄제 염소를 잡아 그 피를 가지고 장 안에 들어가서 그 수송아지 피로 행함 같이 그 피로 행하여 속죄소 위와 속죄소 앞에 뿌릴지니","reference":"레위기 16:15","category":"$undefined"},{"id":"3218","book":"레위기","book_name":"레위기","chapter":16,"verse":16,"text":"곧 이스라엘 자손의 부정과 그 범한 모든 죄를 인하여 지성소를 위하여 속죄하고 또 그들의 부정한 중에 있는 회막을 위하여 그같이 할 것이요","reference":"레위기 16:16","category":"$undefined"},{"id":"3219","book":"레위기","book_name":"레위기","chapter":16,"verse":17,"text":"그가 지성소에 속죄하러 들어가서 자기와 그 권속과 이스라엘 온회중을 위하여 속죄하고 나오기까지는 누구든지 회막에 있지 못할 것이며","reference":"레위기 16:17","category":"$undefined"},{"id":"3220","book":"레위기","book_name":"레위기","chapter":16,"verse":18,"text":"그는 여호와 앞 단으로 나와서 그것을 위하여 속죄할지니 곧 그 수송아지의 피와 염소의 피를 취하여 단 귀퉁이 뿔들에 바르고","reference":"레위기 16:18","category":"$undefined"},{"id":"3221","book":"레위기","book_name":"레위기","chapter":16,"verse":19,"text":"또 손가락으로 그 피를 그 위에 일곱번 뿌려 이스라엘 자손의 부정에서 단을 성결케 할 것이요","reference":"레위기 16:19","category":"$undefined"},{"id":"3222","book":"레위기","book_name":"레위기","chapter":16,"verse":20,"text":"그 지성소와 회막과 단을 위하여 속죄하기를 마친 후에 산 염소를 드리되","reference":"레위기 16:20","category":"$undefined"},{"id":"3223","book":"레위기","book_name":"레위기","chapter":16,"verse":21,"text":"아론은 두 손으로 산 염소의 머리에 안수하여 이스라엘 자손의 모든 불의와 그 범한 모든 죄를 고하고 그 죄를 염소의 머리에 두어 미리 정한 사람에게 맡겨 광야로 보낼지니","reference":"레위기 16:21","category":"$undefined"},{"id":"3224","book":"레위기","book_name":"레위기","chapter":16,"verse":22,"text":"염소가 그들의 모든 불의를 지고 무인지경에 이르거든 그는 그 염소를 광야에 놓을지니라","reference":"레위기 16:22","category":"$undefined"},{"id":"3225","book":"레위기","book_name":"레위기","chapter":16,"verse":23,"text":"아론은 회막에 들어가서 지성소에 들어갈 때에 입었던 세마포 옷을 벗어 거기 두고","reference":"레위기 16:23","category":"$undefined"},{"id":"3226","book":"레위기","book_name":"레위기","chapter":16,"verse":24,"text":"거룩한 곳에서 물로 몸을 씻고 자기 옷을 입고 나와서 자기의 번제와 백성의 번제를 드려 자기와 백성을 위하여 속죄하고","reference":"레위기 16:24","category":"$undefined"},{"id":"3227","book":"레위기","book_name":"레위기","chapter":16,"verse":25,"text":"속죄제 희생의 기름을 단에 불사를 것이요","reference":"레위기 16:25","category":"$undefined"},{"id":"3228","book":"레위기","book_name":"레위기","chapter":16,"verse":26,"text":"염소를 아사셀에게 보낸 자는 옷을 빨고 물로 몸을 씻은 후에 진에 들어올 것이며","reference":"레위기 16:26","category":"$undefined"},{"id":"3229","book":"레위기","book_name":"레위기","chapter":16,"verse":27,"text":"속죄제 수송아지와 속죄제 염소의 피를 성소로 들여다가 속죄하였은즉 그 가죽과 고기와 똥을 밖으로 내어다가 불사를 것이요","reference":"레위기 16:27","category":"$undefined"},{"id":"3230","book":"레위기","book_name":"레위기","chapter":16,"verse":28,"text":"불사른 자는 옷을 빨고 물로 몸을 씻은 후에 진에 들어올지니라","reference":"레위기 16:28","category":"$undefined"},{"id":"3231","book":"레위기","book_name":"레위기","chapter":16,"verse":29,"text":"너희는 영원히 이 규례를 지킬지니라 ! 칠월 곧 그 달 십일에 너희는 스스로 괴롭게 하고 아무 일도 하지 말되 본토인이든지 너희 중에 우거하는 객이든지 그리하라","reference":"레위기 16:29","category":"$undefined"},{"id":"3232","book":"레위기","book_name":"레위기","chapter":16,"verse":30,"text":"이 날에 너희를 위하여 속죄하여 너희로 정결케 하리니 너희 모든 죄에서 너희가 여호와 앞에 정결하리라","reference":"레위기 16:30","category":"$undefined"},{"id":"3233","book":"레위기","book_name":"레위기","chapter":16,"verse":31,"text":"이는 너희에게 큰 안식일인즉 너희는 스스로 괴롭게 할지니 영원히 지킬 규례라","reference":"레위기 16:31","category":"$undefined"},{"id":"3234","book":"레위기","book_name":"레위기","chapter":16,"verse":32,"text":"그 기름 부음을 받고 위임되어 그 아비를 대신하여 제사장의 직분을 행하는 제사장은 속죄하되 세마포 옷 곧 성의를 입고","reference":"레위기 16:32","category":"$undefined"},{"id":"3235","book":"레위기","book_name":"레위기","chapter":16,"verse":33,"text":"지성소를 위하여 속죄하며 회막과 단을 위하여 속죄하고 또 제사장들과 백성의 회중을 위하여 속죄할지니","reference":"레위기 16:33","category":"$undefined"},{"id":"3236","book":"레위기","book_name":"레위기","chapter":16,"verse":34,"text":"이는 너희의 영원히 지킬 규례라 이스라엘 자손의 모든 죄를 위하여 일년 일차 속죄할 것이니라 아론이 여호와께서 모세에게 명하신 대로 행하니라","reference":"레위기 16:34","category":"$undefined"}],"bookSlug":"leviticus"}]
