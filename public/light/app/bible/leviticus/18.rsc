2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":18,"verses":[{"id":"3253","book":"레위기","book_name":"레위기","chapter":18,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 18:1","category":"$undefined"},{"id":"3254","book":"레위기","book_name":"레위기","chapter":18,"verse":2,"text":"너는 이스라엘 자손에게 고하여 이르라 나는 여호와 너희 하나님이라 !","reference":"레위기 18:2","category":"$undefined"},{"id":"3255","book":"레위기","book_name":"레위기","chapter":18,"verse":3,"text":"너희는 그 거하던 애굽 땅의 풍속을 좇지 말며 내가 너희를 인도할 가나안 땅의 풍속과 규례도 행하지 말고","reference":"레위기 18:3","category":"$undefined"},{"id":"3256","book":"레위기","book_name":"레위기","chapter":18,"verse":4,"text":"너희는 나의 법도를 좇으며 나의 규례를 지켜 그대로 행하라 ! 나는 너희의 하나님 여호와니라 !","reference":"레위기 18:4","category":"$undefined"},{"id":"3257","book":"레위기","book_name":"레위기","chapter":18,"verse":5,"text":"너희는 나의 규례와 법도를 지키라 ! 사람이 이를 행하면 그로 인하여 살리라 ! 나는 여호와니라 !","reference":"레위기 18:5","category":"$undefined"},{"id":"3258","book":"레위기","book_name":"레위기","chapter":18,"verse":6,"text":"너희는 골육지친을 가까이하여 그 하체를 범치 말라 나는 여호와니라 !","reference":"레위기 18:6","category":"$undefined"},{"id":"3259","book":"레위기","book_name":"레위기","chapter":18,"verse":7,"text":"네 어미의 하체는 곧 네 아비의 하체니 너는 범치 말라 그는 네 어미인즉 너는 그의 하체를 너는 범치 말지니라","reference":"레위기 18:7","category":"$undefined"},{"id":"3260","book":"레위기","book_name":"레위기","chapter":18,"verse":8,"text":"너는 계모의 하체를 범치 말라 이는 네 아비의 하체니라","reference":"레위기 18:8","category":"$undefined"},{"id":"3261","book":"레위기","book_name":"레위기","chapter":18,"verse":9,"text":"너는 네 자매 곧 네 아비의 딸이나 네 어미의 딸이나 집에서나 타처에서 출생하였음을 물론하고 그들의 하체를 범치 말지니라","reference":"레위기 18:9","category":"$undefined"},{"id":"3262","book":"레위기","book_name":"레위기","chapter":18,"verse":10,"text":"너는 손녀나 외손녀의 하체를 범치 말라 이는 너의 하체니라","reference":"레위기 18:10","category":"$undefined"},{"id":"3263","book":"레위기","book_name":"레위기","chapter":18,"verse":11,"text":"네 계모가 네 아비에게 낳은 딸은 네 누이니 너는 그 하체를 범치 말지니라","reference":"레위기 18:11","category":"$undefined"},{"id":"3264","book":"레위기","book_name":"레위기","chapter":18,"verse":12,"text":"너는 고모의 하체를 범치 말라 그는 네 아비의 골육지친이니라","reference":"레위기 18:12","category":"$undefined"},{"id":"3265","book":"레위기","book_name":"레위기","chapter":18,"verse":13,"text":"너는 이모의 하체를 범치 말라 그는 네 어미의 골육지친이니라","reference":"레위기 18:13","category":"$undefined"},{"id":"3266","book":"레위기","book_name":"레위기","chapter":18,"verse":14,"text":"너는 네 아비 형제의 아내를 가까이하여 그 하체를 범치 말라 그는 네 백숙모니라","reference":"레위기 18:14","category":"$undefined"},{"id":"3267","book":"레위기","book_name":"레위기","chapter":18,"verse":15,"text":"너는 자부의 하체를 범치 말라 그는 네 아들의 아내니 그 하체를 범치 말지니라","reference":"레위기 18:15","category":"$undefined"},{"id":"3268","book":"레위기","book_name":"레위기","chapter":18,"verse":16,"text":"너는 형제의 아내의 하체를 범치 말라 이는 네 형제의 하체니라","reference":"레위기 18:16","category":"$undefined"},{"id":"3269","book":"레위기","book_name":"레위기","chapter":18,"verse":17,"text":"너는 여인과 그 여인의 딸의 하체를 아울러 범치 말며 또 그 여인의 손녀나 외손녀를 아울러 취하여 그 하체를 범치 말라 그들은 그의 골육지친이니 이는 악행이니라","reference":"레위기 18:17","category":"$undefined"},{"id":"3270","book":"레위기","book_name":"레위기","chapter":18,"verse":18,"text":"너는 아내가 생존할 동안에 그 형제를 취하여 하체를 범하여 그로 투기케 하지 말지니라","reference":"레위기 18:18","category":"$undefined"},{"id":"3271","book":"레위기","book_name":"레위기","chapter":18,"verse":19,"text":"너는 여인이 경도로 불결할 동안에 그에게 가까이하여 그 하체를 범치 말지니라","reference":"레위기 18:19","category":"$undefined"},{"id":"3272","book":"레위기","book_name":"레위기","chapter":18,"verse":20,"text":"너는 타인의 아내와 통간하여 그로 자기를 더럽히지 말지니라","reference":"레위기 18:20","category":"$undefined"},{"id":"3273","book":"레위기","book_name":"레위기","chapter":18,"verse":21,"text":"너는 결단코 자녀를 몰렉에게 주어 불로 통과케 말아서 네 하나님의 이름을 욕되게 하지 말라 나는 여호와니라 !","reference":"레위기 18:21","category":"$undefined"},{"id":"3274","book":"레위기","book_name":"레위기","chapter":18,"verse":22,"text":"너는 여자와 교합함 같이 남자와 교합하지 말라 이는 가증한 일이니라","reference":"레위기 18:22","category":"$undefined"},{"id":"3275","book":"레위기","book_name":"레위기","chapter":18,"verse":23,"text":"너는 짐승과 교합하여 자기를 더럽히지 말며 여자가 된 자는 짐승 앞에 서서 그것과 교접하지 말라 이는 문란한 일이니라","reference":"레위기 18:23","category":"$undefined"},{"id":"3276","book":"레위기","book_name":"레위기","chapter":18,"verse":24,"text":"너희는 이 모든 일로 스스로 더럽히지 말라 내가 너희의 앞에서 쫓아내는 족속들이 이 모든 일로 인하여 더러워졌고","reference":"레위기 18:24","category":"$undefined"},{"id":"3277","book":"레위기","book_name":"레위기","chapter":18,"verse":25,"text":"그 땅도 더러워졌으므로 내가 그 악을 인하여 벌하고 그 땅도 스스로 그 거민을 토하여 내느니라","reference":"레위기 18:25","category":"$undefined"},{"id":"3278","book":"레위기","book_name":"레위기","chapter":18,"verse":26,"text":"그러므로 너희 곧 너희의 동족이나 혹시 너희 중에 우거하는 타국인이나 나의 규례와 법도를 지키고 이런 가증한 일의 하나도 행하지 말라","reference":"레위기 18:26","category":"$undefined"},{"id":"3279","book":"레위기","book_name":"레위기","chapter":18,"verse":27,"text":"너희의 전에 있던 그 땅 거민이 이 모든 가증한 일을 행하였고 그 땅도 더러워졌느니라","reference":"레위기 18:27","category":"$undefined"},{"id":"3280","book":"레위기","book_name":"레위기","chapter":18,"verse":28,"text":"너희도 더럽히면 그 땅이 너희 있기 전 거민을 토함같이 너희를 토할까 하노라","reference":"레위기 18:28","category":"$undefined"},{"id":"3281","book":"레위기","book_name":"레위기","chapter":18,"verse":29,"text":"무릇 이 가증한 일을 하나라도 행하는 자는 그 백성 중에서 끊쳐지리라 !","reference":"레위기 18:29","category":"$undefined"},{"id":"3282","book":"레위기","book_name":"레위기","chapter":18,"verse":30,"text":"그러므로 너희는 내 명령을 지키고 너희 있기 전에 행하던 가증한 풍속을 하나라도 좇음으로 스스로 더럽히지 말라 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 18:30","category":"$undefined"}],"bookSlug":"leviticus"}]
