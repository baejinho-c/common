2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":19,"verses":[{"id":"3283","book":"레위기","book_name":"레위기","chapter":19,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 19:1","category":"$undefined"},{"id":"3284","book":"레위기","book_name":"레위기","chapter":19,"verse":2,"text":"너는 이스라엘 자손의 온 회중에게 고하여 이르라 너희는 거룩하라 ! 나 여호와 너희 하나님이 거룩함이니라","reference":"레위기 19:2","category":"$undefined"},{"id":"3285","book":"레위기","book_name":"레위기","chapter":19,"verse":3,"text":"너희 각 사람은 부모를 경외하고 나의 안식일을 지키라 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 19:3","category":"$undefined"},{"id":"3286","book":"레위기","book_name":"레위기","chapter":19,"verse":4,"text":"너희는 헛것을 위하지 말며 너희를 위하여 신상들을 부어 만들지 말라 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 19:4","category":"$undefined"},{"id":"3287","book":"레위기","book_name":"레위기","chapter":19,"verse":5,"text":"너희는 화목제 희생을 여호와께 드릴 때에 열납되도록 드리고","reference":"레위기 19:5","category":"$undefined"},{"id":"3288","book":"레위기","book_name":"레위기","chapter":19,"verse":6,"text":"그 제물은 드리는 날과 이튿날에 먹고 제 삼일까지 남았거든 불사르라","reference":"레위기 19:6","category":"$undefined"},{"id":"3289","book":"레위기","book_name":"레위기","chapter":19,"verse":7,"text":"제 삼일에 조금이라도 먹으면 가증한 것이 되어 열납되지 못하고","reference":"레위기 19:7","category":"$undefined"},{"id":"3290","book":"레위기","book_name":"레위기","chapter":19,"verse":8,"text":"그것을 먹는 자는 여호와의 성물 더럽힘을 인하여 죄를 당하리니 그가 그 백성 중에서 끊쳐지리라 !","reference":"레위기 19:8","category":"$undefined"},{"id":"3291","book":"레위기","book_name":"레위기","chapter":19,"verse":9,"text":"너희 땅의 곡물을 벨 때에 너는 밭 모퉁이까지 다 거두지 말고 너의 떨어진 이삭도 줍지 말며","reference":"레위기 19:9","category":"$undefined"},{"id":"3292","book":"레위기","book_name":"레위기","chapter":19,"verse":10,"text":"너의 포도원의 열매를 다 따지 말며 너의 포도원에 떨어진 열매도 줍지 말고 가난한 사람과 타국인을 위하여 버려 두라 나는 너희 하나님 여호와니라 !","reference":"레위기 19:10","category":"$undefined"},{"id":"3293","book":"레위기","book_name":"레위기","chapter":19,"verse":11,"text":"너희는 도적질하지 말며 속이지 말며 서로 거짓말하지 말며","reference":"레위기 19:11","category":"$undefined"},{"id":"3294","book":"레위기","book_name":"레위기","chapter":19,"verse":12,"text":"너희는 내 이름으로 거짓 맹세함으로 네 하나님의 이름을 욕되게 하지 말라 ! 나는 여호와니라 !","reference":"레위기 19:12","category":"$undefined"},{"id":"3295","book":"레위기","book_name":"레위기","chapter":19,"verse":13,"text":"너는 네 이웃을 압제하지 말며 늑탈하지 말며 품군의 삯을 아침까지 밤새도록 네게 두지 말며","reference":"레위기 19:13","category":"$undefined"},{"id":"3296","book":"레위기","book_name":"레위기","chapter":19,"verse":14,"text":"너는 귀먹은 자를 저주하지 말며 소경 앞에 장애물을 놓지 말고 네 하나님을 경외하라 ! 나는 여호와니라 !","reference":"레위기 19:14","category":"$undefined"},{"id":"3297","book":"레위기","book_name":"레위기","chapter":19,"verse":15,"text":"너희는 재판할 때에 불의를 행치 말며 가난한 자의 편을 들지 말며 세력있는 자라고 두호하지 말고 공의로 사람을 재판할지며","reference":"레위기 19:15","category":"$undefined"},{"id":"3298","book":"레위기","book_name":"레위기","chapter":19,"verse":16,"text":"너는 네 백성 중으로 돌아다니며 사람을 논단하지 말며 네 이웃을 대적하여 죽을 지경에 이르게 하지 말라 나는 여호와니라 !","reference":"레위기 19:16","category":"$undefined"},{"id":"3299","book":"레위기","book_name":"레위기","chapter":19,"verse":17,"text":"너는 네 형제를 마음으로 미워하지 말며 이웃을 인하여 죄를 당치 않도록 그를 반드시 책선하라","reference":"레위기 19:17","category":"$undefined"},{"id":"3300","book":"레위기","book_name":"레위기","chapter":19,"verse":18,"text":"원수를 갚지 말며 동포를 원망하지 말며 이웃 사랑하기를 네 몸과 같이 하라 ! 나는 여호와니라 !","reference":"레위기 19:18","category":"$undefined"},{"id":"3301","book":"레위기","book_name":"레위기","chapter":19,"verse":19,"text":"너희는 내 규례를 지킬지어다 ! 네 육축을 다른 종류와 교합시키지 말며 네 밭에 두 종자를 섞어 뿌리지 말며 두 재료로 직조한 옷을 입지 말지며","reference":"레위기 19:19","category":"$undefined"},{"id":"3302","book":"레위기","book_name":"레위기","chapter":19,"verse":20,"text":"무릇 아직 속량도 되지 못하고 해방도 되지 못하고 정혼한 씨종과 사람이 행음하면 두 사람이 형벌은 받으려니와 그들이 죽임을 당치 아니할 것은 그 여인은 아직 해방되지 못하였음이라","reference":"레위기 19:20","category":"$undefined"},{"id":"3303","book":"레위기","book_name":"레위기","chapter":19,"verse":21,"text":"그 남자는 그 속건 제물 곧 속건제 수양을 회막 문 여호와께로 끌어올 것이요","reference":"레위기 19:21","category":"$undefined"},{"id":"3304","book":"레위기","book_name":"레위기","chapter":19,"verse":22,"text":"제사장은 그의 범한 죄를 위하여 그 속건제의 수양으로 여호와 앞에 속죄할 것이요 그리하면 그의 범한 죄의 사함을 받으리라 !","reference":"레위기 19:22","category":"$undefined"},{"id":"3305","book":"레위기","book_name":"레위기","chapter":19,"verse":23,"text":"너희가 그 땅에 들어가 각종 과목을 심거든 그 열매는 아직 할례받지 못한 것으로 여기되 곧 삼년 동안 너희는 그것을 할례 받지 못한 것으로 아껴 먹지 말 것이요","reference":"레위기 19:23","category":"$undefined"},{"id":"3306","book":"레위기","book_name":"레위기","chapter":19,"verse":24,"text":"제 사년에는 그 모든 과실이 거룩하니 여호와께 드려 찬송할 것이며","reference":"레위기 19:24","category":"$undefined"},{"id":"3307","book":"레위기","book_name":"레위기","chapter":19,"verse":25,"text":"제 오년에는 그 열매를 먹을지니 그리하면 너희에게 그 소산이 풍성하리라 나는 너희 하나님 여호와니라 !","reference":"레위기 19:25","category":"$undefined"},{"id":"3308","book":"레위기","book_name":"레위기","chapter":19,"verse":26,"text":"너희는 무엇이든지 피 채 먹지 말며 복술을 하지 말며 술수를 행치 말며","reference":"레위기 19:26","category":"$undefined"},{"id":"3309","book":"레위기","book_name":"레위기","chapter":19,"verse":27,"text":"머리 가를 둥글게 깎지 말며 수염 끝을 손상치 말며","reference":"레위기 19:27","category":"$undefined"},{"id":"3310","book":"레위기","book_name":"레위기","chapter":19,"verse":28,"text":"죽은 자를 위하여 너희는 살을 베지 말며 몸에 무늬를 놓지 말라 ! 나는 여호와니라 !","reference":"레위기 19:28","category":"$undefined"},{"id":"3311","book":"레위기","book_name":"레위기","chapter":19,"verse":29,"text":"네 딸을 더럽혀 기생이 되게 말라 ! 음풍이 전국에 퍼져 죄악이 가득할까 하노라","reference":"레위기 19:29","category":"$undefined"},{"id":"3312","book":"레위기","book_name":"레위기","chapter":19,"verse":30,"text":"내 안식일을 지키고 내 성소를 공경하라 ! 나는 여호와니라 !","reference":"레위기 19:30","category":"$undefined"},{"id":"3313","book":"레위기","book_name":"레위기","chapter":19,"verse":31,"text":"너희는 신접한 자와 박수를 믿지 말며 그들을 추종하여 스스로 더럽히지 말라 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 19:31","category":"$undefined"},{"id":"3314","book":"레위기","book_name":"레위기","chapter":19,"verse":32,"text":"너는 센 머리 앞에 일어서고 노인의 얼굴을 공경하며 네 하나님을 경외하라 ! 나는 여호와니라 !","reference":"레위기 19:32","category":"$undefined"},{"id":"3315","book":"레위기","book_name":"레위기","chapter":19,"verse":33,"text":"타국인이 너희 땅에 우거하여 함께 있거든 너희는 그를 학대하지 말고","reference":"레위기 19:33","category":"$undefined"},{"id":"3316","book":"레위기","book_name":"레위기","chapter":19,"verse":34,"text":"너희와 함께 있는 타국인을 너희 중에서 낳은 자 같이 여기며 자기같이 사랑하라 ! 너희도 애굽 땅에서 객이 되었더니라 나는 너희 하나님 여호와니라 !","reference":"레위기 19:34","category":"$undefined"},{"id":"3317","book":"레위기","book_name":"레위기","chapter":19,"verse":35,"text":"너희는 재판에든지 도량형에든지 불의를 행치 말고","reference":"레위기 19:35","category":"$undefined"},{"id":"3318","book":"레위기","book_name":"레위기","chapter":19,"verse":36,"text":"공평한 저울과, 공평한 추와, 공평한 에바와, 공평한 힌을 사용하라 ! 나는 너희를 인도하여 애굽 땅에서 나오게 한 너희 하나님 여호와니라 !","reference":"레위기 19:36","category":"$undefined"},{"id":"3319","book":"레위기","book_name":"레위기","chapter":19,"verse":37,"text":"너희는 나의 모든 규례와 나의 모든 법도를 지켜 행하라 ! 나는 여호와니라 !","reference":"레위기 19:37","category":"$undefined"}],"bookSlug":"leviticus"}]
