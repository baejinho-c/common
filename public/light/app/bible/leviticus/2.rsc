2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":2,"verses":[{"id":"2764","book":"레위기","book_name":"레위기","chapter":2,"verse":1,"text":"누구든지 소제의 예물을 여호와께 드리려거든 고운 가루로 예물을 삼아 그 위에 기름을 붓고 또 그 위에 유향을 놓아","reference":"레위기 2:1","category":"$undefined"},{"id":"2765","book":"레위기","book_name":"레위기","chapter":2,"verse":2,"text":"아론의 자손 제사장들에게로 가져 올 것이요 제사장은 그 고운 기름 가루 한 줌과 그 모든 유향을 취하여 기념물로 단 위에 불 사를지니 이는 화제라 여호와께 향기로운 냄새니라.","reference":"레위기 2:2","category":"$undefined"},{"id":"2766","book":"레위기","book_name":"레위기","chapter":2,"verse":3,"text":"그 소제물의 남은 것은 아론과 그 자손에게 돌릴지니 이는 여호와의 화제 중에 지극히 거룩한 것이니라","reference":"레위기 2:3","category":"$undefined"},{"id":"2767","book":"레위기","book_name":"레위기","chapter":2,"verse":4,"text":"네가 화덕에 구운 것으로 소제의 예물을 드리려거든 고운 가루에 기름을 섞어 만든 무교병이나 기름을 바른 무교병을 드릴 것이요,","reference":"레위기 2:4","category":"$undefined"},{"id":"2768","book":"레위기","book_name":"레위기","chapter":2,"verse":5,"text":"번철에 부친 것으로 소제의 예물을 드리려거든 고운 가루에 누룩을 넣지 말고 기름을 섞어","reference":"레위기 2:5","category":"$undefined"},{"id":"2769","book":"레위기","book_name":"레위기","chapter":2,"verse":6,"text":"조각으로 나누고 그 위에 기름을 부을지니 이는 소제니라","reference":"레위기 2:6","category":"$undefined"},{"id":"2770","book":"레위기","book_name":"레위기","chapter":2,"verse":7,"text":"네가 솥에 삶은 것으로 소제를 드리려거든 고운 가루와 기름을 섞어 만들지니라 !","reference":"레위기 2:7","category":"$undefined"},{"id":"2771","book":"레위기","book_name":"레위기","chapter":2,"verse":8,"text":"너는 이것들로 만든 소제물을 여호와께로 가져다가 제사장에게 줄 것이요, 제사장은 그것을 단으로 가져다가","reference":"레위기 2:8","category":"$undefined"},{"id":"2772","book":"레위기","book_name":"레위기","chapter":2,"verse":9,"text":"그 소제물 중에서 기념할 것을 취하여 단 위에 불사를지니 이는 화제라 여호와께 향기로운 냄새니라.","reference":"레위기 2:9","category":"$undefined"},{"id":"2773","book":"레위기","book_name":"레위기","chapter":2,"verse":10,"text":"소제물의 남은 것은 아론과 그 자손에게 돌릴찌니 이는 여호와의 화제 중에 지극히 거룩한 것이니라","reference":"레위기 2:10","category":"$undefined"},{"id":"2774","book":"레위기","book_name":"레위기","chapter":2,"verse":11,"text":"무릇 너희가 여호와께 드리는 소제물에는 모두 누룩을 넣지 말지니 너희가 누룩이나 꿀을 여호와께 화제로 드려 사르지 못할지니라","reference":"레위기 2:11","category":"$undefined"},{"id":"2775","book":"레위기","book_name":"레위기","chapter":2,"verse":12,"text":"처음 익은 것으로는 그것을 여호와께 드릴지나 향기로운 냄새를 위하여는 단에 올리지 말지며","reference":"레위기 2:12","category":"$undefined"},{"id":"2776","book":"레위기","book_name":"레위기","chapter":2,"verse":13,"text":"네 모든 소제물에 소금을 치라 ! 네 하나님의 언약의 소금을 네 소제에 빼지 못할지니 네 모든 예물에 소금을 드릴지니라 !","reference":"레위기 2:13","category":"$undefined"},{"id":"2777","book":"레위기","book_name":"레위기","chapter":2,"verse":14,"text":"너는 첫 이삭의 소제를 여호와께 드리거든 첫 이삭을 볶아 찧은 것으로 너의 소제를 삼되","reference":"레위기 2:14","category":"$undefined"},{"id":"2778","book":"레위기","book_name":"레위기","chapter":2,"verse":15,"text":"그 위에 기름을 붓고 그 위에 유향을 더할지니 이는 소제니라 !","reference":"레위기 2:15","category":"$undefined"},{"id":"2779","book":"레위기","book_name":"레위기","chapter":2,"verse":16,"text":"제사장은 찧은 곡식 얼마와, 기름의 얼마와, 모든 유향을 기념물로 불사를지니 이는 여호와께 드리는 화제니라","reference":"레위기 2:16","category":"$undefined"}],"bookSlug":"leviticus"}]
