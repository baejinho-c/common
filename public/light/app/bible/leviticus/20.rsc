2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":20,"verses":[{"id":"3320","book":"레위기","book_name":"레위기","chapter":20,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 20:1","category":"$undefined"},{"id":"3321","book":"레위기","book_name":"레위기","chapter":20,"verse":2,"text":"너는 이스라엘 자손에게 또 이르라 무릇 그가 이스라엘 자손이든지 이스라엘에 우거한 타국인이든지 그 자식을 몰렉에게 주거든 반드시 죽이되 그 지방 사람이 돌로 칠 것이요","reference":"레위기 20:2","category":"$undefined"},{"id":"3322","book":"레위기","book_name":"레위기","chapter":20,"verse":3,"text":"나도 그 사람에게 진노하여 그를 그 백성 중에서 끊으리니 이는 그가 그 자식을 몰렉에게 주어서 내 성소를 더럽히고 내 성호를 욕되게 하였음이라","reference":"레위기 20:3","category":"$undefined"},{"id":"3323","book":"레위기","book_name":"레위기","chapter":20,"verse":4,"text":"그가 그 자식을 몰렉에게 주는 것을 그 지방 사람이 못본체하고 그를 죽이지 아니하면","reference":"레위기 20:4","category":"$undefined"},{"id":"3324","book":"레위기","book_name":"레위기","chapter":20,"verse":5,"text":"내가 그 사람과 그 권속에게 진노하여 그와 무릇 그를 본받아 몰렉을 음란히 섬기는 모든 사람을 그 백성 중에서 끊으리라 !","reference":"레위기 20:5","category":"$undefined"},{"id":"3325","book":"레위기","book_name":"레위기","chapter":20,"verse":6,"text":"음란하듯 신접한 자와 박수를 추종하는 자에게는 내가 진노하여 그를 그 백성 중에서 끊으리니","reference":"레위기 20:6","category":"$undefined"},{"id":"3326","book":"레위기","book_name":"레위기","chapter":20,"verse":7,"text":"너희는 스스로 깨끗케 하여 거룩할지어다 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 20:7","category":"$undefined"},{"id":"3327","book":"레위기","book_name":"레위기","chapter":20,"verse":8,"text":"너희는 내 규례를 지켜 행하라 ! 나는 너희를 거룩케 하는 여호와니라 !","reference":"레위기 20:8","category":"$undefined"},{"id":"3328","book":"레위기","book_name":"레위기","chapter":20,"verse":9,"text":"무릇 그 아비나 어미를 저주하는 자는 반드시 죽일지니 그가 그 아비나 어미를 저주하였은즉 그 피가 자기에게로 돌아가리라","reference":"레위기 20:9","category":"$undefined"},{"id":"3329","book":"레위기","book_name":"레위기","chapter":20,"verse":10,"text":"누구든지 남의 아내와 간음하는 자 곧 그 이웃의 아내와 간음하는 자는 그 간부와 음부를 반드시 죽일지니라 !","reference":"레위기 20:10","category":"$undefined"},{"id":"3330","book":"레위기","book_name":"레위기","chapter":20,"verse":11,"text":"누구든지 그 계모와 동침하는 자는 그 아비의 하체를 범하였은즉 둘다 반드시 죽일지니 그 피가 자기에게로 돌아가리라","reference":"레위기 20:11","category":"$undefined"},{"id":"3331","book":"레위기","book_name":"레위기","chapter":20,"verse":12,"text":"누구든지 그 자부와 동침하거든 둘 다 반드시 죽일지니 그들이 가증한 일을 행하였음이라 그 피가 자기에게로 돌아가리라","reference":"레위기 20:12","category":"$undefined"},{"id":"3332","book":"레위기","book_name":"레위기","chapter":20,"verse":13,"text":"누구든지 여인과 교합하듯 남자와 교합하면 둘 다 가증한 일을 행함인즉 반드시 죽일지니 그 피가 자기에게로 돌아가리라","reference":"레위기 20:13","category":"$undefined"},{"id":"3333","book":"레위기","book_name":"레위기","chapter":20,"verse":14,"text":"누구든지 아내와 그 장모를 아울러 취하면 악행인즉 그와 그들을 함께 불사를지니 이는 너희중에 악행이 없게 하려 함이니라","reference":"레위기 20:14","category":"$undefined"},{"id":"3334","book":"레위기","book_name":"레위기","chapter":20,"verse":15,"text":"남자가 짐승과 교합하면 반드시 죽이고 너희는 그 짐승도 죽일 것이며","reference":"레위기 20:15","category":"$undefined"},{"id":"3335","book":"레위기","book_name":"레위기","chapter":20,"verse":16,"text":"여자가 짐승에게 가까이하여 교합하거든 너는 여자와 짐승을 죽이되 이들을 반드시 죽일지니 그 피가 자기에게로 돌아가리라","reference":"레위기 20:16","category":"$undefined"},{"id":"3336","book":"레위기","book_name":"레위기","chapter":20,"verse":17,"text":"누구든지 그 자매 곧 아비의 딸이나 어미의 딸을 취하여 그 여자의 하체를 보고 여자는 그 남자의 하체를 보면 부끄러운 일이라 그 민족 앞에서 그들이 끊어질지니 그가 그 자매의 하체를 범하였은즉 그 죄를 당하리라","reference":"레위기 20:17","category":"$undefined"},{"id":"3337","book":"레위기","book_name":"레위기","chapter":20,"verse":18,"text":"누구든지 경도하는 여인과 동침하여 그의 하체를 범하면 남자는 그 여인의 근원을 드러내었고 여인은 자기의 피 근원을 드러내었음인즉 둘 다 백성 중에서 끊어지리라","reference":"레위기 20:18","category":"$undefined"},{"id":"3338","book":"레위기","book_name":"레위기","chapter":20,"verse":19,"text":"너의 이모나 고모의 하체를 범하지 말지니 이는 골육지친의 하체인즉 그들이 그 죄를 당하리라","reference":"레위기 20:19","category":"$undefined"},{"id":"3339","book":"레위기","book_name":"레위기","chapter":20,"verse":20,"text":"누구든지 백숙모와 동침하면 그 백숙부의 하체를 범함이니 그들이 그 죄를 당하여 무자히 죽으리라","reference":"레위기 20:20","category":"$undefined"},{"id":"3340","book":"레위기","book_name":"레위기","chapter":20,"verse":21,"text":"누구든지 그 형제의 아내를 취하면 더러운 일이라 그가 그 형제의 하체를 범함이니 그들이 무자하리라","reference":"레위기 20:21","category":"$undefined"},{"id":"3341","book":"레위기","book_name":"레위기","chapter":20,"verse":22,"text":"너희는 나의 모든 규례와 법도를 지켜 행하라 ! 그리하여야 내가 너희를 인도하여 거하게 하는 땅이 너희를 토하지 아니하리라","reference":"레위기 20:22","category":"$undefined"},{"id":"3342","book":"레위기","book_name":"레위기","chapter":20,"verse":23,"text":"너희는 내가 너희 앞에서 쫓아내는 족속의 풍속을 좇지 말라 ! 그들이 이 모든 일을 행하므로 내가 그들을 가증히 여기노라","reference":"레위기 20:23","category":"$undefined"},{"id":"3343","book":"레위기","book_name":"레위기","chapter":20,"verse":24,"text":"내가 전에 너희에게 이르기를 너희가 그들의 땅을 기업으로 얻을 것이라 내가 그 땅 곧 젖과 꿀이 흐르는 땅으로 너희에게 주어 유업을 삼게 하리라 하였노라 나는 너희를 만민 중에서 구별한 너희 하나님 여호와라 !","reference":"레위기 20:24","category":"$undefined"},{"id":"3344","book":"레위기","book_name":"레위기","chapter":20,"verse":25,"text":"너희는 짐승의 정하고 부정함과 새의 정하고 부정함을 구별하고 내가 너희를 위하여 부정한 것으로 구별한 짐승이나 새나 땅에 기는 곤충으로 인하여 너희 몸을 더럽히지 말라 !","reference":"레위기 20:25","category":"$undefined"},{"id":"3345","book":"레위기","book_name":"레위기","chapter":20,"verse":26,"text":"너희는 내게 거룩할지어다 ! 이는 나 여호와가 거룩하고 내가 또 너희로 나의 소유를 삼으려고 너희를 만민 중에서 구별하였음이니라","reference":"레위기 20:26","category":"$undefined"},{"id":"3346","book":"레위기","book_name":"레위기","chapter":20,"verse":27,"text":"남자나 여자가 신접하거나 박수가 되거든 반드시 죽일지니 곧 돌로 그를 치라 그 피가 자기에게로 돌아가리라","reference":"레위기 20:27","category":"$undefined"}],"bookSlug":"leviticus"}]
