2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":21,"verses":[{"id":"3347","book":"레위기","book_name":"레위기","chapter":21,"verse":1,"text":"여호와께서 모세에게 이르시되 아론의 자손 제사장들에게 고하여 이르라 백성 중의 죽은 자로 인하여 스스로 더럽히지 말려니와","reference":"레위기 21:1","category":"$undefined"},{"id":"3348","book":"레위기","book_name":"레위기","chapter":21,"verse":2,"text":"골육지친인 부모나 자녀나 형제나","reference":"레위기 21:2","category":"$undefined"},{"id":"3349","book":"레위기","book_name":"레위기","chapter":21,"verse":3,"text":"출가하지 아니한 처녀인 친 자매로 인하여는 몸을 더럽힐 수 있느니라","reference":"레위기 21:3","category":"$undefined"},{"id":"3350","book":"레위기","book_name":"레위기","chapter":21,"verse":4,"text":"제사장은 백성의 어른인즉 스스로 더럽혀 욕되게 하지 말지니라","reference":"레위기 21:4","category":"$undefined"},{"id":"3351","book":"레위기","book_name":"레위기","chapter":21,"verse":5,"text":"제사장은 머리털을 깎아 대머리 같게 하지 말며 그 수염 양편을 깎지 말며 살을 베지 말고","reference":"레위기 21:5","category":"$undefined"},{"id":"3352","book":"레위기","book_name":"레위기","chapter":21,"verse":6,"text":"그 하나님께 대하여 거룩하고 그 하나님의 이름을 욕되게 하지 말 것이며 그들은 여호와의 화제 곧 그 하나님의 식물을 드리는 자인즉 거룩할 것이라","reference":"레위기 21:6","category":"$undefined"},{"id":"3353","book":"레위기","book_name":"레위기","chapter":21,"verse":7,"text":"그들은 기생이나 부정한 여인을 취하지 말 것이며 이혼 당한 여인을 취하지 말지니 이는 그가 여호와께 거룩함이니라","reference":"레위기 21:7","category":"$undefined"},{"id":"3354","book":"레위기","book_name":"레위기","chapter":21,"verse":8,"text":"너는 그를 거룩하게 하라 ! 그는 네 하나님의 식물을 드림이니라 너는 그를 거룩히 여기라 ! 나 여호와 너희를 거룩하게 하는 자는 거룩함이니라","reference":"레위기 21:8","category":"$undefined"},{"id":"3355","book":"레위기","book_name":"레위기","chapter":21,"verse":9,"text":"아무 제사장의 딸이든지 행음하여 스스로 더럽히면 그 아비를 욕되게 함이니 그를 불사를지니라","reference":"레위기 21:9","category":"$undefined"},{"id":"3356","book":"레위기","book_name":"레위기","chapter":21,"verse":10,"text":"자기 형제 중 관유로 부음을 받고 위임되어 예복을 입은 대제사장은 그 머리를 풀지 말며 그 옷을 찢지 말며","reference":"레위기 21:10","category":"$undefined"},{"id":"3357","book":"레위기","book_name":"레위기","chapter":21,"verse":11,"text":"어떤 시체에든지 가까이 말지니 부모로 인하여도 더러워지게 말며","reference":"레위기 21:11","category":"$undefined"},{"id":"3358","book":"레위기","book_name":"레위기","chapter":21,"verse":12,"text":"성소에서 나오지 말며 그 하나님의 성소를 더럽히지 말라 ! 이는 하나님의 위임한 관유가 그 위에 있음이니라 나는 여호와니라 !","reference":"레위기 21:12","category":"$undefined"},{"id":"3359","book":"레위기","book_name":"레위기","chapter":21,"verse":13,"text":"그는 처녀를 취하여 아내를 삼을지니","reference":"레위기 21:13","category":"$undefined"},{"id":"3360","book":"레위기","book_name":"레위기","chapter":21,"verse":14,"text":"과부나 이혼된 여인이나 더러운 여인이나 기생을 취하지 말고 자기 백성 중 처녀를 취하여 아내를 삼아","reference":"레위기 21:14","category":"$undefined"},{"id":"3361","book":"레위기","book_name":"레위기","chapter":21,"verse":15,"text":"그 자손으로 백성 중에서 더럽히지 말지니 나는 그를 거룩하게 하는 여호와임이니라","reference":"레위기 21:15","category":"$undefined"},{"id":"3362","book":"레위기","book_name":"레위기","chapter":21,"verse":16,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 21:16","category":"$undefined"},{"id":"3363","book":"레위기","book_name":"레위기","chapter":21,"verse":17,"text":"아론에게 고하여 이르라 무릇 너의 대대 자손 중 육체에 흠이 있는 자는 그 하나님의 식물을 드리려고 가까이 오지 못할 것이라","reference":"레위기 21:17","category":"$undefined"},{"id":"3364","book":"레위기","book_name":"레위기","chapter":21,"verse":18,"text":"무릇 흠이 있는 자는 가까이 못할지니 곧 소경이나, 절뚝발이나, 코가 불완전한 자나, 지체가 더한 자나,","reference":"레위기 21:18","category":"$undefined"},{"id":"3365","book":"레위기","book_name":"레위기","chapter":21,"verse":19,"text":"발 부러진 자나, 손 부러진 자나,","reference":"레위기 21:19","category":"$undefined"},{"id":"3366","book":"레위기","book_name":"레위기","chapter":21,"verse":20,"text":"곱사등이나, 난장이나, 눈에 백막이 있는 자나, 괴혈병이나, 버짐이 있는 자나, 불알 상한 자나,","reference":"레위기 21:20","category":"$undefined"},{"id":"3367","book":"레위기","book_name":"레위기","chapter":21,"verse":21,"text":"제사장 아론의 자손 중에 흠이 있는 자는 나아와 여호와의 화제를 드리지 못할지니 그는 흠이 있은즉 나아와 하나님의 식물을 드리지 못하느니라","reference":"레위기 21:21","category":"$undefined"},{"id":"3368","book":"레위기","book_name":"레위기","chapter":21,"verse":22,"text":"그는 하나님의 식물의 지성물이든지 성물이든지 먹을 것이나","reference":"레위기 21:22","category":"$undefined"},{"id":"3369","book":"레위기","book_name":"레위기","chapter":21,"verse":23,"text":"장 안에 들어가지 못할 것이요 단에 가까이 못할지니 이는 그가 흠이 있음이라 이와 같이 그가 나의 성소를 더럽히지 못할 것은 나는 그들을 거룩하게 하는 여호와임이니라 !","reference":"레위기 21:23","category":"$undefined"},{"id":"3370","book":"레위기","book_name":"레위기","chapter":21,"verse":24,"text":"모세가 이대로 아론과 그 아들들과 온 이스라엘 자손에게 고하였더라","reference":"레위기 21:24","category":"$undefined"}],"bookSlug":"leviticus"}]
