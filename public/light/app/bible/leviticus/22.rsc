2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":22,"verses":[{"id":"3371","book":"레위기","book_name":"레위기","chapter":22,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 22:1","category":"$undefined"},{"id":"3372","book":"레위기","book_name":"레위기","chapter":22,"verse":2,"text":"아론과 그 아들들에게 고하여 그들로 이스라엘 자손이 내게 드리는 성물에 대하여 스스로 구별하여 내 성호를 욕되게 함이 없게 하라 나는 여호와니라 !","reference":"레위기 22:2","category":"$undefined"},{"id":"3373","book":"레위기","book_name":"레위기","chapter":22,"verse":3,"text":"그들에게 이르라 무릇 너의 대대 자손 중에 그 몸이 부정하고도 이스라엘 자손이 구별하여 여호와께 드리는 성물에 가까이하는 자는 내 앞에서 끊어지리라 나는 여호와니라 !","reference":"레위기 22:3","category":"$undefined"},{"id":"3374","book":"레위기","book_name":"레위기","chapter":22,"verse":4,"text":"아론의 자손 중 문둥 환자나 유출병이 있는 자는 정하기 전에는 성물을 먹지말 것이요 시체로 부정하게 된 자나 설정한 자나","reference":"레위기 22:4","category":"$undefined"},{"id":"3375","book":"레위기","book_name":"레위기","chapter":22,"verse":5,"text":"무릇 사람을 부정하게 하는 벌레에 접촉된 자나 무슨 부정이든지 사람을 더럽힐 만한 자에게 접촉된 자","reference":"레위기 22:5","category":"$undefined"},{"id":"3376","book":"레위기","book_name":"레위기","chapter":22,"verse":6,"text":"곧 이런 것에 접촉된 자는 저녁까지 부정하니 몸을 물로 씻지 아니하면 성물을 먹지 못할지며","reference":"레위기 22:6","category":"$undefined"},{"id":"3377","book":"레위기","book_name":"레위기","chapter":22,"verse":7,"text":"해 질 때에야 정하리니 그 후에 성물을 먹을 것이라 이는 자기의 응식이 됨이니라","reference":"레위기 22:7","category":"$undefined"},{"id":"3378","book":"레위기","book_name":"레위기","chapter":22,"verse":8,"text":"절로 죽은 것이나 들짐승에게 찢긴 것을 먹음으로 자기를 더럽히지 말라 ! 나는 여호와니라 !","reference":"레위기 22:8","category":"$undefined"},{"id":"3379","book":"레위기","book_name":"레위기","chapter":22,"verse":9,"text":"그들은 나의 명을 지킬 것이라 그것을 욕되게 하면 그로 인하여 죄를 짓고 그 가운데서 죽을까 하노라 나는 그들을 거룩하게 하는 여호와니라 !","reference":"레위기 22:9","category":"$undefined"},{"id":"3380","book":"레위기","book_name":"레위기","chapter":22,"verse":10,"text":"외국인은 성물을 먹지 못할 것이며 제사장의 객이나 품군은 다 성물을 먹지 못할 것이니라","reference":"레위기 22:10","category":"$undefined"},{"id":"3381","book":"레위기","book_name":"레위기","chapter":22,"verse":11,"text":"그러나 제사장이 돈으로 사람을 샀으면 그 자는 그것을 먹을 것이고 그 집에서 출생한 자도 그러하여 그들이 제사장의 식물을 먹을 것이며","reference":"레위기 22:11","category":"$undefined"},{"id":"3382","book":"레위기","book_name":"레위기","chapter":22,"verse":12,"text":"제사장의 딸은 외국인에게 출가하였으면 거제의 성물을 먹지 못하되","reference":"레위기 22:12","category":"$undefined"},{"id":"3383","book":"레위기","book_name":"레위기","chapter":22,"verse":13,"text":"그가 과부가 되든지 이혼을 당하든지 자식이 없이 친정에 돌아와서 어릴 때와 같으면 그는 그 아비의 응식을 먹을 것이나 외국인은 먹지 못할 것이니라","reference":"레위기 22:13","category":"$undefined"},{"id":"3384","book":"레위기","book_name":"레위기","chapter":22,"verse":14,"text":"사람이 부지중 성물을 먹으면 그 성물에 그 오분 일을 더하여 제사장에게 줄지니라","reference":"레위기 22:14","category":"$undefined"},{"id":"3385","book":"레위기","book_name":"레위기","chapter":22,"verse":15,"text":"이스라엘 자손이 여호와께 드리는 성물을 그들은 더럽히지 말지니","reference":"레위기 22:15","category":"$undefined"},{"id":"3386","book":"레위기","book_name":"레위기","chapter":22,"verse":16,"text":"그들이 성물을 먹으면 그 죄로 인하여 형벌을 받게 할 것이니라 나는 그들을 거룩하게 하는 여호와니라 !","reference":"레위기 22:16","category":"$undefined"},{"id":"3387","book":"레위기","book_name":"레위기","chapter":22,"verse":17,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 22:17","category":"$undefined"},{"id":"3388","book":"레위기","book_name":"레위기","chapter":22,"verse":18,"text":"아론과 그 아들들과 이스라엘 온 족속에게 고하여 이르라 이스라엘 자손이나 그 중에 우거하는 자가 서원제나 낙헌제로 번제를 여호와께 예물로 드리려거든","reference":"레위기 22:18","category":"$undefined"},{"id":"3389","book":"레위기","book_name":"레위기","chapter":22,"verse":19,"text":"열납되도록 소나 양이나 염소의 흠 없는 수컷으로 드릴지니","reference":"레위기 22:19","category":"$undefined"},{"id":"3390","book":"레위기","book_name":"레위기","chapter":22,"verse":20,"text":"무릇 흠 있는 것을 너희는 드리지 말 것은 그것이 열납되지 못할 것임이니라","reference":"레위기 22:20","category":"$undefined"},{"id":"3391","book":"레위기","book_name":"레위기","chapter":22,"verse":21,"text":"무릇 서원한 것을 갚으려든지 자의로 예물을 드리려든지 하여 소나 양으로 화목제 희생을 여호와께 드리는 자는 열납되도록 아무 흠이 없는 온전한 것으로 할지니","reference":"레위기 22:21","category":"$undefined"},{"id":"3392","book":"레위기","book_name":"레위기","chapter":22,"verse":22,"text":"눈먼 것이나, 상한 것이나, 지체에 베임을 당한 것이나, 종기 있는 것이나, 괴혈병 있는 것이나, 비루먹은 것을 너희는 여호와께 드리지 말며 단 위에 화제로 여호와께 드리지 말라","reference":"레위기 22:22","category":"$undefined"},{"id":"3393","book":"레위기","book_name":"레위기","chapter":22,"verse":23,"text":"우양의 지체가 더하거나 덜하거나 한 것은 너희가 낙헌 예물로는 쓰려니와 서원한 것을 갚음으로 드리면 열납되지 못하리라","reference":"레위기 22:23","category":"$undefined"},{"id":"3394","book":"레위기","book_name":"레위기","chapter":22,"verse":24,"text":"너희는 불알이 상하였거나, 치었거나, 터졌거나, 베임을 당한 것은 여호와께 드리지 말며 너희 땅에서는 이런 일을 행치도 말지며","reference":"레위기 22:24","category":"$undefined"},{"id":"3395","book":"레위기","book_name":"레위기","chapter":22,"verse":25,"text":"너희는 외방인에게서도 이런 것을 받아 너희의 하나님의 식물로 드리지 말라 이는 결점이 있고 흠이 있는 것인즉 너희를 위하여 열납되지 못할 것임이니라","reference":"레위기 22:25","category":"$undefined"},{"id":"3396","book":"레위기","book_name":"레위기","chapter":22,"verse":26,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 22:26","category":"$undefined"},{"id":"3397","book":"레위기","book_name":"레위기","chapter":22,"verse":27,"text":"수소나 양이나 염소가 나거든 칠일동안 그 어미와 같이 있게하라 제 팔일 이후로는 여호와께 화제로 예물을 드리면 열납되리라","reference":"레위기 22:27","category":"$undefined"},{"id":"3398","book":"레위기","book_name":"레위기","chapter":22,"verse":28,"text":"암소나 암양을 무론하고 어미와 새끼를 동일에 잡지 말지니라","reference":"레위기 22:28","category":"$undefined"},{"id":"3399","book":"레위기","book_name":"레위기","chapter":22,"verse":29,"text":"너희가 여호와께 감사 희생을 드리거든 너희가 열납되도록 드릴지며","reference":"레위기 22:29","category":"$undefined"},{"id":"3400","book":"레위기","book_name":"레위기","chapter":22,"verse":30,"text":"그 제물은 당일에 먹고 이튿날까지 두지 말라 나는 여호와니라 !","reference":"레위기 22:30","category":"$undefined"},{"id":"3401","book":"레위기","book_name":"레위기","chapter":22,"verse":31,"text":"너희는 나의 계명을 지키며 행하라 ! 나는 여호와니라 !","reference":"레위기 22:31","category":"$undefined"},{"id":"3402","book":"레위기","book_name":"레위기","chapter":22,"verse":32,"text":"너희는 나의 성호를 욕되게 말라 ! 나는 이스라엘 자손 중에서 거룩하게 함을 받을 것이니라 나는 너희를 거룩하게 하는 여호와요","reference":"레위기 22:32","category":"$undefined"},{"id":"3403","book":"레위기","book_name":"레위기","chapter":22,"verse":33,"text":"너희 하나님이 되려고 너희를 애굽 땅에서 인도하여 낸 자니 나는 여호와니라 !","reference":"레위기 22:33","category":"$undefined"}],"bookSlug":"leviticus"}]
