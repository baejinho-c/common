2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":23,"verses":[{"id":"3404","book":"레위기","book_name":"레위기","chapter":23,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 23:1","category":"$undefined"},{"id":"3405","book":"레위기","book_name":"레위기","chapter":23,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 너희가 공포하여 성회를 삼을 여호와의 절기는 이러하니라","reference":"레위기 23:2","category":"$undefined"},{"id":"3406","book":"레위기","book_name":"레위기","chapter":23,"verse":3,"text":"엿새 동안은 일할 것이요 일곱째 날은 쉴 안식일이니 성회라 너희는 무슨 일이든지 하지 말라 이는 너희 거하는 각처에서 지킬 여호와의 안식일이니라","reference":"레위기 23:3","category":"$undefined"},{"id":"3407","book":"레위기","book_name":"레위기","chapter":23,"verse":4,"text":"기한에 미쳐 너희가 공포하여 성회로 삼을 여호와의 절기는 이러하니라","reference":"레위기 23:4","category":"$undefined"},{"id":"3408","book":"레위기","book_name":"레위기","chapter":23,"verse":5,"text":"정월 십사일 저녁은 여호와의 유월절이요","reference":"레위기 23:5","category":"$undefined"},{"id":"3409","book":"레위기","book_name":"레위기","chapter":23,"verse":6,"text":"이 달 십오일은 여호와의 무교절이니 칠일 동안 너희는 무교병을 먹을 것이요","reference":"레위기 23:6","category":"$undefined"},{"id":"3410","book":"레위기","book_name":"레위기","chapter":23,"verse":7,"text":"그 첫날에는 너희가 성회로 모이고 아무 노동도 하지 말지며","reference":"레위기 23:7","category":"$undefined"},{"id":"3411","book":"레위기","book_name":"레위기","chapter":23,"verse":8,"text":"너희는 칠일 동안 여호와께 화제를 드릴 것이요 제 칠일에도 성회로 모이고 아무 노동도 하지 말지니라","reference":"레위기 23:8","category":"$undefined"},{"id":"3412","book":"레위기","book_name":"레위기","chapter":23,"verse":9,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 23:9","category":"$undefined"},{"id":"3413","book":"레위기","book_name":"레위기","chapter":23,"verse":10,"text":"이스라엘 자손에게 고하여 이르라 너희는 내가 너희에게 주는 땅에 들어가서 너희의 곡물을 거둘 때에 위선 너희의 곡물의 첫 이삭 한 단을 제사장에게로 가져갈 것이요","reference":"레위기 23:10","category":"$undefined"},{"id":"3414","book":"레위기","book_name":"레위기","chapter":23,"verse":11,"text":"제사장은 너희를 위하여 그 단을 여호와 앞에 열납되도록 흔들되 안식일 이튿날에 흔들 것이며","reference":"레위기 23:11","category":"$undefined"},{"id":"3415","book":"레위기","book_name":"레위기","chapter":23,"verse":12,"text":"너희가 그 단을 흔드는 날에 일년 되고 흠 없는 수양을 번제로 여호와께 드리고","reference":"레위기 23:12","category":"$undefined"},{"id":"3416","book":"레위기","book_name":"레위기","chapter":23,"verse":13,"text":"그 소제로는 기름 섞은 고운 가루 에바 십분 이를 여호와께 드려 화제를 삼아 향기로운 냄새가 되게 하고 전제로는 포도주 힌 사분 일을 쓸 것이며","reference":"레위기 23:13","category":"$undefined"},{"id":"3417","book":"레위기","book_name":"레위기","chapter":23,"verse":14,"text":"너희는 너희 하나님께 예물을 가져오는 그 날까지 떡이든지 볶은 곡식이든지 생 이삭이든지 먹지 말지니 이는 너희가 그 거하는 각처에서 대대로 지킬 영원한 규례니라 !","reference":"레위기 23:14","category":"$undefined"},{"id":"3418","book":"레위기","book_name":"레위기","chapter":23,"verse":15,"text":"안식일 이튿날 곧 너희가 요제로 단을 가져온 날부터 세어서 칠안식일의 수효를 채우고","reference":"레위기 23:15","category":"$undefined"},{"id":"3419","book":"레위기","book_name":"레위기","chapter":23,"verse":16,"text":"제 칠 안식일 이튿날까지 합 오십일을 계수하여 새 소제를 여호와께 드리되","reference":"레위기 23:16","category":"$undefined"},{"id":"3420","book":"레위기","book_name":"레위기","chapter":23,"verse":17,"text":"너희 처소에서 에바 십분 이로 만든 떡 두개를 가져다가 흔들지니 이는 고운 가루에 누룩을 넣어서 구운 것이요 이는 첫 요제로 여호와께 드리는 것이며","reference":"레위기 23:17","category":"$undefined"},{"id":"3421","book":"레위기","book_name":"레위기","chapter":23,"verse":18,"text":"너희는 또 이 떡과 함께 일년 되고 흠 없는 어린 양 일곱과 젊은 수소 하나와 수양 둘을 드리되 이들을 그 소제와 그 전제와 함께 여호와께 드려서 번제를 삼을지니 이는 화제라 여호와께 향기로운 냄새며","reference":"레위기 23:18","category":"$undefined"},{"id":"3422","book":"레위기","book_name":"레위기","chapter":23,"verse":19,"text":"또 수염소 하나로 속죄제를 드리며 일년된 어린 수양 둘을 화목제 희생으로 드릴 것이요","reference":"레위기 23:19","category":"$undefined"},{"id":"3423","book":"레위기","book_name":"레위기","chapter":23,"verse":20,"text":"제사장은 그 첫이삭의 떡과 함께 그 두 어린 양을 여호와 앞에 흔들어 요제를 삼을 것이요 이것들은 여호와께 드리는 성물인즉 제사장에게 돌릴 것이며","reference":"레위기 23:20","category":"$undefined"},{"id":"3424","book":"레위기","book_name":"레위기","chapter":23,"verse":21,"text":"이 날에 너희는 너희 중에 성회를 공포하고 아무 노동도 하지 말지니 이는 너희가 그 거하는 각처에서 대대로 지킬 영원한 규례니라 !","reference":"레위기 23:21","category":"$undefined"},{"id":"3425","book":"레위기","book_name":"레위기","chapter":23,"verse":22,"text":"너희 땅의 곡물을 벨 때에 밭 모퉁이까지 다 베지 말며 떨어진 진을 줍지 말고 너는 그것을 가난한 자와 객을 위하여 버려 두라 나는 너희 하나님 여호와니라 !","reference":"레위기 23:22","category":"$undefined"},{"id":"3426","book":"레위기","book_name":"레위기","chapter":23,"verse":23,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 23:23","category":"$undefined"},{"id":"3427","book":"레위기","book_name":"레위기","chapter":23,"verse":24,"text":"이스라엘 자손에게 고하여 이르라 칠월 곧 그 달 일일로 안식일을 삼을지니 이는 나팔을 불어 기념할 날이요 성회라","reference":"레위기 23:24","category":"$undefined"},{"id":"3428","book":"레위기","book_name":"레위기","chapter":23,"verse":25,"text":"아무 노동도 하지 말고 여호와께 화제를 드릴지니라","reference":"레위기 23:25","category":"$undefined"},{"id":"3429","book":"레위기","book_name":"레위기","chapter":23,"verse":26,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 23:26","category":"$undefined"},{"id":"3430","book":"레위기","book_name":"레위기","chapter":23,"verse":27,"text":"칠월 십일은 속죄일이니 너희에게 성회라 너희는 스스로 괴롭게하며 여호와께 화제를 드리고","reference":"레위기 23:27","category":"$undefined"},{"id":"3431","book":"레위기","book_name":"레위기","chapter":23,"verse":28,"text":"이 날에는 아무 일도 하지 말 것은 너희를 위하여 너희 하나님 여호와 앞에 속죄할 속죄일이 됨이니라","reference":"레위기 23:28","category":"$undefined"},{"id":"3432","book":"레위기","book_name":"레위기","chapter":23,"verse":29,"text":"이 날에 스스로 괴롭게 하지 아니하는 자는 그 백성 중에서 끊쳐질 것이라","reference":"레위기 23:29","category":"$undefined"},{"id":"3433","book":"레위기","book_name":"레위기","chapter":23,"verse":30,"text":"이 날에 누구든지 아무 일이나 하는 자는 내가 백성 중에서 멸절시키리니","reference":"레위기 23:30","category":"$undefined"},{"id":"3434","book":"레위기","book_name":"레위기","chapter":23,"verse":31,"text":"너희는 아무 일이든지 하지 말라 이는 너희가 그 거하는 각처에서 대대로 지킬 영원한 규례니라 !","reference":"레위기 23:31","category":"$undefined"},{"id":"3435","book":"레위기","book_name":"레위기","chapter":23,"verse":32,"text":"이는 너희의 쉴 안식일이라 너희는 스스로 괴롭게 하고 이 달 구일 저녁 곧 그 저녁부터 이튿날 저녁까지 안식을 지킬지니라 !","reference":"레위기 23:32","category":"$undefined"},{"id":"3436","book":"레위기","book_name":"레위기","chapter":23,"verse":33,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 23:33","category":"$undefined"},{"id":"3437","book":"레위기","book_name":"레위기","chapter":23,"verse":34,"text":"이스라엘 자손에게 고하여 이르라 칠월 십오일은 초막절이니 여호와를 위하여 칠일동안 지킬 것이라","reference":"레위기 23:34","category":"$undefined"},{"id":"3438","book":"레위기","book_name":"레위기","chapter":23,"verse":35,"text":"첫 날에는 성회가 있을지니 너희는 아무 노동도 하지 말지며","reference":"레위기 23:35","category":"$undefined"},{"id":"3439","book":"레위기","book_name":"레위기","chapter":23,"verse":36,"text":"칠일 동안에 너희는 화제를 여호와께 드릴 것이요 제 팔일에도 너희에게 성회가 될 것이며 화제를 여호와께 드릴지니 이는 거룩한 대회라 너희는 아무 노동도 하지 말지니라 !","reference":"레위기 23:36","category":"$undefined"},{"id":"3440","book":"레위기","book_name":"레위기","chapter":23,"verse":37,"text":"이것들은 여호와의 절기라 너희는 공포하여 성회를 삼고 번제와 소제와 희생과 전제를 각각 그 날에 여호와께 화제로 드릴지니","reference":"레위기 23:37","category":"$undefined"},{"id":"3441","book":"레위기","book_name":"레위기","chapter":23,"verse":38,"text":"이는 여호와의 안식일 외에, 너희의 헌물 외에, 너희의 모든 서원 예물외에,너희의 모든 낙헌 예물 외에 너희가 여호와께 드리는 것이니라","reference":"레위기 23:38","category":"$undefined"},{"id":"3442","book":"레위기","book_name":"레위기","chapter":23,"verse":39,"text":"너희가 토지 소산 거두기를 마치거든 칠월 십오일부터 칠일 동안 여호와의 절기를 지키되 첫날에도 안식하고 제 팔일에도 안식할 것이요","reference":"레위기 23:39","category":"$undefined"},{"id":"3443","book":"레위기","book_name":"레위기","chapter":23,"verse":40,"text":"첫날에는 너희가 아름다운 나무 실과와, 종려 가지와, 무성한 가지와, 시내 버들을 취하여 너희 하나님 여호와 앞에서 칠일동안 즐거워할 것이라","reference":"레위기 23:40","category":"$undefined"},{"id":"3444","book":"레위기","book_name":"레위기","chapter":23,"verse":41,"text":"너희는 매년에 칠일 동안 여호와께 이 절기를 지킬지니 너희 대대로의 영원한 규례라 ! 너희는 칠월에 이를 지킬지니라 !","reference":"레위기 23:41","category":"$undefined"},{"id":"3445","book":"레위기","book_name":"레위기","chapter":23,"verse":42,"text":"너희는 칠일 동안 초막에 거하되 이스라엘에서 난 자는 다 초막에 거할지니","reference":"레위기 23:42","category":"$undefined"},{"id":"3446","book":"레위기","book_name":"레위기","chapter":23,"verse":43,"text":"이는 내가 이스라엘 자손을 애굽 땅에서 인도하여 내던 때에 초막에 거하게 한 줄을 너희 대대로 알게 함이니라 나는 너희 하나님 여호와니라 !","reference":"레위기 23:43","category":"$undefined"},{"id":"3447","book":"레위기","book_name":"레위기","chapter":23,"verse":44,"text":"모세가 여호와의 절기를 이스라엘 자손에게 공포하였더라","reference":"레위기 23:44","category":"$undefined"}],"bookSlug":"leviticus"}]
