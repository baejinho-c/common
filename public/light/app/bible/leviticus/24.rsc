2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":24,"verses":[{"id":"3448","book":"레위기","book_name":"레위기","chapter":24,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 24:1","category":"$undefined"},{"id":"3449","book":"레위기","book_name":"레위기","chapter":24,"verse":2,"text":"이스라엘 자손에게 명하여 감람을 찧어 낸 순결한 기름을 켜기 위하여 네게로 가져오게 하고 끊이지 말고 등잔불을 켤지며","reference":"레위기 24:2","category":"$undefined"},{"id":"3450","book":"레위기","book_name":"레위기","chapter":24,"verse":3,"text":"아론은 회막 안 증거궤 장 밖에서 저녁부터 아침까지 여호와 앞에 항상 등잔불을 정리할지니 너희 대대로 지킬 영원한 규례라","reference":"레위기 24:3","category":"$undefined"},{"id":"3451","book":"레위기","book_name":"레위기","chapter":24,"verse":4,"text":"그가 여호와 앞에서 순결한 등대 위의 등잔들을 끊이지 않고 정리할지니라","reference":"레위기 24:4","category":"$undefined"},{"id":"3452","book":"레위기","book_name":"레위기","chapter":24,"verse":5,"text":"너는 고운 가루를 취하여 떡 열 둘을 굽되 매 덩이를 에바 십분 이로 하여","reference":"레위기 24:5","category":"$undefined"},{"id":"3453","book":"레위기","book_name":"레위기","chapter":24,"verse":6,"text":"여호와 앞 순결한 상 위에 두 줄로 한 줄에 여섯씩 진설하고","reference":"레위기 24:6","category":"$undefined"},{"id":"3454","book":"레위기","book_name":"레위기","chapter":24,"verse":7,"text":"너는 또 정결한 유향을 그 매 줄 위에 두어 기념물로 여호와께 화제를 삼을 것이며","reference":"레위기 24:7","category":"$undefined"},{"id":"3455","book":"레위기","book_name":"레위기","chapter":24,"verse":8,"text":"항상 매 안식일에 이 떡을 여호와 앞에 진설할지니 이는 이스라엘 자손을 위한 것이요 영원한 언약이니라","reference":"레위기 24:8","category":"$undefined"},{"id":"3456","book":"레위기","book_name":"레위기","chapter":24,"verse":9,"text":"이 떡은 아론과 그 자손에게 돌리고 그들은 그것을 거룩한 곳에서 먹을지니 이는 여호와의 화제 중 그에게 돌리는 것으로서 지극히 거룩함이니라 이는 영원한 규례니라","reference":"레위기 24:9","category":"$undefined"},{"id":"3457","book":"레위기","book_name":"레위기","chapter":24,"verse":10,"text":"이스라엘 여인의 아들이요 그 아비는 애굽 사람된 자가 이스라엘 자손 중에 나가서 한 이스라엘 사람과 진중에서 싸우다가","reference":"레위기 24:10","category":"$undefined"},{"id":"3458","book":"레위기","book_name":"레위기","chapter":24,"verse":11,"text":"그 이스라엘 여인의 아들이 여호와의 이름을 훼방하며 저주하므로 무리가 끌고 모세에게로 가니라 그 어미의 이름은 슬로밋이요 단 지파 디브리의 딸이었더라","reference":"레위기 24:11","category":"$undefined"},{"id":"3459","book":"레위기","book_name":"레위기","chapter":24,"verse":12,"text":"그들이 그를 가두고 여호와의 명령을 기다리더니","reference":"레위기 24:12","category":"$undefined"},{"id":"3460","book":"레위기","book_name":"레위기","chapter":24,"verse":13,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 24:13","category":"$undefined"},{"id":"3461","book":"레위기","book_name":"레위기","chapter":24,"verse":14,"text":"저주한 사람을 진 밖에 끌어 내어 그 말을 들은 모든 자로 그 머리에 안수하게 하고 온 회중이 돌로 그를 칠지니라","reference":"레위기 24:14","category":"$undefined"},{"id":"3462","book":"레위기","book_name":"레위기","chapter":24,"verse":15,"text":"너는 이스라엘 자손에게 고하여 이르라 누구든지 자기 하나님을 저주하면 죄를 당할 것이요","reference":"레위기 24:15","category":"$undefined"},{"id":"3463","book":"레위기","book_name":"레위기","chapter":24,"verse":16,"text":"여호와의 이름을 훼방하면 그를 반드시 죽일지니 온 회중이 돌로 그를 칠 것이라 외국인이든지 본토인이든지 여호와의 이름을 훼방하면 그를 죽일지니라","reference":"레위기 24:16","category":"$undefined"},{"id":"3464","book":"레위기","book_name":"레위기","chapter":24,"verse":17,"text":"사람을 쳐 죽인 자는 반드시 죽일 것이요","reference":"레위기 24:17","category":"$undefined"},{"id":"3465","book":"레위기","book_name":"레위기","chapter":24,"verse":18,"text":"짐승을 쳐 죽인 자는 짐승으로 짐승을 갚을 것이며","reference":"레위기 24:18","category":"$undefined"},{"id":"3466","book":"레위기","book_name":"레위기","chapter":24,"verse":19,"text":"사람이 만일 그 이웃을 상하였으면 그 행한 대로 그에게 행할 것이니","reference":"레위기 24:19","category":"$undefined"},{"id":"3467","book":"레위기","book_name":"레위기","chapter":24,"verse":20,"text":"파상은 파상으로, 눈은 눈으로, 이는 이로 갚을지라 남에게 손상을 입힌대로 그에게 그렇게 할것이며","reference":"레위기 24:20","category":"$undefined"},{"id":"3468","book":"레위기","book_name":"레위기","chapter":24,"verse":21,"text":"짐승을 죽인 자는 그것을 물어 줄 것이요 사람을 죽인 자는 죽일지니","reference":"레위기 24:21","category":"$undefined"},{"id":"3469","book":"레위기","book_name":"레위기","chapter":24,"verse":22,"text":"외국인에게든지 본토인에게든지 그 법을 동일히 할 것은 나는 너희 하나님 여호와임이니라 !","reference":"레위기 24:22","category":"$undefined"},{"id":"3470","book":"레위기","book_name":"레위기","chapter":24,"verse":23,"text":"모세가 이스라엘 자손에게 고하니 그들이 저주한 자를 진 밖에 끌어내어 돌로 쳤더라 이스라엘 자손이 여호와께서 모세에게 명하신 대로 행하였더라","reference":"레위기 24:23","category":"$undefined"}],"bookSlug":"leviticus"}]
