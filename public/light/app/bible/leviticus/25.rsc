2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":25,"verses":[{"id":"3471","book":"레위기","book_name":"레위기","chapter":25,"verse":1,"text":"여호와께서 시내산에서 모세에게 일러 가라사대","reference":"레위기 25:1","category":"$undefined"},{"id":"3472","book":"레위기","book_name":"레위기","chapter":25,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 너희는 내가 너희에게 주는 땅에 들어간 후에 그 땅으로 여호와 앞에 안식하게 하라","reference":"레위기 25:2","category":"$undefined"},{"id":"3473","book":"레위기","book_name":"레위기","chapter":25,"verse":3,"text":"너는 육년 동안 그 밭에 파종하며 육년 동안 그 포도원을 다스려 그 열매를 거둘 것이나","reference":"레위기 25:3","category":"$undefined"},{"id":"3474","book":"레위기","book_name":"레위기","chapter":25,"verse":4,"text":"제 칠년에는 땅으로 쉬어 안식하게 할지니 여호와께 대한 안식이라 너는 그 밭에 파종하거나 포도원을 다스리지 말며","reference":"레위기 25:4","category":"$undefined"},{"id":"3475","book":"레위기","book_name":"레위기","chapter":25,"verse":5,"text":"너의 곡물의 스스로 난 것을 거두지 말고 다스리지 아니한 포도나무의 맺은 열매를 거두지 말라 이는 땅의 안식년임이니라","reference":"레위기 25:5","category":"$undefined"},{"id":"3476","book":"레위기","book_name":"레위기","chapter":25,"verse":6,"text":"안식년의 소출은 너희의 먹을 것이니 너와 네 남종과, 네 여종과, 네 품군과, 너와 함께 거하는 객과,","reference":"레위기 25:6","category":"$undefined"},{"id":"3477","book":"레위기","book_name":"레위기","chapter":25,"verse":7,"text":"네 육축과 네 땅에 있는 들짐승들이 다 그 소산으로 식물을 삼을지니라","reference":"레위기 25:7","category":"$undefined"},{"id":"3478","book":"레위기","book_name":"레위기","chapter":25,"verse":8,"text":"너는 일곱 안식년을 계수할지니 이는 칠년이 일곱번인즉 안식년 일곱번 동안 곧 사십 구년이라","reference":"레위기 25:8","category":"$undefined"},{"id":"3479","book":"레위기","book_name":"레위기","chapter":25,"verse":9,"text":"칠월 십일은 속죄일이니 너는 나팔 소리를 내되 전국에서 나팔을 크게 불지며","reference":"레위기 25:9","category":"$undefined"},{"id":"3480","book":"레위기","book_name":"레위기","chapter":25,"verse":10,"text":"제 오십년을 거룩하게 하여 전국 거민에게 자유를 공포하라 ! 이 해는 너희에게 희년이니 너희는 각각 그 기업으로 돌아가며 각각 그 가족에게로 돌아갈지며","reference":"레위기 25:10","category":"$undefined"},{"id":"3481","book":"레위기","book_name":"레위기","chapter":25,"verse":11,"text":"그 오십년은 너희의 희년이니 너희는 파종하지 말며 스스로 난 것을 거두지 말며 다스리지 아니한 포도를 거두지 말라","reference":"레위기 25:11","category":"$undefined"},{"id":"3482","book":"레위기","book_name":"레위기","chapter":25,"verse":12,"text":"이는 희년이니 너희에게 거룩함이니라 너희가 밭의 소산을 먹으리라","reference":"레위기 25:12","category":"$undefined"},{"id":"3483","book":"레위기","book_name":"레위기","chapter":25,"verse":13,"text":"이 희년에는 너희가 각기 기업으로 돌아갈지라","reference":"레위기 25:13","category":"$undefined"},{"id":"3484","book":"레위기","book_name":"레위기","chapter":25,"verse":14,"text":"네 이웃에게 팔든지 네 이웃의 손에서 사거든 너희는 서로 속이지 말라","reference":"레위기 25:14","category":"$undefined"},{"id":"3485","book":"레위기","book_name":"레위기","chapter":25,"verse":15,"text":"희년 후의 연수를 따라서 너는 이웃에게 살 것이요 그도 그 열매를 얻을 연수를 따라서 네게 팔 것인즉","reference":"레위기 25:15","category":"$undefined"},{"id":"3486","book":"레위기","book_name":"레위기","chapter":25,"verse":16,"text":"연수가 많으면 너는 그 값을 많게 하고 연수가 적으면 너는 그 값을 적게 할지니 곧 그가 그 열매의 다소를 따라서 네게 팔 것이라","reference":"레위기 25:16","category":"$undefined"},{"id":"3487","book":"레위기","book_name":"레위기","chapter":25,"verse":17,"text":"너희는 서로 속이지 말고 너희의 하나님을 경외하라 ! 나는 너희 하나님 여호와니라 !","reference":"레위기 25:17","category":"$undefined"},{"id":"3488","book":"레위기","book_name":"레위기","chapter":25,"verse":18,"text":"너희는 내 법도를 행하며 내 규례를 지켜 행하라 ! 그리하면 너희가 그 땅에 안전히 거할 것이라","reference":"레위기 25:18","category":"$undefined"},{"id":"3489","book":"레위기","book_name":"레위기","chapter":25,"verse":19,"text":"땅은 그 산물을 내리니 너희가 배불리 먹고 거기 안전히 거하리라","reference":"레위기 25:19","category":"$undefined"},{"id":"3490","book":"레위기","book_name":"레위기","chapter":25,"verse":20,"text":"혹 너희 말이 우리가 만일 제 칠년에 심지도 못하고 그 산물을 거두지도 못하면 무엇을 먹으리요 하겠으나","reference":"레위기 25:20","category":"$undefined"},{"id":"3491","book":"레위기","book_name":"레위기","chapter":25,"verse":21,"text":"내가 명하여 제 육년에 내 복을 너희에게 내려 그 소출이 삼년 쓰기에 족하게 할지라","reference":"레위기 25:21","category":"$undefined"},{"id":"3492","book":"레위기","book_name":"레위기","chapter":25,"verse":22,"text":"너희가 제 팔년에는 파종하려니와 묵은 곡식을 먹을 것이며 제 구년 곧 추수하기까지 묵은 곡식을 먹으리라","reference":"레위기 25:22","category":"$undefined"},{"id":"3493","book":"레위기","book_name":"레위기","chapter":25,"verse":23,"text":"토지를 영영히 팔지 말 것은 토지는 다 내 것임이라 너희는 나그네요 우거하는 자로서 나와 함께 있느니라","reference":"레위기 25:23","category":"$undefined"},{"id":"3494","book":"레위기","book_name":"레위기","chapter":25,"verse":24,"text":"너희 기업의 온 땅에서 그 토지 무르기를 허락할지니","reference":"레위기 25:24","category":"$undefined"},{"id":"3495","book":"레위기","book_name":"레위기","chapter":25,"verse":25,"text":"만일 너희 형제가 가난하여 그 기업 얼마를 팔았으면 그 근족이 와서 동족의 판 것을 무를 것이요","reference":"레위기 25:25","category":"$undefined"},{"id":"3496","book":"레위기","book_name":"레위기","chapter":25,"verse":26,"text":"만일 그것을 무를 사람이 없고 자기가 부요하게 되어 무를 힘이 있거든","reference":"레위기 25:26","category":"$undefined"},{"id":"3497","book":"레위기","book_name":"레위기","chapter":25,"verse":27,"text":"그 판 해를 계수하여 그 남은 값을 산 자에게 주고 그 기업으로 돌아갈 것이니라","reference":"레위기 25:27","category":"$undefined"},{"id":"3498","book":"레위기","book_name":"레위기","chapter":25,"verse":28,"text":"그러나 자기가 무를 힘이 없으면 그 판것이 희년이 이르기까지 산자의 손에 있다가 희년에 미쳐 돌아올지니 그가 곧 그 기업으로 돌아갈 것이니라","reference":"레위기 25:28","category":"$undefined"},{"id":"3499","book":"레위기","book_name":"레위기","chapter":25,"verse":29,"text":"성벽 있는 성내의 가옥을 팔았으면 판 지 만 일년 안에는 무를 수 있나니 곧 그 기한 안에 무르려니와","reference":"레위기 25:29","category":"$undefined"},{"id":"3500","book":"레위기","book_name":"레위기","chapter":25,"verse":30,"text":"주년 내에 무르지 못하면 그 성내 가옥은 산 자의 소유로 확정되어 대대로 영영히 그에게 속하고 희년에라도 돌려 보내지 아니할 것이니라","reference":"레위기 25:30","category":"$undefined"},{"id":"3501","book":"레위기","book_name":"레위기","chapter":25,"verse":31,"text":"그러나 성벽이 둘리지 아니한 촌락의 가옥은 나라의 전토 일례로 물러주기도 할 것이요 희년에 돌려 보내기도 할 것이니라","reference":"레위기 25:31","category":"$undefined"},{"id":"3502","book":"레위기","book_name":"레위기","chapter":25,"verse":32,"text":"레위 족속의 성읍 곧 그 기업의 성읍의 가옥은 레위 사람이 언제든지 무를 수 있으나","reference":"레위기 25:32","category":"$undefined"},{"id":"3503","book":"레위기","book_name":"레위기","chapter":25,"verse":33,"text":"레위 사람이 만일 무르지 아니하면 그 기업된 성읍의 판 가옥은 희년에 돌려 보낼지니 대저 레위 사람의 성읍의 가옥은 이스라엘 자손 중에서 얻을 기업이 됨이니라","reference":"레위기 25:33","category":"$undefined"},{"id":"3504","book":"레위기","book_name":"레위기","chapter":25,"verse":34,"text":"그러나 그 성읍의 들의 사면 밭은 그의 영원한 기업이니 팔지 못할지니라","reference":"레위기 25:34","category":"$undefined"},{"id":"3505","book":"레위기","book_name":"레위기","chapter":25,"verse":35,"text":"네 동족이 빈한하게 되어 빈 손으로 네 곁에 있거든 너는 그를 도와 객이나 우거하는 자처럼 너와 함께 생활하게 하되","reference":"레위기 25:35","category":"$undefined"},{"id":"3506","book":"레위기","book_name":"레위기","chapter":25,"verse":36,"text":"너는 그에게 이식을 취하지 말고 네 하나님을 경외하여 네 형제로 너와 함께 생활하게 할 것인즉","reference":"레위기 25:36","category":"$undefined"},{"id":"3507","book":"레위기","book_name":"레위기","chapter":25,"verse":37,"text":"너는 그에게 이식을 위하여 돈을 꾸이지 말고 이익을 위하여 식물을 꾸이지 말라","reference":"레위기 25:37","category":"$undefined"},{"id":"3508","book":"레위기","book_name":"레위기","chapter":25,"verse":38,"text":"나는 너희 하나님이 되려고 또는 가나안 땅으로 너희에게 주려고 애굽 땅에서 너희를 인도하여 낸 너희 하나님 여호와니라 !","reference":"레위기 25:38","category":"$undefined"},{"id":"3509","book":"레위기","book_name":"레위기","chapter":25,"verse":39,"text":"네 동족이 반한하게 되어 네게 몸이 팔리거든 너는 그를 종으로 부리지 말고","reference":"레위기 25:39","category":"$undefined"},{"id":"3510","book":"레위기","book_name":"레위기","chapter":25,"verse":40,"text":"품군이나 우거하는 자같이 너와 함께 있게 하여 희년까지 너를 섬기게 하라","reference":"레위기 25:40","category":"$undefined"},{"id":"3511","book":"레위기","book_name":"레위기","chapter":25,"verse":41,"text":"그 때에는 그와 그 자녀가 함께 네게서 떠나 그 본족에게로 돌아가서 조상의 기업을 회복하리라","reference":"레위기 25:41","category":"$undefined"},{"id":"3512","book":"레위기","book_name":"레위기","chapter":25,"verse":42,"text":"그들은 내가 애굽 땅에서 인도하여 낸바 나의 품군인즉 종으로 팔리지 말 것이라","reference":"레위기 25:42","category":"$undefined"},{"id":"3513","book":"레위기","book_name":"레위기","chapter":25,"verse":43,"text":"너는 그를 엄하게 부리지 말고 너의 하나님을 경외하라 !","reference":"레위기 25:43","category":"$undefined"},{"id":"3514","book":"레위기","book_name":"레위기","chapter":25,"verse":44,"text":"너의 종은 남녀를 무론하고 너의 사면 이방인 중에서 취할지니 남녀 종은 이런 자 중에서 살 것이며","reference":"레위기 25:44","category":"$undefined"},{"id":"3515","book":"레위기","book_name":"레위기","chapter":25,"verse":45,"text":"또 너희 중에 우거한 이방인의 자녀 중에서도 너희가 살 수 있고 또 그들이 너희 중에서 살아서 너희 땅에서 가정을 이룬 그 중에서도 그리할 수 있은즉 그들이 너희 소유가 될찌니","reference":"레위기 25:45","category":"$undefined"},{"id":"3516","book":"레위기","book_name":"레위기","chapter":25,"verse":46,"text":"너희는 그들을 너희 후손에게 기업으로 주어 소유가 되게 할 것이라 이방인 중에서는 너희가 영원한 종을 삼으려니와 너희 동족 이스라엘 자손은 너희 피차 엄하게 부리지 말지니라","reference":"레위기 25:46","category":"$undefined"},{"id":"3517","book":"레위기","book_name":"레위기","chapter":25,"verse":47,"text":"너희 중에 우거하는 이방인은 부요하게 되고 그 곁에 사는 너희 동족은 빈한하게 됨으로 너희 중에 우거하는 그 이방인에게나 그 족속에게 몸이 팔렸으면","reference":"레위기 25:47","category":"$undefined"},{"id":"3518","book":"레위기","book_name":"레위기","chapter":25,"verse":48,"text":"팔린 후에 그를 속량할 수 있나니 그 형제 중 하나가 속하거나","reference":"레위기 25:48","category":"$undefined"},{"id":"3519","book":"레위기","book_name":"레위기","chapter":25,"verse":49,"text":"삼촌이나 사촌이 속하거나 그 근족 중 누구든지 속할 것이요 그가 부요하게 되면 스스로 속하되","reference":"레위기 25:49","category":"$undefined"},{"id":"3520","book":"레위기","book_name":"레위기","chapter":25,"verse":50,"text":"자기 몸이 팔린 해로부터 희년까지를 그 산 자와 계산하여 그 년수를 따라서 그 몸의 값을 정할 때에 그 사람을 섬긴 날을 그 사람에게 고용된 날로 여길 것이라","reference":"레위기 25:50","category":"$undefined"},{"id":"3521","book":"레위기","book_name":"레위기","chapter":25,"verse":51,"text":"만일 남은 해가 많으면 그 연수대로 팔린 값에서 속하는 값을 그 사람에게 도로 주고","reference":"레위기 25:51","category":"$undefined"},{"id":"3522","book":"레위기","book_name":"레위기","chapter":25,"verse":52,"text":"만일 희년까지 남은 해가 적으면 그 사람과 계산하여 그 연수대로 속하는 그 값을 그에게 도로 줄지며","reference":"레위기 25:52","category":"$undefined"},{"id":"3523","book":"레위기","book_name":"레위기","chapter":25,"verse":53,"text":"주인은 그를 매년의 삯군과 같이 여기고 너의 목전에서 엄하게 부리지 못하리라","reference":"레위기 25:53","category":"$undefined"},{"id":"3524","book":"레위기","book_name":"레위기","chapter":25,"verse":54,"text":"그가 이같이 속하지 못하면 희년에 이르러 그와 그 자녀가 자유하리니","reference":"레위기 25:54","category":"$undefined"},{"id":"3525","book":"레위기","book_name":"레위기","chapter":25,"verse":55,"text":"이스라엘 자손은 나의 품군이 됨이라 그들은 내가 애굽 땅에서 인도하여 낸 나의 품군이요 나는 너희 하나님 여호와니라 !","reference":"레위기 25:55","category":"$undefined"}],"bookSlug":"leviticus"}]
