11:I[1873,["9203","static/chunks/9203-996b4ec42a4109b3.js","2972","static/chunks/2972-9bb10279b4b15167.js","5920","static/chunks/5920-1440aceac5f52f98.js","6678","static/chunks/6678-c14eef17aa65bcf8.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-fccd9fb1d2a90f99.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":26,"verses":[{"id":"3526","book":"레위기","book_name":"레위기","chapter":26,"verse":1,"text":"너희는 자기를 위하여 우상을 만들지 말지니 목상이나 주상을 세우지 말며 너희 땅에 조각한 석상을 세우고 그에게 경배하지 말라 나는 너희 하나님 여호와임이니라 !","reference":"레위기 26:1","category":"$undefined"},{"id":"3527","book":"레위기","book_name":"레위기","chapter":26,"verse":2,"text":"너희는 나의 안식일을 지키며 나의 성소를 공경하라 ! 나는 여호와니라 !","reference":"레위기 26:2","category":"$undefined"},{"id":"3528","book":"레위기","book_name":"레위기","chapter":26,"verse":3,"text":"너희가 나의 규례와 계명을 준행하면","reference":"레위기 26:3","category":"$undefined"},{"id":"3529","book":"레위기","book_name":"레위기","chapter":26,"verse":4,"text":"내가 너희 비를 그 시후에 주리니 땅은 그 산물을 내고 밭의 수목은 열매를 맺을지라","reference":"레위기 26:4","category":"$undefined"},{"id":"3530","book":"레위기","book_name":"레위기","chapter":26,"verse":5,"text":"너희의 타작은 포도 딸 때까지 미치며 너희의 포도 따는 것은 파종할 때까지 미치리니 너희가 음식을 배불리 먹고 너희 땅에 안전히 거하리라","reference":"레위기 26:5","category":"$undefined"},{"id":"3531","book":"레위기","book_name":"레위기","chapter":26,"verse":6,"text":"내가 그 땅에 평화를 줄 것인즉 너희가 누우나 너희를 두렵게 할자가 없을 것이며 내가 사나운 짐승을 그 땅에서 제할 것이요 칼이 너희 땅에 두루 행하지 아니할 것이며","reference":"레위기 26:6","category":"$undefined"},{"id":"3532","book":"레위기","book_name":"레위기","chapter":26,"verse":7,"text":"너희가 대적을 쫓으리니 그들이 너희 앞에서 칼에 엎드러질 것이라","reference":"레위기 26:7","category":"$undefined"},{"id":"3533","book":"레위기","book_name":"레위기","chapter":26,"verse":8,"text":"너희 다섯이 백을 쫓고, 너희 백이 만을 쫓으리니 너희 대적들이 너희 앞에서 칼에 엎드러질 것이며","reference":"레위기 26:8","category":"$undefined"},{"id":"3534","book":"레위기","book_name":"레위기","chapter":26,"verse":9,"text":"내가 너희를 권고하여 나의 너희와 세운 언약을 이행하여 너희로 번성케 하고 너희로 창대케 할 것이며","reference":"레위기 26:9","category":"$undefined"},{"id":"3535","book":"레위기","book_name":"레위기","chapter":26,"verse":10,"text":"너희는 오래 두었던 묵은 곡식을 먹다가 새 곡식을 인하여 묵은 곡식을 치우게 될 것이며","reference":"레위기 26:10","category":"$undefined"},{"id":"3536","book":"레위기","book_name":"레위기","chapter":26,"verse":11,"text":"내가 내 장막을 너희 중에 세우리니 내 마음이 너희를 싫어하지 아니할 것이며","reference":"레위기 26:11","category":"$undefined"},{"id":"3537","book":"레위기","book_name":"레위기","chapter":26,"verse":12,"text":"나는 너희 중에 행하여 너희 하나님이 되고 너희는 나의 백성이 될 것이니라","reference":"레위기 26:12","category":"$undefined"},{"id":"3538","book":"레위기","book_name":"레위기","chapter":26,"verse":13,"text":"나는 너희를 애굽 땅에서 인도하여 내어 그 종된 것을 면케 한 너희 하나님 여호와라 ! 내가 너희 멍에 빗장목을 깨뜨리고 너희로 바로 서서 걷게 하였느니라","reference":"레위기 26:13","category":"$undefined"},{"id":"3539","book":"레위기","book_name":"레위기","chapter":26,"verse":14,"text":"그러나 너희가 내게 청종치 아니하여 이 모든 명령을 준행치 아니하며","reference":"레위기 26:14","category":"$undefined"},{"id":"3540","book":"레위기","book_name":"레위기","chapter":26,"verse":15,"text":"나의 규례를 멸시하며 마음에 나의 법도를 싫어하여 나의 모든 계명을 준행치 아니하며 나의 언약을 배반할진대","reference":"레위기 26:15","category":"$undefined"},{"id":"3541","book":"레위기","book_name":"레위기","chapter":26,"verse":16,"text":"내가 이같이 너희에게 행하리니 곧 내가 너희에게 놀라운 재앙을 내려 폐병과 열병으로 눈이 어둡고 생명이 쇠약하게 할것이요 너희의 파종은 헛되리니 너희의 대적이 그것을 먹을 것임이며","reference":"레위기 26:16","category":"$undefined"},{"id":"3542","book":"레위기","book_name":"레위기","chapter":26,"verse":17,"text":"내가 너희를 치리니 너희가 너희 대적에게 패할 것이요 너희를 미워하는 자가 너희를 다스릴 것이며 너희는 쫓는 자가 없어도 도망하리라","reference":"레위기 26:17","category":"$undefined"},{"id":"3543","book":"레위기","book_name":"레위기","chapter":26,"verse":18,"text":"너희가 그렇게 되어도 내게 청종치 아니하면 너희 죄를 인하여 내가 너희를 칠배나 더 징치할지라","reference":"레위기 26:18","category":"$undefined"},{"id":"3544","book":"레위기","book_name":"레위기","chapter":26,"verse":19,"text":"내가 너희의 세력을 인한 교만을 꺾고 너희 하늘로 철과 같게 하며 너희 땅으로 놋과 같게 하리니","reference":"레위기 26:19","category":"$undefined"},{"id":"3545","book":"레위기","book_name":"레위기","chapter":26,"verse":20,"text":"너희 수고가 헛될지라 땅은 그 산물을 내지 아니하고 땅의 나무는 그 열매를 맺지 아니하리라","reference":"레위기 26:20","category":"$undefined"},{"id":"3546","book":"레위기","book_name":"레위기","chapter":26,"verse":21,"text":"너희가 나를 거스려 내게 청종치 않을진대 내가 너희 죄대로 너희에게 칠배나 더 재앙을 내릴 것이라","reference":"레위기 26:21","category":"$undefined"},{"id":"3547","book":"레위기","book_name":"레위기","chapter":26,"verse":22,"text":"내가 들짐승을 너희 중에 보내리니 그것들이 너희 자녀를 움키고 너희 육축을 멸하며 너희 수효를 감소케 할지라 너희 도로가 황폐하리라","reference":"레위기 26:22","category":"$undefined"},{"id":"3548","book":"레위기","book_name":"레위기","chapter":26,"verse":23,"text":"이런 일을 당하여도 너희가 내게로 돌아오지 아니하고 나를 대항할진대","reference":"레위기 26:23","category":"$undefined"},{"id":"3549","book":"레위기","book_name":"레위기","chapter":26,"verse":24,"text":"나 곧 나도 너희에게 대항하여 너희 죄를 인하여 너희를 칠배나 더 칠지라","reference":"레위기 26:24","category":"$undefined"},{"id":"3550","book":"레위기","book_name":"레위기","chapter":26,"verse":25,"text":"내가 칼을 너희에게로 가져다가 너희의 배약한 원수를 갚을 것이며 너희가 성읍에 모일지라도 너희 중에 염병을 보내고 너희를 대적의 손에 붙일 것이며","reference":"레위기 26:25","category":"$undefined"},{"id":"3551","book":"레위기","book_name":"레위기","chapter":26,"verse":26,"text":"내가 너희 의뢰하는 양식을 끊을 때에 열 여인이 한 화덕에서 너희 떡을 구워 저울에 달아 주리니 너희가 먹어도 배부르지 아니하리라","reference":"레위기 26:26","category":"$undefined"},{"id":"3552","book":"레위기","book_name":"레위기","chapter":26,"verse":27,"text":"너희가 이같이 될지라도 내게 청종치 아니하고 내게 대항할진대","reference":"레위기 26:27","category":"$undefined"},{"id":"3553","book":"레위기","book_name":"레위기","chapter":26,"verse":28,"text":"내가 진노로 너희에게 대항하되 너희 죄를 인하여 칠배나 더 징책하리니","reference":"레위기 26:28","category":"$undefined"},{"id":"3554","book":"레위기","book_name":"레위기","chapter":26,"verse":29,"text":"너희가 아들의 고기를 먹을 것이요 딸의 고기를 먹을 것이며","reference":"레위기 26:29","category":"$undefined"},{"id":"3555","book":"레위기","book_name":"레위기","chapter":26,"verse":30,"text":"내가 너희의 산당을 헐며 너희의 태양 주상을 찍어 넘기며 너희 시체를 파상한 우상 위에 던지고 내 마음이 너희를 싫어할 것이며","reference":"레위기 26:30","category":"$undefined"},{"id":"3556","book":"레위기","book_name":"레위기","chapter":26,"verse":31,"text":"내가 너희 성읍으로 황폐케 하고 너희 성소들로 황량케 할 것이요 너희의 향기로운 향을 흠향치 아니하고","reference":"레위기 26:31","category":"$undefined"},{"id":"3557","book":"레위기","book_name":"레위기","chapter":26,"verse":32,"text":"그 땅을 황무케 하리니 거기 거하는 너희 대적들이 그것을 인하여 놀랄 것이며","reference":"레위기 26:32","category":"$undefined"},{"id":"3558","book":"레위기","book_name":"레위기","chapter":26,"verse":33,"text":"내가 너희를 열방 중에 흩을 것이요 내가 칼을 빼어 너희를 따르게 하리니 너희의 땅이 황무하며 너희의 성읍이 황폐하리라","reference":"레위기 26:33","category":"$undefined"},{"id":"3559","book":"레위기","book_name":"레위기","chapter":26,"verse":34,"text":"너희가 대적의 땅에 거할 동안에 너희 본토가 황무할 것이므로 땅이 안식을 누릴 것이라 그 때에 땅이 쉬어 안식을 누리리니","reference":"레위기 26:34","category":"$undefined"},{"id":"3560","book":"레위기","book_name":"레위기","chapter":26,"verse":35,"text":"너희가 그 땅에 거한 동안 너희 안식시에 쉼을 얻지 못하던 땅이 그 황무할 동안에는 쉬리라","reference":"레위기 26:35","category":"$undefined"},{"id":"3561","book":"레위기","book_name":"레위기","chapter":26,"verse":36,"text":"너희 남은 자에게는 그 대적의 땅에서 내가 그들의 마음으로 약하게 하리니 그들은 바람에 불린 잎사귀 소리에도 놀라 도망하기를 칼을 피하여 도망하듯 할 것이요 쫓는 자가 없어도 엎드러질 것이라","reference":"레위기 26:36","category":"$undefined"},{"id":"3562","book":"레위기","book_name":"레위기","chapter":26,"verse":37,"text":"그들은 쫓는 자가 없어도 칼 앞에 있음같이 서로 천답하여 넘어지리니 너희가 대적을 당할 힘이 없을 것이요","reference":"레위기 26:37","category":"$undefined"},{"id":"3563","book":"레위기","book_name":"레위기","chapter":26,"verse":38,"text":"너희가 열방 중에서 망하리니 너희 대적의 땅이 너희를 삼킬 것이라","reference":"레위기 26:38","category":"$undefined"},{"id":"3564","book":"레위기","book_name":"레위기","chapter":26,"verse":39,"text":"너희 남은 자가 너희 대적의 땅에서 자기의 죄로 인하여 쇠잔하며 그 열조의 죄로 인하여 그 열조 같이 쇠잔하리라","reference":"레위기 26:39","category":"$undefined"},{"id":"3565","book":"레위기","book_name":"레위기","chapter":26,"verse":40,"text":"그들이 자기 죄와 그 열조의 죄와 및 그들이 나를 거스린 허물을 자복하고 또 자기들이 나를 대항하였으므로","reference":"레위기 26:40","category":"$undefined"},{"id":"3566","book":"레위기","book_name":"레위기","chapter":26,"verse":41,"text":"나도 그들을 대항하여 그 대적의 땅으로 끌어 갔음을 깨닫고 그 할례받지 아니한 마음이 낮아져서 그 죄악의 형벌을 순히 받으면","reference":"레위기 26:41","category":"$undefined"},{"id":"3567","book":"레위기","book_name":"레위기","chapter":26,"verse":42,"text":"내가 야곱과 맺은 내 언약과 이삭과 맺은 내 언약을 생각하며 아브라함과 맺은 내 언약을 생각하고 그 땅을 권고하리라","reference":"레위기 26:42","category":"$undefined"},{"id":"3568","book":"레위기","book_name":"레위기","chapter":26,"verse":43,"text":"그들이 나의 법도를 싫어하며 나의 규례를 멸시하였으므로 그 땅을 떠나서 사람이 없을 때에 땅이 황폐하여 안식을 누릴 것이요 그들은 자기 죄악으로 형벌을 순히 받으리라","reference":"레위기 26:43","category":"$undefined"},{"id":"3569","book":"레위기","book_name":"레위기","chapter":26,"verse":44,"text":"그런즉 그들이 대적의 땅에 거할 때에 내가 싫어 버리지 아니하며, 미워하지 아니하며, 아주 멸하지 아니하여 나의 그들과 세운 언약을 폐하지 아니하리니 나는 여호와 그들의 하나님이 됨이라","reference":"레위기 26:44","category":"$undefined"},{"id":"3570","book":"레위기","book_name":"레위기","chapter":26,"verse":45,"text":"내가 그들의 하나님이 되기 위하여 열방의 목전에 애굽에서 인도하여 낸 그들의 열조와 맺은 언약을 그들을 위하여 기억하리라 나는 여호와니라 !","reference":"레위기 26:45","category":"$undefined"},{"id":"3571","book":"레위기","book_name":"레위기","chapter":26,"verse":46,"text":"이상은 여호와께서 시내산에서 자기와 이스라엘 자손 사이에 모세로 세우신 규례와 법도와 율법이니라","reference":"레위기 26:46","category":"$undefined"}],"bookSlug":"leviticus"}]
