2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":4,"verses":[{"id":"2797","book":"레위기","book_name":"레위기","chapter":4,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 4:1","category":"$undefined"},{"id":"2798","book":"레위기","book_name":"레위기","chapter":4,"verse":2,"text":"이스라엘 자손에게 고하여 이르라 누구든지 여호와의 금령 중 하나라도 그릇 범하였으되","reference":"레위기 4:2","category":"$undefined"},{"id":"2799","book":"레위기","book_name":"레위기","chapter":4,"verse":3,"text":"만일 기름 부음을 받은 제사장이 범죄하여 백성으로 죄얼을 입게 하였으면 그 범한 죄를 인하여 흠 없는 수송아지로 속죄 제물을 삼아 여호와께 드릴지니","reference":"레위기 4:3","category":"$undefined"},{"id":"2800","book":"레위기","book_name":"레위기","chapter":4,"verse":4,"text":"곧 그 수송아지를 회막문 여호와 앞으로 끌어다가 그 수송아지 머리에 안수하고 그것을 여호와 앞에서 잡을 것이요","reference":"레위기 4:4","category":"$undefined"},{"id":"2801","book":"레위기","book_name":"레위기","chapter":4,"verse":5,"text":"기름 부음을 받은 제사장은 그 수송아지의 피를 가지고 회막에 들어가서","reference":"레위기 4:5","category":"$undefined"},{"id":"2802","book":"레위기","book_name":"레위기","chapter":4,"verse":6,"text":"그 제사장이 손가락에 그 피를 찍어 여호와 앞 곧 성소 장 앞에 일곱번 뿌릴 것이며","reference":"레위기 4:6","category":"$undefined"},{"id":"2803","book":"레위기","book_name":"레위기","chapter":4,"verse":7,"text":"제사장은 또 그 피를 여호와 앞 곧 회막 안 향단 뿔에 바르고 그 송아지의 피 전부를 회막문 앞 번제단 밑에 쏟을 것이며","reference":"레위기 4:7","category":"$undefined"},{"id":"2804","book":"레위기","book_name":"레위기","chapter":4,"verse":8,"text":"또 그 속죄 제물 된 수송아지의 모든 기름을 취할지니 곧 내장에 덮인 기름과, 내장에 붙은 모든 기름과,","reference":"레위기 4:8","category":"$undefined"},{"id":"2805","book":"레위기","book_name":"레위기","chapter":4,"verse":9,"text":"두 콩팥과, 그 위의 기름 곧 허리 근방에 있는 것과, 간에 덮인 꺼풀을 콩팥과, 함께 취하되","reference":"레위기 4:9","category":"$undefined"},{"id":"2806","book":"레위기","book_name":"레위기","chapter":4,"verse":10,"text":"화목제 희생의 소에게서 취함 같이 할 것이요, 제사장은 그것을 번제단 위에 불사를 것이며","reference":"레위기 4:10","category":"$undefined"},{"id":"2807","book":"레위기","book_name":"레위기","chapter":4,"verse":11,"text":"그 수송아지의 가죽과, 그 모든 고기와, 그 머리와, 다리와, 내장과,","reference":"레위기 4:11","category":"$undefined"},{"id":"2808","book":"레위기","book_name":"레위기","chapter":4,"verse":12,"text":"곧 그 송아지의 전체를 진 바깥 재 버리는 곳인 청결한 곳으로 가져다가 불로 나무 위에 사르되 곧 재 버리는 곳에서 사를지니라","reference":"레위기 4:12","category":"$undefined"},{"id":"2809","book":"레위기","book_name":"레위기","chapter":4,"verse":13,"text":"만일 이스라엘 온 회중이 여호와의 금령 중 하나라도 그릇 범하여 허물이 있으나 스스로 깨닫지 못하다가","reference":"레위기 4:13","category":"$undefined"},{"id":"2810","book":"레위기","book_name":"레위기","chapter":4,"verse":14,"text":"그 범한 죄를 깨달으면 회중은 수송아지를 속죄제로 드릴지니 그것을 회막 앞으로 끌어다가","reference":"레위기 4:14","category":"$undefined"},{"id":"2811","book":"레위기","book_name":"레위기","chapter":4,"verse":15,"text":"회중의 장로들이 여호와 앞에서 그 수송아지 머리에 안수하고 그것을 여호와 앞에서 잡을 것이요","reference":"레위기 4:15","category":"$undefined"},{"id":"2812","book":"레위기","book_name":"레위기","chapter":4,"verse":16,"text":"기름 부음을 받은 제사장은 그 수송아지의 피를 가지고 회막에 들어가서","reference":"레위기 4:16","category":"$undefined"},{"id":"2813","book":"레위기","book_name":"레위기","chapter":4,"verse":17,"text":"그 제사장이 손가락으로 그 피를 찍어 여호와 앞 장 앞에 일곱번 뿌릴 것이며","reference":"레위기 4:17","category":"$undefined"},{"id":"2814","book":"레위기","book_name":"레위기","chapter":4,"verse":18,"text":"또 그 피로 회막 안 여호와 앞에 있는 단 뿔에 바르고 그 피 전부는 회막문 앞 번제단 밑에 쏟을 것이며","reference":"레위기 4:18","category":"$undefined"},{"id":"2815","book":"레위기","book_name":"레위기","chapter":4,"verse":19,"text":"그 기름은 다 취하여 단 위에 불사르되","reference":"레위기 4:19","category":"$undefined"},{"id":"2816","book":"레위기","book_name":"레위기","chapter":4,"verse":20,"text":"그 송아지를 속제죄의 수송아지에게 한 것 같이 할지며 제사장이 그것으로 회중을 위하여 속죄한즉 그들이 사함을 얻으리라 !","reference":"레위기 4:20","category":"$undefined"},{"id":"2817","book":"레위기","book_name":"레위기","chapter":4,"verse":21,"text":"그는 그 수송아지를 진 밖으로 가져다가 첫번 수송아지를 사름같이 사를지니 이는 회중의 속죄제니라","reference":"레위기 4:21","category":"$undefined"},{"id":"2818","book":"레위기","book_name":"레위기","chapter":4,"verse":22,"text":"만일 족장이 그 하나님 여호와의 금령 중 하나라도 부지중에 범하여 허물이 있었다가","reference":"레위기 4:22","category":"$undefined"},{"id":"2819","book":"레위기","book_name":"레위기","chapter":4,"verse":23,"text":"그 범한 죄에 깨우침을 받거든 그는 흠 없는 수염소를 예물로 가져다가","reference":"레위기 4:23","category":"$undefined"},{"id":"2820","book":"레위기","book_name":"레위기","chapter":4,"verse":24,"text":"그 수염소의 머리에 안수하고 여호와 앞 번제 희생을 잡는 곳에서 잡을지니 이는 속죄제라","reference":"레위기 4:24","category":"$undefined"},{"id":"2821","book":"레위기","book_name":"레위기","chapter":4,"verse":25,"text":"제사장은 그 속죄 희생의 피를 손가락으로 찍어 번제단 뿔에 바르고 그 피는 번제단 밑에 쏟고","reference":"레위기 4:25","category":"$undefined"},{"id":"2822","book":"레위기","book_name":"레위기","chapter":4,"verse":26,"text":"그 모든 기름은 화목제 희생의 기름같이 단 위에 불사를지니 이같이 제사장이 그 범한 죄에 대하여 그를 위하여 속죄한즉 그가 사함을 얻으리라 !","reference":"레위기 4:26","category":"$undefined"},{"id":"2823","book":"레위기","book_name":"레위기","chapter":4,"verse":27,"text":"만일 평민의 하나가 여호와의 금령 중 하나라도 부지중에 범하여 허물이 있었다가","reference":"레위기 4:27","category":"$undefined"},{"id":"2824","book":"레위기","book_name":"레위기","chapter":4,"verse":28,"text":"그 범한 죄에 깨우침을 받거든 그는 흠 없는 암염소를 끌고와서 그 범한 죄를 인하여 그것을 예물로 삼아","reference":"레위기 4:28","category":"$undefined"},{"id":"2825","book":"레위기","book_name":"레위기","chapter":4,"verse":29,"text":"그 속죄제 희생의 머리에 안수하고 그 희생을 번제소에서 잡을 것이요","reference":"레위기 4:29","category":"$undefined"},{"id":"2826","book":"레위기","book_name":"레위기","chapter":4,"verse":30,"text":"제사장은 손가락으로 그 피를 찍어 번제단 뿔에 바르고 그 피 전부를 단 밑에 쏟고","reference":"레위기 4:30","category":"$undefined"},{"id":"2827","book":"레위기","book_name":"레위기","chapter":4,"verse":31,"text":"그 모든 기름을 화목제 희생의 기름을 취한 것 같이 취하여 단 위에 불 살라 여호와께 향기롭게 할지니 제사장이 그를 위하여 속죄 한즉 그가 사함을 얻으리라 !","reference":"레위기 4:31","category":"$undefined"},{"id":"2828","book":"레위기","book_name":"레위기","chapter":4,"verse":32,"text":"그가 만일 어린 양을 속죄 제물로 가져 오려거든 흠 없는 암컷을 끌어다가","reference":"레위기 4:32","category":"$undefined"},{"id":"2829","book":"레위기","book_name":"레위기","chapter":4,"verse":33,"text":"그 속죄제 희생의 머리에 안수하고 번제 희생을 잡는 곳에서 잡아 속죄제를 삼을 것이요","reference":"레위기 4:33","category":"$undefined"},{"id":"2830","book":"레위기","book_name":"레위기","chapter":4,"verse":34,"text":"제사장은 그 속죄제 희생의 피를 손가락으로 찍어 번제단 뿔에 바르고 그 피는 전부를 단 밑에 쏟고","reference":"레위기 4:34","category":"$undefined"},{"id":"2831","book":"레위기","book_name":"레위기","chapter":4,"verse":35,"text":"그 모든 기름을 화목제 어린 양의 기름을 취한것 같이 취하여 단 위 여호와의 화제물 위에 불사를지니 이같이 제사장이 그의 범한죄에 대하여 그를 위하여 속죄한즉 그가 사함을 얻으리라 !","reference":"레위기 4:35","category":"$undefined"}],"bookSlug":"leviticus"}]
