2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":6,"verses":[{"id":"2851","book":"레위기","book_name":"레위기","chapter":6,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 6:1","category":"$undefined"},{"id":"2852","book":"레위기","book_name":"레위기","chapter":6,"verse":2,"text":"누구든지 여호와께 신실치 못하여 범죄하되 곧 남의 물건을 맡거나 전당 잡거나 강도질하거나 늑봉하고도 사실을 부인하거나","reference":"레위기 6:2","category":"$undefined"},{"id":"2853","book":"레위기","book_name":"레위기","chapter":6,"verse":3,"text":"남의 잃은 물건을 얻고도 사실을 부인하여 거짓 맹세하는 등 사람이 이 모든 일 중에 하나라도 행하여 범죄하면","reference":"레위기 6:3","category":"$undefined"},{"id":"2854","book":"레위기","book_name":"레위기","chapter":6,"verse":4,"text":"이는 죄를 범하였고 죄가 있는 자니 그 빼앗은 것이나 늑봉한 것이나 맡은 것이나 얻은 유실물이나","reference":"레위기 6:4","category":"$undefined"},{"id":"2855","book":"레위기","book_name":"레위기","chapter":6,"verse":5,"text":"무릇 그 거짓 맹세한 물건을 돌려 보내되 곧 그 본물에 오분 일을 더하여 돌려 보낼 것이니 그 죄가 드러나는 날에 그 임자에게 줄 것이요","reference":"레위기 6:5","category":"$undefined"},{"id":"2856","book":"레위기","book_name":"레위기","chapter":6,"verse":6,"text":"그는 또 그 속건제를 여호와께 가져 올지니 곧 너의 지정한 가치대로 떼 중 흠 없는 수양을 속건 제물을 위하여 제사장에게로 끌어 올 것이요","reference":"레위기 6:6","category":"$undefined"},{"id":"2857","book":"레위기","book_name":"레위기","chapter":6,"verse":7,"text":"제사장은 여호와 앞에서 그를 위하여 속죄한즉 그는 무슨 허물이든지 사함을 얻으리라 !","reference":"레위기 6:7","category":"$undefined"},{"id":"2858","book":"레위기","book_name":"레위기","chapter":6,"verse":8,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 6:8","category":"$undefined"},{"id":"2859","book":"레위기","book_name":"레위기","chapter":6,"verse":9,"text":"아론과 그 자손에게 명하여 이르라 번제의 규례는 이러하니라 번제물은 단 위 석쇠 위에 아침까지 두고 단의 불로 그 위에서 꺼지지 않게 할 것이요","reference":"레위기 6:9","category":"$undefined"},{"id":"2860","book":"레위기","book_name":"레위기","chapter":6,"verse":10,"text":"제사장은 세마포 긴 옷을 입고 세마포 고의로 하체를 가리우고 단 위에서 탄 번제의 재를 가져다가 단 곁에 두고","reference":"레위기 6:10","category":"$undefined"},{"id":"2861","book":"레위기","book_name":"레위기","chapter":6,"verse":11,"text":"그 옷을 벗고 다른 옷을 입고 그 재를 진 바깥 정결한 곳으로 가져 갈 것이요","reference":"레위기 6:11","category":"$undefined"},{"id":"2862","book":"레위기","book_name":"레위기","chapter":6,"verse":12,"text":"단 위에 불은 항상 피워 꺼지지 않게 할지니 제사장은 아침마다 나무를 그 위에 태우고 번제물을 그 위에 벌여놓고 화목제의 기름을 그 위에 사를지며","reference":"레위기 6:12","category":"$undefined"},{"id":"2863","book":"레위기","book_name":"레위기","chapter":6,"verse":13,"text":"불은 끊이지 않고 단 위에 피워 꺼지지 않게 할지니라","reference":"레위기 6:13","category":"$undefined"},{"id":"2864","book":"레위기","book_name":"레위기","chapter":6,"verse":14,"text":"소제의 규례는 이러하니라 아론의 자손은 그것을 단 앞 여호와 앞에 드리되","reference":"레위기 6:14","category":"$undefined"},{"id":"2865","book":"레위기","book_name":"레위기","chapter":6,"verse":15,"text":"그 소제의 고운 기름 가루 한 웅큼과 소제물 위의 유향을 다 취하여 기념물로 단 위에 불살라 여호와 앞에 향기로운 냄새가 되게 하고","reference":"레위기 6:15","category":"$undefined"},{"id":"2866","book":"레위기","book_name":"레위기","chapter":6,"verse":16,"text":"그 나머지는 아론과 그 자손이 먹되 누룩을 넣지 말고 거룩한 곳 회막 뜰에서 먹을지니라 !","reference":"레위기 6:16","category":"$undefined"},{"id":"2867","book":"레위기","book_name":"레위기","chapter":6,"verse":17,"text":"그것에 누룩을 넣어 굽지 말라 ! 이는 나의 화제 중에서 내가 그들에게 주어 그 소득이 되게 하는 것이라 속죄제와 속건제같이 지극히 거룩한즉","reference":"레위기 6:17","category":"$undefined"},{"id":"2868","book":"레위기","book_name":"레위기","chapter":6,"verse":18,"text":"무릇 아론 자손의 남자는 이를 먹을지니 이는 여호와의 화제 중에서 그들의 대대로 영원한 소득이 됨이라 이를 만지는 자마다 거룩하니라 !","reference":"레위기 6:18","category":"$undefined"},{"id":"2869","book":"레위기","book_name":"레위기","chapter":6,"verse":19,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 6:19","category":"$undefined"},{"id":"2870","book":"레위기","book_name":"레위기","chapter":6,"verse":20,"text":"아론과 그 자손이 기름 부음을 받는 날에 여호와께 드릴 예물은 이러하니라 고운 가루 에바 십분 일을 항상 드리는 소제물로 삼아 그 절반은 아침에,절반은 저녁에 드리되","reference":"레위기 6:20","category":"$undefined"},{"id":"2871","book":"레위기","book_name":"레위기","chapter":6,"verse":21,"text":"그것을 기름으로 반죽하여 번철에 굽고 기름에 적시어다가 썰어 소제로 여호와께 드려 향기로운 냄새가 되게 하라","reference":"레위기 6:21","category":"$undefined"},{"id":"2872","book":"레위기","book_name":"레위기","chapter":6,"verse":22,"text":"이 소제는 아론의 자손 중 기름 부음을 받고 그를 이어 제사장 된 자가 드릴 것이요, 영원한 규례로 여호와께 온전히 불사를 것이니","reference":"레위기 6:22","category":"$undefined"},{"id":"2873","book":"레위기","book_name":"레위기","chapter":6,"verse":23,"text":"무릇 제사장의 소제물은 온전히 불사르고 먹지 말지니라 !","reference":"레위기 6:23","category":"$undefined"},{"id":"2874","book":"레위기","book_name":"레위기","chapter":6,"verse":24,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 6:24","category":"$undefined"},{"id":"2875","book":"레위기","book_name":"레위기","chapter":6,"verse":25,"text":"아론과 그 아들들에게 고하여 이르라 ! 속죄제의 규례는 이러하니라 속죄제 희생은 지극히 거룩하니 여호와 앞 번제 희생을 잡는 곳에서 그 속죄제 희생을 잡을 것이요","reference":"레위기 6:25","category":"$undefined"},{"id":"2876","book":"레위기","book_name":"레위기","chapter":6,"verse":26,"text":"죄를 위하여 제사드리는 제사장이 그것을 먹되 곧 회막 뜰 거룩한 곳에서 먹을 것이며","reference":"레위기 6:26","category":"$undefined"},{"id":"2877","book":"레위기","book_name":"레위기","chapter":6,"verse":27,"text":"무릇 그 고기에 접촉하는 자는 거룩할 것이며 그 피가 어떤 옷에든지 묻었으면 묻은 그것을 거룩한 곳에서 빨 것이요","reference":"레위기 6:27","category":"$undefined"},{"id":"2878","book":"레위기","book_name":"레위기","chapter":6,"verse":28,"text":"그 고기를 토기에 삶았으면 그 그릇을 깨뜨릴 것이요, 유기에 삶았으면 그 그릇을 닦고 물에 씻을 것이며","reference":"레위기 6:28","category":"$undefined"},{"id":"2879","book":"레위기","book_name":"레위기","chapter":6,"verse":29,"text":"그 고기는 지극히 거룩하니 제사장의 남자마다 먹을 것이니라","reference":"레위기 6:29","category":"$undefined"},{"id":"2880","book":"레위기","book_name":"레위기","chapter":6,"verse":30,"text":"그러나 피를 가지고 회막에 들어가 성소에서 속하게 한 속죄제 희생의 고기는 먹지 못할지니 불사를지니라","reference":"레위기 6:30","category":"$undefined"}],"bookSlug":"leviticus"}]
