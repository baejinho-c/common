2:["$","$L11",null,{"book":{"id":"leviticus","name":"레위기","chapters":27,"testament":"old"},"chapter":7,"verses":[{"id":"2881","book":"레위기","book_name":"레위기","chapter":7,"verse":1,"text":"속건제의 규례는 이러하니라 이는 지극히 거룩하니","reference":"레위기 7:1","category":"$undefined"},{"id":"2882","book":"레위기","book_name":"레위기","chapter":7,"verse":2,"text":"번제 희생을 잡는 곳에서 속건제의 희생을 잡을 것이요 제사장은 그 피를 단 사면에 뿌릴 것이며","reference":"레위기 7:2","category":"$undefined"},{"id":"2883","book":"레위기","book_name":"레위기","chapter":7,"verse":3,"text":"그 모든 기름을 드리되 곧 그 기름진 꼬리와, 내장에 덮인 기름과,","reference":"레위기 7:3","category":"$undefined"},{"id":"2884","book":"레위기","book_name":"레위기","chapter":7,"verse":4,"text":"두 콩팥과, 그 위의 기름 곧 허리 근방에 있는 것과, 간에 덮인 꺼풀을 콩팥과 함께 취하고","reference":"레위기 7:4","category":"$undefined"},{"id":"2885","book":"레위기","book_name":"레위기","chapter":7,"verse":5,"text":"제사장은 그것을 다 단 위에 불살라 여호와께 화제로 드릴 것이니라 이는 속건제요","reference":"레위기 7:5","category":"$undefined"},{"id":"2886","book":"레위기","book_name":"레위기","chapter":7,"verse":6,"text":"지극히 거룩하니 이것을 제사장의 남자마다 먹되 거룩한 곳에서 먹을지며","reference":"레위기 7:6","category":"$undefined"},{"id":"2887","book":"레위기","book_name":"레위기","chapter":7,"verse":7,"text":"속건제나 속죄제는 일례니 그 제육은 속하는 제사장에게로 돌아갈 것이요","reference":"레위기 7:7","category":"$undefined"},{"id":"2888","book":"레위기","book_name":"레위기","chapter":7,"verse":8,"text":"사람의 번제를 드리는 제사장 곧 그 제사장은 그 드린 번제물의 가죽을 자기가 얻을 것이며","reference":"레위기 7:8","category":"$undefined"},{"id":"2889","book":"레위기","book_name":"레위기","chapter":7,"verse":9,"text":"무릇 화덕에 구운 소제물과 솥에나 번철에 만든 소제물은 그 드린 제사장에게로 돌아갈 것이니","reference":"레위기 7:9","category":"$undefined"},{"id":"2890","book":"레위기","book_name":"레위기","chapter":7,"verse":10,"text":"무릇 소제물은 기름 섞은 것이나 마른 것이나 아론의 모든 자손이 평균히 분배할 것이니라","reference":"레위기 7:10","category":"$undefined"},{"id":"2891","book":"레위기","book_name":"레위기","chapter":7,"verse":11,"text":"여호와께 드릴 화목제 희생의 규례는 이러하니라","reference":"레위기 7:11","category":"$undefined"},{"id":"2892","book":"레위기","book_name":"레위기","chapter":7,"verse":12,"text":"만일 그것을 감사하므로 드리거든 기름 섞은 무교병과 기름 바른 무교병과 고운 가루에 기름 섞어 구운 과자를 그 감사 희생과 함께 드리고","reference":"레위기 7:12","category":"$undefined"},{"id":"2893","book":"레위기","book_name":"레위기","chapter":7,"verse":13,"text":"또 유교병을 화목제의 감사 희생과 함께 그 예물에 드리되","reference":"레위기 7:13","category":"$undefined"},{"id":"2894","book":"레위기","book_name":"레위기","chapter":7,"verse":14,"text":"그 전체의 예물 중에서 하나씩 여호와께 거제로 드리고 그것을 화목제의 피를 뿌린 제사장들에게로 돌릴지니라 !","reference":"레위기 7:14","category":"$undefined"},{"id":"2895","book":"레위기","book_name":"레위기","chapter":7,"verse":15,"text":"감사함으로 드리는 화목제 희생의 고기는 드리는 그 날에 먹을 것이요, 조금이라도 이튿날 아침까지 두지 말 것이니라","reference":"레위기 7:15","category":"$undefined"},{"id":"2896","book":"레위기","book_name":"레위기","chapter":7,"verse":16,"text":"그러나 그 희생의 예물이 서원이나 자원의 예물이면 그 희생을 드린 날에 먹을 것이요, 그 남은 것은 이튿날에도 먹되","reference":"레위기 7:16","category":"$undefined"},{"id":"2897","book":"레위기","book_name":"레위기","chapter":7,"verse":17,"text":"그 희생의 고기가 제 삼일까지 남았으면 불사를지니","reference":"레위기 7:17","category":"$undefined"},{"id":"2898","book":"레위기","book_name":"레위기","chapter":7,"verse":18,"text":"만일 그 화목제 희생의 고기를 제 삼일에 조금이라도 먹으면 그 제사는 열납되지 않을 것이라 드린 자에게도 예물답게 못되고 도리어 가증한 것이 될 것이며 그것을 먹는 자는 죄를 당하리라","reference":"레위기 7:18","category":"$undefined"},{"id":"2899","book":"레위기","book_name":"레위기","chapter":7,"verse":19,"text":"그 고기가 부정한 물건에 접촉되었으면 먹지 말고 불사를 것이라 그 고기는 깨끗한 자만 먹을 것이니","reference":"레위기 7:19","category":"$undefined"},{"id":"2900","book":"레위기","book_name":"레위기","chapter":7,"verse":20,"text":"만일 몸이 부정한 자가 여호와께 속한 화목제 희생의 고기를 먹으면 그 사람은 자기 백성 중에서 끊쳐질 것이요","reference":"레위기 7:20","category":"$undefined"},{"id":"2901","book":"레위기","book_name":"레위기","chapter":7,"verse":21,"text":"만일 누구든지 부정한 것 곧 사람의 부정이나 부정한 짐승이나 부정하고 가증한 아무 물건이든지 만지고 여호와께 속한 화목제 희생의 고기를 먹으면 그 사람도 자기 백성 중에서 끊쳐지리라 !","reference":"레위기 7:21","category":"$undefined"},{"id":"2902","book":"레위기","book_name":"레위기","chapter":7,"verse":22,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 7:22","category":"$undefined"},{"id":"2903","book":"레위기","book_name":"레위기","chapter":7,"verse":23,"text":"이스라엘 자손에게 고하여 이르라 너희는 소나 양이나 염소의 기름을 먹지 말 것이요","reference":"레위기 7:23","category":"$undefined"},{"id":"2904","book":"레위기","book_name":"레위기","chapter":7,"verse":24,"text":"스스로 죽은 것의 기름이나 짐승에게 찢긴 것의 기름은 달리는 쓰려니와 결단코 먹지 말지니라","reference":"레위기 7:24","category":"$undefined"},{"id":"2905","book":"레위기","book_name":"레위기","chapter":7,"verse":25,"text":"사람이 여호와께 화제로 드리는 희생의 기름을 먹으면 그 먹는 자는 자기 백성 중에서 끊쳐지리라 !","reference":"레위기 7:25","category":"$undefined"},{"id":"2906","book":"레위기","book_name":"레위기","chapter":7,"verse":26,"text":"너희의 사는 모든 곳에서 무슨 피든지 새나 짐승의 피를 먹지 말라 !","reference":"레위기 7:26","category":"$undefined"},{"id":"2907","book":"레위기","book_name":"레위기","chapter":7,"verse":27,"text":"무슨 피든지 먹는 사람이 있으면 그 사람은 다 자기 백성 중에서 끊쳐지리라 !","reference":"레위기 7:27","category":"$undefined"},{"id":"2908","book":"레위기","book_name":"레위기","chapter":7,"verse":28,"text":"여호와께서 모세에게 일러 가라사대","reference":"레위기 7:28","category":"$undefined"},{"id":"2909","book":"레위기","book_name":"레위기","chapter":7,"verse":29,"text":"이스라엘 자손에게 고하여 이르라 화목제의 희생을 여호와께 드리려는 자는 그 화목제 희생 중에서 그 예물을 취하여 여호와께 가져오되","reference":"레위기 7:29","category":"$undefined"},{"id":"2910","book":"레위기","book_name":"레위기","chapter":7,"verse":30,"text":"여호와의 화제는 그 사람이 자기 손으로 가져올지니 곧 그 제물의 기름과 가슴을 가져올 것이요 제사장은 그 가슴을 여호와 앞에 흔들어 요제를 삼고","reference":"레위기 7:30","category":"$undefined"},{"id":"2911","book":"레위기","book_name":"레위기","chapter":7,"verse":31,"text":"그 기름은 단 위에 불사를 것이며 가슴은 아론과 그 자손들에게 돌릴 것이며","reference":"레위기 7:31","category":"$undefined"},{"id":"2912","book":"레위기","book_name":"레위기","chapter":7,"verse":32,"text":"또 너희는 그 화목제 희생의 우편 뒷다리를 제사장에게 주어 거제를 삼을지니","reference":"레위기 7:32","category":"$undefined"},{"id":"2913","book":"레위기","book_name":"레위기","chapter":7,"verse":33,"text":"아론의 자손 중 화목제 희생의 피와 기름을 드리는 자가 그 우편 뒷다리를 자기의 소득으로 삼을 것이라","reference":"레위기 7:33","category":"$undefined"},{"id":"2914","book":"레위기","book_name":"레위기","chapter":7,"verse":34,"text":"내가 이스라엘 자손의 화목제 중에서 그 흔든 가슴과 든 뒷다리를 취하여 제사장 아론과 그 자손에게 주었나니 이는 이스라엘 자손에게 받을 영원한 소득이니라","reference":"레위기 7:34","category":"$undefined"},{"id":"2915","book":"레위기","book_name":"레위기","chapter":7,"verse":35,"text":"이는 여호와의 화제 중에서 아론에게 돌릴 것과 그 자손에게 돌릴 것이니 그들을 세워 여호와의 제사장의 직분을 행하게 한 날","reference":"레위기 7:35","category":"$undefined"},{"id":"2916","book":"레위기","book_name":"레위기","chapter":7,"verse":36,"text":"곧 그들에게 기름 부은 날에 여호와께서 명하사 이스라엘 자손 중에서 그들에게 돌리게 하신 것이라 대대로 영원히 받을 소득이니라","reference":"레위기 7:36","category":"$undefined"},{"id":"2917","book":"레위기","book_name":"레위기","chapter":7,"verse":37,"text":"이는 번제와, 소제와, 속죄제와, 속건제와, 위임제와, 화목제의 규례라","reference":"레위기 7:37","category":"$undefined"},{"id":"2918","book":"레위기","book_name":"레위기","chapter":7,"verse":38,"text":"여호와께서 시내 광야에서 이스라엘 자손에게 그 예물을 여호와께 드리라 명하신 날에 시내산에서 이같이 모세에게 명하셨더라","reference":"레위기 7:38","category":"$undefined"}],"bookSlug":"leviticus"}]
