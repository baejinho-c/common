2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":14,"verses":[{"id":"25555","book":"누가복음","book_name":"누가복음","chapter":14,"verse":1,"text":"안식일에 예수께서 바리새인의 한 두령의 집에 떡 잡수시러 들어가시니 저희가 엿보고 있더라","reference":"누가복음 14:1","category":"$undefined"},{"id":"25556","book":"누가복음","book_name":"누가복음","chapter":14,"verse":2,"text":"주의 앞에 고창병 든 한 사람이 있는지라","reference":"누가복음 14:2","category":"$undefined"},{"id":"25557","book":"누가복음","book_name":"누가복음","chapter":14,"verse":3,"text":"예수께서 대답하여 율법사들과 바리새인들에게 일러 가라사대 안식일에 병 고쳐 주는 것이 합당하냐 ? 아니하냐 ?","reference":"누가복음 14:3","category":"$undefined"},{"id":"25558","book":"누가복음","book_name":"누가복음","chapter":14,"verse":4,"text":"저희가 잠잠하거늘 예수께서 그 사람을 데려다가 고쳐 보내시고","reference":"누가복음 14:4","category":"$undefined"},{"id":"25559","book":"누가복음","book_name":"누가복음","chapter":14,"verse":5,"text":"또 저희에게 이르시되 `너희 중에 누가 그 아들이나 소나 우물에 빠졌으면 안식일에라도 곧 끌어내지 않겠느냐 ?' 하시니","reference":"누가복음 14:5","category":"$undefined"},{"id":"25560","book":"누가복음","book_name":"누가복음","chapter":14,"verse":6,"text":"저희가 이에 대하여 대답지 못하니라","reference":"누가복음 14:6","category":"$undefined"},{"id":"25561","book":"누가복음","book_name":"누가복음","chapter":14,"verse":7,"text":"청함을 받은 사람들의 상좌 택함을 보시고 저희에게 비유로 말씀하여 가라사대","reference":"누가복음 14:7","category":"$undefined"},{"id":"25562","book":"누가복음","book_name":"누가복음","chapter":14,"verse":8,"text":"`네가 누구에게나 혼인 잔치에 청함을 받았을 때에 상좌에 앉지 말라 그렇지 않으면 너보다 더 높은 사람이 청함을 받은 경우에","reference":"누가복음 14:8","category":"$undefined"},{"id":"25563","book":"누가복음","book_name":"누가복음","chapter":14,"verse":9,"text":"너와 저를 청한 자가 와서 너더러 이 사람에게 자리를 내어 주라 하리니 그 때에 네가 부끄러워 말석으로 가게 되리라","reference":"누가복음 14:9","category":"$undefined"},{"id":"25564","book":"누가복음","book_name":"누가복음","chapter":14,"verse":10,"text":"청함을 받았을 때에 차라리 가서 말석에 앉으라 그러면 너를 청한자가 와서 너더러 벗이여 올라 앉으라 하리니 그 때에야 함께 앉은 모든 사람 앞에 영광이 있으리라","reference":"누가복음 14:10","category":"$undefined"},{"id":"25565","book":"누가복음","book_name":"누가복음","chapter":14,"verse":11,"text":"무릇 자기를 높이는 자는 낮아지고 자기를 낮추는 자는 높아지리라","reference":"누가복음 14:11","category":"$undefined"},{"id":"25566","book":"누가복음","book_name":"누가복음","chapter":14,"verse":12,"text":"또 자기를 청한 자에게 이르시되 네가 점심이나 저녁이나 베풀거든 벗이나 형제나 친척이나 부한 이웃을 청하지 말라 두렵건대 그 사람들이 너를 도로 청하여 네게 갚음이 될까 하라","reference":"누가복음 14:12","category":"$undefined"},{"id":"25567","book":"누가복음","book_name":"누가복음","chapter":14,"verse":13,"text":"잔치를 배설하거든 차라리 가난한 자들과 병신들과 저는 자들과 소경들을 청하라","reference":"누가복음 14:13","category":"$undefined"},{"id":"25568","book":"누가복음","book_name":"누가복음","chapter":14,"verse":14,"text":"그리하면 저희가 갚을 것이 없는고로 네게 복이 되리니 이는 의인들의 부활 시에 네가 갚음을 받겠음이니라' 하시더라","reference":"누가복음 14:14","category":"$undefined"},{"id":"25569","book":"누가복음","book_name":"누가복음","chapter":14,"verse":15,"text":"함께 먹는 사람 중에 하나가 이 말을 듣고 이르되 `무릇 하나님의 나라에서 떡을 먹는 자는 복되도다' 하니","reference":"누가복음 14:15","category":"$undefined"},{"id":"25570","book":"누가복음","book_name":"누가복음","chapter":14,"verse":16,"text":"이르시되 `어떤 사람이 큰 잔치를 배설하고 많은 사람을 청하였더니","reference":"누가복음 14:16","category":"$undefined"},{"id":"25571","book":"누가복음","book_name":"누가복음","chapter":14,"verse":17,"text":"잔치할 시간에 그 청하였던 자들에게 종을 보내어 가로되 오소서 모든 것이 준비되었나이다 하매","reference":"누가복음 14:17","category":"$undefined"},{"id":"25572","book":"누가복음","book_name":"누가복음","chapter":14,"verse":18,"text":"다 일치하게 사양하여 하나는 가로되 나는 밭을 샀으매 불가불 나가 보아야 하겠으니 청컨대 나를 용서하도록 하라 하고","reference":"누가복음 14:18","category":"$undefined"},{"id":"25573","book":"누가복음","book_name":"누가복음","chapter":14,"verse":19,"text":"또 하나는 가로되 나는 소 다섯겨리를 샀으매 시험하러 가니 청컨대 나를 용서하도록 하라 하고","reference":"누가복음 14:19","category":"$undefined"},{"id":"25574","book":"누가복음","book_name":"누가복음","chapter":14,"verse":20,"text":"또 하나는 가로되 나는 장가 들었으니 그러므로 가지 못하겠노라 하는지라","reference":"누가복음 14:20","category":"$undefined"},{"id":"25575","book":"누가복음","book_name":"누가복음","chapter":14,"verse":21,"text":"종이 돌아와 주인에게 그대로 고하니 이에 집주인이 노하여 그 종에게 이르되 빨리 시내의 거리와 골목으로 나가서 가난한 자들과 병신들과 소경들과 저는 자들을 데려오라 하니라","reference":"누가복음 14:21","category":"$undefined"},{"id":"25576","book":"누가복음","book_name":"누가복음","chapter":14,"verse":22,"text":"종이 가로되 주인이여 명하신대로 하였으되 오히려 자리가 있나이다","reference":"누가복음 14:22","category":"$undefined"},{"id":"25577","book":"누가복음","book_name":"누가복음","chapter":14,"verse":23,"text":"주인이 종에게 이르되 길과 산울 가로 나가서 사람을 강권하여 데려다가 내 집을 채우라","reference":"누가복음 14:23","category":"$undefined"},{"id":"25578","book":"누가복음","book_name":"누가복음","chapter":14,"verse":24,"text":"내가 너희에게 말하노니 전에 청하였던 그 사람은 하나도 내 잔치를 맛보지 못하리라 하였다' 하시니라","reference":"누가복음 14:24","category":"$undefined"},{"id":"25579","book":"누가복음","book_name":"누가복음","chapter":14,"verse":25,"text":"허다한 무리가 함께 갈새 예수께서 돌이키사 이르시되","reference":"누가복음 14:25","category":"$undefined"},{"id":"25580","book":"누가복음","book_name":"누가복음","chapter":14,"verse":26,"text":"`무릇 내게 오는 자가 자기 부모와 처자와 형제와 자매와 및 자기 목숨까지 미워하지 아니하면 능히 나의 제자가 되지 못하고","reference":"누가복음 14:26","category":"$undefined"},{"id":"25581","book":"누가복음","book_name":"누가복음","chapter":14,"verse":27,"text":"누구든지 자기 십자가를 지고 나를 좇지 않는 자도 능히 나의 제자가 되지 못하리라","reference":"누가복음 14:27","category":"$undefined"},{"id":"25582","book":"누가복음","book_name":"누가복음","chapter":14,"verse":28,"text":"너희 중에 누가 망대를 세우고자 할진대 자기의 가진 것이 준공하기까지에 족할는지 먼저 앉아 그 비용을 예산하지 아니하겠느냐","reference":"누가복음 14:28","category":"$undefined"},{"id":"25583","book":"누가복음","book_name":"누가복음","chapter":14,"verse":29,"text":"그렇게 아니하여 그 기초만 쌓고 능히 이루지 못하면 보는 자가 다 비웃어","reference":"누가복음 14:29","category":"$undefined"},{"id":"25584","book":"누가복음","book_name":"누가복음","chapter":14,"verse":30,"text":"가로되 이 사람이 역사를 시작하고 능히 이루지 못하였다 하리라","reference":"누가복음 14:30","category":"$undefined"},{"id":"25585","book":"누가복음","book_name":"누가복음","chapter":14,"verse":31,"text":"또 어느 임금이 다른 임금과 싸우러 갈 때에 먼저 앉아 일만으로서 저 이만을 가지고 오는 자를 대적할 수 있을까 헤아리지 아니하겠느냐","reference":"누가복음 14:31","category":"$undefined"},{"id":"25586","book":"누가복음","book_name":"누가복음","chapter":14,"verse":32,"text":"만일 못할터이면 저가 아직 멀리 있을 동안에 사신을 보내어 화친을 청할지니라","reference":"누가복음 14:32","category":"$undefined"},{"id":"25587","book":"누가복음","book_name":"누가복음","chapter":14,"verse":33,"text":"이와 같이 너희 중에 누구든지 자기의 모든 소유를 버리지 아니하면 능히 내 제자가 되지 못하리라","reference":"누가복음 14:33","category":"$undefined"},{"id":"25588","book":"누가복음","book_name":"누가복음","chapter":14,"verse":34,"text":"소금이 좋은 것이나 소금도 만일 그 맛을 잃었으면 무엇으로 짜게 하리요","reference":"누가복음 14:34","category":"$undefined"},{"id":"25589","book":"누가복음","book_name":"누가복음","chapter":14,"verse":35,"text":"땅에도 거름에도 쓸데 없어 내어버리느니라 들을 귀가 있는 자는 들을지어다 !' 하시니라","reference":"누가복음 14:35","category":"$undefined"}],"bookSlug":"luke"}]
