2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":17,"verses":[{"id":"25653","book":"누가복음","book_name":"누가복음","chapter":17,"verse":1,"text":"예수께서 제자들에게 이르시되 `실족케 하는 것이 없을 수는 없으나 있게 하는 자에게는 화로다","reference":"누가복음 17:1","category":"$undefined"},{"id":"25654","book":"누가복음","book_name":"누가복음","chapter":17,"verse":2,"text":"저가 이 작은 자 중에 하나를 실족케 할진대 차라리 연자맷돌을 그 목에 매이우고 바다에 던지우는 것이 나으리라","reference":"누가복음 17:2","category":"$undefined"},{"id":"25655","book":"누가복음","book_name":"누가복음","chapter":17,"verse":3,"text":"너희는 스스로 조심하라 만일 네 형제가 죄를 범하거든 경계하고 회개하거든 용서하라","reference":"누가복음 17:3","category":"$undefined"},{"id":"25656","book":"누가복음","book_name":"누가복음","chapter":17,"verse":4,"text":"만일 하루 일곱 번이라도 네게 죄를 얻고 일곱 번 네게 돌아와 내가 회개하노라 하거든 너는 용서하라' 하시더라","reference":"누가복음 17:4","category":"$undefined"},{"id":"25657","book":"누가복음","book_name":"누가복음","chapter":17,"verse":5,"text":"사도들이 주께 여짜오되 `우리에게 믿음을 더하소서 !' 하니","reference":"누가복음 17:5","category":"$undefined"},{"id":"25658","book":"누가복음","book_name":"누가복음","chapter":17,"verse":6,"text":"주께서 가라사대 `너희에게 겨자씨 한 알만한 믿음이 있었더면 이 뽕나무더러 뿌리가 뽑혀 바다에 심기우라 하였을 것이요 그것이 너희에게 순종하였으리라","reference":"누가복음 17:6","category":"$undefined"},{"id":"25659","book":"누가복음","book_name":"누가복음","chapter":17,"verse":7,"text":"너희 중에 뉘게 밭을 갈거나 양을 치거나 하는 종이 있어 밭에서 돌아오면 저더러 곧 와 앉아서 먹으라 할 자가 있느냐 ?","reference":"누가복음 17:7","category":"$undefined"},{"id":"25660","book":"누가복음","book_name":"누가복음","chapter":17,"verse":8,"text":"도리어 저더러 내 먹을 것을 예비하고 띠를 띠고 나의 먹고 마시는 동안에 수종들고 너는 그 후에 먹고 마시라 하지 않겠느냐 ?","reference":"누가복음 17:8","category":"$undefined"},{"id":"25661","book":"누가복음","book_name":"누가복음","chapter":17,"verse":9,"text":"명한 대로 하였다고 종에게 사례하겠느냐 ?","reference":"누가복음 17:9","category":"$undefined"},{"id":"25662","book":"누가복음","book_name":"누가복음","chapter":17,"verse":10,"text":"이와 같이 너희도 명령받은 것을 행한 후에 이르기를 우리는 무익한 종이라 우리의 하여야 할 일을 한 것뿐이라 할지니라'","reference":"누가복음 17:10","category":"$undefined"},{"id":"25663","book":"누가복음","book_name":"누가복음","chapter":17,"verse":11,"text":"예수께서 예루살렘으로 가실 때에 사마리아와 갈릴리 사이로 지나가시다가","reference":"누가복음 17:11","category":"$undefined"},{"id":"25664","book":"누가복음","book_name":"누가복음","chapter":17,"verse":12,"text":"한 촌에 들어가시니 문둥병자 열 명이 예수를 만나 멀리 서서","reference":"누가복음 17:12","category":"$undefined"},{"id":"25665","book":"누가복음","book_name":"누가복음","chapter":17,"verse":13,"text":"소리를 높여 가로되 `예수 선생님이여, 우리를 긍휼히 여기소서' 하거늘","reference":"누가복음 17:13","category":"$undefined"},{"id":"25666","book":"누가복음","book_name":"누가복음","chapter":17,"verse":14,"text":"보시고 가라사대 `가서 제사장들에게 너희 몸을 보이라' 하셨더니 저희가 가다가 깨끗함을 받은지라","reference":"누가복음 17:14","category":"$undefined"},{"id":"25667","book":"누가복음","book_name":"누가복음","chapter":17,"verse":15,"text":"그 중에 하나가 자기의 나은 것을 보고 큰 소리로 하나님께 영광을 돌리며 돌아와","reference":"누가복음 17:15","category":"$undefined"},{"id":"25668","book":"누가복음","book_name":"누가복음","chapter":17,"verse":16,"text":"예수의 발 아래 엎드리어 사례하니 저는 사마리아인이라","reference":"누가복음 17:16","category":"$undefined"},{"id":"25669","book":"누가복음","book_name":"누가복음","chapter":17,"verse":17,"text":"예수께서 대답하여 가라사대 `열 사람이 다 깨끗함을 받지 아니하였느냐 ? 그 아홉은 어디 있느냐 ?","reference":"누가복음 17:17","category":"$undefined"},{"id":"25670","book":"누가복음","book_name":"누가복음","chapter":17,"verse":18,"text":"이 이방인 외에는 하나님께 영광을 돌리러 돌아온 자가 없느냐 ?' 하시고","reference":"누가복음 17:18","category":"$undefined"},{"id":"25671","book":"누가복음","book_name":"누가복음","chapter":17,"verse":19,"text":"그에게 이르시되 `일어나 가라 네 믿음이 너를 구원하였느니라 !' 하시더라","reference":"누가복음 17:19","category":"$undefined"},{"id":"25672","book":"누가복음","book_name":"누가복음","chapter":17,"verse":20,"text":"바리새인들이 `하나님의 나라가 어느 때에 임하나이까 ?' 묻거늘 예수께서 대답하여 가라사대 `하나님의 나라는 볼 수 있게 임하는 것이 아니요","reference":"누가복음 17:20","category":"$undefined"},{"id":"25673","book":"누가복음","book_name":"누가복음","chapter":17,"verse":21,"text":"또 여기 있다 저기 있다고도 못하리니 하나님의 나라는 너희 안에 있느니라 !'","reference":"누가복음 17:21","category":"$undefined"},{"id":"25674","book":"누가복음","book_name":"누가복음","chapter":17,"verse":22,"text":"또 제자들에게 이르시되 `때가 이르리니 너희가 인자의 날 하루를 보고자 하되 보지 못하리라","reference":"누가복음 17:22","category":"$undefined"},{"id":"25675","book":"누가복음","book_name":"누가복음","chapter":17,"verse":23,"text":"사람이 너희에게 말하되 보라 저기 있다 보라 여기 있다 하리라 그러나 너희는 가지도 말고 좇지도 말라","reference":"누가복음 17:23","category":"$undefined"},{"id":"25676","book":"누가복음","book_name":"누가복음","chapter":17,"verse":24,"text":"번개가 하늘 아래 이편에서 번뜻하여 하늘 아래 저편까지 비췸같이 인자도 자기 날에 그러하리라","reference":"누가복음 17:24","category":"$undefined"},{"id":"25677","book":"누가복음","book_name":"누가복음","chapter":17,"verse":25,"text":"그러나 그가 먼저 많은 고난을 받으며 이 세대에게 버린 바 되어야 할지니라","reference":"누가복음 17:25","category":"$undefined"},{"id":"25678","book":"누가복음","book_name":"누가복음","chapter":17,"verse":26,"text":"노아의 때에 된 것과 같이 인자의 때에도 그러하리라","reference":"누가복음 17:26","category":"$undefined"},{"id":"25679","book":"누가복음","book_name":"누가복음","chapter":17,"verse":27,"text":"노아가 방주에 들어가던 날까지 사람들이 먹고 마시고 장가 들고 시집 가더니 홍수가 나서 저희를 다 멸하였으며","reference":"누가복음 17:27","category":"$undefined"},{"id":"25680","book":"누가복음","book_name":"누가복음","chapter":17,"verse":28,"text":"또 롯의 때와 같으리니 사람들이 먹고 마시고 사고 팔고 심고 집을 짓더니","reference":"누가복음 17:28","category":"$undefined"},{"id":"25681","book":"누가복음","book_name":"누가복음","chapter":17,"verse":29,"text":"롯이 소돔에서 나가던 날에 하늘로서 불과 유황이 비오듯 하여 저희를 멸하였느니라","reference":"누가복음 17:29","category":"$undefined"},{"id":"25682","book":"누가복음","book_name":"누가복음","chapter":17,"verse":30,"text":"인자의 나타나는 날에도 이러하리라","reference":"누가복음 17:30","category":"$undefined"},{"id":"25683","book":"누가복음","book_name":"누가복음","chapter":17,"verse":31,"text":"그 날에 만일 사람이 지붕 위에 있고 그 세간이 집 안에 있으면 그것을 가지러 내려 오지 말 것이요 밭에 있는 자도 이와 같이 뒤로 돌이키지 말 것이니라","reference":"누가복음 17:31","category":"$undefined"},{"id":"25684","book":"누가복음","book_name":"누가복음","chapter":17,"verse":32,"text":"롯의 처를 생각하라 !","reference":"누가복음 17:32","category":"$undefined"},{"id":"25685","book":"누가복음","book_name":"누가복음","chapter":17,"verse":33,"text":"무릇 자기 목숨을 보존하고자 하는 자는 잃을 것이요 잃는 자는 살리리라","reference":"누가복음 17:33","category":"$undefined"},{"id":"25686","book":"누가복음","book_name":"누가복음","chapter":17,"verse":34,"text":"내가 너희에게 이르노니 그 밤에 두 남자가 한 자리에 누워 있으매 하나는 데려감을 당하고 하나는 버려둠을 당할 것이요","reference":"누가복음 17:34","category":"$undefined"},{"id":"25687","book":"누가복음","book_name":"누가복음","chapter":17,"verse":35,"text":"두 여자가 함께 매를 갈고 있으매 하나는 데려감을 당하고 하나는 버려둠을 당할 것이니라'","reference":"누가복음 17:35","category":"$undefined"},{"id":"25688","book":"누가복음","book_name":"누가복음","chapter":17,"verse":36,"text":"(없 음)","reference":"누가복음 17:36","category":"$undefined"},{"id":"25689","book":"누가복음","book_name":"누가복음","chapter":17,"verse":37,"text":"저희가 대답하여 가로되 `주여 어디오니이까 ?' 가라사대 `주검 있는 곳에는 독수리가 모이느니라 !' 하시니라","reference":"누가복음 17:37","category":"$undefined"}],"bookSlug":"luke"}]
