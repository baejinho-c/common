2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":18,"verses":[{"id":"25690","book":"누가복음","book_name":"누가복음","chapter":18,"verse":1,"text":"항상 기도하고 낙망치 말아야 될 것을 저희에게 비유로 하여","reference":"누가복음 18:1","category":"$undefined"},{"id":"25691","book":"누가복음","book_name":"누가복음","chapter":18,"verse":2,"text":"가라사대 `어떤 도시에 하나님을 두려워 아니하고 사람을 무시하는 한 재판관이 있는데","reference":"누가복음 18:2","category":"$undefined"},{"id":"25692","book":"누가복음","book_name":"누가복음","chapter":18,"verse":3,"text":"그 도시에 한 과부가 있어 자주 그에게 가서 내 원수에 대한 나의 원한을 풀어 주소서 하되","reference":"누가복음 18:3","category":"$undefined"},{"id":"25693","book":"누가복음","book_name":"누가복음","chapter":18,"verse":4,"text":"그가 얼마 동안 듣지 아니하다가 후에 속으로 생각하되 내가 하나님을 두려워 아니하고 사람을 무시하나","reference":"누가복음 18:4","category":"$undefined"},{"id":"25694","book":"누가복음","book_name":"누가복음","chapter":18,"verse":5,"text":"이 과부가 나를 번거롭게 하니 내가 그 원한을 풀어 주리라 그렇지 않으면 늘 와서 나를 괴롭게 하리라 하였느니라'","reference":"누가복음 18:5","category":"$undefined"},{"id":"25695","book":"누가복음","book_name":"누가복음","chapter":18,"verse":6,"text":"주께서 또 가라사대 `불의한 재판관의 말한 것을 들으라","reference":"누가복음 18:6","category":"$undefined"},{"id":"25696","book":"누가복음","book_name":"누가복음","chapter":18,"verse":7,"text":"하물며 하나님께서 그 밤낮 부르짖는 택하신 자들의 원한을 풀어 주지 아니하시겠느냐 저희에게 오래 참으시겠느냐","reference":"누가복음 18:7","category":"$undefined"},{"id":"25697","book":"누가복음","book_name":"누가복음","chapter":18,"verse":8,"text":"내가 너희에게 이르노니 속히 그 원한을 풀어 주시리라 그러나 인자가 올 때에 세상에서 믿음을 보겠느냐 하시니라","reference":"누가복음 18:8","category":"$undefined"},{"id":"25698","book":"누가복음","book_name":"누가복음","chapter":18,"verse":9,"text":"또 자기를 의롭다고 믿고 다른 사람을 멸시하는 자들에게 이 비유로 말씀하시되","reference":"누가복음 18:9","category":"$undefined"},{"id":"25699","book":"누가복음","book_name":"누가복음","chapter":18,"verse":10,"text":"두 사람이 기도하러 성전에 올라가니 하나는 바리새인이요 하나는 세리라","reference":"누가복음 18:10","category":"$undefined"},{"id":"25700","book":"누가복음","book_name":"누가복음","chapter":18,"verse":11,"text":"바리새인은 서서 따로 기도하여 가로되 하나님이여 ! 나는 다른 사람들 곧 토색,불의,간음을 하는 자들과 같지 아니하고 이 세리와도 같지 아니함을 감사하나이다","reference":"누가복음 18:11","category":"$undefined"},{"id":"25701","book":"누가복음","book_name":"누가복음","chapter":18,"verse":12,"text":"나는 이레에 두 번씩 금식하고 또 소득의 십일조를 드리나이다 하고","reference":"누가복음 18:12","category":"$undefined"},{"id":"25702","book":"누가복음","book_name":"누가복음","chapter":18,"verse":13,"text":"세리는 멀리 서서 감히 눈을 들어 하늘을 우러러 보지도 못하고 다만 가슴을 치며 가로되 하나님이여 불쌍히 여기옵소서 나는 죄인이로소이다 하였느니라","reference":"누가복음 18:13","category":"$undefined"},{"id":"25703","book":"누가복음","book_name":"누가복음","chapter":18,"verse":14,"text":"내가 너희에게 이르노니 이 사람이 저보다 의롭다 하심을 받고 집에 내려 갔느니라 무릇 자기를 높이는 자는 낮아지고 자기를 낮추는 자는 높아지리라' 하시니라","reference":"누가복음 18:14","category":"$undefined"},{"id":"25704","book":"누가복음","book_name":"누가복음","chapter":18,"verse":15,"text":"사람들이 예수의 만져주심을 바라고 자기 어린 아기를 데리고 오매 제자들이 보고 꾸짖거늘","reference":"누가복음 18:15","category":"$undefined"},{"id":"25705","book":"누가복음","book_name":"누가복음","chapter":18,"verse":16,"text":"예수께서 그 어린 아이들을 불러 가까이 하시고 이르시되 `어린 아이들이 내게 오는 것을 용납하고 금하지 말라 하나님의 나라가 이런 자의 것이니라","reference":"누가복음 18:16","category":"$undefined"},{"id":"25706","book":"누가복음","book_name":"누가복음","chapter":18,"verse":17,"text":"내가 진실로 너희에게 이르노니 누구든지 하나님의 나라를 어린 아이와 같이 받들지 않는 자는 결단코 들어가지 못하리라' 하시니라","reference":"누가복음 18:17","category":"$undefined"},{"id":"25707","book":"누가복음","book_name":"누가복음","chapter":18,"verse":18,"text":"어떤 관원이 물어 가로되 `선한 선생님이여, 내가 무엇을 하여야 영생을 얻으리이까 ?'","reference":"누가복음 18:18","category":"$undefined"},{"id":"25708","book":"누가복음","book_name":"누가복음","chapter":18,"verse":19,"text":"예수께서 이르시되 `네가 어찌하여 나를 선하다 일컫느냐 ? 하나님 한분 외에는 선한 이가 없느니라","reference":"누가복음 18:19","category":"$undefined"},{"id":"25709","book":"누가복음","book_name":"누가복음","chapter":18,"verse":20,"text":"네가 계명을 아나니 간음하지 말라, 살인하지 말라, 도적질하지 말라, 거짓 증거하지 말라, 네 부모를 공경하라 하였느니라'","reference":"누가복음 18:20","category":"$undefined"},{"id":"25710","book":"누가복음","book_name":"누가복음","chapter":18,"verse":21,"text":"여짜오되 `이것은 내가 어려서부터 다 지키었나이다'","reference":"누가복음 18:21","category":"$undefined"},{"id":"25711","book":"누가복음","book_name":"누가복음","chapter":18,"verse":22,"text":"예수께서 이 말을 들으시고 이르시되 `네가 오히려 한 가지 부족한 것이 있으니 네게 있는 것을 다 팔아 가난한 자들을 나눠 주라 그리하면 하늘에서 보화가 네게 있으리라 그리고 와서 나를 좇으라' 하시니","reference":"누가복음 18:22","category":"$undefined"},{"id":"25712","book":"누가복음","book_name":"누가복음","chapter":18,"verse":23,"text":"그 사람이 큰 부자인 고로 이 말씀을 듣고 심히 근심하더라","reference":"누가복음 18:23","category":"$undefined"},{"id":"25713","book":"누가복음","book_name":"누가복음","chapter":18,"verse":24,"text":"예수께서 저를 보시고 가라사대 `재산이 있는 자는 하나님의 나라에 들어가기가 어떻게 어려운지","reference":"누가복음 18:24","category":"$undefined"},{"id":"25714","book":"누가복음","book_name":"누가복음","chapter":18,"verse":25,"text":"약대가 바늘귀로 들어가는 것이 부자가 하나님의 나라에 들어가는 것보다 쉬우니라' 하신대","reference":"누가복음 18:25","category":"$undefined"},{"id":"25715","book":"누가복음","book_name":"누가복음","chapter":18,"verse":26,"text":"듣는 자들이 가로되 `그런즉 누가 구원을 얻을 수 있나이까 ?'","reference":"누가복음 18:26","category":"$undefined"},{"id":"25716","book":"누가복음","book_name":"누가복음","chapter":18,"verse":27,"text":"가라사대 `무릇 사람의 할 수 없는 것을 하나님은 하실 수 있느니라 !'","reference":"누가복음 18:27","category":"$undefined"},{"id":"25717","book":"누가복음","book_name":"누가복음","chapter":18,"verse":28,"text":"베드로가 여짜오되 `보옵소서, 우리가 우리의 것을 다 버리고 주를 좇았나이다'","reference":"누가복음 18:28","category":"$undefined"},{"id":"25718","book":"누가복음","book_name":"누가복음","chapter":18,"verse":29,"text":"이르시되 `내가 진실로 너희에게 이르노니 하나님의 나라를 위하여 집이나 아내나 형제나 부모나 자녀를 버린 자는","reference":"누가복음 18:29","category":"$undefined"},{"id":"25719","book":"누가복음","book_name":"누가복음","chapter":18,"verse":30,"text":"금세에 있어 여러 배를 받고 내세에 영생을 받지 못할 자가 없느니라' 하시니라","reference":"누가복음 18:30","category":"$undefined"},{"id":"25720","book":"누가복음","book_name":"누가복음","chapter":18,"verse":31,"text":"예수께서 열 두 제자를 데리시고 이르시되 `보라, 우리가 예루살렘으로 올라가노니 선지자들로 기록된 모든 것이 인자에게 응하리라","reference":"누가복음 18:31","category":"$undefined"},{"id":"25721","book":"누가복음","book_name":"누가복음","chapter":18,"verse":32,"text":"인자가 이방인들에게 넘기워 희롱을 받고 능욕을 받고 침 뱉음을 받겠으며","reference":"누가복음 18:32","category":"$undefined"},{"id":"25722","book":"누가복음","book_name":"누가복음","chapter":18,"verse":33,"text":"저희는 채찍질하고 죽일 것이니 저는 삼 일만에 살아나리라' 하시되","reference":"누가복음 18:33","category":"$undefined"},{"id":"25723","book":"누가복음","book_name":"누가복음","chapter":18,"verse":34,"text":"제자들이 이것을 하나도 깨닫지 못하였으니 그 말씀이 감취었으므로 저희가 그 이르신 바를 알지 못하였더라","reference":"누가복음 18:34","category":"$undefined"},{"id":"25724","book":"누가복음","book_name":"누가복음","chapter":18,"verse":35,"text":"여리고에 가까이 오실 때에 한 소경이 길 가에 앉아 구걸하다가","reference":"누가복음 18:35","category":"$undefined"},{"id":"25725","book":"누가복음","book_name":"누가복음","chapter":18,"verse":36,"text":"무리의 지남을 듣고 `이 무슨 일이냐 ?'고 물은대","reference":"누가복음 18:36","category":"$undefined"},{"id":"25726","book":"누가복음","book_name":"누가복음","chapter":18,"verse":37,"text":"저희가 `나사렛 예수께서 지나신다' 하니","reference":"누가복음 18:37","category":"$undefined"},{"id":"25727","book":"누가복음","book_name":"누가복음","chapter":18,"verse":38,"text":"소경이 외쳐 가로되 `다윗의 자손 예수여 ! 나를 불쌍히 여기소서' 하거늘","reference":"누가복음 18:38","category":"$undefined"},{"id":"25728","book":"누가복음","book_name":"누가복음","chapter":18,"verse":39,"text":"앞서 가는 자들이 저를 꾸짖어 `잠잠하라' 하되 저가 더욱 심히 소리 질러 `다윗의 자손이여 ! 나를 불쌍히 여기소서' 하는지라","reference":"누가복음 18:39","category":"$undefined"},{"id":"25729","book":"누가복음","book_name":"누가복음","chapter":18,"verse":40,"text":"예수께서 머물러 서서 명하여 `데려오라' 하셨더니 저가 가까이 오매 물어 가라사대","reference":"누가복음 18:40","category":"$undefined"},{"id":"25730","book":"누가복음","book_name":"누가복음","chapter":18,"verse":41,"text":"`네게 무엇을 하여 주기를 원하느냐 ?' 가로되 `주여, 보기를 원하나이다'","reference":"누가복음 18:41","category":"$undefined"},{"id":"25731","book":"누가복음","book_name":"누가복음","chapter":18,"verse":42,"text":"예수께서 저에게 이르시되 `보아라, 네 믿음이 너를 구원하였느니라' 하시매","reference":"누가복음 18:42","category":"$undefined"},{"id":"25732","book":"누가복음","book_name":"누가복음","chapter":18,"verse":43,"text":"곧 보게 되어 하나님께 영광을 돌리며 예수를 좇으니 백성이 다 이를 보고 하나님을 찬양하니라","reference":"누가복음 18:43","category":"$undefined"}],"bookSlug":"luke"}]
