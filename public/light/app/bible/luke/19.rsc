2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":19,"verses":[{"id":"25733","book":"누가복음","book_name":"누가복음","chapter":19,"verse":1,"text":"예수께서 여리고로 들어 지나가시더라","reference":"누가복음 19:1","category":"$undefined"},{"id":"25734","book":"누가복음","book_name":"누가복음","chapter":19,"verse":2,"text":"삭개오라 이름하는 자가 있으니 세리장이요 또한 부자라","reference":"누가복음 19:2","category":"$undefined"},{"id":"25735","book":"누가복음","book_name":"누가복음","chapter":19,"verse":3,"text":"저가 예수께서 어떠한 사람인가 하여 보고자 하되 키가 작고 사람이 많아 할 수 없어","reference":"누가복음 19:3","category":"$undefined"},{"id":"25736","book":"누가복음","book_name":"누가복음","chapter":19,"verse":4,"text":"앞으로 달려가 보기 위하여 뽕나무에 올라가니 이는 예수께서 그리로 지나가시게 됨이러라","reference":"누가복음 19:4","category":"$undefined"},{"id":"25737","book":"누가복음","book_name":"누가복음","chapter":19,"verse":5,"text":"예수께서 그 곳에 이르사 우러러 보시고 이르시되 `삭개오야, 속히 내려오라 내가 오늘 네 집에 유하여야 하겠다' 하시니","reference":"누가복음 19:5","category":"$undefined"},{"id":"25738","book":"누가복음","book_name":"누가복음","chapter":19,"verse":6,"text":"급히 내려와 즐거워하며 영접하거늘","reference":"누가복음 19:6","category":"$undefined"},{"id":"25739","book":"누가복음","book_name":"누가복음","chapter":19,"verse":7,"text":"뭇사람이 보고 수군거려 가로되 `저가 죄인의 집에 유하러 들어갔도다' 하더라","reference":"누가복음 19:7","category":"$undefined"},{"id":"25740","book":"누가복음","book_name":"누가복음","chapter":19,"verse":8,"text":"삭개오가 서서 주께 여짜오되 `주여 보시옵소서 내 소유의 절반을 가난한 자들에게 주겠사오며 만일 뉘 것을 토색한 일이 있으면 사 배나 갚겠나이다'","reference":"누가복음 19:8","category":"$undefined"},{"id":"25741","book":"누가복음","book_name":"누가복음","chapter":19,"verse":9,"text":"예수께서 이르시되 `오늘 구원이 이 집에 이르렀으니 이 사람도 아브라함의 자손임이로다","reference":"누가복음 19:9","category":"$undefined"},{"id":"25742","book":"누가복음","book_name":"누가복음","chapter":19,"verse":10,"text":"인자의 온 것은 잃어버린 자를 찾아 구원하려 함이니라'","reference":"누가복음 19:10","category":"$undefined"},{"id":"25743","book":"누가복음","book_name":"누가복음","chapter":19,"verse":11,"text":"저희가 이 말씀을 듣고 있을 때에 비유를 더하여 말씀하시니 이는 자기가 예루살렘에 가까이 오셨고 저희는 하나님의 나라가 당장에 나타날 줄로 생각함이러라","reference":"누가복음 19:11","category":"$undefined"},{"id":"25744","book":"누가복음","book_name":"누가복음","chapter":19,"verse":12,"text":"가라사대 `어떤 귀인이 왕위를 받아 가지고 오려고 먼 나라로 갈때에","reference":"누가복음 19:12","category":"$undefined"},{"id":"25745","book":"누가복음","book_name":"누가복음","chapter":19,"verse":13,"text":"그 종 열을 불러 은 열 므나를 주며 이르되 내가 돌아오기까지 장사하라 하니라","reference":"누가복음 19:13","category":"$undefined"},{"id":"25746","book":"누가복음","book_name":"누가복음","chapter":19,"verse":14,"text":"그런데 그 백성이 저를 미워하여 사자를 뒤로 보내어 가로되 우리는 이 사람이 우리의 왕 됨을 원치 아니하노이다 하였더라","reference":"누가복음 19:14","category":"$undefined"},{"id":"25747","book":"누가복음","book_name":"누가복음","chapter":19,"verse":15,"text":"귀인이 왕위를 받아 가지고 돌아와서 은 준 종들의 각각 어떻게 장사한 것을 알고자 하여 저희를 부르니","reference":"누가복음 19:15","category":"$undefined"},{"id":"25748","book":"누가복음","book_name":"누가복음","chapter":19,"verse":16,"text":"그 첫째가 나아와 가로되 주여 주의 한 므나로 열 므나를 남겼나이다","reference":"누가복음 19:16","category":"$undefined"},{"id":"25749","book":"누가복음","book_name":"누가복음","chapter":19,"verse":17,"text":"주인이 이르되 잘 하였다 착한 종이여 네가 지극히 작은 것에 충성하였으니 열 고을 권세를 차지하라 하고","reference":"누가복음 19:17","category":"$undefined"},{"id":"25750","book":"누가복음","book_name":"누가복음","chapter":19,"verse":18,"text":"그 둘째가 와서 가로되 주여 주의 한 므나로 다섯 므나를 만들었나이다","reference":"누가복음 19:18","category":"$undefined"},{"id":"25751","book":"누가복음","book_name":"누가복음","chapter":19,"verse":19,"text":"주인이 그에게도 이르되 너도 다섯 고을을 차지하라 하고","reference":"누가복음 19:19","category":"$undefined"},{"id":"25752","book":"누가복음","book_name":"누가복음","chapter":19,"verse":20,"text":"또 한 사람이 와서 가로되 주여 보소서 주의 한 므나가 여기 있나이다 내가 수건으로 싸 두었었나이다","reference":"누가복음 19:20","category":"$undefined"},{"id":"25753","book":"누가복음","book_name":"누가복음","chapter":19,"verse":21,"text":"이는 당신이 엄한 사람인 것을 내가 무서워함이라 당신은 두지 않은 것을 취하고 심지 않은 것을 거두나이다","reference":"누가복음 19:21","category":"$undefined"},{"id":"25754","book":"누가복음","book_name":"누가복음","chapter":19,"verse":22,"text":"주인이 이르되 악한 종아 내가 네 말로 너를 판단하노니 너는 내가 두지 않은 것을 취하고 심지 않은 것을 거두는 엄한 사람인 줄을 알았느냐","reference":"누가복음 19:22","category":"$undefined"},{"id":"25755","book":"누가복음","book_name":"누가복음","chapter":19,"verse":23,"text":"그러면 어찌하여 내 은을 은행에 두지 아니하였느냐 그리하였으면 내가 와서 그 변리까지 찾았으리라 하고","reference":"누가복음 19:23","category":"$undefined"},{"id":"25756","book":"누가복음","book_name":"누가복음","chapter":19,"verse":24,"text":"곁에 섰는 자들에게 이르되 그 한 므나를 빼앗아 열 므나 있는 자에게 주라 하니","reference":"누가복음 19:24","category":"$undefined"},{"id":"25757","book":"누가복음","book_name":"누가복음","chapter":19,"verse":25,"text":"저희가 가로되 주여 저에게 이미 열 므나가 있나이다","reference":"누가복음 19:25","category":"$undefined"},{"id":"25758","book":"누가복음","book_name":"누가복음","chapter":19,"verse":26,"text":"주인이 가로되 내가 너희에게 말하노니 무릇 있는 자는 받겠고 없는 자는 그 있는 것도 빼앗기리라","reference":"누가복음 19:26","category":"$undefined"},{"id":"25759","book":"누가복음","book_name":"누가복음","chapter":19,"verse":27,"text":"그리고 나의 왕 됨을 원치 아니하던 저 원수들을 이리로 끌어다가 내 앞에서 죽이라 하였느니라'","reference":"누가복음 19:27","category":"$undefined"},{"id":"25760","book":"누가복음","book_name":"누가복음","chapter":19,"verse":28,"text":"예수께서 이 말씀을 하시고 예루살렘을 향하여 앞서서 가시더라","reference":"누가복음 19:28","category":"$undefined"},{"id":"25761","book":"누가복음","book_name":"누가복음","chapter":19,"verse":29,"text":"감람원이라는 산의 벳바게와 베다니에 가까이 왔을 때에 제자 중 둘을 보내시며","reference":"누가복음 19:29","category":"$undefined"},{"id":"25762","book":"누가복음","book_name":"누가복음","chapter":19,"verse":30,"text":"이르시되 `너희 맞은편 마을로 가라 그리로 들어가면 아직 아무 사람도 타 보지 않은 나귀 새끼의 매여 있는 것을 보리니 풀어 끌고 오너라","reference":"누가복음 19:30","category":"$undefined"},{"id":"25763","book":"누가복음","book_name":"누가복음","chapter":19,"verse":31,"text":"만일 누가 너희에게 어찌하여 푸느냐 ? 묻거든 이렇게 말하되 주가 쓰시겠다 ! 하라' 하시매","reference":"누가복음 19:31","category":"$undefined"},{"id":"25764","book":"누가복음","book_name":"누가복음","chapter":19,"verse":32,"text":"보내심을 받은 자들이 가서 그 말씀하신 대로 만난지라","reference":"누가복음 19:32","category":"$undefined"},{"id":"25765","book":"누가복음","book_name":"누가복음","chapter":19,"verse":33,"text":"나귀 새끼를 풀 때에 그 임자들이 이르되 `어찌하여 나귀 새끼를 푸느냐 ?'","reference":"누가복음 19:33","category":"$undefined"},{"id":"25766","book":"누가복음","book_name":"누가복음","chapter":19,"verse":34,"text":"대답하되 `주께서 쓰시겠다 !' 하고","reference":"누가복음 19:34","category":"$undefined"},{"id":"25767","book":"누가복음","book_name":"누가복음","chapter":19,"verse":35,"text":"그것을 예수께로 끌고 와서 자기들의 겉옷을 나귀 새끼 위에 걸쳐 놓고 예수를 태우니","reference":"누가복음 19:35","category":"$undefined"},{"id":"25768","book":"누가복음","book_name":"누가복음","chapter":19,"verse":36,"text":"가실 때에 저희가 자기의 겉옷을 길에 펴더라","reference":"누가복음 19:36","category":"$undefined"},{"id":"25769","book":"누가복음","book_name":"누가복음","chapter":19,"verse":37,"text":"이미 감람산에서 내려가는 편까지 가까이 오시매 제자의 온 무리가 자기의 본 바 모든 능한 일을 인하여 기뻐하며 큰 소리로 하나님을 찬양하여","reference":"누가복음 19:37","category":"$undefined"},{"id":"25770","book":"누가복음","book_name":"누가복음","chapter":19,"verse":38,"text":"가로되 `찬송하리로다 주의 이름으로 오시는 왕이여 ! 하늘에는 평화요 가장 높은 곳에는 영광이로다' 하니","reference":"누가복음 19:38","category":"$undefined"},{"id":"25771","book":"누가복음","book_name":"누가복음","chapter":19,"verse":39,"text":"무리 중 어떤 바리새인들이 말하되 `선생이여, 당신의 제자들을 책망하소서' 하거늘","reference":"누가복음 19:39","category":"$undefined"},{"id":"25772","book":"누가복음","book_name":"누가복음","chapter":19,"verse":40,"text":"대답하여 가라사대 `내가 너희에게 말하노니 만일 이 사람들이 잠잠하면 돌들이 소리지르리라' 하시니라","reference":"누가복음 19:40","category":"$undefined"},{"id":"25773","book":"누가복음","book_name":"누가복음","chapter":19,"verse":41,"text":"가까이 오사 성을 보시고 우시며","reference":"누가복음 19:41","category":"$undefined"},{"id":"25774","book":"누가복음","book_name":"누가복음","chapter":19,"verse":42,"text":"가라사대 `너도 오늘날 평화에 관한 일을 알았더면 좋을 뻔하였거니와 지금 네 눈에 숨기웠도다","reference":"누가복음 19:42","category":"$undefined"},{"id":"25775","book":"누가복음","book_name":"누가복음","chapter":19,"verse":43,"text":"날이 이를지라 네 원수들이 토성을 쌓고 너를 둘러 사면으로 가두고","reference":"누가복음 19:43","category":"$undefined"},{"id":"25776","book":"누가복음","book_name":"누가복음","chapter":19,"verse":44,"text":"또 너와 및 그 가운데 있는 네 자식들을 땅에 메어치며 돌 하나도 돌위에 남기지 아니하리니 이는 권고 받는 날을 네가 알지 못함을 인함이니라' 하시니라","reference":"누가복음 19:44","category":"$undefined"},{"id":"25777","book":"누가복음","book_name":"누가복음","chapter":19,"verse":45,"text":"성전에 들어가사 장사하는 자들을 내어 쫓으시며","reference":"누가복음 19:45","category":"$undefined"},{"id":"25778","book":"누가복음","book_name":"누가복음","chapter":19,"verse":46,"text":"저희에게 이르시되 `기록된 바 내집은 기도하는 집이 되리라 하였거늘 너희는 강도의 굴혈을 만들었도다' 하시니라","reference":"누가복음 19:46","category":"$undefined"},{"id":"25779","book":"누가복음","book_name":"누가복음","chapter":19,"verse":47,"text":"예수께서 날마다 성전에서 가르치시니 대제사장들과 서기관들과 백성의 두목들이 그를 죽이려고 꾀하되","reference":"누가복음 19:47","category":"$undefined"},{"id":"25780","book":"누가복음","book_name":"누가복음","chapter":19,"verse":48,"text":"백성이 다 그에게 귀를 기울여 들으므로 어찌할 방침을 찾지 못하였더라","reference":"누가복음 19:48","category":"$undefined"}],"bookSlug":"luke"}]
