2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":2,"verses":[{"id":"24975","book":"누가복음","book_name":"누가복음","chapter":2,"verse":1,"text":"이때에 가이사 아구스도가 영을 내려 천하로 다 호적하라 하였으니","reference":"누가복음 2:1","category":"$undefined"},{"id":"24976","book":"누가복음","book_name":"누가복음","chapter":2,"verse":2,"text":"이 호적은 구레뇨가 수리아 총독 되었을때에 첫번 한 것이라","reference":"누가복음 2:2","category":"$undefined"},{"id":"24977","book":"누가복음","book_name":"누가복음","chapter":2,"verse":3,"text":"모든 사람이 호적하러 각각 고향으로 돌아가매","reference":"누가복음 2:3","category":"$undefined"},{"id":"24978","book":"누가복음","book_name":"누가복음","chapter":2,"verse":4,"text":"요셉도 다윗의 집 족속인고로 갈릴리 나사렛 동네에서 유대를 향하여 베들레헴이라 하는 다윗의 동네로","reference":"누가복음 2:4","category":"$undefined"},{"id":"24979","book":"누가복음","book_name":"누가복음","chapter":2,"verse":5,"text":"그 정혼한 마리아아 함께 호적하러 올라가니 마리아가 이미 잉태되었더라","reference":"누가복음 2:5","category":"$undefined"},{"id":"24980","book":"누가복음","book_name":"누가복음","chapter":2,"verse":6,"text":"거기 있을 그 때에 해산할 날이 차서","reference":"누가복음 2:6","category":"$undefined"},{"id":"24981","book":"누가복음","book_name":"누가복음","chapter":2,"verse":7,"text":"맏아들을 낳아 강보로 싸서 구유에 뉘었으니 이는 사관에 있을 곳이 없음이러라","reference":"누가복음 2:7","category":"$undefined"},{"id":"24982","book":"누가복음","book_name":"누가복음","chapter":2,"verse":8,"text":"그 지경에 목자들이 밖에서 밤에 자기 양떼를 지키더니","reference":"누가복음 2:8","category":"$undefined"},{"id":"24983","book":"누가복음","book_name":"누가복음","chapter":2,"verse":9,"text":"주의 사자가 곁에 서고 주의 영광이 저희를 두루 비취매 크게 무서워 하는지라","reference":"누가복음 2:9","category":"$undefined"},{"id":"24984","book":"누가복음","book_name":"누가복음","chapter":2,"verse":10,"text":"천사가 이르되 `무서워 말라 보라 내가 온 백성에게 미칠 큰 기쁨의 좋은 소식을 너희에게 전하노라","reference":"누가복음 2:10","category":"$undefined"},{"id":"24985","book":"누가복음","book_name":"누가복음","chapter":2,"verse":11,"text":"오늘날 다윗의 동네에 너희를 위하여 구주가 나셨으니 곧 그리스도 주시니라","reference":"누가복음 2:11","category":"$undefined"},{"id":"24986","book":"누가복음","book_name":"누가복음","chapter":2,"verse":12,"text":"너희가 가서 강보에 싸여 구유에 누인 아기를 보리니 이것이 너희에게 표적이니라' 하더니","reference":"누가복음 2:12","category":"$undefined"},{"id":"24987","book":"누가복음","book_name":"누가복음","chapter":2,"verse":13,"text":"홀연히 허다한 천군이 그 천사와 함께 있어 하나님을 찬송하여 가로되","reference":"누가복음 2:13","category":"$undefined"},{"id":"24988","book":"누가복음","book_name":"누가복음","chapter":2,"verse":14,"text":"`지극히 높은 곳에서는 하나님께 영광이요 땅에서는 기뻐하심을 입은 사람들 중에 평화로다' 하니라","reference":"누가복음 2:14","category":"$undefined"},{"id":"24989","book":"누가복음","book_name":"누가복음","chapter":2,"verse":15,"text":"천사들이 떠나 하늘로 올라가니 목자가 서로 말하되 `이제 베들레헴까지 가서 주께서 우리에게 알리신 바 이 이루어진 일을 보자' 하고","reference":"누가복음 2:15","category":"$undefined"},{"id":"24990","book":"누가복음","book_name":"누가복음","chapter":2,"verse":16,"text":"빨리 가서 마리아와 요셉과 구유에 누인 아기를 찾아서","reference":"누가복음 2:16","category":"$undefined"},{"id":"24991","book":"누가복음","book_name":"누가복음","chapter":2,"verse":17,"text":"보고 천사가 자기들에게 이 아기에 대하여 말한 것을 고하니","reference":"누가복음 2:17","category":"$undefined"},{"id":"24992","book":"누가복음","book_name":"누가복음","chapter":2,"verse":18,"text":"듣는 자가 다 목자의 말하는 일을 기이히 여기되","reference":"누가복음 2:18","category":"$undefined"},{"id":"24993","book":"누가복음","book_name":"누가복음","chapter":2,"verse":19,"text":"마리아는 이 모든 말을 마음에 지키어 생각하니라","reference":"누가복음 2:19","category":"$undefined"},{"id":"24994","book":"누가복음","book_name":"누가복음","chapter":2,"verse":20,"text":"목자가 자기들에게 이르던 바와 같이 듣고 본 그 모든 것을 인하여 하나님께 영광을 돌리고 찬송하며 돌아가니라","reference":"누가복음 2:20","category":"$undefined"},{"id":"24995","book":"누가복음","book_name":"누가복음","chapter":2,"verse":21,"text":"할례할 팔일이 되매 그 이름을 예수라 하니 곧 수태하기 전에 천사의 일컬은 바러라","reference":"누가복음 2:21","category":"$undefined"},{"id":"24996","book":"누가복음","book_name":"누가복음","chapter":2,"verse":22,"text":"모세의 법대로 결례의 날이 차매 아기를 데리고 예루살렘에 올라가니","reference":"누가복음 2:22","category":"$undefined"},{"id":"24997","book":"누가복음","book_name":"누가복음","chapter":2,"verse":23,"text":"이는 주의 율법에 쓴 바 첫 태에 처음 난 남자마다 주의 거룩한 자라 하리라 한 대로 아기를 주께 드리고","reference":"누가복음 2:23","category":"$undefined"},{"id":"24998","book":"누가복음","book_name":"누가복음","chapter":2,"verse":24,"text":"또 주의 율법에 말씀하신 대로 비둘기 한 쌍이나 혹 어린 반구 둘로 제사하려 함이더라","reference":"누가복음 2:24","category":"$undefined"},{"id":"24999","book":"누가복음","book_name":"누가복음","chapter":2,"verse":25,"text":"예루살렘에 시므온이라 하는 사람이 있으니 이 사람이 의롭고 경건하여 이스라엘의 위로를 기다리는 자라 성령이 그 위에 계시더라","reference":"누가복음 2:25","category":"$undefined"},{"id":"25000","book":"누가복음","book_name":"누가복음","chapter":2,"verse":26,"text":"저가 주의 그리스도를 보기 전에 죽지 아니하리라 하는 성령의 지시를 받았더니","reference":"누가복음 2:26","category":"$undefined"},{"id":"25001","book":"누가복음","book_name":"누가복음","chapter":2,"verse":27,"text":"성령의 감동으로 성전에 들어가매 마침 부모가 율법의 전례대로 행하고자 하여 그 아기 예수를 데리고 오는지라","reference":"누가복음 2:27","category":"$undefined"},{"id":"25002","book":"누가복음","book_name":"누가복음","chapter":2,"verse":28,"text":"시므온이 아기를 안고 하나님을 찬송하여 가로되","reference":"누가복음 2:28","category":"$undefined"},{"id":"25003","book":"누가복음","book_name":"누가복음","chapter":2,"verse":29,"text":"`주재여 이제는 말씀하신 대로 종을 평안히 놓아 주시는도다","reference":"누가복음 2:29","category":"$undefined"},{"id":"25004","book":"누가복음","book_name":"누가복음","chapter":2,"verse":30,"text":"내 눈이 주의 구원을 보았사오니","reference":"누가복음 2:30","category":"$undefined"},{"id":"25005","book":"누가복음","book_name":"누가복음","chapter":2,"verse":31,"text":"이는 만민 앞에 예비하신 것이요","reference":"누가복음 2:31","category":"$undefined"},{"id":"25006","book":"누가복음","book_name":"누가복음","chapter":2,"verse":32,"text":"이방을 비추는 빛이요 주의 백성 이스라엘의 영광이니이다' 하니","reference":"누가복음 2:32","category":"$undefined"},{"id":"25007","book":"누가복음","book_name":"누가복음","chapter":2,"verse":33,"text":"그 부모가 그 아기에 대한 말들을 기이히 여기더라","reference":"누가복음 2:33","category":"$undefined"},{"id":"25008","book":"누가복음","book_name":"누가복음","chapter":2,"verse":34,"text":"시므온이 저희에게 축복하고 그 모친 마리아에게 일러 가로되 `보라 이 아이는 이스라엘 중 많은 사람의 패하고 흥함을 위하여 비방을 받는 표적되기 위하여 세움을 입었고","reference":"누가복음 2:34","category":"$undefined"},{"id":"25009","book":"누가복음","book_name":"누가복음","chapter":2,"verse":35,"text":"또 칼이 네 마음을 찌르듯 하리라 이는 여러 사람의 마음의 생각을 드러내려 함이니라' 하더라","reference":"누가복음 2:35","category":"$undefined"},{"id":"25010","book":"누가복음","book_name":"누가복음","chapter":2,"verse":36,"text":"또 아셀 지파 바누엘의 딸 안나라 하는 선지자가 있어 나이 매우 늙었더라 그가 출가한 후 일곱 해 동안 남편과 함께 살다가","reference":"누가복음 2:36","category":"$undefined"},{"id":"25011","book":"누가복음","book_name":"누가복음","chapter":2,"verse":37,"text":"과부 된 지 팔십사년이라 이 사람이 성전을 떠나지 아니하고 주야에 금식하며 기도함으로 섬기더니","reference":"누가복음 2:37","category":"$undefined"},{"id":"25012","book":"누가복음","book_name":"누가복음","chapter":2,"verse":38,"text":"마침 이 때에 나아와서 하나님께 감사하고 예루살렘의 구속됨을 바라는 모든 사람에게 이 아기에 대하여 말하니라","reference":"누가복음 2:38","category":"$undefined"},{"id":"25013","book":"누가복음","book_name":"누가복음","chapter":2,"verse":39,"text":"주의 율법을 좇아 모든 일을 필하고 갈릴리로 돌아가 본 동네 나사렛에 이르니라","reference":"누가복음 2:39","category":"$undefined"},{"id":"25014","book":"누가복음","book_name":"누가복음","chapter":2,"verse":40,"text":"아기가 자라며 강하여지고 지혜가 충족하며 하나님의 은혜가 그 위에 있더라","reference":"누가복음 2:40","category":"$undefined"},{"id":"25015","book":"누가복음","book_name":"누가복음","chapter":2,"verse":41,"text":"그 부모가 해마다 유월절을 당하면 예루살렘으로 가더니","reference":"누가복음 2:41","category":"$undefined"},{"id":"25016","book":"누가복음","book_name":"누가복음","chapter":2,"verse":42,"text":"예수께서 열 두 살 될 때에 저희가 이 절기의 전례를 좇아 올라 갔다가","reference":"누가복음 2:42","category":"$undefined"},{"id":"25017","book":"누가복음","book_name":"누가복음","chapter":2,"verse":43,"text":"그 날들을 마치고 돌아갈 때에 아이 예수는 예루살렘에 머무셨더라 그 부모는 이를 알지 못하고","reference":"누가복음 2:43","category":"$undefined"},{"id":"25018","book":"누가복음","book_name":"누가복음","chapter":2,"verse":44,"text":"동행 중에 있는 줄로 생각하고 하룻길을 간 후 친족과 아는 자 중에서 찾되","reference":"누가복음 2:44","category":"$undefined"},{"id":"25019","book":"누가복음","book_name":"누가복음","chapter":2,"verse":45,"text":"만나지 못하매 찾으면서 예루살렘에 돌아갔더니","reference":"누가복음 2:45","category":"$undefined"},{"id":"25020","book":"누가복음","book_name":"누가복음","chapter":2,"verse":46,"text":"사흘 후에 성전에서 만난즉 그가 선생들 중에 앉으사 저희에게 듣기도 하시며 묻기도 하시니","reference":"누가복음 2:46","category":"$undefined"},{"id":"25021","book":"누가복음","book_name":"누가복음","chapter":2,"verse":47,"text":"듣는 자가 다 그 지혜와 대답을 기이히 여기더라","reference":"누가복음 2:47","category":"$undefined"},{"id":"25022","book":"누가복음","book_name":"누가복음","chapter":2,"verse":48,"text":"그 부모가 보고 놀라며 그 모친은 가로되 `아이야 어찌하여 우리에게 이렇게 하였느냐 ? 보라 네 아버지와 내가 근심하여 너를 찾았노라'","reference":"누가복음 2:48","category":"$undefined"},{"id":"25023","book":"누가복음","book_name":"누가복음","chapter":2,"verse":49,"text":"예수께서 가라사대 `어찌하여 나를 찾으셨나이까 ? 내가 내 아버지 집에 있어야 될 줄을 알지 못하셨나이까 ?' 하시니","reference":"누가복음 2:49","category":"$undefined"},{"id":"25024","book":"누가복음","book_name":"누가복음","chapter":2,"verse":50,"text":"양친이 그 하신 말씀을 깨닫지 못하더라","reference":"누가복음 2:50","category":"$undefined"},{"id":"25025","book":"누가복음","book_name":"누가복음","chapter":2,"verse":51,"text":"예수께서 한가지로 내려가사 나사렛에 이르러 순종하여 받드시더라 그 모친은 이 모든 말을 마음에 두니라","reference":"누가복음 2:51","category":"$undefined"},{"id":"25026","book":"누가복음","book_name":"누가복음","chapter":2,"verse":52,"text":"예수는 그 지혜와 그 키가 자라가며 하나님과 사람에게 더 사랑스러워 가시더라","reference":"누가복음 2:52","category":"$undefined"}],"bookSlug":"luke"}]
