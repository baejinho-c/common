2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":20,"verses":[{"id":"25781","book":"누가복음","book_name":"누가복음","chapter":20,"verse":1,"text":"하루는 예수께서 성전에서 백성을 가르치시며 복음을 전하실 새 대제사장들과 서기관들이 장로들과 함께 가까이 와서","reference":"누가복음 20:1","category":"$undefined"},{"id":"25782","book":"누가복음","book_name":"누가복음","chapter":20,"verse":2,"text":"말하여 가로되 `당신이 무슨 권세로 이런 일을 하는지 이 권세를 준 이가 누구인지 우리에게 말하라'","reference":"누가복음 20:2","category":"$undefined"},{"id":"25783","book":"누가복음","book_name":"누가복음","chapter":20,"verse":3,"text":"대답하여 가라사대 `나도 한 말을 너희에게 물으리니 내게 말하라","reference":"누가복음 20:3","category":"$undefined"},{"id":"25784","book":"누가복음","book_name":"누가복음","chapter":20,"verse":4,"text":"요한의 세례가 하늘로서냐 ? 사람에게로서냐 ?'","reference":"누가복음 20:4","category":"$undefined"},{"id":"25785","book":"누가복음","book_name":"누가복음","chapter":20,"verse":5,"text":"저희가 서로 의논하여 가로되 `만일 하늘로서라 하면 어찌하여 저를 믿지 아니하였느냐 할 것이요","reference":"누가복음 20:5","category":"$undefined"},{"id":"25786","book":"누가복음","book_name":"누가복음","chapter":20,"verse":6,"text":"만일 사람에게로서라 하면 백성이 요한을 선지자로 인정하니 저희가 다 우리를 돌로 칠 것이라' 하고","reference":"누가복음 20:6","category":"$undefined"},{"id":"25787","book":"누가복음","book_name":"누가복음","chapter":20,"verse":7,"text":"대답하되 `어디로서인지 알지 못하노라' 하니","reference":"누가복음 20:7","category":"$undefined"},{"id":"25788","book":"누가복음","book_name":"누가복음","chapter":20,"verse":8,"text":"예수께서 이르시되 `나도 무슨 권세로 이런 일을 하는지 너희에게 이르지 아니하리라' 하시니라","reference":"누가복음 20:8","category":"$undefined"},{"id":"25789","book":"누가복음","book_name":"누가복음","chapter":20,"verse":9,"text":"이 비유로 백성에게 말씀하시되 `한 사람이 포도원을 만들어 농부들에게 세로 주고 타국에 가서 오래 있다가","reference":"누가복음 20:9","category":"$undefined"},{"id":"25790","book":"누가복음","book_name":"누가복음","chapter":20,"verse":10,"text":"때가 이르매 포도원 소출 얼마를 바치게 하려고 한 종을 농부들에게 보내니 농부들이 종을 심히 때리고 거저 보내었거늘","reference":"누가복음 20:10","category":"$undefined"},{"id":"25791","book":"누가복음","book_name":"누가복음","chapter":20,"verse":11,"text":"다시 다른 종을 보내니 그도 심히 때리고 능욕하고 거저 보내었거늘","reference":"누가복음 20:11","category":"$undefined"},{"id":"25792","book":"누가복음","book_name":"누가복음","chapter":20,"verse":12,"text":"다시 세번째 종을 보내니 이도 상하게 하고 내어 쫓은지라","reference":"누가복음 20:12","category":"$undefined"},{"id":"25793","book":"누가복음","book_name":"누가복음","chapter":20,"verse":13,"text":"포도원 주인이 가로되 어찌할꼬 내 사랑하는 아들을 보내리니 저희가 혹 그는 공경하리라 하였더니","reference":"누가복음 20:13","category":"$undefined"},{"id":"25794","book":"누가복음","book_name":"누가복음","chapter":20,"verse":14,"text":"농부들이 그를 보고 서로 의논하여 가로되 이는 상속자니 죽이고 그 유업을 우리의 것으로 만들자 하고","reference":"누가복음 20:14","category":"$undefined"},{"id":"25795","book":"누가복음","book_name":"누가복음","chapter":20,"verse":15,"text":"포도원 밖에 내어 쫓아 죽였느니라 그런즉 포도원 주인이 이 사람들을 어떻게 하겠느뇨 ?","reference":"누가복음 20:15","category":"$undefined"},{"id":"25796","book":"누가복음","book_name":"누가복음","chapter":20,"verse":16,"text":"와서 그 농부들을 진멸하고 포도원을 다른 사람들에게 주리라 하시니 사람들이 듣고 가로되 그렇게 되지 말아지이다 하거늘","reference":"누가복음 20:16","category":"$undefined"},{"id":"25797","book":"누가복음","book_name":"누가복음","chapter":20,"verse":17,"text":"저희를 보시며 가라사대 그러면 기록된 바 건축자들의 버린 돌이 모퉁이의 머릿돌이 되었느니라 함이 어찜이뇨","reference":"누가복음 20:17","category":"$undefined"},{"id":"25798","book":"누가복음","book_name":"누가복음","chapter":20,"verse":18,"text":"무릇 이 돌 위에 떨어지는 자는 깨어지겠고 이 돌이 사람 위에 떨어지면 저를 가루로 만들어 흩으리라' 하시니라","reference":"누가복음 20:18","category":"$undefined"},{"id":"25799","book":"누가복음","book_name":"누가복음","chapter":20,"verse":19,"text":"서기관들과 대제사장들이 예수의 이 비유는 자기들을 가리켜 말씀하심인 줄 알고 즉시 잡고자 하되 백성을 두려워하더라","reference":"누가복음 20:19","category":"$undefined"},{"id":"25800","book":"누가복음","book_name":"누가복음","chapter":20,"verse":20,"text":"이에 저희가 엿보다가 예수를 총독의 치리와 권세 아래 붙이려 하여 정탐들을 보내어 그들로 스스로 의인인 체하며 예수의 말을 책잡게 하니","reference":"누가복음 20:20","category":"$undefined"},{"id":"25801","book":"누가복음","book_name":"누가복음","chapter":20,"verse":21,"text":"그들이 물어 가로되 `선생님이여 우리가 아노니 당신은 바로 말씀하시고 가르치시며 사람을 외모로 취치 아니하시고 오직 참으로써 하나님의 도를 가르치시나이다","reference":"누가복음 20:21","category":"$undefined"},{"id":"25802","book":"누가복음","book_name":"누가복음","chapter":20,"verse":22,"text":"우리가 가이사에게 세를 바치는 것이 가하니이까 ? 불가하니이까 ?' 하니","reference":"누가복음 20:22","category":"$undefined"},{"id":"25803","book":"누가복음","book_name":"누가복음","chapter":20,"verse":23,"text":"예수께서 그 간계를 아시고 가라사대","reference":"누가복음 20:23","category":"$undefined"},{"id":"25804","book":"누가복음","book_name":"누가복음","chapter":20,"verse":24,"text":"`데나리온 하나를 내게 보이라 뉘 화상과 글이 여기 있느냐 ?' 대답하되 `가이사의 것이니이다'","reference":"누가복음 20:24","category":"$undefined"},{"id":"25805","book":"누가복음","book_name":"누가복음","chapter":20,"verse":25,"text":"가라사대 `그런즉 가이사의 것은 가이사에게 하나님의 것은 하나님께 바치라' 하시니","reference":"누가복음 20:25","category":"$undefined"},{"id":"25806","book":"누가복음","book_name":"누가복음","chapter":20,"verse":26,"text":"저희가 백성 앞에서 그의 말을 능히 책잡지 못하고 그의 대답을 기이히 여겨 잠잠하니라","reference":"누가복음 20:26","category":"$undefined"},{"id":"25807","book":"누가복음","book_name":"누가복음","chapter":20,"verse":27,"text":"부활이 없다 주장하는 사두개인 중 어떤 이들이 와서","reference":"누가복음 20:27","category":"$undefined"},{"id":"25808","book":"누가복음","book_name":"누가복음","chapter":20,"verse":28,"text":"물어 가로되 `선생님이여, 모세가 우리에게 써 주기를 사람의 형이 만일 아내를 두고 자식이 없이 죽거든 그 동생이 그 아내를 취하여 형을 위하여 후사를 세울지니라 하였나이다","reference":"누가복음 20:28","category":"$undefined"},{"id":"25809","book":"누가복음","book_name":"누가복음","chapter":20,"verse":29,"text":"그런데 칠 형제가 있었는데 맏이 아내를 취하였다가 자식이 없이 죽고","reference":"누가복음 20:29","category":"$undefined"},{"id":"25810","book":"누가복음","book_name":"누가복음","chapter":20,"verse":30,"text":"그 둘째와 세째가 저를 취하고","reference":"누가복음 20:30","category":"$undefined"},{"id":"25811","book":"누가복음","book_name":"누가복음","chapter":20,"verse":31,"text":"일곱이 다 그와 같이 자식이 없이 죽고","reference":"누가복음 20:31","category":"$undefined"},{"id":"25812","book":"누가복음","book_name":"누가복음","chapter":20,"verse":32,"text":"그 후에 여자도 죽었나이다","reference":"누가복음 20:32","category":"$undefined"},{"id":"25813","book":"누가복음","book_name":"누가복음","chapter":20,"verse":33,"text":"일곱이 다 저를 아내로 취하였으니 부활 때에 그 중에 뉘 아내가 되리이까 ?'","reference":"누가복음 20:33","category":"$undefined"},{"id":"25814","book":"누가복음","book_name":"누가복음","chapter":20,"verse":34,"text":"예수께서 이르시되 `이 세상의 자녀들은 장가도 가고 시집도 가되","reference":"누가복음 20:34","category":"$undefined"},{"id":"25815","book":"누가복음","book_name":"누가복음","chapter":20,"verse":35,"text":"저 세상과 및 죽은 자 가운데서 부활함을 얻기에 합당히 여김을 입은 자들은 장가가고 시집가는 일이 없으며","reference":"누가복음 20:35","category":"$undefined"},{"id":"25816","book":"누가복음","book_name":"누가복음","chapter":20,"verse":36,"text":"저희는 다시 죽을 수도 없나니 이는 천사와 동등이요 부활의 자녀로서 하나님의 자녀임이니라","reference":"누가복음 20:36","category":"$undefined"},{"id":"25817","book":"누가복음","book_name":"누가복음","chapter":20,"verse":37,"text":"죽은 자의 살아난다는 것은 모세도 가시나무떨기에 관한 글에 보였으되 주를 아브라함의 하나님이요, 이삭의 하나님이요, 야곱의 하나님이시라 칭하였나니","reference":"누가복음 20:37","category":"$undefined"},{"id":"25818","book":"누가복음","book_name":"누가복음","chapter":20,"verse":38,"text":"하나님은 죽은 자의 하나님이 아니요 산 자의 하나님이시라 하나님에게는 모든 사람이 살았느니라' 하시니","reference":"누가복음 20:38","category":"$undefined"},{"id":"25819","book":"누가복음","book_name":"누가복음","chapter":20,"verse":39,"text":"서기관 중 어떤 이들이 말하되 `선생이여, 말씀이 옳으니이다' 하니","reference":"누가복음 20:39","category":"$undefined"},{"id":"25820","book":"누가복음","book_name":"누가복음","chapter":20,"verse":40,"text":"저희는 아무 것도 감히 더 물을 수 없음이더라","reference":"누가복음 20:40","category":"$undefined"},{"id":"25821","book":"누가복음","book_name":"누가복음","chapter":20,"verse":41,"text":"예수께서 저희에게 이르시되 `사람들이 어찌하여 그리스도를 다윗의 자손이라 하느냐 ?","reference":"누가복음 20:41","category":"$undefined"},{"id":"25822","book":"누가복음","book_name":"누가복음","chapter":20,"verse":42,"text":"시편에 다윗이 친히 말하였으되 주께서 내 주께 이르시되","reference":"누가복음 20:42","category":"$undefined"},{"id":"25823","book":"누가복음","book_name":"누가복음","chapter":20,"verse":43,"text":"내가 네 원수를 네 발의 발등상으로 둘 때까지 내 우편에 앉았으라 하셨도다 하였느니라","reference":"누가복음 20:43","category":"$undefined"},{"id":"25824","book":"누가복음","book_name":"누가복음","chapter":20,"verse":44,"text":"그런즉 다윗이 그리스도를 주라 칭하였으니 어찌 그의 자손이 되겠느뇨 ?' 하시니라","reference":"누가복음 20:44","category":"$undefined"},{"id":"25825","book":"누가복음","book_name":"누가복음","chapter":20,"verse":45,"text":"모든 백성이 들을 때에 예수께서 그 제자들에게 이르시되","reference":"누가복음 20:45","category":"$undefined"},{"id":"25826","book":"누가복음","book_name":"누가복음","chapter":20,"verse":46,"text":"`긴 옷을 입고 다니는 것을 원하며 시장에서 문안 받는 것과 회당의 상좌와 잔치의 상석을 좋아하는 서기관들을 삼가라","reference":"누가복음 20:46","category":"$undefined"},{"id":"25827","book":"누가복음","book_name":"누가복음","chapter":20,"verse":47,"text":"저희는 과부의 가산을 삼키며 외식으로 길게 기도하니 그 받는 판결이 더욱 중하리라' 하시니라","reference":"누가복음 20:47","category":"$undefined"}],"bookSlug":"luke"}]
