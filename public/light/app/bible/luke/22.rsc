2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":22,"verses":[{"id":"25866","book":"누가복음","book_name":"누가복음","chapter":22,"verse":1,"text":"유월절이라 하는 무교절이 가까우매","reference":"누가복음 22:1","category":"$undefined"},{"id":"25867","book":"누가복음","book_name":"누가복음","chapter":22,"verse":2,"text":"대제사장들과 서기관들이 예수를 무슨 방책으로 죽일꼬 연구하니 이는 저희가 백성을 두려워함이더라","reference":"누가복음 22:2","category":"$undefined"},{"id":"25868","book":"누가복음","book_name":"누가복음","chapter":22,"verse":3,"text":"열 둘 중에 하나인 가룟인이라 부르는 유다에게 사단이 들어가니","reference":"누가복음 22:3","category":"$undefined"},{"id":"25869","book":"누가복음","book_name":"누가복음","chapter":22,"verse":4,"text":"이에 유다가 대제사장들과 군관들에게 가서 예수를 넘겨 줄 방책을 의논하매","reference":"누가복음 22:4","category":"$undefined"},{"id":"25870","book":"누가복음","book_name":"누가복음","chapter":22,"verse":5,"text":"저희가 기뻐하여 돈을 주기로 언약하는지라","reference":"누가복음 22:5","category":"$undefined"},{"id":"25871","book":"누가복음","book_name":"누가복음","chapter":22,"verse":6,"text":"유다가 허락하고 예수를 무리가 없을 때에 넘겨 줄 기회를 찾더라","reference":"누가복음 22:6","category":"$undefined"},{"id":"25872","book":"누가복음","book_name":"누가복음","chapter":22,"verse":7,"text":"유월절 양을 잡을 무교절일이 이른지라","reference":"누가복음 22:7","category":"$undefined"},{"id":"25873","book":"누가복음","book_name":"누가복음","chapter":22,"verse":8,"text":"예수께서 베드로와 요한을 보내시며 가라사대 `가서 우리를 위하여 유월절을 예비하여 우리로 먹게 하라'","reference":"누가복음 22:8","category":"$undefined"},{"id":"25874","book":"누가복음","book_name":"누가복음","chapter":22,"verse":9,"text":"여짜오되 `어디서 예비하기를 원하시나이까 ?'","reference":"누가복음 22:9","category":"$undefined"},{"id":"25875","book":"누가복음","book_name":"누가복음","chapter":22,"verse":10,"text":"이르시되 `보라 너희가 성내로 들어가면 물 한 동이를 가지고 가는 사람을 만나리니 그의 들어가는 집으로 따라 들어가서","reference":"누가복음 22:10","category":"$undefined"},{"id":"25876","book":"누가복음","book_name":"누가복음","chapter":22,"verse":11,"text":"그 집 주인에게 이르되 선생님이 네게 하는 말씀이 내가 내 제자들과 함께 유월절을 먹을 객실이 어디 있느뇨 하시더라 하라","reference":"누가복음 22:11","category":"$undefined"},{"id":"25877","book":"누가복음","book_name":"누가복음","chapter":22,"verse":12,"text":"그리하면 저가 자리를 베푼 큰 다락방을 보이리니 거기서 예비하라' 하신대","reference":"누가복음 22:12","category":"$undefined"},{"id":"25878","book":"누가복음","book_name":"누가복음","chapter":22,"verse":13,"text":"저희가 나가 그 하시던 말씀대로 만나 유월절을 예비하니라","reference":"누가복음 22:13","category":"$undefined"},{"id":"25879","book":"누가복음","book_name":"누가복음","chapter":22,"verse":14,"text":"때가 이르매 예수께서 사도들과 함께 앉으사","reference":"누가복음 22:14","category":"$undefined"},{"id":"25880","book":"누가복음","book_name":"누가복음","chapter":22,"verse":15,"text":"이르시되 `내가 고난을 받기 전에 너희와 함께 이 유월절 먹기를 원하고 원하였노라","reference":"누가복음 22:15","category":"$undefined"},{"id":"25881","book":"누가복음","book_name":"누가복음","chapter":22,"verse":16,"text":"내가 너희에게 이르노니 이 유월절이 하나님의 나라에서 이루기까지 다시 먹지 아니하리라' 하시고","reference":"누가복음 22:16","category":"$undefined"},{"id":"25882","book":"누가복음","book_name":"누가복음","chapter":22,"verse":17,"text":"이에 잔을 받으사 사례하시고 가라사대 `이것을 갖다가 너희끼리 나누라","reference":"누가복음 22:17","category":"$undefined"},{"id":"25883","book":"누가복음","book_name":"누가복음","chapter":22,"verse":18,"text":"내가 너희에게 이르노니 내가 이제부터 하나님의 나라가 임할 때까지 포도나무에서 난 것을 다시 마시지 아니하리라' 하시고","reference":"누가복음 22:18","category":"$undefined"},{"id":"25884","book":"누가복음","book_name":"누가복음","chapter":22,"verse":19,"text":"또 떡을 가져 사례하시고 떼어 저희에게 주시며 가라사대 `이것은 너희를 위하여 주는 내 몸이라 너희가 이를 행하여 나를 기념하라 !' 하시고","reference":"누가복음 22:19","category":"$undefined"},{"id":"25885","book":"누가복음","book_name":"누가복음","chapter":22,"verse":20,"text":"저녁 먹은 후에 잔도 이와 같이 하여 가라사대 `이 잔은 내 피로 세우는 새 언약이니 곧 너희를 위하여 붓는 것이라","reference":"누가복음 22:20","category":"$undefined"},{"id":"25886","book":"누가복음","book_name":"누가복음","chapter":22,"verse":21,"text":"그러나 보라 나를 파는 자의 손이 나와 함께 상 위에 있도다","reference":"누가복음 22:21","category":"$undefined"},{"id":"25887","book":"누가복음","book_name":"누가복음","chapter":22,"verse":22,"text":"인자는 이미 작정된 대로 가거니와 그를 파는 그 사람에게는 화가 있으리로다' 하시니","reference":"누가복음 22:22","category":"$undefined"},{"id":"25888","book":"누가복음","book_name":"누가복음","chapter":22,"verse":23,"text":"저희가 서로 묻되 `우리 중에서 이 일을 행할 자가 누구일까 ?' 하더라","reference":"누가복음 22:23","category":"$undefined"},{"id":"25889","book":"누가복음","book_name":"누가복음","chapter":22,"verse":24,"text":"또 저희 사이에 그 중 누가 크냐 하는 다툼이 난지라","reference":"누가복음 22:24","category":"$undefined"},{"id":"25890","book":"누가복음","book_name":"누가복음","chapter":22,"verse":25,"text":"예수께서 이르시되 `이방인의 임금들은 저희를 주관하며 그 집권자들은 은인이라 칭함을 받으나","reference":"누가복음 22:25","category":"$undefined"},{"id":"25891","book":"누가복음","book_name":"누가복음","chapter":22,"verse":26,"text":"너희는 그렇지 않을지니 너희 중에 큰 자는 젊은 자와 같고 두목은 섬기는 자와 같을지니라","reference":"누가복음 22:26","category":"$undefined"},{"id":"25892","book":"누가복음","book_name":"누가복음","chapter":22,"verse":27,"text":"앉아서 먹는 자가 크냐 ? 섬기는 자가 크냐 ? 앉아 먹는 자가 아니냐 ? 그러나 나는 섬기는 자로 너희 중에 있노라","reference":"누가복음 22:27","category":"$undefined"},{"id":"25893","book":"누가복음","book_name":"누가복음","chapter":22,"verse":28,"text":"너희는 나의 모든 시험 중에 항상 나와 함께 한 자들인즉","reference":"누가복음 22:28","category":"$undefined"},{"id":"25894","book":"누가복음","book_name":"누가복음","chapter":22,"verse":29,"text":"내 아버지께서 나라를 내게 맡기신 것같이 나도 너희에게 맡겨","reference":"누가복음 22:29","category":"$undefined"},{"id":"25895","book":"누가복음","book_name":"누가복음","chapter":22,"verse":30,"text":"너희로 내 나라에 있어 내 상에서 먹고 마시며 또는 보좌에 앉아 이스라엘 열 두 지파를 다스리게 하려 하노라","reference":"누가복음 22:30","category":"$undefined"},{"id":"25896","book":"누가복음","book_name":"누가복음","chapter":22,"verse":31,"text":"시몬아, 시몬아 보라 사단이 밀 까부르듯 하려고 너희를 청구하였으나","reference":"누가복음 22:31","category":"$undefined"},{"id":"25897","book":"누가복음","book_name":"누가복음","chapter":22,"verse":32,"text":"그러나 내가 너를 위하여 네 믿음이 떨어지지 않기를 기도하였노니 너는 돌이킨 후에 네 형제를 굳게 하라'","reference":"누가복음 22:32","category":"$undefined"},{"id":"25898","book":"누가복음","book_name":"누가복음","chapter":22,"verse":33,"text":"저가 말하되 `주여, 내가 주와 함께 옥에도, 죽는데도 가기를 준비하였나이다'","reference":"누가복음 22:33","category":"$undefined"},{"id":"25899","book":"누가복음","book_name":"누가복음","chapter":22,"verse":34,"text":"가라사대 `베드로야 내가 네게 말하노니 오늘 닭 울기 전에 네가 세번 나를 모른다고 부인하리라' 하시니라","reference":"누가복음 22:34","category":"$undefined"},{"id":"25900","book":"누가복음","book_name":"누가복음","chapter":22,"verse":35,"text":"저희에게 이르시되 `내가 너희를 전대와 주머니와 신도 없이 보내었을 때에 부족한 것이 있더냐 ?' 가로되 `없었나이다'","reference":"누가복음 22:35","category":"$undefined"},{"id":"25901","book":"누가복음","book_name":"누가복음","chapter":22,"verse":36,"text":"이르시되 `이제는 전대 있는 자는 가질 것이요 주머니도 그리하고 검없는 자는 겉옷을 팔아 살지어다","reference":"누가복음 22:36","category":"$undefined"},{"id":"25902","book":"누가복음","book_name":"누가복음","chapter":22,"verse":37,"text":"내가 너희에게 말하노니 기록된 바 저는 불법자의 동류로 여김을 받았다 한 말이 내게 이루어져야 하리니 내게 관한 일이 이루어 감이니라'","reference":"누가복음 22:37","category":"$undefined"},{"id":"25903","book":"누가복음","book_name":"누가복음","chapter":22,"verse":38,"text":"저희가 여짜오되 주여 보소서 여기 검 둘이 있나이다 대답하시되 족하다 하시니라","reference":"누가복음 22:38","category":"$undefined"},{"id":"25904","book":"누가복음","book_name":"누가복음","chapter":22,"verse":39,"text":"예수께서 나가사 습관을 좇아 감람산에 가시매 제자들도 좇았더니","reference":"누가복음 22:39","category":"$undefined"},{"id":"25905","book":"누가복음","book_name":"누가복음","chapter":22,"verse":40,"text":"그 곳에 이르러 저희에게 이르시되 `시험에 들지 않기를 기도하라 !' 하시고","reference":"누가복음 22:40","category":"$undefined"},{"id":"25906","book":"누가복음","book_name":"누가복음","chapter":22,"verse":41,"text":"저희를 떠나 돌 던질 만큼 가서 무릎을 꿇고 기도하여","reference":"누가복음 22:41","category":"$undefined"},{"id":"25907","book":"누가복음","book_name":"누가복음","chapter":22,"verse":42,"text":"가라사대 `아버지여 만일 아버지의 뜻이어든 이 잔을 내게서 옮기시옵소서 그러나 내 원대로 마옵시고 아버지의 원대로 되기를 원하나이다' 하시니","reference":"누가복음 22:42","category":"$undefined"},{"id":"25908","book":"누가복음","book_name":"누가복음","chapter":22,"verse":43,"text":"사자가 하늘로부터 예수께 나타나 힘을 돕더라","reference":"누가복음 22:43","category":"$undefined"},{"id":"25909","book":"누가복음","book_name":"누가복음","chapter":22,"verse":44,"text":"예수께서 힘쓰고 애써 더욱 간절히 기도하시니 땀이 땅에 떨어지는 피방울 같이 되더라","reference":"누가복음 22:44","category":"$undefined"},{"id":"25910","book":"누가복음","book_name":"누가복음","chapter":22,"verse":45,"text":"기도 후에 일어나 제자들에게 가서 슬픔을 인하여 잠든 것을 보시고","reference":"누가복음 22:45","category":"$undefined"},{"id":"25911","book":"누가복음","book_name":"누가복음","chapter":22,"verse":46,"text":"이르시되 `어찌하여 자느냐 시험에 들지 않게 일어나 기도하라 !' 하시니라","reference":"누가복음 22:46","category":"$undefined"},{"id":"25912","book":"누가복음","book_name":"누가복음","chapter":22,"verse":47,"text":"말씀하실 때에 한 무리가 오는데 열 둘 중에 하나인 유다라 하는 자가 그들의 앞에 서서 와서","reference":"누가복음 22:47","category":"$undefined"},{"id":"25913","book":"누가복음","book_name":"누가복음","chapter":22,"verse":48,"text":"예수께 입을 맞추려고 가까이 하는지라 예수께서 이르시되 `유다야 네가 입 맞춤으로 인자를 파느냐 ?' 하시니","reference":"누가복음 22:48","category":"$undefined"},{"id":"25914","book":"누가복음","book_name":"누가복음","chapter":22,"verse":49,"text":"좌우가 그 될 일을 보고 여짜오되 `주여, 우리가 검으로 치리이까 ?' 하고","reference":"누가복음 22:49","category":"$undefined"},{"id":"25915","book":"누가복음","book_name":"누가복음","chapter":22,"verse":50,"text":"그 중에 한 사람이 대제사장의 종을 쳐 그 오른편 귀를 떨어뜨린지라","reference":"누가복음 22:50","category":"$undefined"},{"id":"25916","book":"누가복음","book_name":"누가복음","chapter":22,"verse":51,"text":"예수께서 일러 가라사대 `이것까지 참으라' 하시고 그 귀를 만져 낫게 하시더라","reference":"누가복음 22:51","category":"$undefined"},{"id":"25917","book":"누가복음","book_name":"누가복음","chapter":22,"verse":52,"text":"예수께서 그 잡으러 온 대제사장들과 성전의 군관들과 장로들에게 이르시되 `너희가 강도를 잡는 것 같이 검과 몽치를 가지고 나왔느냐 ?","reference":"누가복음 22:52","category":"$undefined"},{"id":"25918","book":"누가복음","book_name":"누가복음","chapter":22,"verse":53,"text":"내가 날마다 너희와 함께 성전에 있을 때에 내게 손을 대지 아니하였도다 그러나 이제는 너희 때요 어두움의 권세로다' 하시더라","reference":"누가복음 22:53","category":"$undefined"},{"id":"25919","book":"누가복음","book_name":"누가복음","chapter":22,"verse":54,"text":"예수를 잡아 끌고 대제사장의 집으로 들어갈쌔 베드로가 멀찍이 따라가니라","reference":"누가복음 22:54","category":"$undefined"},{"id":"25920","book":"누가복음","book_name":"누가복음","chapter":22,"verse":55,"text":"사람들이 뜰 가운데 불을 피우고 함께 앉았는지라 베드로도 그 가운데 앉았더니","reference":"누가복음 22:55","category":"$undefined"},{"id":"25921","book":"누가복음","book_name":"누가복음","chapter":22,"verse":56,"text":"한 비자가 베드로의 불빛을 향하여 앉은 것을 보고 주목하여 가로되 이 사람도 그와 함께 있었느니라 하니","reference":"누가복음 22:56","category":"$undefined"},{"id":"25922","book":"누가복음","book_name":"누가복음","chapter":22,"verse":57,"text":"베드로가 부인하여 가로되 `이 여자여, 내가 저를 알지 못하노라' 하더라","reference":"누가복음 22:57","category":"$undefined"},{"id":"25923","book":"누가복음","book_name":"누가복음","chapter":22,"verse":58,"text":"조금 후에 다른 사람이 보고 가로되 `너도 그 당(黨)이라' 하거늘 베드로가 가로되 `이 사람아 나는 아니로라' 하더라","reference":"누가복음 22:58","category":"$undefined"},{"id":"25924","book":"누가복음","book_name":"누가복음","chapter":22,"verse":59,"text":"한 시쯤 있다가 또 한 사람이 장담하여 가로되 `이는 갈릴리 사람이니 참으로 그와 함께 있었느니라'","reference":"누가복음 22:59","category":"$undefined"},{"id":"25925","book":"누가복음","book_name":"누가복음","chapter":22,"verse":60,"text":"베드로가 가로되 `이 사람아, 나는 너 하는 말을 알지 못하노라'고 방금 말할 때에 닭이 곧 울더라","reference":"누가복음 22:60","category":"$undefined"},{"id":"25926","book":"누가복음","book_name":"누가복음","chapter":22,"verse":61,"text":"주께서 돌이켜 베드로를 보시니 베드로가 주의 말씀 곧 오늘 닭 울기 전에 네가 세 번 나를 부인하리라 하심이 생각나서","reference":"누가복음 22:61","category":"$undefined"},{"id":"25927","book":"누가복음","book_name":"누가복음","chapter":22,"verse":62,"text":"밖에 나가서 심히 통곡하니라","reference":"누가복음 22:62","category":"$undefined"},{"id":"25928","book":"누가복음","book_name":"누가복음","chapter":22,"verse":63,"text":"지키는 사람들이 예수를 희롱하고 때리며","reference":"누가복음 22:63","category":"$undefined"},{"id":"25929","book":"누가복음","book_name":"누가복음","chapter":22,"verse":64,"text":"그의 눈을 가리우고 물어 가로되 `선지자 노릇하라 너를 친 자가 누구냐 ?' 하고","reference":"누가복음 22:64","category":"$undefined"},{"id":"25930","book":"누가복음","book_name":"누가복음","chapter":22,"verse":65,"text":"이 외에도 많은 말로 욕하더라","reference":"누가복음 22:65","category":"$undefined"},{"id":"25931","book":"누가복음","book_name":"누가복음","chapter":22,"verse":66,"text":"날이 새매 백성의 장로들 곧 대제사장들과 서기관들이 모이어 예수를 그 공회로 끌어들여","reference":"누가복음 22:66","category":"$undefined"},{"id":"25932","book":"누가복음","book_name":"누가복음","chapter":22,"verse":67,"text":"가로되 `네가 그리스도여든 우리에게 말하라' 대답하시되 `내가 말할지라도 너희가 믿지 아니할 것이요","reference":"누가복음 22:67","category":"$undefined"},{"id":"25933","book":"누가복음","book_name":"누가복음","chapter":22,"verse":68,"text":"내가 물어도 너희가 대답지 아니할 것이니라","reference":"누가복음 22:68","category":"$undefined"},{"id":"25934","book":"누가복음","book_name":"누가복음","chapter":22,"verse":69,"text":"그러나 이제 후로는 인자가 하나님의 권능의 우편에 앉아 있으리라' 하시니","reference":"누가복음 22:69","category":"$undefined"},{"id":"25935","book":"누가복음","book_name":"누가복음","chapter":22,"verse":70,"text":"다 가로되 `그러면 네가 하나님의 아들이냐 ?' 대답하시되 `너희 말과 같이 내가 그니라 !'","reference":"누가복음 22:70","category":"$undefined"},{"id":"25936","book":"누가복음","book_name":"누가복음","chapter":22,"verse":71,"text":"저희가 가로되 `어찌 더 증거를 요구하리요 우리가 친히 그 입에서 들었노라' 하더라","reference":"누가복음 22:71","category":"$undefined"}],"bookSlug":"luke"}]
