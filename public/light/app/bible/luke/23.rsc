2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":23,"verses":[{"id":"25937","book":"누가복음","book_name":"누가복음","chapter":23,"verse":1,"text":"무리가 다 일어나 예수를 빌라도에게 끌고 가서","reference":"누가복음 23:1","category":"$undefined"},{"id":"25938","book":"누가복음","book_name":"누가복음","chapter":23,"verse":2,"text":"고소하여 가로되 `우리가 이 사람을 보매 우리 백성을 미혹하고 가이사에게 세 바치는 것을 금하며 자칭 왕 그리스도라 하더이다' 하니","reference":"누가복음 23:2","category":"$undefined"},{"id":"25939","book":"누가복음","book_name":"누가복음","chapter":23,"verse":3,"text":"빌라도가 예수께 물어 가로되 `네가 유대인의 왕이냐 ?' 대답하여 가라사대 `네 말이 옳도다'","reference":"누가복음 23:3","category":"$undefined"},{"id":"25940","book":"누가복음","book_name":"누가복음","chapter":23,"verse":4,"text":"빌라도가 대제사장들과 무리에게 이르되 `내가 보니 이 사람에게 죄가 없도다' 하니","reference":"누가복음 23:4","category":"$undefined"},{"id":"25941","book":"누가복음","book_name":"누가복음","chapter":23,"verse":5,"text":"무리가 더욱 굳세게 말하되 `저가 온 유대에서 가르치고 갈릴리에서부터 시작하여 여기까지 와서 백성을 소동케 하나이다'","reference":"누가복음 23:5","category":"$undefined"},{"id":"25942","book":"누가복음","book_name":"누가복음","chapter":23,"verse":6,"text":"빌라도가 듣고 묻되 `저가 갈릴리 사람이냐 ?' 하여","reference":"누가복음 23:6","category":"$undefined"},{"id":"25943","book":"누가복음","book_name":"누가복음","chapter":23,"verse":7,"text":"헤롯의 관할에 속한 줄을 알고 헤롯에게 보내니 때에 헤롯이 예루살렘에 있더라","reference":"누가복음 23:7","category":"$undefined"},{"id":"25944","book":"누가복음","book_name":"누가복음","chapter":23,"verse":8,"text":"헤롯이 예수를 보고 심히 기뻐하니 이는 그의 소문을 들었으므로 보고자 한 지 오래였고 또한 무엇이나 이적 행하심을 볼까 바랐던 연고러라","reference":"누가복음 23:8","category":"$undefined"},{"id":"25945","book":"누가복음","book_name":"누가복음","chapter":23,"verse":9,"text":"여러 말로 물으나 아무 말도 대답지 아니하시니","reference":"누가복음 23:9","category":"$undefined"},{"id":"25946","book":"누가복음","book_name":"누가복음","chapter":23,"verse":10,"text":"대제사장들과 서기관들이 서서 힘써 고소하더라","reference":"누가복음 23:10","category":"$undefined"},{"id":"25947","book":"누가복음","book_name":"누가복음","chapter":23,"verse":11,"text":"헤롯이 그 군병들과 함께 예수를 업신여기며 희롱하고 빛난 옷을 입혀 빌라도에게 도로 보내니","reference":"누가복음 23:11","category":"$undefined"},{"id":"25948","book":"누가복음","book_name":"누가복음","chapter":23,"verse":12,"text":"헤롯과 빌라도가 전에는 원수이었으나 당일에 서로 친구가 되니라","reference":"누가복음 23:12","category":"$undefined"},{"id":"25949","book":"누가복음","book_name":"누가복음","chapter":23,"verse":13,"text":"빌라도가 대제사장들과 관원들과 백성을 불러 모으고","reference":"누가복음 23:13","category":"$undefined"},{"id":"25950","book":"누가복음","book_name":"누가복음","chapter":23,"verse":14,"text":"이르되 `너희가 이 사람을 백성을 미혹하는 자라 하여 내게 끌어왔도다 보라 내가 너희 앞에서 사실하였으되 너희의 고소하는 일에 대하여 이 사람에게 죄를 찾지 못하였고","reference":"누가복음 23:14","category":"$undefined"},{"id":"25951","book":"누가복음","book_name":"누가복음","chapter":23,"verse":15,"text":"헤롯이 또한 그렇게 하여 저를 우리에게 도로 보내었도다 보라 저의 행한 것은 죽일 일이 없느니라","reference":"누가복음 23:15","category":"$undefined"},{"id":"25952","book":"누가복음","book_name":"누가복음","chapter":23,"verse":16,"text":"그러므로 때려서 놓겠노라'","reference":"누가복음 23:16","category":"$undefined"},{"id":"25953","book":"누가복음","book_name":"누가복음","chapter":23,"verse":17,"text":"(없 음)","reference":"누가복음 23:17","category":"$undefined"},{"id":"25954","book":"누가복음","book_name":"누가복음","chapter":23,"verse":18,"text":"무리가 일제히 소리질러 가로되 `이 사람을 없이하고 바라바를 우리에게 놓아 주소서'하니","reference":"누가복음 23:18","category":"$undefined"},{"id":"25955","book":"누가복음","book_name":"누가복음","chapter":23,"verse":19,"text":"이 바라바는 성중에서 일어난 민란과 살인을 인하여 옥에 갇힌 자러라","reference":"누가복음 23:19","category":"$undefined"},{"id":"25956","book":"누가복음","book_name":"누가복음","chapter":23,"verse":20,"text":"빌라도는 예수를 놓고자 하여 다시 저희에게 말하되","reference":"누가복음 23:20","category":"$undefined"},{"id":"25957","book":"누가복음","book_name":"누가복음","chapter":23,"verse":21,"text":"저희는 소리질러 가로되 `저를 십자가에 못박게 하소서 ! 십자가에 못박게 하소서 !' 하는지라","reference":"누가복음 23:21","category":"$undefined"},{"id":"25958","book":"누가복음","book_name":"누가복음","chapter":23,"verse":22,"text":"빌라도가 세 번째 말하되 `이 사람이 무슨 악한 일을 하였느냐 ? 나는 그 죽일 죄를 찾지 못하였나니 때려서 놓으리라'한대","reference":"누가복음 23:22","category":"$undefined"},{"id":"25959","book":"누가복음","book_name":"누가복음","chapter":23,"verse":23,"text":"저희가 큰 소리로 재촉하여 십자가에 못 박기를 구하니 저희의 소리가 이긴지라","reference":"누가복음 23:23","category":"$undefined"},{"id":"25960","book":"누가복음","book_name":"누가복음","chapter":23,"verse":24,"text":"이에 빌라도가 저희의 구하는대로 하기를 언도하고","reference":"누가복음 23:24","category":"$undefined"},{"id":"25961","book":"누가복음","book_name":"누가복음","chapter":23,"verse":25,"text":"저희의 구하는 자 곧 민란과 살인을 인하여 옥에 갇힌 자를 놓고 예수를 넘겨 주어 저희 뜻대로 하게 하니라","reference":"누가복음 23:25","category":"$undefined"},{"id":"25962","book":"누가복음","book_name":"누가복음","chapter":23,"verse":26,"text":"저희가 예수를 끌고 갈 때에 시몬이라는 구레네 사람이 시골로서 오는 것을 잡아 그에게 십자가를 지워 예수를 좇게 하더라","reference":"누가복음 23:26","category":"$undefined"},{"id":"25963","book":"누가복음","book_name":"누가복음","chapter":23,"verse":27,"text":"또 백성과 및 그를 위하여 가슴을 치며 슬피 우는 여자의 큰 무리가 따라 오는지라","reference":"누가복음 23:27","category":"$undefined"},{"id":"25964","book":"누가복음","book_name":"누가복음","chapter":23,"verse":28,"text":"예수께서 돌이켜 그들을 향하여 가라사대 `예루살렘의 딸들아 ! 나를 위하여 울지 말고 너희와 너희 자녀를 위하여 울라","reference":"누가복음 23:28","category":"$undefined"},{"id":"25965","book":"누가복음","book_name":"누가복음","chapter":23,"verse":29,"text":"보라, 날이 이르면 사람이 말하기를 수태 못하는 이와 해산하지 못한 배와 먹이지 못한 젖이 복이 있다 하리라","reference":"누가복음 23:29","category":"$undefined"},{"id":"25966","book":"누가복음","book_name":"누가복음","chapter":23,"verse":30,"text":"그 때에 사람이 산들을 대하여 우리 위에 무너지라 하며 작은 산들을 대하여 우리를 덮으라 하리라","reference":"누가복음 23:30","category":"$undefined"},{"id":"25967","book":"누가복음","book_name":"누가복음","chapter":23,"verse":31,"text":"푸른 나무에도 이같이 하거든 마른 나무에는 어떻게 되리요' 하시니라","reference":"누가복음 23:31","category":"$undefined"},{"id":"25968","book":"누가복음","book_name":"누가복음","chapter":23,"verse":32,"text":"또 다른 두 행악자도 사형을 받게 되어 예수와 함께 끌려 가니라","reference":"누가복음 23:32","category":"$undefined"},{"id":"25969","book":"누가복음","book_name":"누가복음","chapter":23,"verse":33,"text":"해골이라 하는 곳에 이르러 거기서 예수를 십자가에 못 박고 두 행악자도 그렇게 하니 하나는 우편에 하나는 좌편에 있더라","reference":"누가복음 23:33","category":"$undefined"},{"id":"25970","book":"누가복음","book_name":"누가복음","chapter":23,"verse":34,"text":"이에 예수께서 가라사대 `아버지여 저희를 사하여 주옵소서 자기의 하는 것을 알지 못함이니이다' 하시더라 저희가 그의 옷을 나눠 제비 뽑을쌔","reference":"누가복음 23:34","category":"$undefined"},{"id":"25971","book":"누가복음","book_name":"누가복음","chapter":23,"verse":35,"text":"백성은 서서 구경하며 관원들도 비웃어 가로되 `저가 남을 구원하였으니 만일 하나님의 택하신 자 그리스도여든 자기도 구원할지어다'하고","reference":"누가복음 23:35","category":"$undefined"},{"id":"25972","book":"누가복음","book_name":"누가복음","chapter":23,"verse":36,"text":"군병들도 희롱하면서 나아와 신포도주를 주며","reference":"누가복음 23:36","category":"$undefined"},{"id":"25973","book":"누가복음","book_name":"누가복음","chapter":23,"verse":37,"text":"가로되 `네가 만일 유대인의 왕이어든 네가 너를 구원하라' 하더라","reference":"누가복음 23:37","category":"$undefined"},{"id":"25974","book":"누가복음","book_name":"누가복음","chapter":23,"verse":38,"text":"그의 위에 이는 유대인의 왕이라 쓴 패가 있더라","reference":"누가복음 23:38","category":"$undefined"},{"id":"25975","book":"누가복음","book_name":"누가복음","chapter":23,"verse":39,"text":"달린 행악자 중 하나는 비방하여 가로되 `네가 그리스도가 아니냐 ? 너와 우리를 구원하라' 하되","reference":"누가복음 23:39","category":"$undefined"},{"id":"25976","book":"누가복음","book_name":"누가복음","chapter":23,"verse":40,"text":"하나는 그 사람을 꾸짖어 가로되 `네가 동일한 정죄를 받고서도 하나님을 두려워 아니하느냐 ?","reference":"누가복음 23:40","category":"$undefined"},{"id":"25977","book":"누가복음","book_name":"누가복음","chapter":23,"verse":41,"text":"우리는 우리의 행한 일에 상당한 보응을 받는 것이니 이에 당연하거니와 이 사람의 행한 것은 옳지 않은 것이 없느니라' 하고","reference":"누가복음 23:41","category":"$undefined"},{"id":"25978","book":"누가복음","book_name":"누가복음","chapter":23,"verse":42,"text":"가로되 `예수여 당신의 나라에 임하실 때에 나를 생각하소서 !' 하니","reference":"누가복음 23:42","category":"$undefined"},{"id":"25979","book":"누가복음","book_name":"누가복음","chapter":23,"verse":43,"text":"예수께서 이르시되 `내가 진실로 네게 이르노니 오늘 네가 나와 함께 낙원에 있으리라 !' 하시니라","reference":"누가복음 23:43","category":"$undefined"},{"id":"25980","book":"누가복음","book_name":"누가복음","chapter":23,"verse":44,"text":"때가 제 육시쯤 되어 해가 빛을 잃고 온 땅에 어두움이 임하여 제 구시까지 계속하며","reference":"누가복음 23:44","category":"$undefined"},{"id":"25981","book":"누가복음","book_name":"누가복음","chapter":23,"verse":45,"text":"성소의 휘장이 한가운데가 찢어지더라","reference":"누가복음 23:45","category":"$undefined"},{"id":"25982","book":"누가복음","book_name":"누가복음","chapter":23,"verse":46,"text":"예수께서 큰 소리로 불러 가라사대 `아버지여 ! 내 영혼을 아버지 손에 부탁하나이다 !' 하고 이 말씀을 하신 후 운명하시다","reference":"누가복음 23:46","category":"$undefined"},{"id":"25983","book":"누가복음","book_name":"누가복음","chapter":23,"verse":47,"text":"이 그 된 일을 보고 하나님께 영광을 돌려 가로되 `이 사람은 정녕 의인이었도다' 하고","reference":"누가복음 23:47","category":"$undefined"},{"id":"25984","book":"누가복음","book_name":"누가복음","chapter":23,"verse":48,"text":"이를 구경하러 모인 무리도 그 된 일을 보고 다 가슴을 두드리며 돌아가고","reference":"누가복음 23:48","category":"$undefined"},{"id":"25985","book":"누가복음","book_name":"누가복음","chapter":23,"verse":49,"text":"예수의 아는 자들과 및 갈릴리로부터 따라온 여자들도 다 멀리 서서 이 일을 보니라","reference":"누가복음 23:49","category":"$undefined"},{"id":"25986","book":"누가복음","book_name":"누가복음","chapter":23,"verse":50,"text":"공회 의원으로 선하고 의로운 요셉이라 하는 사람이 있으니","reference":"누가복음 23:50","category":"$undefined"},{"id":"25987","book":"누가복음","book_name":"누가복음","chapter":23,"verse":51,"text":"(저희의 결의와 행사에 가타 하지 아니한 자라) 그는 유대인의 동네 아리마대 사람이요 하나님의 나라를 기다리는 자러니","reference":"누가복음 23:51","category":"$undefined"},{"id":"25988","book":"누가복음","book_name":"누가복음","chapter":23,"verse":52,"text":"빌라도에게 가서 예수의 시체를 달라 하여","reference":"누가복음 23:52","category":"$undefined"},{"id":"25989","book":"누가복음","book_name":"누가복음","chapter":23,"verse":53,"text":"이를 내려 세마포로 싸고 아직 사람을 장사한 일이 없는 바위에 판 무덤에 넣어 두니","reference":"누가복음 23:53","category":"$undefined"},{"id":"25990","book":"누가복음","book_name":"누가복음","chapter":23,"verse":54,"text":"이 날은 예비일이요 안식일이 거의 되었더라","reference":"누가복음 23:54","category":"$undefined"},{"id":"25991","book":"누가복음","book_name":"누가복음","chapter":23,"verse":55,"text":"갈릴리에서 예수와 함께 온 여자들이 뒤를 좇아 그 무덤과 그의 시체를 어떻게 둔 것을 보고","reference":"누가복음 23:55","category":"$undefined"},{"id":"25992","book":"누가복음","book_name":"누가복음","chapter":23,"verse":56,"text":"돌아가 향품과 향유를 예비하더라 계명을 좇아 안식일에 쉬더라","reference":"누가복음 23:56","category":"$undefined"}],"bookSlug":"luke"}]
