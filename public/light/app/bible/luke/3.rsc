2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":3,"verses":[{"id":"25027","book":"누가복음","book_name":"누가복음","chapter":3,"verse":1,"text":"디베료 가이사가 위에 있은 지 열다섯 해 곧 본디오 빌라도가 유대의 총독으로,헤롯이 갈릴리의 분봉왕으로,그 동생 빌립이 이두래와 드라고닛 지방의 분봉왕으로,루사니아가 아빌레네의 분봉왕으로","reference":"누가복음 3:1","category":"$undefined"},{"id":"25028","book":"누가복음","book_name":"누가복음","chapter":3,"verse":2,"text":"안나스와 가야바가 대제사장으로 있을 때에 하나님의 말씀이 빈들에서 사가랴의 아들 요한에게 임한지라","reference":"누가복음 3:2","category":"$undefined"},{"id":"25029","book":"누가복음","book_name":"누가복음","chapter":3,"verse":3,"text":"요한이 요단강 부근 각처에 와서 죄 사함을 얻게 하는 회개의 세례를 전파하니","reference":"누가복음 3:3","category":"$undefined"},{"id":"25030","book":"누가복음","book_name":"누가복음","chapter":3,"verse":4,"text":"선지자 이사야의 책에 쓴 바 광야에 외치는 자의 소리가 있어 가로되 너희는 주의 길을 예비하라 그의 첩경을 평탄케 하라","reference":"누가복음 3:4","category":"$undefined"},{"id":"25031","book":"누가복음","book_name":"누가복음","chapter":3,"verse":5,"text":"모든 골짜기가 메워지고 모든 산과 작은 산이 낮아지고 굽은 것이 곧아지고 험한 길이 평탄하여 질 것이요","reference":"누가복음 3:5","category":"$undefined"},{"id":"25032","book":"누가복음","book_name":"누가복음","chapter":3,"verse":6,"text":"모든 육체가 하나님의 구원하심을 보리라 함과 같으니라","reference":"누가복음 3:6","category":"$undefined"},{"id":"25033","book":"누가복음","book_name":"누가복음","chapter":3,"verse":7,"text":"요한이 세례 받으러 나오는 무리에게 이르되 `독사의 자식들아 누가 너희를 가르쳐 장차 올 진노를 피하라 하더냐","reference":"누가복음 3:7","category":"$undefined"},{"id":"25034","book":"누가복음","book_name":"누가복음","chapter":3,"verse":8,"text":"그러므로 회개에 합당한 열매를 맺고 속으로 아브라함이 우리 조상이라 말하지 말라 내가 너희에게 이르노니 하나님이 능히 이 돌들로도 아브라함의 자손이 되게 하시리라","reference":"누가복음 3:8","category":"$undefined"},{"id":"25035","book":"누가복음","book_name":"누가복음","chapter":3,"verse":9,"text":"이미 도끼가 나무 뿌리에 놓였으니 좋은 열매 맺지 아니하는 나무마다 찍혀 불에 던지우리라'","reference":"누가복음 3:9","category":"$undefined"},{"id":"25036","book":"누가복음","book_name":"누가복음","chapter":3,"verse":10,"text":"무리가 물어 가로되 `그러하면 우리가 무엇을 하리이까 ?'","reference":"누가복음 3:10","category":"$undefined"},{"id":"25037","book":"누가복음","book_name":"누가복음","chapter":3,"verse":11,"text":"대답하여 가로되 `옷 두 벌 있는 자는 옷 없는 자에게 나눠 줄 것이요 먹을 것이 있는 자도 그렇게 할 것이니라' 하고","reference":"누가복음 3:11","category":"$undefined"},{"id":"25038","book":"누가복음","book_name":"누가복음","chapter":3,"verse":12,"text":"세리들도 세례를 받고자 하여 와서 가로되 `선생이여, 우리는 무엇을 하리이까 ?' 하매","reference":"누가복음 3:12","category":"$undefined"},{"id":"25039","book":"누가복음","book_name":"누가복음","chapter":3,"verse":13,"text":"가로되 `정한 세 외에는 늑징치 말라' 하고","reference":"누가복음 3:13","category":"$undefined"},{"id":"25040","book":"누가복음","book_name":"누가복음","chapter":3,"verse":14,"text":"군병들도 물어 가로되 우리는 무엇을 하리이까 ? 하매 가로되 사람에게 강포하지 말며 무소하지 말고 받는 요(料)를 족한 줄로 알라 하니라","reference":"누가복음 3:14","category":"$undefined"},{"id":"25041","book":"누가복음","book_name":"누가복음","chapter":3,"verse":15,"text":"백성들이 바라고 기다리므로 모든 사람들이 요한을 혹 그리스도신가 심중에 의논하니","reference":"누가복음 3:15","category":"$undefined"},{"id":"25042","book":"누가복음","book_name":"누가복음","chapter":3,"verse":16,"text":"요한이 모든 사람에게 대답하여 가로되 `나는 물로 너희에게 세례를 주거니와 나보다 능력이 많으신 이가 오시나니 나는 그 신들메를 풀기도 감당치 못하겠노라 그는 성령과 불로 너희에게 세례를 주실 것이요","reference":"누가복음 3:16","category":"$undefined"},{"id":"25043","book":"누가복음","book_name":"누가복음","chapter":3,"verse":17,"text":"손에 키를 들고 자기의 타작 마당을 정하게 하사 알곡은 모아 곡간에 들이고 쭉정이는 꺼지지 않는 불에 태우시리라'","reference":"누가복음 3:17","category":"$undefined"},{"id":"25044","book":"누가복음","book_name":"누가복음","chapter":3,"verse":18,"text":"또 기타 여러가지로 권하여 백성에게 좋은 소식을 전하였으나","reference":"누가복음 3:18","category":"$undefined"},{"id":"25045","book":"누가복음","book_name":"누가복음","chapter":3,"verse":19,"text":"분봉왕 헤롯은 그 동생의 아내 헤로디아의 일과 또 그의 행한 모든 악한 일을 인하여 요한에게 책망을 받고","reference":"누가복음 3:19","category":"$undefined"},{"id":"25046","book":"누가복음","book_name":"누가복음","chapter":3,"verse":20,"text":"이 위에 한 가지 악을 더 하여 요한을 옥에 가두니라","reference":"누가복음 3:20","category":"$undefined"},{"id":"25047","book":"누가복음","book_name":"누가복음","chapter":3,"verse":21,"text":"백성이 다 세례를 받을새 예수도 세례를 받으시고 기도하실 때에 하늘이 열리며","reference":"누가복음 3:21","category":"$undefined"},{"id":"25048","book":"누가복음","book_name":"누가복음","chapter":3,"verse":22,"text":"성령이 형체로 비둘기같이 그의 위에 강림하시더니 하늘로서 소리가 나기를 `너는 내 사랑하는 아들이라 내가 너를 기뻐하노라' 하시니라","reference":"누가복음 3:22","category":"$undefined"},{"id":"25049","book":"누가복음","book_name":"누가복음","chapter":3,"verse":23,"text":"예수께서 가르치심을 시작할 때에 삼십세 쯤 되시니라 사람들의 아는대로는 요셉의 아들이니 요셉의 이상은 헬리요","reference":"누가복음 3:23","category":"$undefined"},{"id":"25050","book":"누가복음","book_name":"누가복음","chapter":3,"verse":24,"text":"그 이상은 맛닷이요, 그 이상은 레위요, 그 이상은 멜기요, 그 이상은 얀나요, 그 이상은 요셉이요","reference":"누가복음 3:24","category":"$undefined"},{"id":"25051","book":"누가복음","book_name":"누가복음","chapter":3,"verse":25,"text":"그 이상은 맛다디아요, 그 이상은 아모스요, 그 이상은 나훔이요, 그 이상은 에슬리요, 그 이상은 낙개요","reference":"누가복음 3:25","category":"$undefined"},{"id":"25052","book":"누가복음","book_name":"누가복음","chapter":3,"verse":26,"text":"그 이상은 마앗이요, 그 이상은 맛다디아요, 그 이상은 서머인이요, 그 이상은 요섹이요, 그 이상은 요다요","reference":"누가복음 3:26","category":"$undefined"},{"id":"25053","book":"누가복음","book_name":"누가복음","chapter":3,"verse":27,"text":"그 이상은 요아난이요, 그 이상은 레사요, 그 이상은 스룹바벨이요, 그 이상은 스알디엘이요, 그 이상은 네리요","reference":"누가복음 3:27","category":"$undefined"},{"id":"25054","book":"누가복음","book_name":"누가복음","chapter":3,"verse":28,"text":"그 이상은 멜기요, 그 이상은 앗디요, 그 이상은 고삼이요, 그 이상은 엘마담이요, 그 이상은 에르요","reference":"누가복음 3:28","category":"$undefined"},{"id":"25055","book":"누가복음","book_name":"누가복음","chapter":3,"verse":29,"text":"그 이상은 예수요, 그 이상은 엘리에서요, 그 이상은 요림이요, 그 이상은 맛닷이요, 그 이상은 레위요","reference":"누가복음 3:29","category":"$undefined"},{"id":"25056","book":"누가복음","book_name":"누가복음","chapter":3,"verse":30,"text":"그 이상은 시므온이요, 그 이상은 유다요, 그 이상은 요셉이요, 그 이상은 요남이요, 그 이상은 엘리아김이요","reference":"누가복음 3:30","category":"$undefined"},{"id":"25057","book":"누가복음","book_name":"누가복음","chapter":3,"verse":31,"text":"그 이상은 멜레아요, 그 이상은 멘나요, 그 이상은 맛다다요, 그 이상은 나단이요, 그 이상은 다윗이요","reference":"누가복음 3:31","category":"$undefined"},{"id":"25058","book":"누가복음","book_name":"누가복음","chapter":3,"verse":32,"text":"그 이상은 이새요, 그 이상은 오벳이요, 그 이상은 보아스요, 그 이상은 살몬이요, 그 이상은 나손이요","reference":"누가복음 3:32","category":"$undefined"},{"id":"25059","book":"누가복음","book_name":"누가복음","chapter":3,"verse":33,"text":"그 이상은 아미나답이요, 그 이상은 아니요, 그 이상은 헤스론이요, 그 이상은 베레스요, 그 이상은 유다요","reference":"누가복음 3:33","category":"$undefined"},{"id":"25060","book":"누가복음","book_name":"누가복음","chapter":3,"verse":34,"text":"그 이상은 야곱이요, 그 이상은 이삭이요, 그 이상은 아브라함이요, 그 이상은 데라요, 그 이상은 나홀이요","reference":"누가복음 3:34","category":"$undefined"},{"id":"25061","book":"누가복음","book_name":"누가복음","chapter":3,"verse":35,"text":"그 이상은 스룩이요, 그 이상은 르우요, 그 이상은 벨렉이요, 그 이상은 헤버요, 그 이상은 살라요","reference":"누가복음 3:35","category":"$undefined"},{"id":"25062","book":"누가복음","book_name":"누가복음","chapter":3,"verse":36,"text":"그 이상은 가이난이요, 그 이상은 아박삿이요, 그 이상은 셈이요, 그 이상은 노아요, 그 이상은 레멕이요","reference":"누가복음 3:36","category":"$undefined"},{"id":"25063","book":"누가복음","book_name":"누가복음","chapter":3,"verse":37,"text":"그 이상은 므두셀라요, 그 이상은 에녹이요, 그 이상은 야렛이요, 그 이상은 마할랄렐이요, 그 이상은 가이난이요","reference":"누가복음 3:37","category":"$undefined"},{"id":"25064","book":"누가복음","book_name":"누가복음","chapter":3,"verse":38,"text":"그 이상은 에노스요, 그 이상은 셋이요, 그 이상은 아담이요, 그 이상은 하나님이시니라","reference":"누가복음 3:38","category":"$undefined"}],"bookSlug":"luke"}]
