2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":4,"verses":[{"id":"25065","book":"누가복음","book_name":"누가복음","chapter":4,"verse":1,"text":"예수께서 성령의 충만함을 입어 요단강에서 돌아오사 광야에서 사십 일 동안 성령에게 이끌리시며","reference":"누가복음 4:1","category":"$undefined"},{"id":"25066","book":"누가복음","book_name":"누가복음","chapter":4,"verse":2,"text":"마귀에게 시험을 받으시더라 이 모든 날에 아무 것도 잡수시지 아니하시니 날 수가 다하매 주리신지라","reference":"누가복음 4:2","category":"$undefined"},{"id":"25067","book":"누가복음","book_name":"누가복음","chapter":4,"verse":3,"text":"마귀가 가로되 `네가 만일 하나님의 아들이어든 이 돌들에게 명하여 떡덩이가 되게 하라'","reference":"누가복음 4:3","category":"$undefined"},{"id":"25068","book":"누가복음","book_name":"누가복음","chapter":4,"verse":4,"text":"예수께서 대답하시되 `기록하기를 사람이 떡으로만 살 것이 아니라 하였느니라'","reference":"누가복음 4:4","category":"$undefined"},{"id":"25069","book":"누가복음","book_name":"누가복음","chapter":4,"verse":5,"text":"마귀가 또 예수를 이끌고 올라가서 순식간에 천하 만국을 보이며","reference":"누가복음 4:5","category":"$undefined"},{"id":"25070","book":"누가복음","book_name":"누가복음","chapter":4,"verse":6,"text":"가로되 `이 모든 권세와 그 영광을 내가 네게 주리라 이것은 내게 넘겨 준 것이므로 나의 원하는 자에게 주노라","reference":"누가복음 4:6","category":"$undefined"},{"id":"25071","book":"누가복음","book_name":"누가복음","chapter":4,"verse":7,"text":"그러므로 네가 만일 내게 절하면 다 네 것이 되리라'","reference":"누가복음 4:7","category":"$undefined"},{"id":"25072","book":"누가복음","book_name":"누가복음","chapter":4,"verse":8,"text":"예수께서 대답하여 가라사대 기록하기를 `주 너의 하나님께 경배하고 다만 그를 섬기라 하였느니라'","reference":"누가복음 4:8","category":"$undefined"},{"id":"25073","book":"누가복음","book_name":"누가복음","chapter":4,"verse":9,"text":"또 이끌고 예루살렘으로 가서 성전 꼭대기에 세우고 가로되 `네가 만일 하나님의 아들이어든 여기서 뛰어 내리라","reference":"누가복음 4:9","category":"$undefined"},{"id":"25074","book":"누가복음","book_name":"누가복음","chapter":4,"verse":10,"text":"기록하였으되 하나님이 너를 위하여 그 사자들을 명하사 너를 지키게 하시리라 하였고","reference":"누가복음 4:10","category":"$undefined"},{"id":"25075","book":"누가복음","book_name":"누가복음","chapter":4,"verse":11,"text":"또한 저희가 손으로 너를 받들어 네 발이 돌에 부딪히지 않게 하시리라 하였느니라'","reference":"누가복음 4:11","category":"$undefined"},{"id":"25076","book":"누가복음","book_name":"누가복음","chapter":4,"verse":12,"text":"예수께서 대답하여 가라사대 `말씀하기를 주 너의 하나님을 시험치 말라 하였느니라'","reference":"누가복음 4:12","category":"$undefined"},{"id":"25077","book":"누가복음","book_name":"누가복음","chapter":4,"verse":13,"text":"마귀가 모든 시험을 다 한 후에 얼마 동안 떠나리라","reference":"누가복음 4:13","category":"$undefined"},{"id":"25078","book":"누가복음","book_name":"누가복음","chapter":4,"verse":14,"text":"예수께서 성령의 권능으로 갈릴리에 돌아가시니 그 소문이 사방에 퍼졌고","reference":"누가복음 4:14","category":"$undefined"},{"id":"25079","book":"누가복음","book_name":"누가복음","chapter":4,"verse":15,"text":"친히 그 여러 회당에서 가르치시매 뭇 사람에게 칭송을 받으시더라","reference":"누가복음 4:15","category":"$undefined"},{"id":"25080","book":"누가복음","book_name":"누가복음","chapter":4,"verse":16,"text":"예수께서 그 자라나신 곳 나사렛에 이르사 안식일에 자기 규례대로 회당에 들어가사 성경을 읽으려고 서시매","reference":"누가복음 4:16","category":"$undefined"},{"id":"25081","book":"누가복음","book_name":"누가복음","chapter":4,"verse":17,"text":"선지자 이사야의 글을 드리거늘 책을 펴서 이렇게 기록한 데를 찾으시니 곧","reference":"누가복음 4:17","category":"$undefined"},{"id":"25082","book":"누가복음","book_name":"누가복음","chapter":4,"verse":18,"text":"주의 성령이 내게 임하셨으니 이는 가난한 자에게 복음을 전하게 하시려고 내게 기름을 부으시고 나를 보내사 포로된 자에게 자유를 눈먼 자에게 다시보게 함을 전파하며 눌린 자를 자유케 하고","reference":"누가복음 4:18","category":"$undefined"},{"id":"25083","book":"누가복음","book_name":"누가복음","chapter":4,"verse":19,"text":"주의 은혜의 해를 전파하게 하려 하심이라 하였더라","reference":"누가복음 4:19","category":"$undefined"},{"id":"25084","book":"누가복음","book_name":"누가복음","chapter":4,"verse":20,"text":"책을 덮어 그 맡은 자에게 주시고 앉으시니 회당에 있는 자들이 다 주목하여 보더라","reference":"누가복음 4:20","category":"$undefined"},{"id":"25085","book":"누가복음","book_name":"누가복음","chapter":4,"verse":21,"text":"이에 예수께서 저희에게 말씀하시되 `이 글이 오늘날 너희 귀에 응하였느니라' 하시니","reference":"누가복음 4:21","category":"$undefined"},{"id":"25086","book":"누가복음","book_name":"누가복음","chapter":4,"verse":22,"text":"저희가 다 그를 증거하고 그 입으로 나오는 바 은혜로운 말을 기이히 여겨 가로되 `이 사람이 요셉의 아들이 아니냐 ?'","reference":"누가복음 4:22","category":"$undefined"},{"id":"25087","book":"누가복음","book_name":"누가복음","chapter":4,"verse":23,"text":"예수께서 저희에게 이르시되 `너희가 반드시 의원아 너를 고치라 하는 속담을 인증하여 내게 말하기를 우리의 들은 바 가버나움에서 행한 일을 네 고향 여기서도 행하라 하리라'","reference":"누가복음 4:23","category":"$undefined"},{"id":"25088","book":"누가복음","book_name":"누가복음","chapter":4,"verse":24,"text":"또 가라사대 `내가 진실로 너희에게 이르노니 선지자가 고향에서 환영을 받는 자가 없느니라","reference":"누가복음 4:24","category":"$undefined"},{"id":"25089","book":"누가복음","book_name":"누가복음","chapter":4,"verse":25,"text":"내가 참으로 너희에게 이르노니 엘리야 시대에 하늘이 세 해 여섯달을 닫히어 온 땅에 큰 흉년이 들었을 때에 이스라엘에 많은 과부가 있었으되","reference":"누가복음 4:25","category":"$undefined"},{"id":"25090","book":"누가복음","book_name":"누가복음","chapter":4,"verse":26,"text":"엘리야가 그 중 한 사람에게도 보내심을 받지 않고 오직 시돈 땅에 있는 사렙다의 한 과부에게 뿐이었으며","reference":"누가복음 4:26","category":"$undefined"},{"id":"25091","book":"누가복음","book_name":"누가복음","chapter":4,"verse":27,"text":"또 선지자 엘리사 때에 이스라엘에 많은 문둥이가 있었으되 그 중에 한 사람도 깨끗함을 얻지 못하고 오직 수리아 사람 나아만 뿐이니라'","reference":"누가복음 4:27","category":"$undefined"},{"id":"25092","book":"누가복음","book_name":"누가복음","chapter":4,"verse":28,"text":"회당에 있는 자들이 이것을 듣고 다 분이 가득하여","reference":"누가복음 4:28","category":"$undefined"},{"id":"25093","book":"누가복음","book_name":"누가복음","chapter":4,"verse":29,"text":"일어나 동네 밖으로 쫓아내어 그 동네가 건설된 산 낭떠러지까지 끌고 가서 밀쳐 내리치고자 하되","reference":"누가복음 4:29","category":"$undefined"},{"id":"25094","book":"누가복음","book_name":"누가복음","chapter":4,"verse":30,"text":"예수께서 저희 가운데로 지나서 가시니라","reference":"누가복음 4:30","category":"$undefined"},{"id":"25095","book":"누가복음","book_name":"누가복음","chapter":4,"verse":31,"text":"갈릴리 가버나움 동네에 내려오사 안식일에 가르치시매","reference":"누가복음 4:31","category":"$undefined"},{"id":"25096","book":"누가복음","book_name":"누가복음","chapter":4,"verse":32,"text":"저희가 그 가르치심에 놀라니 이는 그 말씀이 권세가 있음이러라","reference":"누가복음 4:32","category":"$undefined"},{"id":"25097","book":"누가복음","book_name":"누가복음","chapter":4,"verse":33,"text":"회당에 더러운 귀신 들린 사람이 있어 크게 소리질러 가로되","reference":"누가복음 4:33","category":"$undefined"},{"id":"25098","book":"누가복음","book_name":"누가복음","chapter":4,"verse":34,"text":"`아, 나사렛 예수여 ! 우리가 당신과 무슨 상관이 있나이까 ? 우리를 멸하러 왔나이까 ? 나는 당신이 누구인 줄 아노니 하나님의 거룩한자니이다'","reference":"누가복음 4:34","category":"$undefined"},{"id":"25099","book":"누가복음","book_name":"누가복음","chapter":4,"verse":35,"text":"예수께서 꾸짖어 가라사대 `잠잠하고 그 사람에게서 나오라' 하시니 귀신이 그 사람을 무리 중에 넘어 뜨리고 나오되 그 사람은 상하지 아니한지라","reference":"누가복음 4:35","category":"$undefined"},{"id":"25100","book":"누가복음","book_name":"누가복음","chapter":4,"verse":36,"text":"다 놀라 서로 말하여 가로되 `이 어떠한 말씀인고 권세와 능력으로 더러운 귀신을 명하매 나가는도다' 하더라","reference":"누가복음 4:36","category":"$undefined"},{"id":"25101","book":"누가복음","book_name":"누가복음","chapter":4,"verse":37,"text":"이에 예수의 소문이 그 근처 사방에 퍼지니라","reference":"누가복음 4:37","category":"$undefined"},{"id":"25102","book":"누가복음","book_name":"누가복음","chapter":4,"verse":38,"text":"예수께서 일어나 회당에서 나가사 시몬의 집에 들어가시니 시몬의 장모가 중한 열병에 붙들린지라 사람이 저를 위하여 예수께 구하니","reference":"누가복음 4:38","category":"$undefined"},{"id":"25103","book":"누가복음","book_name":"누가복음","chapter":4,"verse":39,"text":"예수께서 가까이 서서 열병을 꾸짖으신대 병이 떠나고 여자가 곧 일어나 저희에게 수종드니라","reference":"누가복음 4:39","category":"$undefined"},{"id":"25104","book":"누가복음","book_name":"누가복음","chapter":4,"verse":40,"text":"해 질 적에 각색 병으로 앓는 자 있는 사람들이 다 병인을 데리고 나아오매 예수께서 일일이 그 위에 손을 얹으사 고치시니","reference":"누가복음 4:40","category":"$undefined"},{"id":"25105","book":"누가복음","book_name":"누가복음","chapter":4,"verse":41,"text":"여러 사람에게서 귀신들이 나가며 소리질러 가로되 `당신은 하나님의 아들이니이다' 예수께서 꾸짖으사 저희의 말함을 허락치 아니하시니 이는 자기를 그리스도인 줄 앎이니라","reference":"누가복음 4:41","category":"$undefined"},{"id":"25106","book":"누가복음","book_name":"누가복음","chapter":4,"verse":42,"text":"날이 밝으매 예수께서 나오사 한적한 곳에 가시니 무리가 찾다가 만나서 자기들에게 떠나시지 못하게 만류하려 하매","reference":"누가복음 4:42","category":"$undefined"},{"id":"25107","book":"누가복음","book_name":"누가복음","chapter":4,"verse":43,"text":"예수께서 이르시되 `내가 다른 동네에서도 하나님의 나라 복음을 전하여야 하리니 나는 이 일로 보내심을 입었노라' 하시고","reference":"누가복음 4:43","category":"$undefined"},{"id":"25108","book":"누가복음","book_name":"누가복음","chapter":4,"verse":44,"text":"갈릴리 여러 회당에서 전도하시더라","reference":"누가복음 4:44","category":"$undefined"}],"bookSlug":"luke"}]
