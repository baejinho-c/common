2:["$","$L11",null,{"book":{"id":"luke","name":"누가복음","chapters":24,"testament":"new"},"chapter":8,"verses":[{"id":"25247","book":"누가복음","book_name":"누가복음","chapter":8,"verse":1,"text":"이후에 예수께서 각 성과 촌에 두루 다니시며 하나님의 나라를 반포하시며 그 복음을 전하실새 열 두 제자가 함께 하였고","reference":"누가복음 8:1","category":"$undefined"},{"id":"25248","book":"누가복음","book_name":"누가복음","chapter":8,"verse":2,"text":"또한 악귀를 쫓아내심과 병 고침을 받은 어떤 여자들 곧 일곱 귀신이 나간 자 막달라인이라 하는 마리아와","reference":"누가복음 8:2","category":"$undefined"},{"id":"25249","book":"누가복음","book_name":"누가복음","chapter":8,"verse":3,"text":"또 헤롯의 청지기 구사의 아내 요안나와 또 수산나와 다른 여러 여자가 함께하여 자기들의 소유로 저희를 섬기더라","reference":"누가복음 8:3","category":"$undefined"},{"id":"25250","book":"누가복음","book_name":"누가복음","chapter":8,"verse":4,"text":"각 동네 사람들이 예수께로 나아와 큰 무리를 이루니 예수께서 비유로 말씀하시되","reference":"누가복음 8:4","category":"$undefined"},{"id":"25251","book":"누가복음","book_name":"누가복음","chapter":8,"verse":5,"text":"`씨를 뿌리는 자가 그 씨를 뿌리러 나가서 뿌릴새 더러는 길 가에 떨어지매 밟히며 공중의 새들이 먹어버렸고","reference":"누가복음 8:5","category":"$undefined"},{"id":"25252","book":"누가복음","book_name":"누가복음","chapter":8,"verse":6,"text":"더러는 바위 위에 떨어지매 났다가 습기가 없으므로 말랐고","reference":"누가복음 8:6","category":"$undefined"},{"id":"25253","book":"누가복음","book_name":"누가복음","chapter":8,"verse":7,"text":"더러는 가시 떨기 속에 떨어지매 가시가 함께 자라서 기운을 막았고","reference":"누가복음 8:7","category":"$undefined"},{"id":"25254","book":"누가복음","book_name":"누가복음","chapter":8,"verse":8,"text":"더러는 좋은 땅에 떨어지매 나서 백 배의 결실을 하였느니라' 이 말씀을 하시고 외치시되 `들을 귀 있는 자는 들을지어다 !'","reference":"누가복음 8:8","category":"$undefined"},{"id":"25255","book":"누가복음","book_name":"누가복음","chapter":8,"verse":9,"text":"제자들이 이 비유의 뜻을 물으니","reference":"누가복음 8:9","category":"$undefined"},{"id":"25256","book":"누가복음","book_name":"누가복음","chapter":8,"verse":10,"text":"가라사대 `하나님 나라의 비밀을 아는 것이 너희에게는 허락되었으나 다른 사람에게는 비유로 하나니 이는 저희로 보아도 보지 못하고 들어도 깨닫지 못하게 하려 함이니라","reference":"누가복음 8:10","category":"$undefined"},{"id":"25257","book":"누가복음","book_name":"누가복음","chapter":8,"verse":11,"text":"이 비유는 이러하니라 씨는 하나님의 말씀이요","reference":"누가복음 8:11","category":"$undefined"},{"id":"25258","book":"누가복음","book_name":"누가복음","chapter":8,"verse":12,"text":"길 가에 있다는 것은 말씀을 들은 자니 이에 마귀가 와서 그들로 믿어 구원을 얻지 못하게 하려고 말씀을 그 마음에서 빼앗는 것이요","reference":"누가복음 8:12","category":"$undefined"},{"id":"25259","book":"누가복음","book_name":"누가복음","chapter":8,"verse":13,"text":"바위 위에 있다는 것은 말씀을 들을 때에 기쁨으로 받으나 뿌리가 없어 잠간 믿다가 시험을 받을 때에 배반하는 자요","reference":"누가복음 8:13","category":"$undefined"},{"id":"25260","book":"누가복음","book_name":"누가복음","chapter":8,"verse":14,"text":"가시떨기에 떨어졌다는 것은 말씀을 들은 자니 지내는 중 이생의 염려와 재리와 일락에 기운이 막혀 온전히 결실치 못하는 자요","reference":"누가복음 8:14","category":"$undefined"},{"id":"25261","book":"누가복음","book_name":"누가복음","chapter":8,"verse":15,"text":"좋은 땅에 있다는 것은 착하고 좋은 마음으로 말씀을 듣고 지키어 인내로 결실하는 자니라","reference":"누가복음 8:15","category":"$undefined"},{"id":"25262","book":"누가복음","book_name":"누가복음","chapter":8,"verse":16,"text":"누구든지 등불을 켜서 그릇으로 덮거나 평상 아래 두지 아니하고 등경 위에 두나니 이는 들어가는 자들로 그 빛을 보게 하려 함이라","reference":"누가복음 8:16","category":"$undefined"},{"id":"25263","book":"누가복음","book_name":"누가복음","chapter":8,"verse":17,"text":"숨은 것이 장차 드러나지 아니 할 것이 없고 감추인 것이 장차 알려지고 나타나지 않을 것이 없느니라","reference":"누가복음 8:17","category":"$undefined"},{"id":"25264","book":"누가복음","book_name":"누가복음","chapter":8,"verse":18,"text":"그러므로 너희가 어떻게 듣는가 스스로 삼가라 누구든지 있는 자는 받겠고 없는 자는 그 있는 줄로 아는 것까지 빼앗기리라' 하시니라","reference":"누가복음 8:18","category":"$undefined"},{"id":"25265","book":"누가복음","book_name":"누가복음","chapter":8,"verse":19,"text":"예수의 모친과 그 동생들이 왔으나 무리를 인하여 가까이하지 못하니","reference":"누가복음 8:19","category":"$undefined"},{"id":"25266","book":"누가복음","book_name":"누가복음","chapter":8,"verse":20,"text":"혹이 고하되 `당신의 모친과 동생들이 당신을 보려고 밖에 섰나이다'","reference":"누가복음 8:20","category":"$undefined"},{"id":"25267","book":"누가복음","book_name":"누가복음","chapter":8,"verse":21,"text":"예수께서 대답하여 가라사대 `내 모친과 내 동생들은 곧 하나님의 말씀을 듣고 행하는 이 사람들이라' 하시니라","reference":"누가복음 8:21","category":"$undefined"},{"id":"25268","book":"누가복음","book_name":"누가복음","chapter":8,"verse":22,"text":"하루는 제자들과 함께 배에 오르사 저희에게 이르시되 `호수 저편으로 건너가자' 하시매 이에 떠나","reference":"누가복음 8:22","category":"$undefined"},{"id":"25269","book":"누가복음","book_name":"누가복음","chapter":8,"verse":23,"text":"행선할 때에 예수께서 잠이 드셨더니 마침 광풍이 호수로 내리치매 배에 물이 가득하게 되어 위태한지라","reference":"누가복음 8:23","category":"$undefined"},{"id":"25270","book":"누가복음","book_name":"누가복음","chapter":8,"verse":24,"text":"제자들이 나아와 깨워 가로되 `주여, 주여 우리가 죽겠나이다' 한대 예수께서 잠을 깨사 바람과 물결을 꾸짖으시니 이에 그쳐 잔잔하여지더라","reference":"누가복음 8:24","category":"$undefined"},{"id":"25271","book":"누가복음","book_name":"누가복음","chapter":8,"verse":25,"text":"제자들에게 이르시되 `너희 믿음이 어디 있느냐 ?' 하시니 저희가 두려워하고 기이히 여겨 서로 말하되 `저가 뉘기에 바람과 물을 명하매 순종 하는고' 하더라","reference":"누가복음 8:25","category":"$undefined"},{"id":"25272","book":"누가복음","book_name":"누가복음","chapter":8,"verse":26,"text":"갈릴리 맞은편 거라사인의 땅에 이르러","reference":"누가복음 8:26","category":"$undefined"},{"id":"25273","book":"누가복음","book_name":"누가복음","chapter":8,"verse":27,"text":"육지에 내리시매 그 도시 사람으로서 귀신들린 자 하나가 예수를 만나니 이 사람은 오래 옷을 입지 아니하며 집에 거하지도 아니하고 무덤 사이에 거하는 자라","reference":"누가복음 8:27","category":"$undefined"},{"id":"25274","book":"누가복음","book_name":"누가복음","chapter":8,"verse":28,"text":"예수를 보고 부르짖으며 그 앞에 엎드리어 큰 소리로 불러 가로되 지극히 높으신 하나님의 아들 예수여 나와 당신과 무슨 상관이 있나이까 ? 당신께 구하노니 나를 괴롭게 마옵소서 하니","reference":"누가복음 8:28","category":"$undefined"},{"id":"25275","book":"누가복음","book_name":"누가복음","chapter":8,"verse":29,"text":"이는 예수께서 이미 더러운 귀신을 명하사 `이 사람에게서 나오라' 하셨음이라 (귀신이 가끔 이 사람을 붙잡으므로 저가 쇠사슬과 고랑에 매이어 지키웠으되 그 맨 것을 끊고 귀신에게 몰려 광야로 나갔더라)","reference":"누가복음 8:29","category":"$undefined"},{"id":"25276","book":"누가복음","book_name":"누가복음","chapter":8,"verse":30,"text":"예수께서 `네 이름이 무엇이냐 ?' 물으신즉 가로되 `군대라' 하니 이는 많은 귀신이 들렸음이라","reference":"누가복음 8:30","category":"$undefined"},{"id":"25277","book":"누가복음","book_name":"누가복음","chapter":8,"verse":31,"text":"무저갱으로 들어가라 하지 마시기를 간구하더니","reference":"누가복음 8:31","category":"$undefined"},{"id":"25278","book":"누가복음","book_name":"누가복음","chapter":8,"verse":32,"text":"마침 거기 많은 돼지 떼가 산에서 먹고 있는지라 귀신들이 그 돼지에게로 들어가게 허하심을 간구하니 이에 허하신대","reference":"누가복음 8:32","category":"$undefined"},{"id":"25279","book":"누가복음","book_name":"누가복음","chapter":8,"verse":33,"text":"귀신들이 그 사람에게서 나와 돼지에게로 들어가니 그 떼가 비탈로 내리달아 호수에 들어가 몰사하거늘","reference":"누가복음 8:33","category":"$undefined"},{"id":"25280","book":"누가복음","book_name":"누가복음","chapter":8,"verse":34,"text":"치던 자들이 그 된 것을 보고 도망하여 성내와 촌에 고하니","reference":"누가복음 8:34","category":"$undefined"},{"id":"25281","book":"누가복음","book_name":"누가복음","chapter":8,"verse":35,"text":"사람들이 그 된 것을 보러 나와서 예수께 이르러 귀신 나간 사람이 옷을 입고 정신이 온전하여 예수의 발 아래 앉은 것을 보고 두려워하거늘","reference":"누가복음 8:35","category":"$undefined"},{"id":"25282","book":"누가복음","book_name":"누가복음","chapter":8,"verse":36,"text":"귀신들렸던 자의 어떻게 구원 받은 것을 본 자들이 저희에게 이르매","reference":"누가복음 8:36","category":"$undefined"},{"id":"25283","book":"누가복음","book_name":"누가복음","chapter":8,"verse":37,"text":"거라사인의 땅 근방 모든 백성이 크게 두려워하여 떠나가시기를 구하더라 예수께서 배에 올라 돌아가실새","reference":"누가복음 8:37","category":"$undefined"},{"id":"25284","book":"누가복음","book_name":"누가복음","chapter":8,"verse":38,"text":"귀신나간 사람이 함께 있기를 구하였으나 예수께서 저를 보내시며 가라사대","reference":"누가복음 8:38","category":"$undefined"},{"id":"25285","book":"누가복음","book_name":"누가복음","chapter":8,"verse":39,"text":"`집으로 돌아가 하나님이 네게 어떻게 큰 일 행하신 것을 일일이 고하라' 하시니 저가 가서 예수께서 자기에게 어떻게 큰 일 하신 것을 온 성내에 전파하니라","reference":"누가복음 8:39","category":"$undefined"},{"id":"25286","book":"누가복음","book_name":"누가복음","chapter":8,"verse":40,"text":"예수께서 돌아오시매 무리가 환영하니 이는 다 기다렸음이러라","reference":"누가복음 8:40","category":"$undefined"},{"id":"25287","book":"누가복음","book_name":"누가복음","chapter":8,"verse":41,"text":"이에 회당장인 야이로라 하는 사람이 와서 예수의 발 아래 엎드려 자기 집에 오시기를 간구하니","reference":"누가복음 8:41","category":"$undefined"},{"id":"25288","book":"누가복음","book_name":"누가복음","chapter":8,"verse":42,"text":"이는 자기에게 열 두 살 먹은 외딸이 있어 죽어감이러라 예수께서 가실 때에 무리가 옹위하더라","reference":"누가복음 8:42","category":"$undefined"},{"id":"25289","book":"누가복음","book_name":"누가복음","chapter":8,"verse":43,"text":"이에 열 두 해를 혈루증으로 앓는 중에 아무에게도 고침을 받지 못하던 여자가","reference":"누가복음 8:43","category":"$undefined"},{"id":"25290","book":"누가복음","book_name":"누가복음","chapter":8,"verse":44,"text":"예수의 뒤로 와서 그 옷 가에 손을 대니 혈루증이 즉시 그쳤더라","reference":"누가복음 8:44","category":"$undefined"},{"id":"25291","book":"누가복음","book_name":"누가복음","chapter":8,"verse":45,"text":"예수께서 가라사대 `내게 손을 댄 자가 누구냐 ?' 하시니 다 아니라 할때에 베드로가 가로되 `주여 무리가 옹위하여 미나이다'","reference":"누가복음 8:45","category":"$undefined"},{"id":"25292","book":"누가복음","book_name":"누가복음","chapter":8,"verse":46,"text":"예수께서 가라사대 `내게 손을 댄 자가 있도다 이는 내게서 능력이 나간 줄 앎이로다' 하신대","reference":"누가복음 8:46","category":"$undefined"},{"id":"25293","book":"누가복음","book_name":"누가복음","chapter":8,"verse":47,"text":"여자가 스스로 숨기지 못할 줄을 알고 떨며 나아와 엎드리어 그 손댄 연고와 곧 나은 것을 모든 사람 앞에서 고하니","reference":"누가복음 8:47","category":"$undefined"},{"id":"25294","book":"누가복음","book_name":"누가복음","chapter":8,"verse":48,"text":"예수께서 이르시되 `딸아, 네 믿음이 너를 구원하였으니 평안히 가라 !' 하시더라","reference":"누가복음 8:48","category":"$undefined"},{"id":"25295","book":"누가복음","book_name":"누가복음","chapter":8,"verse":49,"text":"아직 말씀하실 때에 회당장의 집에서 사람이 와서 말하되 `당신의 딸이 죽었나이다 선생을 더 괴롭게 마소서' 하거늘","reference":"누가복음 8:49","category":"$undefined"},{"id":"25296","book":"누가복음","book_name":"누가복음","chapter":8,"verse":50,"text":"예수께서 들으시고 가라사대 `두려워 말고 믿기만 하라 ! 그리하면 딸이 구원을 얻으리라' 하시고","reference":"누가복음 8:50","category":"$undefined"},{"id":"25297","book":"누가복음","book_name":"누가복음","chapter":8,"verse":51,"text":"집에 이르러 베드로와 요한과 야고보와 및 아이의 부모 외에는 함께 들어가기를 허하지 아니하시니라","reference":"누가복음 8:51","category":"$undefined"},{"id":"25298","book":"누가복음","book_name":"누가복음","chapter":8,"verse":52,"text":"모든 사람이 아이를 위하여 울며 통곡하매 예수께서 이르시되 `울지 말라 죽은 것이 아니라 잔다' 하시니","reference":"누가복음 8:52","category":"$undefined"},{"id":"25299","book":"누가복음","book_name":"누가복음","chapter":8,"verse":53,"text":"저희가 그 죽은 것을 아는고로 비웃더라","reference":"누가복음 8:53","category":"$undefined"},{"id":"25300","book":"누가복음","book_name":"누가복음","chapter":8,"verse":54,"text":"예수께서 아이의 손을 잡고 불러 가라사대 `아이야 일어나라 !' 하시니","reference":"누가복음 8:54","category":"$undefined"},{"id":"25301","book":"누가복음","book_name":"누가복음","chapter":8,"verse":55,"text":"그 영(靈)이 돌아와 아이가 곧 일어나거늘 예수께서 `먹을 것을 주라' 명하신대","reference":"누가복음 8:55","category":"$undefined"},{"id":"25302","book":"누가복음","book_name":"누가복음","chapter":8,"verse":56,"text":"그 부모가 놀라는지라 예수께서 경계하사 `이 일을 아무에게도 말하지 말라' 하시니라","reference":"누가복음 8:56","category":"$undefined"}],"bookSlug":"luke"}]
