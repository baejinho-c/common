2:["$","$L11",null,{"book":{"id":"malachi","name":"말라기","chapters":4,"testament":"old"},"chapter":1,"verses":[{"id":"23091","book":"말라기","book_name":"말라기","chapter":1,"verse":1,"text":"여호와께서 말라기로 이스라엘에게 말씀하신 경고라","reference":"말라기 1:1","category":"$undefined"},{"id":"23092","book":"말라기","book_name":"말라기","chapter":1,"verse":2,"text":"여호와께서 가라사대 내가 너희를 사랑하였노라 하나 너희는 이르기를 주께서 어떻게 우리를 사랑하셨나이까 하는도다 나 여호와가 말하노라 에서는 야곱의 형이 아니냐 ? 그러나 내가 야곱을 사랑하였고","reference":"말라기 1:2","category":"$undefined"},{"id":"23093","book":"말라기","book_name":"말라기","chapter":1,"verse":3,"text":"에서는 미워하였으며 그의 산들을 황무케 하였고 그의 산업을 광야의 시랑에게 붙였느니라","reference":"말라기 1:3","category":"$undefined"},{"id":"23094","book":"말라기","book_name":"말라기","chapter":1,"verse":4,"text":"에돔은 말하기를 우리가 무너뜨림을 당하였으나 황폐된 곳을 다시 쌓으리라 하거니와 나 만군의 여호와는 이르노라 그들은 쌓을지라도 나는 헐리라 사람들이 그들을 일컬어 악한 지경이라 할 것이요 여호와의 영영한 진노를 받은 백성이라 할 것이며","reference":"말라기 1:4","category":"$undefined"},{"id":"23095","book":"말라기","book_name":"말라기","chapter":1,"verse":5,"text":"너희는 목도하고 이르기를 여호와께서는 이스라엘 지경 밖에서 크시다 하리라","reference":"말라기 1:5","category":"$undefined"},{"id":"23096","book":"말라기","book_name":"말라기","chapter":1,"verse":6,"text":"내 이름을 멸시하는 제사장들아 나 만군의 여호와가 너희에게 이르기를 아들은 그 아비를, 종은 그 주인을 공경하나니 내가 아비일진대 나를 공경함이 어디 있느냐 내가 주인일진대 나를 두려워함이 어디 있느냐 ? 하나 너희는 이르기를 우리가 어떻게 주의 이름을 멸시하였나이까 하는도다","reference":"말라기 1:6","category":"$undefined"},{"id":"23097","book":"말라기","book_name":"말라기","chapter":1,"verse":7,"text":"너희가 더러운 떡을 나의 단에 드리고도 말하기를 우리가 어떻게 주를 더럽게 하였나이까 하는도다 이는 너희가 주의 상은 경멸히 여길 것이라 말함을 인함이니라","reference":"말라기 1:7","category":"$undefined"},{"id":"23098","book":"말라기","book_name":"말라기","chapter":1,"verse":8,"text":"만군의 여호와가 이르노라 ! 너희가 눈 먼 희생으로 드리는 것이 어찌 악하지 아니하며 저는 것, 병든 것으로 드리는 것이 어찌 악하지 아니하냐 ? 이제 그것을 너희 총독에게 드려보라 그가 너를기뻐하겠느냐 ? 너를 가납하겠느냐 ?","reference":"말라기 1:8","category":"$undefined"},{"id":"23099","book":"말라기","book_name":"말라기","chapter":1,"verse":9,"text":"만군의 여호와가 이르노라 ! 너희는 나 하나님께 은혜를 구하기를 우리를 긍휼히 여기소서 하여 보라 너희가 이같이 행하였으니 내가 너희 중 하나인들 받겠느냐","reference":"말라기 1:9","category":"$undefined"},{"id":"23100","book":"말라기","book_name":"말라기","chapter":1,"verse":10,"text":"만군의 여호와가 이르노라 ! 너희가 내 단 위에 헛되이 불 사르지 못하게 하기 위하여 너희 중에 성전 문을 닫을 자가 있었으면 좋겠도다 내가 너희를 기뻐하지 아니하며 너희 손으로 드리는 것을 받지도 아니하리라","reference":"말라기 1:10","category":"$undefined"},{"id":"23101","book":"말라기","book_name":"말라기","chapter":1,"verse":11,"text":"만군의 여호와가 이르노라 ! 해 뜨는 곳에서부터 해 지는 곳까지의 이방 민족 중에서 내 이름이 크게 될 것이라 각처에서 내 이름을 위하여 분향하며 깨끗한 제물을 드리리니 이는 내 이름이 이방 민족 중에서 크게 될 것임이니라","reference":"말라기 1:11","category":"$undefined"},{"id":"23102","book":"말라기","book_name":"말라기","chapter":1,"verse":12,"text":"그러나 너희는 말하기를 여호와의 상은 더러웠고 그 위에 있는 실과 곧 식물은 경멸히 여길 것이라 하여 내 이름을 더럽히는도다","reference":"말라기 1:12","category":"$undefined"},{"id":"23103","book":"말라기","book_name":"말라기","chapter":1,"verse":13,"text":"만군의 여호와가 이르노라 ! 너희가 또 말하기를 이 일이 얼마나 번폐스러운고 하며 코웃음하고 토색한 물건과 저는 것 병든 것을 가져왔느니라 너희가 이같이 헌물을 가져오니 내가 그것을 너희 손에서 받겠느냐 여호와의 말이니라","reference":"말라기 1:13","category":"$undefined"},{"id":"23104","book":"말라기","book_name":"말라기","chapter":1,"verse":14,"text":"떼 가운데 수컷이 있거늘 그 서원하는 일에 흠있는 것으로 사기하여 내게 드리는 자는 저주를 받으리니 나는 큰 임금이요 내 이름은 열방 중에서 두려워하는 것이 됨이니라 만군의 여호와의 말이니라","reference":"말라기 1:14","category":"$undefined"}],"bookSlug":"malachi"}]
