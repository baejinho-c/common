2:["$","$L11",null,{"book":{"id":"malachi","name":"말라기","chapters":4,"testament":"old"},"chapter":2,"verses":[{"id":"23105","book":"말라기","book_name":"말라기","chapter":2,"verse":1,"text":"너의 제사장들아 ! 이제 너희에게 이같이 명령하노라","reference":"말라기 2:1","category":"$undefined"},{"id":"23106","book":"말라기","book_name":"말라기","chapter":2,"verse":2,"text":"만군의 여호와가 이르노라 ! 너희가 만일 듣지 아니하며 마음에 두지 아니하여 내 이름을 영화롭게 하지 아니하면 내가 너희에게 저주를 내려 너희의 복을 저주하리라 내가 이미 저주하였나니 이는 너희가 그것을 마음에 두지 아니하였음이니라","reference":"말라기 2:2","category":"$undefined"},{"id":"23107","book":"말라기","book_name":"말라기","chapter":2,"verse":3,"text":"보라 ! 내가 너희의 종자를 견책할 것이요 똥, 곧 너희 절기의 희생의 똥을 너희 얼굴에 바를 것이라 너희가 그것과 함께 제하여 버림을 당하리라","reference":"말라기 2:3","category":"$undefined"},{"id":"23108","book":"말라기","book_name":"말라기","chapter":2,"verse":4,"text":"만군의 여호와가 이르노라 내가 이 명령을 너희에게 내린 것은 레위와 세운 나의 언약이 항상 있게 하려 함인 줄을 너희가 알리라","reference":"말라기 2:4","category":"$undefined"},{"id":"23109","book":"말라기","book_name":"말라기","chapter":2,"verse":5,"text":"레위와 세운 나의 언약은 생명과 평강의 언약이라 내가 이것으로 그에게 준 것은 그로 경외하게 하려 함이라 그가 나를 경외하고 내 이름을 두려워하였으며","reference":"말라기 2:5","category":"$undefined"},{"id":"23110","book":"말라기","book_name":"말라기","chapter":2,"verse":6,"text":"그 입에는 진리의 법이 있었고 그 입술에는 불의함이 없었으며 그가 화평과 정직한 중에서 나와 동행하며 많은 사람을 돌이켜 죄악에서 떠나게 하였느니라","reference":"말라기 2:6","category":"$undefined"},{"id":"23111","book":"말라기","book_name":"말라기","chapter":2,"verse":7,"text":"대저 제사장의 입술은 지식을 지켜야 하겠고 사람들이 그 입에서 율법을 구하게 되어야 할 것이니 제사장은 만군의 여호와의 사자가 됨이어늘","reference":"말라기 2:7","category":"$undefined"},{"id":"23112","book":"말라기","book_name":"말라기","chapter":2,"verse":8,"text":"너희는 정도에서 떠나 많은 사람으로 율법에 거치게 하도다 나 만군의 여호와가 이르노니 너희가 레위의 언약을 파하였느니라","reference":"말라기 2:8","category":"$undefined"},{"id":"23113","book":"말라기","book_name":"말라기","chapter":2,"verse":9,"text":"너희가 내 도를 지키지 아니하고 율법을 행할 때에 사람에게 편벽되이 하였으므로 나도 너희로 모든 백성 앞에 멸시와 천대를 당하게 하였느니라 하시니라","reference":"말라기 2:9","category":"$undefined"},{"id":"23114","book":"말라기","book_name":"말라기","chapter":2,"verse":10,"text":"우리는 한 아버지를 가지지 아니하였느냐 ? 한 하나님의 지으신 바가 아니냐 어찌하여 우리 각 사람이 자기 형제에게 궤사를 행하여 우리 열조의 언약을 욕되게 하느냐 ?","reference":"말라기 2:10","category":"$undefined"},{"id":"23115","book":"말라기","book_name":"말라기","chapter":2,"verse":11,"text":"유다는 궤사를 행하였고 이스라엘과 예루살렘 중에서는 가증한 일을 행하였으며 유다는 여호와의 사랑하시는 그 성결을 욕되게 하여 이방 신의 딸과 결혼하였으니","reference":"말라기 2:11","category":"$undefined"},{"id":"23116","book":"말라기","book_name":"말라기","chapter":2,"verse":12,"text":"이 일을 행하는 사람에게 속한 자는 깨는 자나 응답하는 자는 물론이요 만군의 여호와께 제사를 드리는 자도 여호와께서 야곱의 장막 가운데서 끊어 버리시리라","reference":"말라기 2:12","category":"$undefined"},{"id":"23117","book":"말라기","book_name":"말라기","chapter":2,"verse":13,"text":"너희가 이런 일도 행하나니 곧 눈물과 울음과 탄식으로 여호와의 단을 가리우게 하도다 그러므로 여호와께서 다시는 너희의 헌물을 돌아보지도 아니하시며 그것을 너희 손에서 기꺼이 받지도 아니하시거늘","reference":"말라기 2:13","category":"$undefined"},{"id":"23118","book":"말라기","book_name":"말라기","chapter":2,"verse":14,"text":"너희는 이르기를 어찜이니까 하는도다 이는 너와 너의 어려서 취한 아내 사이에 여호와께서 일찌기 증거하셨음을 인함이니라 그는 네 짝이요 너와 맹약한 아내로되 네가 그에게 궤사를 행하도다","reference":"말라기 2:14","category":"$undefined"},{"id":"23119","book":"말라기","book_name":"말라기","chapter":2,"verse":15,"text":"여호와는 영이 유여하실지라도 오직 하나를 짓지 아니하셨느냐 ? 어찌하여 하나만 지으셨느냐 ? 이는 경건한 자손을 얻고자 하심이니라 그러므로 네 심령을 삼가 지켜 어려서 취한 아내에게 궤사를 행치 말지니라","reference":"말라기 2:15","category":"$undefined"},{"id":"23120","book":"말라기","book_name":"말라기","chapter":2,"verse":16,"text":"이스라엘의 하나님 여호와가 이르노니 나는 이혼하는 것과 학대로 옷을 가리우는 자를 미워하노라 만군의 여호와의 말이니라 그러므로 너희 심령을 삼가 지켜 궤사를 행치 말찌니라","reference":"말라기 2:16","category":"$undefined"},{"id":"23121","book":"말라기","book_name":"말라기","chapter":2,"verse":17,"text":"너희가 말로 여호와를 괴로우시게 하고도 이르기를 우리가 어떻게 여호와를 괴로우시게 하였나 하는도다 이는 너희가 말하기를 모든 행악하는 자는 여호와의 눈에 선히 보이며 그에게 기쁨이 된다 하며 또 말하기를 공의의 하나님이 어디 계시냐 함이니라","reference":"말라기 2:17","category":"$undefined"}],"bookSlug":"malachi"}]
