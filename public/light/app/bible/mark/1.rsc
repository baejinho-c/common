2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":1,"verses":[{"id":"24217","book":"마가복음","book_name":"마가복음","chapter":1,"verse":1,"text":"하나님의 아들 예수 그리스도 복음의 시작이라","reference":"마가복음 1:1","category":"$undefined"},{"id":"24218","book":"마가복음","book_name":"마가복음","chapter":1,"verse":2,"text":"선지자 이사야의 글에 보라 내가 내 사자를 네 앞에 보내노니 저가 네 길을 예비하리라","reference":"마가복음 1:2","category":"$undefined"},{"id":"24219","book":"마가복음","book_name":"마가복음","chapter":1,"verse":3,"text":"광야에 외치는 자의 소리가 있어 가로되 너희는 주의 길을 예비하라 그의 첩경을 평탄케 하라 기록된 것과 같이","reference":"마가복음 1:3","category":"$undefined"},{"id":"24220","book":"마가복음","book_name":"마가복음","chapter":1,"verse":4,"text":"세례요한이 이르러 광야에서 죄 사함을 받게하는 회개의 세례를 전파하니","reference":"마가복음 1:4","category":"$undefined"},{"id":"24221","book":"마가복음","book_name":"마가복음","chapter":1,"verse":5,"text":"온 유대 지방과 예루살렘 사람이 다 나아가 자기 죄를 자복하고 요단강에서 그에게 세례를 받더라","reference":"마가복음 1:5","category":"$undefined"},{"id":"24222","book":"마가복음","book_name":"마가복음","chapter":1,"verse":6,"text":"요한은 약대털을 입고 허리에 가죽띠를 띠고 메뚜기와 석청을 먹더라","reference":"마가복음 1:6","category":"$undefined"},{"id":"24223","book":"마가복음","book_name":"마가복음","chapter":1,"verse":7,"text":"그가 전파하여 가로되 `나보다 능력 많으신 이가 내 뒤에 오시나니 나는 그의 신들메를 풀기도 감당치 못하겠노라","reference":"마가복음 1:7","category":"$undefined"},{"id":"24224","book":"마가복음","book_name":"마가복음","chapter":1,"verse":8,"text":"나는 너희에게 물로 세례 주었거니와 그는 성령으로 너희에게 세례를 주시리라'","reference":"마가복음 1:8","category":"$undefined"},{"id":"24225","book":"마가복음","book_name":"마가복음","chapter":1,"verse":9,"text":"그 때에 예수께서 갈릴리 나사렛으로부터 와서 요단강에서 요한에게 세례를 받으시고","reference":"마가복음 1:9","category":"$undefined"},{"id":"24226","book":"마가복음","book_name":"마가복음","chapter":1,"verse":10,"text":"곧 물에서 올라 오실새 하늘이 갈라짐과 성령이 비둘기같이 자기에게 내려 오심을 보시더니","reference":"마가복음 1:10","category":"$undefined"},{"id":"24227","book":"마가복음","book_name":"마가복음","chapter":1,"verse":11,"text":"하늘로서 소리가 나기를 `너는 내 사랑하는 아들이라 내가 너를 기뻐 하노라' 하시니라","reference":"마가복음 1:11","category":"$undefined"},{"id":"24228","book":"마가복음","book_name":"마가복음","chapter":1,"verse":12,"text":"성령이 곧 예수를 광야로 몰아 내신지라","reference":"마가복음 1:12","category":"$undefined"},{"id":"24229","book":"마가복음","book_name":"마가복음","chapter":1,"verse":13,"text":"광야에서 사십일을 계셔서 사단에게 시험을 받으시며 들짐승과 함께 계시니 천사들이 수종들더라","reference":"마가복음 1:13","category":"$undefined"},{"id":"24230","book":"마가복음","book_name":"마가복음","chapter":1,"verse":14,"text":"요한이 잡힌 후 예수께서 갈릴리에 오셔서 하나님의 복음을 전파하여","reference":"마가복음 1:14","category":"$undefined"},{"id":"24231","book":"마가복음","book_name":"마가복음","chapter":1,"verse":15,"text":"가라사대 `때가 찼고 하나님 나라가 가까왔으니 회개하고 복음을 믿으라 !' 하시더라","reference":"마가복음 1:15","category":"$undefined"},{"id":"24232","book":"마가복음","book_name":"마가복음","chapter":1,"verse":16,"text":"갈릴리 해변으로 지나가시다가 시몬과 그 형제 안드레가 바다에 그물 던지는 것을 보고 저희는 어부라","reference":"마가복음 1:16","category":"$undefined"},{"id":"24233","book":"마가복음","book_name":"마가복음","chapter":1,"verse":17,"text":"예수께서 가라사대 `나를 따라 오너라 내가 너희로 사람을 낚는 어부가 되게 하리라' 하시니","reference":"마가복음 1:17","category":"$undefined"},{"id":"24234","book":"마가복음","book_name":"마가복음","chapter":1,"verse":18,"text":"곧 그물을 버려 두고 좇으니라","reference":"마가복음 1:18","category":"$undefined"},{"id":"24235","book":"마가복음","book_name":"마가복음","chapter":1,"verse":19,"text":"조금 더 가시다가 세베대의 아들 야고보와 그 형제 요한을 보시니 저희도 배에 있어 그물을 깁는데","reference":"마가복음 1:19","category":"$undefined"},{"id":"24236","book":"마가복음","book_name":"마가복음","chapter":1,"verse":20,"text":"곧 부르시니 그 아비 세베대를 삯군들과 함께 배에 버려두고 예수를 따라 가니라","reference":"마가복음 1:20","category":"$undefined"},{"id":"24237","book":"마가복음","book_name":"마가복음","chapter":1,"verse":21,"text":"저희가 가버나움에 들어가니라 예수께서 곧 안식일에 회당에 들어가 가르치시매","reference":"마가복음 1:21","category":"$undefined"},{"id":"24238","book":"마가복음","book_name":"마가복음","chapter":1,"verse":22,"text":"뭇사람이 그의 교훈에 놀라니 이는 그 가르치시는 것이 권세 있는 자와 같고 서기관들과 같지 아니함일러라","reference":"마가복음 1:22","category":"$undefined"},{"id":"24239","book":"마가복음","book_name":"마가복음","chapter":1,"verse":23,"text":"마침 저희 회당에 더러운 귀신들린 사람이 있어 소리질러 가로되","reference":"마가복음 1:23","category":"$undefined"},{"id":"24240","book":"마가복음","book_name":"마가복음","chapter":1,"verse":24,"text":"`나사렛 예수여 우리가 당신과 무슨 상관이 있나이까 ? 우리를 멸하러 왔나이까 ? 나는 당신이 누구인줄 아노니 하나님의 거룩한 자니이다'","reference":"마가복음 1:24","category":"$undefined"},{"id":"24241","book":"마가복음","book_name":"마가복음","chapter":1,"verse":25,"text":"예수께서 꾸짖어 가라사대 `잠잠하고 그사람에게서 나오라 !' 하시니","reference":"마가복음 1:25","category":"$undefined"},{"id":"24242","book":"마가복음","book_name":"마가복음","chapter":1,"verse":26,"text":"더러운 귀신이 그사람으로 경련을 일으키게 하고 큰소리를 지르며 나오는지라","reference":"마가복음 1:26","category":"$undefined"},{"id":"24243","book":"마가복음","book_name":"마가복음","chapter":1,"verse":27,"text":"다 놀라 서로 물어 가로되 `이는 어찜이뇨 권세있는 새 교훈이로다 더러운 귀신들을 명한즉 순종하는도다' 하더라","reference":"마가복음 1:27","category":"$undefined"},{"id":"24244","book":"마가복음","book_name":"마가복음","chapter":1,"verse":28,"text":"예수의 소문이 곧 온 갈릴리 사방에 퍼지더라","reference":"마가복음 1:28","category":"$undefined"},{"id":"24245","book":"마가복음","book_name":"마가복음","chapter":1,"verse":29,"text":"회당에서 나와 곧 야고보와 요한과 함께 시몬과 안드레의 집에 들어 가시니","reference":"마가복음 1:29","category":"$undefined"},{"id":"24246","book":"마가복음","book_name":"마가복음","chapter":1,"verse":30,"text":"시몬의 장모가 열병으로 누웠는지라 사람들이 곧 그의 일로 예수께 여짜온대","reference":"마가복음 1:30","category":"$undefined"},{"id":"24247","book":"마가복음","book_name":"마가복음","chapter":1,"verse":31,"text":"나아가사 그 손을 잡아 일으키시니 열병이 떠나고 여자가 저희에게 수종드니라","reference":"마가복음 1:31","category":"$undefined"},{"id":"24248","book":"마가복음","book_name":"마가복음","chapter":1,"verse":32,"text":"저물어 해 질때에 모든 병자와 귀신들린 자를 예수께 데려오니","reference":"마가복음 1:32","category":"$undefined"},{"id":"24249","book":"마가복음","book_name":"마가복음","chapter":1,"verse":33,"text":"온 동네가 문 앞에 모였더라","reference":"마가복음 1:33","category":"$undefined"},{"id":"24250","book":"마가복음","book_name":"마가복음","chapter":1,"verse":34,"text":"예수께서 각색 병든 많은 사람을 고치시며 많은 귀신을 내어 쫓으시되 귀신이 자기를 알므로 그 말하는 것을 허락지 아니하시니","reference":"마가복음 1:34","category":"$undefined"},{"id":"24251","book":"마가복음","book_name":"마가복음","chapter":1,"verse":35,"text":"새벽 오히려 미명에 예수께서 일어나 나가 한적한 곳으로 가사 거기서 기도하시더니","reference":"마가복음 1:35","category":"$undefined"},{"id":"24252","book":"마가복음","book_name":"마가복음","chapter":1,"verse":36,"text":"시몬과 및 그와 함께 있는 자들이 예수의 뒤를 따라가","reference":"마가복음 1:36","category":"$undefined"},{"id":"24253","book":"마가복음","book_name":"마가복음","chapter":1,"verse":37,"text":"만나서 가로되 `모든 사람이 주를 찾나이다'","reference":"마가복음 1:37","category":"$undefined"},{"id":"24254","book":"마가복음","book_name":"마가복음","chapter":1,"verse":38,"text":"이르시되 `우리가 다른 가까운 마을들로 가자 거기서도 전도하리니 내가 이를 위하여 왔노라' 하시고","reference":"마가복음 1:38","category":"$undefined"},{"id":"24255","book":"마가복음","book_name":"마가복음","chapter":1,"verse":39,"text":"이에 온 갈릴리에 다니시며 저희 여러 회당에서 전도하시고 또 귀신들을 내어 쫓으시더라","reference":"마가복음 1:39","category":"$undefined"},{"id":"24256","book":"마가복음","book_name":"마가복음","chapter":1,"verse":40,"text":"한 문둥병자가 예수께 와서 꿇어 엎드리어 간구하여 가로되 `원하시면 저를 깨끗케 하실수 있나이다'","reference":"마가복음 1:40","category":"$undefined"},{"id":"24257","book":"마가복음","book_name":"마가복음","chapter":1,"verse":41,"text":"예수께서 민망히 여기사 손을 내밀어 저에게 대시며 가라사대 `내가 원하노니 깨끗함을 받으라 !' 하신대","reference":"마가복음 1:41","category":"$undefined"},{"id":"24258","book":"마가복음","book_name":"마가복음","chapter":1,"verse":42,"text":"곧 문둥병이 그 사람에게서 떠나가고 깨끗하여진지라","reference":"마가복음 1:42","category":"$undefined"},{"id":"24259","book":"마가복음","book_name":"마가복음","chapter":1,"verse":43,"text":"엄히 경계하사 곧 보내시며","reference":"마가복음 1:43","category":"$undefined"},{"id":"24260","book":"마가복음","book_name":"마가복음","chapter":1,"verse":44,"text":"가라사대 `삼가 아무에게 아무 말도 하지 말고 가서 네 몸을 제사장에게 보이고 네 깨끗케 됨을 인하여 모세의 명한 것을 드려 저희에게 증거하라' 하셨더니","reference":"마가복음 1:44","category":"$undefined"},{"id":"24261","book":"마가복음","book_name":"마가복음","chapter":1,"verse":45,"text":"그러나 그 사람이 나가서 이 일을 많이 전파하여 널리 퍼지게 하니 그러므로 예수께서 다시는 드러나게 동네에 들어가지 못하시고 오직 바깥 한적한 곳에 계셨으나 사방에서 그에게로 나아오더라","reference":"마가복음 1:45","category":"$undefined"}],"bookSlug":"mark"}]
