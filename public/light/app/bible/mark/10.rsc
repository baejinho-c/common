2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":10,"verses":[{"id":"24590","book":"마가복음","book_name":"마가복음","chapter":10,"verse":1,"text":"예수께서 거기서 떠나 유대 지경과 요단강 건너편으로 가시니 무리가 다시 모여 들거늘 예수께서 다시 전례대로 가르치시더니","reference":"마가복음 10:1","category":"$undefined"},{"id":"24591","book":"마가복음","book_name":"마가복음","chapter":10,"verse":2,"text":"바리새인들이 예수께 나아와 그를 시험하여 묻되 `사람이 아내를 내어 버리는 것이 옳으니이까 ?'","reference":"마가복음 10:2","category":"$undefined"},{"id":"24592","book":"마가복음","book_name":"마가복음","chapter":10,"verse":3,"text":"대답하여 가라사대 `모세가 어떻게 너희에게 명하였느냐 ?'","reference":"마가복음 10:3","category":"$undefined"},{"id":"24593","book":"마가복음","book_name":"마가복음","chapter":10,"verse":4,"text":"가로되 `모세는 이혼증서를 써주어 내어 버리기를 허락하였나이다'","reference":"마가복음 10:4","category":"$undefined"},{"id":"24594","book":"마가복음","book_name":"마가복음","chapter":10,"verse":5,"text":"예수께서 저희에게 이르시되 `너희 마음의 완악함을 인하여 이 명령을 기록하였거니와","reference":"마가복음 10:5","category":"$undefined"},{"id":"24595","book":"마가복음","book_name":"마가복음","chapter":10,"verse":6,"text":"창조시로부터 저희를 남자와 여자로 만드셨으니","reference":"마가복음 10:6","category":"$undefined"},{"id":"24596","book":"마가복음","book_name":"마가복음","chapter":10,"verse":7,"text":"이러므로 사람이 그 부모를 떠나서","reference":"마가복음 10:7","category":"$undefined"},{"id":"24597","book":"마가복음","book_name":"마가복음","chapter":10,"verse":8,"text":"그 둘이 한 몸이 될지니라 이러한즉 이제 둘이 아니요 한 몸이니","reference":"마가복음 10:8","category":"$undefined"},{"id":"24598","book":"마가복음","book_name":"마가복음","chapter":10,"verse":9,"text":"그러므로 하나님이 짝지어 주신 것을 사람이 나누지 못할지니라' 하시더라","reference":"마가복음 10:9","category":"$undefined"},{"id":"24599","book":"마가복음","book_name":"마가복음","chapter":10,"verse":10,"text":"집에서 제자들이 다시 이일을 묻자온대","reference":"마가복음 10:10","category":"$undefined"},{"id":"24600","book":"마가복음","book_name":"마가복음","chapter":10,"verse":11,"text":"이르시되 `누구든지 그 아내를 내어버리고 다른 데 장가드는 자는 본처에게 간음을 행함이요","reference":"마가복음 10:11","category":"$undefined"},{"id":"24601","book":"마가복음","book_name":"마가복음","chapter":10,"verse":12,"text":"또 아내가 남편을 버리고 다른데로 시집 가면 간음을 행함이니라'","reference":"마가복음 10:12","category":"$undefined"},{"id":"24602","book":"마가복음","book_name":"마가복음","chapter":10,"verse":13,"text":"사람들이 예수의 만져주심을 바라고 어린 아이들을 데리고 오매 제자들이 꾸짖거늘","reference":"마가복음 10:13","category":"$undefined"},{"id":"24603","book":"마가복음","book_name":"마가복음","chapter":10,"verse":14,"text":"예수께서 보시고 분히 여겨 이르시되 `어린 아이들의 내게 오는 것을 용납하고 금하지 말라 하나님의 나라가 이런 자의 것이니라","reference":"마가복음 10:14","category":"$undefined"},{"id":"24604","book":"마가복음","book_name":"마가복음","chapter":10,"verse":15,"text":"내가 진실로 너희에게 이르노니 누구든지 하나님의 나라를 어린 아이와 같이 받들지 않는 자는 결단코 들어가지 못하리라' 하시고","reference":"마가복음 10:15","category":"$undefined"},{"id":"24605","book":"마가복음","book_name":"마가복음","chapter":10,"verse":16,"text":"그 어린 아이들을 안고 저희 위에 안수하시고 축복하시니라","reference":"마가복음 10:16","category":"$undefined"},{"id":"24606","book":"마가복음","book_name":"마가복음","chapter":10,"verse":17,"text":"예수께서 길에 나가실새 한사람이 달려와서 꿇어 앉아 묻자오되 `선한 선생님이여, 내가 무엇을 하여야 영생을 얻으리이까 ?'","reference":"마가복음 10:17","category":"$undefined"},{"id":"24607","book":"마가복음","book_name":"마가복음","chapter":10,"verse":18,"text":"예수께서 이르시되 `네가 어찌하여 나를 선하다 일컫느냐 ? 하나님 한 분 외에는 선한 이가 없느니라","reference":"마가복음 10:18","category":"$undefined"},{"id":"24608","book":"마가복음","book_name":"마가복음","chapter":10,"verse":19,"text":"네가 계명을 아나니 살인하지 말라, 간음하지 말라, 도적질하지 말라, 거짓 증거하지 말라, 속여 취하지 말라, 네 부모를 공경하라 하였느니라'","reference":"마가복음 10:19","category":"$undefined"},{"id":"24609","book":"마가복음","book_name":"마가복음","chapter":10,"verse":20,"text":"여짜오되 `선생님이여, 이것은 내가 어려서부터 다 지키었나이다'","reference":"마가복음 10:20","category":"$undefined"},{"id":"24610","book":"마가복음","book_name":"마가복음","chapter":10,"verse":21,"text":"예수께서 그를 보시고 사랑하여 가라사대 `네게 오히려 한 가지 부족한 것이 있으니 가서 네 있는 것을 다 팔아 가난한 자들을 주라 그리하면 하늘에서 보화가 네게 있으리라 그리고 와서 나를 좇으라 !' 하시니","reference":"마가복음 10:21","category":"$undefined"},{"id":"24611","book":"마가복음","book_name":"마가복음","chapter":10,"verse":22,"text":"그 사람은 재물이 많은고로 이 말씀을 인하여 슬픈 기색을 띠고 근심하며 가니라","reference":"마가복음 10:22","category":"$undefined"},{"id":"24612","book":"마가복음","book_name":"마가복음","chapter":10,"verse":23,"text":"예수께서 둘러 보시고 제자들에게 이르시되 `재물이 있는 자는 하나님의 나라에 들어가기가 심히 어렵도다' 하시니","reference":"마가복음 10:23","category":"$undefined"},{"id":"24613","book":"마가복음","book_name":"마가복음","chapter":10,"verse":24,"text":"제자들이 그 말씀에 놀라는지라 예수께서 다시 대답하여 가라사대 얘들아 하나님의 나라에 들어가기가 어떻게 어려운지","reference":"마가복음 10:24","category":"$undefined"},{"id":"24614","book":"마가복음","book_name":"마가복음","chapter":10,"verse":25,"text":"약대가 바늘귀로 나가는 것이 부자가 하나님의 나라에 들어가는 것보다 쉬우니라 하신대","reference":"마가복음 10:25","category":"$undefined"},{"id":"24615","book":"마가복음","book_name":"마가복음","chapter":10,"verse":26,"text":"제자들이 심히 놀라 서로 말하되 `그런즉 누가 구원을 얻을 수 있는가 ?' 하니","reference":"마가복음 10:26","category":"$undefined"},{"id":"24616","book":"마가복음","book_name":"마가복음","chapter":10,"verse":27,"text":"예수께서 저희를 보시며 가라사대 `사람으로는 할 수 없으되 하나님으로는 그렇지 아니하니 하나님으로서는 다 하실 수 있느니라 !'","reference":"마가복음 10:27","category":"$undefined"},{"id":"24617","book":"마가복음","book_name":"마가복음","chapter":10,"verse":28,"text":"베드로가 여짜와 가로되 `보소서, 우리가 모든 것을 버리고 주를 좇았나이다'","reference":"마가복음 10:28","category":"$undefined"},{"id":"24618","book":"마가복음","book_name":"마가복음","chapter":10,"verse":29,"text":"예수께서 가라사대 `내가 진실로 너희에게 이르노니 나와 및 복음을 위하여 집이나, 형제나, 자매나, 어미나, 아비나, 자식이나, 전토를 버린 자는","reference":"마가복음 10:29","category":"$undefined"},{"id":"24619","book":"마가복음","book_name":"마가복음","chapter":10,"verse":30,"text":"금세에 있어 집과 형제와 자매와 모친과 자식과 전토를 백배나 받되 핍박을 겸하여 받고 내세에 영생을 받지 못할 자가 없느니라","reference":"마가복음 10:30","category":"$undefined"},{"id":"24620","book":"마가복음","book_name":"마가복음","chapter":10,"verse":31,"text":"그러나 먼저 된 자로서 나중 되고 나중 된 자로서 먼저 될 자가 많으니라'","reference":"마가복음 10:31","category":"$undefined"},{"id":"24621","book":"마가복음","book_name":"마가복음","chapter":10,"verse":32,"text":"예루살렘으로 올라가는 길에 예수께서 제자들 앞에 서서 가시는데 저희가 놀라고 좇는 자들은 두려워하더라 이에 다시 열 두 제자를 데리시고 자기의 당할 일을 일러 가라사대","reference":"마가복음 10:32","category":"$undefined"},{"id":"24622","book":"마가복음","book_name":"마가복음","chapter":10,"verse":33,"text":"`보라, 우리가 예루살렘에 올라가노니 인자가 대제사장들과 서기관들에게 넘기우매 저희가 죽이기로 결안하고 이방인들에게 넘겨 주겠고","reference":"마가복음 10:33","category":"$undefined"},{"id":"24623","book":"마가복음","book_name":"마가복음","chapter":10,"verse":34,"text":"그들은 능욕하며 침 뱉으며 채찍질하고 죽일 것이니 저는 삼일 만에 살아나리라' 하시니라","reference":"마가복음 10:34","category":"$undefined"},{"id":"24624","book":"마가복음","book_name":"마가복음","chapter":10,"verse":35,"text":"세베대의 아들 야고보와 요한이 주께 나아와 여짜오되 `선생님이여, 무엇이든지 우리의 구하는 바를 우리에게 하여 주시기를 원하옵나이다'","reference":"마가복음 10:35","category":"$undefined"},{"id":"24625","book":"마가복음","book_name":"마가복음","chapter":10,"verse":36,"text":"이르시되 `너희에게 무엇을 하여 주기를 원하느냐 ?'","reference":"마가복음 10:36","category":"$undefined"},{"id":"24626","book":"마가복음","book_name":"마가복음","chapter":10,"verse":37,"text":"여짜오되 `주의 영광 중에서 우리를 하나는 주의 우편에, 하나는 좌편에 앉게 하여 주옵소서'","reference":"마가복음 10:37","category":"$undefined"},{"id":"24627","book":"마가복음","book_name":"마가복음","chapter":10,"verse":38,"text":"예수께서 가라사대 `너희 구하는 것을 너희가 알지 못하는도다 너희가 나의 마시는 잔을 마시며 나의 받는 세례를 받을 수 있느냐 ?'","reference":"마가복음 10:38","category":"$undefined"},{"id":"24628","book":"마가복음","book_name":"마가복음","chapter":10,"verse":39,"text":"저희가 말하되 `할 수 있나이다' 예수께서 이르시되 `너희가 나의 마시는 잔을 마시며 나의 받는 세례를 받으려니와","reference":"마가복음 10:39","category":"$undefined"},{"id":"24629","book":"마가복음","book_name":"마가복음","chapter":10,"verse":40,"text":"내 좌우편에 앉는 것은 나의 줄 것이 아니라 누구를 위하여 예비되었든지 그들이 얻을 것이니라'","reference":"마가복음 10:40","category":"$undefined"},{"id":"24630","book":"마가복음","book_name":"마가복음","chapter":10,"verse":41,"text":"열 제자가 듣고 야고보와 요한에 대하여 분히 여기거늘","reference":"마가복음 10:41","category":"$undefined"},{"id":"24631","book":"마가복음","book_name":"마가복음","chapter":10,"verse":42,"text":"예수께서 불러다가 이르시되 `이방인의 소위 집권자들이 저희를 임의로 주관하고 그 대인(大人)들이 저희에게 권세를 부리는 줄을 너희가 알거니와","reference":"마가복음 10:42","category":"$undefined"},{"id":"24632","book":"마가복음","book_name":"마가복음","chapter":10,"verse":43,"text":"너희 중에는 그렇지 아니하니 너희 중에 누구든지 크고자 하는 자는 너희를 섬기는 자가 되고","reference":"마가복음 10:43","category":"$undefined"},{"id":"24633","book":"마가복음","book_name":"마가복음","chapter":10,"verse":44,"text":"너희 중에 누구든지 으뜸이 되고자 하는 자는 모든 사람의 종이 되어야 하리라","reference":"마가복음 10:44","category":"$undefined"},{"id":"24634","book":"마가복음","book_name":"마가복음","chapter":10,"verse":45,"text":"인자의 온 것은 섬김을 받으려 함이 아니라 도리어 섬기려 하고 자기 목숨을 많은 사람의 대속물로 주려 함이니라'","reference":"마가복음 10:45","category":"$undefined"},{"id":"24635","book":"마가복음","book_name":"마가복음","chapter":10,"verse":46,"text":"저희가 여리고에 이르렀더니 예수께서 제자들과 허다한 무리와 함께 여리고에 나가실 때에 디매오의 아들인 소경 거지 바디매오가 길가에 앉았다가","reference":"마가복음 10:46","category":"$undefined"},{"id":"24636","book":"마가복음","book_name":"마가복음","chapter":10,"verse":47,"text":"나사렛 예수시란 말을 듣고 소리질러 가로되 `다윗의 자손 예수여, 나를 불쌍히 여기소서 !' 하거늘","reference":"마가복음 10:47","category":"$undefined"},{"id":"24637","book":"마가복음","book_name":"마가복음","chapter":10,"verse":48,"text":"많은 사람이 꾸짖어 잠잠하라 하되 그가 더욱 소리질러 가로되 `다윗의 자손이여, 나를 불쌍히 여기소서 !' 하는지라","reference":"마가복음 10:48","category":"$undefined"},{"id":"24638","book":"마가복음","book_name":"마가복음","chapter":10,"verse":49,"text":"예수께서 머물러 서서 `저를 부르라' 하시니 저희가 그 소경을 부르며 이르되 `안심하고 일어나라 너를 부르신다' 하매","reference":"마가복음 10:49","category":"$undefined"},{"id":"24639","book":"마가복음","book_name":"마가복음","chapter":10,"verse":50,"text":"소경이 겉옷을 내어 버리고 뛰어 일어나 예수께 나아오거늘","reference":"마가복음 10:50","category":"$undefined"},{"id":"24640","book":"마가복음","book_name":"마가복음","chapter":10,"verse":51,"text":"예수께서 일러 가라사대 `네게 무엇을 하여 주기를 원하느냐 ?' 소경이 가로되 `선생님이여, 보기를 원하나이다'","reference":"마가복음 10:51","category":"$undefined"},{"id":"24641","book":"마가복음","book_name":"마가복음","chapter":10,"verse":52,"text":"예수께서 이르시되 `가라, 네 믿음이 너를 구원하였느니라 !' 하시니 저가 곧 보게 되어 예수를 길에서 좇으니라","reference":"마가복음 10:52","category":"$undefined"}],"bookSlug":"mark"}]
