2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":11,"verses":[{"id":"24642","book":"마가복음","book_name":"마가복음","chapter":11,"verse":1,"text":"저희가 예루살렘에 가까이 와서 감람산 벳바게와 베다니에 이르렀을 때에 예수께서 제자 중 둘을 보내시며","reference":"마가복음 11:1","category":"$undefined"},{"id":"24643","book":"마가복음","book_name":"마가복음","chapter":11,"verse":2,"text":"이르시되 `너희 맞은편 마을로 가라 그리로 들어가면 곧 아직 아무 사람도 타 보지 않은 나귀 새끼의 매여 있는 것을 보리니 풀어 끌고 오너라","reference":"마가복음 11:2","category":"$undefined"},{"id":"24644","book":"마가복음","book_name":"마가복음","chapter":11,"verse":3,"text":"만일 누가 너희에게 왜 이리 하느냐 ? 묻거든 주가 쓰시겠다 ! 하라 그리하면 즉시 이리로 보내리라' 하시니","reference":"마가복음 11:3","category":"$undefined"},{"id":"24645","book":"마가복음","book_name":"마가복음","chapter":11,"verse":4,"text":"제자들이 가서 본즉 나귀 새끼가 문 앞 거리에 매여 있는지라 그것을 푸니","reference":"마가복음 11:4","category":"$undefined"},{"id":"24646","book":"마가복음","book_name":"마가복음","chapter":11,"verse":5,"text":"거기 섰는 사람 중 어떤 이들이 가로되 `나귀새끼를 풀어 무엇하려느냐 ?' 하매","reference":"마가복음 11:5","category":"$undefined"},{"id":"24647","book":"마가복음","book_name":"마가복음","chapter":11,"verse":6,"text":"제자들이 예수의 이르신대로 말한대 이에 허락하는지라","reference":"마가복음 11:6","category":"$undefined"},{"id":"24648","book":"마가복음","book_name":"마가복음","chapter":11,"verse":7,"text":"나귀 새끼를 예수께로 끌고 와서 자기들의 겉옷을 그 위에 걸쳐 두매 예수께서 타시니","reference":"마가복음 11:7","category":"$undefined"},{"id":"24649","book":"마가복음","book_name":"마가복음","chapter":11,"verse":8,"text":"많은 사람은 자기 겉옷과 다른 이들은 밭에서 벤 나무가지를 길에 펴며","reference":"마가복음 11:8","category":"$undefined"},{"id":"24650","book":"마가복음","book_name":"마가복음","chapter":11,"verse":9,"text":"앞에서 가고 뒤에서 따르는 자들이 소리지르되 `호산나 찬송하리로다 주의 이름으로 오시는 이여 !","reference":"마가복음 11:9","category":"$undefined"},{"id":"24651","book":"마가복음","book_name":"마가복음","chapter":11,"verse":10,"text":"찬송하리로다 오는 우리 조상 다윗의 나라여 ! 가장 높은 곳에서 호산나' 하더라","reference":"마가복음 11:10","category":"$undefined"},{"id":"24652","book":"마가복음","book_name":"마가복음","chapter":11,"verse":11,"text":"예수께서 예루살렘에 이르러 성전에 들어가사 모든 것을 둘러 보시고 때가 이미 저물매 열 두 제자를 데리시고 베다니에 나가시다","reference":"마가복음 11:11","category":"$undefined"},{"id":"24653","book":"마가복음","book_name":"마가복음","chapter":11,"verse":12,"text":"이튿날 저희가 베다니에서 나왔을 때에 예수께서 시장하신지라","reference":"마가복음 11:12","category":"$undefined"},{"id":"24654","book":"마가복음","book_name":"마가복음","chapter":11,"verse":13,"text":"멀리서 잎사귀 있는 한 무화과나무를 보시고 혹 그 나무에 무엇이 있을까 하여 가셨더니 가서 보신즉 잎사귀 외에 아무 것도 없더라 이는 무화과의 때가 아님이라","reference":"마가복음 11:13","category":"$undefined"},{"id":"24655","book":"마가복음","book_name":"마가복음","chapter":11,"verse":14,"text":"예수께서 나무에게 일러 가라사대 `이제부터 영원토록 사람이 네게서 열매를 따먹지 못하리라' 하시니 제자들이 이를 듣더라","reference":"마가복음 11:14","category":"$undefined"},{"id":"24656","book":"마가복음","book_name":"마가복음","chapter":11,"verse":15,"text":"저희가 예루살렘에 들어가니라 예수께서 성전에 들어가사 성전 안에서 매매하는 자들을 내어 쫓으시며 돈 바꾸는 자들의 상과 비둘기 파는 자들의 의자를 둘러 엎으시며","reference":"마가복음 11:15","category":"$undefined"},{"id":"24657","book":"마가복음","book_name":"마가복음","chapter":11,"verse":16,"text":"아무나 기구를 가지고 성전 안으로 지나다님을 허치 아니하시고","reference":"마가복음 11:16","category":"$undefined"},{"id":"24658","book":"마가복음","book_name":"마가복음","chapter":11,"verse":17,"text":"이에 가르쳐 이르시되 `기록된 바 내 집은 만민의 기도하는 집이라 칭함을 받으리라고 하지 아니하였느냐 ? 너희는 강도의 굴혈을 만들었도다' 하시매","reference":"마가복음 11:17","category":"$undefined"},{"id":"24659","book":"마가복음","book_name":"마가복음","chapter":11,"verse":18,"text":"대제사장들과 서기관들이 듣고 예수를 어떻게 멸할까 하고 꾀하니 이는 무리가 다 그의 교훈을 기이히 여기므로 그를 두려워함 일러라","reference":"마가복음 11:18","category":"$undefined"},{"id":"24660","book":"마가복음","book_name":"마가복음","chapter":11,"verse":19,"text":"매양 저물매 저희가 성 밖으로 나가더라","reference":"마가복음 11:19","category":"$undefined"},{"id":"24661","book":"마가복음","book_name":"마가복음","chapter":11,"verse":20,"text":"저희가 아침에 지나갈 때에 무화과나무가 뿌리로부터 마른 것을 보고","reference":"마가복음 11:20","category":"$undefined"},{"id":"24662","book":"마가복음","book_name":"마가복음","chapter":11,"verse":21,"text":"베드로가 생각이 나서 여짜오되 `랍비여, 보소서 저주하신 무화과 나무가 말랐나이다'","reference":"마가복음 11:21","category":"$undefined"},{"id":"24663","book":"마가복음","book_name":"마가복음","chapter":11,"verse":22,"text":"예수께서 대답하여 저희에게 이르시되 `하나님을 믿으라 !","reference":"마가복음 11:22","category":"$undefined"},{"id":"24664","book":"마가복음","book_name":"마가복음","chapter":11,"verse":23,"text":"내가 진실로 너희에게 이르노니 누구든지 이 산더러 들리어 바다에 던지우라 하며 그 말하는 것이 이를 줄 믿고 마음에 의심치 아니하면 그대로 되리라 !","reference":"마가복음 11:23","category":"$undefined"},{"id":"24665","book":"마가복음","book_name":"마가복음","chapter":11,"verse":24,"text":"그러므로 내가 너희에게 말하노니 무엇이든지 기도하고 구하는 것은 받은 줄로 믿으라 그리하면 너희에게 그대로 되리라","reference":"마가복음 11:24","category":"$undefined"},{"id":"24666","book":"마가복음","book_name":"마가복음","chapter":11,"verse":25,"text":"서서 기도할 때에 아무에게나 혐의가 있거든 용서하라 그리하여야 하늘에 계신 너희 아버지도 너희 허물을 사하여 주시리라' 하셨더라","reference":"마가복음 11:25","category":"$undefined"},{"id":"24667","book":"마가복음","book_name":"마가복음","chapter":11,"verse":26,"text":"(없 음)","reference":"마가복음 11:26","category":"$undefined"},{"id":"24668","book":"마가복음","book_name":"마가복음","chapter":11,"verse":27,"text":"저희가 다시 예루살렘에 들어가니라 예수께서 성전에서 걸어다니실 때에 대제사장들과 서기관들과 장로들이 나아와","reference":"마가복음 11:27","category":"$undefined"},{"id":"24669","book":"마가복음","book_name":"마가복음","chapter":11,"verse":28,"text":"가로되 `무슨 권세로 이런 일을 하느뇨 ? 누가 이런 일 할 이 권세를 주었느뇨 ?'","reference":"마가복음 11:28","category":"$undefined"},{"id":"24670","book":"마가복음","book_name":"마가복음","chapter":11,"verse":29,"text":"예수께서 가라사대 `나도 한 말을 너희에게 물으리니 대답하라 그리하면 나도 무슨 권세로 이런 일을 하는지 이르리라","reference":"마가복음 11:29","category":"$undefined"},{"id":"24671","book":"마가복음","book_name":"마가복음","chapter":11,"verse":30,"text":"요한의 세례가 하늘로서냐 ? 사람에게로서냐 ? 내게 대답하라'","reference":"마가복음 11:30","category":"$undefined"},{"id":"24672","book":"마가복음","book_name":"마가복음","chapter":11,"verse":31,"text":"저희가 서로 의논하여 가로되 `만일 하늘로서라 하면 어찌하여 저를 믿지 아니하였느냐 ? 할 것이니","reference":"마가복음 11:31","category":"$undefined"},{"id":"24673","book":"마가복음","book_name":"마가복음","chapter":11,"verse":32,"text":"그러면 사람에게로서라 할까 ?' 하였으나 모든 사람이 요한을 참 선지자로 여기므로 저희가 백성을 무서워하는지라","reference":"마가복음 11:32","category":"$undefined"},{"id":"24674","book":"마가복음","book_name":"마가복음","chapter":11,"verse":33,"text":"이에 예수께 대답하여 가로되 `우리가 알지 못하노라? 하니 예수께서 가라사대 `나도 무슨 권세로 이런 일을 하는지 너희에게 이르지 아니하리라' 하시니라","reference":"마가복음 11:33","category":"$undefined"}],"bookSlug":"mark"}]
