2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":12,"verses":[{"id":"24675","book":"마가복음","book_name":"마가복음","chapter":12,"verse":1,"text":"예수께서 비유로 저희에게 말씀하시되 `한사람이 포도원을 만들고 산울로 두르고 즙 짜는 구유 자리를 파고 망대를 짓고 농부들에게 세로 주고 타국에 갔더니","reference":"마가복음 12:1","category":"$undefined"},{"id":"24676","book":"마가복음","book_name":"마가복음","chapter":12,"verse":2,"text":"때가 이르매 농부들에게 포도원 소출 얼마를 받으려고 한 종을 보내니","reference":"마가복음 12:2","category":"$undefined"},{"id":"24677","book":"마가복음","book_name":"마가복음","chapter":12,"verse":3,"text":"저희가 종을 잡아 심히 때리고 거저 보내었거늘","reference":"마가복음 12:3","category":"$undefined"},{"id":"24678","book":"마가복음","book_name":"마가복음","chapter":12,"verse":4,"text":"다시 다른 종을 보내니 그의 머리에 상처를 내고 능욕하였거늘","reference":"마가복음 12:4","category":"$undefined"},{"id":"24679","book":"마가복음","book_name":"마가복음","chapter":12,"verse":5,"text":"또 다른 종을 보내니 저희가 그를 죽이고 또 그 외 많은 종들도 혹은 때리고 혹은 죽인지라","reference":"마가복음 12:5","category":"$undefined"},{"id":"24680","book":"마가복음","book_name":"마가복음","chapter":12,"verse":6,"text":"오히려 한사람이 있으니 곧 그의 사랑하는 아들이라 최후로 이를 보내며 가로되 내 아들은 공경하리라 하였더니","reference":"마가복음 12:6","category":"$undefined"},{"id":"24681","book":"마가복음","book_name":"마가복음","chapter":12,"verse":7,"text":"저 농부들이 서로 말하되 이는 상속자니 자, 죽이자 그러면 그 유업이 우리 것이 되리라 하고","reference":"마가복음 12:7","category":"$undefined"},{"id":"24682","book":"마가복음","book_name":"마가복음","chapter":12,"verse":8,"text":"이에 잡아 죽여 포도원 밖에 내어 던졌느니라","reference":"마가복음 12:8","category":"$undefined"},{"id":"24683","book":"마가복음","book_name":"마가복음","chapter":12,"verse":9,"text":"포도원 주인이 어떻게 하겠느뇨 ? 와서 그 농부들을 진멸하고 포도원을 다른 사람들에게 주리라","reference":"마가복음 12:9","category":"$undefined"},{"id":"24684","book":"마가복음","book_name":"마가복음","chapter":12,"verse":10,"text":"너희가 성경에 건축자들의 버린 돌이 모퉁이의 머릿돌이 되었나니","reference":"마가복음 12:10","category":"$undefined"},{"id":"24685","book":"마가복음","book_name":"마가복음","chapter":12,"verse":11,"text":"이것은 주로 말미암아 된 것이요 우리 눈에 기이하도다 함을 읽어 보지도 못하였느냐 ?' 하시더라","reference":"마가복음 12:11","category":"$undefined"},{"id":"24686","book":"마가복음","book_name":"마가복음","chapter":12,"verse":12,"text":"저희가 예수의 이 비유는 자기들을 가리켜 말씀하심인 줄 알고 잡고자 하되 무리를 두려워하여 예수를 버려두고 가니라","reference":"마가복음 12:12","category":"$undefined"},{"id":"24687","book":"마가복음","book_name":"마가복음","chapter":12,"verse":13,"text":"저희가 예수의 말씀을 책잡으려 하여 바리새인과 헤롯당 중에서 사람을 보내매","reference":"마가복음 12:13","category":"$undefined"},{"id":"24688","book":"마가복음","book_name":"마가복음","chapter":12,"verse":14,"text":"와서 가로되 `선생님이여, 우리가 아노니 당신은 참되시고 아무라도 꺼리는 일이 없으시니 이는 사람을 외모로 보지 않고 오직 참으로써 하나님의 도를 가르치심이니이다 가이사에게 세를 바치는것이 가하니이까 ? 불가하니이까 ?","reference":"마가복음 12:14","category":"$undefined"},{"id":"24689","book":"마가복음","book_name":"마가복음","chapter":12,"verse":15,"text":"우리가 바치리이까 ? 말리이까 ?'한대 예수께서 그 외식함을 아시고 이르시되 `어찌하여 나를 시험하느냐 ? 데나리온 하나를 가져다가 내게 보이라' 하시니","reference":"마가복음 12:15","category":"$undefined"},{"id":"24690","book":"마가복음","book_name":"마가복음","chapter":12,"verse":16,"text":"가져왔거늘 예수께서 가라사대 `이 화상과 이 글이 뉘 것이냐 ?' 가로되 `가이사의 것이니이다'","reference":"마가복음 12:16","category":"$undefined"},{"id":"24691","book":"마가복음","book_name":"마가복음","chapter":12,"verse":17,"text":"이에 예수께서 가라사대 `가이사의 것은 가이사에게 하나님의 것은 하나님께 바치라' 하시니 저희가 예수께 대하여 심히 기이히 여기더라","reference":"마가복음 12:17","category":"$undefined"},{"id":"24692","book":"마가복음","book_name":"마가복음","chapter":12,"verse":18,"text":"부활이 없다 하는 사두개인들이 예수께 와서 물어 가로되","reference":"마가복음 12:18","category":"$undefined"},{"id":"24693","book":"마가복음","book_name":"마가복음","chapter":12,"verse":19,"text":"`선생님이여, 모세가 우리에게 써 주기를 사람의 형이 자식이 없이 아내를 두고 죽거든 그 동생이 그 아내를 취하여 형을 위하여 후사를 세울지니라 하였나이다","reference":"마가복음 12:19","category":"$undefined"},{"id":"24694","book":"마가복음","book_name":"마가복음","chapter":12,"verse":20,"text":"칠 형제가 있었는데 맏이 아내를 취하였다가 후사가 없이 죽고","reference":"마가복음 12:20","category":"$undefined"},{"id":"24695","book":"마가복음","book_name":"마가복음","chapter":12,"verse":21,"text":"둘째도 그 여자를 취하였다가 후사가 없이 죽고 세째도 그렇게 하여","reference":"마가복음 12:21","category":"$undefined"},{"id":"24696","book":"마가복음","book_name":"마가복음","chapter":12,"verse":22,"text":"일곱이 다 후사가 없었고 최후에 여자도 죽었나이다","reference":"마가복음 12:22","category":"$undefined"},{"id":"24697","book":"마가복음","book_name":"마가복음","chapter":12,"verse":23,"text":"일곱사람이 다 그를 아내로 취하였으니 부활을 당하여 저희가 살아날 때에 그 중에 뉘 아내가 되리이까 ?'","reference":"마가복음 12:23","category":"$undefined"},{"id":"24698","book":"마가복음","book_name":"마가복음","chapter":12,"verse":24,"text":"예수께서 가라사대 `너희가 성경도 하나님의 능력도 알지 못하므로 오해함이 아니냐 ?","reference":"마가복음 12:24","category":"$undefined"},{"id":"24699","book":"마가복음","book_name":"마가복음","chapter":12,"verse":25,"text":"사람이 죽은 자 가운데서 살아날 때에는 장가도 아니가고 시집도 아니가고 하늘에 있는 천사들과 같으니라","reference":"마가복음 12:25","category":"$undefined"},{"id":"24700","book":"마가복음","book_name":"마가복음","chapter":12,"verse":26,"text":"죽은 자의 살아난다는 것을 의논할찐대 너희가 모세의 책 중 가시나무떨기에 관한 글에 하나님께서 모세에게 이르시되 나는 아브라함의 하나님이요 이삭의 하나님이요 야곱의 하나님이로라 하신 말씀을 읽어보지 하였느냐","reference":"마가복음 12:26","category":"$undefined"},{"id":"24701","book":"마가복음","book_name":"마가복음","chapter":12,"verse":27,"text":"하나님은 죽은 자의 하나님이 아니요 산 자의 하나님이시라 너희가 크게 오해하였도다' 하시니라","reference":"마가복음 12:27","category":"$undefined"},{"id":"24702","book":"마가복음","book_name":"마가복음","chapter":12,"verse":28,"text":"서기관 중 한사람이 저희의 변론하는 것을 듣고 예수께서 대답 잘하신 줄을 알고 나아와 묻되 `모든 계명 중에 첫째가 무엇이니이까 ?'","reference":"마가복음 12:28","category":"$undefined"},{"id":"24703","book":"마가복음","book_name":"마가복음","chapter":12,"verse":29,"text":"예수께서 대답하시되 `첫째는 이것이니 이스라엘아 ! 들으라 주, 곧 우리 하나님은 유일한 주시라","reference":"마가복음 12:29","category":"$undefined"},{"id":"24704","book":"마가복음","book_name":"마가복음","chapter":12,"verse":30,"text":"네 마음을 다하고 목숨을 다하고 뜻을 다하고 힘을 다하여 주 너의 하나님을 사랑하라 하신 것이라","reference":"마가복음 12:30","category":"$undefined"},{"id":"24705","book":"마가복음","book_name":"마가복음","chapter":12,"verse":31,"text":"둘째는 이것이니 네 이웃을 네몸과 같이 사랑하라 하신 것이라 이에서 더 큰 계명이 없느니라'","reference":"마가복음 12:31","category":"$undefined"},{"id":"24706","book":"마가복음","book_name":"마가복음","chapter":12,"verse":32,"text":"서기관이 가로되 `선생님이여, 옳소이다 하나님은 한 분이시요 그 외에 다른 이가 없다 하신 말씀이 참이니이다","reference":"마가복음 12:32","category":"$undefined"},{"id":"24707","book":"마가복음","book_name":"마가복음","chapter":12,"verse":33,"text":"또 마음을 다하고 지혜를 다하고 힘을 다하여 하나님을 사랑하는 것과 또 이웃을 제몸과 같이 사랑하는 것이 전체로 드리는 모든 번제물과 기타 제물보다 나으니이다'","reference":"마가복음 12:33","category":"$undefined"},{"id":"24708","book":"마가복음","book_name":"마가복음","chapter":12,"verse":34,"text":"예수께서 그 지혜 있게 대답함을 보시고 이르시되 `네가 하나님의 나라에 멀지 않도다' 하시니 그 후에 감히 묻는 자가 없더라","reference":"마가복음 12:34","category":"$undefined"},{"id":"24709","book":"마가복음","book_name":"마가복음","chapter":12,"verse":35,"text":"예수께서 성전에서 가르치실새 대답하여 가라사대 `어찌하여 서기관들이 그리스도를 다윗의 자손이라 하느뇨 ?","reference":"마가복음 12:35","category":"$undefined"},{"id":"24710","book":"마가복음","book_name":"마가복음","chapter":12,"verse":36,"text":"다윗이 성령에 감동하여 친히 말하되 주께서 내 주께 이르시되 내가 네 원수를 발 아래 둘 때까지 내 우편에 앉았으라 하셨도다 하였느니라","reference":"마가복음 12:36","category":"$undefined"},{"id":"24711","book":"마가복음","book_name":"마가복음","chapter":12,"verse":37,"text":"다윗이 그리스도를 주라 하였은즉 어찌 그의 자손이 되겠느냐 ?' 하시더라 백성이 즐겁게 듣더라","reference":"마가복음 12:37","category":"$undefined"},{"id":"24712","book":"마가복음","book_name":"마가복음","chapter":12,"verse":38,"text":"예수께서 가르치실 때에 가라사대 `긴 옷을 입고 다니는 것과 시장에서 문안 받는 것과","reference":"마가복음 12:38","category":"$undefined"},{"id":"24713","book":"마가복음","book_name":"마가복음","chapter":12,"verse":39,"text":"회당의 상좌와 잔치의 상석을 원하는 서기관들을 삼가라","reference":"마가복음 12:39","category":"$undefined"},{"id":"24714","book":"마가복음","book_name":"마가복음","chapter":12,"verse":40,"text":"저희는 과부의 가산을 삼키며 외식으로 길게 기도하는 자니 그 받는 판결이 더욱 중하리라' 하시니라","reference":"마가복음 12:40","category":"$undefined"},{"id":"24715","book":"마가복음","book_name":"마가복음","chapter":12,"verse":41,"text":"예수께서 연보궤를 대하여 앉으사 무리의 연보 궤에 돈 넣는 것을 보실새 여러 부자는 많이 넣는데","reference":"마가복음 12:41","category":"$undefined"},{"id":"24716","book":"마가복음","book_name":"마가복음","chapter":12,"verse":42,"text":"한 가난한 과부는 와서 두 렙돈 곧 한 고드란트를 넣는지라","reference":"마가복음 12:42","category":"$undefined"},{"id":"24717","book":"마가복음","book_name":"마가복음","chapter":12,"verse":43,"text":"예수께서 제자들을 불러다가 이르시되 `내가 진실로 너희에게 이르노니 이 가난한 과부는 연보 궤에 넣는 모든 사람보다 많이 넣었도다","reference":"마가복음 12:43","category":"$undefined"},{"id":"24718","book":"마가복음","book_name":"마가복음","chapter":12,"verse":44,"text":"저희는 다 그 풍족한 중에서 넣었거니와 이 과부는 그 구차한 중에서 자기 모든 소유 곧 생활비 전부를 넣었느니라' 하셨더라","reference":"마가복음 12:44","category":"$undefined"}],"bookSlug":"mark"}]
