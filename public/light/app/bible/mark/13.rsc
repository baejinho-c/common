2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":13,"verses":[{"id":"24719","book":"마가복음","book_name":"마가복음","chapter":13,"verse":1,"text":"예수께서 성전에서 나가실 때에 제자 중 하나가 가로되 `선생님이여, 보소서 이 돌들이 어떠하며 이 건물들이 어떠하니이까 ?'","reference":"마가복음 13:1","category":"$undefined"},{"id":"24720","book":"마가복음","book_name":"마가복음","chapter":13,"verse":2,"text":"예수께서 이르시되 `네가 이 큰 건물들을 보느냐 ? 돌 하나도 돌 위에 남지 않고 다 무너뜨려지리라' 하시니라","reference":"마가복음 13:2","category":"$undefined"},{"id":"24721","book":"마가복음","book_name":"마가복음","chapter":13,"verse":3,"text":"예수께서 감람산에서 성전을 마주 대하여 앉으셨을 때에 베드로와 야고보와 요한과 안드레가 종용히 묻자오되","reference":"마가복음 13:3","category":"$undefined"},{"id":"24722","book":"마가복음","book_name":"마가복음","chapter":13,"verse":4,"text":"`우리에게 이르소서 어느 때에 이런 일이 있겠사오며 이 모든 일이 이루려 할 때에 무슨 징조가 있사오리이까 ?'","reference":"마가복음 13:4","category":"$undefined"},{"id":"24723","book":"마가복음","book_name":"마가복음","chapter":13,"verse":5,"text":"예수께서 이르시되 `너희가 사람의 미혹을 받지 않도록 주의하라","reference":"마가복음 13:5","category":"$undefined"},{"id":"24724","book":"마가복음","book_name":"마가복음","chapter":13,"verse":6,"text":"많은 사람이 내 이름으로 와서 이르되 내가 그로라 하여 많은 사람을 미혹케 하리라","reference":"마가복음 13:6","category":"$undefined"},{"id":"24725","book":"마가복음","book_name":"마가복음","chapter":13,"verse":7,"text":"난리와 난리 소문을 들을 때에 두려워 말라 이런 일이 있어야 하되 끝은 아직 아니니라","reference":"마가복음 13:7","category":"$undefined"},{"id":"24726","book":"마가복음","book_name":"마가복음","chapter":13,"verse":8,"text":"민족이 민족을 나라가 나라를 대적하여 일어나겠고 처처에 지진이 있으며 기근이 있으리니 이는 재난의 시작이니라","reference":"마가복음 13:8","category":"$undefined"},{"id":"24727","book":"마가복음","book_name":"마가복음","chapter":13,"verse":9,"text":"너희는 스스로 조심하라 사람들이 너희를 공회에 넘겨주겠고 너희를 회당에서 매질하겠으며 나를 인하여 너희가 관장들과 임금들 앞에 서리니 이는 저희에게 증거되려 함이라","reference":"마가복음 13:9","category":"$undefined"},{"id":"24728","book":"마가복음","book_name":"마가복음","chapter":13,"verse":10,"text":"또 복음이 먼저 만국에 전파되어야 할 것이니라","reference":"마가복음 13:10","category":"$undefined"},{"id":"24729","book":"마가복음","book_name":"마가복음","chapter":13,"verse":11,"text":"사람들이 너희를 끌어다가 넘겨줄 때에 무슨 말을 할까 미리 염려치 말고 무엇이든지 그 시에 너희에게 주시는 그 말을 하라 말하는 이는 너희가 아니요 성령이시니라","reference":"마가복음 13:11","category":"$undefined"},{"id":"24730","book":"마가복음","book_name":"마가복음","chapter":13,"verse":12,"text":"형제가 형제를 아비가 자식을 죽는데 내어주며 자식들이 부모를 대적하여 죽게 하리라","reference":"마가복음 13:12","category":"$undefined"},{"id":"24731","book":"마가복음","book_name":"마가복음","chapter":13,"verse":13,"text":"또 너희가 내 이름을 인하여 모든 사람에게 미움을 받을 것이나 나중까지 견디는 자는 구원을 얻으리라","reference":"마가복음 13:13","category":"$undefined"},{"id":"24732","book":"마가복음","book_name":"마가복음","chapter":13,"verse":14,"text":"멸망의 가증한 것이 서지 못할 곳에 선 것을 보거든 (읽는 자는 깨달을진저)그 때에 유대에 있는 자들은 산으로 도망할지어다","reference":"마가복음 13:14","category":"$undefined"},{"id":"24733","book":"마가복음","book_name":"마가복음","chapter":13,"verse":15,"text":"지붕 위에 있는 자는 내려가지도 말고 집에 있는 무엇을 가지러 들어가지도 말며","reference":"마가복음 13:15","category":"$undefined"},{"id":"24734","book":"마가복음","book_name":"마가복음","chapter":13,"verse":16,"text":"밭에 있는 자는 겉옷을 가지러 뒤로 돌이키지 말지어다","reference":"마가복음 13:16","category":"$undefined"},{"id":"24735","book":"마가복음","book_name":"마가복음","chapter":13,"verse":17,"text":"그 날에는 아이 밴 자들과 젖먹이는 자들에게 화가 있으리로다","reference":"마가복음 13:17","category":"$undefined"},{"id":"24736","book":"마가복음","book_name":"마가복음","chapter":13,"verse":18,"text":"이 일이 겨울에 나지 않도록 기도하라","reference":"마가복음 13:18","category":"$undefined"},{"id":"24737","book":"마가복음","book_name":"마가복음","chapter":13,"verse":19,"text":"이는 그날들은 환난의 날이 되겠음이라 하나님의 창조하신 창조부터 지금까지 이런 환난이 없었고 후에도 없으리라","reference":"마가복음 13:19","category":"$undefined"},{"id":"24738","book":"마가복음","book_name":"마가복음","chapter":13,"verse":20,"text":"만일 주께서 그날들을 감하지 아니하셨더면 모든 육체가 구원을 얻지 못할 것이어늘 자기의 택하신 백성을 위하여 그 날들을 감하셨느니라","reference":"마가복음 13:20","category":"$undefined"},{"id":"24739","book":"마가복음","book_name":"마가복음","chapter":13,"verse":21,"text":"그 때에 사람이 너희에게 말하되 보라 그리스도가 여기 있다 보라 저기 있다 하여도 믿지 말라","reference":"마가복음 13:21","category":"$undefined"},{"id":"24740","book":"마가복음","book_name":"마가복음","chapter":13,"verse":22,"text":"거짓 그리스도들과 거짓 선지자들이 일어나서 이적과 기사를 행하여 할 수만 있으면 택하신 백성을 미혹케 하려 하리라","reference":"마가복음 13:22","category":"$undefined"},{"id":"24741","book":"마가복음","book_name":"마가복음","chapter":13,"verse":23,"text":"너희는 삼가라 내가 모든 일을 너희에게 미리 말하였노라","reference":"마가복음 13:23","category":"$undefined"},{"id":"24742","book":"마가복음","book_name":"마가복음","chapter":13,"verse":24,"text":"그 때에 그 환난 후 해가 어두워지며 달이 빛을 내지 아니하며","reference":"마가복음 13:24","category":"$undefined"},{"id":"24743","book":"마가복음","book_name":"마가복음","chapter":13,"verse":25,"text":"별들이 하늘에서 떨어지며 하늘에 있는 권능들이 흔들리리라","reference":"마가복음 13:25","category":"$undefined"},{"id":"24744","book":"마가복음","book_name":"마가복음","chapter":13,"verse":26,"text":"그 때에 인자가 구름을 타고 큰 권능과 영광으로 오는 것을 사람들이 보리라","reference":"마가복음 13:26","category":"$undefined"},{"id":"24745","book":"마가복음","book_name":"마가복음","chapter":13,"verse":27,"text":"또 그 때에 저가 천사들을 보내어 자기 택하신 자들을 땅 끝으로 부터 하늘 끝까지 사방에서 모으리라","reference":"마가복음 13:27","category":"$undefined"},{"id":"24746","book":"마가복음","book_name":"마가복음","chapter":13,"verse":28,"text":"무화과나무의 비유를 배우라 그 가지가 연하여지고 잎사귀를 내면 여름이 가까운 줄을 아나니","reference":"마가복음 13:28","category":"$undefined"},{"id":"24747","book":"마가복음","book_name":"마가복음","chapter":13,"verse":29,"text":"이와 같이 너희가 이런 일이 나는 것을 보거든 인자가 가까이 곧 문앞에 이른 줄을 알라","reference":"마가복음 13:29","category":"$undefined"},{"id":"24748","book":"마가복음","book_name":"마가복음","chapter":13,"verse":30,"text":"내가 진실로 너희에게 말하노니 이 세대가 지나가기 전에 이 일이 다 이루리라","reference":"마가복음 13:30","category":"$undefined"},{"id":"24749","book":"마가복음","book_name":"마가복음","chapter":13,"verse":31,"text":"천지는 없어지겠으나 내 말은 없어지지 아니하리라","reference":"마가복음 13:31","category":"$undefined"},{"id":"24750","book":"마가복음","book_name":"마가복음","chapter":13,"verse":32,"text":"그러나 그 날과 그 때는 아무도 모르나니 하늘에 있는 천사들도 아들도 모르고 아버지만 아시느니라","reference":"마가복음 13:32","category":"$undefined"},{"id":"24751","book":"마가복음","book_name":"마가복음","chapter":13,"verse":33,"text":"주의하라 깨어 있으라 그 때가 언제인지 알지 못함이니라","reference":"마가복음 13:33","category":"$undefined"},{"id":"24752","book":"마가복음","book_name":"마가복음","chapter":13,"verse":34,"text":"가령 사람이 집을 떠나 타국으로 갈 때에 그 종들에게 권한을 주어 각각 사무를 맡기며 문지기에게 깨어 있으라 명함과 같으니","reference":"마가복음 13:34","category":"$undefined"},{"id":"24753","book":"마가복음","book_name":"마가복음","chapter":13,"verse":35,"text":"그러므로 깨어 있으라 집 주인이 언제 올는지 혹 저물 때엘는지, 밤중엘는지, 닭 울 때엘는지, 새벽엘는지, 너희가 알지 못함이라","reference":"마가복음 13:35","category":"$undefined"},{"id":"24754","book":"마가복음","book_name":"마가복음","chapter":13,"verse":36,"text":"그가 홀연히 와서 너희의 자는 것을 보지 않도록 하라","reference":"마가복음 13:36","category":"$undefined"},{"id":"24755","book":"마가복음","book_name":"마가복음","chapter":13,"verse":37,"text":"깨어 있으라 내가 너희에게 하는 이 말이 모든 사람에게 하는 말이니라' 하시니라","reference":"마가복음 13:37","category":"$undefined"}],"bookSlug":"mark"}]
