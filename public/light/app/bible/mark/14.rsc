2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":14,"verses":[{"id":"24756","book":"마가복음","book_name":"마가복음","chapter":14,"verse":1,"text":"이틀이 지나면 유월절과 무교절이라 대제사장들과 서기관들이 예수를 궤계로 잡아 죽일 방책을 구하며","reference":"마가복음 14:1","category":"$undefined"},{"id":"24757","book":"마가복음","book_name":"마가복음","chapter":14,"verse":2,"text":"가로되 `민요가 날까 하노니 명절에는 말자' 하더라","reference":"마가복음 14:2","category":"$undefined"},{"id":"24758","book":"마가복음","book_name":"마가복음","chapter":14,"verse":3,"text":"예수께서 베다니 문둥이 시몬의 집에서 식사하실 때에 한 여자가 매우 값진 향유 곧 순전한 나드 한 옥합을 가지고 와서 그 옥합을 깨뜨리고 예수의 머리에 부으니","reference":"마가복음 14:3","category":"$undefined"},{"id":"24759","book":"마가복음","book_name":"마가복음","chapter":14,"verse":4,"text":"어떤 사람들이 분내어 서로 말하되 `무슨 의사로 이 향유를 허비하였는가","reference":"마가복음 14:4","category":"$undefined"},{"id":"24760","book":"마가복음","book_name":"마가복음","chapter":14,"verse":5,"text":"이 향유를 삼백 데나리온 이상에 팔아 가난한 자들에게 줄 수 있었겠도다' 하며 그 여자를 책망하는지라","reference":"마가복음 14:5","category":"$undefined"},{"id":"24761","book":"마가복음","book_name":"마가복음","chapter":14,"verse":6,"text":"예수께서 가라사대 `가만 두어라 너희가 어찌하여 저를 괴롭게 하느냐 저가 내게 좋은 일을 하였느니라","reference":"마가복음 14:6","category":"$undefined"},{"id":"24762","book":"마가복음","book_name":"마가복음","chapter":14,"verse":7,"text":"가난한 자들은 항상 너희와 함께 있으니 아무 때라도 원하는 대로 도울 수 있거니와 나는 너희와 항상 함께 있지 아니하리라","reference":"마가복음 14:7","category":"$undefined"},{"id":"24763","book":"마가복음","book_name":"마가복음","chapter":14,"verse":8,"text":"저가 힘을 다하여 내 몸에 향유를 부어 내 장사를 미리 준비하였느니라","reference":"마가복음 14:8","category":"$undefined"},{"id":"24764","book":"마가복음","book_name":"마가복음","chapter":14,"verse":9,"text":"내가 진실로 너희에게 이르노니 온 천하에 어디서든지 복음이 전파되는 곳에는 이 여자의 행한 일도 말하여 저를 기념하리라' 하시니라","reference":"마가복음 14:9","category":"$undefined"},{"id":"24765","book":"마가복음","book_name":"마가복음","chapter":14,"verse":10,"text":"열 둘 중에 하나인 가룟 유다가 예수를 넘겨 주려고 대제사장들에게 가매","reference":"마가복음 14:10","category":"$undefined"},{"id":"24766","book":"마가복음","book_name":"마가복음","chapter":14,"verse":11,"text":"저희가 듣고 기뻐하여 돈을 주기로 약속하니 유다가 예수를 어떻게 넘겨 줄 기회를 찾더라","reference":"마가복음 14:11","category":"$undefined"},{"id":"24767","book":"마가복음","book_name":"마가복음","chapter":14,"verse":12,"text":"무교절의 첫날 곧 유월절 양 잡는 날에 제자들이 예수께 여짜오되 `우리가 어디로 가서 선생님으로 유월절을 잡수시게 예비하기를 원하시나이까 ?' 하매","reference":"마가복음 14:12","category":"$undefined"},{"id":"24768","book":"마가복음","book_name":"마가복음","chapter":14,"verse":13,"text":"예수께서 제자 중에 둘을 보내시며 가라사대 `성내(城內)로 들어가라 그리하면 물 한 동이를 가지고 가는 사람을 만나리니 그를 따라 가서","reference":"마가복음 14:13","category":"$undefined"},{"id":"24769","book":"마가복음","book_name":"마가복음","chapter":14,"verse":14,"text":"어디든지 그의 들어가는 그 집주인에게 이르되 `선생님의 말씀이 내가 내 제자들과 함께 유월절을 먹을 나의 객실이 어디 있느뇨 ? 하시더라 하라","reference":"마가복음 14:14","category":"$undefined"},{"id":"24770","book":"마가복음","book_name":"마가복음","chapter":14,"verse":15,"text":"그리하면 자리를 베풀고 예비된 큰 다락방을 보이리니 거기서 우리를 위하여 예비하라' 하신대","reference":"마가복음 14:15","category":"$undefined"},{"id":"24771","book":"마가복음","book_name":"마가복음","chapter":14,"verse":16,"text":"제자들이 나가 성내로 들어가서 예수의 하시던 말씀대로 만나 유월절을 예비하니라","reference":"마가복음 14:16","category":"$undefined"},{"id":"24772","book":"마가복음","book_name":"마가복음","chapter":14,"verse":17,"text":"저물매 그 열 둘을 데리시고 와서","reference":"마가복음 14:17","category":"$undefined"},{"id":"24773","book":"마가복음","book_name":"마가복음","chapter":14,"verse":18,"text":"다 앉아 먹을 때에 예수께서 가라사대 `내가 진실로 너희에게 이르노니 너희 중에 한사람 곧 나와 함께 먹는 자가 나를 팔리라' 하신대","reference":"마가복음 14:18","category":"$undefined"},{"id":"24774","book":"마가복음","book_name":"마가복음","chapter":14,"verse":19,"text":"저희가 근심하여 하나씩 하나씩 여짜오되 `내니이까 ?'","reference":"마가복음 14:19","category":"$undefined"},{"id":"24775","book":"마가복음","book_name":"마가복음","chapter":14,"verse":20,"text":"이르시되 `열 둘 중 하나 곧 나와 함께 그릇에 손을 넣는 자니라","reference":"마가복음 14:20","category":"$undefined"},{"id":"24776","book":"마가복음","book_name":"마가복음","chapter":14,"verse":21,"text":"인자는 자기에게 대하여 기록된 대로 가거니와 인자를 파는 그 사람에게는 화가 있으리로다 그 사람은 차라리 나지 아니하였더면 제게 좋을뻔 하였느니라' 하시니라","reference":"마가복음 14:21","category":"$undefined"},{"id":"24777","book":"마가복음","book_name":"마가복음","chapter":14,"verse":22,"text":"저희가 먹을 때에 예수께서 떡을 가지사 축복하시고 떼어 제자들에게 주시며 가라사대 `받으라 이것이 내 몸이니라' 하시고","reference":"마가복음 14:22","category":"$undefined"},{"id":"24778","book":"마가복음","book_name":"마가복음","chapter":14,"verse":23,"text":"또 잔을 가지사 사례하시고 저희에게 주시니 다 이를 마시매","reference":"마가복음 14:23","category":"$undefined"},{"id":"24779","book":"마가복음","book_name":"마가복음","chapter":14,"verse":24,"text":"가라사대 `이것은 많은 사람을 위하여 흘리는바 나의 피 곧 언약의 피니라","reference":"마가복음 14:24","category":"$undefined"},{"id":"24780","book":"마가복음","book_name":"마가복음","chapter":14,"verse":25,"text":"진실로 너희에게 이르노니 내가 포도나무에서 난 것을 하나님 나라에서 새 것으로 마시는 날까지 다시 마시지 아니하리라' 하시니라","reference":"마가복음 14:25","category":"$undefined"},{"id":"24781","book":"마가복음","book_name":"마가복음","chapter":14,"verse":26,"text":"이에 저희가 찬미하고 감람산으로 나가니라","reference":"마가복음 14:26","category":"$undefined"},{"id":"24782","book":"마가복음","book_name":"마가복음","chapter":14,"verse":27,"text":"예수께서 제자들에게 이르시되 `너희가 다 나를 버리리라 이는 기록된바 내가 목자를 치리니 양들이 흩어지리라 하였느니라","reference":"마가복음 14:27","category":"$undefined"},{"id":"24783","book":"마가복음","book_name":"마가복음","chapter":14,"verse":28,"text":"그러나 내가 살아난 후에 너희 보다 먼저 갈릴리로 가리라'","reference":"마가복음 14:28","category":"$undefined"},{"id":"24784","book":"마가복음","book_name":"마가복음","chapter":14,"verse":29,"text":"베드로가 여짜오되 `다 버릴지라도 나는 그렇지 않겠나이다'","reference":"마가복음 14:29","category":"$undefined"},{"id":"24785","book":"마가복음","book_name":"마가복음","chapter":14,"verse":30,"text":"예수께서 가라사대 `내가 진실로 네게 이르노니 오늘 이 밤 닭이 두번 울기전에 네가 세 번 나를 부인하리라'","reference":"마가복음 14:30","category":"$undefined"},{"id":"24786","book":"마가복음","book_name":"마가복음","chapter":14,"verse":31,"text":"베드로가 힘있게 말하되 `내가 주와 함께 죽을지언정 주를 부인하지 않겠나이다' 하고 모든 제자도 이와 같이 말하니라","reference":"마가복음 14:31","category":"$undefined"},{"id":"24787","book":"마가복음","book_name":"마가복음","chapter":14,"verse":32,"text":"저희가 겟세마네라 하는 곳에 이르매 예수께서 제자들에게 이르시되 나의 기도할 동안에 너희는 여기 앉았으라 하시고","reference":"마가복음 14:32","category":"$undefined"},{"id":"24788","book":"마가복음","book_name":"마가복음","chapter":14,"verse":33,"text":"베드로와 야고보와 요한을 데리고 가실새 심히 놀라시며 슬퍼하사","reference":"마가복음 14:33","category":"$undefined"},{"id":"24789","book":"마가복음","book_name":"마가복음","chapter":14,"verse":34,"text":"말씀하시되 `내 마음이 심히 고민하여 죽게 되었으니 너희는 여기 머물러 깨어 있으라' 하시고","reference":"마가복음 14:34","category":"$undefined"},{"id":"24790","book":"마가복음","book_name":"마가복음","chapter":14,"verse":35,"text":"조금 나아가사 땅에 엎드리어 될 수 있는대로 이 때가 자기에게서 지나가기를 구하여","reference":"마가복음 14:35","category":"$undefined"},{"id":"24791","book":"마가복음","book_name":"마가복음","chapter":14,"verse":36,"text":"가라사대 `아바, 아버지여 ! 아버지께는 모든 것이 가능하오니 이 잔을 내게서 옮기시옵소서 그러나 나의 원대로 마옵시고 아버지의 원대로 하옵소서' 하시고","reference":"마가복음 14:36","category":"$undefined"},{"id":"24792","book":"마가복음","book_name":"마가복음","chapter":14,"verse":37,"text":"돌아오사 제자들의 자는 것을 보시고 베드로에게 말씀하시되 `시몬아, 자느냐 ? 네가 한 시 동안도 깨어 있을 수 없더냐 ?","reference":"마가복음 14:37","category":"$undefined"},{"id":"24793","book":"마가복음","book_name":"마가복음","chapter":14,"verse":38,"text":"시험에 들지 않게 깨어 있어 기도하라 ! 마음에는 원이로되 육신이 약하도다' 하시고","reference":"마가복음 14:38","category":"$undefined"},{"id":"24794","book":"마가복음","book_name":"마가복음","chapter":14,"verse":39,"text":"다시 나아가 동일한 말씀으로 기도하시고","reference":"마가복음 14:39","category":"$undefined"},{"id":"24795","book":"마가복음","book_name":"마가복음","chapter":14,"verse":40,"text":"다시 오사 보신즉 저희가 자니 이는 저희 눈이 심히 피곤함이라 저희가 예수께 무엇으로 대답할 줄을 알지 못하더라","reference":"마가복음 14:40","category":"$undefined"},{"id":"24796","book":"마가복음","book_name":"마가복음","chapter":14,"verse":41,"text":"세번째 오사 저희에게 이르시되 `이제는 자고 쉬라 그만이다 때가 왔도다 보라, 인자가 죄인의 손에 팔리우느니라","reference":"마가복음 14:41","category":"$undefined"},{"id":"24797","book":"마가복음","book_name":"마가복음","chapter":14,"verse":42,"text":"일어나라 함께 가자 보라 나를 파는 자가 가까이 왔느니라'","reference":"마가복음 14:42","category":"$undefined"},{"id":"24798","book":"마가복음","book_name":"마가복음","chapter":14,"verse":43,"text":"말씀하실 때에 곧 열 둘 중의 하나인 유다가 왔는데 대제사장들과 서기관들과 장로들에게 파송된 무리가 검과 몽치를 가지고 그와 함께 하였더라","reference":"마가복음 14:43","category":"$undefined"},{"id":"24799","book":"마가복음","book_name":"마가복음","chapter":14,"verse":44,"text":"예수를 파는 자가 이미 그들과 군호를 짜 가로되 `내가 입 맞추는 자가 그 이니 그를 잡아 단단히 끌어가라' 하였는지라","reference":"마가복음 14:44","category":"$undefined"},{"id":"24800","book":"마가복음","book_name":"마가복음","chapter":14,"verse":45,"text":"이에 와서 곧 예수께 나아와 `랍비여' 하고 입을 맞추니","reference":"마가복음 14:45","category":"$undefined"},{"id":"24801","book":"마가복음","book_name":"마가복음","chapter":14,"verse":46,"text":"저희가 예수께 손을 대어 잡거늘","reference":"마가복음 14:46","category":"$undefined"},{"id":"24802","book":"마가복음","book_name":"마가복음","chapter":14,"verse":47,"text":"곁에 섰는 자 중에 한사람이 검을 빼어 대제사장의 종을 쳐 그 귀를 떨어뜨리니라","reference":"마가복음 14:47","category":"$undefined"},{"id":"24803","book":"마가복음","book_name":"마가복음","chapter":14,"verse":48,"text":"예수께서 무리에게 말씀하여 가라사대 `너희가 강도를 잡는 것같이 검과 몽치를 가지고 나를 잡으러 나왔느냐 ?","reference":"마가복음 14:48","category":"$undefined"},{"id":"24804","book":"마가복음","book_name":"마가복음","chapter":14,"verse":49,"text":"내가 날마다 너희와 함께 성전에 있어서 가르쳤으되 너희가 나를 잡지 아니하였도다 그러나 이는 성경을 이루려 함이니라' 하시더라","reference":"마가복음 14:49","category":"$undefined"},{"id":"24805","book":"마가복음","book_name":"마가복음","chapter":14,"verse":50,"text":"제자들이 다 예수를 버리고 도망하니라","reference":"마가복음 14:50","category":"$undefined"},{"id":"24806","book":"마가복음","book_name":"마가복음","chapter":14,"verse":51,"text":"한 청년이 벗은 몸에 베 홑이불을 두르고 예수를 따라오다가 무리에게 잡히매","reference":"마가복음 14:51","category":"$undefined"},{"id":"24807","book":"마가복음","book_name":"마가복음","chapter":14,"verse":52,"text":"베 홑이불을 버리고 벗은 몸으로 도망하니라","reference":"마가복음 14:52","category":"$undefined"},{"id":"24808","book":"마가복음","book_name":"마가복음","chapter":14,"verse":53,"text":"저희가 예수를 끌고 대제사장에게로 가니 대제사장들과 장로들과 서기관들이 다 모이더라","reference":"마가복음 14:53","category":"$undefined"},{"id":"24809","book":"마가복음","book_name":"마가복음","chapter":14,"verse":54,"text":"베드로가 예수를 멀찍이 좇아 대제사장의 집 뜰안까지 들어가서 하속들과 함께 앉아 불을 쬐더라","reference":"마가복음 14:54","category":"$undefined"},{"id":"24810","book":"마가복음","book_name":"마가복음","chapter":14,"verse":55,"text":"대제사장들과 온 공회가 예수를 죽이려고 그를 칠 증거를 찾되 얻지 못하니","reference":"마가복음 14:55","category":"$undefined"},{"id":"24811","book":"마가복음","book_name":"마가복음","chapter":14,"verse":56,"text":"이는 예수를 쳐서 거짓 증거하는 자가 많으나 그 증거가 서로 합하지 못함이라","reference":"마가복음 14:56","category":"$undefined"},{"id":"24812","book":"마가복음","book_name":"마가복음","chapter":14,"verse":57,"text":"어떤 사람들이 일어나 예수를 쳐서 거짓 증거하여 가로되","reference":"마가복음 14:57","category":"$undefined"},{"id":"24813","book":"마가복음","book_name":"마가복음","chapter":14,"verse":58,"text":"`우리가 그의 말을 들으니 손으로 지은 이 성전을 내가 헐고 손으로 짓지 아니한 다른 성전을 사흘에 지으리라 하더라' 하되","reference":"마가복음 14:58","category":"$undefined"},{"id":"24814","book":"마가복음","book_name":"마가복음","chapter":14,"verse":59,"text":"오히려 그 증거도 서로 합하지 않더라","reference":"마가복음 14:59","category":"$undefined"},{"id":"24815","book":"마가복음","book_name":"마가복음","chapter":14,"verse":60,"text":"대제사장이 가운데 일어서서 예수에게 물어 가로되 `너는 아무 대답도 없느냐 ? 이 사람들의 너를 치는 증거가 어떠하냐 ?' 하되","reference":"마가복음 14:60","category":"$undefined"},{"id":"24816","book":"마가복음","book_name":"마가복음","chapter":14,"verse":61,"text":"잠잠하고 아무 대답도 아니하시거늘 대제사장이 다시 물어 가로되 `네가 찬송 받을 자의 아들 그리스도냐 ?'","reference":"마가복음 14:61","category":"$undefined"},{"id":"24817","book":"마가복음","book_name":"마가복음","chapter":14,"verse":62,"text":"예수께서 이르시되 `내가 그니라 ! 인자가 권능자의 우편에 앉은 것과 하늘 구름을 타고 오는 것을 너희가 보리라' 하시니","reference":"마가복음 14:62","category":"$undefined"},{"id":"24818","book":"마가복음","book_name":"마가복음","chapter":14,"verse":63,"text":"대제사장이 자기 옷을 찢으며 가로되 `우리가 어찌 더 증인을 요구하리요","reference":"마가복음 14:63","category":"$undefined"},{"id":"24819","book":"마가복음","book_name":"마가복음","chapter":14,"verse":64,"text":"그 참람한 말을 너희가 들었도다 너희는 어떻게 생각하느뇨 ?' 하니 저희가 다 예수를 사형에 해당한 자로 정죄하고","reference":"마가복음 14:64","category":"$undefined"},{"id":"24820","book":"마가복음","book_name":"마가복음","chapter":14,"verse":65,"text":"혹은 그에게 침을 뱉으며 그의 얼굴을 가리우고 주먹으로 치며 가로되 `선지자 노릇을 하라' 하고 하속들은 손바닥으로 치더라","reference":"마가복음 14:65","category":"$undefined"},{"id":"24821","book":"마가복음","book_name":"마가복음","chapter":14,"verse":66,"text":"베드로는 아래 뜰에 있더니 대제사장의 비자 하나가 와서","reference":"마가복음 14:66","category":"$undefined"},{"id":"24822","book":"마가복음","book_name":"마가복음","chapter":14,"verse":67,"text":"베드로의 불 쬠을 보고 주목하여 가로되 `너도 나사렛 예수와 함께 있었도다' 하거늘","reference":"마가복음 14:67","category":"$undefined"},{"id":"24823","book":"마가복음","book_name":"마가복음","chapter":14,"verse":68,"text":"베드로가 부인하여 가로되 `나는 네 말하는 것이 무엇인지 알지도 못하고 깨닫지도 못하겠노라' 하며 앞뜰로 나갈새","reference":"마가복음 14:68","category":"$undefined"},{"id":"24824","book":"마가복음","book_name":"마가복음","chapter":14,"verse":69,"text":"비자가 그를 보고 곁에 서 있는 자들에게 다시 이르되 `이 사람은 그 당(黨)이라' 하되","reference":"마가복음 14:69","category":"$undefined"},{"id":"24825","book":"마가복음","book_name":"마가복음","chapter":14,"verse":70,"text":"또 부인하더라 조금 후에 곁에 서 있는 사람들이 다시 베드로에게 말하되 `너는 갈릴리 사람이니 참으로 그 당(黨)이니라'","reference":"마가복음 14:70","category":"$undefined"},{"id":"24826","book":"마가복음","book_name":"마가복음","chapter":14,"verse":71,"text":"베드로가 저주하며 맹세하되 `나는 너희의 말하는 이 사람을 알지 못하노라' 하니","reference":"마가복음 14:71","category":"$undefined"},{"id":"24827","book":"마가복음","book_name":"마가복음","chapter":14,"verse":72,"text":"닭이 곧 두 번째 울더라 이에 베드로가 예수께서 자기에게 하신 말씀 곧 닭이 두 번 울기 전에 네가 세번 나를 부인하리라 하심이 기억되어 생각하고 울었더라","reference":"마가복음 14:72","category":"$undefined"}],"bookSlug":"mark"}]
