2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":15,"verses":[{"id":"24828","book":"마가복음","book_name":"마가복음","chapter":15,"verse":1,"text":"새벽에 대제사장들이 즉시 장로들과 서기관들 곧 온 공회로 더불어 의논하고 예수를 결박하여 끌고 가서 빌라도에게 넘겨 주니","reference":"마가복음 15:1","category":"$undefined"},{"id":"24829","book":"마가복음","book_name":"마가복음","chapter":15,"verse":2,"text":"빌라도가 묻되 `네가 유대인의 왕이냐 ?' 예수께서 대답하여 가라사대 `네 말이 옳도다' 하시매","reference":"마가복음 15:2","category":"$undefined"},{"id":"24830","book":"마가복음","book_name":"마가복음","chapter":15,"verse":3,"text":"대제사장들이 여러 가지로 고소 하는지라","reference":"마가복음 15:3","category":"$undefined"},{"id":"24831","book":"마가복음","book_name":"마가복음","chapter":15,"verse":4,"text":"빌라도가 또 물어 가로되 `아무 대답도 없느냐 ? 저희가 얼마나 많은 것으로 너를 고소하는가 보라' 하되","reference":"마가복음 15:4","category":"$undefined"},{"id":"24832","book":"마가복음","book_name":"마가복음","chapter":15,"verse":5,"text":"예수께서 다시 아무 말씀도 대답지 아니하시니 빌라도가 기이히 여기더라","reference":"마가복음 15:5","category":"$undefined"},{"id":"24833","book":"마가복음","book_name":"마가복음","chapter":15,"verse":6,"text":"명절을 당하면 백성의 구하는 대로 죄수 하나를 놓아 주는 전례가 있더니","reference":"마가복음 15:6","category":"$undefined"},{"id":"24834","book":"마가복음","book_name":"마가복음","chapter":15,"verse":7,"text":"민란을 꾸미고 이 민란에 살인하고 포박된 자 중에 바라바라 하는 자가 있는지라","reference":"마가복음 15:7","category":"$undefined"},{"id":"24835","book":"마가복음","book_name":"마가복음","chapter":15,"verse":8,"text":"무리가 나아가서 전례대로 하여 주기를 구한대","reference":"마가복음 15:8","category":"$undefined"},{"id":"24836","book":"마가복음","book_name":"마가복음","chapter":15,"verse":9,"text":"빌라도가 대답하여 가로되 `너희는 내가 유대인의 왕을 너희에게 놓아주기를 원하느냐 ?' 하니","reference":"마가복음 15:9","category":"$undefined"},{"id":"24837","book":"마가복음","book_name":"마가복음","chapter":15,"verse":10,"text":"이는 저가 대제사장들이 시기로 예수를 넘겨 준 줄 앎이러라","reference":"마가복음 15:10","category":"$undefined"},{"id":"24838","book":"마가복음","book_name":"마가복음","chapter":15,"verse":11,"text":"그러나 대제사장들이 무리를 충동하여 도리어 바라바를 놓아 달라 하게 하니","reference":"마가복음 15:11","category":"$undefined"},{"id":"24839","book":"마가복음","book_name":"마가복음","chapter":15,"verse":12,"text":"빌라도가 또 대답하여 가로되 `그러면 너희가 유대인의 왕이라 하는 이는 내가 어떻게 하랴 ?'","reference":"마가복음 15:12","category":"$undefined"},{"id":"24840","book":"마가복음","book_name":"마가복음","chapter":15,"verse":13,"text":"저희가 다시 소리지르되 `저를 십자가에 못 박게 하소서'","reference":"마가복음 15:13","category":"$undefined"},{"id":"24841","book":"마가복음","book_name":"마가복음","chapter":15,"verse":14,"text":"빌라도가 가로되 `어찜이뇨 무슨 악한 일을 하였느냐 ?' 하니 더욱 소리지르되 `십자가에 못 박게 하소서' 하는지라","reference":"마가복음 15:14","category":"$undefined"},{"id":"24842","book":"마가복음","book_name":"마가복음","chapter":15,"verse":15,"text":"빌라도가 무리에게 만족을 주고자 하여 바라바는 놓아 주고 예수는 채찍질하고 십자가에 못 박히게 넘겨주니라","reference":"마가복음 15:15","category":"$undefined"},{"id":"24843","book":"마가복음","book_name":"마가복음","chapter":15,"verse":16,"text":"군병들이 예수를 끌고 브라이도리온이라는 뜰 안으로 들어가서 온 군대를 모으고","reference":"마가복음 15:16","category":"$undefined"},{"id":"24844","book":"마가복음","book_name":"마가복음","chapter":15,"verse":17,"text":"예수에게 자색 옷을 입히고 가시 면류관을 엮어 씌우고","reference":"마가복음 15:17","category":"$undefined"},{"id":"24845","book":"마가복음","book_name":"마가복음","chapter":15,"verse":18,"text":"예(禮)하여 가로되 `유대인의 왕이여 평안할지어다' 하고","reference":"마가복음 15:18","category":"$undefined"},{"id":"24846","book":"마가복음","book_name":"마가복음","chapter":15,"verse":19,"text":"갈대로 그의 머리를 치며 침을 뱉으며 꿇어 절하더라","reference":"마가복음 15:19","category":"$undefined"},{"id":"24847","book":"마가복음","book_name":"마가복음","chapter":15,"verse":20,"text":"희롱을 다한 후 자색 옷을 벗기고 도로 그의 옷을 입히고 십자가에 못 박으려고 끌고 나가니라","reference":"마가복음 15:20","category":"$undefined"},{"id":"24848","book":"마가복음","book_name":"마가복음","chapter":15,"verse":21,"text":"마침 알렉산더와 루포의 아비인 구레네 사람 시몬이 시골로서 와서 지나가는데 저희가 그를 억지로 같이 가게 하여 예수의 십자가를 지우고","reference":"마가복음 15:21","category":"$undefined"},{"id":"24849","book":"마가복음","book_name":"마가복음","chapter":15,"verse":22,"text":"예수를 끌고 골고다라 하는 곳(번역하면 해골의 곳)에 이르러","reference":"마가복음 15:22","category":"$undefined"},{"id":"24850","book":"마가복음","book_name":"마가복음","chapter":15,"verse":23,"text":"몰약을 탄 포도주를 주었으나 예수께서 받지 아니하시니라","reference":"마가복음 15:23","category":"$undefined"},{"id":"24851","book":"마가복음","book_name":"마가복음","chapter":15,"verse":24,"text":"십자가에 못 박고 그 옷을 나눌새 누가 어느 것을 얻을까 하여 제비를 뽑더라","reference":"마가복음 15:24","category":"$undefined"},{"id":"24852","book":"마가복음","book_name":"마가복음","chapter":15,"verse":25,"text":"때가 제 삼시가 되어 십자가에 못 박으니라","reference":"마가복음 15:25","category":"$undefined"},{"id":"24853","book":"마가복음","book_name":"마가복음","chapter":15,"verse":26,"text":"그 위에 있는 죄 패에 유대인의 왕이라 썼고","reference":"마가복음 15:26","category":"$undefined"},{"id":"24854","book":"마가복음","book_name":"마가복음","chapter":15,"verse":27,"text":"강도 둘을 예수와 함께 십자가에 못 박으니 하나는 그의 우편에 하나는 좌편에 있더라","reference":"마가복음 15:27","category":"$undefined"},{"id":"24855","book":"마가복음","book_name":"마가복음","chapter":15,"verse":28,"text":"(없 음)","reference":"마가복음 15:28","category":"$undefined"},{"id":"24856","book":"마가복음","book_name":"마가복음","chapter":15,"verse":29,"text":"지나가는 자들은 자기 머리를 흔들며 예수를 모욕하여 가로되 `아하, 성전을 헐고 사흘에 짓는 자여","reference":"마가복음 15:29","category":"$undefined"},{"id":"24857","book":"마가복음","book_name":"마가복음","chapter":15,"verse":30,"text":"네가 너를 구원하여 십자가에서 내려 오라' 하고","reference":"마가복음 15:30","category":"$undefined"},{"id":"24858","book":"마가복음","book_name":"마가복음","chapter":15,"verse":31,"text":"그와 같이 대제사장들도 서기관들과 함께 희롱하며 서로 말하되 `저가 남은 구원하였으되 자기는 구원할 수 없도다","reference":"마가복음 15:31","category":"$undefined"},{"id":"24859","book":"마가복음","book_name":"마가복음","chapter":15,"verse":32,"text":"이스라엘의 왕 그리스도가 지금 십자가에서 내려와 우리로 보고 믿게 할지어다' 하며 함께 십자가에 못박힌 자들도 예수를 욕하더라","reference":"마가복음 15:32","category":"$undefined"},{"id":"24860","book":"마가복음","book_name":"마가복음","chapter":15,"verse":33,"text":"제 육시가 되매 온 땅에 어두움이 임하여 제 구시까지 계속하더니","reference":"마가복음 15:33","category":"$undefined"},{"id":"24861","book":"마가복음","book_name":"마가복음","chapter":15,"verse":34,"text":"제 구시에 예수께서 크게 소리지르시되 `엘리 엘리 라마 사박다니 !' 하시니 이를 번역하면 [나의 하나님 나의 하나님 어찌하여 나를 버리셨나이까 ?] 하는 뜻이라","reference":"마가복음 15:34","category":"$undefined"},{"id":"24862","book":"마가복음","book_name":"마가복음","chapter":15,"verse":35,"text":"곁에 섰던 자 중 어떤 이들이 듣고 가로되 `보라 엘리야를 부른다' 하고","reference":"마가복음 15:35","category":"$undefined"},{"id":"24863","book":"마가복음","book_name":"마가복음","chapter":15,"verse":36,"text":"한사람이 달려가서 해융에 신포도주를 머금게 하여 갈대에 꿰어 마시우고 가로되 `가만 두어라 엘리야가 와서 저를 내려 주나 보자' 하더라","reference":"마가복음 15:36","category":"$undefined"},{"id":"24864","book":"마가복음","book_name":"마가복음","chapter":15,"verse":37,"text":"예수께서 큰 소리를 지르시고 운명하시다","reference":"마가복음 15:37","category":"$undefined"},{"id":"24865","book":"마가복음","book_name":"마가복음","chapter":15,"verse":38,"text":"이에 성소 휘장이 위로부터 아래까지 찢어져 둘이 되니라","reference":"마가복음 15:38","category":"$undefined"},{"id":"24866","book":"마가복음","book_name":"마가복음","chapter":15,"verse":39,"text":"예수를 향하여 섰던 백부장이 그렇게 운명하심을 보고 가로되 `이 사람은 진실로 하나님의 아들이었도다' 하더라","reference":"마가복음 15:39","category":"$undefined"},{"id":"24867","book":"마가복음","book_name":"마가복음","chapter":15,"verse":40,"text":"멀리서 바라보는 여자들도 있는데 그 중에 막달라 마리아와 또 작은 야고보와 요세의 어머니 마리아와 또 살로메가 있었으니","reference":"마가복음 15:40","category":"$undefined"},{"id":"24868","book":"마가복음","book_name":"마가복음","chapter":15,"verse":41,"text":"이들은 예수께서 갈릴리에 계실 때에 좇아 섬기던 자요 또 이 외에도 예수와 함께 예루살렘에 올라온 여자가 많이 있었더라","reference":"마가복음 15:41","category":"$undefined"},{"id":"24869","book":"마가복음","book_name":"마가복음","chapter":15,"verse":42,"text":"이 날은 예비일 곧 안식일 전날이므로 저물었을 때에","reference":"마가복음 15:42","category":"$undefined"},{"id":"24870","book":"마가복음","book_name":"마가복음","chapter":15,"verse":43,"text":"아리마대 사람 요셉이 와서 당돌히 빌라도에게 들어가 예수의 시체를 달라 하니 이 사람은 존귀한 공회원이요 하나님의 나라를 기다리는 자라","reference":"마가복음 15:43","category":"$undefined"},{"id":"24871","book":"마가복음","book_name":"마가복음","chapter":15,"verse":44,"text":"빌라도는 예수께서 벌써 죽었을까 하고 이상히 여겨 백부장을 불러 죽은지 오래냐 ? 묻고","reference":"마가복음 15:44","category":"$undefined"},{"id":"24872","book":"마가복음","book_name":"마가복음","chapter":15,"verse":45,"text":"백부장에게 알아 본 후에 요셉에게 시체를 내어 주는지라","reference":"마가복음 15:45","category":"$undefined"},{"id":"24873","book":"마가복음","book_name":"마가복음","chapter":15,"verse":46,"text":"요셉이 세마포를 사고 예수를 내려다가 이것으로 싸서 바위 속에 판 무덤에 넣어 두고 돌을 굴려 무덤 문에 놓으매","reference":"마가복음 15:46","category":"$undefined"},{"id":"24874","book":"마가복음","book_name":"마가복음","chapter":15,"verse":47,"text":"때에 막달라 마리아와 요세의 어머니 마리아가 예수 둔 곳을 보더라","reference":"마가복음 15:47","category":"$undefined"}],"bookSlug":"mark"}]
