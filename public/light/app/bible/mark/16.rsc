2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":16,"verses":[{"id":"24875","book":"마가복음","book_name":"마가복음","chapter":16,"verse":1,"text":"안식일이 지나매 막달라 마리아와 야고보의 어머니 마리아와 또 살로메가 가서 예수께 바르기 위하여 향품을 사다 두었다가","reference":"마가복음 16:1","category":"$undefined"},{"id":"24876","book":"마가복음","book_name":"마가복음","chapter":16,"verse":2,"text":"안식 후 첫날 매우 일찌기 해 돋은 때에 그 무덤으로 가며","reference":"마가복음 16:2","category":"$undefined"},{"id":"24877","book":"마가복음","book_name":"마가복음","chapter":16,"verse":3,"text":"서로 말하되 `누가 우리를 위하여 무덤 문에서 돌을 굴려 주리요' 하더니","reference":"마가복음 16:3","category":"$undefined"},{"id":"24878","book":"마가복음","book_name":"마가복음","chapter":16,"verse":4,"text":"눈을 들어 본즉 돌이 벌써 굴려졌으니 그 돌이 심히 크더라","reference":"마가복음 16:4","category":"$undefined"},{"id":"24879","book":"마가복음","book_name":"마가복음","chapter":16,"verse":5,"text":"무덤에 들어가서 흰 옷을 입은 한 청년이 우편에 앉은 것을 보고 놀라매","reference":"마가복음 16:5","category":"$undefined"},{"id":"24880","book":"마가복음","book_name":"마가복음","chapter":16,"verse":6,"text":"청년이 이르되 `놀라지 말라 너희가 십자가에 못 박히신 나사렛 예수를 찾는구나 그가 살아나셨고 여기 계시지 아니하니라 보라 그를 두었던 곳이니라","reference":"마가복음 16:6","category":"$undefined"},{"id":"24881","book":"마가복음","book_name":"마가복음","chapter":16,"verse":7,"text":"가서 그의 제자들과 베드로에게 이르기를 예수께서 너희보다 먼저 갈릴리로 가시나니 전에 너희에게 말씀하신 대로 너희가 거기서 뵈오리라 하라' 하는지라","reference":"마가복음 16:7","category":"$undefined"},{"id":"24882","book":"마가복음","book_name":"마가복음","chapter":16,"verse":8,"text":"여자들이 심히 놀라 떨며 나와 무덤에서 도망하고 무서워하여 아무에게 아무 말도 하지 못하더라","reference":"마가복음 16:8","category":"$undefined"},{"id":"24883","book":"마가복음","book_name":"마가복음","chapter":16,"verse":9,"text":"(예수께서 안식 후 첫날 이른 아침에 살아나신 후 전에 일곱 귀신을 쫓아 내어 주신 막달라 마리아에게 먼저 보이시니","reference":"마가복음 16:9","category":"$undefined"},{"id":"24884","book":"마가복음","book_name":"마가복음","chapter":16,"verse":10,"text":"마리아가 가서 예수와 함께 하던 사람들의 슬퍼하며 울고 있는 중에 이 일을 고하매","reference":"마가복음 16:10","category":"$undefined"},{"id":"24885","book":"마가복음","book_name":"마가복음","chapter":16,"verse":11,"text":"그들은 예수의 살으셨다는 것과 마리아에게 보이셨다는 것을 듣고도 믿지 아니하니라","reference":"마가복음 16:11","category":"$undefined"},{"id":"24886","book":"마가복음","book_name":"마가복음","chapter":16,"verse":12,"text":"그 후에 저희 중 두사람이 걸어서 시골로 갈 때에 예수께서 다른 모양으로 저희에게 나타나시니","reference":"마가복음 16:12","category":"$undefined"},{"id":"24887","book":"마가복음","book_name":"마가복음","chapter":16,"verse":13,"text":"두사람이 가서 남은 제자들에게 고하였으되 역시 믿지 아니하니라","reference":"마가복음 16:13","category":"$undefined"},{"id":"24888","book":"마가복음","book_name":"마가복음","chapter":16,"verse":14,"text":"그 후에 열 한 제자가 음식 먹을 때에 예수께서 저희에게 나타나사 저희의 믿음 없는 것과 마음이 완악한 것을 꾸짖으시니 이는 자기의 살아난 것을 본 자들의 말을 믿지 아니함일러라","reference":"마가복음 16:14","category":"$undefined"},{"id":"24889","book":"마가복음","book_name":"마가복음","chapter":16,"verse":15,"text":"또 가라사대 `너희는 온 천하에 다니며 만민에게 복음을 전파하라","reference":"마가복음 16:15","category":"$undefined"},{"id":"24890","book":"마가복음","book_name":"마가복음","chapter":16,"verse":16,"text":"믿고 세례를 받는 사람은 구원을 얻을 것이요 믿지 않는 사람은 정죄를 받으리라","reference":"마가복음 16:16","category":"$undefined"},{"id":"24891","book":"마가복음","book_name":"마가복음","chapter":16,"verse":17,"text":"믿는 자들에게는 이런 표적이 따르리니 곧 저희가 내 이름으로 귀신을 쫓아 내며 새 방언을 말하며","reference":"마가복음 16:17","category":"$undefined"},{"id":"24892","book":"마가복음","book_name":"마가복음","chapter":16,"verse":18,"text":"뱀을 집으며 무슨 독을 마실지라도 해를 받지 아니하며 병든 사람에게 손을 얹은즉 나으리라' 하시더라","reference":"마가복음 16:18","category":"$undefined"},{"id":"24893","book":"마가복음","book_name":"마가복음","chapter":16,"verse":19,"text":"주 예수께서 말씀을 마치신 후에 하늘로 올리우사 하나님 우편에 앉으시니라","reference":"마가복음 16:19","category":"$undefined"},{"id":"24894","book":"마가복음","book_name":"마가복음","chapter":16,"verse":20,"text":"제자들이 나가 두루 전파할새 주께서 함께 역사하사 그 따르는 표적으로 말씀을 확실히 증거하시니라)","reference":"마가복음 16:20","category":"$undefined"}],"bookSlug":"mark"}]
