2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":2,"verses":[{"id":"24262","book":"마가복음","book_name":"마가복음","chapter":2,"verse":1,"text":"수일 후에 예수께서 다시 가버나움에 들어가시니 집에 계신 소문이 들린지라","reference":"마가복음 2:1","category":"$undefined"},{"id":"24263","book":"마가복음","book_name":"마가복음","chapter":2,"verse":2,"text":"많은 사람이 모여서 문 앞에라도 용신할 수 없게 되었는데 예수께서 저희에게 도를 말씀하시더니","reference":"마가복음 2:2","category":"$undefined"},{"id":"24264","book":"마가복음","book_name":"마가복음","chapter":2,"verse":3,"text":"사람들이 한 중풍병자를 네 사람에게 메워 가지고 예수께로 올새","reference":"마가복음 2:3","category":"$undefined"},{"id":"24265","book":"마가복음","book_name":"마가복음","chapter":2,"verse":4,"text":"무리를 인하여 예수께 데려갈 수 없으므로 그 계신 곳의 지붕을 뜯어 구멍을 내고 중풍병자의 누운 상을 달아내리니","reference":"마가복음 2:4","category":"$undefined"},{"id":"24266","book":"마가복음","book_name":"마가복음","chapter":2,"verse":5,"text":"예수께서 저희의 믿음을 보시고 중풍환자에게 이르시되 `소자야 네 죄사함을 받았느니라' 하시니","reference":"마가복음 2:5","category":"$undefined"},{"id":"24267","book":"마가복음","book_name":"마가복음","chapter":2,"verse":6,"text":"어떤 서기관들이 거기 앉아서 마음에 의논하기를","reference":"마가복음 2:6","category":"$undefined"},{"id":"24268","book":"마가복음","book_name":"마가복음","chapter":2,"verse":7,"text":"`이 사람이 어찌 이렇게 말하는가 참람하도다 오직 하나님 한 분외에는 누가 능히 죄를 사하겠느냐 ?'","reference":"마가복음 2:7","category":"$undefined"},{"id":"24269","book":"마가복음","book_name":"마가복음","chapter":2,"verse":8,"text":"저희가 속으로 이렇게 의논하는 줄을 예수께서 곧 중심에 아시고 이르시되 `어찌하여 이것을 마음에 의논하느냐 ?","reference":"마가복음 2:8","category":"$undefined"},{"id":"24270","book":"마가복음","book_name":"마가복음","chapter":2,"verse":9,"text":"중풍병자에게 네 죄 사함을 받았느니라 하는 말과 일어나 네 상을 가지고 걸어가라 하는 말이 어느 것이 쉽겠느냐 ?","reference":"마가복음 2:9","category":"$undefined"},{"id":"24271","book":"마가복음","book_name":"마가복음","chapter":2,"verse":10,"text":"그러나 인자가 땅에서 죄를 사하는 권세가 있는 줄을 너희로 알게 하려 하노라' 하시고 중풍병자에게 말씀하시되","reference":"마가복음 2:10","category":"$undefined"},{"id":"24272","book":"마가복음","book_name":"마가복음","chapter":2,"verse":11,"text":"`내가 네게 이르노니 일어나 네 상을 가지고 집으로 가라 !' 하시니","reference":"마가복음 2:11","category":"$undefined"},{"id":"24273","book":"마가복음","book_name":"마가복음","chapter":2,"verse":12,"text":"그가 일어나 곧 상을 가지고 모든 사람 앞에서 나가거늘 저희가 다 놀라 영광을 하나님께 돌리며 가로되 `우리가 이런 일을 도무지 보지 못하였다' 하더라","reference":"마가복음 2:12","category":"$undefined"},{"id":"24274","book":"마가복음","book_name":"마가복음","chapter":2,"verse":13,"text":"예수께서 다시 바닷가에 나가시매 무리가 다 나아왔거늘 예수께서 저희를 가르치시니라","reference":"마가복음 2:13","category":"$undefined"},{"id":"24275","book":"마가복음","book_name":"마가복음","chapter":2,"verse":14,"text":"또 지나가시다가 알패오의 아들 레위가 세관에 앉아 있는것을 보시고 저에게 이르시되 `나를 좇으라 !' 하시니 일어나 좇으니라","reference":"마가복음 2:14","category":"$undefined"},{"id":"24276","book":"마가복음","book_name":"마가복음","chapter":2,"verse":15,"text":"그의 집에 앉아 잡수실때에 많은 세리와 죄인들이 예수와 그 제자들과 함께 앉았으니 이는 저희가 많이 있어서 예수를 좇음이러라","reference":"마가복음 2:15","category":"$undefined"},{"id":"24277","book":"마가복음","book_name":"마가복음","chapter":2,"verse":16,"text":"바리새인의 서기관들이 예수께서 죄인과 세리들과 함께 잡수시는 것을 보고 그 제자들에게 이르되 어찌하여 세리와 죄인들과 함께 먹는가","reference":"마가복음 2:16","category":"$undefined"},{"id":"24278","book":"마가복음","book_name":"마가복음","chapter":2,"verse":17,"text":"예수께서 들으시고 저희에게 이르시되 `건강한 자에게는 의원이 쓸데없고 병든 자에게라야 쓸데 있느니라 내가 의원을 부르러 온것이 아니요 죄인을 부르러 왔노라' 하시니라","reference":"마가복음 2:17","category":"$undefined"},{"id":"24279","book":"마가복음","book_name":"마가복음","chapter":2,"verse":18,"text":"요한의 제자들과 바리새인들이 금식하고 있는지라 혹이 예수께 와서 말하되 `요한의 제자들과 바리새인의 제자들은 금식하는데 어찌하여 당신의 제자들은 금식하지 아니하나이까 ?'","reference":"마가복음 2:18","category":"$undefined"},{"id":"24280","book":"마가복음","book_name":"마가복음","chapter":2,"verse":19,"text":"예수께서 저희에게 이르시되 `혼인집 손님들이 신랑과 함께 있을때에 금식할 수 있느냐 신랑과 함께 있을 동안에는 금식할 수 없나니","reference":"마가복음 2:19","category":"$undefined"},{"id":"24281","book":"마가복음","book_name":"마가복음","chapter":2,"verse":20,"text":"그러나 신랑을 빼앗길 날이 이르리니 그 날에는 금식할 것이니라","reference":"마가복음 2:20","category":"$undefined"},{"id":"24282","book":"마가복음","book_name":"마가복음","chapter":2,"verse":21,"text":"생베 조각을 낡은 옷에 붙이는 자가 없나니 만일 그렇게 하면 기운 새것이 낡은 그것을 당기어 해어짐이 더하게 되느니라","reference":"마가복음 2:21","category":"$undefined"},{"id":"24283","book":"마가복음","book_name":"마가복음","chapter":2,"verse":22,"text":"새 포도주를 낡은 가죽부대에 넣는 자가 없나니 만일 그렇게 하면 새 포도주가 부대를 터뜨려 포도주와 부대를 버리게 되리라 오직 새 포도주는 새 부대에 넣느니라' 하시니라","reference":"마가복음 2:22","category":"$undefined"},{"id":"24284","book":"마가복음","book_name":"마가복음","chapter":2,"verse":23,"text":"안식일에 예수께서 밀밭 사이로 지나가실새 그 제자들이 길을 열며 이삭을 자르니","reference":"마가복음 2:23","category":"$undefined"},{"id":"24285","book":"마가복음","book_name":"마가복음","chapter":2,"verse":24,"text":"바리새인들이 예수께 말하되 `보시오 저희가 어찌하여 안식일에 하지 못할 일을 하나이까 ?'","reference":"마가복음 2:24","category":"$undefined"},{"id":"24286","book":"마가복음","book_name":"마가복음","chapter":2,"verse":25,"text":"예수께서 가라사대 `다윗이 자기와 및 함께 한 자들이 핍절되어 시장할 때에 한 일을 읽지 못하였느냐 ?","reference":"마가복음 2:25","category":"$undefined"},{"id":"24287","book":"마가복음","book_name":"마가복음","chapter":2,"verse":26,"text":"그가 아비아달 대제사장 때에 하나님의 전에 들어가서 제사장 외에는 먹지 못하는 진설병을 먹고 함께 한자들에게도 주지 아니하였느냐 ?","reference":"마가복음 2:26","category":"$undefined"},{"id":"24288","book":"마가복음","book_name":"마가복음","chapter":2,"verse":27,"text":"또 가라사대 안식일은 사람을 위하여 있는 것이요 사람이 안식일을 위하여 있는 것이 아니니","reference":"마가복음 2:27","category":"$undefined"},{"id":"24289","book":"마가복음","book_name":"마가복음","chapter":2,"verse":28,"text":"이러므로 인자는 안식일에도 주인이니라 !'","reference":"마가복음 2:28","category":"$undefined"}],"bookSlug":"mark"}]
