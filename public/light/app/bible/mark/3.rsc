2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":3,"verses":[{"id":"24290","book":"마가복음","book_name":"마가복음","chapter":3,"verse":1,"text":"예수께서 다시 회당에 들어가시니 한편 손 마른 사람이 거기 있는지라","reference":"마가복음 3:1","category":"$undefined"},{"id":"24291","book":"마가복음","book_name":"마가복음","chapter":3,"verse":2,"text":"사람들이 예수를 송사하려 하여 안식일에 그 사람을 고치시는가 엿보거늘","reference":"마가복음 3:2","category":"$undefined"},{"id":"24292","book":"마가복음","book_name":"마가복음","chapter":3,"verse":3,"text":"예수께서 손 마른 사람에게 이르시되 `한가운데 일어서라 !' 하시고","reference":"마가복음 3:3","category":"$undefined"},{"id":"24293","book":"마가복음","book_name":"마가복음","chapter":3,"verse":4,"text":"저희에게 이르시되 `안식일에 선을 행하는 것과 악을 행하는 것 생명을 구하는 것과 죽이는 것 어느 것이 옳으냐 ?' 하시니 저희가 잠잠하거늘","reference":"마가복음 3:4","category":"$undefined"},{"id":"24294","book":"마가복음","book_name":"마가복음","chapter":3,"verse":5,"text":"저희 마음의 완악함을 근심하사 노하심으로 저희를 둘러 보시고 그 사람에게 이르시되 `네 손을 내밀라' 하시니 그가 내밀매 그 손이 회복되었더라","reference":"마가복음 3:5","category":"$undefined"},{"id":"24295","book":"마가복음","book_name":"마가복음","chapter":3,"verse":6,"text":"바리새인들이 나가서 곧 헤롯당과 함께 어떻게 하여 예수를 죽일꼬 의논하니라","reference":"마가복음 3:6","category":"$undefined"},{"id":"24296","book":"마가복음","book_name":"마가복음","chapter":3,"verse":7,"text":"예수께서 제자들과 함께 바다로 물러가시니 갈릴리에서 큰 무리가 좇으며","reference":"마가복음 3:7","category":"$undefined"},{"id":"24297","book":"마가복음","book_name":"마가복음","chapter":3,"verse":8,"text":"유대와 예루살렘과 이두매와 요단강 건너편과 또 두로와 시돈 근처에서 허다한 무리가 그의 하신 큰 일을 듣고 나아오는지라","reference":"마가복음 3:8","category":"$undefined"},{"id":"24298","book":"마가복음","book_name":"마가복음","chapter":3,"verse":9,"text":"예수께서 무리의 에워싸 미는 것을 면키 위하여 작은 배를 등대하도록 제자들에게 명하셨으니","reference":"마가복음 3:9","category":"$undefined"},{"id":"24299","book":"마가복음","book_name":"마가복음","chapter":3,"verse":10,"text":"이는 많은 사람을 고치셨으므로 병에 고생하는 자들이 예수를 만지고자 하여 핍근히 함이더라","reference":"마가복음 3:10","category":"$undefined"},{"id":"24300","book":"마가복음","book_name":"마가복음","chapter":3,"verse":11,"text":"더러운 귀신들도 어느 때든지 예수를 보면 그 앞에 엎드려 부르짖어 가로되 `당신은 하나님의 아들이니이다' 하니","reference":"마가복음 3:11","category":"$undefined"},{"id":"24301","book":"마가복음","book_name":"마가복음","chapter":3,"verse":12,"text":"예수께서 자기를 나타내지 말라고 많이 경계하시니라","reference":"마가복음 3:12","category":"$undefined"},{"id":"24302","book":"마가복음","book_name":"마가복음","chapter":3,"verse":13,"text":"또 산에 오르사 자기의 원하는 자들을 부르시니 나아온지라","reference":"마가복음 3:13","category":"$undefined"},{"id":"24303","book":"마가복음","book_name":"마가복음","chapter":3,"verse":14,"text":"이에 열 둘을 세우셨으니 이는 자기와 함께 있게 하시고 또 보내사 전도도 하며","reference":"마가복음 3:14","category":"$undefined"},{"id":"24304","book":"마가복음","book_name":"마가복음","chapter":3,"verse":15,"text":"귀신을 내어쫓는 권세도 있게 하려 하심이러라","reference":"마가복음 3:15","category":"$undefined"},{"id":"24305","book":"마가복음","book_name":"마가복음","chapter":3,"verse":16,"text":"이 열 둘을 세우셨으니 시몬에게는 베드로란 이름을 더하셨고","reference":"마가복음 3:16","category":"$undefined"},{"id":"24306","book":"마가복음","book_name":"마가복음","chapter":3,"verse":17,"text":"또 세베대의 아들 야고보와 야고보의 형제 요한이니 이 둘에게는 보아너게 곧 우뢰의 아들이란 이름을 더하셨으며","reference":"마가복음 3:17","category":"$undefined"},{"id":"24307","book":"마가복음","book_name":"마가복음","chapter":3,"verse":18,"text":"또 안드레와 빌립과 바돌로매와 마태와 도마와 알패오의 아들 야고보와 및 다대오와 가나안인 시몬이며","reference":"마가복음 3:18","category":"$undefined"},{"id":"24308","book":"마가복음","book_name":"마가복음","chapter":3,"verse":19,"text":"또 가룟 유다니 이는 예수를 판 자러라","reference":"마가복음 3:19","category":"$undefined"},{"id":"24309","book":"마가복음","book_name":"마가복음","chapter":3,"verse":20,"text":"집에 들어가시니 무리가 다시 모이므로 식사할 겨를도 없는지라","reference":"마가복음 3:20","category":"$undefined"},{"id":"24310","book":"마가복음","book_name":"마가복음","chapter":3,"verse":21,"text":"예수의 친속들이 듣고 붙들러 나오니 이는 그가 미쳤다 함일러라","reference":"마가복음 3:21","category":"$undefined"},{"id":"24311","book":"마가복음","book_name":"마가복음","chapter":3,"verse":22,"text":"예루살렘에서 내려온 서기관들은 저가 바알세불을 지폈다 하며 또 귀신의 왕을 힘입어 귀신을 쫓아낸다 하니","reference":"마가복음 3:22","category":"$undefined"},{"id":"24312","book":"마가복음","book_name":"마가복음","chapter":3,"verse":23,"text":"예수께서 저희를 불러다가 비유로 말씀하시되 `사단이 어찌 사단을 쫓아낼 수 있느냐 ?","reference":"마가복음 3:23","category":"$undefined"},{"id":"24313","book":"마가복음","book_name":"마가복음","chapter":3,"verse":24,"text":"또 만일 나라가 스스로 분쟁하면 그 나라가 설 수 없고","reference":"마가복음 3:24","category":"$undefined"},{"id":"24314","book":"마가복음","book_name":"마가복음","chapter":3,"verse":25,"text":"만일 집이 스스로 분쟁하면 그 집이 설 수 없고","reference":"마가복음 3:25","category":"$undefined"},{"id":"24315","book":"마가복음","book_name":"마가복음","chapter":3,"verse":26,"text":"만일 사단이 자기를 거스려 일어나 분쟁하면 설 수 없고 이에 망하느니라","reference":"마가복음 3:26","category":"$undefined"},{"id":"24316","book":"마가복음","book_name":"마가복음","chapter":3,"verse":27,"text":"사람이 먼저 강한 자를 결박지 않고는 그 강한 자의 집에 들어가 세간을 늑탈치 못하리니 결박한 후에야 그 집을 늑탈하리라","reference":"마가복음 3:27","category":"$undefined"},{"id":"24317","book":"마가복음","book_name":"마가복음","chapter":3,"verse":28,"text":"내가 진실로 너희에게 이르노니 사람의 모든 죄와 무릇 훼방하는 훼방은 사하심을 얻되","reference":"마가복음 3:28","category":"$undefined"},{"id":"24318","book":"마가복음","book_name":"마가복음","chapter":3,"verse":29,"text":"누구든지 성령을 훼방하는 자는 사하심을 영원히 얻지 못하고 영원한 죄에 처하느니라' 하시니","reference":"마가복음 3:29","category":"$undefined"},{"id":"24319","book":"마가복음","book_name":"마가복음","chapter":3,"verse":30,"text":"이는 저희가 말하기를 더러운 귀신이 들렸다 함이러라","reference":"마가복음 3:30","category":"$undefined"},{"id":"24320","book":"마가복음","book_name":"마가복음","chapter":3,"verse":31,"text":"때에 예수의 모친과 동생들이 와서 밖에 서서 사람을 보내어 예수를 부르니","reference":"마가복음 3:31","category":"$undefined"},{"id":"24321","book":"마가복음","book_name":"마가복음","chapter":3,"verse":32,"text":"무리가 예수를 둘러 앉았다가 여짜오되 `보소서 당신의 모친과 동생들과 누이들이 밖에서 찾나이다'","reference":"마가복음 3:32","category":"$undefined"},{"id":"24322","book":"마가복음","book_name":"마가복음","chapter":3,"verse":33,"text":"대답하시되 `누가 내 모친이며 동생들이냐 ?' 하시고","reference":"마가복음 3:33","category":"$undefined"},{"id":"24323","book":"마가복음","book_name":"마가복음","chapter":3,"verse":34,"text":"둘러 앉은 자들을 둘러 보시며 가라사대 `내 모친과 내 동생들을 보라","reference":"마가복음 3:34","category":"$undefined"},{"id":"24324","book":"마가복음","book_name":"마가복음","chapter":3,"verse":35,"text":"누구든지 하나님의 뜻대로 하는 자는 내 형제요 자매요 모친이니라'","reference":"마가복음 3:35","category":"$undefined"}],"bookSlug":"mark"}]
