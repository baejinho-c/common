2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":4,"verses":[{"id":"24325","book":"마가복음","book_name":"마가복음","chapter":4,"verse":1,"text":"예수께서 다시 바닷가에서 가르치시니 큰 무리가 모여 들거늘 예수께서 배에 올라 바다에 떠 앉으시고 온 무리는 바다 곁 육지에 있더라","reference":"마가복음 4:1","category":"$undefined"},{"id":"24326","book":"마가복음","book_name":"마가복음","chapter":4,"verse":2,"text":"이에 예수께서 여러 가지를 비유로 가르치시니 그 가르치시는 중에 저희에게 이르시되","reference":"마가복음 4:2","category":"$undefined"},{"id":"24327","book":"마가복음","book_name":"마가복음","chapter":4,"verse":3,"text":"`들으라 씨를 뿌리는 자가 뿌리러 나가서","reference":"마가복음 4:3","category":"$undefined"},{"id":"24328","book":"마가복음","book_name":"마가복음","chapter":4,"verse":4,"text":"뿌릴새 더러는 길 가에 떨어지매 새들이 와서 먹어 버렸고","reference":"마가복음 4:4","category":"$undefined"},{"id":"24329","book":"마가복음","book_name":"마가복음","chapter":4,"verse":5,"text":"더러는 흙이 얇은 돌밭에 떨어지매 흙이 깊지 아니하므로 곧 싹이 나오나","reference":"마가복음 4:5","category":"$undefined"},{"id":"24330","book":"마가복음","book_name":"마가복음","chapter":4,"verse":6,"text":"해가 돋은 후에 터져서 뿌리가 없으므로 말랐고","reference":"마가복음 4:6","category":"$undefined"},{"id":"24331","book":"마가복음","book_name":"마가복음","chapter":4,"verse":7,"text":"더러는 가시떨기에 떨어지매 가시가 자라 기운을 막으므로 결실치 못하였고","reference":"마가복음 4:7","category":"$undefined"},{"id":"24332","book":"마가복음","book_name":"마가복음","chapter":4,"verse":8,"text":"더러는 좋은 땅에 떨어지매 자라 무성하여 결실하였으니 삼십배와 육십배와 백배가 되었느니라' 하시고","reference":"마가복음 4:8","category":"$undefined"},{"id":"24333","book":"마가복음","book_name":"마가복음","chapter":4,"verse":9,"text":"또 이르시되 `들을 귀 있는 자는 들으라' 하시니라","reference":"마가복음 4:9","category":"$undefined"},{"id":"24334","book":"마가복음","book_name":"마가복음","chapter":4,"verse":10,"text":"예수께서 홀로 계실 때에 함께한 사람들이 열 두 제자로 더불어 그 비유를 묻자오니","reference":"마가복음 4:10","category":"$undefined"},{"id":"24335","book":"마가복음","book_name":"마가복음","chapter":4,"verse":11,"text":"이르시되 `하나님 나라의 비밀을 너희에게는 주었으나 외인에게는 모든 것을 비유로 하나니","reference":"마가복음 4:11","category":"$undefined"},{"id":"24336","book":"마가복음","book_name":"마가복음","chapter":4,"verse":12,"text":"이는 저희로 보기는 보아도 알지 못하며 듣기는 들어도 깨닫지 못하게 하여 돌이켜 죄 사함을 얻지 못하게 하여 함이니라' 하시고","reference":"마가복음 4:12","category":"$undefined"},{"id":"24337","book":"마가복음","book_name":"마가복음","chapter":4,"verse":13,"text":"또 가라사대 `너희가 이 비유를 알지 못할진대 어떻게 모든 비유를 알겠느뇨?","reference":"마가복음 4:13","category":"$undefined"},{"id":"24338","book":"마가복음","book_name":"마가복음","chapter":4,"verse":14,"text":"뿌리는 자는 말씀을 뿌리는 것이다","reference":"마가복음 4:14","category":"$undefined"},{"id":"24339","book":"마가복음","book_name":"마가복음","chapter":4,"verse":15,"text":"말씀이 길가에 뿌리웠다는 것은 이들이니 곧 말씀을 들었을 때에 사단이 즉시 와서 저희에게 뿌리운 말씀을 빼앗는 것이요","reference":"마가복음 4:15","category":"$undefined"},{"id":"24340","book":"마가복음","book_name":"마가복음","chapter":4,"verse":16,"text":"또 이와 같이 돌밭에 뿌리웠다는 것은 이들이니 곧 말씀을 들을 때에 즉시 기쁨으로 받으나","reference":"마가복음 4:16","category":"$undefined"},{"id":"24341","book":"마가복음","book_name":"마가복음","chapter":4,"verse":17,"text":"그 속에 뿌리가 없어 잠간 견디다가 말씀을 인하여 환난이나 핍박이 일어나는 때에는 곧 넘어지는 자요","reference":"마가복음 4:17","category":"$undefined"},{"id":"24342","book":"마가복음","book_name":"마가복음","chapter":4,"verse":18,"text":"또 어떤이는 가시떨기에 뿌리우는 자니 이들은 말씀을 듣되","reference":"마가복음 4:18","category":"$undefined"},{"id":"24343","book":"마가복음","book_name":"마가복음","chapter":4,"verse":19,"text":"세상의 염려와 재리의 유혹과 기타 욕심이 들어와 말씀을 막아 결실치 못하게 되는 자요","reference":"마가복음 4:19","category":"$undefined"},{"id":"24344","book":"마가복음","book_name":"마가복음","chapter":4,"verse":20,"text":"좋은 땅에 뿌리웠다는 것은 곧 말씀을 듣고 받아 삼십배와 육십배와 백배의 결실을 하는 자니라'","reference":"마가복음 4:20","category":"$undefined"},{"id":"24345","book":"마가복음","book_name":"마가복음","chapter":4,"verse":21,"text":"또 저희에게 이르시되 `사람이 등불을 가져오는 것은 말 아래나 평상 아래나 두려함이냐 등경 위에 두려함이 아니냐","reference":"마가복음 4:21","category":"$undefined"},{"id":"24346","book":"마가복음","book_name":"마가복음","chapter":4,"verse":22,"text":"드러내려 하지 않고는 숨긴 것이 없고 나타내려 하지 않고는 감추인 것이 없느니라","reference":"마가복음 4:22","category":"$undefined"},{"id":"24347","book":"마가복음","book_name":"마가복음","chapter":4,"verse":23,"text":"들을 귀 있는 자는 들으라'","reference":"마가복음 4:23","category":"$undefined"},{"id":"24348","book":"마가복음","book_name":"마가복음","chapter":4,"verse":24,"text":"또 가라사대 `너희가 무엇을 듣는가 스스로 삼가라 너희의 헤아리는 그 헤아림으로 너희가 헤아림을 받을것이요 또 더 받으리니","reference":"마가복음 4:24","category":"$undefined"},{"id":"24349","book":"마가복음","book_name":"마가복음","chapter":4,"verse":25,"text":"있는자는 받을것이요 없는 자는 그 있는 것까지 빼앗기리라'","reference":"마가복음 4:25","category":"$undefined"},{"id":"24350","book":"마가복음","book_name":"마가복음","chapter":4,"verse":26,"text":"또 가라사대 `하나님의 나라는 사람이 씨를 땅에 뿌림과 같으니","reference":"마가복음 4:26","category":"$undefined"},{"id":"24351","book":"마가복음","book_name":"마가복음","chapter":4,"verse":27,"text":"저가 밤낮 자고 깨고 하는 중에 씨가 나서 자라되 그 어떻게 된 것을 알지 못하느니라","reference":"마가복음 4:27","category":"$undefined"},{"id":"24352","book":"마가복음","book_name":"마가복음","chapter":4,"verse":28,"text":"땅이 스스로 열매를 맺되 처음에는 싹이요 다음에는 이삭이요 그 다음에는 이삭에 충실한 곡식이라","reference":"마가복음 4:28","category":"$undefined"},{"id":"24353","book":"마가복음","book_name":"마가복음","chapter":4,"verse":29,"text":"열매가 익으면 곧 낫을 대나니 이는 추수 때가 이르렀음이니라'","reference":"마가복음 4:29","category":"$undefined"},{"id":"24354","book":"마가복음","book_name":"마가복음","chapter":4,"verse":30,"text":"또 가라사대 `우리가 하나님의 나라를 어떻게 비하며 또 무슨 비유로 나타낼꼬","reference":"마가복음 4:30","category":"$undefined"},{"id":"24355","book":"마가복음","book_name":"마가복음","chapter":4,"verse":31,"text":"겨자씨 한 알과 같으니 땅에 심길 때에는 땅 위의 모든 씨보다 작은 것이로되","reference":"마가복음 4:31","category":"$undefined"},{"id":"24356","book":"마가복음","book_name":"마가복음","chapter":4,"verse":32,"text":"심긴 후에는 자라서 모든 나물보다 커지며 큰 가지를 내니 공중의 새들이 그 그늘에 깃들일 만큼 되느니라'","reference":"마가복음 4:32","category":"$undefined"},{"id":"24357","book":"마가복음","book_name":"마가복음","chapter":4,"verse":33,"text":"예수께서 이러한 많은 비유로 저희가 알아 들을 수 있는대로 말씀을 가르치시되","reference":"마가복음 4:33","category":"$undefined"},{"id":"24358","book":"마가복음","book_name":"마가복음","chapter":4,"verse":34,"text":"비유가 아니면 말씀하지 아니 하시고 다만 혼자 계실 때에 그 제자들에게 모든것을 해석하시더라","reference":"마가복음 4:34","category":"$undefined"},{"id":"24359","book":"마가복음","book_name":"마가복음","chapter":4,"verse":35,"text":"그날 저물 때에 제자들에게 이르시되 `우리가 저편으로 건너가자' 하시니","reference":"마가복음 4:35","category":"$undefined"},{"id":"24360","book":"마가복음","book_name":"마가복음","chapter":4,"verse":36,"text":"저희가 무리를 떠나 예수를 배에 계신 그대로 모시고 가매 다른 배들도 함께 하더니","reference":"마가복음 4:36","category":"$undefined"},{"id":"24361","book":"마가복음","book_name":"마가복음","chapter":4,"verse":37,"text":"큰 광풍이 일어나며 물결이 부딪혀 배에 들어와 배에 가득하게 되었더라","reference":"마가복음 4:37","category":"$undefined"},{"id":"24362","book":"마가복음","book_name":"마가복음","chapter":4,"verse":38,"text":"예수께서는 고물에서 베개를 베시고 주무시더니 제자들이 깨우며 가로되 `선생님이여 우리의 죽게 된것을 돌아보지 아니하시나이까 ?' 하니","reference":"마가복음 4:38","category":"$undefined"},{"id":"24363","book":"마가복음","book_name":"마가복음","chapter":4,"verse":39,"text":"예수께서 깨어 바람을 꾸짖으시며 바다더러 이르시되 `잠잠하라 ! 고요하라 !' 하시니 바람이 그치고 아주 잔잔하여지더라","reference":"마가복음 4:39","category":"$undefined"},{"id":"24364","book":"마가복음","book_name":"마가복음","chapter":4,"verse":40,"text":"이에 제자들에게 이르시되 `어찌하여 이렇게 무서워하느냐 ? 너희가 어찌 믿음이 없느냐 ?' 하시니","reference":"마가복음 4:40","category":"$undefined"},{"id":"24365","book":"마가복음","book_name":"마가복음","chapter":4,"verse":41,"text":"저희가 심히 두려워하여 서로 말하되 `저가 뉘기에 바람과 바다라도 순종하는고' 하였더라","reference":"마가복음 4:41","category":"$undefined"}],"bookSlug":"mark"}]
