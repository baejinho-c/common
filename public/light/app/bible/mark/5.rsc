2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":5,"verses":[{"id":"24366","book":"마가복음","book_name":"마가복음","chapter":5,"verse":1,"text":"예수께서 바다 건너편 거라사인의 지방에 이르러","reference":"마가복음 5:1","category":"$undefined"},{"id":"24367","book":"마가복음","book_name":"마가복음","chapter":5,"verse":2,"text":"배에서 나오시매 곧 더러운 귀신들린 사람이 무덤 사이에서 나와 예수를 만나다","reference":"마가복음 5:2","category":"$undefined"},{"id":"24368","book":"마가복음","book_name":"마가복음","chapter":5,"verse":3,"text":"그 사람은 무덤 사이에 거처하는데 이제는 아무나 쇠사슬로도 맬 수 없게 되었으니","reference":"마가복음 5:3","category":"$undefined"},{"id":"24369","book":"마가복음","book_name":"마가복음","chapter":5,"verse":4,"text":"이는 여러 번 고랑과 쇠사슬에 매였어도 쇠사슬을 끊고 고랑을 깨뜨렸음이러라 그리하여 아무도 저를 제어 할 힘이 없는지라","reference":"마가복음 5:4","category":"$undefined"},{"id":"24370","book":"마가복음","book_name":"마가복음","chapter":5,"verse":5,"text":"밤낮 무덤 사이에서나 산에서나 늘 소리지르며 돌로 제 몸을 상하고 있었더라","reference":"마가복음 5:5","category":"$undefined"},{"id":"24371","book":"마가복음","book_name":"마가복음","chapter":5,"verse":6,"text":"그가 멀리서 예수를 보고 달려와 절하며","reference":"마가복음 5:6","category":"$undefined"},{"id":"24372","book":"마가복음","book_name":"마가복음","chapter":5,"verse":7,"text":"큰 소리로 부르짖어 가로되 `지극히 높으신 하나님의 아들 예수여 ! 나와 당신과 무슨 상관이 있나이까 ? 원컨대 하나님 앞에 맹세하고 나를 괴롭게 마옵소서' 하니","reference":"마가복음 5:7","category":"$undefined"},{"id":"24373","book":"마가복음","book_name":"마가복음","chapter":5,"verse":8,"text":"이는 예수께서 이미 저에게 이르시기를 `더러운 귀신아 ! 그 사람에게서 나오라' 하셨음이라","reference":"마가복음 5:8","category":"$undefined"},{"id":"24374","book":"마가복음","book_name":"마가복음","chapter":5,"verse":9,"text":"이에 물으시되 `네 이름이 무엇이냐 ?' 가로되 `내 이름은 군대니 우리가 많음이니이다' 하고","reference":"마가복음 5:9","category":"$undefined"},{"id":"24375","book":"마가복음","book_name":"마가복음","chapter":5,"verse":10,"text":"자기를 이 지방에서 내어 보내지 마시기를 간절히 구하더니","reference":"마가복음 5:10","category":"$undefined"},{"id":"24376","book":"마가복음","book_name":"마가복음","chapter":5,"verse":11,"text":"마침 거기 돼지의 큰 떼가 산 곁에서 먹고 있는지라","reference":"마가복음 5:11","category":"$undefined"},{"id":"24377","book":"마가복음","book_name":"마가복음","chapter":5,"verse":12,"text":"이에 간구하여 가로되 `우리를 돼지에게로 보내어 들어가게 하소서' 하니","reference":"마가복음 5:12","category":"$undefined"},{"id":"24378","book":"마가복음","book_name":"마가복음","chapter":5,"verse":13,"text":"허락하신대 더러운 귀신들이 나와서 돼지에게로 들어가니 거의 이천 마리 되는 떼가 바다를 향하여 비탈로 내리달아 바다에서 몰사하거늘","reference":"마가복음 5:13","category":"$undefined"},{"id":"24379","book":"마가복음","book_name":"마가복음","chapter":5,"verse":14,"text":"치던 자들이 도망하여 읍내와 촌에 고하니 사람들이 그 어떻게 된 것을 보러 와서","reference":"마가복음 5:14","category":"$undefined"},{"id":"24380","book":"마가복음","book_name":"마가복음","chapter":5,"verse":15,"text":"예수께 이르러 그 귀신 들렸던 자 곧 군대 지폈던 자가 옷을 입고 정신이 온전하여 앉은 것을 보고 두려워 하더라","reference":"마가복음 5:15","category":"$undefined"},{"id":"24381","book":"마가복음","book_name":"마가복음","chapter":5,"verse":16,"text":"이에 귀신 들렸던 자의 당한 것과 돼지의 일을 본 자들이 저희에게 고하매","reference":"마가복음 5:16","category":"$undefined"},{"id":"24382","book":"마가복음","book_name":"마가복음","chapter":5,"verse":17,"text":"저희가 예수께 그 지경에서 떠나시기를 간구하더라","reference":"마가복음 5:17","category":"$undefined"},{"id":"24383","book":"마가복음","book_name":"마가복음","chapter":5,"verse":18,"text":"예수께서 배에 오르실 때에 귀신 들렸던 사람이 함께 있기를 간구하였으나","reference":"마가복음 5:18","category":"$undefined"},{"id":"24384","book":"마가복음","book_name":"마가복음","chapter":5,"verse":19,"text":"허락지 아니하시고 저에게 이르시되 `집으로 돌아가 주께서 네게 어떻게 큰 일을 행하사 너를 불쌍히 여기신 것을 네 친속에게 고하라' 하신대","reference":"마가복음 5:19","category":"$undefined"},{"id":"24385","book":"마가복음","book_name":"마가복음","chapter":5,"verse":20,"text":"그가 가서 예수께서 자기에게 어떻게 큰 일 행하신 것을 데가볼리에 전파하니 모든 사람이 기이히 여기더라","reference":"마가복음 5:20","category":"$undefined"},{"id":"24386","book":"마가복음","book_name":"마가복음","chapter":5,"verse":21,"text":"예수께서 배를 타시고 다시 저편으로 건너가시매 큰 무리가 그에게로 모이거늘 이에 바닷가에 계시더니","reference":"마가복음 5:21","category":"$undefined"},{"id":"24387","book":"마가복음","book_name":"마가복음","chapter":5,"verse":22,"text":"회당장 중 하나인 야이로라 하는 이가 와서 예수를 보고 발 아래 엎드리어","reference":"마가복음 5:22","category":"$undefined"},{"id":"24388","book":"마가복음","book_name":"마가복음","chapter":5,"verse":23,"text":"많이 간구하여 가로되 `내 어린 딸이 죽게 되었사오니 오셔서 그 위에 손을 얹으사 그로 구원을 얻어 살게 하소서' 하거늘","reference":"마가복음 5:23","category":"$undefined"},{"id":"24389","book":"마가복음","book_name":"마가복음","chapter":5,"verse":24,"text":"이에 그와 함께 가실새 큰 무리가 따라가며 에워싸 밀더라","reference":"마가복음 5:24","category":"$undefined"},{"id":"24390","book":"마가복음","book_name":"마가복음","chapter":5,"verse":25,"text":"열 두 해를 혈루증으로 앓는 한 여자가 있어","reference":"마가복음 5:25","category":"$undefined"},{"id":"24391","book":"마가복음","book_name":"마가복음","chapter":5,"verse":26,"text":"많은 의원에게 많은 괴로움을 받았고 있던 것도 다 허비하였으되 아무 효험이 없고 도리어 더 중하여졌던 차에","reference":"마가복음 5:26","category":"$undefined"},{"id":"24392","book":"마가복음","book_name":"마가복음","chapter":5,"verse":27,"text":"예수의 소문을 듣고 무리 가운데 섞여 뒤로 와서 그의 옷에 손을 대니","reference":"마가복음 5:27","category":"$undefined"},{"id":"24393","book":"마가복음","book_name":"마가복음","chapter":5,"verse":28,"text":"이는 내가 그의 옷에만 손을 대어도 구원을 얻으리라 함일러라","reference":"마가복음 5:28","category":"$undefined"},{"id":"24394","book":"마가복음","book_name":"마가복음","chapter":5,"verse":29,"text":"이에 그의 혈루 근원이 곧 마르매 병이 나은 줄을 몸에 깨달으니라","reference":"마가복음 5:29","category":"$undefined"},{"id":"24395","book":"마가복음","book_name":"마가복음","chapter":5,"verse":30,"text":"예수께서 그 능력이 자기에게서 나간 줄을 곧 스스로 아시고 무리 가운데서 돌이켜 말씀하시되 `누가 내 옷에 손을 대었느냐 ?' 하시니","reference":"마가복음 5:30","category":"$undefined"},{"id":"24396","book":"마가복음","book_name":"마가복음","chapter":5,"verse":31,"text":"제자들이 여짜오되 `무리가 에워싸 미는 것을 보시며 누가 내게 손을 대었느냐 물으시나이까 ?' 하되","reference":"마가복음 5:31","category":"$undefined"},{"id":"24397","book":"마가복음","book_name":"마가복음","chapter":5,"verse":32,"text":"예수께서 이 일 행한 여자를 보려고 둘러 보시니","reference":"마가복음 5:32","category":"$undefined"},{"id":"24398","book":"마가복음","book_name":"마가복음","chapter":5,"verse":33,"text":"여자가 제게 이루어진 일을 알고 두려워하여 떨며 와서 그 앞에 엎드려 모든 사실을 여짜온대","reference":"마가복음 5:33","category":"$undefined"},{"id":"24399","book":"마가복음","book_name":"마가복음","chapter":5,"verse":34,"text":"예수께서 가라사대 `딸아 네 믿음이 너를 구원하였으니 평안히 가라 ! 네 병에서 놓여 건강할지어다 !'","reference":"마가복음 5:34","category":"$undefined"},{"id":"24400","book":"마가복음","book_name":"마가복음","chapter":5,"verse":35,"text":"아직 말씀하실 때에 회당장의 집에서 사람들이 와서 가로되 `당신의 딸이 죽었나이다 어찌하여 선생을 더 괴롭게 하나이까 ?'","reference":"마가복음 5:35","category":"$undefined"},{"id":"24401","book":"마가복음","book_name":"마가복음","chapter":5,"verse":36,"text":"예수께서 그 하는 말을 곁에서 들으시고 회당장에게 이르시되 `두려워 말고 믿기만 하라 !' 하시고","reference":"마가복음 5:36","category":"$undefined"},{"id":"24402","book":"마가복음","book_name":"마가복음","chapter":5,"verse":37,"text":"베드로와 야고보와 야고보의 형제 요한 외에 아무도 따라옴을 허치 아니하시고","reference":"마가복음 5:37","category":"$undefined"},{"id":"24403","book":"마가복음","book_name":"마가복음","chapter":5,"verse":38,"text":"회당장의 집에 함께 가사 훤화함과 사람들의 울며 심히 통곡함을 보시고","reference":"마가복음 5:38","category":"$undefined"},{"id":"24404","book":"마가복음","book_name":"마가복음","chapter":5,"verse":39,"text":"들어가서 저희에게 이르시되 `너희가 어찌하여 훤화하며 우느냐 ? 이 아이가 죽은 것이 아니라 잔다' 하시니","reference":"마가복음 5:39","category":"$undefined"},{"id":"24405","book":"마가복음","book_name":"마가복음","chapter":5,"verse":40,"text":"저희가 비웃더라 예수께서 저희를 다 내어보내신 후에 아이의 부모와 또 자기와 함께 한 자들을 데리시고 아이 있는 곳에 들어가사","reference":"마가복음 5:40","category":"$undefined"},{"id":"24406","book":"마가복음","book_name":"마가복음","chapter":5,"verse":41,"text":"그 아이의 손을 잡고 가라사대 `달리다굼 !' 하시니 번역하면 곧 소녀야 내가 네게 말하노니 일어나라 하심이라","reference":"마가복음 5:41","category":"$undefined"},{"id":"24407","book":"마가복음","book_name":"마가복음","chapter":5,"verse":42,"text":"소녀가 곧 일어나서 걸으니 나이 열 두살이라 사람들이 곧 크게 놀라고 놀라거늘","reference":"마가복음 5:42","category":"$undefined"},{"id":"24408","book":"마가복음","book_name":"마가복음","chapter":5,"verse":43,"text":"예수께서 이 일을 아무도 알지 못하게 하라고 저희를 많이 경계하시고 이에 소녀에게 먹을 것을 주라 하시니라","reference":"마가복음 5:43","category":"$undefined"}],"bookSlug":"mark"}]
