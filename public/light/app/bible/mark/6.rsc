2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":6,"verses":[{"id":"24409","book":"마가복음","book_name":"마가복음","chapter":6,"verse":1,"text":"예수께서 거기를 떠나사 고향으로 가시니 제자들도 좇으니라","reference":"마가복음 6:1","category":"$undefined"},{"id":"24410","book":"마가복음","book_name":"마가복음","chapter":6,"verse":2,"text":"안식일이 되어 회당에서 가르치시니 많은 사람이 듣고 놀라 가로되 `이 사람이 어디서 이런 것을 얻었느뇨 이 사람의 받은 지혜와 그 손으로 이루어지는 이런 권능이 어찌 됨이뇨","reference":"마가복음 6:2","category":"$undefined"},{"id":"24411","book":"마가복음","book_name":"마가복음","chapter":6,"verse":3,"text":"이 사람이 마리아의 아들 목수가 아니냐 ? 야고보와 요셉과 유다와 시몬의 형제가 아니냐 ? 그 누이들이 우리와 함께 여기 있지 아니하냐 ?' 하고 예수를 배척한지라","reference":"마가복음 6:3","category":"$undefined"},{"id":"24412","book":"마가복음","book_name":"마가복음","chapter":6,"verse":4,"text":"예수께서 저희에게 이르시되 `선지자가 자기 고향과 자기 친척과 자기집 외에서는 존경을 받지 않음이 없느니라' 하시며","reference":"마가복음 6:4","category":"$undefined"},{"id":"24413","book":"마가복음","book_name":"마가복음","chapter":6,"verse":5,"text":"거기서는 아무 권능도 행하실 수 없어 다만 소수의 병인에게 안수하여 고치실 뿐이었고","reference":"마가복음 6:5","category":"$undefined"},{"id":"24414","book":"마가복음","book_name":"마가복음","chapter":6,"verse":6,"text":"저희의 믿지 않음을 이상히 여기셨더라 이에 모든 촌에 두루 다니시며 가르치시더라","reference":"마가복음 6:6","category":"$undefined"},{"id":"24415","book":"마가복음","book_name":"마가복음","chapter":6,"verse":7,"text":"열 두 제자를 부르사 둘씩 둘씩 보내시며 더러운 귀신을 제어하는 권세를 주시고","reference":"마가복음 6:7","category":"$undefined"},{"id":"24416","book":"마가복음","book_name":"마가복음","chapter":6,"verse":8,"text":"명하시되 `여행을 위하여 지팡이 외에는 양식이나 주머니나 전대의 돈이나 아무 것도 가지지 말며","reference":"마가복음 6:8","category":"$undefined"},{"id":"24417","book":"마가복음","book_name":"마가복음","chapter":6,"verse":9,"text":"신만 신고 두 벌 옷도 입지 말라' 하시고","reference":"마가복음 6:9","category":"$undefined"},{"id":"24418","book":"마가복음","book_name":"마가복음","chapter":6,"verse":10,"text":"또 가라사대 `어디서든 뉘 집에 들어가거든 그 곳을 떠나기까지 거기 유하라","reference":"마가복음 6:10","category":"$undefined"},{"id":"24419","book":"마가복음","book_name":"마가복음","chapter":6,"verse":11,"text":"어느 곳에서든지 너희를 영접지 아니하고 너희 말을 듣지도 아니하거든 거기서 나갈 때에 발 아래 먼지를 떨어버려 저희에게 증거를 삼으라' 하시니","reference":"마가복음 6:11","category":"$undefined"},{"id":"24420","book":"마가복음","book_name":"마가복음","chapter":6,"verse":12,"text":"제자들이 나가서 회개하라 전파하고","reference":"마가복음 6:12","category":"$undefined"},{"id":"24421","book":"마가복음","book_name":"마가복음","chapter":6,"verse":13,"text":"많은 귀신을 쫓아내며 많은 병인에게 기름을 발라 고치더라","reference":"마가복음 6:13","category":"$undefined"},{"id":"24422","book":"마가복음","book_name":"마가복음","chapter":6,"verse":14,"text":"이에 예수의 이름이 드러난지라 헤롯 왕이 듣고 가로되 `이는 세례 요한이 죽은 자 가운데서 살아났도다 그러므로 이런 능력이 그 속에서 운동하느니라' 하고","reference":"마가복음 6:14","category":"$undefined"},{"id":"24423","book":"마가복음","book_name":"마가복음","chapter":6,"verse":15,"text":"어떤 이는 이가 엘리야라 하고 또 어떤이는 이가 선지자니 옛 선지자 중의 하나와 같다 하되","reference":"마가복음 6:15","category":"$undefined"},{"id":"24424","book":"마가복음","book_name":"마가복음","chapter":6,"verse":16,"text":"헤롯은 듣고 가로되 `내가 목베인 요한 그가 살아났다' 하더라","reference":"마가복음 6:16","category":"$undefined"},{"id":"24425","book":"마가복음","book_name":"마가복음","chapter":6,"verse":17,"text":"전에 헤롯이 자기가 동생 빌립의 아내 헤로디아에게 장가 든고로 이 여자를 위하여 사람을 보내어 요한을 잡아 옥에 가두었으니","reference":"마가복음 6:17","category":"$undefined"},{"id":"24426","book":"마가복음","book_name":"마가복음","chapter":6,"verse":18,"text":"이는 요한이 헤롯에게 말하되 `동생의 아내를 취한 것이 옳지 않다' 하였음이라","reference":"마가복음 6:18","category":"$undefined"},{"id":"24427","book":"마가복음","book_name":"마가복음","chapter":6,"verse":19,"text":"헤로디아가 요한을 원수로 여겨 죽이고자 하였으되 하지 못한것은","reference":"마가복음 6:19","category":"$undefined"},{"id":"24428","book":"마가복음","book_name":"마가복음","chapter":6,"verse":20,"text":"헤롯이 요한을 의롭고 거룩한 사람으로 알고 두려워하여 보호하며 또 그의 말을 들을 때에 크게 번민을 느끼면서도 달게 들음이러라","reference":"마가복음 6:20","category":"$undefined"},{"id":"24429","book":"마가복음","book_name":"마가복음","chapter":6,"verse":21,"text":"마침 기회 좋은 날이 왔으니 곧 헤롯이 자기 생일에 대신들과 천부장들과 갈릴리의 귀인들로 더불어 잔치할새","reference":"마가복음 6:21","category":"$undefined"},{"id":"24430","book":"마가복음","book_name":"마가복음","chapter":6,"verse":22,"text":"헤로디아의 딸이 친히 들어와 춤을 추어 헤롯과 및 함께 앉은 자들을 기쁘게 한지라 왕이 그 여아에게 이르되 `무엇이든지 너 원하는 것을 내게 구하라 내가 주리라' 하고","reference":"마가복음 6:22","category":"$undefined"},{"id":"24431","book":"마가복음","book_name":"마가복음","chapter":6,"verse":23,"text":"또 맹세하되 `무엇이든지 네가 내게 구하면 내 나라의 절반까지라도 주리라' 하거늘","reference":"마가복음 6:23","category":"$undefined"},{"id":"24432","book":"마가복음","book_name":"마가복음","chapter":6,"verse":24,"text":"저가 나가서 그 어미에게 말하되 `내가 무엇을 구하리이까 ?' 그 어미가 가로되 `세례 요한의 머리를 구하라' 하니","reference":"마가복음 6:24","category":"$undefined"},{"id":"24433","book":"마가복음","book_name":"마가복음","chapter":6,"verse":25,"text":"저가 곧 왕에게 급히 들어가 구하여 가로되 `세례 요한의 머리를 소반에 담아 곧 내게 주기를 원하옵나이다' 한대","reference":"마가복음 6:25","category":"$undefined"},{"id":"24434","book":"마가복음","book_name":"마가복음","chapter":6,"verse":26,"text":"왕이 심히 근심하나 자기의 맹세한 것과 그 앉은 자들을 인하여 저를 거절할 수 없는지라","reference":"마가복음 6:26","category":"$undefined"},{"id":"24435","book":"마가복음","book_name":"마가복음","chapter":6,"verse":27,"text":"왕이 곧 시위병 하나를 보내어 `요한의 머리를 가져오라' 명하니 그 사람이 나가 옥에서 요한을 목 베어","reference":"마가복음 6:27","category":"$undefined"},{"id":"24436","book":"마가복음","book_name":"마가복음","chapter":6,"verse":28,"text":"그 머리를 소반에 담아다가 여아에게 주니 여아가 이것을 그 어미에게 주니라","reference":"마가복음 6:28","category":"$undefined"},{"id":"24437","book":"마가복음","book_name":"마가복음","chapter":6,"verse":29,"text":"요한의 제자들이 듣고 와서 시체를 가져다가 장사하니라","reference":"마가복음 6:29","category":"$undefined"},{"id":"24438","book":"마가복음","book_name":"마가복음","chapter":6,"verse":30,"text":"사도들이 예수께 모여 자기들의 행한 것과 가르친 것을 낱낱이 고하니","reference":"마가복음 6:30","category":"$undefined"},{"id":"24439","book":"마가복음","book_name":"마가복음","chapter":6,"verse":31,"text":"이르시되 `너희는 따로 한적한 곳에 와서 잠간 쉬어라' 하시니 이는 오고 가는 사람이 많아 음식 먹을 겨를도 없음이라","reference":"마가복음 6:31","category":"$undefined"},{"id":"24440","book":"마가복음","book_name":"마가복음","chapter":6,"verse":32,"text":"이에 배를 타고 따로 한적한 곳에 갈새","reference":"마가복음 6:32","category":"$undefined"},{"id":"24441","book":"마가복음","book_name":"마가복음","chapter":6,"verse":33,"text":"그 가는 것을 보고 많은 사람이 저희인 줄 안지라 모든 고을로부터 도보로 그 곳에 달려와 저희보다 먼저 갔더라","reference":"마가복음 6:33","category":"$undefined"},{"id":"24442","book":"마가복음","book_name":"마가복음","chapter":6,"verse":34,"text":"예수께서 나오사 큰 무리를 보시고 그 목자 없는 양 같음을 인하여 불쌍히 여기사 이에 여러 가지로 가르치시더라","reference":"마가복음 6:34","category":"$undefined"},{"id":"24443","book":"마가복음","book_name":"마가복음","chapter":6,"verse":35,"text":"때가 저물어가매 제자들이 예수께 나아와 여짜오되 `이곳은 빈 들이요 때도 저물어가니","reference":"마가복음 6:35","category":"$undefined"},{"id":"24444","book":"마가복음","book_name":"마가복음","chapter":6,"verse":36,"text":"무리를 보내어 두루 촌과 마을로 가서 무엇을 사 먹게 하옵소서'","reference":"마가복음 6:36","category":"$undefined"},{"id":"24445","book":"마가복음","book_name":"마가복음","chapter":6,"verse":37,"text":"대답하여 가라사대 `너희가 먹을 것을 주라' 하시니 여짜오되 `우리가 가서 이백 데나리온의 떡을 사다 먹이리이까 ?'","reference":"마가복음 6:37","category":"$undefined"},{"id":"24446","book":"마가복음","book_name":"마가복음","chapter":6,"verse":38,"text":"이르시되 `너희에게 떡 몇 개나 있느냐 ? 가서 보라' 하시니 알아보고 가로되 `떡 다섯 개와 물고기 두 마리가 있더이다' 하거늘","reference":"마가복음 6:38","category":"$undefined"},{"id":"24447","book":"마가복음","book_name":"마가복음","chapter":6,"verse":39,"text":"제자들을 명하사 그 모든 사람으로 떼를 지어 푸른 잔디 위에 앉게 하시니","reference":"마가복음 6:39","category":"$undefined"},{"id":"24448","book":"마가복음","book_name":"마가복음","chapter":6,"verse":40,"text":"떼로 혹 백씩 혹 오십씩 앉은지라","reference":"마가복음 6:40","category":"$undefined"},{"id":"24449","book":"마가복음","book_name":"마가복음","chapter":6,"verse":41,"text":"예수께서 떡 다섯개와 물고기 두 마리를 가지사 하늘을 우러러 축사하시고 떡을 떼어 제자들에게 주어 사람들 앞에 놓게 하시고 또 물고기 두 마리도 모든 사람에게 나누어 주시매","reference":"마가복음 6:41","category":"$undefined"},{"id":"24450","book":"마가복음","book_name":"마가복음","chapter":6,"verse":42,"text":"다 배불리 먹고","reference":"마가복음 6:42","category":"$undefined"},{"id":"24451","book":"마가복음","book_name":"마가복음","chapter":6,"verse":43,"text":"남은 떡 조각과 물고기를 열 두 바구니에 차게 거두었으며","reference":"마가복음 6:43","category":"$undefined"},{"id":"24452","book":"마가복음","book_name":"마가복음","chapter":6,"verse":44,"text":"떡을 먹은 남자가 오천 명이었더라","reference":"마가복음 6:44","category":"$undefined"},{"id":"24453","book":"마가복음","book_name":"마가복음","chapter":6,"verse":45,"text":"예수께서 즉시 제자들을 재촉하사 자기가 무리를 보내는 동안에 배타고 앞서 건너편 벳새다로 가게 하시고","reference":"마가복음 6:45","category":"$undefined"},{"id":"24454","book":"마가복음","book_name":"마가복음","chapter":6,"verse":46,"text":"무리를 작별하신 후에 기도하러 산으로 가시다","reference":"마가복음 6:46","category":"$undefined"},{"id":"24455","book":"마가복음","book_name":"마가복음","chapter":6,"verse":47,"text":"저물매 배는 바다 가운데 있고 예수는 홀로 뭍에 계시다가","reference":"마가복음 6:47","category":"$undefined"},{"id":"24456","book":"마가복음","book_name":"마가복음","chapter":6,"verse":48,"text":"바람이 거스리므로 제자들의 괴로이 노 젓는 것을 보시고 밤 사경 즈음에 바다 위로 걸어서 저희에게 오사 지나가려고 하시매","reference":"마가복음 6:48","category":"$undefined"},{"id":"24457","book":"마가복음","book_name":"마가복음","chapter":6,"verse":49,"text":"제자들이 그의 바다 위로 걸어 오심을 보고 유령인가 하여 소리 지르니","reference":"마가복음 6:49","category":"$undefined"},{"id":"24458","book":"마가복음","book_name":"마가복음","chapter":6,"verse":50,"text":"저희가 다 예수를 보고 놀람이라 이에 예수께서 곧 더불어 말씀하여 가라사대 `안심하라 ! 내니 두려워 말라 !' 하시고","reference":"마가복음 6:50","category":"$undefined"},{"id":"24459","book":"마가복음","book_name":"마가복음","chapter":6,"verse":51,"text":"배에 올라 저희에게 가시니 바람이 그치는지라 제자들이 마음에 심히 놀라니","reference":"마가복음 6:51","category":"$undefined"},{"id":"24460","book":"마가복음","book_name":"마가복음","chapter":6,"verse":52,"text":"이는 저희가 그 떡 떼시던 일을 깨닫지 못하고 도리어 그 마음이 둔하여졌음이러라","reference":"마가복음 6:52","category":"$undefined"},{"id":"24461","book":"마가복음","book_name":"마가복음","chapter":6,"verse":53,"text":"건너가 게네사렛 땅에 이르러 대고","reference":"마가복음 6:53","category":"$undefined"},{"id":"24462","book":"마가복음","book_name":"마가복음","chapter":6,"verse":54,"text":"배에서 내리니 사람들이 곧 예수신 줄을 알고","reference":"마가복음 6:54","category":"$undefined"},{"id":"24463","book":"마가복음","book_name":"마가복음","chapter":6,"verse":55,"text":"그 온 지방으로 달려 돌아 다니며 예수께서 어디 계시단 말을 듣는대로 병든 자를 침상채로 메고 나아오니","reference":"마가복음 6:55","category":"$undefined"},{"id":"24464","book":"마가복음","book_name":"마가복음","chapter":6,"verse":56,"text":"아무데나 예수께서 들어가시는 마을이나 도시나 촌에서 병자를 시장에 두고 예수의 옷가에라도 손을 대게 하시기를 간구하니 손을 대는 자는 다 성함을 얻으니라","reference":"마가복음 6:56","category":"$undefined"}],"bookSlug":"mark"}]
