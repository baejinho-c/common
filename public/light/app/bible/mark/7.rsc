2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":7,"verses":[{"id":"24465","book":"마가복음","book_name":"마가복음","chapter":7,"verse":1,"text":"바리새인들과 또 서기관 중 몇이 예루살렘에서 와서 예수께 모였다가","reference":"마가복음 7:1","category":"$undefined"},{"id":"24466","book":"마가복음","book_name":"마가복음","chapter":7,"verse":2,"text":"그의 제자 중 몇 사람의 부정한 손 곧 씻지 아니한 손으로 떡 먹는 것을 보았더라","reference":"마가복음 7:2","category":"$undefined"},{"id":"24467","book":"마가복음","book_name":"마가복음","chapter":7,"verse":3,"text":"(바리새인들과 모든 유대인들이 장로들의 유전을 지키어 손을 부지런히 씻지 않으면 먹지 아니하며","reference":"마가복음 7:3","category":"$undefined"},{"id":"24468","book":"마가복음","book_name":"마가복음","chapter":7,"verse":4,"text":"또 시장에서 돌아와서는 물을 뿌리지 않으면 먹지 아니하며 그 외에도 여러가지를 지키어 오는 것이 있으니 잔과 주발과 놋그릇을 씻음이러라","reference":"마가복음 7:4","category":"$undefined"},{"id":"24469","book":"마가복음","book_name":"마가복음","chapter":7,"verse":5,"text":"이에 바리새인들과 서기관들이 예수께 묻되 `어찌하여 당신의 제자들은 장로들의 유전을 준행치 아니하고 부정한 손으로 떡을 먹나이까 ?'","reference":"마가복음 7:5","category":"$undefined"},{"id":"24470","book":"마가복음","book_name":"마가복음","chapter":7,"verse":6,"text":"가라사대 `이사야가 너희 외식하는 자에 대하여 잘 예언하였도다 기록하였으되 이 백성이 입술로는 나를 존경하되 마음은 내게서 멀도다","reference":"마가복음 7:6","category":"$undefined"},{"id":"24471","book":"마가복음","book_name":"마가복음","chapter":7,"verse":7,"text":"사람의 계명으로 교훈을 삼아 가르치니 나를 헛되이 경배하는도다 하였느니라","reference":"마가복음 7:7","category":"$undefined"},{"id":"24472","book":"마가복음","book_name":"마가복음","chapter":7,"verse":8,"text":"너희가 하나님의 계명은 버리고 사람의 유전을 지키느니라'","reference":"마가복음 7:8","category":"$undefined"},{"id":"24473","book":"마가복음","book_name":"마가복음","chapter":7,"verse":9,"text":"또 가라사대 `너희가 너희 유전을 지키려고 하나님의 계명을 잘 저버리는도다","reference":"마가복음 7:9","category":"$undefined"},{"id":"24474","book":"마가복음","book_name":"마가복음","chapter":7,"verse":10,"text":"모세는 네 부모를 공경하라 하고 또 아비나 어미를 훼방하는 자는 반드시 죽으리라 하였거늘","reference":"마가복음 7:10","category":"$undefined"},{"id":"24475","book":"마가복음","book_name":"마가복음","chapter":7,"verse":11,"text":"너희는 가로되 사람이 아비에게나 어미에게나 말하기를 내가 드려 유익하게 할 것이 고르반 곧 하나님께 드림이 되었다고 하기만 하면 그만이라 하고","reference":"마가복음 7:11","category":"$undefined"},{"id":"24476","book":"마가복음","book_name":"마가복음","chapter":7,"verse":12,"text":"제 아비나 어미에게 다시 아무것이라도 하여 드리기를 허하지 아니하여","reference":"마가복음 7:12","category":"$undefined"},{"id":"24477","book":"마가복음","book_name":"마가복음","chapter":7,"verse":13,"text":"너희의 전한 유전으로 하나님의 말씀을 폐하며 또 이같은 일을 많이 행하느니라' 하시고","reference":"마가복음 7:13","category":"$undefined"},{"id":"24478","book":"마가복음","book_name":"마가복음","chapter":7,"verse":14,"text":"무리를 다시 불러 이르시되 `너희는 다 내 말을 듣고 깨달으라","reference":"마가복음 7:14","category":"$undefined"},{"id":"24479","book":"마가복음","book_name":"마가복음","chapter":7,"verse":15,"text":"무엇이든지 밖에서 사람에게로 들어가는 것은 능히 사람을 더럽게 하지 못하되","reference":"마가복음 7:15","category":"$undefined"},{"id":"24480","book":"마가복음","book_name":"마가복음","chapter":7,"verse":16,"text":"사람 안에서 나오는 것이 사람을 더럽게 하는 것이니라' 하시고","reference":"마가복음 7:16","category":"$undefined"},{"id":"24481","book":"마가복음","book_name":"마가복음","chapter":7,"verse":17,"text":"무리를 떠나 집으로 들어가시니 제자들이 그 비유를 묻자온대","reference":"마가복음 7:17","category":"$undefined"},{"id":"24482","book":"마가복음","book_name":"마가복음","chapter":7,"verse":18,"text":"예수께서 이르시되 `너희도 이렇게 깨달음이 없느냐 ? 무엇이든지 밖에서 들어가는 것이 능히 사람을 더럽게 하지 못함을 알지 못하느냐 ?","reference":"마가복음 7:18","category":"$undefined"},{"id":"24483","book":"마가복음","book_name":"마가복음","chapter":7,"verse":19,"text":"이는 마음에 들어가지 아니하고 배에 들어가 뒤로 나감이니라 하심으로 모든 식물을 깨끗하다 하셨느니라'","reference":"마가복음 7:19","category":"$undefined"},{"id":"24484","book":"마가복음","book_name":"마가복음","chapter":7,"verse":20,"text":"또 가라사대 `사람에게서 나오는 그것이 사람을 더럽게 하느니라","reference":"마가복음 7:20","category":"$undefined"},{"id":"24485","book":"마가복음","book_name":"마가복음","chapter":7,"verse":21,"text":"속에서 곧 사람의 마음에서 나오는 것은 악한 생각 곧 음란과, 도적질과, 살인과,","reference":"마가복음 7:21","category":"$undefined"},{"id":"24486","book":"마가복음","book_name":"마가복음","chapter":7,"verse":22,"text":"간음과, 탐욕과, 악독과, 속임과, 음탕과, 흘기는 눈과, 훼방과, 교만과, 광패니","reference":"마가복음 7:22","category":"$undefined"},{"id":"24487","book":"마가복음","book_name":"마가복음","chapter":7,"verse":23,"text":"이 모든 악한 것이 다 속에서 나와서 사람을 더럽게 하느니라'","reference":"마가복음 7:23","category":"$undefined"},{"id":"24488","book":"마가복음","book_name":"마가복음","chapter":7,"verse":24,"text":"예수께서 일어나사 거기를 떠나 두로 지경으로 가서 한 집에 들어가 아무도 모르게 하시려하나 숨길 수 없더라","reference":"마가복음 7:24","category":"$undefined"},{"id":"24489","book":"마가복음","book_name":"마가복음","chapter":7,"verse":25,"text":"이에 더러운 귀신 들린 어린 딸을 둔 한 여자가 예수의 소문을 듣고 곧 와서 그 발 아래 엎드리니","reference":"마가복음 7:25","category":"$undefined"},{"id":"24490","book":"마가복음","book_name":"마가복음","chapter":7,"verse":26,"text":"그 여자는 헬라인이요 수로보니게 족속이라 자기 딸에게서 귀신 쫓아 주시기를 간구하거늘","reference":"마가복음 7:26","category":"$undefined"},{"id":"24491","book":"마가복음","book_name":"마가복음","chapter":7,"verse":27,"text":"예수께서 이르시되 `자녀로 먼저 배불리 먹게 할지니 자녀의 떡을 취하여 개들에게 던짐이 마땅치 아니하니라'","reference":"마가복음 7:27","category":"$undefined"},{"id":"24492","book":"마가복음","book_name":"마가복음","chapter":7,"verse":28,"text":"여자가 대답하여 가로되 `주여, 옳소이다마는 상 아래 개들도 아이들의 먹던 부스러기를 먹나이다'","reference":"마가복음 7:28","category":"$undefined"},{"id":"24493","book":"마가복음","book_name":"마가복음","chapter":7,"verse":29,"text":"예수께서 가라사대 `이 말을 하였으니 돌아가라 귀신이 네 딸에게서 나갔느니라' 하시매","reference":"마가복음 7:29","category":"$undefined"},{"id":"24494","book":"마가복음","book_name":"마가복음","chapter":7,"verse":30,"text":"여자가 집에 돌아가 본즉 아이가 침상에 누웠고 귀신이 나갔더라","reference":"마가복음 7:30","category":"$undefined"},{"id":"24495","book":"마가복음","book_name":"마가복음","chapter":7,"verse":31,"text":"예수께서 다시 두로 지경에서 나와 시돈을 지나고 데가볼리 지경을 통과하여 갈릴리 호수에 이르시매","reference":"마가복음 7:31","category":"$undefined"},{"id":"24496","book":"마가복음","book_name":"마가복음","chapter":7,"verse":32,"text":"사람들이 귀먹고 어눌한 자를 데리고 예수께 나아와 안수하여 주시기를 간구하거늘","reference":"마가복음 7:32","category":"$undefined"},{"id":"24497","book":"마가복음","book_name":"마가복음","chapter":7,"verse":33,"text":"예수께서 그 사람을 따로 데리고 무리를 떠나사 손가락을 그의 양 귀에 넣고 침뱉아 그의 혀에 손을 대시며","reference":"마가복음 7:33","category":"$undefined"},{"id":"24498","book":"마가복음","book_name":"마가복음","chapter":7,"verse":34,"text":"하늘을 우러러 탄식하시며 그에게 이르시되 `에바다 !' 하시니 이는 열리라는 뜻이라","reference":"마가복음 7:34","category":"$undefined"},{"id":"24499","book":"마가복음","book_name":"마가복음","chapter":7,"verse":35,"text":"그의 귀가 열리고 혀의 맺힌 것이 곧 풀려 말이 분명하더라","reference":"마가복음 7:35","category":"$undefined"},{"id":"24500","book":"마가복음","book_name":"마가복음","chapter":7,"verse":36,"text":"예수께서 저희에게 경계하사 `아무에게라도 이르지 말라' 하시되 경계하실수록 저희가 더욱 널리 전파하니","reference":"마가복음 7:36","category":"$undefined"},{"id":"24501","book":"마가복음","book_name":"마가복음","chapter":7,"verse":37,"text":"사람들이 심히 놀라 가로되 `그가 다 잘 하였도다 귀머거리도 듣게 하고 벙어리도 말하게 한다' 하니라","reference":"마가복음 7:37","category":"$undefined"}],"bookSlug":"mark"}]
