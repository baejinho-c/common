2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":8,"verses":[{"id":"24502","book":"마가복음","book_name":"마가복음","chapter":8,"verse":1,"text":"그 즈음에 또 큰 무리가 있어 먹을 것이 없는지라 예수께서 제자들을 불러 이르시되","reference":"마가복음 8:1","category":"$undefined"},{"id":"24503","book":"마가복음","book_name":"마가복음","chapter":8,"verse":2,"text":"`내가 무리를 불쌍히 여기노라 저희가 나와 함께 있은 지 이미 사흘이매 먹을 것이 없도다","reference":"마가복음 8:2","category":"$undefined"},{"id":"24504","book":"마가복음","book_name":"마가복음","chapter":8,"verse":3,"text":"만일 내가 저희를 굶겨 집으로 보내면 길에서 기진하리라 그 중에는 멀리서 온 사람도 있느니라'","reference":"마가복음 8:3","category":"$undefined"},{"id":"24505","book":"마가복음","book_name":"마가복음","chapter":8,"verse":4,"text":"제자들이 대답하되 `이 광야에서 어디서 떡을 얻어 이 사람들로 배부르게 할 수 있으리이까 ?'","reference":"마가복음 8:4","category":"$undefined"},{"id":"24506","book":"마가복음","book_name":"마가복음","chapter":8,"verse":5,"text":"예수께서 물으시되 너희에게 떡 몇개나 있느냐 ? 가로되 일곱이로소이다 하거늘","reference":"마가복음 8:5","category":"$undefined"},{"id":"24507","book":"마가복음","book_name":"마가복음","chapter":8,"verse":6,"text":"예수께서 무리를 명하사 땅에 앉게 하시고 떡 일곱 개를 가지사 축사하시고 떼어 제자들에게 주어 그 앞에 놓게 하시니 제자들이 무리 앞에 놓더라","reference":"마가복음 8:6","category":"$undefined"},{"id":"24508","book":"마가복음","book_name":"마가복음","chapter":8,"verse":7,"text":"또 작은 생선 두어 마리가 있는지라 이에 축복하시고 명하사 이것도 그 앞에 놓게 하시니","reference":"마가복음 8:7","category":"$undefined"},{"id":"24509","book":"마가복음","book_name":"마가복음","chapter":8,"verse":8,"text":"배불리 먹고 남은 조각 일곱 광주리를 거두었으며","reference":"마가복음 8:8","category":"$undefined"},{"id":"24510","book":"마가복음","book_name":"마가복음","chapter":8,"verse":9,"text":"사람은 약 사천 명이었더라 예수께서 저희를 흩어 보내시고","reference":"마가복음 8:9","category":"$undefined"},{"id":"24511","book":"마가복음","book_name":"마가복음","chapter":8,"verse":10,"text":"곧 제자들과 함께 배에 오르사 달마누다 지방으로 가시니라","reference":"마가복음 8:10","category":"$undefined"},{"id":"24512","book":"마가복음","book_name":"마가복음","chapter":8,"verse":11,"text":"바리새인들이 나와서 예수께 힐난하며 그를 시험하여 하늘로서 오는 표적을 구하거늘","reference":"마가복음 8:11","category":"$undefined"},{"id":"24513","book":"마가복음","book_name":"마가복음","chapter":8,"verse":12,"text":"예수께서 마음 속에 깊이 탄식하시며 가라사대 `어찌하여 이 세대가 표적을 구하느냐 ? 내가 진실로 너희에게 이르노니 이 세대에게 표적을 주시지 아니하리라' 하시고","reference":"마가복음 8:12","category":"$undefined"},{"id":"24514","book":"마가복음","book_name":"마가복음","chapter":8,"verse":13,"text":"저희를 떠나 다시 배에 올라 건너편으로 가시니라","reference":"마가복음 8:13","category":"$undefined"},{"id":"24515","book":"마가복음","book_name":"마가복음","chapter":8,"verse":14,"text":"제자들이 떡 가져 오기를 잊었으매 배에 떡 한 개밖에 저희에게 없더라","reference":"마가복음 8:14","category":"$undefined"},{"id":"24516","book":"마가복음","book_name":"마가복음","chapter":8,"verse":15,"text":"예수께서 경계하여 가라사대 `삼가 바리새인들의 누룩과 헤롯의 누룩을 주의하라' 하신대","reference":"마가복음 8:15","category":"$undefined"},{"id":"24517","book":"마가복음","book_name":"마가복음","chapter":8,"verse":16,"text":"제자들이 서로 의논하기를 `이는 우리에게 떡이 없음이로다' 하거늘","reference":"마가복음 8:16","category":"$undefined"},{"id":"24518","book":"마가복음","book_name":"마가복음","chapter":8,"verse":17,"text":"예수께서 아시고 이르시되 `너희가 어찌 떡이 없음으로 의논하느냐 ? 아직도 알지 못하며 깨닫지 못하느냐 ? 너희 마음이 둔하냐 ?","reference":"마가복음 8:17","category":"$undefined"},{"id":"24519","book":"마가복음","book_name":"마가복음","chapter":8,"verse":18,"text":"너희가 눈이 있어도 보지 못하며 귀가 있어도 듣지 못하느냐 ? 또 기억지 못하느냐 ?","reference":"마가복음 8:18","category":"$undefined"},{"id":"24520","book":"마가복음","book_name":"마가복음","chapter":8,"verse":19,"text":"내가 떡 다섯 개를 오천 명에게 떼어 줄 때에 조각 몇 바구니를 거두었더냐 ?' 가로되 `열 둘이니이다'","reference":"마가복음 8:19","category":"$undefined"},{"id":"24521","book":"마가복음","book_name":"마가복음","chapter":8,"verse":20,"text":"`또 일곱 개를 사천 명에게 떼어줄 때에 조각 몇광주리를 거두었더냐 ?' 가로되 `일곱이니이다'","reference":"마가복음 8:20","category":"$undefined"},{"id":"24522","book":"마가복음","book_name":"마가복음","chapter":8,"verse":21,"text":"가라사대 `아직도 깨닫지 못하느냐 ?' 하시니라","reference":"마가복음 8:21","category":"$undefined"},{"id":"24523","book":"마가복음","book_name":"마가복음","chapter":8,"verse":22,"text":"벳새다에 이르매 사람들이 소경 하나를 데리고 예수께 나아와 손 대시기를 구하거늘","reference":"마가복음 8:22","category":"$undefined"},{"id":"24524","book":"마가복음","book_name":"마가복음","chapter":8,"verse":23,"text":"예수께서 소경의 손을 붙드시고 마을 밖으로 데리고 나가사 눈에 침을 뱉으시며 그에게 안수하시고 `무엇이 보이느냐 ?' 물으시니","reference":"마가복음 8:23","category":"$undefined"},{"id":"24525","book":"마가복음","book_name":"마가복음","chapter":8,"verse":24,"text":"우러러보며 가로되 `사람들이 보이나이다 나무 같은 것들의 걸어 가는 것을 보나이다' 하거늘","reference":"마가복음 8:24","category":"$undefined"},{"id":"24526","book":"마가복음","book_name":"마가복음","chapter":8,"verse":25,"text":"이에 그 눈에 다시 안수하시매 저가 주목하여 보더니 나아서 만물을 밝히 보는지라","reference":"마가복음 8:25","category":"$undefined"},{"id":"24527","book":"마가복음","book_name":"마가복음","chapter":8,"verse":26,"text":"예수께서 그 사람을 집으로 보내시며 가라사대 `마을에도 들어가지 말라' 하시니라","reference":"마가복음 8:26","category":"$undefined"},{"id":"24528","book":"마가복음","book_name":"마가복음","chapter":8,"verse":27,"text":"예수와 제자들이 가이사랴 빌립보 여러 마을로 나가실새 노중에서 제자들에게 물어 가라사대 `사람들이 나를 누구라고 하느냐 ?'","reference":"마가복음 8:27","category":"$undefined"},{"id":"24529","book":"마가복음","book_name":"마가복음","chapter":8,"verse":28,"text":"여짜와 가로되 `세례 요한이라 라고 더러는 엘리야 더러는 선지자 중의 하나라 하나이다'","reference":"마가복음 8:28","category":"$undefined"},{"id":"24530","book":"마가복음","book_name":"마가복음","chapter":8,"verse":29,"text":"또 물으시되 `너희는 나를 누구라 하느냐 ?' 베드로가 대답하여 가로되 `주는 그리스도시니이다' 하매","reference":"마가복음 8:29","category":"$undefined"},{"id":"24531","book":"마가복음","book_name":"마가복음","chapter":8,"verse":30,"text":"이에 `자기의 일을 아무에게도 말하지 말라' 경계하시고","reference":"마가복음 8:30","category":"$undefined"},{"id":"24532","book":"마가복음","book_name":"마가복음","chapter":8,"verse":31,"text":"인자가 많은 고난을 받고 장로들과 대제사장들과 서기관들에게 버린바 되어 죽임을 당하고 사흘만에 살아나야 할 것을 비로소 저희에게 가르치시되","reference":"마가복음 8:31","category":"$undefined"},{"id":"24533","book":"마가복음","book_name":"마가복음","chapter":8,"verse":32,"text":"드러내놓고 이 말씀을 하시니 베드로가 예수를 붙들고 간하매","reference":"마가복음 8:32","category":"$undefined"},{"id":"24534","book":"마가복음","book_name":"마가복음","chapter":8,"verse":33,"text":"예수께서 돌이키사 제자들을 보시며 베드로를 꾸짖어 가라사대 `사단아 ! 내 뒤로 물러가라 네가 하나님의 일을 생각지 아니하고 도리어 사람의 일을 생각하는도다' 하시고","reference":"마가복음 8:33","category":"$undefined"},{"id":"24535","book":"마가복음","book_name":"마가복음","chapter":8,"verse":34,"text":"무리와 제자들을 불러 이르시되 `아무든지 나를 따라 오려거든 자기를 부인하고 자기 십자가를 지고 나를 좇을 것이니라","reference":"마가복음 8:34","category":"$undefined"},{"id":"24536","book":"마가복음","book_name":"마가복음","chapter":8,"verse":35,"text":"누구든지 제 목숨을 구원코자 하면 잃을 것이요 누구든지 나와 복음을 위하여 제 목숨을 잃으면 구원하리라","reference":"마가복음 8:35","category":"$undefined"},{"id":"24537","book":"마가복음","book_name":"마가복음","chapter":8,"verse":36,"text":"사람이 만일 온 천하를 얻고도 제 목숨을 잃으면 무엇이 유익하리요","reference":"마가복음 8:36","category":"$undefined"},{"id":"24538","book":"마가복음","book_name":"마가복음","chapter":8,"verse":37,"text":"사람이 무엇을 주고 제 목숨을 바꾸겠느냐 ?","reference":"마가복음 8:37","category":"$undefined"},{"id":"24539","book":"마가복음","book_name":"마가복음","chapter":8,"verse":38,"text":"누구든지 이 음란하고 죄 많은 세대에서 나와 내 말을 부끄러워하면 인자도 아버지의 영광으로 거룩한 천사들과 함께 올 때에 그사람을 부끄러워하리라'","reference":"마가복음 8:38","category":"$undefined"}],"bookSlug":"mark"}]
