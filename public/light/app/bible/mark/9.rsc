2:["$","$L11",null,{"book":{"id":"mark","name":"마가복음","chapters":16,"testament":"new"},"chapter":9,"verses":[{"id":"24540","book":"마가복음","book_name":"마가복음","chapter":9,"verse":1,"text":"또 저희에게 이르시되 `내가 진실로 너희에게 이르노니 여기 섰는 사람 중에 죽기 전에 하나님의 나라가 권능으로 임하는 것을 볼 자들도 있느니라' 하시니라","reference":"마가복음 9:1","category":"$undefined"},{"id":"24541","book":"마가복음","book_name":"마가복음","chapter":9,"verse":2,"text":"엿새 후에 예수께서 베드로와 야고보와 요한을 데리시고 따로 높은 산에 올라 가셨더니 저희 앞에서 변형되사","reference":"마가복음 9:2","category":"$undefined"},{"id":"24542","book":"마가복음","book_name":"마가복음","chapter":9,"verse":3,"text":"그 옷이 광채가 나며 세상에서 빨래하는 자가 그렇게 희게 할 수 없을 만큼 심히 희어졌더라","reference":"마가복음 9:3","category":"$undefined"},{"id":"24543","book":"마가복음","book_name":"마가복음","chapter":9,"verse":4,"text":"이에 엘리야가 모세와 함께 저희에게 나타나 예수로 더불어 말씀하거늘","reference":"마가복음 9:4","category":"$undefined"},{"id":"24544","book":"마가복음","book_name":"마가복음","chapter":9,"verse":5,"text":"베드로가 예수께 고하되 `랍비여 우리가 여기 있는 것이 좋사오니 우리가 초막 셋을 짓되 하나는 주를 위하여, 하나는 모세를 위하여, 하나는 엘리야를 위하여 하사이다' 하니","reference":"마가복음 9:5","category":"$undefined"},{"id":"24545","book":"마가복음","book_name":"마가복음","chapter":9,"verse":6,"text":"이는 저희가 심히 무서워하므로 저가 무슨 말을 할는지 알지 못함이더라","reference":"마가복음 9:6","category":"$undefined"},{"id":"24546","book":"마가복음","book_name":"마가복음","chapter":9,"verse":7,"text":"마침 구름이 와서 저희를 덮으며 구름 속에서 소리가 나되 `이는 내 사랑하는 아들이니 너희는 저의 말을 들으라' 하는지라","reference":"마가복음 9:7","category":"$undefined"},{"id":"24547","book":"마가복음","book_name":"마가복음","chapter":9,"verse":8,"text":"문득 둘러 보니 아무도 보이지 아니하고 오직 예수와 자기들 뿐이었더라","reference":"마가복음 9:8","category":"$undefined"},{"id":"24548","book":"마가복음","book_name":"마가복음","chapter":9,"verse":9,"text":"저희가 산에서 내려 올 때에 예수께서 경계하시되 `인자가 죽은 자 가운데서 살아날 때까지는 본 것을 아무에게도 이르지 말라' 하시니","reference":"마가복음 9:9","category":"$undefined"},{"id":"24549","book":"마가복음","book_name":"마가복음","chapter":9,"verse":10,"text":"저희가 이 말씀을 마음에 두며 서로 문의하되 `죽은 자 가운데서 살아나는 것이 무엇일까 ?' 하고","reference":"마가복음 9:10","category":"$undefined"},{"id":"24550","book":"마가복음","book_name":"마가복음","chapter":9,"verse":11,"text":"이에 예수께 묻자와 가로되 `어찌하여 서기관들이 엘리야가 먼저 와야 하리라 하나이까 ?'","reference":"마가복음 9:11","category":"$undefined"},{"id":"24551","book":"마가복음","book_name":"마가복음","chapter":9,"verse":12,"text":"가라사대 `엘리야가 과연 먼저와서 모든 것을 회복하거니와 어찌 인자에 대하여 기록하기를 많은 고난을 받고 멸시를 당하리라 하였느냐","reference":"마가복음 9:12","category":"$undefined"},{"id":"24552","book":"마가복음","book_name":"마가복음","chapter":9,"verse":13,"text":"그러나 내가 너희에게 이르노니 엘리야가 왔으되 기록된 바와 같이 사람들이 임의로 대우하였느니라' 하시니라","reference":"마가복음 9:13","category":"$undefined"},{"id":"24553","book":"마가복음","book_name":"마가복음","chapter":9,"verse":14,"text":"저희가 이에 제자들에게 와서 보니 큰 무리가 둘렀고 서기관들이 더불어 변론하더니","reference":"마가복음 9:14","category":"$undefined"},{"id":"24554","book":"마가복음","book_name":"마가복음","chapter":9,"verse":15,"text":"온 무리가 곧 예수를 보고 심히 놀라며 달려와 문안하거늘","reference":"마가복음 9:15","category":"$undefined"},{"id":"24555","book":"마가복음","book_name":"마가복음","chapter":9,"verse":16,"text":"예수께서 물으시되 `너희가 무엇을 저희와 변론하느냐 ?'","reference":"마가복음 9:16","category":"$undefined"},{"id":"24556","book":"마가복음","book_name":"마가복음","chapter":9,"verse":17,"text":"무리 중에 하나가 대답하되 `선생님, 벙어리 귀신 들린 내 아들을 선생님께 데려 왔나이다","reference":"마가복음 9:17","category":"$undefined"},{"id":"24557","book":"마가복음","book_name":"마가복음","chapter":9,"verse":18,"text":"귀신이 어디서든지 저를 잡으면 거꾸러져 거품을 흘리며 이를 갈며 그리고 파리하여 가는지라 내가 선생의 제자들에게 내어 쫓아달라 하였으나 저희가 능히 하지 못하더이다'","reference":"마가복음 9:18","category":"$undefined"},{"id":"24558","book":"마가복음","book_name":"마가복음","chapter":9,"verse":19,"text":"대답하여 가라사대 `믿음이 없는 세대여 ! 내가 얼마나 너희와 함께 있으며 얼마나 너희를 참으리요 그를 내게로 데려오라' 하시매","reference":"마가복음 9:19","category":"$undefined"},{"id":"24559","book":"마가복음","book_name":"마가복음","chapter":9,"verse":20,"text":"이에 데리고 오니 귀신이 예수를 보고 곧 그 아이로 심히 경련을 일으키게 하는지라 저가 땅에 엎드러져 굴며 거품을 흘리더라","reference":"마가복음 9:20","category":"$undefined"},{"id":"24560","book":"마가복음","book_name":"마가복음","chapter":9,"verse":21,"text":"예수께서 그 아비에게 물으시되 `언제부터 이렇게 되었느냐 ?' 하시니 가로되 `어릴 때부터니이다","reference":"마가복음 9:21","category":"$undefined"},{"id":"24561","book":"마가복음","book_name":"마가복음","chapter":9,"verse":22,"text":"귀신이 저를 죽이려고 불과 물에 자주 던졌나이다 그러나 무엇을 하실 수 있거든 우리를 불쌍히 여기사 도와 주옵소서'","reference":"마가복음 9:22","category":"$undefined"},{"id":"24562","book":"마가복음","book_name":"마가복음","chapter":9,"verse":23,"text":"예수께서 이르시되 `할 수 있거든 이 무슨 말이냐 ? 믿는 자에게는 능치 못할 일이 없느니라 !' 하시니","reference":"마가복음 9:23","category":"$undefined"},{"id":"24563","book":"마가복음","book_name":"마가복음","chapter":9,"verse":24,"text":"곧 그 아이의 아비가 소리를 질러 가로되 `내가 믿나이다 나의 믿음 없는 것을 도와주소서 !' 하더라","reference":"마가복음 9:24","category":"$undefined"},{"id":"24564","book":"마가복음","book_name":"마가복음","chapter":9,"verse":25,"text":"예수께서 무리의 달려 모이는 것을 보시고 그 더러운 귀신을 꾸짖어 가라사대 `벙어리 되고 귀먹은 귀신아 ! 내가 네게 명하노니 그 아이에게서 나오고 다시 들어가지 말라' 하시매","reference":"마가복음 9:25","category":"$undefined"},{"id":"24565","book":"마가복음","book_name":"마가복음","chapter":9,"verse":26,"text":"귀신이 소리지르며 아이로 심히 경련을 일으키게 하고 나가니 그 아이가 죽은 것같이 되어 많은 사람이 말하기를 죽었다 하나","reference":"마가복음 9:26","category":"$undefined"},{"id":"24566","book":"마가복음","book_name":"마가복음","chapter":9,"verse":27,"text":"예수께서 그 손을 잡아 일으키시니 이에 일어서니라","reference":"마가복음 9:27","category":"$undefined"},{"id":"24567","book":"마가복음","book_name":"마가복음","chapter":9,"verse":28,"text":"집에 들어가시매 제자들이 종용히 묻자오되 `우리는 어찌하여 능히 그 귀신을 쫓아내지 못하였나이까 ?'","reference":"마가복음 9:28","category":"$undefined"},{"id":"24568","book":"마가복음","book_name":"마가복음","chapter":9,"verse":29,"text":"이르시되 `기도 외에 다른 것으로는 이런 유가 나갈 수 없느니라' 하시니라","reference":"마가복음 9:29","category":"$undefined"},{"id":"24569","book":"마가복음","book_name":"마가복음","chapter":9,"verse":30,"text":"그곳을 떠나 갈릴리 가운데로 지날새 예수께서 아무에게도 알리고자 아니하시니","reference":"마가복음 9:30","category":"$undefined"},{"id":"24570","book":"마가복음","book_name":"마가복음","chapter":9,"verse":31,"text":"이는 제자들을 가르치시며 또 인자가 사람들의 손에 넘기워 죽임을 당하고 죽은 지 삼 일만에 살아나리라는 것을 말씀하시는 연고더라","reference":"마가복음 9:31","category":"$undefined"},{"id":"24571","book":"마가복음","book_name":"마가복음","chapter":9,"verse":32,"text":"그러나 제자들은 이 말씀을 깨닫지 못하고 묻기도 무서워하더라","reference":"마가복음 9:32","category":"$undefined"},{"id":"24572","book":"마가복음","book_name":"마가복음","chapter":9,"verse":33,"text":"가버나움에 이르러 집에 계실새 제자들에게 물으시되 `너희가 노중에서 서로 토론한 것이 무엇이냐 ?' 하시되","reference":"마가복음 9:33","category":"$undefined"},{"id":"24573","book":"마가복음","book_name":"마가복음","chapter":9,"verse":34,"text":"저희가 잠잠하니 이는 노중에서 서로 누가 크냐 ? 하고 쟁론하였음이라","reference":"마가복음 9:34","category":"$undefined"},{"id":"24574","book":"마가복음","book_name":"마가복음","chapter":9,"verse":35,"text":"예수께서 앉으사 열 두 제자를 불러서 이르시되 `아무든지 첫째가 되고자 하면 뭇사람의 끝이 되며 뭇사람을 섬기는 자가 되어야 하리라' 하시고","reference":"마가복음 9:35","category":"$undefined"},{"id":"24575","book":"마가복음","book_name":"마가복음","chapter":9,"verse":36,"text":"어린 아이 하나를 데려다가 그들 가운데 세우시고 안으시며 제자들에게 이르시되","reference":"마가복음 9:36","category":"$undefined"},{"id":"24576","book":"마가복음","book_name":"마가복음","chapter":9,"verse":37,"text":"`누구든지 내 이름으로 이런 어린 아이 하나를 영접하면 곧 나를 영접함이요 누구든지 나를 영접하면 나를 영접함이 아니요 나를 보내신 이를 영접함이니라'","reference":"마가복음 9:37","category":"$undefined"},{"id":"24577","book":"마가복음","book_name":"마가복음","chapter":9,"verse":38,"text":"요한이 예수께 여짜오되 `선생님 우리를 따르지 않는 어떤 자가 주의 이름으로 귀신을 내어 쫓는 것을 우리가 보고 우리를 따르지 아니하므로 금하였나이다'","reference":"마가복음 9:38","category":"$undefined"},{"id":"24578","book":"마가복음","book_name":"마가복음","chapter":9,"verse":39,"text":"예수께서 가라사대 `금하지 말라 내 이름을 의탁하여 능한 일을 행하고 즉시로 나를 비방할 자가 없느니라","reference":"마가복음 9:39","category":"$undefined"},{"id":"24579","book":"마가복음","book_name":"마가복음","chapter":9,"verse":40,"text":"우리를 반대하지 않는 자는 우리를 위하는 자니라","reference":"마가복음 9:40","category":"$undefined"},{"id":"24580","book":"마가복음","book_name":"마가복음","chapter":9,"verse":41,"text":"누구든지 너희를 그리스도에게 속한 자라 하여 물 한 그릇을 주면 내가 진실로 너희에게 이르노니 저가 결단코 상을 잃지 않으리라","reference":"마가복음 9:41","category":"$undefined"},{"id":"24581","book":"마가복음","book_name":"마가복음","chapter":9,"verse":42,"text":"또 누구든지 나를 믿는 이 소자 중 하나를 실족케 하면 차라리 연자 맷돌을 그 목에 달리우고 바다에 던지움이 나으리라","reference":"마가복음 9:42","category":"$undefined"},{"id":"24582","book":"마가복음","book_name":"마가복음","chapter":9,"verse":43,"text":"만일 네 손이 너를 범죄케 하거든 찍어 버리라 불구자로 영생에 들어가는 것이 두 손을 가지고 지옥 꺼지지 않는 불에 들어가는 것보다 나으니라","reference":"마가복음 9:43","category":"$undefined"},{"id":"24583","book":"마가복음","book_name":"마가복음","chapter":9,"verse":44,"text":"(없 음)","reference":"마가복음 9:44","category":"$undefined"},{"id":"24584","book":"마가복음","book_name":"마가복음","chapter":9,"verse":45,"text":"만일 네 발이 너를 범죄케 하거든 찍어 버리라 절뚝발이로 영생에 들어가는 것이 두 발을 가지고 지옥에 던지우는 것보다 나으니라","reference":"마가복음 9:45","category":"$undefined"},{"id":"24585","book":"마가복음","book_name":"마가복음","chapter":9,"verse":46,"text":"(없 음)","reference":"마가복음 9:46","category":"$undefined"},{"id":"24586","book":"마가복음","book_name":"마가복음","chapter":9,"verse":47,"text":"만일 네 눈이 너를 범죄케 하거든 뻬어버리라 한 눈으로 하나님의 나라에 들어가는 것이 두 눈을 가지고 지옥에 던지우는 것보다 나으니라","reference":"마가복음 9:47","category":"$undefined"},{"id":"24587","book":"마가복음","book_name":"마가복음","chapter":9,"verse":48,"text":"거기는 구더기도 죽지 않고 불도 꺼지지 아니하느니라","reference":"마가복음 9:48","category":"$undefined"},{"id":"24588","book":"마가복음","book_name":"마가복음","chapter":9,"verse":49,"text":"사람마다 불로서 소금 치듯함을 받으리라","reference":"마가복음 9:49","category":"$undefined"},{"id":"24589","book":"마가복음","book_name":"마가복음","chapter":9,"verse":50,"text":"소금은 좋은 것이로되 만일 소금이 그 맛을 잃으면 무엇으로 이를 짜게 하리요 너희 속에 소금을 두고 서로 화목하라 !' 하시니라","reference":"마가복음 9:50","category":"$undefined"}],"bookSlug":"mark"}]
