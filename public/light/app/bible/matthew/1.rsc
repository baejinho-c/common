11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":1,"verses":[{"id":"23146","book":"마태복음","book_name":"마태복음","chapter":1,"verse":1,"text":"아브라함과 다윗의 자손 예수 그리스도의 세계라","reference":"마태복음 1:1","category":"$undefined"},{"id":"23147","book":"마태복음","book_name":"마태복음","chapter":1,"verse":2,"text":"아브라함이 이삭을 낳고 이삭은 야곱을 낳고 야곱은 유다와 그의 형제를 낳고","reference":"마태복음 1:2","category":"$undefined"},{"id":"23148","book":"마태복음","book_name":"마태복음","chapter":1,"verse":3,"text":"유다는 다말에게서 베레스와 세라를 낳고, 베레스는 헤스론을 낳고, 헤스론은 람을 낳고","reference":"마태복음 1:3","category":"$undefined"},{"id":"23149","book":"마태복음","book_name":"마태복음","chapter":1,"verse":4,"text":"람은 아미나답을 낳고, 아미나답은 나손을 낳고, 나손은 살몬을 낳고","reference":"마태복음 1:4","category":"$undefined"},{"id":"23150","book":"마태복음","book_name":"마태복음","chapter":1,"verse":5,"text":"살몬은 라합에게서 보아스를 낳고, 보아스는 룻에게서 오벳을 낳고, 오벳은 이새를 낳고","reference":"마태복음 1:5","category":"$undefined"},{"id":"23151","book":"마태복음","book_name":"마태복음","chapter":1,"verse":6,"text":"이새는 다윗왕을 낳으니라 다윗은 우리야의 아내에게서 솔로몬을 낳고","reference":"마태복음 1:6","category":"$undefined"},{"id":"23152","book":"마태복음","book_name":"마태복음","chapter":1,"verse":7,"text":"솔로몬은 르호보암을 낳고, 르호보암은 아비야를 낳고, 아비야는 아사를 낳고","reference":"마태복음 1:7","category":"$undefined"},{"id":"23153","book":"마태복음","book_name":"마태복음","chapter":1,"verse":8,"text":"아사는 여호사밧을 낳고, 여호사밧은 요람을 낳고, 요람은 웃시야를 낳고","reference":"마태복음 1:8","category":"$undefined"},{"id":"23154","book":"마태복음","book_name":"마태복음","chapter":1,"verse":9,"text":"웃시야는 요담을 낳고, 요담은 아하스를 낳고, 아하스는 히스기야를 낳고","reference":"마태복음 1:9","category":"$undefined"},{"id":"23155","book":"마태복음","book_name":"마태복음","chapter":1,"verse":10,"text":"히스기야는 므낫세를 낳고, 므낫세는 아몬을 낳고, 아몬은 요시야를 낳고","reference":"마태복음 1:10","category":"$undefined"},{"id":"23156","book":"마태복음","book_name":"마태복음","chapter":1,"verse":11,"text":"바벨론으로 이거할 때에 요시야는 여고냐와 그의 형제를 낳으니라","reference":"마태복음 1:11","category":"$undefined"},{"id":"23157","book":"마태복음","book_name":"마태복음","chapter":1,"verse":12,"text":"바벨론으로 이거한 후에 여고냐는 스알디엘을 낳고, 스알디엘은 스룹바벨을 낳고","reference":"마태복음 1:12","category":"$undefined"},{"id":"23158","book":"마태복음","book_name":"마태복음","chapter":1,"verse":13,"text":"스룹바벨은 아비훗을 낳고, 아비훗은 엘리아김을 낳고, 엘리아김은 아소르를 낳고","reference":"마태복음 1:13","category":"$undefined"},{"id":"23159","book":"마태복음","book_name":"마태복음","chapter":1,"verse":14,"text":"아소르는 사독을 낳고, 사독은 아킴를 낳고, 아킴은 엘리웃을 낳고","reference":"마태복음 1:14","category":"$undefined"},{"id":"23160","book":"마태복음","book_name":"마태복음","chapter":1,"verse":15,"text":"엘리웃은 엘르아살을 낳고, 엘르아살은 맛단을 낳고, 맛단은 야곱을 낳고","reference":"마태복음 1:15","category":"$undefined"},{"id":"23161","book":"마태복음","book_name":"마태복음","chapter":1,"verse":16,"text":"야곱은 마리아의 남편 요셉을 낳았으니 마리아에게서 그리스도라 칭하는 예수가 나시니라","reference":"마태복음 1:16","category":"$undefined"},{"id":"23162","book":"마태복음","book_name":"마태복음","chapter":1,"verse":17,"text":"그런즉 모든 대수가 아브라함부터 다윗까지 열 네대요, 다윗부터 바벨론으로 이거할 때까지 열 네대요, 바벨론으로 이거한 후부터 그리스도까지 열 네대러라","reference":"마태복음 1:17","category":"$undefined"},{"id":"23163","book":"마태복음","book_name":"마태복음","chapter":1,"verse":18,"text":"예수 그리스도의 나심은 이러하니라 그 모친 마리아가 요셉과 정혼하고 동거하기 전에 성령으로 잉태된 것이 나타났더니","reference":"마태복음 1:18","category":"$undefined"},{"id":"23164","book":"마태복음","book_name":"마태복음","chapter":1,"verse":19,"text":"그 남편 요셉은 의로운 사람이라 저를 드러내지 아니하고 가만히 끊고자 하여","reference":"마태복음 1:19","category":"$undefined"},{"id":"23165","book":"마태복음","book_name":"마태복음","chapter":1,"verse":20,"text":"이 일을 생각할 때에 주의 사자가 현몽하여 가로되 `다윗의 자손 요셉아 네 아내 마리아 데려오기를 무서워 말라 저에게 잉태된 자는 성령으로 된 것이라","reference":"마태복음 1:20","category":"$undefined"},{"id":"23166","book":"마태복음","book_name":"마태복음","chapter":1,"verse":21,"text":"아들을 낳으리니 이름을 예수라 하라 이는 그가 자기 백성을 저희 죄에서 구원할 자이심이라' 하니라","reference":"마태복음 1:21","category":"$undefined"},{"id":"23167","book":"마태복음","book_name":"마태복음","chapter":1,"verse":22,"text":"이 모든 일의 된 것은 주께서 선지자로 하신 말씀을 이루려 하심이니 가라사대","reference":"마태복음 1:22","category":"$undefined"},{"id":"23168","book":"마태복음","book_name":"마태복음","chapter":1,"verse":23,"text":"보라 ! 처녀가 잉태하여 아들을 낳을 것이요 그 이름은 임마누엘이라 하리라 하셨으니 이를 `번역한즉 하나님이 우리와 함께 계시다'함이라","reference":"마태복음 1:23","category":"$undefined"},{"id":"23169","book":"마태복음","book_name":"마태복음","chapter":1,"verse":24,"text":"요셉이 잠을 깨어 일어나서 주의 사자의 분부대로 행하여 그 아내를 데려 왔으나","reference":"마태복음 1:24","category":"$undefined"},{"id":"23170","book":"마태복음","book_name":"마태복음","chapter":1,"verse":25,"text":"아들을 낳기까지 동침치 아니하더니 낳으매 이름을 예수라 하니라","reference":"마태복음 1:25","category":"$undefined"}],"bookSlug":"matthew"}]
