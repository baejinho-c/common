2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":10,"verses":[{"id":"23419","book":"마태복음","book_name":"마태복음","chapter":10,"verse":1,"text":"예수께서 그 열 두 제자를 부르사 더러운 귀신을 쫓아내며 모든 병과 모든 약한 것을 고치는 권능을 주시니라","reference":"마태복음 10:1","category":"$undefined"},{"id":"23420","book":"마태복음","book_name":"마태복음","chapter":10,"verse":2,"text":"열 두 사도의 이름은 이러하니 베드로라 하는 시몬을 비롯하여 그의 형제 안드레와, 세베대의 아들 야고보와, 그의 형제 요한,","reference":"마태복음 10:2","category":"$undefined"},{"id":"23421","book":"마태복음","book_name":"마태복음","chapter":10,"verse":3,"text":"빌립과 바돌로매, 도마와, 세리 마태, 알패오의 아들 야고보와, 다대오,","reference":"마태복음 10:3","category":"$undefined"},{"id":"23422","book":"마태복음","book_name":"마태복음","chapter":10,"verse":4,"text":"가나안인 시몬과, 및 가룟 유다 곧 예수를 판 자라","reference":"마태복음 10:4","category":"$undefined"},{"id":"23423","book":"마태복음","book_name":"마태복음","chapter":10,"verse":5,"text":"예수께서 이 열 둘을 내어 보내시며 명하여 가라사대 이방인의 길로도 가지 말고 사마리아인의 고을에도 들어가지 말고","reference":"마태복음 10:5","category":"$undefined"},{"id":"23424","book":"마태복음","book_name":"마태복음","chapter":10,"verse":6,"text":"차라리 이스라엘 집의 잃어버린 양에게로 가라","reference":"마태복음 10:6","category":"$undefined"},{"id":"23425","book":"마태복음","book_name":"마태복음","chapter":10,"verse":7,"text":"가면서 전파하여 말하되 천국이 가까왔다 하고","reference":"마태복음 10:7","category":"$undefined"},{"id":"23426","book":"마태복음","book_name":"마태복음","chapter":10,"verse":8,"text":"병든 자를 고치며 죽은 자를 살리며 문둥이를 깨끗하게 하며 귀신을 쫓아내되 너희가 거저 받았으니 거저 주어라","reference":"마태복음 10:8","category":"$undefined"},{"id":"23427","book":"마태복음","book_name":"마태복음","chapter":10,"verse":9,"text":"너희 전대에 금이나 은이나 동이나 가지지 말고","reference":"마태복음 10:9","category":"$undefined"},{"id":"23428","book":"마태복음","book_name":"마태복음","chapter":10,"verse":10,"text":"여행을 위하여 주머니나 두 벌 옷이나 신이나 지팡이를 가지지 말라 이는 일군이 저 먹을 것 받는 것이 마땅함이니라","reference":"마태복음 10:10","category":"$undefined"},{"id":"23429","book":"마태복음","book_name":"마태복음","chapter":10,"verse":11,"text":"아무 성이나 촌에 들어가든지 그 중에 합당한 자를 찾아내어 너희 떠나기까지 거기서 머물라","reference":"마태복음 10:11","category":"$undefined"},{"id":"23430","book":"마태복음","book_name":"마태복음","chapter":10,"verse":12,"text":"또 그 집에 들어가면서 평안하기를 빌라","reference":"마태복음 10:12","category":"$undefined"},{"id":"23431","book":"마태복음","book_name":"마태복음","chapter":10,"verse":13,"text":"그 집이 이에 합당하면 너희 빈 평안이 거기 임할 것이요 만일 합당치 아니하면 그 평안이 너희에게 돌아올 것이니라","reference":"마태복음 10:13","category":"$undefined"},{"id":"23432","book":"마태복음","book_name":"마태복음","chapter":10,"verse":14,"text":"누구든지 너희를 영접도 아니하고 너희 말을 듣지도 아니하거든 그 집이나 성에서 나가 너희 발의 먼지를 떨어 버리라","reference":"마태복음 10:14","category":"$undefined"},{"id":"23433","book":"마태복음","book_name":"마태복음","chapter":10,"verse":15,"text":"내가 진실로 너희에게 이르노니 심판날에 소돔과 고모라 땅이 그 성보다 견디기 쉬우리라","reference":"마태복음 10:15","category":"$undefined"},{"id":"23434","book":"마태복음","book_name":"마태복음","chapter":10,"verse":16,"text":"보라 내가 너희를 보냄이 양을 이리 가운데 보냄과 같도다 그러므로 너희는 뱀같이 지혜롭고 비둘기같이 순결하라","reference":"마태복음 10:16","category":"$undefined"},{"id":"23435","book":"마태복음","book_name":"마태복음","chapter":10,"verse":17,"text":"사람들을 삼가라 저희가 너희를 공회에 넘겨 주겠고 저희 회당에서 채찍질하리라","reference":"마태복음 10:17","category":"$undefined"},{"id":"23436","book":"마태복음","book_name":"마태복음","chapter":10,"verse":18,"text":"또 너희가 나를 인하여 총독들과 임금들 앞에 끌려 가리니 이는 저희와 이방인들에게 증거가 되게 하려 하심이라","reference":"마태복음 10:18","category":"$undefined"},{"id":"23437","book":"마태복음","book_name":"마태복음","chapter":10,"verse":19,"text":"너희를 넘겨 줄 때에 어떻게 또는 무엇을 말할까 염려치 말라 그때에 무슨 말할 것을 주시리니","reference":"마태복음 10:19","category":"$undefined"},{"id":"23438","book":"마태복음","book_name":"마태복음","chapter":10,"verse":20,"text":"말하는 이는 너희가 아니라 너희 속에서 말씀하시는 자 곧 너희 아버지의 성령이시니라","reference":"마태복음 10:20","category":"$undefined"},{"id":"23439","book":"마태복음","book_name":"마태복음","chapter":10,"verse":21,"text":"장차 형제가 형제를 아비가 자식을 죽는 데 내어주며 자식들이 부모를 대적하여 죽게 하리라","reference":"마태복음 10:21","category":"$undefined"},{"id":"23440","book":"마태복음","book_name":"마태복음","chapter":10,"verse":22,"text":"또 너희가 내 이름을 인하여 모든 사람에게 미움을 받을 것이나 나중까지 견디는 자는 구원을 얻으리라","reference":"마태복음 10:22","category":"$undefined"},{"id":"23441","book":"마태복음","book_name":"마태복음","chapter":10,"verse":23,"text":"이 동네에서 너희를 핍박하거든 저 동네로 피하라 내가 진실로 너희에게 이르노니 이스라엘의 모든 동네를 다 다니지 못하여서 인자가 오리라","reference":"마태복음 10:23","category":"$undefined"},{"id":"23442","book":"마태복음","book_name":"마태복음","chapter":10,"verse":24,"text":"제자가 그 선생보다 또는 종이 그 상전보다 높지 못하나니","reference":"마태복음 10:24","category":"$undefined"},{"id":"23443","book":"마태복음","book_name":"마태복음","chapter":10,"verse":25,"text":"제자가 그 선생 같고 종이 그 상전 같으면 족하도다 집 주인을 바알세불이라 하였거든 하물며 그 집 사람들이랴","reference":"마태복음 10:25","category":"$undefined"},{"id":"23444","book":"마태복음","book_name":"마태복음","chapter":10,"verse":26,"text":"그런즉 저희를 두려워하지 말라 감추인 것이 드러나지 않을 것이 없고 숨은 것이 알려지지 않을 것이 없느니라","reference":"마태복음 10:26","category":"$undefined"},{"id":"23445","book":"마태복음","book_name":"마태복음","chapter":10,"verse":27,"text":"내가 너희에게 어두운 데서 이르는 것을 광명한 데서 말하며 너희가 귓속으로 듣는 것을 집 위에서 전파하라","reference":"마태복음 10:27","category":"$undefined"},{"id":"23446","book":"마태복음","book_name":"마태복음","chapter":10,"verse":28,"text":"몸은 죽여도 영혼은 능히 죽이지 못하는 자들을 두려워하지 말고 오직 몸과 영혼을 능히 지옥에 멸하시는 자를 두려워하라 !","reference":"마태복음 10:28","category":"$undefined"},{"id":"23447","book":"마태복음","book_name":"마태복음","chapter":10,"verse":29,"text":"참새 두 마리가 한 앗사리온에 팔리는 것이 아니냐 그러나 너희 아버지께서 허락지 아니하시면 그 하나라도 땅에 떨어지지 아니하리라","reference":"마태복음 10:29","category":"$undefined"},{"id":"23448","book":"마태복음","book_name":"마태복음","chapter":10,"verse":30,"text":"너희에게는 머리털까지 다 세신바 되었나니","reference":"마태복음 10:30","category":"$undefined"},{"id":"23449","book":"마태복음","book_name":"마태복음","chapter":10,"verse":31,"text":"두려워하지 말라 너희는 많은 참새보다 귀하니라","reference":"마태복음 10:31","category":"$undefined"},{"id":"23450","book":"마태복음","book_name":"마태복음","chapter":10,"verse":32,"text":"누구든지 사람 앞에서 나를 시인하면 나도 하늘에 계신 내 아버지 앞에서 저를 시인할 것이요","reference":"마태복음 10:32","category":"$undefined"},{"id":"23451","book":"마태복음","book_name":"마태복음","chapter":10,"verse":33,"text":"누구든지 사람 앞에서 나를 부인하면 나도 하늘에 계신 내 아버지 앞에서 저를 부인하리라","reference":"마태복음 10:33","category":"$undefined"},{"id":"23452","book":"마태복음","book_name":"마태복음","chapter":10,"verse":34,"text":"내가 세상에 화평을 주러 온 줄로 생각지 말라 화평이 아니요 검을 주러 왔노라","reference":"마태복음 10:34","category":"$undefined"},{"id":"23453","book":"마태복음","book_name":"마태복음","chapter":10,"verse":35,"text":"내가 온 것은 사람이 그 아비와, 딸이 어미와, 며느리가 시어미와 불화하게 하려 함이니","reference":"마태복음 10:35","category":"$undefined"},{"id":"23454","book":"마태복음","book_name":"마태복음","chapter":10,"verse":36,"text":"사람의 원수가 자기 집안 식구리라","reference":"마태복음 10:36","category":"$undefined"},{"id":"23455","book":"마태복음","book_name":"마태복음","chapter":10,"verse":37,"text":"아비나 어미를 나보다 더 사랑하는 자는 내게 합당치 아니하고 아들이나 딸을 나보다 더 사랑하는 자도 내게 합당치 아니하고","reference":"마태복음 10:37","category":"$undefined"},{"id":"23456","book":"마태복음","book_name":"마태복음","chapter":10,"verse":38,"text":"또 자기 십자가를 지고 나를 좇지 않는 자도 내게 합당치 아니하니라","reference":"마태복음 10:38","category":"$undefined"},{"id":"23457","book":"마태복음","book_name":"마태복음","chapter":10,"verse":39,"text":"자기 목숨을 얻는 자는 잃을 것이요 나를 위하여 자기 목숨을 잃는 자는 얻으리라","reference":"마태복음 10:39","category":"$undefined"},{"id":"23458","book":"마태복음","book_name":"마태복음","chapter":10,"verse":40,"text":"너희를 영접하는 자는 나를 영접하는 것이요 나를 영접하는 자는 나 보내신 이를 영접하는 것이니라","reference":"마태복음 10:40","category":"$undefined"},{"id":"23459","book":"마태복음","book_name":"마태복음","chapter":10,"verse":41,"text":"선지자의 이름으로 선지자를 영접하는 자는 선지자의 상을 받을 것이요 의인의 이름으로 의인을 영접하는 자는 의인의 상을 받을 것이요","reference":"마태복음 10:41","category":"$undefined"},{"id":"23460","book":"마태복음","book_name":"마태복음","chapter":10,"verse":42,"text":"또 누구든지 제자의 이름으로 이 소자 중 하나에게 냉수 한 그릇이라도 주는 자는 내가 진실로 너희에게 이르노니 그 사람이 결단코 상을 잃지 아니하리라 하시니라","reference":"마태복음 10:42","category":"$undefined"}],"bookSlug":"matthew"}]
