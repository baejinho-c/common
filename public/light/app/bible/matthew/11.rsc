2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":11,"verses":[{"id":"23461","book":"마태복음","book_name":"마태복음","chapter":11,"verse":1,"text":"예수께서 열 두 제자에게 명하시기를 마치시고 이에 저희 여러 동네에서 가르치시며 전도하시려고 거기를 떠나 가시니라","reference":"마태복음 11:1","category":"$undefined"},{"id":"23462","book":"마태복음","book_name":"마태복음","chapter":11,"verse":2,"text":"요한이 옥에서 그리스도의 하신 일을 듣고 제자들을 보내어","reference":"마태복음 11:2","category":"$undefined"},{"id":"23463","book":"마태복음","book_name":"마태복음","chapter":11,"verse":3,"text":"예수께 여짜오되 `오실 그이가 당신이오니이까 ? 우리가 다른 이를 기다리오리이까 ?'","reference":"마태복음 11:3","category":"$undefined"},{"id":"23464","book":"마태복음","book_name":"마태복음","chapter":11,"verse":4,"text":"예수께서 대답하여 가라사대 너희가 가서 듣고 보는 것을 요한에게 고하되","reference":"마태복음 11:4","category":"$undefined"},{"id":"23465","book":"마태복음","book_name":"마태복음","chapter":11,"verse":5,"text":"소경이 보며 앉은뱅이가 걸으며 문둥이가 깨끗함을 받으며 귀머거리가 들으며 죽은 자가 살아나며 가난한 자에게 복음이 전파된다 하라","reference":"마태복음 11:5","category":"$undefined"},{"id":"23466","book":"마태복음","book_name":"마태복음","chapter":11,"verse":6,"text":"누구든지 나를 인하여 실족하지 아니하는 자는 복이 있도다 하시니라","reference":"마태복음 11:6","category":"$undefined"},{"id":"23467","book":"마태복음","book_name":"마태복음","chapter":11,"verse":7,"text":"저희가 떠나매 예수께서 무리에게 요한에 대하여 말씀하시되 너희가 무엇을 보려고 광야에 나갔더냐 ? 바람에 흔들리는 갈대냐 ?","reference":"마태복음 11:7","category":"$undefined"},{"id":"23468","book":"마태복음","book_name":"마태복음","chapter":11,"verse":8,"text":"그러면 너희가 무엇을 보려고 나갔더냐 ? 부드러운 옷 입은 사람이냐 ? 부드러운 옷을 입은 자들은 왕궁에 있느니라","reference":"마태복음 11:8","category":"$undefined"},{"id":"23469","book":"마태복음","book_name":"마태복음","chapter":11,"verse":9,"text":"그러면 너희가 어찌하여 나갔더냐 ? 선지자를 보려더냐 ? 옳다, 내가 너희에게 이르노니 선지자보다도 나은 자니라","reference":"마태복음 11:9","category":"$undefined"},{"id":"23470","book":"마태복음","book_name":"마태복음","chapter":11,"verse":10,"text":"기록된바 보라 내가 내 사자를 네 앞에 보내노니 저가 네 길을 네 앞에 예비하리라 하신 것이 이 사람에 대한 말씀이니라","reference":"마태복음 11:10","category":"$undefined"},{"id":"23471","book":"마태복음","book_name":"마태복음","chapter":11,"verse":11,"text":"내가 진실로 너희에게 말하노니 여자가 낳은 자 중에 세례 요한보다 큰 이가 일어남이 없도다 그러나 천국에서는 극히 작은 자라도 저보다 크니라","reference":"마태복음 11:11","category":"$undefined"},{"id":"23472","book":"마태복음","book_name":"마태복음","chapter":11,"verse":12,"text":"세례 요한의 때부터 지금까지 천국은 침노를 당하나니 침노하는 자는 빼앗느니라","reference":"마태복음 11:12","category":"$undefined"},{"id":"23473","book":"마태복음","book_name":"마태복음","chapter":11,"verse":13,"text":"모든 선지자와 및 율법의 예언한 것이 요한까지니","reference":"마태복음 11:13","category":"$undefined"},{"id":"23474","book":"마태복음","book_name":"마태복음","chapter":11,"verse":14,"text":"만일 너희가 즐겨 받을진대 오리라 한 엘리야가 곧 이 사람이니라","reference":"마태복음 11:14","category":"$undefined"},{"id":"23475","book":"마태복음","book_name":"마태복음","chapter":11,"verse":15,"text":"귀 있는 자는 들을지어다","reference":"마태복음 11:15","category":"$undefined"},{"id":"23476","book":"마태복음","book_name":"마태복음","chapter":11,"verse":16,"text":"이 세대를 무엇으로 비유할꼬 비유컨대 아이들이 장터에 앉아 제 동무를 불러","reference":"마태복음 11:16","category":"$undefined"},{"id":"23477","book":"마태복음","book_name":"마태복음","chapter":11,"verse":17,"text":"가로되 우리가 너희를 향하여 피리를 불어도 너희가 춤추지 않고 우리가 애곡하여도 너희가 가슴을 치지 아니하였다 함과 같도다","reference":"마태복음 11:17","category":"$undefined"},{"id":"23478","book":"마태복음","book_name":"마태복음","chapter":11,"verse":18,"text":"요한이 와서 먹지도 않고 마시지도 아니하매 저희가 말하기를 귀신이 들렸다 하더니","reference":"마태복음 11:18","category":"$undefined"},{"id":"23479","book":"마태복음","book_name":"마태복음","chapter":11,"verse":19,"text":"인자는 와서 먹고 마시매 말하기를 보라 먹기를 탐하고 포도주를 즐기는 사람이요 세리와 죄인의 친구로다 하니 지혜는 그 행한 일로 인하여 옳다 함을 얻느니라","reference":"마태복음 11:19","category":"$undefined"},{"id":"23480","book":"마태복음","book_name":"마태복음","chapter":11,"verse":20,"text":"예수께서 권능을 가장 많이 베푸신 고을들이 회개치 아니하므로 그 때에 책망하시되","reference":"마태복음 11:20","category":"$undefined"},{"id":"23481","book":"마태복음","book_name":"마태복음","chapter":11,"verse":21,"text":"화가 있을진저 고라신아 ! 화가 있을진저 벳새다야 ! 너희에게서 행한 모든 권능을 두로와 시돈에서 행하였더면 저희가 벌써 베옷을 입고 재에 앉아 회개하였으리라","reference":"마태복음 11:21","category":"$undefined"},{"id":"23482","book":"마태복음","book_name":"마태복음","chapter":11,"verse":22,"text":"내가 너희에게 이르노니 심판날에 두로와 시돈이 너희보다 견디기 쉬우리라","reference":"마태복음 11:22","category":"$undefined"},{"id":"23483","book":"마태복음","book_name":"마태복음","chapter":11,"verse":23,"text":"가버나움아 ! 네가 하늘에까지 높아지겠느냐 ? 음부에까지 낮아지리라 네게서 행한 모든 권능을 소돔에서 행하였더면 그 성이 오늘날까지 있었으리라","reference":"마태복음 11:23","category":"$undefined"},{"id":"23484","book":"마태복음","book_name":"마태복음","chapter":11,"verse":24,"text":"내가 너희에게 이르노니 심판날에 소돔 땅이 너보다 견디기 쉬우리라 하시니라","reference":"마태복음 11:24","category":"$undefined"},{"id":"23485","book":"마태복음","book_name":"마태복음","chapter":11,"verse":25,"text":"그 때에 예수께서 대답하여 가라사대 천지의 주재이신 아버지여 ! 이것을 지혜롭고 슬기 있는 자들에게는 숨기시고 어린 아이들에게는 나타내심을 감사하나이다","reference":"마태복음 11:25","category":"$undefined"},{"id":"23486","book":"마태복음","book_name":"마태복음","chapter":11,"verse":26,"text":"옳소이다 이렇게 된 것이 아버지의 뜻이니이다","reference":"마태복음 11:26","category":"$undefined"},{"id":"23487","book":"마태복음","book_name":"마태복음","chapter":11,"verse":27,"text":"내 아버지께서 모든 것을 내게 주셨으니 아버지 외에는 아들을 아는 자가 없고 아들과 또 아들의 소원대로 계시를 받는 자 외에는 아버지를 아는 자가 없느니라","reference":"마태복음 11:27","category":"$undefined"},{"id":"23488","book":"마태복음","book_name":"마태복음","chapter":11,"verse":28,"text":"수고하고 무거운 짐진 자들아 ! 다 내게로 오라 내가 너희를 쉬게 하리라","reference":"마태복음 11:28","category":"$undefined"},{"id":"23489","book":"마태복음","book_name":"마태복음","chapter":11,"verse":29,"text":"나는 마음이 온유하고 겸손하니 나의 멍에를 메고 내게 배우라 그러면 너희 마음이 쉼을 얻으리니","reference":"마태복음 11:29","category":"$undefined"},{"id":"23490","book":"마태복음","book_name":"마태복음","chapter":11,"verse":30,"text":"이는 내 멍에는 쉽고 내 짐은 가벼움이라 하시니라","reference":"마태복음 11:30","category":"$undefined"}],"bookSlug":"matthew"}]
