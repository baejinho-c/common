2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":12,"verses":[{"id":"23491","book":"마태복음","book_name":"마태복음","chapter":12,"verse":1,"text":"그 때에 예수께서 안식일에 밀밭 사이로 가실새 제자들이 시장하여 이삭을 잘라 먹으니","reference":"마태복음 12:1","category":"$undefined"},{"id":"23492","book":"마태복음","book_name":"마태복음","chapter":12,"verse":2,"text":"바리새인들이 보고 예수께 고하되 `보시오 당신의 제자들이 안식일에 하지 못할 일을 하나이다'","reference":"마태복음 12:2","category":"$undefined"},{"id":"23493","book":"마태복음","book_name":"마태복음","chapter":12,"verse":3,"text":"예수께서 가라사대 다윗이 자기와 그 함께 한 자들이 시장할 때에 한 일을 읽지 못하였느냐 ?","reference":"마태복음 12:3","category":"$undefined"},{"id":"23494","book":"마태복음","book_name":"마태복음","chapter":12,"verse":4,"text":"그가 하나님의 전에 들어가서 제사장 외에는 자기나 그 함께한 자들이 먹지 못하는 진설병을 먹지 아니하였느냐 ?","reference":"마태복음 12:4","category":"$undefined"},{"id":"23495","book":"마태복음","book_name":"마태복음","chapter":12,"verse":5,"text":"또 안식일에 제사장들이 성전 안에서 안식을 범하여도 죄가 없음을 너희가 율법에서 읽지 못하였느냐 ?","reference":"마태복음 12:5","category":"$undefined"},{"id":"23496","book":"마태복음","book_name":"마태복음","chapter":12,"verse":6,"text":"내가 너희에게 이르노니 성전보다 더 큰 이가 여기 있느니라 !","reference":"마태복음 12:6","category":"$undefined"},{"id":"23497","book":"마태복음","book_name":"마태복음","chapter":12,"verse":7,"text":"나는 자비를 원하고 제사를 원치 아니하노라 하신 뜻을 너희가 알았더면 무죄한 자를 죄로 정치 아니하였으리라","reference":"마태복음 12:7","category":"$undefined"},{"id":"23498","book":"마태복음","book_name":"마태복음","chapter":12,"verse":8,"text":"인자는 안식일의 주인이니라 ! 하시니라","reference":"마태복음 12:8","category":"$undefined"},{"id":"23499","book":"마태복음","book_name":"마태복음","chapter":12,"verse":9,"text":"거기를 떠나 저희 회당에 들어가시니","reference":"마태복음 12:9","category":"$undefined"},{"id":"23500","book":"마태복음","book_name":"마태복음","chapter":12,"verse":10,"text":"한편 손 마른 사람이 있는지라 사람들이 예수를 송사하려 하여 물어 가로되 `안식일에 병 고치는 것이 옳으니이까 ?'","reference":"마태복음 12:10","category":"$undefined"},{"id":"23501","book":"마태복음","book_name":"마태복음","chapter":12,"verse":11,"text":"예수께서 가라사대 너희 중에 어느 사람이 양 한 마리가 있어 안식일에 구덩이에 빠졌으면 붙잡아 내지 않겠느냐 ?","reference":"마태복음 12:11","category":"$undefined"},{"id":"23502","book":"마태복음","book_name":"마태복음","chapter":12,"verse":12,"text":"사람이 양보다 얼마나 더 귀하냐 그러므로 안식일에 선을 행하는 것이 옳으니라 하시고","reference":"마태복음 12:12","category":"$undefined"},{"id":"23503","book":"마태복음","book_name":"마태복음","chapter":12,"verse":13,"text":"이에 그 사람에게 이르시되 손을 내밀라 하시니 저가 내밀매 다른 손과 같이 회복되어 성하더라","reference":"마태복음 12:13","category":"$undefined"},{"id":"23504","book":"마태복음","book_name":"마태복음","chapter":12,"verse":14,"text":"바리새인들이 나가서 어떻게 하여 예수를 죽일꼬 의논하거늘","reference":"마태복음 12:14","category":"$undefined"},{"id":"23505","book":"마태복음","book_name":"마태복음","chapter":12,"verse":15,"text":"예수께서 아시고 거기를 떠나가시니 사람이 많이 좇는지라 예수께서 저희 병을 다 고치시고","reference":"마태복음 12:15","category":"$undefined"},{"id":"23506","book":"마태복음","book_name":"마태복음","chapter":12,"verse":16,"text":"자기를 나타내지 말라 경계하셨으니","reference":"마태복음 12:16","category":"$undefined"},{"id":"23507","book":"마태복음","book_name":"마태복음","chapter":12,"verse":17,"text":"이는 선지자 이사야로 말씀하신 바","reference":"마태복음 12:17","category":"$undefined"},{"id":"23508","book":"마태복음","book_name":"마태복음","chapter":12,"verse":18,"text":"보라 나의 택한 종 곧 내 마음에 기뻐하는 바 나의 사랑하는 자로다 내가 내 성령을 줄 터이니 그가 심판을 이방에 알게 하리라","reference":"마태복음 12:18","category":"$undefined"},{"id":"23509","book":"마태복음","book_name":"마태복음","chapter":12,"verse":19,"text":"그가 다투지도 아니하며 들레지도 아니하리니 아무도 길에서 그 소리를 듣지 못하리라","reference":"마태복음 12:19","category":"$undefined"},{"id":"23510","book":"마태복음","book_name":"마태복음","chapter":12,"verse":20,"text":"상한 갈대를 꺾지 아니하며 꺼져가는 심지를 끄지 아니하기를 심판하여 이길 때까지 하리니","reference":"마태복음 12:20","category":"$undefined"},{"id":"23511","book":"마태복음","book_name":"마태복음","chapter":12,"verse":21,"text":"또한 이방들이 그 이름을 바라리라 함을 이루려 하심이니라","reference":"마태복음 12:21","category":"$undefined"},{"id":"23512","book":"마태복음","book_name":"마태복음","chapter":12,"verse":22,"text":"그 때에 귀신들려 눈 멀고 벙어리 된 자를 데리고 왔거늘 예수께서 고쳐 주시매 그 벙어리가 말하며 보게 된지라","reference":"마태복음 12:22","category":"$undefined"},{"id":"23513","book":"마태복음","book_name":"마태복음","chapter":12,"verse":23,"text":"무리가 다 놀라 가로되 `이는 다윗의 자손이 아니냐' 하니","reference":"마태복음 12:23","category":"$undefined"},{"id":"23514","book":"마태복음","book_name":"마태복음","chapter":12,"verse":24,"text":"바리새인들은 듣고 가로되 `이가 귀신의 왕 바알세불을 힘입지 않고는 귀신을 쫓아 내지 못하느니라' 하거늘","reference":"마태복음 12:24","category":"$undefined"},{"id":"23515","book":"마태복음","book_name":"마태복음","chapter":12,"verse":25,"text":"예수께서 저희 생각을 아시고 가라사대 스스로 분쟁하는 나라마다 황폐하여질 것이요 스스로 분쟁하는 동네나 집마다 서지 못하리라","reference":"마태복음 12:25","category":"$undefined"},{"id":"23516","book":"마태복음","book_name":"마태복음","chapter":12,"verse":26,"text":"사단이 만일 사단을 쫓아 내면 스스로 분쟁하는 것이니 그리하고야 저의 나라가 어떻게 서겠느냐","reference":"마태복음 12:26","category":"$undefined"},{"id":"23517","book":"마태복음","book_name":"마태복음","chapter":12,"verse":27,"text":"또 내가 바알세불을 힘입어 귀신을 쫓아 내면 너희 아들들은 누구를 힘입어 쫓아 내느냐 그러므로 저희가 너희 재판관이 되리라","reference":"마태복음 12:27","category":"$undefined"},{"id":"23518","book":"마태복음","book_name":"마태복음","chapter":12,"verse":28,"text":"그러나 내가 하나님의 성령을 힘입어 귀신을 쫓아 내는 것이면 하나님의 나라가 이미 너희에게 임하였느니라","reference":"마태복음 12:28","category":"$undefined"},{"id":"23519","book":"마태복음","book_name":"마태복음","chapter":12,"verse":29,"text":"사람이 먼저 강한 자를 결박하지 않고야 어떻게 그 강한 자의 집에 들어가 그 세간을 늑탈하겠느냐 결박한 후에야 그 집을 늑탈하리라","reference":"마태복음 12:29","category":"$undefined"},{"id":"23520","book":"마태복음","book_name":"마태복음","chapter":12,"verse":30,"text":"나와 함께 아니하는 자는 나를 반대하는 자요 나와 함께 모으지 아니하는 자는 헤치는 자니라","reference":"마태복음 12:30","category":"$undefined"},{"id":"23521","book":"마태복음","book_name":"마태복음","chapter":12,"verse":31,"text":"그러므로 내가 너희에게 이르노니 사람의 모든 죄와 훼방은 사하심을 얻되 성령을 훼방하는 것은 사하심을 얻지 못하겠고","reference":"마태복음 12:31","category":"$undefined"},{"id":"23522","book":"마태복음","book_name":"마태복음","chapter":12,"verse":32,"text":"또 누구든지 말로 인자를 거역하면 사하심을 얻되 누구든지 말로 성령을 거역하면 이 세상과 오는 세상에도 사하심을 얻지 못하리라","reference":"마태복음 12:32","category":"$undefined"},{"id":"23523","book":"마태복음","book_name":"마태복음","chapter":12,"verse":33,"text":"나무도 좋고 실과도 좋다 하든지 나무도 좋지 않고 실과도 좋지 않다 하든지 하라 그 실과로 나무를 아느니라","reference":"마태복음 12:33","category":"$undefined"},{"id":"23524","book":"마태복음","book_name":"마태복음","chapter":12,"verse":34,"text":"독사의 자식들아 ! 너희는 악하니 어떻게 선한 말을 할 수 있느냐 ? 이는 마음에 가득한 것을 입으로 말함이라","reference":"마태복음 12:34","category":"$undefined"},{"id":"23525","book":"마태복음","book_name":"마태복음","chapter":12,"verse":35,"text":"선한 사람은 그 쌓은 선에서 선한 것을 내고 악한 사람은 그 쌓은 악에서 악한 것을 내느니라","reference":"마태복음 12:35","category":"$undefined"},{"id":"23526","book":"마태복음","book_name":"마태복음","chapter":12,"verse":36,"text":"내가 너희에게 이르노니 사람이 무슨 무익한 말을 하든지 심판 날에 이에 대하여 심문을 받으리니","reference":"마태복음 12:36","category":"$undefined"},{"id":"23527","book":"마태복음","book_name":"마태복음","chapter":12,"verse":37,"text":"네 말로 의롭다함을 받고 네 말로 정죄함을 받으리라","reference":"마태복음 12:37","category":"$undefined"},{"id":"23528","book":"마태복음","book_name":"마태복음","chapter":12,"verse":38,"text":"그 때에 서기관과 바리새인 중 몇 사람이 말하되 `선생님이여 우리에게 표적보여 주시기를 원하나이다'","reference":"마태복음 12:38","category":"$undefined"},{"id":"23529","book":"마태복음","book_name":"마태복음","chapter":12,"verse":39,"text":"예수께서 대답하여 가라사대 악하고 음란한 세대가 표적을 구하나 선지자 요나의 표적 밖에는 보일 표적이 없느니라","reference":"마태복음 12:39","category":"$undefined"},{"id":"23530","book":"마태복음","book_name":"마태복음","chapter":12,"verse":40,"text":"요나가 밤낮 사흘을 큰 물고기 뱃속에 있었던 것같이 인자도 밤낮 사흘을 땅 속에 있으리라","reference":"마태복음 12:40","category":"$undefined"},{"id":"23531","book":"마태복음","book_name":"마태복음","chapter":12,"verse":41,"text":"심판 때에 니느웨 사람들이 일어나 이 세대 사람을 정죄하리니 이는 그들이 요나의 전도를 듣고 회개하였음이어니와 요나보다 더 큰 이가 여기 있으며","reference":"마태복음 12:41","category":"$undefined"},{"id":"23532","book":"마태복음","book_name":"마태복음","chapter":12,"verse":42,"text":"심판 때에 남방 여왕이 일어나 이 세대 사람을 정죄하리니 이는 그가 솔로몬의 지혜로운 말을 들으려고 땅 끝에서 왔음이어니와 솔로몬보다 더 큰 이가 여기 있느니라","reference":"마태복음 12:42","category":"$undefined"},{"id":"23533","book":"마태복음","book_name":"마태복음","chapter":12,"verse":43,"text":"더러운 귀신이 사람에게서 나갔을 때에 물 없는 곳으로 다니며 쉬기를 구하되 얻지 못하고","reference":"마태복음 12:43","category":"$undefined"},{"id":"23534","book":"마태복음","book_name":"마태복음","chapter":12,"verse":44,"text":"이에 가로되 내가 나온 집으로 돌아가리라 하고 와 보니 그 집이 비고 소제되고 수리 되었거늘","reference":"마태복음 12:44","category":"$undefined"},{"id":"23535","book":"마태복음","book_name":"마태복음","chapter":12,"verse":45,"text":"이에 가서 저보다 더 악한 귀신 일곱을 데리고 들어가서 거하니 그 사람의 나중 형편이 전보다 더욱 심하게 되느니라 이 악한 세대가 또한 이렇게 되리라","reference":"마태복음 12:45","category":"$undefined"},{"id":"23536","book":"마태복음","book_name":"마태복음","chapter":12,"verse":46,"text":"예수께서 무리에게 말씀 하실 때에 그 모친과 동생들이 예수께 말하려고 밖에 섰더니","reference":"마태복음 12:46","category":"$undefined"},{"id":"23537","book":"마태복음","book_name":"마태복음","chapter":12,"verse":47,"text":"한사람이 예수께 여짜오되 `보소서 당신의 모친과 동생들이 당신께 말하려고 밖에 섰나이다' 하니","reference":"마태복음 12:47","category":"$undefined"},{"id":"23538","book":"마태복음","book_name":"마태복음","chapter":12,"verse":48,"text":"말하던 사람에게 대답하여 가라사대 누가 내 모친이며 내 동생들이냐 ? 하시고","reference":"마태복음 12:48","category":"$undefined"},{"id":"23539","book":"마태복음","book_name":"마태복음","chapter":12,"verse":49,"text":"손을 내밀어 제자들을 가리켜 가라사대 나의 모친과 나의 동생들을 보라","reference":"마태복음 12:49","category":"$undefined"},{"id":"23540","book":"마태복음","book_name":"마태복음","chapter":12,"verse":50,"text":"누구든지 하늘에 계신 내 아버지의 뜻대로 하는 자가 내 형제요 자매요 모친이니라 하시더라","reference":"마태복음 12:50","category":"$undefined"}],"bookSlug":"matthew"}]
