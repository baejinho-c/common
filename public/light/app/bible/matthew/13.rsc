2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":13,"verses":[{"id":"23541","book":"마태복음","book_name":"마태복음","chapter":13,"verse":1,"text":"그 날에 예수께서 집에서 나가사 바닷가에 앉으시매","reference":"마태복음 13:1","category":"$undefined"},{"id":"23542","book":"마태복음","book_name":"마태복음","chapter":13,"verse":2,"text":"큰 무리가 그에게로 모여 들거늘 예수께서 배에 올라가 앉으시고 온 무리는 해변에 섰더니","reference":"마태복음 13:2","category":"$undefined"},{"id":"23543","book":"마태복음","book_name":"마태복음","chapter":13,"verse":3,"text":"예수께서 비유로 여러가지를 저희에게 말씀하여 가라사대 씨를 뿌리는 자가 뿌리러 나가서","reference":"마태복음 13:3","category":"$undefined"},{"id":"23544","book":"마태복음","book_name":"마태복음","chapter":13,"verse":4,"text":"뿌릴새 더러는 길 가에 떨어지매 새들이 와서 먹어버렸고","reference":"마태복음 13:4","category":"$undefined"},{"id":"23545","book":"마태복음","book_name":"마태복음","chapter":13,"verse":5,"text":"더러는 흙이 얇은 돌밭에 떨어지매 흙이 깊지 아니하므로 곧 싹이 나오나","reference":"마태복음 13:5","category":"$undefined"},{"id":"23546","book":"마태복음","book_name":"마태복음","chapter":13,"verse":6,"text":"해가 돋은 후에 타져서 뿌리가 없으므로 말랐고","reference":"마태복음 13:6","category":"$undefined"},{"id":"23547","book":"마태복음","book_name":"마태복음","chapter":13,"verse":7,"text":"더러는 가시떨기 위에 떨어지매 가시가 자라서 기운을 막았고","reference":"마태복음 13:7","category":"$undefined"},{"id":"23548","book":"마태복음","book_name":"마태복음","chapter":13,"verse":8,"text":"더러는 좋은 땅에 떨어지매 혹 백 배, 혹 육십 배, 혹 삼십 배의 결실을 하였느니라","reference":"마태복음 13:8","category":"$undefined"},{"id":"23549","book":"마태복음","book_name":"마태복음","chapter":13,"verse":9,"text":"귀 있는 자는 들으라 하시니라","reference":"마태복음 13:9","category":"$undefined"},{"id":"23550","book":"마태복음","book_name":"마태복음","chapter":13,"verse":10,"text":"제자들이 예수께 나아와 가로되 `어찌하여 저희에게 비유로 말씀하시나이까 ?'","reference":"마태복음 13:10","category":"$undefined"},{"id":"23551","book":"마태복음","book_name":"마태복음","chapter":13,"verse":11,"text":"대답하여 가라사대 천국의 비밀을 아는 것이 너희에게는 허락되었으나 저희에게는 아니 되었나니","reference":"마태복음 13:11","category":"$undefined"},{"id":"23552","book":"마태복음","book_name":"마태복음","chapter":13,"verse":12,"text":"무릇 있는 자는 받아 넉넉하게 되되 무릇 없는 자는 그 있는 것도 빼앗기리라","reference":"마태복음 13:12","category":"$undefined"},{"id":"23553","book":"마태복음","book_name":"마태복음","chapter":13,"verse":13,"text":"그러므로 내가 저희에게 비유로 말하기는 저희가 보아도 보지 못하며 들어도 듣지 못하며 깨닫지 못함이니라","reference":"마태복음 13:13","category":"$undefined"},{"id":"23554","book":"마태복음","book_name":"마태복음","chapter":13,"verse":14,"text":"이사야의 예언이 저희에게 이루었으니 일렀으되 너희가 듣기는 들어도 깨닫지 못할 것이요 보기는 보아도 알지 못하리라","reference":"마태복음 13:14","category":"$undefined"},{"id":"23555","book":"마태복음","book_name":"마태복음","chapter":13,"verse":15,"text":"이 백성들의 마음이 완악하여져서 그 귀는 듣기에 둔하고 눈은 감았으니 이는 눈으로 보고 귀로 듣고 마음으로 깨달아 돌이켜 내게 고침을 받을까 두려워 함이라 하였느니라","reference":"마태복음 13:15","category":"$undefined"},{"id":"23556","book":"마태복음","book_name":"마태복음","chapter":13,"verse":16,"text":"그러나 너희 눈은 봄으로 너희 귀는 들음으로 복이 있도다","reference":"마태복음 13:16","category":"$undefined"},{"id":"23557","book":"마태복음","book_name":"마태복음","chapter":13,"verse":17,"text":"내가 진실로 너희에게 이르노니 많은 선지자와 의인이 너희 보는 것들을 보고자 하여도 보지 못하였고 너희 듣는 것들을 듣고자 하여도 듣지 못하였느니라","reference":"마태복음 13:17","category":"$undefined"},{"id":"23558","book":"마태복음","book_name":"마태복음","chapter":13,"verse":18,"text":"그런즉 씨 뿌리는 비유를 들으라","reference":"마태복음 13:18","category":"$undefined"},{"id":"23559","book":"마태복음","book_name":"마태복음","chapter":13,"verse":19,"text":"아무나 천국 말씀을 듣고 깨닫지 못할 때는 악한 자가 와서 그 마음에 뿌리는 것을 빼앗나니 이는 곧 길가에 뿌리운 자요","reference":"마태복음 13:19","category":"$undefined"},{"id":"23560","book":"마태복음","book_name":"마태복음","chapter":13,"verse":20,"text":"돌밭에 뿌리웠다는 것은 말씀을 듣고 즉시 기쁨으로 받되","reference":"마태복음 13:20","category":"$undefined"},{"id":"23561","book":"마태복음","book_name":"마태복음","chapter":13,"verse":21,"text":"그 속에 뿌리가 없어 잠시 견디다가 말씀을 인하여 환난이나 핍박이 일어나는 때에는 곧 넘어지는 자요","reference":"마태복음 13:21","category":"$undefined"},{"id":"23562","book":"마태복음","book_name":"마태복음","chapter":13,"verse":22,"text":"가시떨기에 뿌리웠다는 것은 말씀을 들으나 세상의 염려와 재리의 유혹에 말씀이 막혀 결실치 못하는 자요","reference":"마태복음 13:22","category":"$undefined"},{"id":"23563","book":"마태복음","book_name":"마태복음","chapter":13,"verse":23,"text":"좋은 땅에 뿌리웠다는 것은 말씀을 듣고 깨닫는 자니 결실하여 혹 백 배, 혹 육십 배, 혹 삼십 배가 되느니라 하시더라","reference":"마태복음 13:23","category":"$undefined"},{"id":"23564","book":"마태복음","book_name":"마태복음","chapter":13,"verse":24,"text":"예수께서 그들 앞에 또 비유를 베풀어 가라사대 천국은 좋은 씨를 제 밭에 뿌린 사람과 같으니","reference":"마태복음 13:24","category":"$undefined"},{"id":"23565","book":"마태복음","book_name":"마태복음","chapter":13,"verse":25,"text":"사람들이 잘 때에 그 원수가 와서 곡식 가운데 가라지를 덧뿌리고 갔더니","reference":"마태복음 13:25","category":"$undefined"},{"id":"23566","book":"마태복음","book_name":"마태복음","chapter":13,"verse":26,"text":"싹이 나고 결실할 때에 가라지도 보이거늘","reference":"마태복음 13:26","category":"$undefined"},{"id":"23567","book":"마태복음","book_name":"마태복음","chapter":13,"verse":27,"text":"집 주인의 종들이 와서 말하되 주여 밭에 좋은 씨를 심지 아니하였나이까 그러면 가라지가 어디서 생겼나이까","reference":"마태복음 13:27","category":"$undefined"},{"id":"23568","book":"마태복음","book_name":"마태복음","chapter":13,"verse":28,"text":"주인이 가로되 원수가 이렇게 하였구나 종들이 말하되 그러면 우리가 가서 이것을 뽑기를 원하시나이까","reference":"마태복음 13:28","category":"$undefined"},{"id":"23569","book":"마태복음","book_name":"마태복음","chapter":13,"verse":29,"text":"주인이 가로되 가만 두어라 가라지를 뽑다가 곡식까지 뽑을까 염려 하노라","reference":"마태복음 13:29","category":"$undefined"},{"id":"23570","book":"마태복음","book_name":"마태복음","chapter":13,"verse":30,"text":"둘 다 추수 때까지 함께 자라게 두어라 추수 때에 내가 추숫군들에게 말하기를 가라지는 먼저 거두어 불사르게 단으로 묶고 곡식은 모아 내 곳간에 넣으라 하리라","reference":"마태복음 13:30","category":"$undefined"},{"id":"23571","book":"마태복음","book_name":"마태복음","chapter":13,"verse":31,"text":"또 비유를 베풀어 가라사대 천국은 마치 사람이 자기 밭에 갖다 심은 겨자씨 한 알 같으니","reference":"마태복음 13:31","category":"$undefined"},{"id":"23572","book":"마태복음","book_name":"마태복음","chapter":13,"verse":32,"text":"이는 모든 씨보다 작은 것이로되 자란 후에는 나물보다 커서 나무가 되매 공중의 새들이 와서 그 가지에 깃들이느니라","reference":"마태복음 13:32","category":"$undefined"},{"id":"23573","book":"마태복음","book_name":"마태복음","chapter":13,"verse":33,"text":"또 비유로 말씀하시되 천국은 마치 여자가 가루 서 말 속에 갖다 넣어 전부 부풀게 한 누룩과 같으니라","reference":"마태복음 13:33","category":"$undefined"},{"id":"23574","book":"마태복음","book_name":"마태복음","chapter":13,"verse":34,"text":"예수께서 이 모든 것을 무리에게 비유로 말씀하시고 비유가 아니면 아무 것도 말씀하지 아니하셨으니","reference":"마태복음 13:34","category":"$undefined"},{"id":"23575","book":"마태복음","book_name":"마태복음","chapter":13,"verse":35,"text":"이는 선지자로 말씀하신 바 내가 입을 열어 비유로 말하고 창세부터 감추인 것들을 드러내리라 함을 이루려 하심이니라","reference":"마태복음 13:35","category":"$undefined"},{"id":"23576","book":"마태복음","book_name":"마태복음","chapter":13,"verse":36,"text":"이에 예수께서 무리를 떠나사 집에 들어가시니 제자들이 나아와 가로되 `밭의 가라지의 비유를 우리에게 설명하여 주소서'","reference":"마태복음 13:36","category":"$undefined"},{"id":"23577","book":"마태복음","book_name":"마태복음","chapter":13,"verse":37,"text":"대답하여 가라사대 좋은 씨를 뿌리는 이는 인자요","reference":"마태복음 13:37","category":"$undefined"},{"id":"23578","book":"마태복음","book_name":"마태복음","chapter":13,"verse":38,"text":"밭은 세상이요 좋은 씨는 천국의 아들들이요 가라지는 악한 자의 아들들이요","reference":"마태복음 13:38","category":"$undefined"},{"id":"23579","book":"마태복음","book_name":"마태복음","chapter":13,"verse":39,"text":"가라지를 심은 원수는 마귀요 추수 때는 세상 끝이요 추숫군은 천사들이니","reference":"마태복음 13:39","category":"$undefined"},{"id":"23580","book":"마태복음","book_name":"마태복음","chapter":13,"verse":40,"text":"그런즉 가라지를 거두어 불에 사르는 것같이 세상 끝에도 그러하리라","reference":"마태복음 13:40","category":"$undefined"},{"id":"23581","book":"마태복음","book_name":"마태복음","chapter":13,"verse":41,"text":"인자가 그 천사들을 보내리니 저희가 그 나라에서 모든 넘어지게 하는 것과 또 불법을 행하는 자들을 거두어 내어","reference":"마태복음 13:41","category":"$undefined"},{"id":"23582","book":"마태복음","book_name":"마태복음","chapter":13,"verse":42,"text":"풀무불에 던져 넣으리니 거기서 울며 이를 갊이 있으리라","reference":"마태복음 13:42","category":"$undefined"},{"id":"23583","book":"마태복음","book_name":"마태복음","chapter":13,"verse":43,"text":"그 때에 의인들은 자기 아버지 나라에서 해와 같이 빛나리라 귀 있는 자는 들으라","reference":"마태복음 13:43","category":"$undefined"},{"id":"23584","book":"마태복음","book_name":"마태복음","chapter":13,"verse":44,"text":"천국은 마치 밭에 감추인 보화와 같으니 사람이 이를 발견한 후 숨겨두고 기뻐하여 돌아가서 자기의 소유를 다 팔아 그 밭을 샀느니라","reference":"마태복음 13:44","category":"$undefined"},{"id":"23585","book":"마태복음","book_name":"마태복음","chapter":13,"verse":45,"text":"또 천국은 마치 좋은 진주를 구하는 장사와 같으니","reference":"마태복음 13:45","category":"$undefined"},{"id":"23586","book":"마태복음","book_name":"마태복음","chapter":13,"verse":46,"text":"극히 값진 진주 하나를 만나매 가서 자기의 소유를 다 팔아 그 진주를 샀느니라","reference":"마태복음 13:46","category":"$undefined"},{"id":"23587","book":"마태복음","book_name":"마태복음","chapter":13,"verse":47,"text":"또 천국은 마치 바다에 치고 각종 물고기를 모는 그물과 같으니","reference":"마태복음 13:47","category":"$undefined"},{"id":"23588","book":"마태복음","book_name":"마태복음","chapter":13,"verse":48,"text":"그물에 가득하매 물 가로 끌어 내고 앉아서 좋은 것은 그릇에 담고 못된 것은 내어 버리느니라","reference":"마태복음 13:48","category":"$undefined"},{"id":"23589","book":"마태복음","book_name":"마태복음","chapter":13,"verse":49,"text":"세상 끝에도 이러하리라 천사들이 와서 의인 중에서 악인을 갈라내어","reference":"마태복음 13:49","category":"$undefined"},{"id":"23590","book":"마태복음","book_name":"마태복음","chapter":13,"verse":50,"text":"풀무불에 던져 넣으리니 거기서 울며 이를 갊이 있으리라","reference":"마태복음 13:50","category":"$undefined"},{"id":"23591","book":"마태복음","book_name":"마태복음","chapter":13,"verse":51,"text":"이 모든 것을 깨달았느냐 ? 하시니 대답하되 `그러하오이다'","reference":"마태복음 13:51","category":"$undefined"},{"id":"23592","book":"마태복음","book_name":"마태복음","chapter":13,"verse":52,"text":"예수께서 가라사대 그러므로 천국의 제자된 서기관마다 마치 새 것과 옛 것을 그 곳간에서 내어 오는 집 주인과 같으니라","reference":"마태복음 13:52","category":"$undefined"},{"id":"23593","book":"마태복음","book_name":"마태복음","chapter":13,"verse":53,"text":"예수께서 이 모든 비유를 마치신 후에 거기를 떠나서","reference":"마태복음 13:53","category":"$undefined"},{"id":"23594","book":"마태복음","book_name":"마태복음","chapter":13,"verse":54,"text":"고향으로 돌아가사 저희 회당에서 가르치시니 저희가 놀라 가로되 `이 사람의 이 지혜와 이런 능력이 어디서 났느뇨 ?","reference":"마태복음 13:54","category":"$undefined"},{"id":"23595","book":"마태복음","book_name":"마태복음","chapter":13,"verse":55,"text":"이는 그 목수의 아들이 아니냐 그 모친은 마리아, 그 형제들은 야고보, 요셉, 시몬, 유다라 하지 않느냐 ?","reference":"마태복음 13:55","category":"$undefined"},{"id":"23596","book":"마태복음","book_name":"마태복음","chapter":13,"verse":56,"text":"그 누이들은 다 우리와 함께 있지 아니하냐 ? 그런즉 이 사람의 이 모든 것이 어디서 났느뇨' 하고","reference":"마태복음 13:56","category":"$undefined"},{"id":"23597","book":"마태복음","book_name":"마태복음","chapter":13,"verse":57,"text":"예수를 배척한지라 예수께서 저희에게 말씀하시되 선지자가 자기 고향과 자기 집 외에서는 존경을 받지 않음이 없느니라 하시고","reference":"마태복음 13:57","category":"$undefined"},{"id":"23598","book":"마태복음","book_name":"마태복음","chapter":13,"verse":58,"text":"저희의 믿지 않음을 인하여 거기서 많은 능력을 행치 아니하시니라","reference":"마태복음 13:58","category":"$undefined"}],"bookSlug":"matthew"}]
