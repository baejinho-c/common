2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":14,"verses":[{"id":"23599","book":"마태복음","book_name":"마태복음","chapter":14,"verse":1,"text":"그 때에 분봉왕 헤롯이 예수의 소문을 듣고","reference":"마태복음 14:1","category":"$undefined"},{"id":"23600","book":"마태복음","book_name":"마태복음","chapter":14,"verse":2,"text":"그 신하들에게 이르되 `이는 세례 요한이라 저가 죽은 자 가운데서 살아 났으니 그러므로 이런 권능이 그 속에서 운동하는도다' 하더라","reference":"마태복음 14:2","category":"$undefined"},{"id":"23601","book":"마태복음","book_name":"마태복음","chapter":14,"verse":3,"text":"전에 헤롯이 그 동생 빌립의 아내 헤로디아의 일로 요한을 잡아 결박하여 옥에 가두었으니","reference":"마태복음 14:3","category":"$undefined"},{"id":"23602","book":"마태복음","book_name":"마태복음","chapter":14,"verse":4,"text":"이는 요한이 헤롯에게 말하되 `당신이 그 여자를 취한 것이 옳지 않다' 하였음이라","reference":"마태복음 14:4","category":"$undefined"},{"id":"23603","book":"마태복음","book_name":"마태복음","chapter":14,"verse":5,"text":"헤롯이 요한을 죽이려 하되 민중이 저를 선지자로 여기므로 민중을 두려워하더니","reference":"마태복음 14:5","category":"$undefined"},{"id":"23604","book":"마태복음","book_name":"마태복음","chapter":14,"verse":6,"text":"마침 헤롯의 생일을 당하여 헤로디아의 딸이 연석 가운데서 춤을 추어 헤롯을 기쁘게 하니","reference":"마태복음 14:6","category":"$undefined"},{"id":"23605","book":"마태복음","book_name":"마태복음","chapter":14,"verse":7,"text":"헤롯이 맹세로 `그에게 무엇이든지 달라는대로 주겠다' 허락하거늘","reference":"마태복음 14:7","category":"$undefined"},{"id":"23606","book":"마태복음","book_name":"마태복음","chapter":14,"verse":8,"text":"그가 제 어미의 시킴을 듣고 가로되 `세례 요한의 머리를 소반에 담아 여기서 내게 주소서' 하니","reference":"마태복음 14:8","category":"$undefined"},{"id":"23607","book":"마태복음","book_name":"마태복음","chapter":14,"verse":9,"text":"왕이 근심하나 자기의 맹세한 것과 그 함께 앉은 사람들을 인하여 주라 명하고","reference":"마태복음 14:9","category":"$undefined"},{"id":"23608","book":"마태복음","book_name":"마태복음","chapter":14,"verse":10,"text":"사람을 보내어 요한을 옥에서 목 베어","reference":"마태복음 14:10","category":"$undefined"},{"id":"23609","book":"마태복음","book_name":"마태복음","chapter":14,"verse":11,"text":"그 머리를 소반에 담아다가 그 여아에게 주니 그가 제 어미에게 가져 가니라","reference":"마태복음 14:11","category":"$undefined"},{"id":"23610","book":"마태복음","book_name":"마태복음","chapter":14,"verse":12,"text":"요한의 제자들이 와서 시체를 가져다가 장사하고 가서 예수께 고하니라","reference":"마태복음 14:12","category":"$undefined"},{"id":"23611","book":"마태복음","book_name":"마태복음","chapter":14,"verse":13,"text":"예수께서 들으시고 배를 타고 떠나사 따로 빈 들에 가시니 무리가 듣고 여러 고을로부터 걸어서 좇아간지라","reference":"마태복음 14:13","category":"$undefined"},{"id":"23612","book":"마태복음","book_name":"마태복음","chapter":14,"verse":14,"text":"예수께서 나오사 큰 무리를 보시고 불쌍히 여기사 그 중에 있는 병인을 고쳐 주시니라","reference":"마태복음 14:14","category":"$undefined"},{"id":"23613","book":"마태복음","book_name":"마태복음","chapter":14,"verse":15,"text":"저녁이 되매 제자들이 나아와 가로되 `이곳은 빈 들이요 때도 이미 저물었으니 무리를 보내어 마을에 들어가 먹을 것을 사먹게 하소서'","reference":"마태복음 14:15","category":"$undefined"},{"id":"23614","book":"마태복음","book_name":"마태복음","chapter":14,"verse":16,"text":"예수께서 가라사대 갈 것 없다 너희가 먹을 것을 주라","reference":"마태복음 14:16","category":"$undefined"},{"id":"23615","book":"마태복음","book_name":"마태복음","chapter":14,"verse":17,"text":"제자들이 가로되 `여기 우리에게 있는 것은 떡 다섯 개와 물고기 두 마리 뿐이니이다'","reference":"마태복음 14:17","category":"$undefined"},{"id":"23616","book":"마태복음","book_name":"마태복음","chapter":14,"verse":18,"text":"가라사대 그것을 내게 가져오라 하시고","reference":"마태복음 14:18","category":"$undefined"},{"id":"23617","book":"마태복음","book_name":"마태복음","chapter":14,"verse":19,"text":"무리를 명하여 잔디 위에 앉히시고 떡 다섯개와 물고기 두 마리를 가지사 하늘을 우러러 축사하시고 떡을 떼어 제자들에게 주시매 제자들이 무리에게 주니","reference":"마태복음 14:19","category":"$undefined"},{"id":"23618","book":"마태복음","book_name":"마태복음","chapter":14,"verse":20,"text":"다 배불리 먹고 남은 조각을 열 두 바구니에 차게 거두었으며","reference":"마태복음 14:20","category":"$undefined"},{"id":"23619","book":"마태복음","book_name":"마태복음","chapter":14,"verse":21,"text":"먹은 사람은 여자와 아이 외에 오천 명이나 되었더라","reference":"마태복음 14:21","category":"$undefined"},{"id":"23620","book":"마태복음","book_name":"마태복음","chapter":14,"verse":22,"text":"예수께서 즉시 제자들을 재촉하사 자기가 무리를 보내는 동안에 배를 타고 앞서 건너편으로 가게 하시고","reference":"마태복음 14:22","category":"$undefined"},{"id":"23621","book":"마태복음","book_name":"마태복음","chapter":14,"verse":23,"text":"무리를 보내신 후에 기도하러 따로 산에 올라가시다 저물매 거기 혼자 계시더니","reference":"마태복음 14:23","category":"$undefined"},{"id":"23622","book":"마태복음","book_name":"마태복음","chapter":14,"verse":24,"text":"배가 이미 육지에서 수 리나 떠나서 바람이 거슬리므로 물결을 인하여 고난을 당하더라","reference":"마태복음 14:24","category":"$undefined"},{"id":"23623","book":"마태복음","book_name":"마태복음","chapter":14,"verse":25,"text":"밤 사경에 예수께서 바다 위로 걸어서 제자들에게 오시니","reference":"마태복음 14:25","category":"$undefined"},{"id":"23624","book":"마태복음","book_name":"마태복음","chapter":14,"verse":26,"text":"제자들이 그 바다 위로 걸어 오심을 보고 놀라 유령이라 하며 무서워하여 소리지르거늘","reference":"마태복음 14:26","category":"$undefined"},{"id":"23625","book":"마태복음","book_name":"마태복음","chapter":14,"verse":27,"text":"예수께서 즉시 일러 가라사대 안심하라 내니 두려워 말라 !","reference":"마태복음 14:27","category":"$undefined"},{"id":"23626","book":"마태복음","book_name":"마태복음","chapter":14,"verse":28,"text":"베드로가 대답하여 가로되 `주여 만일 주시어든 나를 명하사 물 위로 오라 하소서' 한대","reference":"마태복음 14:28","category":"$undefined"},{"id":"23627","book":"마태복음","book_name":"마태복음","chapter":14,"verse":29,"text":"오라 ! 하시니 베드로가 배에서 내려 물 위로 걸어서 예수께로 가되","reference":"마태복음 14:29","category":"$undefined"},{"id":"23628","book":"마태복음","book_name":"마태복음","chapter":14,"verse":30,"text":"바람을 보고 무서워 빠져 가는지라 소리질러 가로되 `주여 나를 구원하소서' 하니","reference":"마태복음 14:30","category":"$undefined"},{"id":"23629","book":"마태복음","book_name":"마태복음","chapter":14,"verse":31,"text":"예수께서 즉시 손을 내밀어 저를 붙잡으시며 가라사대 믿음이 적은 자여 ! 왜 의심하였느냐 ? 하시고","reference":"마태복음 14:31","category":"$undefined"},{"id":"23630","book":"마태복음","book_name":"마태복음","chapter":14,"verse":32,"text":"배에 함께 오르매 바람이 그치는지라","reference":"마태복음 14:32","category":"$undefined"},{"id":"23631","book":"마태복음","book_name":"마태복음","chapter":14,"verse":33,"text":"배에 있는 사람들이 예수께 절하며 가로되 `진실로 하나님의 아들이로소이다' 하더라","reference":"마태복음 14:33","category":"$undefined"},{"id":"23632","book":"마태복음","book_name":"마태복음","chapter":14,"verse":34,"text":"저희가 건너가 게네사렛 땅에 이르니","reference":"마태복음 14:34","category":"$undefined"},{"id":"23633","book":"마태복음","book_name":"마태복음","chapter":14,"verse":35,"text":"그 곳 사람들이 예수신 줄을 알고 그 근방에 두루 통지하여 모든 병든 자를 예수께 데리고 와서","reference":"마태복음 14:35","category":"$undefined"},{"id":"23634","book":"마태복음","book_name":"마태복음","chapter":14,"verse":36,"text":"다만 예수의 옷가에라도 손을 대게 하시기를 간구하니 손을 대는 자는 다 나음을 얻으니라","reference":"마태복음 14:36","category":"$undefined"}],"bookSlug":"matthew"}]
