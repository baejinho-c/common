2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":15,"verses":[{"id":"23635","book":"마태복음","book_name":"마태복음","chapter":15,"verse":1,"text":"그 때에 바리새인과 서기관들이 예루살렘으로부터 예수께 나아와 가로되","reference":"마태복음 15:1","category":"$undefined"},{"id":"23636","book":"마태복음","book_name":"마태복음","chapter":15,"verse":2,"text":"`당신의 제자들이 어찌하여 장로들의 유전을 범하나이까 떡 먹을 때에 손을 씻지 아니하나이다'","reference":"마태복음 15:2","category":"$undefined"},{"id":"23637","book":"마태복음","book_name":"마태복음","chapter":15,"verse":3,"text":"대답하여 가라사대 너희는 어찌하여 너희 유전으로 하나님의 계명을 범하느뇨","reference":"마태복음 15:3","category":"$undefined"},{"id":"23638","book":"마태복음","book_name":"마태복음","chapter":15,"verse":4,"text":"하나님이 이르셨으되 네 부모를 공경하라 하시고 또 아비나 어미를 훼방하는 자는 반드시 죽으리라 하셨거늘","reference":"마태복음 15:4","category":"$undefined"},{"id":"23639","book":"마태복음","book_name":"마태복음","chapter":15,"verse":5,"text":"너희는 가로되 누구든지 아비에게나 어미에게 말하기를 내가 드려 유익하게 할 것이 하나님께 드림이 되었다고 하기만 하면","reference":"마태복음 15:5","category":"$undefined"},{"id":"23640","book":"마태복음","book_name":"마태복음","chapter":15,"verse":6,"text":"그 부모를 공경할 것이 없다 하여 너희 유전으로 하나님의 말씀을 폐하는도다","reference":"마태복음 15:6","category":"$undefined"},{"id":"23641","book":"마태복음","book_name":"마태복음","chapter":15,"verse":7,"text":"외식하는 자들아 이사야가 너희에게 대하여 잘 예언하였도다 일렀으되","reference":"마태복음 15:7","category":"$undefined"},{"id":"23642","book":"마태복음","book_name":"마태복음","chapter":15,"verse":8,"text":"이 백성이 입술로는 나를 존경하되 마음은 내게서 멀도다","reference":"마태복음 15:8","category":"$undefined"},{"id":"23643","book":"마태복음","book_name":"마태복음","chapter":15,"verse":9,"text":"사람의 계명으로 교훈을 삼아 가르치니 나를 헛되이 경배하는도다 하였느니라 하시고","reference":"마태복음 15:9","category":"$undefined"},{"id":"23644","book":"마태복음","book_name":"마태복음","chapter":15,"verse":10,"text":"무리를 불러 이르시되 듣고 깨달으라","reference":"마태복음 15:10","category":"$undefined"},{"id":"23645","book":"마태복음","book_name":"마태복음","chapter":15,"verse":11,"text":"입에 들어가는 것이 사람을 더럽게 하는 것이 아니라 입에서 나오는 그것이 사람을 더럽게 하는 것이니라","reference":"마태복음 15:11","category":"$undefined"},{"id":"23646","book":"마태복음","book_name":"마태복음","chapter":15,"verse":12,"text":"이에 제자들이 나아와 가로되 `바리새인들이 이 말씀을 듣고 걸림이 된 줄 아시나이까'","reference":"마태복음 15:12","category":"$undefined"},{"id":"23647","book":"마태복음","book_name":"마태복음","chapter":15,"verse":13,"text":"예수께서 대답하여 가라사대 심은 것마다 내 천부께서 심으시지 않은 것은 뽑힐 것이니","reference":"마태복음 15:13","category":"$undefined"},{"id":"23648","book":"마태복음","book_name":"마태복음","chapter":15,"verse":14,"text":"그냥 두어라 저희는 소경이 소경을 인도하는 자로다 만일 소경이 되어 소경을 인도하면 둘이 다 구덩이에 빠지리라 하신대","reference":"마태복음 15:14","category":"$undefined"},{"id":"23649","book":"마태복음","book_name":"마태복음","chapter":15,"verse":15,"text":"베드로가 대답하여 가로되 `이 비유를 우리에게 설명하여 주옵소서'","reference":"마태복음 15:15","category":"$undefined"},{"id":"23650","book":"마태복음","book_name":"마태복음","chapter":15,"verse":16,"text":"예수께서 가라사대 너희도 아직까지 깨달음이 없느냐 ?","reference":"마태복음 15:16","category":"$undefined"},{"id":"23651","book":"마태복음","book_name":"마태복음","chapter":15,"verse":17,"text":"입으로 들어가는 모든 것은 배로 들어가서 뒤로 내어버려지는 줄을 알지 못하느냐","reference":"마태복음 15:17","category":"$undefined"},{"id":"23652","book":"마태복음","book_name":"마태복음","chapter":15,"verse":18,"text":"입에서 나오는 것들은 마음에서 나오나니 이것이야말로 사람을 더럽게 하느니라","reference":"마태복음 15:18","category":"$undefined"},{"id":"23653","book":"마태복음","book_name":"마태복음","chapter":15,"verse":19,"text":"마음에서 나오는 것은 악한 생각과, 살인과, 간음과, 음란과, 도적질과, 거짓 증거와, 훼방이니","reference":"마태복음 15:19","category":"$undefined"},{"id":"23654","book":"마태복음","book_name":"마태복음","chapter":15,"verse":20,"text":"이런 것들이 사람을 더럽게 하는 것이요 씻지 않은 손으로 먹는 것은 사람을 더럽게 하지 못하느니라","reference":"마태복음 15:20","category":"$undefined"},{"id":"23655","book":"마태복음","book_name":"마태복음","chapter":15,"verse":21,"text":"예수께서 거기서 나가사 두로와 시돈 지방으로 들어가시니","reference":"마태복음 15:21","category":"$undefined"},{"id":"23656","book":"마태복음","book_name":"마태복음","chapter":15,"verse":22,"text":"가나안 여자 하나가 그 지경에서 나와서 소리질러 가로되 `주 다윗의 자손이여 ! 나를 불쌍히 여기소서 내 딸이 흉악히 귀신들렸나이다' 하되","reference":"마태복음 15:22","category":"$undefined"},{"id":"23657","book":"마태복음","book_name":"마태복음","chapter":15,"verse":23,"text":"예수는 한 말씀도 대답지 아니하시니 제자들이 와서 청하여 말하되 `그 여자가 우리 뒤에서 소리를 지르오니 보내소서'","reference":"마태복음 15:23","category":"$undefined"},{"id":"23658","book":"마태복음","book_name":"마태복음","chapter":15,"verse":24,"text":"예수께서 대답하여 가라사대 나는 이스라엘 집의 잃어버린 양 외에는 다른 데로 보내심을 받지 아니하였노라 하신대","reference":"마태복음 15:24","category":"$undefined"},{"id":"23659","book":"마태복음","book_name":"마태복음","chapter":15,"verse":25,"text":"여자가 와서 예수께 절하며 가로되 `주여 ! 저를 도우소서'","reference":"마태복음 15:25","category":"$undefined"},{"id":"23660","book":"마태복음","book_name":"마태복음","chapter":15,"verse":26,"text":"대답하여 가라사대 자녀의 떡을 취하여 개들에게 던짐이 마땅치 아니하니라","reference":"마태복음 15:26","category":"$undefined"},{"id":"23661","book":"마태복음","book_name":"마태복음","chapter":15,"verse":27,"text":"여자가 가로되 `주여 ! 옳소이다마는 개들도 제 주인의 상에서 떨어지는 부스러기를 먹나이다' 하니","reference":"마태복음 15:27","category":"$undefined"},{"id":"23662","book":"마태복음","book_name":"마태복음","chapter":15,"verse":28,"text":"이에 예수께서 대답하여 가라사대 여자야 네 믿음이 크도다 ! 네 소원대로 되리라 ! 하시니 그 시로부터 그의 딸이 나으니라","reference":"마태복음 15:28","category":"$undefined"},{"id":"23663","book":"마태복음","book_name":"마태복음","chapter":15,"verse":29,"text":"예수께서 거기서 떠나사 갈릴리 호숫가에 이르러 산에 올라가 거기 앉으시니","reference":"마태복음 15:29","category":"$undefined"},{"id":"23664","book":"마태복음","book_name":"마태복음","chapter":15,"verse":30,"text":"큰 무리가 절뚝발이와 불구자와 소경과 벙어리와 기타 여럿을 데리고 와서 예수의 발 앞에 두매 고쳐 주시니","reference":"마태복음 15:30","category":"$undefined"},{"id":"23665","book":"마태복음","book_name":"마태복음","chapter":15,"verse":31,"text":"벙어리가 말하고 불구자가 건전하고 절뚝발이가 걸으며 소경이 보는 것을 무리가 보고 기이히 여겨 이스라엘의 하나님께 영광을 돌리니라","reference":"마태복음 15:31","category":"$undefined"},{"id":"23666","book":"마태복음","book_name":"마태복음","chapter":15,"verse":32,"text":"예수께서 제자들을 불러 가라사대 내가 무리를 불쌍히 여기노라 저희가 나와 함께 있은지 이미 사흘이매 먹을 것이 없도다 길에서 기진할까 하여 굶겨 보내지 못하겠노라","reference":"마태복음 15:32","category":"$undefined"},{"id":"23667","book":"마태복음","book_name":"마태복음","chapter":15,"verse":33,"text":"제자들이 가로되 `광야에 있어 우리가 어디서 이런 무리의 배부를 만큼 떡을 얻으리이까 ?'","reference":"마태복음 15:33","category":"$undefined"},{"id":"23668","book":"마태복음","book_name":"마태복음","chapter":15,"verse":34,"text":"예수께서 가라사대 너희에게 떡이 몇 개나 있느냐 ? 가로되 `일곱 개와 작은 생선 두어 마리가 있나이다' 하거늘","reference":"마태복음 15:34","category":"$undefined"},{"id":"23669","book":"마태복음","book_name":"마태복음","chapter":15,"verse":35,"text":"예수께서 무리를 명하여 땅에 앉게 하시고","reference":"마태복음 15:35","category":"$undefined"},{"id":"23670","book":"마태복음","book_name":"마태복음","chapter":15,"verse":36,"text":"떡 일곱 개와 그 생선을 가지사 축사하시고 떼어 제자들에게 주시니 제자들이 무리에게 주매","reference":"마태복음 15:36","category":"$undefined"},{"id":"23671","book":"마태복음","book_name":"마태복음","chapter":15,"verse":37,"text":"다 배불리 먹고 남은 조각을 일곱 광주리에 차게 거두었으며","reference":"마태복음 15:37","category":"$undefined"},{"id":"23672","book":"마태복음","book_name":"마태복음","chapter":15,"verse":38,"text":"먹은 자는 여자와 아이 외에 사천 명이었더라","reference":"마태복음 15:38","category":"$undefined"},{"id":"23673","book":"마태복음","book_name":"마태복음","chapter":15,"verse":39,"text":"예수께서 무리를 흩어 보내시고 배에 오르사 마가단 지경에 가시니라","reference":"마태복음 15:39","category":"$undefined"}],"bookSlug":"matthew"}]
