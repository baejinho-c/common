2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":16,"verses":[{"id":"23674","book":"마태복음","book_name":"마태복음","chapter":16,"verse":1,"text":"바리새인과 사두개인들이 와서 예수를 시험하여 하늘로서 오는 표적 보이기를 청하니","reference":"마태복음 16:1","category":"$undefined"},{"id":"23675","book":"마태복음","book_name":"마태복음","chapter":16,"verse":2,"text":"예수께서 대답하여 가라사대 너희가 저녁에 하늘이 붉으면 날이 좋겠다 하고","reference":"마태복음 16:2","category":"$undefined"},{"id":"23676","book":"마태복음","book_name":"마태복음","chapter":16,"verse":3,"text":"아침에 하늘이 붉고 흐리면 오늘은 날이 궂겠다 하나니 너희가 천기는 분별할 줄 알면서 시대의 표적은 분별할 수 없느냐 ?","reference":"마태복음 16:3","category":"$undefined"},{"id":"23677","book":"마태복음","book_name":"마태복음","chapter":16,"verse":4,"text":"악하고 음란한 세대가 표적을 구하나 요나의 표적 밖에는 보여줄 표적이 없느니라 하시고 저희를 떠나가시다","reference":"마태복음 16:4","category":"$undefined"},{"id":"23678","book":"마태복음","book_name":"마태복음","chapter":16,"verse":5,"text":"제자들이 건너편으로 갈새 떡 가져가기를 잊었더니","reference":"마태복음 16:5","category":"$undefined"},{"id":"23679","book":"마태복음","book_name":"마태복음","chapter":16,"verse":6,"text":"예수께서 이르시되 삼가 바리새인과 사두개인들의 누룩을 주의하라 하신대","reference":"마태복음 16:6","category":"$undefined"},{"id":"23680","book":"마태복음","book_name":"마태복음","chapter":16,"verse":7,"text":"제자들이 서로 의논하여 가로되 `우리가 떡을 가져오지 아니하였도다' 하거늘","reference":"마태복음 16:7","category":"$undefined"},{"id":"23681","book":"마태복음","book_name":"마태복음","chapter":16,"verse":8,"text":"예수께서 아시고 가라사대 믿음이 적은 자들아 ! 어찌 떡이 없음으로 서로 의논하느냐 ?","reference":"마태복음 16:8","category":"$undefined"},{"id":"23682","book":"마태복음","book_name":"마태복음","chapter":16,"verse":9,"text":"너희가 아직도 깨닫지 못하느냐 ? 떡 다섯 개로 오천 명을 먹이고 주운 것이 몇 바구니며","reference":"마태복음 16:9","category":"$undefined"},{"id":"23683","book":"마태복음","book_name":"마태복음","chapter":16,"verse":10,"text":"떡 일곱 개로 사천 명을 먹이고 주운 것이 몇 광주리이던 것을 기억지 못하느냐 ?","reference":"마태복음 16:10","category":"$undefined"},{"id":"23684","book":"마태복음","book_name":"마태복음","chapter":16,"verse":11,"text":"어찌 내 말한 것이 떡에 관함이 아닌 줄을 깨닫지 못하느냐 오직 바리새인과 사두개인들의 누룩을 주의하라 하시니","reference":"마태복음 16:11","category":"$undefined"},{"id":"23685","book":"마태복음","book_name":"마태복음","chapter":16,"verse":12,"text":"그제야 제자들이 떡의 누룩이 아니요 바리새인과 사두개인들의 교훈을 삼가라고 말씀하신 줄을 깨달으니라","reference":"마태복음 16:12","category":"$undefined"},{"id":"23686","book":"마태복음","book_name":"마태복음","chapter":16,"verse":13,"text":"예수께서 가이사랴 빌립보 지방에 이르러 제자들에게 물어 가라사대 사람들이 인자를 누구라 하느냐 ?","reference":"마태복음 16:13","category":"$undefined"},{"id":"23687","book":"마태복음","book_name":"마태복음","chapter":16,"verse":14,"text":"가로되 `더러는 세례 요한, 더러는 엘리야, 어떤 이는 예레미야나 선지자 중의 하나라 하나이다'","reference":"마태복음 16:14","category":"$undefined"},{"id":"23688","book":"마태복음","book_name":"마태복음","chapter":16,"verse":15,"text":"가라사대 너희는 나를 누구라 하느냐 ?","reference":"마태복음 16:15","category":"$undefined"},{"id":"23689","book":"마태복음","book_name":"마태복음","chapter":16,"verse":16,"text":"시몬 베드로가 대답하여 가로되 `주는 그리스도시요 ! 살아계신 하나님의 아들이시니이다 !'","reference":"마태복음 16:16","category":"$undefined"},{"id":"23690","book":"마태복음","book_name":"마태복음","chapter":16,"verse":17,"text":"예수께서 대답하여 가라사대 바요나 시몬아 네가 복이 있도다 이를 네게 알게 한 이는 혈육이 아니요 하늘에 계신 내 아버지시니라","reference":"마태복음 16:17","category":"$undefined"},{"id":"23691","book":"마태복음","book_name":"마태복음","chapter":16,"verse":18,"text":"또 내가 네게 이르노니 너는 베드로라 내가 이 반석 위에 내 교회를 세우리니 음부의 권세가 이기지 못하리라","reference":"마태복음 16:18","category":"$undefined"},{"id":"23692","book":"마태복음","book_name":"마태복음","chapter":16,"verse":19,"text":"내가 천국 열쇠를 네게 주리니 네가 땅에서 무엇이든지 매면 하늘에서도 매일 것이요 네가 땅에서 무엇이든지 풀면 하늘에서도 풀리리라 하시고","reference":"마태복음 16:19","category":"$undefined"},{"id":"23693","book":"마태복음","book_name":"마태복음","chapter":16,"verse":20,"text":"이에 제자들을 경계하사 자기가 그리스도인 것을 아무에게도 이르지 말라 하시니라","reference":"마태복음 16:20","category":"$undefined"},{"id":"23694","book":"마태복음","book_name":"마태복음","chapter":16,"verse":21,"text":"이 때로부터 예수 그리스도께서 자기가 예루살렘에 올라가 장로들과 대제사장들과 서기관들에게 많은 고난을 받고 죽임을 당하고 제 삼일에 살아나야 할 것을 제자들에게 비로소 가르치시니","reference":"마태복음 16:21","category":"$undefined"},{"id":"23695","book":"마태복음","book_name":"마태복음","chapter":16,"verse":22,"text":"베드로가 예수를 붙들고 간하여 가로되 `주여 그리 마옵소서 이 일이 결코 주에게 미치지 아니하리이다'","reference":"마태복음 16:22","category":"$undefined"},{"id":"23696","book":"마태복음","book_name":"마태복음","chapter":16,"verse":23,"text":"예수께서 돌이키시며 베드로에게 이르시되 사단아 ! 내 뒤로 물러가라 너는 나를 넘어지게 하는 자로다 네가 하나님의 일을 생각지 아니하고 도리어 사람의 일을 생각하는도다 하시고","reference":"마태복음 16:23","category":"$undefined"},{"id":"23697","book":"마태복음","book_name":"마태복음","chapter":16,"verse":24,"text":"이에 예수께서 제자들에게 이르시되 아무든지 나를 따라 오려거든 자기를 부인하고 자기 십자가를 지고 나를 좇을 것이니라","reference":"마태복음 16:24","category":"$undefined"},{"id":"23698","book":"마태복음","book_name":"마태복음","chapter":16,"verse":25,"text":"누구든지 제 목숨을 구원코자 하면 잃을 것이요 누구든지 나를 위하여 제 목숨을 잃으면 찾으리라","reference":"마태복음 16:25","category":"$undefined"},{"id":"23699","book":"마태복음","book_name":"마태복음","chapter":16,"verse":26,"text":"사람이 만일 온 천하를 얻고도 제 목숨을 잃으면 무엇이 유익하리요 사람이 무엇을 주고 제 목숨을 바꾸겠느냐","reference":"마태복음 16:26","category":"$undefined"},{"id":"23700","book":"마태복음","book_name":"마태복음","chapter":16,"verse":27,"text":"인자가 아버지의 영광으로 그 천사들과 함께 오리니 그 때에 각 사람의 행한 대로 갚으리라","reference":"마태복음 16:27","category":"$undefined"},{"id":"23701","book":"마태복음","book_name":"마태복음","chapter":16,"verse":28,"text":"진실로 너희에게 이르노니 여기 섰는 사람 중에 죽기 전에 인자가 그 왕권을 가지고 오는 것을 볼 자들도 있느니라","reference":"마태복음 16:28","category":"$undefined"}],"bookSlug":"matthew"}]
