2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":17,"verses":[{"id":"23702","book":"마태복음","book_name":"마태복음","chapter":17,"verse":1,"text":"엿새 후에 예수께서 베드로와 야고보와 그 형제 요한을 데리시고 따로 높은 산에 올라 가셨더니","reference":"마태복음 17:1","category":"$undefined"},{"id":"23703","book":"마태복음","book_name":"마태복음","chapter":17,"verse":2,"text":"저희 앞에서 변형되사 그 얼굴이 해같이 빛나며 옷이 빛과 같이 희어졌더라","reference":"마태복음 17:2","category":"$undefined"},{"id":"23704","book":"마태복음","book_name":"마태복음","chapter":17,"verse":3,"text":"때에 모세와 엘리야가 예수로 더불어 말씀하는 것이 저희에게 보이거늘","reference":"마태복음 17:3","category":"$undefined"},{"id":"23705","book":"마태복음","book_name":"마태복음","chapter":17,"verse":4,"text":"베드로가 예수께 여짜와 가로되 `주여 우리가 여기 있는 것이 좋사오니 주께서 만일 원하시면 내가 여기서 초막 셋을 짓되 하나는 주를 위하여, 하나는 모세를 위하여, 하나는 엘리야를 위하여 하리이다'","reference":"마태복음 17:4","category":"$undefined"},{"id":"23706","book":"마태복음","book_name":"마태복음","chapter":17,"verse":5,"text":"말할 때에 홀연히 빛난 구름이 저희를 덮으며 구름 속에서 소리가 나서 가로되 `이는 내 사랑하는 아들이요 내 기뻐하는 자니 너희는 저의 말을 들으라 !' 하는지라","reference":"마태복음 17:5","category":"$undefined"},{"id":"23707","book":"마태복음","book_name":"마태복음","chapter":17,"verse":6,"text":"제자들이 듣고 엎드리어 심히 두려워하니","reference":"마태복음 17:6","category":"$undefined"},{"id":"23708","book":"마태복음","book_name":"마태복음","chapter":17,"verse":7,"text":"예수께서 나아가 저희에게 손을 대시며 가라사대 일어나라 두려워 말라 하신대","reference":"마태복음 17:7","category":"$undefined"},{"id":"23709","book":"마태복음","book_name":"마태복음","chapter":17,"verse":8,"text":"제자들이 눈을 들고 보매 오직 ! 예수 외에는 아무도 보이지 아니하더라","reference":"마태복음 17:8","category":"$undefined"},{"id":"23710","book":"마태복음","book_name":"마태복음","chapter":17,"verse":9,"text":"저희가 산에서 내려올 때에 예수께서 명하여 가라사대 인자가 죽은 자 가운데서 살아나기 전에는 본 것을 아무에게도 이르지 말라 하시니","reference":"마태복음 17:9","category":"$undefined"},{"id":"23711","book":"마태복음","book_name":"마태복음","chapter":17,"verse":10,"text":"제자들이 묻자와 가로되 `그러면 어찌하여 서기관들이 엘리야가 먼저 와야 하리라 하나이까 ?'","reference":"마태복음 17:10","category":"$undefined"},{"id":"23712","book":"마태복음","book_name":"마태복음","chapter":17,"verse":11,"text":"예수께서 대답하여 가라사대 엘리야가 과연 먼저 와서 모든 일을 회복하리라","reference":"마태복음 17:11","category":"$undefined"},{"id":"23713","book":"마태복음","book_name":"마태복음","chapter":17,"verse":12,"text":"내가 너희에게 말하노니 엘리야가 이미 왔으되 사람들이 알지 못하고 임의로 대우하였도다 인자도 이와 같이 그들에게 고난을 받으리라 하시니","reference":"마태복음 17:12","category":"$undefined"},{"id":"23714","book":"마태복음","book_name":"마태복음","chapter":17,"verse":13,"text":"그제야 제자들이 예수의 말씀하신 것이 세례 요한인 줄을 깨달으니라","reference":"마태복음 17:13","category":"$undefined"},{"id":"23715","book":"마태복음","book_name":"마태복음","chapter":17,"verse":14,"text":"저희가 무리에게 이르매 한사람이 예수께 와서 꿇어 엎드리어 가로되","reference":"마태복음 17:14","category":"$undefined"},{"id":"23716","book":"마태복음","book_name":"마태복음","chapter":17,"verse":15,"text":"`주여 ! 내 아들을 불쌍히 여기소서 저가 간질로 심히 고생하여 자주 불에도 넘어지며 물에도 넘어지는지라","reference":"마태복음 17:15","category":"$undefined"},{"id":"23717","book":"마태복음","book_name":"마태복음","chapter":17,"verse":16,"text":"내가 주의 제자들에게 데리고 왔으나 능히 고치지 못하더이다'","reference":"마태복음 17:16","category":"$undefined"},{"id":"23718","book":"마태복음","book_name":"마태복음","chapter":17,"verse":17,"text":"예수께서 대답하여 가라사대 믿음이 없고 패역한 세대여 ! 내가 얼마나 너희와 함께 있으며 얼마나 너희를 참으리요 그를 이리로 데려오라 하시다","reference":"마태복음 17:17","category":"$undefined"},{"id":"23719","book":"마태복음","book_name":"마태복음","chapter":17,"verse":18,"text":"이에 예수께서 꾸짖으시니 귀신이 나가고 아이가 그 때부터 나으니라","reference":"마태복음 17:18","category":"$undefined"},{"id":"23720","book":"마태복음","book_name":"마태복음","chapter":17,"verse":19,"text":"이 때에 제자들이 종용히 예수께 나아와 가로되 `우리는 어찌하여 쫓아내지 못하였나이까 ?'","reference":"마태복음 17:19","category":"$undefined"},{"id":"23721","book":"마태복음","book_name":"마태복음","chapter":17,"verse":20,"text":"가라사대 너희 믿음이 적은 연고니라 진실로 너희에게 이르노니 너희가 만일 믿음이 한 겨자씨만큼만 있으면 이 산을 명하여 여기서 저기로 옮기라 하여도 옮길 것이요 또 너희가 못할 것이 없으리라","reference":"마태복음 17:20","category":"$undefined"},{"id":"23722","book":"마태복음","book_name":"마태복음","chapter":17,"verse":21,"text":"(없 음)","reference":"마태복음 17:21","category":"$undefined"},{"id":"23723","book":"마태복음","book_name":"마태복음","chapter":17,"verse":22,"text":"갈릴리에 모일 때에 예수께서 제자들에게 이르시되 인자가 장차 사람들의 손에 넘기워","reference":"마태복음 17:22","category":"$undefined"},{"id":"23724","book":"마태복음","book_name":"마태복음","chapter":17,"verse":23,"text":"죽임을 당하고 제 삼일에 살아나리라 하시니 제자들이 심히 근심하더라","reference":"마태복음 17:23","category":"$undefined"},{"id":"23725","book":"마태복음","book_name":"마태복음","chapter":17,"verse":24,"text":"가버나움에 이르니 반 세겔 받는 자들이 베드로에게 나아와 가로되 너의 선생이 반 세겔을 내지 아니하느냐 ?","reference":"마태복음 17:24","category":"$undefined"},{"id":"23726","book":"마태복음","book_name":"마태복음","chapter":17,"verse":25,"text":"가로되 `내신다' 하고 집에 들어가니 예수께서 먼저 가라사대 시몬아, 네 생각은 어떠하뇨 ? 세상 임금들이 뉘게 관세와 정세를 받느냐 ? 자기 아들에게냐 ? 타인에게냐 ?","reference":"마태복음 17:25","category":"$undefined"},{"id":"23727","book":"마태복음","book_name":"마태복음","chapter":17,"verse":26,"text":"베드로가 가로되 `타인에게니이다' 예수께서 가라사대 그러하면 아들들은 세를 면하리라","reference":"마태복음 17:26","category":"$undefined"},{"id":"23728","book":"마태복음","book_name":"마태복음","chapter":17,"verse":27,"text":"그러나 우리가 저희로 오해케 하지 않기 위하여 네가 바다에 가서 낚시를 던져 먼저 오르는 고기를 가져 입을 열면 돈 한 세겔을 얻을 것이니 가져다가 나와 너를 위하여 주라 하시니라","reference":"마태복음 17:27","category":"$undefined"}],"bookSlug":"matthew"}]
