2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":18,"verses":[{"id":"23729","book":"마태복음","book_name":"마태복음","chapter":18,"verse":1,"text":"그 때에 제자들이 예수께 나아와 가로되 `천국에서는 누가 크니이까 ?'","reference":"마태복음 18:1","category":"$undefined"},{"id":"23730","book":"마태복음","book_name":"마태복음","chapter":18,"verse":2,"text":"예수께서 한 어린 아이를 불러 저희 가운데 세우시고","reference":"마태복음 18:2","category":"$undefined"},{"id":"23731","book":"마태복음","book_name":"마태복음","chapter":18,"verse":3,"text":"가라사대 진실로 너희에게 이르노니 너희가 돌이켜 어린 아이들과 같이 되지 아니하면 결단코 천국에 들어가지 못하리라","reference":"마태복음 18:3","category":"$undefined"},{"id":"23732","book":"마태복음","book_name":"마태복음","chapter":18,"verse":4,"text":"그러므로 누구든지 이 어린 아이와 같이 자기를 낮추는 그이가 천국에서 큰 자니라","reference":"마태복음 18:4","category":"$undefined"},{"id":"23733","book":"마태복음","book_name":"마태복음","chapter":18,"verse":5,"text":"또 누구든지 내 이름으로 이런 어린아이 하나를 영접하면 곧 나를 영접함이니","reference":"마태복음 18:5","category":"$undefined"},{"id":"23734","book":"마태복음","book_name":"마태복음","chapter":18,"verse":6,"text":"누구든지 나를 믿는 이 소자 중 하나를 실족케 하면 차라리 연자 맷돌을 그목에 달리우고 깊은 바다에 빠뜨리우는 것이 나으리라","reference":"마태복음 18:6","category":"$undefined"},{"id":"23735","book":"마태복음","book_name":"마태복음","chapter":18,"verse":7,"text":"실족케 하는 일들이 있음을 인하여 세상에 화가 있도다 실족케 하는 일이 없을 수는 없으나 실족케 하는 그 사람에게는 화가 있도다","reference":"마태복음 18:7","category":"$undefined"},{"id":"23736","book":"마태복음","book_name":"마태복음","chapter":18,"verse":8,"text":"만일 네 손이나 네 발이 너를 범죄케 하거든 찍어 내버리라 불구자나 절뚝발이로 영생에 들어가는 것이 두 손과 두 발을 가지고 영원한 불에 던지우는 것보다 나으니라","reference":"마태복음 18:8","category":"$undefined"},{"id":"23737","book":"마태복음","book_name":"마태복음","chapter":18,"verse":9,"text":"만일 네 눈이 너를 범죄케 하거든 빼어 내버리라 한 눈으로 영생에 들어가는 것이 두 눈을 가지고 지옥불에 던지우는 것보다 나으니라","reference":"마태복음 18:9","category":"$undefined"},{"id":"23738","book":"마태복음","book_name":"마태복음","chapter":18,"verse":10,"text":"삼가 이 소자 중에 하나도 업신 여기지 말라 너희에게 말하노니 저희 천사들이 하늘에서 하늘에 계신 내 아버지의 얼굴을 항상 뵈옵느니라","reference":"마태복음 18:10","category":"$undefined"},{"id":"23739","book":"마태복음","book_name":"마태복음","chapter":18,"verse":11,"text":"(없 음)","reference":"마태복음 18:11","category":"$undefined"},{"id":"23740","book":"마태복음","book_name":"마태복음","chapter":18,"verse":12,"text":"너희 생각에는 어떻겠느뇨 만일 어떤 사람이 양 일백 마리가 있는데 그 중에 하나가 길을 잃었으면 그 아흔 아홉 마리를 산에 두고 가서 길 잃은 양을 찾지 않겠느냐","reference":"마태복음 18:12","category":"$undefined"},{"id":"23741","book":"마태복음","book_name":"마태복음","chapter":18,"verse":13,"text":"진실로 너희에게 이르노니 만일 찾으면 길을 잃지 아니한 아흔 아홉 마리보다 이것을 더 기뻐하리라","reference":"마태복음 18:13","category":"$undefined"},{"id":"23742","book":"마태복음","book_name":"마태복음","chapter":18,"verse":14,"text":"이와 같이 이 소자 중에 하나라도 잃어지는 것은 하늘에 계신 너희 아버지의 뜻이 아니니라","reference":"마태복음 18:14","category":"$undefined"},{"id":"23743","book":"마태복음","book_name":"마태복음","chapter":18,"verse":15,"text":"네 형제가 죄를 범하거든 가서 너와 그 사람과만 상대하여 권고하라 만일 들으면 네가 네 형제를 얻은 것이요","reference":"마태복음 18:15","category":"$undefined"},{"id":"23744","book":"마태복음","book_name":"마태복음","chapter":18,"verse":16,"text":"만일 듣지 않거든 한 두 사람을 데리고 가서 두 세 증인의 입으로 말마다 증참케 하라","reference":"마태복음 18:16","category":"$undefined"},{"id":"23745","book":"마태복음","book_name":"마태복음","chapter":18,"verse":17,"text":"만일 그들의 말도 듣지 않거든 교회에 말하고 교회의 말도 듣지 않거든 이방인과 세리와 같이 여기라","reference":"마태복음 18:17","category":"$undefined"},{"id":"23746","book":"마태복음","book_name":"마태복음","chapter":18,"verse":18,"text":"진실로 너희에게 이르노니 무엇이든지 너희가 땅에서 매면 하늘에서도 매일 것이요 무엇이든지 땅에서 풀면 하늘에서도 풀리리라","reference":"마태복음 18:18","category":"$undefined"},{"id":"23747","book":"마태복음","book_name":"마태복음","chapter":18,"verse":19,"text":"진실로 다시 너희에게 이르노니 너희 중에 두 사람이 땅에서 합심하여 무엇이든지 구하면 하늘에 계신 내 아버지께서 저희를 위하여 이루게 하시리라","reference":"마태복음 18:19","category":"$undefined"},{"id":"23748","book":"마태복음","book_name":"마태복음","chapter":18,"verse":20,"text":"두 세 사람이 내 이름으로 모인 곳에는 나도 그들 중에 있느니라","reference":"마태복음 18:20","category":"$undefined"},{"id":"23749","book":"마태복음","book_name":"마태복음","chapter":18,"verse":21,"text":"그 때에 베드로가 나아와 가로되 `주여, 형제가 내게 죄를 범하면 몇 번이나 용서하여 주리이까 ? 일곱 번까지 하오리이까 ?'","reference":"마태복음 18:21","category":"$undefined"},{"id":"23750","book":"마태복음","book_name":"마태복음","chapter":18,"verse":22,"text":"예수께서 가라사대 네게 이르노니 일곱번뿐 아니라 일흔 번씩 일곱번이라도 할지니라","reference":"마태복음 18:22","category":"$undefined"},{"id":"23751","book":"마태복음","book_name":"마태복음","chapter":18,"verse":23,"text":"이러므로 천국은 그 종들과 회계하려 하던 어떤 임금과 같으니","reference":"마태복음 18:23","category":"$undefined"},{"id":"23752","book":"마태복음","book_name":"마태복음","chapter":18,"verse":24,"text":"회계할 때에 일만 달란트 빚진 자 하나를 데려오매","reference":"마태복음 18:24","category":"$undefined"},{"id":"23753","book":"마태복음","book_name":"마태복음","chapter":18,"verse":25,"text":"갚을 것이 없는지라 주인이 명하여 그 몸과 처와 자식들과 모든 소유를 다 팔아 갚게 하라 한대","reference":"마태복음 18:25","category":"$undefined"},{"id":"23754","book":"마태복음","book_name":"마태복음","chapter":18,"verse":26,"text":"그 종이 엎드리어 절하며 가로되 내게 참으소서 다 갚으리이다 하거늘","reference":"마태복음 18:26","category":"$undefined"},{"id":"23755","book":"마태복음","book_name":"마태복음","chapter":18,"verse":27,"text":"그 종의 주인이 불쌍히 여겨 놓아 보내며 그 빚을 탕감하여 주었더니","reference":"마태복음 18:27","category":"$undefined"},{"id":"23756","book":"마태복음","book_name":"마태복음","chapter":18,"verse":28,"text":"그 종이 나가서 제게 백 데나리온 빚진 동관 하나를 만나 붙들어 목을 잡고 가로되 빚을 갚으라 하매","reference":"마태복음 18:28","category":"$undefined"},{"id":"23757","book":"마태복음","book_name":"마태복음","chapter":18,"verse":29,"text":"그 동관이 엎드리어 간구하여 가로되 나를 참아 주소서 갚으리이다 하되","reference":"마태복음 18:29","category":"$undefined"},{"id":"23758","book":"마태복음","book_name":"마태복음","chapter":18,"verse":30,"text":"허락하지 아니하고 이에 가서 저가 빚을 갚도록 옥에 가두거늘","reference":"마태복음 18:30","category":"$undefined"},{"id":"23759","book":"마태복음","book_name":"마태복음","chapter":18,"verse":31,"text":"그 동관들이 그것을 보고 심히 민망하여 주인에게 가서 그 일을 다 고하니","reference":"마태복음 18:31","category":"$undefined"},{"id":"23760","book":"마태복음","book_name":"마태복음","chapter":18,"verse":32,"text":"이에 주인이 저를 불러다가 말하되 악한 종아 네가 빌기에 내가 네 빚을 전부 탕감하여 주었거늘","reference":"마태복음 18:32","category":"$undefined"},{"id":"23761","book":"마태복음","book_name":"마태복음","chapter":18,"verse":33,"text":"내가 너를 불쌍히 여김과 같이 너도 네 동관을 불쌍히 여김이 마땅치 아니하냐 하고","reference":"마태복음 18:33","category":"$undefined"},{"id":"23762","book":"마태복음","book_name":"마태복음","chapter":18,"verse":34,"text":"주인이 노하여 그 빚을 다 갚도록 저를 옥졸들에게 붙이니라","reference":"마태복음 18:34","category":"$undefined"},{"id":"23763","book":"마태복음","book_name":"마태복음","chapter":18,"verse":35,"text":"너희가 각각 중심으로 형제를 용서하지 아니하면 내 천부께서도 너희에게 이와 같이 하시리라","reference":"마태복음 18:35","category":"$undefined"}],"bookSlug":"matthew"}]
