2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":19,"verses":[{"id":"23764","book":"마태복음","book_name":"마태복음","chapter":19,"verse":1,"text":"예수께서 이 말씀을 마치시고 갈릴리에서 떠나 요단강 건너 유대 지경에 이르시니","reference":"마태복음 19:1","category":"$undefined"},{"id":"23765","book":"마태복음","book_name":"마태복음","chapter":19,"verse":2,"text":"큰 무리가 좇거늘 예수께서 거기서 저희 병을 고치시더라","reference":"마태복음 19:2","category":"$undefined"},{"id":"23766","book":"마태복음","book_name":"마태복음","chapter":19,"verse":3,"text":"바리새인들이 예수께 나아와 그를 시험하여 가로되 `사람이 아무 연고를 물론하고 그 아내를 내어버리는 것이 옳으니이까'","reference":"마태복음 19:3","category":"$undefined"},{"id":"23767","book":"마태복음","book_name":"마태복음","chapter":19,"verse":4,"text":"예수께서 대답하여 가라사대 사람을 지으신 이가 본래 저희를 남자와 여자로 만드시고","reference":"마태복음 19:4","category":"$undefined"},{"id":"23768","book":"마태복음","book_name":"마태복음","chapter":19,"verse":5,"text":"말씀하시기를 이러므로 사람이 그 부모를 떠나서 아내에게 합하여 그 둘이 한 몸이 될지니라 하신 것을 읽지 못하였느냐 ?","reference":"마태복음 19:5","category":"$undefined"},{"id":"23769","book":"마태복음","book_name":"마태복음","chapter":19,"verse":6,"text":"이러한즉 이제 둘이 아니요 한 몸이니 그러므로 하나님이 짝지어 주신 것을 사람이 나누지 못할지니라 ! 하시니","reference":"마태복음 19:6","category":"$undefined"},{"id":"23770","book":"마태복음","book_name":"마태복음","chapter":19,"verse":7,"text":"여짜오되 `그러하면 어찌하여 모세는 이혼 증서를 주어서 내어버리라 명하였나이까'","reference":"마태복음 19:7","category":"$undefined"},{"id":"23771","book":"마태복음","book_name":"마태복음","chapter":19,"verse":8,"text":"예수께서 가라사대 모세가 너희 마음의 완악함을 인하여 아내 내어버림을 허락하였거니와 본래는 그렇지 아니하니라","reference":"마태복음 19:8","category":"$undefined"},{"id":"23772","book":"마태복음","book_name":"마태복음","chapter":19,"verse":9,"text":"내가 너희에게 말하노니 누구든지 음행한 연고 외에 아내를 내어버리고 다른데 장가드는 자는 간음함이니라","reference":"마태복음 19:9","category":"$undefined"},{"id":"23773","book":"마태복음","book_name":"마태복음","chapter":19,"verse":10,"text":"제자들이 가로되 `만일 사람이 아내에게 이같이 할진대 장가 들지 않는 것이 좋삽나이다'","reference":"마태복음 19:10","category":"$undefined"},{"id":"23774","book":"마태복음","book_name":"마태복음","chapter":19,"verse":11,"text":"예수께서 가라사대 사람마다 이 말을 받지 못하고 오직 타고난 자라야 할지니라","reference":"마태복음 19:11","category":"$undefined"},{"id":"23775","book":"마태복음","book_name":"마태복음","chapter":19,"verse":12,"text":"어미의 태로부터 된 고자도 있고 사람이 만든 고자도 있고 천국을 위하여 스스로 된 고자도 있도다 이 말을 받을만한 자는 받을지어다","reference":"마태복음 19:12","category":"$undefined"},{"id":"23776","book":"마태복음","book_name":"마태복음","chapter":19,"verse":13,"text":"때에 사람들이 예수의 안수하고 기도하심을 바라고 어린 아이들을 데리고 오매 제자들이 꾸짖거늘","reference":"마태복음 19:13","category":"$undefined"},{"id":"23777","book":"마태복음","book_name":"마태복음","chapter":19,"verse":14,"text":"예수께서 가라사대 어린 아이들을 용납하고 내게 오는 것을 금하지 말라 천국이 이런 자의 것이니라 하시고","reference":"마태복음 19:14","category":"$undefined"},{"id":"23778","book":"마태복음","book_name":"마태복음","chapter":19,"verse":15,"text":"저희 위에 안수하시고 거기서 떠나시니라","reference":"마태복음 19:15","category":"$undefined"},{"id":"23779","book":"마태복음","book_name":"마태복음","chapter":19,"verse":16,"text":"어떤 사람이 주께 와서 가로되 `선생님이여 내가 무슨 선한 일을 하여야 영생을 얻으리이까 ?'","reference":"마태복음 19:16","category":"$undefined"},{"id":"23780","book":"마태복음","book_name":"마태복음","chapter":19,"verse":17,"text":"예수께서 가라사대 어찌하여 선한 일을 내게 묻느냐 ? 선한 이는 오직 한 분이시니라 ! 네가 생명에 들어 가려면 계명들을 지키라","reference":"마태복음 19:17","category":"$undefined"},{"id":"23781","book":"마태복음","book_name":"마태복음","chapter":19,"verse":18,"text":"가로되 `어느 계명이오니이까 ?' 예수께서 가라사대 살인하지말라, 간음하지말라, 도적질하지 말라, 거짓 증거하지말라,","reference":"마태복음 19:18","category":"$undefined"},{"id":"23782","book":"마태복음","book_name":"마태복음","chapter":19,"verse":19,"text":"네 부모를 공경하라, 네 이웃을 네 몸과 같이 사랑하라 하신 것이니라","reference":"마태복음 19:19","category":"$undefined"},{"id":"23783","book":"마태복음","book_name":"마태복음","chapter":19,"verse":20,"text":"그 청년이 가로되 `이 모든 것을 내가 지키었사오니 아직도 무엇이 부족하니이까 ?'","reference":"마태복음 19:20","category":"$undefined"},{"id":"23784","book":"마태복음","book_name":"마태복음","chapter":19,"verse":21,"text":"예수께서 가라사대 네가 온전하고자 할진대 가서 네 소유를 팔아 가난한 자들을 주라 그리하면 하늘에서 보화가 네게 있으리라 그리고 와서 나를 좇으라 하시니","reference":"마태복음 19:21","category":"$undefined"},{"id":"23785","book":"마태복음","book_name":"마태복음","chapter":19,"verse":22,"text":"그 청년이 재물이 많으므로 이 말씀을 듣고 근심하며 가니라","reference":"마태복음 19:22","category":"$undefined"},{"id":"23786","book":"마태복음","book_name":"마태복음","chapter":19,"verse":23,"text":"예수께서 제자들에게 이르시되 내가 진실로 너희에게 이르노니 부자는 천국에 들어가기가 어려우니라","reference":"마태복음 19:23","category":"$undefined"},{"id":"23787","book":"마태복음","book_name":"마태복음","chapter":19,"verse":24,"text":"다시 너희에게 말하노니 약대가 바늘귀로 들어가는 것이 부자가 하나님의 나라에 들어가는 것보다 쉬우니라 하신대","reference":"마태복음 19:24","category":"$undefined"},{"id":"23788","book":"마태복음","book_name":"마태복음","chapter":19,"verse":25,"text":"제자들이 듣고 심히 놀라 가로되 `그런즉 누가 구원을 얻을수 있으리이까'","reference":"마태복음 19:25","category":"$undefined"},{"id":"23789","book":"마태복음","book_name":"마태복음","chapter":19,"verse":26,"text":"예수께서 저희를 보시며 가라사대 사람으로는 할 수 없으되 하나님으로서는 다 할 수 있느니라","reference":"마태복음 19:26","category":"$undefined"},{"id":"23790","book":"마태복음","book_name":"마태복음","chapter":19,"verse":27,"text":"이에 베드로가 대답하여 가로되 `보소서 우리가 모든 것을 버리고 주를 좇았사오니 그런즉 우리가 무엇을 얻으리이까 ?'","reference":"마태복음 19:27","category":"$undefined"},{"id":"23791","book":"마태복음","book_name":"마태복음","chapter":19,"verse":28,"text":"예수께서 가라사대 내가 진실로 너희에게 이르노니 세상이 새롭게 되어 인자가 자기 영광의 보좌에 앉을 때에 나를 좇는 너희도 열 두 보좌에 앉아 이스라엘 열 두 지파를 심판하리라","reference":"마태복음 19:28","category":"$undefined"},{"id":"23792","book":"마태복음","book_name":"마태복음","chapter":19,"verse":29,"text":"또 내 이름을 위하여 집이나 형제나 자매나 부모나 자식이나 전토를 버린 자마다 여러 배를 받고 또 영생을 상속하리라","reference":"마태복음 19:29","category":"$undefined"},{"id":"23793","book":"마태복음","book_name":"마태복음","chapter":19,"verse":30,"text":"그러나 먼저 된 자로서 나중 되고 나중 된 자로서 먼저 될 자가 많으니라","reference":"마태복음 19:30","category":"$undefined"}],"bookSlug":"matthew"}]
