2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":2,"verses":[{"id":"23171","book":"마태복음","book_name":"마태복음","chapter":2,"verse":1,"text":"헤롯왕 때에 예수께서 유대 베들레헴에서 나시매 동방으로부터 박사들이 예루살렘에 이르러 말하되","reference":"마태복음 2:1","category":"$undefined"},{"id":"23172","book":"마태복음","book_name":"마태복음","chapter":2,"verse":2,"text":"`유대인의 왕으로 나신 이가 어디계시뇨 ? 우리가 동방에서 그의 별을 보고 그에게 경배하러 왔노라' 하니","reference":"마태복음 2:2","category":"$undefined"},{"id":"23173","book":"마태복음","book_name":"마태복음","chapter":2,"verse":3,"text":"헤롯 왕과 온 예루살렘이 듣고 소동한지라","reference":"마태복음 2:3","category":"$undefined"},{"id":"23174","book":"마태복음","book_name":"마태복음","chapter":2,"verse":4,"text":"왕이 모든 대제사장과 백성의 서기관들을 모아 `그리스도가 어디서 나겠느뇨 ?' 물으니","reference":"마태복음 2:4","category":"$undefined"},{"id":"23175","book":"마태복음","book_name":"마태복음","chapter":2,"verse":5,"text":"가로되 `유대 베들레헴이오니 이는 선지자로 이렇게 기록된 바","reference":"마태복음 2:5","category":"$undefined"},{"id":"23176","book":"마태복음","book_name":"마태복음","chapter":2,"verse":6,"text":"또 유대땅 베들레헴아 너는 유대 고을 중에 가장 작지 아니하도다 네게서 한 다스리는 자가 나와서 내 백성 이스라엘의 목자가 되리라 하였음이니이다'","reference":"마태복음 2:6","category":"$undefined"},{"id":"23177","book":"마태복음","book_name":"마태복음","chapter":2,"verse":7,"text":"이에 헤롯이 가만히 박사들을 불러 별이 나타난 때를 자세히 묻고","reference":"마태복음 2:7","category":"$undefined"},{"id":"23178","book":"마태복음","book_name":"마태복음","chapter":2,"verse":8,"text":"베들레헴으로 보내며 이르되 `가서 아기에 대하여 자세히 알아보고 찾거든 내게 고하여 나도 가서 그에게 경배하게 하라'","reference":"마태복음 2:8","category":"$undefined"},{"id":"23179","book":"마태복음","book_name":"마태복음","chapter":2,"verse":9,"text":"박사들이 왕의 말을 듣고 갈새 동방에서 보던 그 별이 문득 앞서 인도하여 가다가 아기 있는 곳 위에 머물러 섰는지라","reference":"마태복음 2:9","category":"$undefined"},{"id":"23180","book":"마태복음","book_name":"마태복음","chapter":2,"verse":10,"text":"저희가 별을 보고 가장 크게 기뻐하고 기뻐하더라","reference":"마태복음 2:10","category":"$undefined"},{"id":"23181","book":"마태복음","book_name":"마태복음","chapter":2,"verse":11,"text":"집에 들어가 아기와 그 모친 마리아의 함께 있는 것을 보고 엎드려 아기께 경배하고 보배합을 열어 황금과 유향과 몰약을 예물로 드리니라","reference":"마태복음 2:11","category":"$undefined"},{"id":"23182","book":"마태복음","book_name":"마태복음","chapter":2,"verse":12,"text":"꿈에 헤롯에게로 돌아가지 말라 지시하심을 받아 다른 길로 고국에 돌아가니라","reference":"마태복음 2:12","category":"$undefined"},{"id":"23183","book":"마태복음","book_name":"마태복음","chapter":2,"verse":13,"text":"저희가 떠난 후에 주의 사자가 요셉에게 현몽하여 가로되 `헤롯이 아기를 찾아 죽이려 하니 일어나 아기와 그의 모친을 데리고 애굽으로 피하여 내가 네게 이르기까지 거기 있으라' 하시니","reference":"마태복음 2:13","category":"$undefined"},{"id":"23184","book":"마태복음","book_name":"마태복음","chapter":2,"verse":14,"text":"요셉이 일어나서 밤에 아기와 그의 모친을 데리고 애굽으로 떠나가","reference":"마태복음 2:14","category":"$undefined"},{"id":"23185","book":"마태복음","book_name":"마태복음","chapter":2,"verse":15,"text":"헤롯이 죽기까지 거기 있었으니 이는 주께서 선지자로 말씀하신바 애굽에서 내 아들을 불렀다 함을 이루려 하심이니라","reference":"마태복음 2:15","category":"$undefined"},{"id":"23186","book":"마태복음","book_name":"마태복음","chapter":2,"verse":16,"text":"이에 헤롯이 박사들에게 속은 줄을 알고 심히 노하여 사람을 보내어 베들레헴과 그 모든 지경 안에 있는 사내아이를 박사들에게 자세히 알아 본 그 때를 표준하여 두살부터 그 아래로 다 죽이니","reference":"마태복음 2:16","category":"$undefined"},{"id":"23187","book":"마태복음","book_name":"마태복음","chapter":2,"verse":17,"text":"이에 선지자 예레미야로 말씀하신 바","reference":"마태복음 2:17","category":"$undefined"},{"id":"23188","book":"마태복음","book_name":"마태복음","chapter":2,"verse":18,"text":"라마에서 슬퍼하며 크게 통곡하는 소리가 들리니 라헬이 그 자식을 위하여 애곡하는 것이라 그가 자식이 없으므로 위로 받기를 거절하였도다 함이 이루어졌느니라","reference":"마태복음 2:18","category":"$undefined"},{"id":"23189","book":"마태복음","book_name":"마태복음","chapter":2,"verse":19,"text":"헤롯이 죽은 후에 주의 사자가 애굽에서 요셉에게 현몽하여 가로되","reference":"마태복음 2:19","category":"$undefined"},{"id":"23190","book":"마태복음","book_name":"마태복음","chapter":2,"verse":20,"text":"`일어나 아기와 그 모친을 데리고 이스라엘 땅으로 가라 아기의 목숨을 찾던 자들이 죽었느니라' 하시니","reference":"마태복음 2:20","category":"$undefined"},{"id":"23191","book":"마태복음","book_name":"마태복음","chapter":2,"verse":21,"text":"요셉이 일어나 아기와 그 모친을 데리고 이스라엘 땅으로 들어오니라","reference":"마태복음 2:21","category":"$undefined"},{"id":"23192","book":"마태복음","book_name":"마태복음","chapter":2,"verse":22,"text":"그러나 아켈라오가 그 부친 헤롯을 이어 유대의 임금 됨을 듣고 거기로 가기를 무서워하더니 꿈에 지시하심을 받아 갈릴리 지방으로 떠나가","reference":"마태복음 2:22","category":"$undefined"},{"id":"23193","book":"마태복음","book_name":"마태복음","chapter":2,"verse":23,"text":"나사렛이란 동네에 와서 사니 이는 선지자로 하신 말씀에 나사렛 사람이라 칭하리라 하심을 이루려 함이러라","reference":"마태복음 2:23","category":"$undefined"}],"bookSlug":"matthew"}]
