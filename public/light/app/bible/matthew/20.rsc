2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":20,"verses":[{"id":"23794","book":"마태복음","book_name":"마태복음","chapter":20,"verse":1,"text":"천국은 마치 품군을 얻어 포도원에 들여 보내려고 이른 아침에 나간 집 주인과 같으니","reference":"마태복음 20:1","category":"$undefined"},{"id":"23795","book":"마태복음","book_name":"마태복음","chapter":20,"verse":2,"text":"저가 하루 한 데나리온씩 품군들과 약속하여 포도원에 들여 보내고","reference":"마태복음 20:2","category":"$undefined"},{"id":"23796","book":"마태복음","book_name":"마태복음","chapter":20,"verse":3,"text":"또 제 삼시에 나가 보니 장터에 놀고 섰는 사람들이 또 있는지라","reference":"마태복음 20:3","category":"$undefined"},{"id":"23797","book":"마태복음","book_name":"마태복음","chapter":20,"verse":4,"text":"저희에게 이르되 너희도 포도원에 들어가라 내가 너희에게 상당하게 주리라 하니 저희가 가고","reference":"마태복음 20:4","category":"$undefined"},{"id":"23798","book":"마태복음","book_name":"마태복음","chapter":20,"verse":5,"text":"제 육시와 제 구시에 또 나가 그와 같이 하고","reference":"마태복음 20:5","category":"$undefined"},{"id":"23799","book":"마태복음","book_name":"마태복음","chapter":20,"verse":6,"text":"제 십일 시에도 나가 보니 섰는 사람들이 또 있는지라","reference":"마태복음 20:6","category":"$undefined"},{"id":"23800","book":"마태복음","book_name":"마태복음","chapter":20,"verse":7,"text":"가로되 너희는 어찌하여 종일토록 놀고 여기 섰느뇨 가로되 우리를 품군으로 쓰는 이가 없음이니이다 가로되 너희도 포도원에 들어가라 하니라","reference":"마태복음 20:7","category":"$undefined"},{"id":"23801","book":"마태복음","book_name":"마태복음","chapter":20,"verse":8,"text":"저물매 포도원 주인이 청지기에게 이르되 품군들을 불러 나중 온 자로부터 시작하여 먼저 온 자까지 삯을 주라 하니","reference":"마태복음 20:8","category":"$undefined"},{"id":"23802","book":"마태복음","book_name":"마태복음","chapter":20,"verse":9,"text":"제 십일 시에 온 자들이 와서 한 데나리온씩을 받거늘","reference":"마태복음 20:9","category":"$undefined"},{"id":"23803","book":"마태복음","book_name":"마태복음","chapter":20,"verse":10,"text":"먼저 온 자들이 와서 더 받을 줄 알았더니 저희도 한 데나리온씩 받은지라","reference":"마태복음 20:10","category":"$undefined"},{"id":"23804","book":"마태복음","book_name":"마태복음","chapter":20,"verse":11,"text":"받은 후 집 주인을 원망하여 가로되","reference":"마태복음 20:11","category":"$undefined"},{"id":"23805","book":"마태복음","book_name":"마태복음","chapter":20,"verse":12,"text":"나중 온 이 사람들은 한 시간만 일하였거늘 저희를 종일 수고와 더위를 견딘 우리와 같게 하였나이다","reference":"마태복음 20:12","category":"$undefined"},{"id":"23806","book":"마태복음","book_name":"마태복음","chapter":20,"verse":13,"text":"주인이 그 중의 한사람에게 대답하여 가로되 친구여 내가 네게 잘못한 것이 없노라 네가 나와 한 데나리온의 약속을 하지 아니 하였느냐","reference":"마태복음 20:13","category":"$undefined"},{"id":"23807","book":"마태복음","book_name":"마태복음","chapter":20,"verse":14,"text":"네 것이나 가지고 가라 나중 온 이 사람에게 너와 같이 주는 것이 내 뜻이니라","reference":"마태복음 20:14","category":"$undefined"},{"id":"23808","book":"마태복음","book_name":"마태복음","chapter":20,"verse":15,"text":"내 것을 가지고 내 뜻대로 할 것이 아니냐 내가 선하므로 네가 악하게 보느냐","reference":"마태복음 20:15","category":"$undefined"},{"id":"23809","book":"마태복음","book_name":"마태복음","chapter":20,"verse":16,"text":"이와 같이 나중 된 자로서 먼저 되고 먼저 된 자로서 나중 되리라","reference":"마태복음 20:16","category":"$undefined"},{"id":"23810","book":"마태복음","book_name":"마태복음","chapter":20,"verse":17,"text":"예수께서 예루살렘으로 올라 가려 하실 때에 열 두 제자를 따로 데리시고 길에서 이르시되","reference":"마태복음 20:17","category":"$undefined"},{"id":"23811","book":"마태복음","book_name":"마태복음","chapter":20,"verse":18,"text":"보라, 우리가 예루살렘으로 올라 가노니 인자가 대제사장들과 서기관들에게 넘기우매 저희가 죽이기로 결안하고","reference":"마태복음 20:18","category":"$undefined"},{"id":"23812","book":"마태복음","book_name":"마태복음","chapter":20,"verse":19,"text":"이방인들에게 넘겨 주어 그를 능욕하며 채찍질하며 십자가에 못박게 하리니 제 삼일에 살아나리라","reference":"마태복음 20:19","category":"$undefined"},{"id":"23813","book":"마태복음","book_name":"마태복음","chapter":20,"verse":20,"text":"그 때에 세베대의 아들의 어미가 그 아들들을 데리고 예수께 와서 절하며 무엇을 구하니","reference":"마태복음 20:20","category":"$undefined"},{"id":"23814","book":"마태복음","book_name":"마태복음","chapter":20,"verse":21,"text":"예수께서 가라사대 무엇을 원하느뇨 ? 가로되 `이 나의 두 아들을 주의 나라에서 하나는 주의 우편에 하나는 주의 좌편에 앉게 명하소서'","reference":"마태복음 20:21","category":"$undefined"},{"id":"23815","book":"마태복음","book_name":"마태복음","chapter":20,"verse":22,"text":"예수께서 대답하여 가라사대 너희 구하는 것을 너희가 알지 못하는도다 나의 마시려는 잔을 너희가 마실 수 있느냐 ? 저희가 말하되 `할 수 있나이다'","reference":"마태복음 20:22","category":"$undefined"},{"id":"23816","book":"마태복음","book_name":"마태복음","chapter":20,"verse":23,"text":"가라사대 너희가 과연 내 잔을 마시려니와 내 좌우편에 앉는 것은 나의 줄 것이 아니라 내 아버지께서 누구를 위하여 예비하셨든지 그들이 얻을 것이니라","reference":"마태복음 20:23","category":"$undefined"},{"id":"23817","book":"마태복음","book_name":"마태복음","chapter":20,"verse":24,"text":"열 제자가 듣고 그 두 형제에 대하여 분히 여기거늘","reference":"마태복음 20:24","category":"$undefined"},{"id":"23818","book":"마태복음","book_name":"마태복음","chapter":20,"verse":25,"text":"예수께서 제자들을 불러다가 가라사대 이방인의 집권자들이 저희를 임의로 주관하고 그 대인들이 저희에게 권세를 부리는 줄을 너희가 알거니와","reference":"마태복음 20:25","category":"$undefined"},{"id":"23819","book":"마태복음","book_name":"마태복음","chapter":20,"verse":26,"text":"너희 중에는 그렇지 아니하니 너희 중에 누구든지 크고자 하는 자는 너희를 섬기는 자가 되고","reference":"마태복음 20:26","category":"$undefined"},{"id":"23820","book":"마태복음","book_name":"마태복음","chapter":20,"verse":27,"text":"너희 중에 누구든지 으뜸이 되고자 하는 자는 너희 종이 되어야 하리라","reference":"마태복음 20:27","category":"$undefined"},{"id":"23821","book":"마태복음","book_name":"마태복음","chapter":20,"verse":28,"text":"인자가 온 것은 섬김을 받으려 함이 아니라 도리어 섬기려 하고 자기 목숨을 많은 사람의 대속물로 주려 함이니라","reference":"마태복음 20:28","category":"$undefined"},{"id":"23822","book":"마태복음","book_name":"마태복음","chapter":20,"verse":29,"text":"저희가 여리고에서 떠나갈 때에 큰 무리가 예수를 좇더라","reference":"마태복음 20:29","category":"$undefined"},{"id":"23823","book":"마태복음","book_name":"마태복음","chapter":20,"verse":30,"text":"소경 둘이 길 가에 앉았다가 예수께서 지나가신다 함을 듣고 소리질러 가로되 `주여 ! 우리를 불쌍히 여기소서 다윗의 자손이여' 하니","reference":"마태복음 20:30","category":"$undefined"},{"id":"23824","book":"마태복음","book_name":"마태복음","chapter":20,"verse":31,"text":"무리가 꾸짖어 잠잠하라 하되 더욱 소리질러 가로되 `주여 ! 우리를 불쌍히 여기소서 다윗의 자손이여' 하는지라","reference":"마태복음 20:31","category":"$undefined"},{"id":"23825","book":"마태복음","book_name":"마태복음","chapter":20,"verse":32,"text":"예수께서 머물러 서서 저희를 불러","reference":"마태복음 20:32","category":"$undefined"},{"id":"23826","book":"마태복음","book_name":"마태복음","chapter":20,"verse":33,"text":"가라사대 너희에게 무엇을 하여주기를 원하느냐 ? 가로되 `주여 ! 우리 눈뜨기를 원하나이다'","reference":"마태복음 20:33","category":"$undefined"},{"id":"23827","book":"마태복음","book_name":"마태복음","chapter":20,"verse":34,"text":"예수께서 민망히 여기사 저희 눈을 만지시니 곧 보게 되어 저희가 예수를 좇으니라","reference":"마태복음 20:34","category":"$undefined"}],"bookSlug":"matthew"}]
