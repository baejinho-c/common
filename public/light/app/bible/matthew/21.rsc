2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":21,"verses":[{"id":"23828","book":"마태복음","book_name":"마태복음","chapter":21,"verse":1,"text":"저희가 예루살렘에 가까이 와서 감람산 벳바게에 이르렀을 때에 예수께서 두 제자를 보내시며","reference":"마태복음 21:1","category":"$undefined"},{"id":"23829","book":"마태복음","book_name":"마태복음","chapter":21,"verse":2,"text":"이르시되 너희 맞은편 마을로 가라 곧 매인 나귀와 나귀 새끼가 함께 있는 것을 보리니 풀어 내게로 끌고 오너라","reference":"마태복음 21:2","category":"$undefined"},{"id":"23830","book":"마태복음","book_name":"마태복음","chapter":21,"verse":3,"text":"만일 누가 무슨 말을 하거든 주가 쓰시겠다 ! 하라 그리하면 즉시 보내리라 하시니","reference":"마태복음 21:3","category":"$undefined"},{"id":"23831","book":"마태복음","book_name":"마태복음","chapter":21,"verse":4,"text":"이는 선지자로 하신 말씀을 이루려 하심이라 일렀으되","reference":"마태복음 21:4","category":"$undefined"},{"id":"23832","book":"마태복음","book_name":"마태복음","chapter":21,"verse":5,"text":"시온 딸에게 이르기를 네 왕이 네게 임하나니 그는 겸손하여 나귀 곧 멍에 메는 짐승의 새끼를 탔도다 하라 하였느니라","reference":"마태복음 21:5","category":"$undefined"},{"id":"23833","book":"마태복음","book_name":"마태복음","chapter":21,"verse":6,"text":"제자들이 가서 예수의 명하신대로 하여","reference":"마태복음 21:6","category":"$undefined"},{"id":"23834","book":"마태복음","book_name":"마태복음","chapter":21,"verse":7,"text":"나귀와 나귀 새끼를 끌고 와서 자기들의 겉옷을 그 위에 얹으매 예수께서 그 위에 타시니","reference":"마태복음 21:7","category":"$undefined"},{"id":"23835","book":"마태복음","book_name":"마태복음","chapter":21,"verse":8,"text":"무리의 대부분은 그 겉옷을 길에 펴며 다른 이는 나무가지를 베어 길에 펴고","reference":"마태복음 21:8","category":"$undefined"},{"id":"23836","book":"마태복음","book_name":"마태복음","chapter":21,"verse":9,"text":"앞에서 가고 뒤에서 따르는 무리가 소리질러 가로되 `호산나 ! 다윗의 자손이여 ! 찬송하리로다 주의 이름으로 오시는 이여 ! 가장 높은곳에서 호산나' 하더라","reference":"마태복음 21:9","category":"$undefined"},{"id":"23837","book":"마태복음","book_name":"마태복음","chapter":21,"verse":10,"text":"예수께서 예루살렘에 들어가시니 온 성이 소동하여 가로되 `이는 누구뇨' 하거늘","reference":"마태복음 21:10","category":"$undefined"},{"id":"23838","book":"마태복음","book_name":"마태복음","chapter":21,"verse":11,"text":"무리가 가로되 `갈릴리 나사렛에서 나온 선지자 예수라' 하니라","reference":"마태복음 21:11","category":"$undefined"},{"id":"23839","book":"마태복음","book_name":"마태복음","chapter":21,"verse":12,"text":"예수께서 성전에 들어가사 성전 안에서 매매하는 모든 자를 내어 쫓으시며 돈 바꾸는 자들의 상과 비둘기 파는 자들의 의자를 둘러 엎으시고","reference":"마태복음 21:12","category":"$undefined"},{"id":"23840","book":"마태복음","book_name":"마태복음","chapter":21,"verse":13,"text":"저희에게 이르시되 기록된 바 내 집은 기도하는 집이라 일컬음을 받으리라 하였거늘 너희는 강도의 굴혈을 만드는도다 하시니라","reference":"마태복음 21:13","category":"$undefined"},{"id":"23841","book":"마태복음","book_name":"마태복음","chapter":21,"verse":14,"text":"소경과 저는 자들이 성전에서 예수께 나아오매 고쳐 주시니","reference":"마태복음 21:14","category":"$undefined"},{"id":"23842","book":"마태복음","book_name":"마태복음","chapter":21,"verse":15,"text":"대제사장들과 서기관들이 예수의 하시는 이상한 일과 또 성전에서 소리질러 호산나 다윗의 자손이여 하는 아이들을 보고 분하여","reference":"마태복음 21:15","category":"$undefined"},{"id":"23843","book":"마태복음","book_name":"마태복음","chapter":21,"verse":16,"text":"예수께 말하되 `저희의 하는 말을 듣느뇨' 예수께서 가라사대 그렇다 어린아기와 젖먹이들의 입에서 나오는 찬미를 온전케 하셨나이다 함을 너희가 읽어 본 일이 없느냐 ? 하시고","reference":"마태복음 21:16","category":"$undefined"},{"id":"23844","book":"마태복음","book_name":"마태복음","chapter":21,"verse":17,"text":"그들을 떠나 성 밖으로 베다니에 가서 거기서 유하시니라","reference":"마태복음 21:17","category":"$undefined"},{"id":"23845","book":"마태복음","book_name":"마태복음","chapter":21,"verse":18,"text":"이른 아침에 성으로 들어오실 때에 시장하신지라","reference":"마태복음 21:18","category":"$undefined"},{"id":"23846","book":"마태복음","book_name":"마태복음","chapter":21,"verse":19,"text":"길 가에서 한 무화과나무를 보시고 그리로 가사 잎사귀 밖에 아무것도 얻지 못하시고 나무에게 이르시되 이제부터 영원토록 네게 열매가 맺지 못하리라 하시니 무화과나무가 곧 마른지라","reference":"마태복음 21:19","category":"$undefined"},{"id":"23847","book":"마태복음","book_name":"마태복음","chapter":21,"verse":20,"text":"제자들이 보고 이상히 여겨 가로되 `무화과나무가 어찌하여 곧 말랐나이까'","reference":"마태복음 21:20","category":"$undefined"},{"id":"23848","book":"마태복음","book_name":"마태복음","chapter":21,"verse":21,"text":"예수께서 대답하여 가라사대 내가 진실로 너희에게 이르노니 만일 너희가 믿음이 있고 의심치 아니하면 이 무화과나무에게 된 이런 일만 할뿐 아니라 이 산더러 들려 바다에 던지우라 하여도 될 것이요","reference":"마태복음 21:21","category":"$undefined"},{"id":"23849","book":"마태복음","book_name":"마태복음","chapter":21,"verse":22,"text":"너희가 기도할 때에 무엇이든지 믿고 구하는 것은 다 받으리라 ! 하시니라","reference":"마태복음 21:22","category":"$undefined"},{"id":"23850","book":"마태복음","book_name":"마태복음","chapter":21,"verse":23,"text":"예수께서 성전에 들어가 가르치실새 대제사장들과 백성의 장로들이 나아와 가로되 `네가 무슨 권세로 이런 일을 하느뇨 ? 또 누가 이 권세를 주었느뇨 ?'","reference":"마태복음 21:23","category":"$undefined"},{"id":"23851","book":"마태복음","book_name":"마태복음","chapter":21,"verse":24,"text":"예수께서 대답하시되 나도 한 말을 너희에게 물으리니 너희가 대답하면 나도 무슨 권세로 이런 일을 하는지 이르리라","reference":"마태복음 21:24","category":"$undefined"},{"id":"23852","book":"마태복음","book_name":"마태복음","chapter":21,"verse":25,"text":"요한의 세례가 어디로서 왔느냐 ? 하늘로서냐 사람에게로서냐 저희가 서로 의논하여 가로되 `만일 하늘로서라 하면 어찌하여 저를 믿지 아니하였느냐 할 것이요","reference":"마태복음 21:25","category":"$undefined"},{"id":"23853","book":"마태복음","book_name":"마태복음","chapter":21,"verse":26,"text":"만일 사람에게로서라 하면 모든 사람이 요한을 선지자로 여기니 백성이 무섭다' 하여","reference":"마태복음 21:26","category":"$undefined"},{"id":"23854","book":"마태복음","book_name":"마태복음","chapter":21,"verse":27,"text":"예수께 대답하여 가로되 `우리가 알지 못하노라' 하니 예수께서 가라사대 나도 무슨 권세로 이런 일을 하는지 너희에게 이르지 아니하리라","reference":"마태복음 21:27","category":"$undefined"},{"id":"23855","book":"마태복음","book_name":"마태복음","chapter":21,"verse":28,"text":"그러나 너희 생각에는 어떠하뇨 ? 한사람이 두 아들이 있는데 맏아들에게 가서 이르되 얘 오늘 포도원에 가서 일하라 하니","reference":"마태복음 21:28","category":"$undefined"},{"id":"23856","book":"마태복음","book_name":"마태복음","chapter":21,"verse":29,"text":"대답하여 가로되 아버지여 가겠소이다 하더니 가지 아니하고","reference":"마태복음 21:29","category":"$undefined"},{"id":"23857","book":"마태복음","book_name":"마태복음","chapter":21,"verse":30,"text":"둘째 아들에게 가서 또 이같이 말하니 대답하여 가로되 싫소이다 하더니 그 후에 뉘우치고 갔으니","reference":"마태복음 21:30","category":"$undefined"},{"id":"23858","book":"마태복음","book_name":"마태복음","chapter":21,"verse":31,"text":"그 둘 중에 누가 아비의 뜻대로 하였느뇨 가로되 `둘째 아들이니이다' 예수께서 저희에게 이르시되 내가 진실로 너희에게 이르노니 세리들과 창기들이 너희보다 먼저 하나님의 나라에 들어가리라","reference":"마태복음 21:31","category":"$undefined"},{"id":"23859","book":"마태복음","book_name":"마태복음","chapter":21,"verse":32,"text":"요한이 의의 도로 너희에게 왔거늘 너희는 저를 믿지 아니하였으되 세리와 창기는 믿었으며 너희는 이것을 보고도 종시 뉘우쳐 믿지 아니하였도다","reference":"마태복음 21:32","category":"$undefined"},{"id":"23860","book":"마태복음","book_name":"마태복음","chapter":21,"verse":33,"text":"다시 한 비유를 들으라 한 집 주인이 포도원을 만들고 산울로 두르고 거기 즙 짜는 구유를 파고 망대를 짓고 농부들에게 세로 주고 타국에 갔더니","reference":"마태복음 21:33","category":"$undefined"},{"id":"23861","book":"마태복음","book_name":"마태복음","chapter":21,"verse":34,"text":"실과 때가 가까우매 그 실과를 받으려고 자기 종들을 농부들에게 보내니","reference":"마태복음 21:34","category":"$undefined"},{"id":"23862","book":"마태복음","book_name":"마태복음","chapter":21,"verse":35,"text":"농부들이 종들을 잡아 하나는 심히 때리고 하나는 죽이고 하나는 돌로 쳤거늘","reference":"마태복음 21:35","category":"$undefined"},{"id":"23863","book":"마태복음","book_name":"마태복음","chapter":21,"verse":36,"text":"다시 다른 종들을 처음보다 많이 보내니 저희에게도 그렇게 하였는지라","reference":"마태복음 21:36","category":"$undefined"},{"id":"23864","book":"마태복음","book_name":"마태복음","chapter":21,"verse":37,"text":"후에 자기 아들을 보내며 가로되 저희가 내 아들은 공경하리라 하였더니","reference":"마태복음 21:37","category":"$undefined"},{"id":"23865","book":"마태복음","book_name":"마태복음","chapter":21,"verse":38,"text":"농부들이 그 아들을 보고 서로 말하되 이는 상속자니 자, 죽이고 그의 유업을 차지하자 하고","reference":"마태복음 21:38","category":"$undefined"},{"id":"23866","book":"마태복음","book_name":"마태복음","chapter":21,"verse":39,"text":"이에 잡아 포도원 밖에 내어쫓아 죽였느니라","reference":"마태복음 21:39","category":"$undefined"},{"id":"23867","book":"마태복음","book_name":"마태복음","chapter":21,"verse":40,"text":"그러면 포도원 주인이 올 때에 이 농부들을 어떻게 하겠느뇨 ?","reference":"마태복음 21:40","category":"$undefined"},{"id":"23868","book":"마태복음","book_name":"마태복음","chapter":21,"verse":41,"text":"저희가 말하되 `이 악한 자들을 진멸하고 포도원은 제 때에 실과를 바칠만한 다른 농부들에게 세로 줄지니이다'","reference":"마태복음 21:41","category":"$undefined"},{"id":"23869","book":"마태복음","book_name":"마태복음","chapter":21,"verse":42,"text":"예수께서 가라사대 너희가 성경에 건축자들의 버린 돌이 모퉁이의 머릿돌이 되었나니 이것은 주로 말미암아 된 것이요 우리 눈에 기이하도다 함을 읽어 본 일이 없느냐","reference":"마태복음 21:42","category":"$undefined"},{"id":"23870","book":"마태복음","book_name":"마태복음","chapter":21,"verse":43,"text":"그러므로 내가 너희에게 이르노니 하나님의 나라를 너희는 빼앗기고 그 나라의 열매 맺는 백성이 받으리라","reference":"마태복음 21:43","category":"$undefined"},{"id":"23871","book":"마태복음","book_name":"마태복음","chapter":21,"verse":44,"text":"이 돌 위에 떨어지는 자는 깨어지겠고 이 돌이 사람 위에 떨어지면 저를 가루로 만들어 흩으리라 하시니","reference":"마태복음 21:44","category":"$undefined"},{"id":"23872","book":"마태복음","book_name":"마태복음","chapter":21,"verse":45,"text":"대제사장들과 바리새인들이 예수의 비유를 듣고 자기들을 가리켜 말씀하심인 줄 알고","reference":"마태복음 21:45","category":"$undefined"},{"id":"23873","book":"마태복음","book_name":"마태복음","chapter":21,"verse":46,"text":"잡고자 하나 무리를 무서워하니 이는 저희가 예수를 선지자로 앎이었더라","reference":"마태복음 21:46","category":"$undefined"}],"bookSlug":"matthew"}]
