2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":22,"verses":[{"id":"23874","book":"마태복음","book_name":"마태복음","chapter":22,"verse":1,"text":"예수께서 다시 비유로 대답하여 가라사대","reference":"마태복음 22:1","category":"$undefined"},{"id":"23875","book":"마태복음","book_name":"마태복음","chapter":22,"verse":2,"text":"천국은 마치 자기 아들을 위하여 혼인 잔치를 베푼 어떤 임금과 같으니","reference":"마태복음 22:2","category":"$undefined"},{"id":"23876","book":"마태복음","book_name":"마태복음","chapter":22,"verse":3,"text":"그 종들을 보내어 그 청한 사람들을 혼인 잔치에 오라 하였더니 오기를 싫어하거늘","reference":"마태복음 22:3","category":"$undefined"},{"id":"23877","book":"마태복음","book_name":"마태복음","chapter":22,"verse":4,"text":"다시 다른 종들을 보내며 가로되 청한 사람들에게 이르기를 내가 오찬을 준비하되 나의 소와 살진 짐승을 잡고 모든 것을 갖추었으니 혼인 잔치에 오소서 하라 하였더니","reference":"마태복음 22:4","category":"$undefined"},{"id":"23878","book":"마태복음","book_name":"마태복음","chapter":22,"verse":5,"text":"저희가 돌아보지도 않고 하나는 자기 밭으로 하나는 자기 상업차로 가고","reference":"마태복음 22:5","category":"$undefined"},{"id":"23879","book":"마태복음","book_name":"마태복음","chapter":22,"verse":6,"text":"그 남은 자들은 종들을 잡아 능욕하고 죽이니","reference":"마태복음 22:6","category":"$undefined"},{"id":"23880","book":"마태복음","book_name":"마태복음","chapter":22,"verse":7,"text":"임금이 노하여 군대를 보내어 그 살인한 자들을 진멸하고 그 동네를 불사르고","reference":"마태복음 22:7","category":"$undefined"},{"id":"23881","book":"마태복음","book_name":"마태복음","chapter":22,"verse":8,"text":"이에 종들에게 이르되 혼인 잔치는 예비되었으나 청한 사람들은 합당치 아니하니","reference":"마태복음 22:8","category":"$undefined"},{"id":"23882","book":"마태복음","book_name":"마태복음","chapter":22,"verse":9,"text":"사거리 길에 가서 사람을 만나는대로 혼인 잔치에 청하여 오너라 한대","reference":"마태복음 22:9","category":"$undefined"},{"id":"23883","book":"마태복음","book_name":"마태복음","chapter":22,"verse":10,"text":"종들이 길에 나가 악한 자나 선한 자나 만나는대로 모두 데려오니 혼인 자리에 손이 가득한지라","reference":"마태복음 22:10","category":"$undefined"},{"id":"23884","book":"마태복음","book_name":"마태복음","chapter":22,"verse":11,"text":"임금이 손을 보러 들어올새 거기서 예복을 입지 않은 한사람을 보고","reference":"마태복음 22:11","category":"$undefined"},{"id":"23885","book":"마태복음","book_name":"마태복음","chapter":22,"verse":12,"text":"가로되 친구여 어찌하여 예복을 입지 않고 여기 들어왔느냐 하니 저가 유구무언이어늘","reference":"마태복음 22:12","category":"$undefined"},{"id":"23886","book":"마태복음","book_name":"마태복음","chapter":22,"verse":13,"text":"임금이 사환들에게 말하되 그 수족을 결박하여 바깥 어두움에 내어 던지라 거기서 슬피 울며 이를 갊이 있으리라 하니라","reference":"마태복음 22:13","category":"$undefined"},{"id":"23887","book":"마태복음","book_name":"마태복음","chapter":22,"verse":14,"text":"청함을 받은 자는 많되 택함을 입은 자는 적으니라","reference":"마태복음 22:14","category":"$undefined"},{"id":"23888","book":"마태복음","book_name":"마태복음","chapter":22,"verse":15,"text":"이에 바리새인들이 가서 어떻게 하여 예수로 말의 올무에 걸리게 할까 상론하고","reference":"마태복음 22:15","category":"$undefined"},{"id":"23889","book":"마태복음","book_name":"마태복음","chapter":22,"verse":16,"text":"자기 제자들을 헤롯 당원들과 함께 예수께 보내어 말하되 `선생님이여 우리가 아노니 당신은 참되시고 참으로써 하나님의 도를 가르치시며 아무라도 꺼리는 일이 없으시니 이는 사람을 외모로 보지 아니하심이니이다","reference":"마태복음 22:16","category":"$undefined"},{"id":"23890","book":"마태복음","book_name":"마태복음","chapter":22,"verse":17,"text":"그러면 당신의 생각에는 어떠한지 우리에게 이르소서 가이사에게 세를 바치는 것이 가하니이까 불가하니이까' 한대","reference":"마태복음 22:17","category":"$undefined"},{"id":"23891","book":"마태복음","book_name":"마태복음","chapter":22,"verse":18,"text":"예수께서 저희의 악함을 아시고 가라사대 외식하는 자들아 어찌하여 나를 시험하느냐 ?","reference":"마태복음 22:18","category":"$undefined"},{"id":"23892","book":"마태복음","book_name":"마태복음","chapter":22,"verse":19,"text":"셋돈을 내게 보이라 하시니 데나리온 하나를 가져 왔거늘","reference":"마태복음 22:19","category":"$undefined"},{"id":"23893","book":"마태복음","book_name":"마태복음","chapter":22,"verse":20,"text":"예수께서 말씀하시되 이 형상과 이 글이 뉘 것이냐 ?","reference":"마태복음 22:20","category":"$undefined"},{"id":"23894","book":"마태복음","book_name":"마태복음","chapter":22,"verse":21,"text":"가로되 `가이사의 것이니이다` 이에 가라사대 그런즉 가이사의 것은 가이사에게 하나님의 것은 하나님께 바치라 하시니","reference":"마태복음 22:21","category":"$undefined"},{"id":"23895","book":"마태복음","book_name":"마태복음","chapter":22,"verse":22,"text":"저희가 이 말씀을 듣고 기이히 여겨 예수를 떠나가니라","reference":"마태복음 22:22","category":"$undefined"},{"id":"23896","book":"마태복음","book_name":"마태복음","chapter":22,"verse":23,"text":"부활이 없다 하는 사두개인들이 그 날에 예수께 와서 물어 가로되","reference":"마태복음 22:23","category":"$undefined"},{"id":"23897","book":"마태복음","book_name":"마태복음","chapter":22,"verse":24,"text":"`선생님이여 모세가 일렀으되 사람이 만일 자식이 없이 죽으면 그 동생이 그 아내에게 장가들어 형을 위하여 후사를 세울지니라 하였나이다","reference":"마태복음 22:24","category":"$undefined"},{"id":"23898","book":"마태복음","book_name":"마태복음","chapter":22,"verse":25,"text":"우리 중에 칠 형제가 있었는데 맏이 장가들었다가 죽어 후사가 없으므로 그의 아내를 그 동생에게 끼쳐두고","reference":"마태복음 22:25","category":"$undefined"},{"id":"23899","book":"마태복음","book_name":"마태복음","chapter":22,"verse":26,"text":"그 둘째와 세째로 일곱째까지 그렇게 하다가","reference":"마태복음 22:26","category":"$undefined"},{"id":"23900","book":"마태복음","book_name":"마태복음","chapter":22,"verse":27,"text":"최후에 그 여자도 죽었나이다","reference":"마태복음 22:27","category":"$undefined"},{"id":"23901","book":"마태복음","book_name":"마태복음","chapter":22,"verse":28,"text":"그런즉 저희가 다 그를 취하였으니 부활 때에 일곱 중에 뉘 아내가 되리이까 ?'","reference":"마태복음 22:28","category":"$undefined"},{"id":"23902","book":"마태복음","book_name":"마태복음","chapter":22,"verse":29,"text":"예수께서 대답하여 가라사대 너희가 성경도 하나님의 능력도 알지 못하는고로 오해하였도다","reference":"마태복음 22:29","category":"$undefined"},{"id":"23903","book":"마태복음","book_name":"마태복음","chapter":22,"verse":30,"text":"부활 때에는 장가도 아니가고 시집도 아니가고 하늘에 있는 천사들과 같으니라","reference":"마태복음 22:30","category":"$undefined"},{"id":"23904","book":"마태복음","book_name":"마태복음","chapter":22,"verse":31,"text":"죽은 자의 부활을 의논할진대 하나님이 너희에게 말씀하신 바","reference":"마태복음 22:31","category":"$undefined"},{"id":"23905","book":"마태복음","book_name":"마태복음","chapter":22,"verse":32,"text":"나는 아브라함의 하나님이요, 이삭의 하나님이요, 야곱의 하나님이로라 하신 것을 읽어 보지 못하였느냐 하나님은 죽은 자의 하나님이 아니요 산자의 하나님이시니라 ! 하시니","reference":"마태복음 22:32","category":"$undefined"},{"id":"23906","book":"마태복음","book_name":"마태복음","chapter":22,"verse":33,"text":"무리가 듣고 그의 가르치심에 놀라더라","reference":"마태복음 22:33","category":"$undefined"},{"id":"23907","book":"마태복음","book_name":"마태복음","chapter":22,"verse":34,"text":"예수께서 사두개인들로 대답할 수 없게 하셨다 함을 바리새인들이 듣고 모였는데","reference":"마태복음 22:34","category":"$undefined"},{"id":"23908","book":"마태복음","book_name":"마태복음","chapter":22,"verse":35,"text":"그 중에 한 율법사가 예수를 시험하여 묻되","reference":"마태복음 22:35","category":"$undefined"},{"id":"23909","book":"마태복음","book_name":"마태복음","chapter":22,"verse":36,"text":"`선생님이여 율법 중에 어느 계명이 크니이까 ?'","reference":"마태복음 22:36","category":"$undefined"},{"id":"23910","book":"마태복음","book_name":"마태복음","chapter":22,"verse":37,"text":"예수께서 가라사대 네 마음을 다하고 목숨을 다하고 뜻을 다하여 주 너의 하나님을 사랑하라 하셨으니","reference":"마태복음 22:37","category":"$undefined"},{"id":"23911","book":"마태복음","book_name":"마태복음","chapter":22,"verse":38,"text":"이것이 크고 첫째 되는 계명이요","reference":"마태복음 22:38","category":"$undefined"},{"id":"23912","book":"마태복음","book_name":"마태복음","chapter":22,"verse":39,"text":"둘째는 그와 같으니 네 이웃을 네 몸과 같이 사랑하라 하셨으니","reference":"마태복음 22:39","category":"$undefined"},{"id":"23913","book":"마태복음","book_name":"마태복음","chapter":22,"verse":40,"text":"이 두 계명이 온 율법과 선지자의 강령이니라","reference":"마태복음 22:40","category":"$undefined"},{"id":"23914","book":"마태복음","book_name":"마태복음","chapter":22,"verse":41,"text":"바리새인들이 모였을 때에 예수께서 그들에게 물으시되","reference":"마태복음 22:41","category":"$undefined"},{"id":"23915","book":"마태복음","book_name":"마태복음","chapter":22,"verse":42,"text":"너희는 그리스도에 대하여 어떻게 생각하느냐 ? 뉘 자손이냐 ? 대답하되 `다윗의 자손이니이다'","reference":"마태복음 22:42","category":"$undefined"},{"id":"23916","book":"마태복음","book_name":"마태복음","chapter":22,"verse":43,"text":"가라사대 그러면 다윗이 성령에 감동하여 어찌 그리스도를 주라 칭하여 말하되","reference":"마태복음 22:43","category":"$undefined"},{"id":"23917","book":"마태복음","book_name":"마태복음","chapter":22,"verse":44,"text":"주께서 내 주께 이르시되 내가 네 원수를 네 발 아래 둘 때까지 내 우편에 앉았으라 하셨도다 하였느냐","reference":"마태복음 22:44","category":"$undefined"},{"id":"23918","book":"마태복음","book_name":"마태복음","chapter":22,"verse":45,"text":"다윗이 그리스도를 주라 칭하였은즉 어찌 그의 자손이 되겠느냐 하시니","reference":"마태복음 22:45","category":"$undefined"},{"id":"23919","book":"마태복음","book_name":"마태복음","chapter":22,"verse":46,"text":"한 말도 능히 대답하는 자가 없고 그 날부터 감히 그에게 묻는 자도 없더라","reference":"마태복음 22:46","category":"$undefined"}],"bookSlug":"matthew"}]
