2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":23,"verses":[{"id":"23920","book":"마태복음","book_name":"마태복음","chapter":23,"verse":1,"text":"이에 예수께서 무리와 제자들에게 말씀하여 가라사대","reference":"마태복음 23:1","category":"$undefined"},{"id":"23921","book":"마태복음","book_name":"마태복음","chapter":23,"verse":2,"text":"서기관들과 바리새인들이 모세의 자리에 앉았으니","reference":"마태복음 23:2","category":"$undefined"},{"id":"23922","book":"마태복음","book_name":"마태복음","chapter":23,"verse":3,"text":"그러므로 무엇이든지 저희의 말하는 바는 행하고 지키되 저희의 하는 행위는 본받지 말라 저희는 말만 하고 행치 아니하며","reference":"마태복음 23:3","category":"$undefined"},{"id":"23923","book":"마태복음","book_name":"마태복음","chapter":23,"verse":4,"text":"또 무거운 짐을 묶어 사람의 어깨에 지우되 자기는 이것을 한 손가락으로도 움직이려 하지 아니하며","reference":"마태복음 23:4","category":"$undefined"},{"id":"23924","book":"마태복음","book_name":"마태복음","chapter":23,"verse":5,"text":"저희 모든 행위를 사람에게 보이고자 하여 하나니 곧 그 차는 경문을 넓게 하며 옷술을 크게 하고","reference":"마태복음 23:5","category":"$undefined"},{"id":"23925","book":"마태복음","book_name":"마태복음","chapter":23,"verse":6,"text":"잔치의 상석과 회당의 상좌와","reference":"마태복음 23:6","category":"$undefined"},{"id":"23926","book":"마태복음","book_name":"마태복음","chapter":23,"verse":7,"text":"시장에서 문안 받는 것과 사람에게 랍비라 칭함을 받는 것을 좋아하느니라","reference":"마태복음 23:7","category":"$undefined"},{"id":"23927","book":"마태복음","book_name":"마태복음","chapter":23,"verse":8,"text":"그러나 너희는 랍비라 칭함을 받지 말라 너희 선생은 하나이요 너희는 다 형제니라","reference":"마태복음 23:8","category":"$undefined"},{"id":"23928","book":"마태복음","book_name":"마태복음","chapter":23,"verse":9,"text":"땅에 있는 자를 아비라 하지 말라 너희 아버지는 하나이시니 곧 하늘에 계신 자시니라","reference":"마태복음 23:9","category":"$undefined"},{"id":"23929","book":"마태복음","book_name":"마태복음","chapter":23,"verse":10,"text":"또한 지도자라 칭함을 받지 말라 너희 지도자는 하나이니 곧 그리스도니라","reference":"마태복음 23:10","category":"$undefined"},{"id":"23930","book":"마태복음","book_name":"마태복음","chapter":23,"verse":11,"text":"너희 중에 큰 자는 너희를 섬기는 자가 되어야 하리라","reference":"마태복음 23:11","category":"$undefined"},{"id":"23931","book":"마태복음","book_name":"마태복음","chapter":23,"verse":12,"text":"누구든지 자기를 높이는 자는 낮아지고 누구든지 자기를 낮추는 자는 높아지리라","reference":"마태복음 23:12","category":"$undefined"},{"id":"23932","book":"마태복음","book_name":"마태복음","chapter":23,"verse":13,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 너희는 천국 문을 사람들 앞에서 닫고 너희도 들어가지 않고 들어가려 하는 자도 들어가지 못하게 하는도다","reference":"마태복음 23:13","category":"$undefined"},{"id":"23933","book":"마태복음","book_name":"마태복음","chapter":23,"verse":14,"text":"(없 음)","reference":"마태복음 23:14","category":"$undefined"},{"id":"23934","book":"마태복음","book_name":"마태복음","chapter":23,"verse":15,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 너희는 교인 하나를 얻기 위하여 바다와 육지를 두루 다니다가 생기면 너희보다 배나 더 지옥 자식이 되게 하는도다","reference":"마태복음 23:15","category":"$undefined"},{"id":"23935","book":"마태복음","book_name":"마태복음","chapter":23,"verse":16,"text":"화 있을진저 ! 소경된 인도자여 너희가 말하되 누구든지 성전으로 맹세하면 아무 일 없거니와 성전의 금으로 맹세하면 지킬지라 하는도다","reference":"마태복음 23:16","category":"$undefined"},{"id":"23936","book":"마태복음","book_name":"마태복음","chapter":23,"verse":17,"text":"우맹이요 소경들이여 ! 어느 것이 크뇨 그 금이냐 금을 거룩하게 하는 성전이냐","reference":"마태복음 23:17","category":"$undefined"},{"id":"23937","book":"마태복음","book_name":"마태복음","chapter":23,"verse":18,"text":"너희가 또 이르되 누구든지 제단으로 맹세하면 아무 일 없거니와 그 위에 있는 예물로 맹세하면 지킬지라 하는도다","reference":"마태복음 23:18","category":"$undefined"},{"id":"23938","book":"마태복음","book_name":"마태복음","chapter":23,"verse":19,"text":"소경들이여 ! 어느 것이 크뇨 그 예물이냐 예물을 거룩하게 하는 제단이냐","reference":"마태복음 23:19","category":"$undefined"},{"id":"23939","book":"마태복음","book_name":"마태복음","chapter":23,"verse":20,"text":"그러므로 제단으로 맹세하는 자는 제단과 그 위에 있는 모든 것으로 맹세함이요","reference":"마태복음 23:20","category":"$undefined"},{"id":"23940","book":"마태복음","book_name":"마태복음","chapter":23,"verse":21,"text":"또 성전으로 맹세하는 자는 성전과 그 안에 계신 이로 맹세함이요","reference":"마태복음 23:21","category":"$undefined"},{"id":"23941","book":"마태복음","book_name":"마태복음","chapter":23,"verse":22,"text":"또 하늘로 맹세하는 자는 하나님의 보좌와 그 위에 앉으신 이로 맹세함이니라","reference":"마태복음 23:22","category":"$undefined"},{"id":"23942","book":"마태복음","book_name":"마태복음","chapter":23,"verse":23,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 너희가 박하와 회향과 근채의 십일조를 드리되 율법의 더 중한 바 의와 인과 신은 버렸도다 그러나 이것도 행하고 저것도 버리지 말아야 할지니라","reference":"마태복음 23:23","category":"$undefined"},{"id":"23943","book":"마태복음","book_name":"마태복음","chapter":23,"verse":24,"text":"소경된 인도자여 하루살이는 걸러내고 약대는 삼키는도다","reference":"마태복음 23:24","category":"$undefined"},{"id":"23944","book":"마태복음","book_name":"마태복음","chapter":23,"verse":25,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 잔과 대접의 겉은 깨끗이 하되 그 안에는 탐욕과 방탕으로 가득하게 하는도다","reference":"마태복음 23:25","category":"$undefined"},{"id":"23945","book":"마태복음","book_name":"마태복음","chapter":23,"verse":26,"text":"소경된 바리새인아 너는 먼저 안을 깨끗이 하라 그리하면 겉도 깨끗하리라","reference":"마태복음 23:26","category":"$undefined"},{"id":"23946","book":"마태복음","book_name":"마태복음","chapter":23,"verse":27,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 회칠한 무덤 같으니 겉으로는 아름답게 보이나 그 안에는 죽은 사람의 뼈와 모든 더러운 것이 가득하도다","reference":"마태복음 23:27","category":"$undefined"},{"id":"23947","book":"마태복음","book_name":"마태복음","chapter":23,"verse":28,"text":"이와같이 너희도 겉으로는 사람에게 옳게 보이되 안으로는 외식과 불법이 가득하도다","reference":"마태복음 23:28","category":"$undefined"},{"id":"23948","book":"마태복음","book_name":"마태복음","chapter":23,"verse":29,"text":"화 있을진저 ! 외식하는 서기관들과 바리새인들이여 너희는 선지자들의 무덤을 쌓고 의인들의 비석을 꾸미며 가로되","reference":"마태복음 23:29","category":"$undefined"},{"id":"23949","book":"마태복음","book_name":"마태복음","chapter":23,"verse":30,"text":"만일 우리가 조상 때에 있었더면 우리는 저희가 선지자의 피를 흘리는데 참예하지 아니하였으리라 하니","reference":"마태복음 23:30","category":"$undefined"},{"id":"23950","book":"마태복음","book_name":"마태복음","chapter":23,"verse":31,"text":"그러면 너희가 선지자를 죽인 자의 자손됨을 스스로 증거함이로다","reference":"마태복음 23:31","category":"$undefined"},{"id":"23951","book":"마태복음","book_name":"마태복음","chapter":23,"verse":32,"text":"너희가 너희 조상의 양을 채우라","reference":"마태복음 23:32","category":"$undefined"},{"id":"23952","book":"마태복음","book_name":"마태복음","chapter":23,"verse":33,"text":"뱀들아 독사의 새끼들아 ! 너희가 어떻게 지옥의 판결을 피하겠느냐","reference":"마태복음 23:33","category":"$undefined"},{"id":"23953","book":"마태복음","book_name":"마태복음","chapter":23,"verse":34,"text":"그러므로 내가 너희에게 선지자들과 지혜있는 자들과 서기관들을 보내매 너희가 그 중에서 더러는 죽이고 십자가에 못박고 그 중에 더러는 너희 회당에서 채찍질하고 이 동네에서 저 동네로 구박하리라","reference":"마태복음 23:34","category":"$undefined"},{"id":"23954","book":"마태복음","book_name":"마태복음","chapter":23,"verse":35,"text":"그러므로 의인 아벨의 피로부터 성전과 제단 사이에서 너희가 죽인 바라갸의 아들 사가랴의 피까지 땅 위에서 흘린 의로운 피가 다 너희에게 돌아 가리라","reference":"마태복음 23:35","category":"$undefined"},{"id":"23955","book":"마태복음","book_name":"마태복음","chapter":23,"verse":36,"text":"내가 진실로 너희에게 이르노니 이것이 다 이 세대에게 돌아가리라","reference":"마태복음 23:36","category":"$undefined"},{"id":"23956","book":"마태복음","book_name":"마태복음","chapter":23,"verse":37,"text":"예루살렘아 ! 예루살렘아 ! 선지자들을 죽이고 네게 파송된 자들을 돌로 치는 자여 암탉이 그 새끼를 날개 아래 모음같이 내가 네 자녀를 모으려 한 일이 몇번이냐 그러나 너희가 원치 아니하였도다","reference":"마태복음 23:37","category":"$undefined"},{"id":"23957","book":"마태복음","book_name":"마태복음","chapter":23,"verse":38,"text":"보라 ! 너희집이 황폐하여 버린바 되리라","reference":"마태복음 23:38","category":"$undefined"},{"id":"23958","book":"마태복음","book_name":"마태복음","chapter":23,"verse":39,"text":"내가 너희에게 이르노니 이제부터 너희는 찬송하리로다 주의 이름으로 오시는이여 할 때까지 나를 보지 못하리라 하시니라","reference":"마태복음 23:39","category":"$undefined"}],"bookSlug":"matthew"}]
