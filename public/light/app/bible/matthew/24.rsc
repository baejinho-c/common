2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":24,"verses":[{"id":"23959","book":"마태복음","book_name":"마태복음","chapter":24,"verse":1,"text":"예수께서 성전에서 나와서 가실 때에 제자들이 성전 건물들을 가리켜 보이려고 나아오니","reference":"마태복음 24:1","category":"$undefined"},{"id":"23960","book":"마태복음","book_name":"마태복음","chapter":24,"verse":2,"text":"대답하여 가라사대 너희가 이 모든 것을 보지 못하느냐 ? 내가 진실로 너희에게 이르노니 돌 하나도 돌 위에 남지 않고 다 무너뜨리우리라","reference":"마태복음 24:2","category":"$undefined"},{"id":"23961","book":"마태복음","book_name":"마태복음","chapter":24,"verse":3,"text":"예수께서 감람산 위에 앉으셨을 때에 제자들이 종용히 와서 가로되 우리에게 이르소서 어느 때에 이런 일이 있겠사오며 또 주의 임하심과 세상 끝에는 무슨 징조가 있사오리이까 ?","reference":"마태복음 24:3","category":"$undefined"},{"id":"23962","book":"마태복음","book_name":"마태복음","chapter":24,"verse":4,"text":"예수께서 대답하여 가라사대 너희가 사람의 미혹을 받지 않도록 주의하라","reference":"마태복음 24:4","category":"$undefined"},{"id":"23963","book":"마태복음","book_name":"마태복음","chapter":24,"verse":5,"text":"많은 사람이 내 이름으로 와서 이르되 나는 그리스도라 하여 많은 사람을 미혹케 하리라","reference":"마태복음 24:5","category":"$undefined"},{"id":"23964","book":"마태복음","book_name":"마태복음","chapter":24,"verse":6,"text":"난리와 난리 소문을 듣겠으나 너희는 삼가 두려워 말라 이런 일이 있어야 하되 끝은 아직 아니니라","reference":"마태복음 24:6","category":"$undefined"},{"id":"23965","book":"마태복음","book_name":"마태복음","chapter":24,"verse":7,"text":"민족이 민족을, 나라가 나라를 대적하여 일어나겠고 처처에 기근과 지진이 있으리니","reference":"마태복음 24:7","category":"$undefined"},{"id":"23966","book":"마태복음","book_name":"마태복음","chapter":24,"verse":8,"text":"이 모든 것이 재난의 시작이니라","reference":"마태복음 24:8","category":"$undefined"},{"id":"23967","book":"마태복음","book_name":"마태복음","chapter":24,"verse":9,"text":"그 때에 사람들이 너희를 환난에 넘겨 주겠으며 너희를 죽이리니 너희가 내 이름을 위하여 모든 민족에게 미움을 받으리라","reference":"마태복음 24:9","category":"$undefined"},{"id":"23968","book":"마태복음","book_name":"마태복음","chapter":24,"verse":10,"text":"그 때에 많은 사람이 시험에 빠져 서로 잡아 주고 서로 미워하겠으며","reference":"마태복음 24:10","category":"$undefined"},{"id":"23969","book":"마태복음","book_name":"마태복음","chapter":24,"verse":11,"text":"거짓 선지자가 많이 일어나 많은 사람을 미혹하게 하겠으며","reference":"마태복음 24:11","category":"$undefined"},{"id":"23970","book":"마태복음","book_name":"마태복음","chapter":24,"verse":12,"text":"불법이 성하므로 많은 사람의 사랑이 식어지리라","reference":"마태복음 24:12","category":"$undefined"},{"id":"23971","book":"마태복음","book_name":"마태복음","chapter":24,"verse":13,"text":"그러나 끝까지 견디는 자는 구원을 얻으리라","reference":"마태복음 24:13","category":"$undefined"},{"id":"23972","book":"마태복음","book_name":"마태복음","chapter":24,"verse":14,"text":"이 천국 복음이 모든 민족에게 증거되기 위하여 온 세상에 전파되리니 그제야 끝이 오리라","reference":"마태복음 24:14","category":"$undefined"},{"id":"23973","book":"마태복음","book_name":"마태복음","chapter":24,"verse":15,"text":"그러므로 너희가 선지자 다니엘의 말한 바 멸망의 가증한 것이 거룩한 곳에 선 것을 보거든 (읽는 자는 깨달을진저)","reference":"마태복음 24:15","category":"$undefined"},{"id":"23974","book":"마태복음","book_name":"마태복음","chapter":24,"verse":16,"text":"그 때에 유대에 있는 자들은 산으로 도망할지어다","reference":"마태복음 24:16","category":"$undefined"},{"id":"23975","book":"마태복음","book_name":"마태복음","chapter":24,"verse":17,"text":"지붕 위에 있는 자는 집안에 있는 물건을 가질러 내려 가지 말며","reference":"마태복음 24:17","category":"$undefined"},{"id":"23976","book":"마태복음","book_name":"마태복음","chapter":24,"verse":18,"text":"밭에 있는 자는 겉옷을 가질러 뒤로 돌이키지 말지어다","reference":"마태복음 24:18","category":"$undefined"},{"id":"23977","book":"마태복음","book_name":"마태복음","chapter":24,"verse":19,"text":"그 날에는 아이 밴 자들과 젖먹이는 자들에게 화가 있으리로다","reference":"마태복음 24:19","category":"$undefined"},{"id":"23978","book":"마태복음","book_name":"마태복음","chapter":24,"verse":20,"text":"너희의 도망하는 일이 겨울에나 안식일에 되지 않도록 기도하라","reference":"마태복음 24:20","category":"$undefined"},{"id":"23979","book":"마태복음","book_name":"마태복음","chapter":24,"verse":21,"text":"이는 그 때에 큰 환난이 있겠음이라 창세로부터 지금까지 이런 환난이 없었고 후에도 없으리라","reference":"마태복음 24:21","category":"$undefined"},{"id":"23980","book":"마태복음","book_name":"마태복음","chapter":24,"verse":22,"text":"그 날들을 감하지 아니할 것이면 모든 육체가 구원을 얻지 못할 것이나 그러나 택하신 자들을 위하여 그 날들을 감하시리라","reference":"마태복음 24:22","category":"$undefined"},{"id":"23981","book":"마태복음","book_name":"마태복음","chapter":24,"verse":23,"text":"그 때에 사람이 너희에게 말하되 보라 그리스도가 여기 있다 혹 저기 있다 하여도 믿지 말라","reference":"마태복음 24:23","category":"$undefined"},{"id":"23982","book":"마태복음","book_name":"마태복음","chapter":24,"verse":24,"text":"거짓 그리스도들과 거짓 선지자들이 일어나 큰 표적과 기사를 보이어 할 수만 있으면 택하신 자들도 미혹하게 하리라","reference":"마태복음 24:24","category":"$undefined"},{"id":"23983","book":"마태복음","book_name":"마태복음","chapter":24,"verse":25,"text":"보라 내가 너희에게 미리 말하였노라","reference":"마태복음 24:25","category":"$undefined"},{"id":"23984","book":"마태복음","book_name":"마태복음","chapter":24,"verse":26,"text":"그러면 사람들이 너희에게 말하되 보라 그리스도가 광야에 있다 하여도 나가지 말고 보라 골방에 있다 하여도 믿지 말라","reference":"마태복음 24:26","category":"$undefined"},{"id":"23985","book":"마태복음","book_name":"마태복음","chapter":24,"verse":27,"text":"번개가 동편에서 나서 서편까지 번쩍임같이 인자의 임함도 그러하리라","reference":"마태복음 24:27","category":"$undefined"},{"id":"23986","book":"마태복음","book_name":"마태복음","chapter":24,"verse":28,"text":"주검이 있는 곳에는 독수리들이 모일지니라","reference":"마태복음 24:28","category":"$undefined"},{"id":"23987","book":"마태복음","book_name":"마태복음","chapter":24,"verse":29,"text":"그 날 환난 후에 즉시 해가 어두워지며 달이 빛을 내지 아니하며 별들이 하늘에서 떨어지며 하늘의 권능들이 흔들리리라","reference":"마태복음 24:29","category":"$undefined"},{"id":"23988","book":"마태복음","book_name":"마태복음","chapter":24,"verse":30,"text":"그 때에 인자의 징조가 하늘에서 보이겠고 그 때에 땅의 모든 족속들이 통곡하며 그들이 인자가 구름을 타고 능력과 큰 영광으로 오는 것을 보리라","reference":"마태복음 24:30","category":"$undefined"},{"id":"23989","book":"마태복음","book_name":"마태복음","chapter":24,"verse":31,"text":"저가 큰 나팔 소리와 함께 천사들을 보내리니 저희가 그 택하신 자들을 하늘 이 끝에서 저 끝까지 사방에서 모으리라","reference":"마태복음 24:31","category":"$undefined"},{"id":"23990","book":"마태복음","book_name":"마태복음","chapter":24,"verse":32,"text":"무화과나무의 비유를 배우라 그 가지가 연하여지고 잎사귀를 내면 여름이 가까운 줄을 아나니","reference":"마태복음 24:32","category":"$undefined"},{"id":"23991","book":"마태복음","book_name":"마태복음","chapter":24,"verse":33,"text":"이와 같이 너희도 이 모든 일을 보거든 인자가 가까이 곧 문앞에 이른 줄 알라","reference":"마태복음 24:33","category":"$undefined"},{"id":"23992","book":"마태복음","book_name":"마태복음","chapter":24,"verse":34,"text":"내가 진실로 너희에게 말하노니 이 세대가 지나가기 전에 이 일이 다 이루리라","reference":"마태복음 24:34","category":"$undefined"},{"id":"23993","book":"마태복음","book_name":"마태복음","chapter":24,"verse":35,"text":"천지는 없어지겠으나 내 말은 없어지지 아니하리라","reference":"마태복음 24:35","category":"$undefined"},{"id":"23994","book":"마태복음","book_name":"마태복음","chapter":24,"verse":36,"text":"그러나 그 날과 그 때는 아무도 모르나니 하늘의 천사들도,아들도 모르고 오직 아버지만 아시느니라","reference":"마태복음 24:36","category":"$undefined"},{"id":"23995","book":"마태복음","book_name":"마태복음","chapter":24,"verse":37,"text":"노아의 때와 같이 인자의 임함도 그러하리라","reference":"마태복음 24:37","category":"$undefined"},{"id":"23996","book":"마태복음","book_name":"마태복음","chapter":24,"verse":38,"text":"홍수 전에 노아가 방주에 들어가던 날까지 사람들이 먹고 마시고 장가 들고 시집 가고 있으면서","reference":"마태복음 24:38","category":"$undefined"},{"id":"23997","book":"마태복음","book_name":"마태복음","chapter":24,"verse":39,"text":"홍수가 나서 저희를 다 멸하기까지 깨닫지 못하였으니 인자의 임함도 이와 같으리라","reference":"마태복음 24:39","category":"$undefined"},{"id":"23998","book":"마태복음","book_name":"마태복음","chapter":24,"verse":40,"text":"그 때에 두 사람이 밭에 있으매 하나는 데려감을 당하고 하나는 버려둠을 당할 것이요","reference":"마태복음 24:40","category":"$undefined"},{"id":"23999","book":"마태복음","book_name":"마태복음","chapter":24,"verse":41,"text":"두 여자가 매를 갈고 있으매 하나는 데려감을 당하고 하나는 버려둠을 당할 것이니라","reference":"마태복음 24:41","category":"$undefined"},{"id":"24000","book":"마태복음","book_name":"마태복음","chapter":24,"verse":42,"text":"그러므로 깨어 있으라 ! 어느 날에 너희 주가 임할는지","reference":"마태복음 24:42","category":"$undefined"},{"id":"24001","book":"마태복음","book_name":"마태복음","chapter":24,"verse":43,"text":"너희가 알지 못함이니라 너희도 아는 바니 만일 집 주인이 도적이 어느 경점에 올 줄을 알았더면 깨어 있어 그 집을 뚫지 못하게 하였으리라","reference":"마태복음 24:43","category":"$undefined"},{"id":"24002","book":"마태복음","book_name":"마태복음","chapter":24,"verse":44,"text":"이러므로 너희도 예비하고 있으라 생각지 않은 때에 인자가 오리라","reference":"마태복음 24:44","category":"$undefined"},{"id":"24003","book":"마태복음","book_name":"마태복음","chapter":24,"verse":45,"text":"충성되고 지혜 있는 종이 되어 주인에게 그 집 사람들을 맡아 때를 따라 양식을 나눠 줄 자가 누구뇨","reference":"마태복음 24:45","category":"$undefined"},{"id":"24004","book":"마태복음","book_name":"마태복음","chapter":24,"verse":46,"text":"주인이 올 때에 그 종의 이렇게 하는 것을 보면 그 종이 복이 있으리로다","reference":"마태복음 24:46","category":"$undefined"},{"id":"24005","book":"마태복음","book_name":"마태복음","chapter":24,"verse":47,"text":"내가 진실로 너희에게 이르노니 주인이 그 모든 소유를 저에게 맡기리라","reference":"마태복음 24:47","category":"$undefined"},{"id":"24006","book":"마태복음","book_name":"마태복음","chapter":24,"verse":48,"text":"만일 그 악한 종이 마음에 생각하기를 주인이 더디 오리라 하여","reference":"마태복음 24:48","category":"$undefined"},{"id":"24007","book":"마태복음","book_name":"마태복음","chapter":24,"verse":49,"text":"동무들을 때리며 술 친구들로 더불어 먹고 마시게 되면","reference":"마태복음 24:49","category":"$undefined"},{"id":"24008","book":"마태복음","book_name":"마태복음","chapter":24,"verse":50,"text":"생각지 않은 날 알지 못하는 시간에 그 종의 주인이 이르러","reference":"마태복음 24:50","category":"$undefined"},{"id":"24009","book":"마태복음","book_name":"마태복음","chapter":24,"verse":51,"text":"엄히 때리고 외식하는 자의 받는 율에 처하리니 거기서 슬피 울며 이를 갊이 있으리라","reference":"마태복음 24:51","category":"$undefined"}],"bookSlug":"matthew"}]
