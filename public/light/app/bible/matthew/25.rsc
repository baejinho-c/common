11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":25,"verses":[{"id":"24010","book":"마태복음","book_name":"마태복음","chapter":25,"verse":1,"text":"그 때에 천국은 마치 등을 들고 신랑을 맞으러 나간 열 처녀와 같다 하리니","reference":"마태복음 25:1","category":"$undefined"},{"id":"24011","book":"마태복음","book_name":"마태복음","chapter":25,"verse":2,"text":"그 중에 다섯은 미련하고 다섯은 슬기 있는지라","reference":"마태복음 25:2","category":"$undefined"},{"id":"24012","book":"마태복음","book_name":"마태복음","chapter":25,"verse":3,"text":"미련한 자들은 등을 가지되 기름을 가지지 아니하고","reference":"마태복음 25:3","category":"$undefined"},{"id":"24013","book":"마태복음","book_name":"마태복음","chapter":25,"verse":4,"text":"슬기 있는 자들은 그릇에 기름을 담아 등과 함께 가져갔더니","reference":"마태복음 25:4","category":"$undefined"},{"id":"24014","book":"마태복음","book_name":"마태복음","chapter":25,"verse":5,"text":"신랑이 더디 오므로 다 졸며 잘새","reference":"마태복음 25:5","category":"$undefined"},{"id":"24015","book":"마태복음","book_name":"마태복음","chapter":25,"verse":6,"text":"밤 중에 소리가 나되 보라 신랑이로다 맞으러 나오라 하매","reference":"마태복음 25:6","category":"$undefined"},{"id":"24016","book":"마태복음","book_name":"마태복음","chapter":25,"verse":7,"text":"이에 그 처녀들이 다 일어나 등을 준비할 새","reference":"마태복음 25:7","category":"$undefined"},{"id":"24017","book":"마태복음","book_name":"마태복음","chapter":25,"verse":8,"text":"미련한 자들이 슬기 있는 자들에게 이르되 우리 등불이 꺼져가니 너희 기름을 좀 나눠달라 하거늘","reference":"마태복음 25:8","category":"$undefined"},{"id":"24018","book":"마태복음","book_name":"마태복음","chapter":25,"verse":9,"text":"슬기 있는 자들이 대답하여 가로되 우리와 너희의 쓰기에 다 부족할까 하노니 차라리 파는 자들에게 가서 너희 쓸 것을 사라 하니","reference":"마태복음 25:9","category":"$undefined"},{"id":"24019","book":"마태복음","book_name":"마태복음","chapter":25,"verse":10,"text":"저희가 사러 간 동안에 신랑이 오므로 예비하였던 자들은 함께 혼인 잔치에 들어가고 문은 닫힌지라","reference":"마태복음 25:10","category":"$undefined"},{"id":"24020","book":"마태복음","book_name":"마태복음","chapter":25,"verse":11,"text":"그 후에 남은 처녀들이 와서 가로되 주여 주여 우리에게 열어 주소서","reference":"마태복음 25:11","category":"$undefined"},{"id":"24021","book":"마태복음","book_name":"마태복음","chapter":25,"verse":12,"text":"대답하여 가로되 진실로 너희에게 이르노니 내가 너희를 알지 못하노라 하였느니라","reference":"마태복음 25:12","category":"$undefined"},{"id":"24022","book":"마태복음","book_name":"마태복음","chapter":25,"verse":13,"text":"그런즉 깨어 있으라 너희는 그 날과 그 시를 알지 못하느니라","reference":"마태복음 25:13","category":"$undefined"},{"id":"24023","book":"마태복음","book_name":"마태복음","chapter":25,"verse":14,"text":"또 어떤 사람이 타국에 갈제 그 종들을 불러 자기 소유를 맡김과 같으니","reference":"마태복음 25:14","category":"$undefined"},{"id":"24024","book":"마태복음","book_name":"마태복음","chapter":25,"verse":15,"text":"각각 그 재능대로 하나에게는 금 다섯 달란트를, 하나에게는 두 달란트를, 하나에게는 한 달란트를 주고 떠났더니","reference":"마태복음 25:15","category":"$undefined"},{"id":"24025","book":"마태복음","book_name":"마태복음","chapter":25,"verse":16,"text":"다섯 달란트 받은자는 바로 가서 그것으로 장사하여 또 다섯 달란트를 남기고","reference":"마태복음 25:16","category":"$undefined"},{"id":"24026","book":"마태복음","book_name":"마태복음","chapter":25,"verse":17,"text":"두 달란트를 받은 자도 그같이 하여 또 두 달란트를 남겼으되","reference":"마태복음 25:17","category":"$undefined"},{"id":"24027","book":"마태복음","book_name":"마태복음","chapter":25,"verse":18,"text":"한 달란트 받은 자는 가서 땅을 파고 그 주인의 돈을 감추어 두었더니","reference":"마태복음 25:18","category":"$undefined"},{"id":"24028","book":"마태복음","book_name":"마태복음","chapter":25,"verse":19,"text":"오랜 후에 그 종들의 주인이 돌아와 저희와 회계할새","reference":"마태복음 25:19","category":"$undefined"},{"id":"24029","book":"마태복음","book_name":"마태복음","chapter":25,"verse":20,"text":"다섯 달란트 받았던 자는 다섯 달란트를 더 가지고 와서 가로되 주여 내게 다섯 달란트를 주셨는데 보소서 내가 또 다섯 달란트를 남겼나이다","reference":"마태복음 25:20","category":"$undefined"},{"id":"24030","book":"마태복음","book_name":"마태복음","chapter":25,"verse":21,"text":"그 주인이 이르되 잘 하였도다 착하고 충성된 종아 ! 네가 작은 일에 충성하였으매 내가 많은 것으로 네게 맡기리니 네 주인의 즐거움에 참예할지어다 하고","reference":"마태복음 25:21","category":"$undefined"},{"id":"24031","book":"마태복음","book_name":"마태복음","chapter":25,"verse":22,"text":"두 달란트 받았던 자도 와서 가로되 주여 내게 두 달란트를 주셨는데 보소서 내가 또 두 달란트를 남겼나이다","reference":"마태복음 25:22","category":"$undefined"},{"id":"24032","book":"마태복음","book_name":"마태복음","chapter":25,"verse":23,"text":"그 주인이 이르되 잘 하였도다 착하고 충성된 종아 ! 네가 작은 일에 충성하였으매 내가 많은 것으로 네게 맡기리니 네 주인의 즐거움에 참예할지어다 하고","reference":"마태복음 25:23","category":"$undefined"},{"id":"24033","book":"마태복음","book_name":"마태복음","chapter":25,"verse":24,"text":"한 달란트 받았던 자도 와서 가로되 주여 당신은 굳은 사람이라 심지않은 데서 거두고 헤치지 않은 데서 모으는 줄을 내가 알았으므로","reference":"마태복음 25:24","category":"$undefined"},{"id":"24034","book":"마태복음","book_name":"마태복음","chapter":25,"verse":25,"text":"두려워하여 나가서 당신의 달란트를 땅에 감추어 두었나이다 보소서 당신의 것을 받으셨나이다","reference":"마태복음 25:25","category":"$undefined"},{"id":"24035","book":"마태복음","book_name":"마태복음","chapter":25,"verse":26,"text":"그 주인이 대답하여 가로되 악하고 게으른 종아 ! 나는 심지 않은 데서 거두고 헤치지 않은 데서 모으는 줄로 네가 알았느냐","reference":"마태복음 25:26","category":"$undefined"},{"id":"24036","book":"마태복음","book_name":"마태복음","chapter":25,"verse":27,"text":"그러면 네가 마땅히 내 돈을 취리하는 자들에게나 두었다가 나로 돌아와서 내 본전과 변리를 받게 할 것이니라 하고","reference":"마태복음 25:27","category":"$undefined"},{"id":"24037","book":"마태복음","book_name":"마태복음","chapter":25,"verse":28,"text":"그에게서 그 한 달란트를 빼앗아 열 달란트를 가진 자에게 주어라","reference":"마태복음 25:28","category":"$undefined"},{"id":"24038","book":"마태복음","book_name":"마태복음","chapter":25,"verse":29,"text":"무릇 있는 자는 받아 풍족하게 되고 없는 자는 그 있는 것까지 빼앗기리라","reference":"마태복음 25:29","category":"$undefined"},{"id":"24039","book":"마태복음","book_name":"마태복음","chapter":25,"verse":30,"text":"이 무익한 종을 바깥 어두운 데로 내어 쫓으라 거기서 슬피 울며 이를 갊이 있으리라 하니라","reference":"마태복음 25:30","category":"$undefined"},{"id":"24040","book":"마태복음","book_name":"마태복음","chapter":25,"verse":31,"text":"인자가 자기 영광으로 모든 천사와 함께 올 때에 자기 영광의 보좌에 앉으리니","reference":"마태복음 25:31","category":"$undefined"},{"id":"24041","book":"마태복음","book_name":"마태복음","chapter":25,"verse":32,"text":"모든 민족을 그 앞에 모으고 각각 분별하기를 목자가 양과 염소를 분별 하는것 같이 하여","reference":"마태복음 25:32","category":"$undefined"},{"id":"24042","book":"마태복음","book_name":"마태복음","chapter":25,"verse":33,"text":"양은 그 오른편에 염소는 왼편에 두리라","reference":"마태복음 25:33","category":"$undefined"},{"id":"24043","book":"마태복음","book_name":"마태복음","chapter":25,"verse":34,"text":"그 때에 임금이 그 오른편에 있는 자들에게 이르시되 내 아버지께 복받을 자들이여 ! 나아와 창세로부터 너희를 위하여 예비된 나라를 상속하라","reference":"마태복음 25:34","category":"$undefined"},{"id":"24044","book":"마태복음","book_name":"마태복음","chapter":25,"verse":35,"text":"내가 주릴 때에 너희가 먹을 것을 주었고 목마를 때에 마시게 하였고 나그네 되었을 때에 영접하였고","reference":"마태복음 25:35","category":"$undefined"},{"id":"24045","book":"마태복음","book_name":"마태복음","chapter":25,"verse":36,"text":"벗었을 때에 옷을 입혔고, 병들었을 때에 돌아보았고, 옥에 갇혔을 때에 와서 보았느니라","reference":"마태복음 25:36","category":"$undefined"},{"id":"24046","book":"마태복음","book_name":"마태복음","chapter":25,"verse":37,"text":"이에 의인들이 대답하여 가로되 주여 우리가 어느 때에 주의 주리신 것을 보고 공궤하였으며 목마르신 것을 보고 마시게 하였나이까","reference":"마태복음 25:37","category":"$undefined"},{"id":"24047","book":"마태복음","book_name":"마태복음","chapter":25,"verse":38,"text":"어느 때에 나그네 되신 것을 보고 영접하였으며 벗으신 것을 보고 옷 입혔나이까 ?","reference":"마태복음 25:38","category":"$undefined"},{"id":"24048","book":"마태복음","book_name":"마태복음","chapter":25,"verse":39,"text":"어느 때에 병드신 것이나 옥에 갇히신 것을 보고 가서 뵈었나이까 ? 하리니","reference":"마태복음 25:39","category":"$undefined"},{"id":"24049","book":"마태복음","book_name":"마태복음","chapter":25,"verse":40,"text":"임금이 대답하여 가라사대 내가 진실로 너희에게 이르노니 너희가 여기 내 형제 중에 지극히 작은 자 하나에게 한 것이 곧 내게 한 것이니라 하시고","reference":"마태복음 25:40","category":"$undefined"},{"id":"24050","book":"마태복음","book_name":"마태복음","chapter":25,"verse":41,"text":"또 왼편에 있는 자들에게 이르시되 저주를 받은 자들아 ! 나를 떠나 마귀와 그 사자들을 위하여 예비된 영영한 불에 들어가라","reference":"마태복음 25:41","category":"$undefined"},{"id":"24051","book":"마태복음","book_name":"마태복음","chapter":25,"verse":42,"text":"내가 주릴 때에 너희가 먹을 것을 주지 아니하였고 목마를 때에 마시게 하지 아니하였고","reference":"마태복음 25:42","category":"$undefined"},{"id":"24052","book":"마태복음","book_name":"마태복음","chapter":25,"verse":43,"text":"나그네 되었을 때에 영접하지 아니하였고 벗었을 때에 옷 입히지 아니하였고 병들었을 때와 옥에 갇혔을 때에 돌아보지 아니하였느니라 하시니","reference":"마태복음 25:43","category":"$undefined"},{"id":"24053","book":"마태복음","book_name":"마태복음","chapter":25,"verse":44,"text":"저희도 대답하여 가로되 주여 우리가 어느 때에 주의 주리신 것이나 목마르신 것이나 나그네 되신 것이나 벗으신 것이나 병드신 것이나 옥에 갇히신 것을 보고 공양치 아니하더이까","reference":"마태복음 25:44","category":"$undefined"},{"id":"24054","book":"마태복음","book_name":"마태복음","chapter":25,"verse":45,"text":"이에 임금이 대답하여 가라사대 내가 진실로 너희에게 이르노니 이 지극히 작은 자 하나에게 하지 아니한 것이 곧 내게 하지 아니한 것이니라 하시리니","reference":"마태복음 25:45","category":"$undefined"},{"id":"24055","book":"마태복음","book_name":"마태복음","chapter":25,"verse":46,"text":"저희는 영벌에 의인들은 영생에 들어가리라 하시니라","reference":"마태복음 25:46","category":"$undefined"}],"bookSlug":"matthew"}]
