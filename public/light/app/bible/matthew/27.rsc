2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":27,"verses":[{"id":"24131","book":"마태복음","book_name":"마태복음","chapter":27,"verse":1,"text":"새벽에 모든 대제사장과 백성의 장로들이 예수를 죽이려고 함께 의논하고","reference":"마태복음 27:1","category":"$undefined"},{"id":"24132","book":"마태복음","book_name":"마태복음","chapter":27,"verse":2,"text":"결박하여 끌고 가서 총독 빌라도에게 넘겨 주니라","reference":"마태복음 27:2","category":"$undefined"},{"id":"24133","book":"마태복음","book_name":"마태복음","chapter":27,"verse":3,"text":"때에 예수를 판 유다가 그의 정죄됨을 보고 스스로 뉘우쳐 그 은 삼십을 대제사장들과 장로들에게 도로 갖다 주며","reference":"마태복음 27:3","category":"$undefined"},{"id":"24134","book":"마태복음","book_name":"마태복음","chapter":27,"verse":4,"text":"가로되 `내가 무죄한 피를 팔고 죄를 범하였도다' 하니 저희가 가로되 `그것이 우리에게 무슨 상관이 있느냐 네가 당하라' 하거늘","reference":"마태복음 27:4","category":"$undefined"},{"id":"24135","book":"마태복음","book_name":"마태복음","chapter":27,"verse":5,"text":"유다가 은을 성소에 던져 넣고 물러가서 스스로 목매어 죽은지라","reference":"마태복음 27:5","category":"$undefined"},{"id":"24136","book":"마태복음","book_name":"마태복음","chapter":27,"verse":6,"text":"대제사장들이 그 은을 거두며 가로되 `이것은 피 값이라 성전고에 넣어둠이 옳지 않다' 하고","reference":"마태복음 27:6","category":"$undefined"},{"id":"24137","book":"마태복음","book_name":"마태복음","chapter":27,"verse":7,"text":"의논한 후 이것으로 토기장이의 밭을 사서 나그네의 묘지를 삼았으니","reference":"마태복음 27:7","category":"$undefined"},{"id":"24138","book":"마태복음","book_name":"마태복음","chapter":27,"verse":8,"text":"그러므로 오늘날까지 그 밭을 피밭이라 일컫느니라","reference":"마태복음 27:8","category":"$undefined"},{"id":"24139","book":"마태복음","book_name":"마태복음","chapter":27,"verse":9,"text":"이에 선지자 예레미야로 하신 말씀이 이루었나니 일렀으되 저희가 그 정가된 자 곧 이스라엘 자손 중에서 정가한 자의 가격 곧 은 삼십을 가지고","reference":"마태복음 27:9","category":"$undefined"},{"id":"24140","book":"마태복음","book_name":"마태복음","chapter":27,"verse":10,"text":"토기장이의 밭 값으로 주었으니 이는 주께서 내게 명하신 바와 같으니라 하였더라","reference":"마태복음 27:10","category":"$undefined"},{"id":"24141","book":"마태복음","book_name":"마태복음","chapter":27,"verse":11,"text":"예수께서 총독 앞에 섰으매 총독이 물어 가로되 `네가 유대인의 왕이냐 ?' 예수께서 대답하시되 `네 말이 옳도다' 하시고","reference":"마태복음 27:11","category":"$undefined"},{"id":"24142","book":"마태복음","book_name":"마태복음","chapter":27,"verse":12,"text":"대제사장들과 장로들에게 고소를 당하되 아무 대답도 아니하시는지라","reference":"마태복음 27:12","category":"$undefined"},{"id":"24143","book":"마태복음","book_name":"마태복음","chapter":27,"verse":13,"text":"이에 빌라도가 이르되 `저희가 너를 쳐서 얼마나 많은 것으로 증거하는지 듣지 못하느냐 ?' 하되","reference":"마태복음 27:13","category":"$undefined"},{"id":"24144","book":"마태복음","book_name":"마태복음","chapter":27,"verse":14,"text":"한 마디도 대답지 아니하시니 총독이 심히 기이히 여기더라","reference":"마태복음 27:14","category":"$undefined"},{"id":"24145","book":"마태복음","book_name":"마태복음","chapter":27,"verse":15,"text":"명절을 당하면 총독이 무리의 소원대로 죄수 하나를 놓아 주는 전례가 있더니","reference":"마태복음 27:15","category":"$undefined"},{"id":"24146","book":"마태복음","book_name":"마태복음","chapter":27,"verse":16,"text":"그 때에 바라바라 하는 유명한 죄수가 있는데","reference":"마태복음 27:16","category":"$undefined"},{"id":"24147","book":"마태복음","book_name":"마태복음","chapter":27,"verse":17,"text":"저희가 모였을 때에 빌라도가 물어 가로되 `너희는 내가 누구를 너희에게 놓아 주기를 원하느냐 ? 바라바냐 ? 그리스도라 하는 예수냐 ?' 하니","reference":"마태복음 27:17","category":"$undefined"},{"id":"24148","book":"마태복음","book_name":"마태복음","chapter":27,"verse":18,"text":"이는 저가 그들의 시기로 예수를 넘겨준 줄 앎이러라","reference":"마태복음 27:18","category":"$undefined"},{"id":"24149","book":"마태복음","book_name":"마태복음","chapter":27,"verse":19,"text":"총독이 재판 자리에 앉았을때에 그 아내가 사람을 보내어 가로되 `저 옳은 사람에게 아무 상관도 하지 마옵소서 오늘 꿈에 내가 그 사람을 인하여 애를 많이 썼나이다' 하더라","reference":"마태복음 27:19","category":"$undefined"},{"id":"24150","book":"마태복음","book_name":"마태복음","chapter":27,"verse":20,"text":"대제사장들과 장로들이 무리를 권하여 바라바를 달라 하게 하고 예수를 멸하자 하게 하였더니","reference":"마태복음 27:20","category":"$undefined"},{"id":"24151","book":"마태복음","book_name":"마태복음","chapter":27,"verse":21,"text":"총독이 대답하여 가로되 `둘 중에 누구를 너희에게 놓아 주기를 원하느냐 ?' 가로되 `바라바로소이다'","reference":"마태복음 27:21","category":"$undefined"},{"id":"24152","book":"마태복음","book_name":"마태복음","chapter":27,"verse":22,"text":"빌라도가 가로되 `그러면 그리스도라하는 예수를 내가 어떻게 하랴' 저희가 다 가로되 `십자가에 못 박혀야 하겠나이다'","reference":"마태복음 27:22","category":"$undefined"},{"id":"24153","book":"마태복음","book_name":"마태복음","chapter":27,"verse":23,"text":"빌라도가 가로되 `어찜이뇨 무슨 악한 일을 하였느냐' 저희가 더욱 소리질러 가로되 `십자가에 못 박혀야 하겠나이다' 하는지라","reference":"마태복음 27:23","category":"$undefined"},{"id":"24154","book":"마태복음","book_name":"마태복음","chapter":27,"verse":24,"text":"빌라도가 아무 효험도 없이 도리어 민란이 나려는 것을 보고 물을 가져다가 무리 앞에서 손을 씻으며 가로되 `이 사람의 피에 대하여 나는 무죄하니 너희가 당하라'","reference":"마태복음 27:24","category":"$undefined"},{"id":"24155","book":"마태복음","book_name":"마태복음","chapter":27,"verse":25,"text":"백성이 다 대답하여 가로되 `그 피를 우리와 우리 자손에게 돌릴지어다' 하거늘","reference":"마태복음 27:25","category":"$undefined"},{"id":"24156","book":"마태복음","book_name":"마태복음","chapter":27,"verse":26,"text":"이에 바라바는 저희에게 놓아주고 예수는 채찍질하고 십자가에 못박히게 넘겨 주니라","reference":"마태복음 27:26","category":"$undefined"},{"id":"24157","book":"마태복음","book_name":"마태복음","chapter":27,"verse":27,"text":"이에 총독의 군병들이 예수를 데리고 관정 안으로 들어가서 온 군대를 그에게로 모으고","reference":"마태복음 27:27","category":"$undefined"},{"id":"24158","book":"마태복음","book_name":"마태복음","chapter":27,"verse":28,"text":"그의 옷을 벗기고 홍포를 입히며","reference":"마태복음 27:28","category":"$undefined"},{"id":"24159","book":"마태복음","book_name":"마태복음","chapter":27,"verse":29,"text":"가시 면류관을 엮어 그 머리에 씌우고 갈대를 그 오른손에 들리고 그 앞에서 무릎을 꿇고 희롱하여 가로되 `유대인의 왕이여 평안 할지어다' 하며","reference":"마태복음 27:29","category":"$undefined"},{"id":"24160","book":"마태복음","book_name":"마태복음","chapter":27,"verse":30,"text":"그에게 침 뱉고 갈대를 빼앗아 그의 머리를 치더라","reference":"마태복음 27:30","category":"$undefined"},{"id":"24161","book":"마태복음","book_name":"마태복음","chapter":27,"verse":31,"text":"희롱을 다한 후 홍포를 벗기고 도로 그의 옷을 입혀 십자가에 못 박으려고 끌고 나가니라","reference":"마태복음 27:31","category":"$undefined"},{"id":"24162","book":"마태복음","book_name":"마태복음","chapter":27,"verse":32,"text":"나가다가 시몬이란 구레네 사람을 만나매 그를 억지로 같이 가게 하여 예수의 십자가를 지웠더라","reference":"마태복음 27:32","category":"$undefined"},{"id":"24163","book":"마태복음","book_name":"마태복음","chapter":27,"verse":33,"text":"골고다 즉 해골의 곳이라는 곳에 이르러","reference":"마태복음 27:33","category":"$undefined"},{"id":"24164","book":"마태복음","book_name":"마태복음","chapter":27,"verse":34,"text":"쓸개 탄 포도주를 예수께 주어 마시게 하려 하였더니 예수께서 맛보시고 마시고자 아니하시더라","reference":"마태복음 27:34","category":"$undefined"},{"id":"24165","book":"마태복음","book_name":"마태복음","chapter":27,"verse":35,"text":"저희가 예수를 십자가에 못 박은 후에 그 옷을 제비 뽑아 나누고","reference":"마태복음 27:35","category":"$undefined"},{"id":"24166","book":"마태복음","book_name":"마태복음","chapter":27,"verse":36,"text":"거기 앉아 지키더라","reference":"마태복음 27:36","category":"$undefined"},{"id":"24167","book":"마태복음","book_name":"마태복음","chapter":27,"verse":37,"text":"그 머리 위에 이는 유대인의 왕 예수라 쓴 죄패를 붙였더라","reference":"마태복음 27:37","category":"$undefined"},{"id":"24168","book":"마태복음","book_name":"마태복음","chapter":27,"verse":38,"text":"이 때에 예수와 함께 강도 둘이 십자가에 못 박히니 하나는 우편에 하나는 좌편에 있더라","reference":"마태복음 27:38","category":"$undefined"},{"id":"24169","book":"마태복음","book_name":"마태복음","chapter":27,"verse":39,"text":"지나가는 자들은 자기 머리를 흔들며 예수를 모욕하여","reference":"마태복음 27:39","category":"$undefined"},{"id":"24170","book":"마태복음","book_name":"마태복음","chapter":27,"verse":40,"text":"가로되 `성전을 헐고 사흘에 짓는 자여 네가 만일 하나님의 아들이어든 자기를 구원하고 십자가에서 내려오라' 하며","reference":"마태복음 27:40","category":"$undefined"},{"id":"24171","book":"마태복음","book_name":"마태복음","chapter":27,"verse":41,"text":"그와 같이 대제사장들과 서기관들과 장로들과 함께 희롱하여 가로되","reference":"마태복음 27:41","category":"$undefined"},{"id":"24172","book":"마태복음","book_name":"마태복음","chapter":27,"verse":42,"text":"`저가 남은 구원하였으되 자기는 구원할 수 없도다 저가 이스라엘의 왕이로다 지금 십자가에서 내려올지어다 그러면 우리가 믿겠노라","reference":"마태복음 27:42","category":"$undefined"},{"id":"24173","book":"마태복음","book_name":"마태복음","chapter":27,"verse":43,"text":"저가 하나님을 신뢰하니 하나님이 저를 기뻐하시면 이제 구원하실지라 제 말이 나는 하나님의 아들이라 하였도다' 하며","reference":"마태복음 27:43","category":"$undefined"},{"id":"24174","book":"마태복음","book_name":"마태복음","chapter":27,"verse":44,"text":"함께 십자가에 못 박힌 강도들도 이와 같이 욕하더라","reference":"마태복음 27:44","category":"$undefined"},{"id":"24175","book":"마태복음","book_name":"마태복음","chapter":27,"verse":45,"text":"제 육시로부터 온 땅에 어두움이 임하여 제 구시까지 계속하더니","reference":"마태복음 27:45","category":"$undefined"},{"id":"24176","book":"마태복음","book_name":"마태복음","chapter":27,"verse":46,"text":"제 구시 즈음에 예수께서 크게 소리질러 가라사대 엘리 엘리 라마 사박다니 ! 하시니 이는 곧 `나의 하나님,나의 하나님, 어찌하여 나를 버리셨나이까 ?' 하는 뜻이라","reference":"마태복음 27:46","category":"$undefined"},{"id":"24177","book":"마태복음","book_name":"마태복음","chapter":27,"verse":47,"text":"거기 섰던 자 중 어떤 이들이 듣고 가로되 `이 사람이 엘리야를 부른다' 하고","reference":"마태복음 27:47","category":"$undefined"},{"id":"24178","book":"마태복음","book_name":"마태복음","chapter":27,"verse":48,"text":"그 중에 한사람이 곧 달려가서 해융을 가지고 신 포도주를 머금게 하여 갈대에 꿰어 마시우거늘","reference":"마태복음 27:48","category":"$undefined"},{"id":"24179","book":"마태복음","book_name":"마태복음","chapter":27,"verse":49,"text":"그 남은 사람들이 가로되 `가만 두어라 엘리야가 와서 저를 구원하나 보자' 하더라","reference":"마태복음 27:49","category":"$undefined"},{"id":"24180","book":"마태복음","book_name":"마태복음","chapter":27,"verse":50,"text":"예수께서 다시 크게 소리 지르시고 영혼이 떠나시다","reference":"마태복음 27:50","category":"$undefined"},{"id":"24181","book":"마태복음","book_name":"마태복음","chapter":27,"verse":51,"text":"이에 성소 휘장이 위로부터 아래까지 찢어져 둘이 되고 땅이 진동하며 바위가 터지고","reference":"마태복음 27:51","category":"$undefined"},{"id":"24182","book":"마태복음","book_name":"마태복음","chapter":27,"verse":52,"text":"무덤들이 열리며 자던 성도의 몸이 많이 일어나되","reference":"마태복음 27:52","category":"$undefined"},{"id":"24183","book":"마태복음","book_name":"마태복음","chapter":27,"verse":53,"text":"예수의 부활 후에 저희가 무덤에서 나와서 거룩한 성에 들어가 많은 사람에게 보이니라","reference":"마태복음 27:53","category":"$undefined"},{"id":"24184","book":"마태복음","book_name":"마태복음","chapter":27,"verse":54,"text":"백부장과 및 함께 예수를 지키던 자들이 지진과 그 되는 일들을 보고 심히 두려워하여 가로되 `이는 진실로 하나님의 아들이었도다' 하더라","reference":"마태복음 27:54","category":"$undefined"},{"id":"24185","book":"마태복음","book_name":"마태복음","chapter":27,"verse":55,"text":"예수를 섬기며 갈릴리에서부터 좇아 온 많은 여자가 거기 있어 멀리서 바라보고 있으니","reference":"마태복음 27:55","category":"$undefined"},{"id":"24186","book":"마태복음","book_name":"마태복음","chapter":27,"verse":56,"text":"그 중에 막달라 마리아와 또 야고보와 요셉의 어머니 마리아와 또 세베대의 아들들의 어머니도 있더라","reference":"마태복음 27:56","category":"$undefined"},{"id":"24187","book":"마태복음","book_name":"마태복음","chapter":27,"verse":57,"text":"저물었을 때에 아리마대 부자 요셉이라 하는 사람이 왔으니 그도 예수의 제자라","reference":"마태복음 27:57","category":"$undefined"},{"id":"24188","book":"마태복음","book_name":"마태복음","chapter":27,"verse":58,"text":"빌라도에게 가서 예수의 시체를 달라 하니 이에 빌라도가 내어 주라 분부하거늘","reference":"마태복음 27:58","category":"$undefined"},{"id":"24189","book":"마태복음","book_name":"마태복음","chapter":27,"verse":59,"text":"요셉이 시체를 가져다가 정한 세마포로 싸서","reference":"마태복음 27:59","category":"$undefined"},{"id":"24190","book":"마태복음","book_name":"마태복음","chapter":27,"verse":60,"text":"바위 속에 판 자기 새 무덤에 넣어두고 큰 돌을 굴려 무덤 문에 놓고 가니","reference":"마태복음 27:60","category":"$undefined"},{"id":"24191","book":"마태복음","book_name":"마태복음","chapter":27,"verse":61,"text":"거기 막달라 마리아와 다른 마리아가 무덤을 향하여 앉았더라","reference":"마태복음 27:61","category":"$undefined"},{"id":"24192","book":"마태복음","book_name":"마태복음","chapter":27,"verse":62,"text":"그 이튿날은 예비일 다음날이라 대제사장들과 바리새인들이 함께 빌라도에게 모여 가로되","reference":"마태복음 27:62","category":"$undefined"},{"id":"24193","book":"마태복음","book_name":"마태복음","chapter":27,"verse":63,"text":"`주여 저 유혹하던 자가 살았을 때에 말하되 내가 사흘 후에 다시 살아나리라 한 것을 우리가 기억하노니","reference":"마태복음 27:63","category":"$undefined"},{"id":"24194","book":"마태복음","book_name":"마태복음","chapter":27,"verse":64,"text":"그러므로 분부하여 그 무덤을 사흘까지 굳게 지키게 하소서 그의 제자들이 와서 시체를 도적질하여 가고 백성에게 말하되 그가 죽은 자 가운데서 살아났다 하면 후의 유혹이 전보다 더 될까 하나이다' 하니","reference":"마태복음 27:64","category":"$undefined"},{"id":"24195","book":"마태복음","book_name":"마태복음","chapter":27,"verse":65,"text":"빌라도가 가로되 너희에게 파숫군이 있으니 가서 힘대로 굳게 하라 하거늘","reference":"마태복음 27:65","category":"$undefined"},{"id":"24196","book":"마태복음","book_name":"마태복음","chapter":27,"verse":66,"text":"저희가 파숫군과 함께 가서 돌을 인봉하고 무덤을 굳게 하니라","reference":"마태복음 27:66","category":"$undefined"}],"bookSlug":"matthew"}]
