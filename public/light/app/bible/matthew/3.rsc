2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":3,"verses":[{"id":"23194","book":"마태복음","book_name":"마태복음","chapter":3,"verse":1,"text":"그 때에 세례 요한이 이르러 유대 광야에서 전파하여 가로되","reference":"마태복음 3:1","category":"$undefined"},{"id":"23195","book":"마태복음","book_name":"마태복음","chapter":3,"verse":2,"text":"`회개하라 ! 천국이 가까왔느니라' 하였으니","reference":"마태복음 3:2","category":"$undefined"},{"id":"23196","book":"마태복음","book_name":"마태복음","chapter":3,"verse":3,"text":"저는 선지자 이사야로 말씀하신 자라 일렀으되 광야에 외치는 자의 소리가 있어 가로되 너희는 주의 길을 예비하라 그의 첩경을 평탄케 하라 하였느니라","reference":"마태복음 3:3","category":"$undefined"},{"id":"23197","book":"마태복음","book_name":"마태복음","chapter":3,"verse":4,"text":"이 요한은 약대 털옷을 입고 허리에 가죽띠를 띠고 음식은 메뚜기와 석청이었더라","reference":"마태복음 3:4","category":"$undefined"},{"id":"23198","book":"마태복음","book_name":"마태복음","chapter":3,"verse":5,"text":"이 때에 예루살렘과 온 유대와 요단강 사방에서 다 그에게 나아와","reference":"마태복음 3:5","category":"$undefined"},{"id":"23199","book":"마태복음","book_name":"마태복음","chapter":3,"verse":6,"text":"자기들의 죄를 자복하고 요단강에서 그에게 세례를 받더니","reference":"마태복음 3:6","category":"$undefined"},{"id":"23200","book":"마태복음","book_name":"마태복음","chapter":3,"verse":7,"text":"요한이 많은 바리새인과 사두개인이 세례 베푸는 데 오는 것을 보고 이르되 `독사의 자식들아 누가 너희를 가르쳐 임박한 진노를 피하라 하더냐 ?","reference":"마태복음 3:7","category":"$undefined"},{"id":"23201","book":"마태복음","book_name":"마태복음","chapter":3,"verse":8,"text":"그러므로 회개에 합당한 열매를 맺고","reference":"마태복음 3:8","category":"$undefined"},{"id":"23202","book":"마태복음","book_name":"마태복음","chapter":3,"verse":9,"text":"속으로 아브라함이 우리 조상이라고 생각지 말라 내가 너희에게 이르노니 하나님이 능히 이 돌들로도 아브라함의 자손이 되게 하시리라","reference":"마태복음 3:9","category":"$undefined"},{"id":"23203","book":"마태복음","book_name":"마태복음","chapter":3,"verse":10,"text":"이미 도끼가 나무 뿌리에 놓였으니 좋은 열매 맺지 아니하는 나무마다 찍혀 불에 던지우리라","reference":"마태복음 3:10","category":"$undefined"},{"id":"23204","book":"마태복음","book_name":"마태복음","chapter":3,"verse":11,"text":"나는 너희로 회개케 하기 위하여 물로 세례를 주거니와 내 뒤에 오시는 이는 나보다 능력이 많으시니 나는 그의 신을 들기도 감당치 못하겠노라 그는 성령과 불로 너희에게 세례를 주실 것이요","reference":"마태복음 3:11","category":"$undefined"},{"id":"23205","book":"마태복음","book_name":"마태복음","chapter":3,"verse":12,"text":"손에 키를 들고 자기의 타작 마당을 정하게 하사 알곡은 모아 곡간에 들이고 쭉정이는 꺼지지 않는 불에 태우시리라'","reference":"마태복음 3:12","category":"$undefined"},{"id":"23206","book":"마태복음","book_name":"마태복음","chapter":3,"verse":13,"text":"이 때에 예수께서 갈릴리로서 요단강에 이르러 요한에게 세례를 받으려 하신대","reference":"마태복음 3:13","category":"$undefined"},{"id":"23207","book":"마태복음","book_name":"마태복음","chapter":3,"verse":14,"text":"요한이 말려 가로되 `내가 당신에게 세례를 받아야 할 터인데 당신이 내게로 오시나이까 ?'","reference":"마태복음 3:14","category":"$undefined"},{"id":"23208","book":"마태복음","book_name":"마태복음","chapter":3,"verse":15,"text":"예수께서 대답하여 가라사대 이제 허락하라 우리가 이와 같이 하여 모든 의를 이루는 것이 합당하니라 하신대 이에 요한이 허락하는지라","reference":"마태복음 3:15","category":"$undefined"},{"id":"23209","book":"마태복음","book_name":"마태복음","chapter":3,"verse":16,"text":"예수께서 세례를 받으시고 곧 물에서 올라오실새 하늘이 열리고 하나님의 성령이 비둘기같이 내려 자기 위에 임하심을 보시더니","reference":"마태복음 3:16","category":"$undefined"},{"id":"23210","book":"마태복음","book_name":"마태복음","chapter":3,"verse":17,"text":"하늘로서 소리가 있어 말씀하시되 `이는 내 사랑하는 아들이요 내 기뻐하는 자라' 하시니라","reference":"마태복음 3:17","category":"$undefined"}],"bookSlug":"matthew"}]
