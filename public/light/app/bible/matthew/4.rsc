2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":4,"verses":[{"id":"23211","book":"마태복음","book_name":"마태복음","chapter":4,"verse":1,"text":"그 때에 예수께서 성령에게 이끌리어 마귀에게 시험을 받으러 광야로 가사","reference":"마태복음 4:1","category":"$undefined"},{"id":"23212","book":"마태복음","book_name":"마태복음","chapter":4,"verse":2,"text":"사십 일을 밤낮으로 금식하신 후에 주리신지라","reference":"마태복음 4:2","category":"$undefined"},{"id":"23213","book":"마태복음","book_name":"마태복음","chapter":4,"verse":3,"text":"시험하는 자가 예수께 나아가서 가로되 `네가 만일 하나님의 아들이어든 명하여 이 돌들이 떡덩이가 되게 하라'","reference":"마태복음 4:3","category":"$undefined"},{"id":"23214","book":"마태복음","book_name":"마태복음","chapter":4,"verse":4,"text":"예수께서 대답하여 가라사대 기록되었으되 사람이 떡으로만 살것이 아니요 하나님의 입으로 나오는 모든 말씀으로 살 것이라 하였느니라 하시니라","reference":"마태복음 4:4","category":"$undefined"},{"id":"23215","book":"마태복음","book_name":"마태복음","chapter":4,"verse":5,"text":"이에 마귀가 예수를 거룩한 성으로 데려다가 성전 꼭대기에 세우고","reference":"마태복음 4:5","category":"$undefined"},{"id":"23216","book":"마태복음","book_name":"마태복음","chapter":4,"verse":6,"text":"가로되 `네가 만일 하나님의 아들이어든 뛰어내리라 기록하였으되 저가 너를 위하여 그 사자들을 명하시리니 저희가 손으로 너를 받들어 발이 돌에 부딪히지 않게 하리로다 하였느니라'","reference":"마태복음 4:6","category":"$undefined"},{"id":"23217","book":"마태복음","book_name":"마태복음","chapter":4,"verse":7,"text":"예수께서 이르시되 또 기록되었으되 주 너의 하나님을 시험치 말라 하였느니라 하신대","reference":"마태복음 4:7","category":"$undefined"},{"id":"23218","book":"마태복음","book_name":"마태복음","chapter":4,"verse":8,"text":"마귀가 또 그를 데리고 지극히 높은 산으로 가서 천하 만국과 그 영광을 보여","reference":"마태복음 4:8","category":"$undefined"},{"id":"23219","book":"마태복음","book_name":"마태복음","chapter":4,"verse":9,"text":"가로되 `만일 내게 엎드려 경배하면 이 모든 것을 네게 주리라'","reference":"마태복음 4:9","category":"$undefined"},{"id":"23220","book":"마태복음","book_name":"마태복음","chapter":4,"verse":10,"text":"이에 예수께서 말씀하시되 사단아 ! 물러가라 기록되었으되 주 너의 하나님께 경배하고 다만 그를 섬기라 ! 하였느니라","reference":"마태복음 4:10","category":"$undefined"},{"id":"23221","book":"마태복음","book_name":"마태복음","chapter":4,"verse":11,"text":"이에 마귀는 예수를 떠나고 천사들이 나아와서 수종드니라","reference":"마태복음 4:11","category":"$undefined"},{"id":"23222","book":"마태복음","book_name":"마태복음","chapter":4,"verse":12,"text":"예수께서 요한의 잡힘을 들으시고 갈릴리로 물러 가셨다가","reference":"마태복음 4:12","category":"$undefined"},{"id":"23223","book":"마태복음","book_name":"마태복음","chapter":4,"verse":13,"text":"나사렛을 떠나 스불론과 납달리 지경 해변에 있는 가버나움에 가서 사시니","reference":"마태복음 4:13","category":"$undefined"},{"id":"23224","book":"마태복음","book_name":"마태복음","chapter":4,"verse":14,"text":"이는 선지자 이사야로 하신 말씀을 이루려 하심이라 일렀으되","reference":"마태복음 4:14","category":"$undefined"},{"id":"23225","book":"마태복음","book_name":"마태복음","chapter":4,"verse":15,"text":"스불론 땅과 납달리 땅과 요단강 저편 해변 길과 이방의 갈릴리여 !","reference":"마태복음 4:15","category":"$undefined"},{"id":"23226","book":"마태복음","book_name":"마태복음","chapter":4,"verse":16,"text":"흑암에 앉은 백성이 큰 빛을 보았고 사망의 땅과 그늘에 앉은 자들에게 빛이 비취었도다 하였느니라","reference":"마태복음 4:16","category":"$undefined"},{"id":"23227","book":"마태복음","book_name":"마태복음","chapter":4,"verse":17,"text":"이 때부터 예수께서 비로소 전파하여 가라사대 회개하라 ! 천국이 가까왔느니라 ! 하시더라","reference":"마태복음 4:17","category":"$undefined"},{"id":"23228","book":"마태복음","book_name":"마태복음","chapter":4,"verse":18,"text":"갈릴리 해변에 다니시다가 두 형제 곧 베드로라 하는 시몬과 그 형제 안드레가 바다에 그물 던지는 것을 보시니 저희는 어부라","reference":"마태복음 4:18","category":"$undefined"},{"id":"23229","book":"마태복음","book_name":"마태복음","chapter":4,"verse":19,"text":"말씀하시되 나를 따라 오너라 ! 내가 너희로 사람을 낚는 어부가 되게 하리라 하시니","reference":"마태복음 4:19","category":"$undefined"},{"id":"23230","book":"마태복음","book_name":"마태복음","chapter":4,"verse":20,"text":"저희가 곧 그물을 버려 두고 예수를 좇으니라","reference":"마태복음 4:20","category":"$undefined"},{"id":"23231","book":"마태복음","book_name":"마태복음","chapter":4,"verse":21,"text":"거기서 더 가시다가 다른 두 형제 곧 세베대의 아들 야고보와 그 형제 요한이 그 부친 세베대와 한가지로 배에서 그물 깁는 것을 보시고 부르시니","reference":"마태복음 4:21","category":"$undefined"},{"id":"23232","book":"마태복음","book_name":"마태복음","chapter":4,"verse":22,"text":"저희가 곧 배와 부친을 버려두고 예수를 좇으니라","reference":"마태복음 4:22","category":"$undefined"},{"id":"23233","book":"마태복음","book_name":"마태복음","chapter":4,"verse":23,"text":"예수께서 온 갈릴리에 두루 다니사 저희 회당에서 가르치시며 천국 복음을 전파하시며 백성 중에 모든 병과 모든 약한 것을 고치시니","reference":"마태복음 4:23","category":"$undefined"},{"id":"23234","book":"마태복음","book_name":"마태복음","chapter":4,"verse":24,"text":"그의 소문이 온 수리아에 퍼진지라 사람들이 모든 앓는 자 곧 각색병과, 고통에 걸린 자, 귀신 들린 자, 간질하는 자, 중풍병자들을 데려오니 저희를 고치시더라","reference":"마태복음 4:24","category":"$undefined"},{"id":"23235","book":"마태복음","book_name":"마태복음","chapter":4,"verse":25,"text":"갈릴리와 데가볼리와 예루살렘과 유대와 요단강 건너 편에서 허다한 무리가 좇으니라","reference":"마태복음 4:25","category":"$undefined"}],"bookSlug":"matthew"}]
