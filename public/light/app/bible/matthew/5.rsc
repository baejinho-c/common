2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":5,"verses":[{"id":"23236","book":"마태복음","book_name":"마태복음","chapter":5,"verse":1,"text":"예수께서 무리를 보시고 산에 올라가 앉으시니 제자들이 나아온지라","reference":"마태복음 5:1","category":"$undefined"},{"id":"23237","book":"마태복음","book_name":"마태복음","chapter":5,"verse":2,"text":"입을 열어 가르쳐 가라사대","reference":"마태복음 5:2","category":"$undefined"},{"id":"23238","book":"마태복음","book_name":"마태복음","chapter":5,"verse":3,"text":"심령이 가난한 자는 복이 있나니 천국이 저희 것임이요","reference":"마태복음 5:3","category":"$undefined"},{"id":"23239","book":"마태복음","book_name":"마태복음","chapter":5,"verse":4,"text":"애통하는 자는 복이 있나니 저희가 위로를 받을 것임이요","reference":"마태복음 5:4","category":"$undefined"},{"id":"23240","book":"마태복음","book_name":"마태복음","chapter":5,"verse":5,"text":"온유한 자는 복이 있나니 저희가 땅을 기업으로 받을 것임이요","reference":"마태복음 5:5","category":"$undefined"},{"id":"23241","book":"마태복음","book_name":"마태복음","chapter":5,"verse":6,"text":"의에 주리고 목마른 자는 복이 있나니 저희가 배부를 것임이요","reference":"마태복음 5:6","category":"$undefined"},{"id":"23242","book":"마태복음","book_name":"마태복음","chapter":5,"verse":7,"text":"긍휼히 여기는 자는 복이 있나니 저희가 긍휼히 여김을 받을 것임이요","reference":"마태복음 5:7","category":"$undefined"},{"id":"23243","book":"마태복음","book_name":"마태복음","chapter":5,"verse":8,"text":"마음이 청결한 자는 복이 있나니 저희가 하나님을 볼 것임이요","reference":"마태복음 5:8","category":"$undefined"},{"id":"23244","book":"마태복음","book_name":"마태복음","chapter":5,"verse":9,"text":"화평케 하는 자는 복이 있나니 저희가 하나님의 아들이라 일컬음을 받을 것임이요","reference":"마태복음 5:9","category":"$undefined"},{"id":"23245","book":"마태복음","book_name":"마태복음","chapter":5,"verse":10,"text":"의를 위하여 핍박을 받은 자는 복이 있나니 천국이 저희 것임이라","reference":"마태복음 5:10","category":"$undefined"},{"id":"23246","book":"마태복음","book_name":"마태복음","chapter":5,"verse":11,"text":"나를 인하여 너희를 욕하고 핍박하고 거짓으로 너희를 거스려 모든 악한 말을 할 때에는 너희에게 복이 있나니","reference":"마태복음 5:11","category":"$undefined"},{"id":"23247","book":"마태복음","book_name":"마태복음","chapter":5,"verse":12,"text":"기뻐하고 즐거워하라 ! 하늘에서 너희의 상이 큼이라 너희 전에 있던 선지자들을 이같이 핍박하였느니라","reference":"마태복음 5:12","category":"$undefined"},{"id":"23248","book":"마태복음","book_name":"마태복음","chapter":5,"verse":13,"text":"너희는 세상의 소금이니 소금이 만일 그 맛을 잃으면 무엇으로 짜게 하리요 후에는 아무 쓸데 없어 다만 밖에 버리워 사람에게 밟힐 뿐이니라","reference":"마태복음 5:13","category":"$undefined"},{"id":"23249","book":"마태복음","book_name":"마태복음","chapter":5,"verse":14,"text":"너희는 세상의 빛이라 ! 산 위에 있는 동네가 숨기우지 못할 것이요","reference":"마태복음 5:14","category":"$undefined"},{"id":"23250","book":"마태복음","book_name":"마태복음","chapter":5,"verse":15,"text":"사람이 등불을 켜서 말 아래 두지 아니하고 등경 위에 두나니 이러므로 집안 모든 사람에게 비취느니라","reference":"마태복음 5:15","category":"$undefined"},{"id":"23251","book":"마태복음","book_name":"마태복음","chapter":5,"verse":16,"text":"이같이 너희 빛을 사람 앞에 비취게 하여 저희로 너희 착한 행실을 보고 하늘에 계신 너희 아버지께 영광을 돌리게 하라","reference":"마태복음 5:16","category":"$undefined"},{"id":"23252","book":"마태복음","book_name":"마태복음","chapter":5,"verse":17,"text":"내가 율법이나 선지자나 폐하러 온 줄로 생각지 말라 폐하러 온 것이 아니요 완전케 하려 함이로다","reference":"마태복음 5:17","category":"$undefined"},{"id":"23253","book":"마태복음","book_name":"마태복음","chapter":5,"verse":18,"text":"진실로 너희에게 이르노니 천지가 없어지기 전에는 율법의 일점 일획이라도 반드시 없어지지 아니하고 다 이루리라","reference":"마태복음 5:18","category":"$undefined"},{"id":"23254","book":"마태복음","book_name":"마태복음","chapter":5,"verse":19,"text":"그러므로 누구든지 이 계명 중에 지극히 작은 것 하나라도 버리고 또 그같이 사람을 가르치는 자는 천국에서 지극히 작다 일컬음을 받을 것이요 누구든지 이를 행하며 가르치는 자는 천국에서 크다 일컬음을 받으리라","reference":"마태복음 5:19","category":"$undefined"},{"id":"23255","book":"마태복음","book_name":"마태복음","chapter":5,"verse":20,"text":"내가 너희에게 이르노니 너희 의가 서기관과 바리새인보다 더 낫지 못하면 결단코 천국에 들어가지 못하리라","reference":"마태복음 5:20","category":"$undefined"},{"id":"23256","book":"마태복음","book_name":"마태복음","chapter":5,"verse":21,"text":"옛 사람에게 말한 바 살인치 말라 누구든지 살인하면 심판을 받게 되리라 하였다는 것을 너희가 들었으나","reference":"마태복음 5:21","category":"$undefined"},{"id":"23257","book":"마태복음","book_name":"마태복음","chapter":5,"verse":22,"text":"나는 너희에게 이르노니 형제에게 노하는 자마다 심판을 받게 되고 형제를 대하여 라가라 하는 자는 공회에 잡히게 되고 미련한 놈이라 하는 자는 지옥 불에 들어가게 되리라","reference":"마태복음 5:22","category":"$undefined"},{"id":"23258","book":"마태복음","book_name":"마태복음","chapter":5,"verse":23,"text":"그러므로 예물을 제단에 드리다가 거기서 네 형제에게 원망들을 만한 일이 있는 줄 생각나거든","reference":"마태복음 5:23","category":"$undefined"},{"id":"23259","book":"마태복음","book_name":"마태복음","chapter":5,"verse":24,"text":"예물을 제단 앞에 두고 먼저 가서 형제와 화목하고 그 후에 와서 예물을 드리라","reference":"마태복음 5:24","category":"$undefined"},{"id":"23260","book":"마태복음","book_name":"마태복음","chapter":5,"verse":25,"text":"너를 송사하는 자와 함께 길에 있을 때에 급히 사화하라 그 송사하는 자가 너를 재판관에게 내어주고 재판관이 관예에게 내어주어 옥에 가둘까 염려하라","reference":"마태복음 5:25","category":"$undefined"},{"id":"23261","book":"마태복음","book_name":"마태복음","chapter":5,"verse":26,"text":"진실로 네게 이르노니 네가 호리라도 남김이 없이 다 갚기 전에는 결단코 거기서 나오지 못하리라","reference":"마태복음 5:26","category":"$undefined"},{"id":"23262","book":"마태복음","book_name":"마태복음","chapter":5,"verse":27,"text":"또 간음치 말라 하였다는 것을 너희가 들었으나","reference":"마태복음 5:27","category":"$undefined"},{"id":"23263","book":"마태복음","book_name":"마태복음","chapter":5,"verse":28,"text":"나는 너희에게 이르노니 여자를 보고 음욕을 품는 자마다 마음에 이미 간음하였느니라","reference":"마태복음 5:28","category":"$undefined"},{"id":"23264","book":"마태복음","book_name":"마태복음","chapter":5,"verse":29,"text":"만일 네 오른눈이 너로 실족케 하거든 빼어 내버리라 네 백체 중 하나가 없어지고 온 몸이 지옥에 던지우지 않는 것이 유익하며","reference":"마태복음 5:29","category":"$undefined"},{"id":"23265","book":"마태복음","book_name":"마태복음","chapter":5,"verse":30,"text":"또한 만일 네 오른손이 너로 실족케 하거든 찍어 내버리라 네 백체 중 하나가 없어지고 온 몸이 지옥에 던지우지 않는 것이 유익하니라","reference":"마태복음 5:30","category":"$undefined"},{"id":"23266","book":"마태복음","book_name":"마태복음","chapter":5,"verse":31,"text":"또 일렀으되 누구든지 아내를 버리거든 이혼증서를 줄 것이라 하였으나","reference":"마태복음 5:31","category":"$undefined"},{"id":"23267","book":"마태복음","book_name":"마태복음","chapter":5,"verse":32,"text":"나는 너희에게 이르노니 누구든지 음행한 연고 없이 아내를 버리면 이는 저로 간음하게 함이요 또 누구든지 버린 여자에게 장가 드는 자도 간음함이니라","reference":"마태복음 5:32","category":"$undefined"},{"id":"23268","book":"마태복음","book_name":"마태복음","chapter":5,"verse":33,"text":"또 옛 사람에게 말한 바 헛 맹세를 하지 말고 네 맹세한 것을 주께 지키라 하였다는 것을 너희가 들었으나","reference":"마태복음 5:33","category":"$undefined"},{"id":"23269","book":"마태복음","book_name":"마태복음","chapter":5,"verse":34,"text":"나는 너희에게 이르노니 도무지 맹세하지 말지니 하늘로도 말라 이는 하나님의 보좌임이요","reference":"마태복음 5:34","category":"$undefined"},{"id":"23270","book":"마태복음","book_name":"마태복음","chapter":5,"verse":35,"text":"땅으로도 말라 이는 하나님의 발등상임이요 예루살렘으로도 말라 이는 큰 임금의 성임이요","reference":"마태복음 5:35","category":"$undefined"},{"id":"23271","book":"마태복음","book_name":"마태복음","chapter":5,"verse":36,"text":"네 머리로도 말라 이는 네가 한 터럭도 희고 검게 할 수 없음이라","reference":"마태복음 5:36","category":"$undefined"},{"id":"23272","book":"마태복음","book_name":"마태복음","chapter":5,"verse":37,"text":"오직 너희 말은 옳다 옳다,아니라 아니라 하라 이에서 지나는 것은 악으로 좇아 나느니라","reference":"마태복음 5:37","category":"$undefined"},{"id":"23273","book":"마태복음","book_name":"마태복음","chapter":5,"verse":38,"text":"또 눈은 눈으로, 이는 이로 갚으라 하였다는 것을 너희가 들었으나","reference":"마태복음 5:38","category":"$undefined"},{"id":"23274","book":"마태복음","book_name":"마태복음","chapter":5,"verse":39,"text":"나는 너희에게 이르노니 악한 자를 대적지 말라 누구든지 네 오른편 뺨을 치거든 왼편도 돌려 대며","reference":"마태복음 5:39","category":"$undefined"},{"id":"23275","book":"마태복음","book_name":"마태복음","chapter":5,"verse":40,"text":"또 너를 송사하여 속옷을 가지고자 하는 자에게 겉옷까지도 가지게 하며","reference":"마태복음 5:40","category":"$undefined"},{"id":"23276","book":"마태복음","book_name":"마태복음","chapter":5,"verse":41,"text":"또 누구든지 너로 억지로 오리를 가게 하거든 그 사람과 십리를 동행하고","reference":"마태복음 5:41","category":"$undefined"},{"id":"23277","book":"마태복음","book_name":"마태복음","chapter":5,"verse":42,"text":"네게 구하는 자에게 주며 네게 꾸고자 하는 자에게 거절하지 말라","reference":"마태복음 5:42","category":"$undefined"},{"id":"23278","book":"마태복음","book_name":"마태복음","chapter":5,"verse":43,"text":"또 네 이웃을 사랑하고 네 원수를 미워하라 하였다는 것을 너희가 들었으나","reference":"마태복음 5:43","category":"$undefined"},{"id":"23279","book":"마태복음","book_name":"마태복음","chapter":5,"verse":44,"text":"나는 너희에게 이르노니 너희 원수를 사랑하며 너희를 핍박하는 자를 위하여 기도하라","reference":"마태복음 5:44","category":"$undefined"},{"id":"23280","book":"마태복음","book_name":"마태복음","chapter":5,"verse":45,"text":"이같이 한즉 하늘에 계신 너희 아버지의 아들이 되리니 이는 하나님이 그 해를 악인과 선인에게 비취게 하시며 비를 의로운 자와 불의한 자에게 내리우심이니라","reference":"마태복음 5:45","category":"$undefined"},{"id":"23281","book":"마태복음","book_name":"마태복음","chapter":5,"verse":46,"text":"너희가 너희를 사랑하는 자를 사랑하면 무슨 상이 있으리요 세리도 이같이 아니하느냐","reference":"마태복음 5:46","category":"$undefined"},{"id":"23282","book":"마태복음","book_name":"마태복음","chapter":5,"verse":47,"text":"또 너희가 너희 형제에게만 문안하면 남보다 더 하는 것이 무엇이냐 이방인들도 이같이 아니하느냐","reference":"마태복음 5:47","category":"$undefined"},{"id":"23283","book":"마태복음","book_name":"마태복음","chapter":5,"verse":48,"text":"그러므로 하늘에 계신 너희 아버지의 온전하심과 같이 너희도 온전하라","reference":"마태복음 5:48","category":"$undefined"}],"bookSlug":"matthew"}]
