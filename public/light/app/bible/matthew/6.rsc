2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":6,"verses":[{"id":"23284","book":"마태복음","book_name":"마태복음","chapter":6,"verse":1,"text":"사람에게 보이려고 그들 앞에서 너희 의를 행치 않도록 주의하라 그렇지 아니하면 하늘에 계신 너희 아버지께 상을 얻지 못하느니라","reference":"마태복음 6:1","category":"$undefined"},{"id":"23285","book":"마태복음","book_name":"마태복음","chapter":6,"verse":2,"text":"그러므로 구제할 때에 외식하는 자가 사람에게 영광을 얻으려고 회당과 거리에서 하는 것같이 너희 앞에 나팔을 불지 말라 진실로 너희에게 이르노니 저희는 자기 상을 이미 받았느니라","reference":"마태복음 6:2","category":"$undefined"},{"id":"23286","book":"마태복음","book_name":"마태복음","chapter":6,"verse":3,"text":"너는 구제할 때에 오른손의 하는 것을 왼손이 모르게 하여","reference":"마태복음 6:3","category":"$undefined"},{"id":"23287","book":"마태복음","book_name":"마태복음","chapter":6,"verse":4,"text":"네 구제함이 은밀하게 하라 은밀한 중에 보시는 너의 아버지가 갚으시리라","reference":"마태복음 6:4","category":"$undefined"},{"id":"23288","book":"마태복음","book_name":"마태복음","chapter":6,"verse":5,"text":"또 너희가 기도할 때에 외식하는 자와 같이 되지 말라 저희는 사람에게 보이려고 회당과 큰 거리 어귀에 서서 기도하기를 좋아하느니라 내가 진실로 너희에게 이르노니 저희는 자기 상을 이미 받았느니라","reference":"마태복음 6:5","category":"$undefined"},{"id":"23289","book":"마태복음","book_name":"마태복음","chapter":6,"verse":6,"text":"너는 기도할 때에 네 골방에 들어가 문을 닫고 은밀한 중에 계신 네 아버지께 기도하라 은밀한 중에 보시는 네 아버지께서 갚으시리라","reference":"마태복음 6:6","category":"$undefined"},{"id":"23290","book":"마태복음","book_name":"마태복음","chapter":6,"verse":7,"text":"또 기도할 때에 이방인과 같이 중언부언하지 말라 저희는 말을 많이 하여야 들으실 줄 생각하느니라","reference":"마태복음 6:7","category":"$undefined"},{"id":"23291","book":"마태복음","book_name":"마태복음","chapter":6,"verse":8,"text":"그러므로 저희를 본받지 말라 구하기 전에 너희에게 있어야 할 것을 하나님 너희 아버지께서 아시느니라","reference":"마태복음 6:8","category":"$undefined"},{"id":"23292","book":"마태복음","book_name":"마태복음","chapter":6,"verse":9,"text":"그러므로 너희는 이렇게 기도하라 하늘에 계신 우리 아버지여 ! 이름이 거룩히 여김을 받으시오며","reference":"마태복음 6:9","category":"$undefined"},{"id":"23293","book":"마태복음","book_name":"마태복음","chapter":6,"verse":10,"text":"나라이 임하옵시며 뜻이 하늘에서 이룬 것같이 땅에서도 이루어지이다","reference":"마태복음 6:10","category":"$undefined"},{"id":"23294","book":"마태복음","book_name":"마태복음","chapter":6,"verse":11,"text":"오늘날 우리에게 일용할 양식을 주옵시고","reference":"마태복음 6:11","category":"$undefined"},{"id":"23295","book":"마태복음","book_name":"마태복음","chapter":6,"verse":12,"text":"우리가 우리에게 죄 지은 자를 사하여 준 것 같이 우리 죄를 사하여 주옵시고","reference":"마태복음 6:12","category":"$undefined"},{"id":"23296","book":"마태복음","book_name":"마태복음","chapter":6,"verse":13,"text":"우리를 시험에 들게 하지 마옵시고 다만 악에서 구하옵소서 (나라와 권세와 영광이 아버지께 영원히 있사옵나이다 아멘)","reference":"마태복음 6:13","category":"$undefined"},{"id":"23297","book":"마태복음","book_name":"마태복음","chapter":6,"verse":14,"text":"너희가 사람의 과실을 용서하면 너희 천부께서도 너희 과실을 용서하시려니와","reference":"마태복음 6:14","category":"$undefined"},{"id":"23298","book":"마태복음","book_name":"마태복음","chapter":6,"verse":15,"text":"너희가 사람의 과실을 용서하지 아니하면 너희 아버지께서도 너희 과실을 용서하지 아니하시리라","reference":"마태복음 6:15","category":"$undefined"},{"id":"23299","book":"마태복음","book_name":"마태복음","chapter":6,"verse":16,"text":"금식할 때에 너희는 외식하는 자들과 같이 슬픈 기색을 내지 말라 저희는 금식하는 것을 사람에게 보이려고 얼굴을 흉하게 하느니라 내가 진실로 너희에게 이르노니 저희는 자기 상을 이미 받았느니라","reference":"마태복음 6:16","category":"$undefined"},{"id":"23300","book":"마태복음","book_name":"마태복음","chapter":6,"verse":17,"text":"너는 금식할 때에 머리에 기름을 바르고 얼굴을 씻으라","reference":"마태복음 6:17","category":"$undefined"},{"id":"23301","book":"마태복음","book_name":"마태복음","chapter":6,"verse":18,"text":"이는 금식하는 자로 사람에게 보이지 않고 오직 은밀한 중에 계신 네 아버지께 보이게 하려 함이라 은밀한 중에 보시는 네 아버께서 갚으시리라","reference":"마태복음 6:18","category":"$undefined"},{"id":"23302","book":"마태복음","book_name":"마태복음","chapter":6,"verse":19,"text":"너희를 위하여 보물을 땅에 쌓아 두지 말라 거기는 좀과 동록이 해하며 동록이 구멍을 뚫고 도적질하느니라","reference":"마태복음 6:19","category":"$undefined"},{"id":"23303","book":"마태복음","book_name":"마태복음","chapter":6,"verse":20,"text":"오직 ! 너희를 위하여 보물을 하늘에 쌓아 두라 저기는 좀이나 동록이 해하지 못하며 도적이 구멍을 뚫지도 못하고 도적질도 못하느니라","reference":"마태복음 6:20","category":"$undefined"},{"id":"23304","book":"마태복음","book_name":"마태복음","chapter":6,"verse":21,"text":"네 보물 있는 그 곳에는 네 마음도 있느니라 !","reference":"마태복음 6:21","category":"$undefined"},{"id":"23305","book":"마태복음","book_name":"마태복음","chapter":6,"verse":22,"text":"눈은 몸의 등불이니 그러므로 네 눈이 성하면 온 몸이 밝을 것이요","reference":"마태복음 6:22","category":"$undefined"},{"id":"23306","book":"마태복음","book_name":"마태복음","chapter":6,"verse":23,"text":"눈이 나쁘면 온 몸이 어두울 것이니 그러므로 네게 있는 빛이 어두우면 그 어두움이 얼마나 하겠느뇨","reference":"마태복음 6:23","category":"$undefined"},{"id":"23307","book":"마태복음","book_name":"마태복음","chapter":6,"verse":24,"text":"한사람이 두 주인을 섬기지 못 할 것이니 혹 이를 미워하며 저를 사랑하거나 혹 이를 중히 여기며 저를 경히 여김이라 너희가 하나님과 재물을 겸하여 섬기지 못하느니라","reference":"마태복음 6:24","category":"$undefined"},{"id":"23308","book":"마태복음","book_name":"마태복음","chapter":6,"verse":25,"text":"그러므로 내가 너희에게 이르노니 목숨을 위하여 무엇을 먹을까 ? 무엇을 마실까 ? 몸을 위하여 무엇을 입을까 ? 염려하지 말라 목숨이 음식보다 중하지 아니하며 몸이 의복보다 중하지 아니하냐","reference":"마태복음 6:25","category":"$undefined"},{"id":"23309","book":"마태복음","book_name":"마태복음","chapter":6,"verse":26,"text":"공중의 새를 보라 심지도 않고 거두지도 않고 창고에 모아 들이지도 아니하되 너희 천부께서 기르시나니 너희는 이것들보다 귀하지 아니하냐 ?","reference":"마태복음 6:26","category":"$undefined"},{"id":"23310","book":"마태복음","book_name":"마태복음","chapter":6,"verse":27,"text":"너희 중에 누가 염려함으로 그 키를 한 자나 더할 수 있느냐 ?","reference":"마태복음 6:27","category":"$undefined"},{"id":"23311","book":"마태복음","book_name":"마태복음","chapter":6,"verse":28,"text":"또 너희가 어찌 의복을 위하여 염려하느냐 들의 백합화가 어떻게 자라는가 생각하여 보아라 수고도 아니하고 길쌈도 아니하느니라","reference":"마태복음 6:28","category":"$undefined"},{"id":"23312","book":"마태복음","book_name":"마태복음","chapter":6,"verse":29,"text":"그러나 내가 너희에게 말하노니 솔로몬의 모든 영광으로도 입은 것이 이 꽃 하나만 같지 못하였느니라","reference":"마태복음 6:29","category":"$undefined"},{"id":"23313","book":"마태복음","book_name":"마태복음","chapter":6,"verse":30,"text":"오늘 있다가 내일 아궁이에 던지우는 들풀도 하나님이 이렇게 입히시거든 하물며 너희일까보냐 믿음이 적은 자들아 !","reference":"마태복음 6:30","category":"$undefined"},{"id":"23314","book":"마태복음","book_name":"마태복음","chapter":6,"verse":31,"text":"그러므로 염려하여 이르기를 무엇을 먹을까 ? 무엇을 마실까 ? 무엇을 입을까 ? 하지 말라","reference":"마태복음 6:31","category":"$undefined"},{"id":"23315","book":"마태복음","book_name":"마태복음","chapter":6,"verse":32,"text":"이는 다 이방인들이 구하는 것이라 너희 천부께서 이 모든 것이 너희에게 있어야 할 줄을 아시느니라","reference":"마태복음 6:32","category":"$undefined"},{"id":"23316","book":"마태복음","book_name":"마태복음","chapter":6,"verse":33,"text":"너희는 먼저 그의 나라와 그의 의를 구하라 ! 그리하면 이 모든 것을 너희에게 더하시리라","reference":"마태복음 6:33","category":"$undefined"},{"id":"23317","book":"마태복음","book_name":"마태복음","chapter":6,"verse":34,"text":"그러므로 내일 일을 위하여 염려하지 말라 내일 일은 내일 염려할 것이요 한 날 괴로움은 그 날에 족하니라","reference":"마태복음 6:34","category":"$undefined"}],"bookSlug":"matthew"}]
