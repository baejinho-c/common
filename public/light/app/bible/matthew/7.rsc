2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":7,"verses":[{"id":"23318","book":"마태복음","book_name":"마태복음","chapter":7,"verse":1,"text":"비판을 받지 아니하려거든 비판하지 말라","reference":"마태복음 7:1","category":"$undefined"},{"id":"23319","book":"마태복음","book_name":"마태복음","chapter":7,"verse":2,"text":"너희의 비판하는 그 비판으로 너희가 비판을 받을 것이요 너희의 헤아리는 그 헤아림으로 너희가 헤아림을 받을 것이니라","reference":"마태복음 7:2","category":"$undefined"},{"id":"23320","book":"마태복음","book_name":"마태복음","chapter":7,"verse":3,"text":"어찌하여 형제의 눈 속에 있는 티는 보고 네 눈 속에 있는 들보는 깨닫지 못하느냐 ?","reference":"마태복음 7:3","category":"$undefined"},{"id":"23321","book":"마태복음","book_name":"마태복음","chapter":7,"verse":4,"text":"보라 네 눈 속에 들보가 있는데 어찌하여 형제에게 말하기를 나로 네 눈 속에 있는 티를 빼게 하라 하겠느냐 ?","reference":"마태복음 7:4","category":"$undefined"},{"id":"23322","book":"마태복음","book_name":"마태복음","chapter":7,"verse":5,"text":"외식하는 자여 ! 먼저 네 눈 속에서 들보를 빼어라 그 후에야 밝히 보고 형제의 눈 속에서 티를 빼리라","reference":"마태복음 7:5","category":"$undefined"},{"id":"23323","book":"마태복음","book_name":"마태복음","chapter":7,"verse":6,"text":"거룩한 것을 개에게 주지 말며 너희 진주를 돼지 앞에 던지지 말라 저희가 그것을 발로 밟고 돌이켜 너희를 찢어 상할까 염려하라","reference":"마태복음 7:6","category":"$undefined"},{"id":"23324","book":"마태복음","book_name":"마태복음","chapter":7,"verse":7,"text":"구하라 ! 그러면 너희에게 주실 것이요 찾으라 ! 그러면 찾을 것이요 문을 두드리라 ! 그러면 너희에게 열릴 것이니","reference":"마태복음 7:7","category":"$undefined"},{"id":"23325","book":"마태복음","book_name":"마태복음","chapter":7,"verse":8,"text":"구하는 이마다 얻을 것이요 찾는 이가 찾을 것이요 두드리는 이에게 열릴 것이니라","reference":"마태복음 7:8","category":"$undefined"},{"id":"23326","book":"마태복음","book_name":"마태복음","chapter":7,"verse":9,"text":"너희 중에 누가 아들이 떡을 달라 하면 돌을 주며","reference":"마태복음 7:9","category":"$undefined"},{"id":"23327","book":"마태복음","book_name":"마태복음","chapter":7,"verse":10,"text":"생선을 달라 하면 뱀을 줄 사람이 있겠느냐","reference":"마태복음 7:10","category":"$undefined"},{"id":"23328","book":"마태복음","book_name":"마태복음","chapter":7,"verse":11,"text":"너희가 악한 자라도 좋은 것으로 자식에게 줄 줄 알거든 하물며 하늘에 계신 너희 아버지께서 구하는 자에게 좋은 것으로 주시지 않겠느냐 ?","reference":"마태복음 7:11","category":"$undefined"},{"id":"23329","book":"마태복음","book_name":"마태복음","chapter":7,"verse":12,"text":"그러므로 무엇이든지 남에게 대접을 받고자 하는대로 너희도 남을 대접하라 이것이 율법이요 선지자니라","reference":"마태복음 7:12","category":"$undefined"},{"id":"23330","book":"마태복음","book_name":"마태복음","chapter":7,"verse":13,"text":"좁은 문으로 들어가라 멸망으로 인도하는 문은 크고 그 길이 넓어 그리로 들어가는 자가 많고","reference":"마태복음 7:13","category":"$undefined"},{"id":"23331","book":"마태복음","book_name":"마태복음","chapter":7,"verse":14,"text":"생명으로 인도하는 문은 좁고 길이 협착하여 찾는 이가 적음이니라","reference":"마태복음 7:14","category":"$undefined"},{"id":"23332","book":"마태복음","book_name":"마태복음","chapter":7,"verse":15,"text":"거짓 선지자들을 삼가라 양의 옷을 입고 너희에게 나아오나 속에는 노략질하는 이리라","reference":"마태복음 7:15","category":"$undefined"},{"id":"23333","book":"마태복음","book_name":"마태복음","chapter":7,"verse":16,"text":"그의 열매로 그들을 알지니 가시나무에서 포도를 또는 엉겅퀴에서 무화과를 따겠느냐 ?","reference":"마태복음 7:16","category":"$undefined"},{"id":"23334","book":"마태복음","book_name":"마태복음","chapter":7,"verse":17,"text":"이와 같이 좋은 나무마다 아름다운 열매를 맺고 못된 나무가 나쁜 열매를 맺나니","reference":"마태복음 7:17","category":"$undefined"},{"id":"23335","book":"마태복음","book_name":"마태복음","chapter":7,"verse":18,"text":"좋은 나무가 나쁜 열매를 맺을 수 없고 못된 나무가 아름다운 열매를 맺을 수 없느니라","reference":"마태복음 7:18","category":"$undefined"},{"id":"23336","book":"마태복음","book_name":"마태복음","chapter":7,"verse":19,"text":"아름다운 열매를 맺지 아니하는 나무마다 찍혀 불에 던지우느니라","reference":"마태복음 7:19","category":"$undefined"},{"id":"23337","book":"마태복음","book_name":"마태복음","chapter":7,"verse":20,"text":"이러므로 그의 열매로 그들을 알리라","reference":"마태복음 7:20","category":"$undefined"},{"id":"23338","book":"마태복음","book_name":"마태복음","chapter":7,"verse":21,"text":"나더러 주여 ! 주여 ! 하는 자마다 천국에 다 들어갈 것이 아니요 다만 하늘에 계신 내 아버지의 뜻대로 행하는 자라야 들어가리라","reference":"마태복음 7:21","category":"$undefined"},{"id":"23339","book":"마태복음","book_name":"마태복음","chapter":7,"verse":22,"text":"그 날에 많은 사람이 나더러 이르되 주여, 주여 우리가 주의 이름으로 선지자 노릇하며 주의 이름으로 귀신을 쫓아 내며 주의 이름으로 많은 권능을 행치 아니하였나이까 하리니","reference":"마태복음 7:22","category":"$undefined"},{"id":"23340","book":"마태복음","book_name":"마태복음","chapter":7,"verse":23,"text":"그 때에 내가 저희에게 밝히 말하되 내가 너희를 도무지 알지 못하니 불법을 행하는 자들아 내게서 떠나가라 하리라","reference":"마태복음 7:23","category":"$undefined"},{"id":"23341","book":"마태복음","book_name":"마태복음","chapter":7,"verse":24,"text":"그러므로 누구든지 나의 이 말을 듣고 행하는 자는 그 집을 반석위에 지은 지혜로운 사람 같으리니","reference":"마태복음 7:24","category":"$undefined"},{"id":"23342","book":"마태복음","book_name":"마태복음","chapter":7,"verse":25,"text":"비가 내리고 창수가 나고 바람이 불어 그 집에 부딪히되 무너지지 아니하나니 이는 주초를 반석 위에 놓은 연고요","reference":"마태복음 7:25","category":"$undefined"},{"id":"23343","book":"마태복음","book_name":"마태복음","chapter":7,"verse":26,"text":"나의 이 말을 듣고 행치 아니하는 자는 그 집을 모래 위에 지은 어리석은 사람 같으리니","reference":"마태복음 7:26","category":"$undefined"},{"id":"23344","book":"마태복음","book_name":"마태복음","chapter":7,"verse":27,"text":"비가 내리고 창수가 나고 바람이 불어 그 집에 부딪히매 무너져 그 무너짐이 심하니라","reference":"마태복음 7:27","category":"$undefined"},{"id":"23345","book":"마태복음","book_name":"마태복음","chapter":7,"verse":28,"text":"예수께서 이 말씀을 마치시매 무리들이 그 가르치심에 놀래니","reference":"마태복음 7:28","category":"$undefined"},{"id":"23346","book":"마태복음","book_name":"마태복음","chapter":7,"verse":29,"text":"이는 그 가르치시는 것이 권세 있는 자와 같고 저희 서기관들과 같지 아니함일러라","reference":"마태복음 7:29","category":"$undefined"}],"bookSlug":"matthew"}]
