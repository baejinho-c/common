2:["$","$L11",null,{"book":{"id":"matthew","name":"마태복음","chapters":28,"testament":"new"},"chapter":8,"verses":[{"id":"23347","book":"마태복음","book_name":"마태복음","chapter":8,"verse":1,"text":"예수께서 산에서 내려오시니 허다한 무리가 좇으니라","reference":"마태복음 8:1","category":"$undefined"},{"id":"23348","book":"마태복음","book_name":"마태복음","chapter":8,"verse":2,"text":"한 문둥병자가 나아와 절하고 가로되 `주여 ! 원하시면 저를 깨끗케 하실수 있나이다' 하거늘","reference":"마태복음 8:2","category":"$undefined"},{"id":"23349","book":"마태복음","book_name":"마태복음","chapter":8,"verse":3,"text":"예수께서 손을 내밀어 저에게 대시며 가라사대 내가 원하노니 깨끗함을 받으라 ! 하신대 즉시 그의 문둥병이 깨끗하여진지라","reference":"마태복음 8:3","category":"$undefined"},{"id":"23350","book":"마태복음","book_name":"마태복음","chapter":8,"verse":4,"text":"예수께서 이르시되 삼가 아무에게도 이르지 말고 다만 가서 제사장에게 네 몸을 보이고 모세의 명한 예물을 드려 저희에게 증거하라 하시니라","reference":"마태복음 8:4","category":"$undefined"},{"id":"23351","book":"마태복음","book_name":"마태복음","chapter":8,"verse":5,"text":"예수께서 가버나움에 들어가시니 한 백부장이 나아와 간구하여","reference":"마태복음 8:5","category":"$undefined"},{"id":"23352","book":"마태복음","book_name":"마태복음","chapter":8,"verse":6,"text":"가로되 `주여 ! 내 하인이 중풍병으로 집에 누워 몹시 괴로와하나이다'","reference":"마태복음 8:6","category":"$undefined"},{"id":"23353","book":"마태복음","book_name":"마태복음","chapter":8,"verse":7,"text":"가라사대 내가 가서 고쳐주리라","reference":"마태복음 8:7","category":"$undefined"},{"id":"23354","book":"마태복음","book_name":"마태복음","chapter":8,"verse":8,"text":"백부장이 대답하여 가로되 `주여 ! 내 집에 들어오심을 나는 감당치 못하겠사오니 다만 말씀으로만 하옵소서 ! 그러면 내 하인이 낫겠삽나이다","reference":"마태복음 8:8","category":"$undefined"},{"id":"23355","book":"마태복음","book_name":"마태복음","chapter":8,"verse":9,"text":"나도 남의 수하에 있는 사람이요 내 아래도 군사가 있으니 이더러 가라 하면 가고 저더러 오라 하면 오고 내 종더러 이것을 하라 하면 하나이다'","reference":"마태복음 8:9","category":"$undefined"},{"id":"23356","book":"마태복음","book_name":"마태복음","chapter":8,"verse":10,"text":"예수께서 들으시고 기이히 여겨 좇는 자들에게 이르시되 내가 진실로 너희에게 이르노니 이스라엘 중 아무에게서도 이만한 믿음을 만나보지 못하였노라","reference":"마태복음 8:10","category":"$undefined"},{"id":"23357","book":"마태복음","book_name":"마태복음","chapter":8,"verse":11,"text":"또 너희에게 이르노니 동서로부터 많은 사람이 이르러 아브라함과 이삭과 야곱과 함께 천국에 앉으려니와","reference":"마태복음 8:11","category":"$undefined"},{"id":"23358","book":"마태복음","book_name":"마태복음","chapter":8,"verse":12,"text":"나라의 본 자손들은 바깥 어두운 데 쫓겨나 거기서 울며 이를 갊이 있으리라","reference":"마태복음 8:12","category":"$undefined"},{"id":"23359","book":"마태복음","book_name":"마태복음","chapter":8,"verse":13,"text":"예수께서 백부장에게 이르시되 가라 ! 네 믿은대로 될지어다 ! 하시니 그 시로 하인이 나으니라","reference":"마태복음 8:13","category":"$undefined"},{"id":"23360","book":"마태복음","book_name":"마태복음","chapter":8,"verse":14,"text":"예수께서 베드로의 집에 들어가사 그의 장모가 열병으로 앓아 누운 것을 보시고","reference":"마태복음 8:14","category":"$undefined"},{"id":"23361","book":"마태복음","book_name":"마태복음","chapter":8,"verse":15,"text":"그의 손을 만지시니 열병이 떠나가고 여인이 일어나서 예수께 수종들더라","reference":"마태복음 8:15","category":"$undefined"},{"id":"23362","book":"마태복음","book_name":"마태복음","chapter":8,"verse":16,"text":"저물매 사람들이 귀신 들린 자를 많이 데리고 예수께 오거늘 예수께서 말씀으로 귀신들을 쫓아 내시고 병든 자를 다 고치시니","reference":"마태복음 8:16","category":"$undefined"},{"id":"23363","book":"마태복음","book_name":"마태복음","chapter":8,"verse":17,"text":"이는 선지자 이사야로 하신 말씀에 우리 연약한 것을 친히 담당하시고 병을 짊어지셨도다 함을 이루려 하심이더라","reference":"마태복음 8:17","category":"$undefined"},{"id":"23364","book":"마태복음","book_name":"마태복음","chapter":8,"verse":18,"text":"예수께서 무리가 자기를 에워쌈을 보시고 저편으로 건너 가기를 명하시니라","reference":"마태복음 8:18","category":"$undefined"},{"id":"23365","book":"마태복음","book_name":"마태복음","chapter":8,"verse":19,"text":"한 서기관이 나아와 예수께 말씀하되 `선생님이여 ! 어디로 가시든지 저는 좇으리이다'","reference":"마태복음 8:19","category":"$undefined"},{"id":"23366","book":"마태복음","book_name":"마태복음","chapter":8,"verse":20,"text":"예수께서 이르시되 여우도 굴이 있고 공중의 새도 거처가 있으되 오직 인자는 머리 둘 곳이 없다 하시더라","reference":"마태복음 8:20","category":"$undefined"},{"id":"23367","book":"마태복음","book_name":"마태복음","chapter":8,"verse":21,"text":"제자 중에 또 하나가 가로되 `주여 ! 나로 먼저 가서 부친을 장사하게 허락하옵소서'","reference":"마태복음 8:21","category":"$undefined"},{"id":"23368","book":"마태복음","book_name":"마태복음","chapter":8,"verse":22,"text":"예수께서 가라사대 죽은 자들로 저희 죽은 자를 장사하게 하고 너는 나를 좇으라 ! 하시니라","reference":"마태복음 8:22","category":"$undefined"},{"id":"23369","book":"마태복음","book_name":"마태복음","chapter":8,"verse":23,"text":"배에 오르시매 제자들이 좇았더니","reference":"마태복음 8:23","category":"$undefined"},{"id":"23370","book":"마태복음","book_name":"마태복음","chapter":8,"verse":24,"text":"바다에 큰 놀이 일어나 물결이 배에 덮이게 되었으되 예수는 주무시는지라","reference":"마태복음 8:24","category":"$undefined"},{"id":"23371","book":"마태복음","book_name":"마태복음","chapter":8,"verse":25,"text":"그 제자들이 나아와 깨우며 가로되 `주여 ! 구원하소서 우리가 죽겠나이다'","reference":"마태복음 8:25","category":"$undefined"},{"id":"23372","book":"마태복음","book_name":"마태복음","chapter":8,"verse":26,"text":"예수께서 이르시되 어찌하여 무서워하느냐 ? 믿음이 적은 자들아 ! 하시고 곧 일어나사 바람과 바다를 꾸짖으신대 아주 잔잔하게 되거늘","reference":"마태복음 8:26","category":"$undefined"},{"id":"23373","book":"마태복음","book_name":"마태복음","chapter":8,"verse":27,"text":"그 사람들이 기이히 여겨 가로되 `이 어떠한 사람이기에 바람과 바다도 순종하는고' 하더라","reference":"마태복음 8:27","category":"$undefined"},{"id":"23374","book":"마태복음","book_name":"마태복음","chapter":8,"verse":28,"text":"또 예수께서 건너편 가다라 지방에 가시매 귀신 들린 자 둘이 무덤 사이에서 나와 예수를 만나니 저희는 심히 사나와 아무도 그 길로 지나갈 수 없을만하더라","reference":"마태복음 8:28","category":"$undefined"},{"id":"23375","book":"마태복음","book_name":"마태복음","chapter":8,"verse":29,"text":"이에 저희가 소리질러 가로되 `하나님의 아들이여 ! 우리와 당신과 무슨 상관이 있나이까 ? 때가 이르기 전에 우리를 괴롭게 하려고 여기 오셨나이까' 하더니","reference":"마태복음 8:29","category":"$undefined"},{"id":"23376","book":"마태복음","book_name":"마태복음","chapter":8,"verse":30,"text":"마침 멀리서 많은 돼지 떼가 먹고 있는지라","reference":"마태복음 8:30","category":"$undefined"},{"id":"23377","book":"마태복음","book_name":"마태복음","chapter":8,"verse":31,"text":"귀신들이 예수께 간구하여 가로되 `만일 우리를 쫓아 내실진대 돼지떼에 들여 보내소서' 한대","reference":"마태복음 8:31","category":"$undefined"},{"id":"23378","book":"마태복음","book_name":"마태복음","chapter":8,"verse":32,"text":"저희더러 가라 하시니 귀신들이 나와서 돼지에게로 들어가는지라 온떼가 비탈로 내리달아 바다에 들어가서 물에서 몰사하거늘","reference":"마태복음 8:32","category":"$undefined"},{"id":"23379","book":"마태복음","book_name":"마태복음","chapter":8,"verse":33,"text":"치던 자들이 달아나 시내에 들어가 이 모든 일과 귀신들린 자의 일을 고하니","reference":"마태복음 8:33","category":"$undefined"},{"id":"23380","book":"마태복음","book_name":"마태복음","chapter":8,"verse":34,"text":"온 시내가 예수를 만나려고 나가서 보고 그 지방에서 떠나시기를 간구하더라","reference":"마태복음 8:34","category":"$undefined"}],"bookSlug":"matthew"}]
