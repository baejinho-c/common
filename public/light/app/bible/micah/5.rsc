2:["$","$L11",null,{"book":{"id":"micah","name":"미가","chapters":7,"testament":"old"},"chapter":5,"verses":[{"id":"22635","book":"미가","book_name":"미가","chapter":5,"verse":1,"text":"딸 군대여, 너는 떼를 모을지어다 그들이 우리를 에워쌌으니 막대기로 이스라엘 재판자의 뺨을 치리로다","reference":"미가 5:1","category":"$undefined"},{"id":"22636","book":"미가","book_name":"미가","chapter":5,"verse":2,"text":"베들레헴 에브라다야, 너는 유다 족속 중에 작을지라도 이스라엘을 다스릴 자가 네게서 내게로 나올 것이라 그의 근본은 상고에 태초에니라","reference":"미가 5:2","category":"$undefined"},{"id":"22637","book":"미가","book_name":"미가","chapter":5,"verse":3,"text":"그러므로 임산한 여인이 해산하기까지 그들을 붙여 두시겠고 그 후에는 그 형제 남은 자가 이스라엘 자손에게로 돌아오리니","reference":"미가 5:3","category":"$undefined"},{"id":"22638","book":"미가","book_name":"미가","chapter":5,"verse":4,"text":"그가 여호와의 능력과 그 하나님 여호와의 이름의 위엄을 의지하고 서서 그 떼에게 먹여서 그들로 안연히 거하게 할 것이라 이제 그가 창대하여 땅 끝까지 미치리라","reference":"미가 5:4","category":"$undefined"},{"id":"22639","book":"미가","book_name":"미가","chapter":5,"verse":5,"text":"이 사람은 우리의 평강이 될 것이라 앗수르 사람이 우리 땅에 들어와서 우리 궁들을 밟을 때에는 우리가 일곱 목자와 여덟 군왕을 일으켜 그를 치리니","reference":"미가 5:5","category":"$undefined"},{"id":"22640","book":"미가","book_name":"미가","chapter":5,"verse":6,"text":"그들이 칼로 앗수르 땅을 황무케 하며 니므롯 땅에 들어와서 우리 지경을 밟을 때에는 그가 우리를 그에게서 건져 내리라","reference":"미가 5:6","category":"$undefined"},{"id":"22641","book":"미가","book_name":"미가","chapter":5,"verse":7,"text":"야곱의 남은 자는 많은 백성 중에 있으리니 그들은 여호와에게로서 내리는 이슬 같고 풀 위에 내리는 단비 같아서 사람을 기다리지 아니하며 인생을 기다리지 아니할 것이며","reference":"미가 5:7","category":"$undefined"},{"id":"22642","book":"미가","book_name":"미가","chapter":5,"verse":8,"text":"야곱의 남은 자는 열국 중과 여러 백성 중에 있으리니 그들은 수풀의 짐승 중의 사자 같고 양떼 중의 젊은 사자 같아서 만일 지나간즉 밟고 찢으리니 능히 구원할 자가 없을 것이라","reference":"미가 5:8","category":"$undefined"},{"id":"22643","book":"미가","book_name":"미가","chapter":5,"verse":9,"text":"네 손이 네 대적 위에 들려서 네 모든 원수를 진멸하기를 바라노라","reference":"미가 5:9","category":"$undefined"},{"id":"22644","book":"미가","book_name":"미가","chapter":5,"verse":10,"text":"여호와께서 가라사대 그 날에 이르러는 내가 너의 말을 너의 중에서 멸절하며 너의 병거를 훼파하며","reference":"미가 5:10","category":"$undefined"},{"id":"22645","book":"미가","book_name":"미가","chapter":5,"verse":11,"text":"너의 땅의 성읍들을 멸하며 너의 모든 견고한 성을 무너뜨릴 것이며","reference":"미가 5:11","category":"$undefined"},{"id":"22646","book":"미가","book_name":"미가","chapter":5,"verse":12,"text":"내가 또 복술을 너의 손에서 끊으리니 네게 다시는 점장이가 없게 될 것이며","reference":"미가 5:12","category":"$undefined"},{"id":"22647","book":"미가","book_name":"미가","chapter":5,"verse":13,"text":"내가 너의 새긴 우상과 주상을 너의 중에서 멸절하리니 네가 네 손으로 만든 것을 다시는 섬기지 아니하리라","reference":"미가 5:13","category":"$undefined"},{"id":"22648","book":"미가","book_name":"미가","chapter":5,"verse":14,"text":"내가 또 너의 아세라 목상을 너의 중에서 빼어 버리고 너의 성읍들을 멸할 것이며","reference":"미가 5:14","category":"$undefined"},{"id":"22649","book":"미가","book_name":"미가","chapter":5,"verse":15,"text":"내가 또 진노와 분한으로 청종치 아니한 나라에 갚으리라 하셨느니라","reference":"미가 5:15","category":"$undefined"}],"bookSlug":"micah"}]
