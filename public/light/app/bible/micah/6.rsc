2:["$","$L11",null,{"book":{"id":"micah","name":"미가","chapters":7,"testament":"old"},"chapter":6,"verses":[{"id":"22650","book":"미가","book_name":"미가","chapter":6,"verse":1,"text":"너희는 여호와의 말씀을 들을지어다 내게 이르시기를 너는 일어나서 산 앞에서 쟁변하여 작은 산으로 네 목소리를 듣게 하라 하셨나니","reference":"미가 6:1","category":"$undefined"},{"id":"22651","book":"미가","book_name":"미가","chapter":6,"verse":2,"text":"너희 산들과 땅의 견고한 지대들아 너희는 여호와의 쟁변을 들으라 여호와께서 자기 백성과 쟁변하시며 이스라엘과 변론하실 것이라","reference":"미가 6:2","category":"$undefined"},{"id":"22652","book":"미가","book_name":"미가","chapter":6,"verse":3,"text":"이르시기를 내 백성아 내가 무엇을 네게 행하였으며 무엇에 너를 괴롭게 하였느냐 너는 내게 증거하라","reference":"미가 6:3","category":"$undefined"},{"id":"22653","book":"미가","book_name":"미가","chapter":6,"verse":4,"text":"내가 너를 애굽 땅에서 인도하여 내어 종노릇하는 집에서 속량하였고 모세와 아론과 미리암을 보내어 네 앞에 행하게 하였었느니라","reference":"미가 6:4","category":"$undefined"},{"id":"22654","book":"미가","book_name":"미가","chapter":6,"verse":5,"text":"내 백성아 너는 모압 왕 발락의 꾀한 것과 브올의 아들 발람이 그에게 대답한 것을 추억하며 싯딤에서부터 길갈까지의 일을 추억하라 그리하면 나 여호와의 의롭게 행한 것을 알리라 하실 것이니라","reference":"미가 6:5","category":"$undefined"},{"id":"22655","book":"미가","book_name":"미가","chapter":6,"verse":6,"text":"내가 무엇을 가지고 여호와 앞에 나아가며 높으신 하나님께 경배할까 내가 번제물 일년 된 송아지를 가지고 그 앞에 나아갈까","reference":"미가 6:6","category":"$undefined"},{"id":"22656","book":"미가","book_name":"미가","chapter":6,"verse":7,"text":"여호와께서 천천의 수양이나 만만의 강수 같은 기름을 기뻐하실까 내 허물을 위하여 내 맏아들을, 내 영혼의 죄를 인하여 내 몸의 열매를 드릴까","reference":"미가 6:7","category":"$undefined"},{"id":"22657","book":"미가","book_name":"미가","chapter":6,"verse":8,"text":"사람아 주께서 선한 것이 무엇임을 네게 보이셨나니 여호와께서 네게 구하시는 것이 오직 공의를 행하며 인자를 사랑하며 겸손히 네 하나님과 함께 행하는 것이 아니냐","reference":"미가 6:8","category":"$undefined"},{"id":"22658","book":"미가","book_name":"미가","chapter":6,"verse":9,"text":"여호와께서 성읍을 향하여 외쳐 부르시나니 완전한 지혜는 주의 이름을 경외함이니라 너희는 매를 순히 받고 그것을 정하신 자를 순종할지니라","reference":"미가 6:9","category":"$undefined"},{"id":"22659","book":"미가","book_name":"미가","chapter":6,"verse":10,"text":"악인의 집에 오히려 불의한 재물이 있느냐 ? 축소시킨 가증한 에바가 있느냐 ?","reference":"미가 6:10","category":"$undefined"},{"id":"22660","book":"미가","book_name":"미가","chapter":6,"verse":11,"text":"내가 만일 부정한 저울을 썼거나 주머니에 거짓 저울추를 두었으면 깨끗하겠느냐 ?","reference":"미가 6:11","category":"$undefined"},{"id":"22661","book":"미가","book_name":"미가","chapter":6,"verse":12,"text":"그 부자들은 강포가 가득하였고 그 거민들은 거짓을 말하니 그 혀가 입에서 궤사하도다","reference":"미가 6:12","category":"$undefined"},{"id":"22662","book":"미가","book_name":"미가","chapter":6,"verse":13,"text":"그러므로 나도 너를 쳐서 중히 상하게 하였으며 네 죄를 인하여 너를 적막하게 하였나니","reference":"미가 6:13","category":"$undefined"},{"id":"22663","book":"미가","book_name":"미가","chapter":6,"verse":14,"text":"네가 먹으나 배부르지 못하고 속이 항상 빌 것이며 네가 감추나 보존되지 못하겠고 보존된 것은 내가 칼에 붙일 것이며","reference":"미가 6:14","category":"$undefined"},{"id":"22664","book":"미가","book_name":"미가","chapter":6,"verse":15,"text":"네가 씨를 뿌리나 추수하지 못할 것이며 감람을 밟으나 기름을 네 몸에 바르지 못할 것이며 포도를 밟으나 술을 마시지 못하리라","reference":"미가 6:15","category":"$undefined"},{"id":"22665","book":"미가","book_name":"미가","chapter":6,"verse":16,"text":"너희가 오므리의 율례와 아합 집의 모든 행위를 지키고 그들의 꾀를 좇으니 이는 나로 너희를 황무케 하며 그 거민으로 사람의 치솟거리를 만들게 하려 함이라 너희가 내 백성의 수욕을 담당하리라","reference":"미가 6:16","category":"$undefined"}],"bookSlug":"micah"}]
