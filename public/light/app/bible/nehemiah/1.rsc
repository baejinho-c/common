2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":1,"verses":[{"id":"12298","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":1,"text":"하가랴의 아들 느헤미야의 말이라 아닥사스다 왕 제 이십년 기슬르월에 내가 수산궁에 있더니","reference":"느헤미야 1:1","category":"$undefined"},{"id":"12299","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":2,"text":"나의 한 형제 중 하나니가 두어 사람과 함께 유다에서 이르렀기로 내가 그 사로잡힘을 면하고 남아있는 유다 사람과 예루살렘 형편을 물은즉","reference":"느헤미야 1:2","category":"$undefined"},{"id":"12300","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":3,"text":"저희가 내게 이르되 `사로잡힘을 면하고 남은 자가 그 도에서 큰 환난을 만나고 능욕을 받으며 예루살렘 성은 훼파되고 성문들은 소화되었다' 하는지라","reference":"느헤미야 1:3","category":"$undefined"},{"id":"12301","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":4,"text":"내가 이 말을 듣고 앉아서 울고 수일 동안 슬퍼하며 하늘의 하나님 앞에 금식하며 기도하여","reference":"느헤미야 1:4","category":"$undefined"},{"id":"12302","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":5,"text":"가로되 `하늘의 하나님 여호와 크고 두려우신 하나님이여, 주를 사랑하고 주의 계명을 지키는 자에게 언약을 지키시며 긍휼을 베푸시는 주여 ! 간구하나이다","reference":"느헤미야 1:5","category":"$undefined"},{"id":"12303","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":6,"text":"이제 종이 주의 종 이스라엘 자손을 위하여 주야로 기도하오며 이스라엘 자손의 주 앞에 범죄함을 자복하오니 주는 귀를 기울이시며 눈을 여시사 종의 기도를 들으시옵소서 ! 나와 나의 아비 집이 범죄하여","reference":"느헤미야 1:6","category":"$undefined"},{"id":"12304","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":7,"text":"주를 향하여 심히 악을 행하여 주의 종 모세에게 주께서 명하신 계명과 율례와 규례를 지키지 아니하였나이다","reference":"느헤미야 1:7","category":"$undefined"},{"id":"12305","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":8,"text":"옛적에 주께서 주의 종 모세에게 명하여 가라사대 만일 너희가 범죄하면 내가 너희를 열국 중에 흩을 것이요","reference":"느헤미야 1:8","category":"$undefined"},{"id":"12306","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":9,"text":"만일 내게로 돌아와서 내 계명을 지켜 행하면 너희 쫓긴 자가 하늘 끝에 있을지라도 내가 거기서 부터 모아 내 이름을 두려고 택한 곳에 돌아오게 하리라 하신 말씀을 이제 청컨대 기억하옵소서","reference":"느헤미야 1:9","category":"$undefined"},{"id":"12307","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":10,"text":"이들은 주께서 일찍 큰 권능과 강한 손으로 구속하신 주의 종이요 주의 백성이니이다","reference":"느헤미야 1:10","category":"$undefined"},{"id":"12308","book":"느헤미야","book_name":"느헤미야","chapter":1,"verse":11,"text":"주여 ! 구하오니 귀를 기울이사 종의 기도와 주의 이름을 경외하기를 기뻐하는 종들의 기도를 들으시고 오늘날 종으로 형통하여 이 사람 앞에서 은혜를 입게 하옵소서' 하였나니 그 때에 내가 왕의 술 관원이 되었었느니라","reference":"느헤미야 1:11","category":"$undefined"}],"bookSlug":"nehemiah"}]
