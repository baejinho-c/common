2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":10,"verses":[{"id":"12551","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":1,"text":"그 인친 자는 하가랴의 아들 방백 느헤미야와, 시드기야","reference":"느헤미야 10:1","category":"$undefined"},{"id":"12552","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":2,"text":"스라야, 아사랴, 예레미야,","reference":"느헤미야 10:2","category":"$undefined"},{"id":"12553","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":3,"text":"바스훌, 아마랴, 말기야,","reference":"느헤미야 10:3","category":"$undefined"},{"id":"12554","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":4,"text":"핫두스, 스바냐, 말룩,","reference":"느헤미야 10:4","category":"$undefined"},{"id":"12555","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":5,"text":"하림, 므레못, 오바댜,","reference":"느헤미야 10:5","category":"$undefined"},{"id":"12556","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":6,"text":"다니엘, 긴느돈, 바룩,","reference":"느헤미야 10:6","category":"$undefined"},{"id":"12557","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":7,"text":"므술람, 아비야, 미야민,","reference":"느헤미야 10:7","category":"$undefined"},{"id":"12558","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":8,"text":"마아시야, 빌개, 스마야니 이는 다 제사장이요","reference":"느헤미야 10:8","category":"$undefined"},{"id":"12559","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":9,"text":"또 레위 사람 곧 아사냐의 아들 예수아 헤나닷의 자손 중 빈누이 갓미엘과","reference":"느헤미야 10:9","category":"$undefined"},{"id":"12560","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":10,"text":"그 형제 스바냐, 호디야, 그리다, 블라야, 하난","reference":"느헤미야 10:10","category":"$undefined"},{"id":"12561","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":11,"text":"미가, 르홉, 하사뱌,","reference":"느헤미야 10:11","category":"$undefined"},{"id":"12562","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":12,"text":"삭굴, 세레뱌,스바냐,","reference":"느헤미야 10:12","category":"$undefined"},{"id":"12563","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":13,"text":"호디야, 바니, 브니누요","reference":"느헤미야 10:13","category":"$undefined"},{"id":"12564","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":14,"text":"또 백성의 두목들 곧 바로스, 바핫모압, 엘람, 삿두, 바니,","reference":"느헤미야 10:14","category":"$undefined"},{"id":"12565","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":15,"text":"분니, 아스갓, 베배,","reference":"느헤미야 10:15","category":"$undefined"},{"id":"12566","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":16,"text":"아도니야, 비그왜, 아딘,","reference":"느헤미야 10:16","category":"$undefined"},{"id":"12567","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":17,"text":"아델, 히스기야, 앗술,","reference":"느헤미야 10:17","category":"$undefined"},{"id":"12568","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":18,"text":"호디야, 하숨, 베새,","reference":"느헤미야 10:18","category":"$undefined"},{"id":"12569","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":19,"text":"하립,아나돗, 노배,","reference":"느헤미야 10:19","category":"$undefined"},{"id":"12570","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":20,"text":"막비아스, 므술람, 헤실,","reference":"느헤미야 10:20","category":"$undefined"},{"id":"12571","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":21,"text":"므세사벨, 사독, 얏두아,","reference":"느헤미야 10:21","category":"$undefined"},{"id":"12572","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":22,"text":"블라댜, 하난, 아나야,","reference":"느헤미야 10:22","category":"$undefined"},{"id":"12573","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":23,"text":"호세아, 하나냐, 핫숩,","reference":"느헤미야 10:23","category":"$undefined"},{"id":"12574","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":24,"text":"할르헤스, 빌하, 소벡,","reference":"느헤미야 10:24","category":"$undefined"},{"id":"12575","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":25,"text":"르훔, 하삼나, 마아세야,","reference":"느헤미야 10:25","category":"$undefined"},{"id":"12576","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":26,"text":"아히야, 하난, 아난,","reference":"느헤미야 10:26","category":"$undefined"},{"id":"12577","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":27,"text":"말룩, 하림, 바아나이었느니라","reference":"느헤미야 10:27","category":"$undefined"},{"id":"12578","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":28,"text":"그 남은 백성과 제사장들과, 레위 사람들과, 문지기들과, 노래하는 자들과, 느디님 사람들과, 및 이방 사람과 절교하고 하나님의 율법을 준행하는 모든 자와 그 아내와 그 자녀들 무릇 지식과 총명이 있는 자가","reference":"느헤미야 10:28","category":"$undefined"},{"id":"12579","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":29,"text":"다 그 형제 귀인들을 좇아 저주로 맹세하기를 우리가 하나님의 종 모세로 주신 하나님의 율법을 좇아 우리 주 여호와의 모든 계명과 규례와 율례를 지켜","reference":"느헤미야 10:29","category":"$undefined"},{"id":"12580","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":30,"text":"우리 딸은 이 땅 백성에게 주지 아니하고 우리 아들을 위하여 저희 딸을 데려오지 아니하며","reference":"느헤미야 10:30","category":"$undefined"},{"id":"12581","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":31,"text":"혹시 이 땅 백성이 안식일에 물화나 식물을 가져다가 팔려 할지라도 우리가 안식일이나 성일에는 사지 않겠고 제 칠년마다 땅을 쉬게 하고 모든 빚을 탕감하리라 하였고","reference":"느헤미야 10:31","category":"$undefined"},{"id":"12582","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":32,"text":"우리가 또 스스로 규례를 정하기를 해마다 각기 세겔의 삼분 일을 수납하여 하나님의 전을 위하여 쓰게 하되","reference":"느헤미야 10:32","category":"$undefined"},{"id":"12583","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":33,"text":"곧 진설병과 항상 드리는 소제와 항상 드리는 번제와 안식일과 초하루와 정한 절기에 쓸 것과 성물과 이스라엘을 위하는 속죄제와 우리 하나님의 전의 모든 일을 위하여 쓰게 하였고","reference":"느헤미야 10:33","category":"$undefined"},{"id":"12584","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":34,"text":"또 우리 제사장들과 레위 사람들과 백성들이 제비 뽑아 각기 종족 대로 해마다 정한 기한에 나무를 우리 하나님의 전에 드려서 율법에 기록한대로 우리 하나님 여호와의 단에 사르게 하였고","reference":"느헤미야 10:34","category":"$undefined"},{"id":"12585","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":35,"text":"해마다 우리 토지 소산의 맏물과 각종 과목의 첫 열매를 여호와의 전에 드리기로 하였고","reference":"느헤미야 10:35","category":"$undefined"},{"id":"12586","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":36,"text":"또 우리의 맏아들들과 생축의 처음 난 것과 우양의 처음 난 것을 율법에 기록된대로 우리 하나님의 전으로 가져다가 우리 하나님의 전에서 섬기는 제사장들에게 주고","reference":"느헤미야 10:36","category":"$undefined"},{"id":"12587","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":37,"text":"또 처음 익은 밀의 가루와 거제물과 각종 과목의 열매와 새 포도주와 기름을 제사장들에게로 가져다가 우리하나님의 전 골방에 두고 또 우리 물산의 십일조를 레위 사람들에게 주리라 하였나니 이 레위 사람들은 우리의 모든 성읍에서 물산의 십일조를 받는 자임이며","reference":"느헤미야 10:37","category":"$undefined"},{"id":"12588","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":38,"text":"레위 사람들이 십일조를 받을 때에는 아론의 자손 제사장 하나가 함께 있을 것이요 레위 사람들은 그 십일조의 십분 일을 가져다가 우리 하나님의 전 골방 곧 곳간에 두되","reference":"느헤미야 10:38","category":"$undefined"},{"id":"12589","book":"느헤미야","book_name":"느헤미야","chapter":10,"verse":39,"text":"곧 이스라엘 자손과 레위 자손이 거제로 드린바 곡식과 새 포도주와 기름을 가져다가 성소의 기명을 두는 골방 곧 섬기는 제사장들과 및 문지기들과 노래하는 자들이 있는 골방에 둘 것이라 그리하여 우리가 우리 하나님의 전을 버리지 아니하리라","reference":"느헤미야 10:39","category":"$undefined"}],"bookSlug":"nehemiah"}]
