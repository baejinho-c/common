2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":11,"verses":[{"id":"12590","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":1,"text":"백성의 두목들은 예루살렘에 머물렀고 그 남은 백성은 제비뽑아 십분의 일은 거룩한 성 예루살렘에 와서 거하게 하고 그 구분은 다른 성읍에 거하게 하였으며","reference":"느헤미야 11:1","category":"$undefined"},{"id":"12591","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":2,"text":"무릇 예루살렘에 거하기를 자원하는 자는 백성들이 위하여 복을 빌었느니라","reference":"느헤미야 11:2","category":"$undefined"},{"id":"12592","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":3,"text":"이스라엘과 제사장들과 레위 사람들과 느디님 사람들과 솔로몬의 신복의 자손은 유다 여러 성읍에서 각각 그 본성 본 기업에 거하였고 예루살렘에 거한 그 도의 두목들은 이러하니","reference":"느헤미야 11:3","category":"$undefined"},{"id":"12593","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":4,"text":"예루살렘에 거한 자는 유다 자손과 베냐민 자손 몇명이라 유다 자손중에는 베레스 자손 아다야니 저는 웃시야의 아들이요, 스가랴의 손자요, 아마랴의 증손이요, 스바댜의 현손이요, 마할랄렐의 오대손이며","reference":"느헤미야 11:4","category":"$undefined"},{"id":"12594","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":5,"text":"또 마아세야니 저는 바룩의 아들이요, 골호세의 손자요, 하사야의 증손이요, 아다야의 현손이요, 요야립의 오대손이요, 스가랴의 육대손이요, 실로 사람의 칠대손이라","reference":"느헤미야 11:5","category":"$undefined"},{"id":"12595","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":6,"text":"예루살렘에 거한 베레스 자손의 도합이 사백 육십 팔명이니 다 용사이었느니라","reference":"느헤미야 11:6","category":"$undefined"},{"id":"12596","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":7,"text":"베냐민 자손은 살루니 저는 므술람의 아들이요, 요엣의 손자요, 브다야의 증손이요, 골라야의 현손이요, 마아세야의 오대손이요, 이디엘의 육대손이요, 여사야의 칠대손이며","reference":"느헤미야 11:7","category":"$undefined"},{"id":"12597","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":8,"text":"그 다음은 갑배와, 살래 등이니 도합이 구백 이십 팔명이라","reference":"느헤미야 11:8","category":"$undefined"},{"id":"12598","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":9,"text":"시그리의 아들 요엘이 그 감독이 되었고 핫스누아의 아들 유다는 버금이 되어 성읍을 다스렸느니라","reference":"느헤미야 11:9","category":"$undefined"},{"id":"12599","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":10,"text":"제사장 중에는 요야립의 아들 여다야와, 야긴이며","reference":"느헤미야 11:10","category":"$undefined"},{"id":"12600","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":11,"text":"또 하나님의 전을 맡은 자 스라야니 저는 힐기야의 아들이요, 므술람의 손자요, 사독의 증손이요, 므라욧의 현손이요, 아히둡의 오대손이며","reference":"느헤미야 11:11","category":"$undefined"},{"id":"12601","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":12,"text":"또 전에서 일하는 그 형제니 도합이 팔백 이십 이명이요 또 아다야니 저는 여로함의 아들이요, 블라야의 손자요, 암시의 증손이요, 스가랴의 현손이요, 바스훌의 오대손이요, 말기야의 육대손이며","reference":"느헤미야 11:12","category":"$undefined"},{"id":"12602","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":13,"text":"또 그 형제의 족장 된 자니 도합이 이백 사십 이명이요 또 아맛새니 저는 아사렐의 아들이요, 아흐새의 손자요, 므실레못의 증손이요, 임멜의 현손이며","reference":"느헤미야 11:13","category":"$undefined"},{"id":"12603","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":14,"text":"또 그 형제의 큰 용사니 도합이 일백 이십 팔명이라 하그돌림의 아들 삽디엘이 그 감독이 되었느니라","reference":"느헤미야 11:14","category":"$undefined"},{"id":"12604","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":15,"text":"레위 사람 중에는 스마야니 저는 핫숩의 아들이요, 아스리감의 손자요, 하사뱌의 증손이요, 분니의 현손이며","reference":"느헤미야 11:15","category":"$undefined"},{"id":"12605","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":16,"text":"또 레위 사람의 족장 삽브대와, 요사밧이니 저희는 하나님의 전 바깥 일을 맡았고","reference":"느헤미야 11:16","category":"$undefined"},{"id":"12606","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":17,"text":"또 아삽의 증손 삽디의 손자 미가의 아들 맛다냐니 저는 기도할때에 감사하는 말씀을 인도하는 어른이 되었고 형제 중에 박부갸가 버금이 되었으며 또 여두둔의 증손 갈랄의 손자 삼무아의 아들 압다니","reference":"느헤미야 11:17","category":"$undefined"},{"id":"12607","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":18,"text":"거룩한 성에 레위 사람의 도합이 이백 팔십 사명이었느니라","reference":"느헤미야 11:18","category":"$undefined"},{"id":"12608","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":19,"text":"성 문지기는 악굽과, 달몬과 그 형제니 도합이 일백 칠십 이명이며","reference":"느헤미야 11:19","category":"$undefined"},{"id":"12609","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":20,"text":"그 나머지 이스라엘 백성과 제사장과 레위 사람은 유다 모든 성읍에 흩어져 각각 자기 기업에 거하였고","reference":"느헤미야 11:20","category":"$undefined"},{"id":"12610","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":21,"text":"느디님 사람은 오벨에 거하니 시하와, 기스바가 그 두목이 되었느니라","reference":"느헤미야 11:21","category":"$undefined"},{"id":"12611","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":22,"text":"노래하는 자 아삽 자손 곧 미가의 현손 맛다냐의 증손 하사뱌의 손자 바니의 아들 웃시는 예루살렘에 거하는 레위 사람의 감독이 되어 하나님의 전 일을 맡아 다스렸으니","reference":"느헤미야 11:22","category":"$undefined"},{"id":"12612","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":23,"text":"이는 왕의 명대로 노래하는 자에게 날마다 양식을 정하여 주는 것이 있음이며","reference":"느헤미야 11:23","category":"$undefined"},{"id":"12613","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":24,"text":"유다의 아들 세라의 자손 곧 므세사벨의 아들 브다히야는 왕의 수하에서 백성의 일을 다스렸느니라","reference":"느헤미야 11:24","category":"$undefined"},{"id":"12614","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":25,"text":"향리와 들로 말하면 유다 자손의 더러는 기럇 아바와 그 촌과 디본과 그 촌과 여갑스엘과 그 동네에 거하며","reference":"느헤미야 11:25","category":"$undefined"},{"id":"12615","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":26,"text":"또 예수아와, 몰라다와, 벧벨렛과","reference":"느헤미야 11:26","category":"$undefined"},{"id":"12616","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":27,"text":"하살수알과, 브엘세바와, 그 촌에 거하며","reference":"느헤미야 11:27","category":"$undefined"},{"id":"12617","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":28,"text":"또 시글락과, 므고나와, 그 촌에 거하며","reference":"느헤미야 11:28","category":"$undefined"},{"id":"12618","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":29,"text":"또 에느림몬과, 소라와, 야르뭇에 거하며","reference":"느헤미야 11:29","category":"$undefined"},{"id":"12619","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":30,"text":"또 사노아와, 아둘람과, 그 동네와, 라기스와, 그 들과, 아세가와, 그 촌에 거하였으니 저희는 브엘세바에서부터 힌놈의 골짜기까지 장막을 쳤으며","reference":"느헤미야 11:30","category":"$undefined"},{"id":"12620","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":31,"text":"또 베냐민 자손은 게바에서부터 믹마스와, 아야와, 벧엘과, 그 촌에 거하며","reference":"느헤미야 11:31","category":"$undefined"},{"id":"12621","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":32,"text":"아나돗과, 놉과, 아나냐와","reference":"느헤미야 11:32","category":"$undefined"},{"id":"12622","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":33,"text":"하솔과, 라마와, 깃다임과","reference":"느헤미야 11:33","category":"$undefined"},{"id":"12623","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":34,"text":"하딧과, 스보임과, 느발랏과","reference":"느헤미야 11:34","category":"$undefined"},{"id":"12624","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":35,"text":"로드와, 오노와, 공장 골짜기에 거하였으며","reference":"느헤미야 11:35","category":"$undefined"},{"id":"12625","book":"느헤미야","book_name":"느헤미야","chapter":11,"verse":36,"text":"유다에 있던 레위 사람의 어떤 반열은 베냐민과 합하였느니라","reference":"느헤미야 11:36","category":"$undefined"}],"bookSlug":"nehemiah"}]
