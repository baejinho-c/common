2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":12,"verses":[{"id":"12626","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":1,"text":"스알디엘의 아들 스룹바벨과 및 예수아를 좇아 돌아온 제사장과 레위 사람은 이러하니라 제사장은 스라야와, 예레미야와, 에스라와","reference":"느헤미야 12:1","category":"$undefined"},{"id":"12627","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":2,"text":"아마랴와, 말룩과, 핫두스와","reference":"느헤미야 12:2","category":"$undefined"},{"id":"12628","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":3,"text":"스가냐와, 르훔과, 므레못과","reference":"느헤미야 12:3","category":"$undefined"},{"id":"12629","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":4,"text":"잇도와, 긴느도이와, 아비야와","reference":"느헤미야 12:4","category":"$undefined"},{"id":"12630","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":5,"text":"미야민과, 마아댜와, 빌가와","reference":"느헤미야 12:5","category":"$undefined"},{"id":"12631","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":6,"text":"스마야와, 요야립과, 여다야와","reference":"느헤미야 12:6","category":"$undefined"},{"id":"12632","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":7,"text":"살루와, 아목과, 힐기야와, 여다야니 이상은 예수아 때에 제사장과 그 형제의 어른이었느니라","reference":"느헤미야 12:7","category":"$undefined"},{"id":"12633","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":8,"text":"레위 사람은 예수아와, 빈누이와, 갓미엘과, 세레뱌와, 유다와, 맛다냐니 이 맛다냐는 그 형제와 함께 찬송하는 일을 맡았고","reference":"느헤미야 12:8","category":"$undefined"},{"id":"12634","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":9,"text":"또 그 형제 박부갸와, 운노는 직무를 따라 저의 맞은편에 있으며","reference":"느헤미야 12:9","category":"$undefined"},{"id":"12635","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":10,"text":"예수아는 요야김을 낳았고, 요야김은 엘리아십을 낳았고 엘리아십은 요야다를 낳았고","reference":"느헤미야 12:10","category":"$undefined"},{"id":"12636","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":11,"text":"요야다는 요나단을 낳았고, 요나단은 얏두아를 낳았느니라","reference":"느헤미야 12:11","category":"$undefined"},{"id":"12637","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":12,"text":"요야김 때에 제사장의 족장된 자는 스라야 족속에는 므라야요, 예레미야 족속에는 하나냐요","reference":"느헤미야 12:12","category":"$undefined"},{"id":"12638","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":13,"text":"에스라 족속에는 므술람이요, 아마랴 족속에는 여호하난이요","reference":"느헤미야 12:13","category":"$undefined"},{"id":"12639","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":14,"text":"말루기 족속에는 요나단이요, 스바냐 족속에는 요셉이요","reference":"느헤미야 12:14","category":"$undefined"},{"id":"12640","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":15,"text":"하림 족속에는 아드나요, 므라욧 족속에는 헬개요","reference":"느헤미야 12:15","category":"$undefined"},{"id":"12641","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":16,"text":"잇도 족속에는 스가랴요, 긴느돈 족속에는 므술람이요","reference":"느헤미야 12:16","category":"$undefined"},{"id":"12642","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":17,"text":"아비야 족속에는 시그리요, 미냐민 곧 모아댜 족속에는 빌대요","reference":"느헤미야 12:17","category":"$undefined"},{"id":"12643","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":18,"text":"빌가 족속에는 삼무아요, 스마야 족속에는 여호나단이요","reference":"느헤미야 12:18","category":"$undefined"},{"id":"12644","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":19,"text":"요야립 족속에는 맛드내요, 여다야 족속에는 웃시요","reference":"느헤미야 12:19","category":"$undefined"},{"id":"12645","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":20,"text":"살래 족속에는 갈래요, 아목 족속에는 에벨이요","reference":"느헤미야 12:20","category":"$undefined"},{"id":"12646","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":21,"text":"힐기야 족속에는 하사뱌요, 여다야 족속에는 느다넬이었느니라","reference":"느헤미야 12:21","category":"$undefined"},{"id":"12647","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":22,"text":"엘리아십과, 요야다와, 요하난과, 얏두아 때에 레위 사람의 족장이 모두 책에 기록되었고 바사 왕 다리오때에 제사장도 책에 기록되었고","reference":"느헤미야 12:22","category":"$undefined"},{"id":"12648","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":23,"text":"레위 자손의 족장들은 엘리아십의 아들 요하난 때까지 역대지략에 기록되었으며","reference":"느헤미야 12:23","category":"$undefined"},{"id":"12649","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":24,"text":"레위 사람의 어른은 하사뱌와, 세레뱌와, 갓미엘의 아들 예수아라 저희가 그 형제의 맞은편에 있어 하나님의 사람 다윗의 명한대로 반차를 따라 주를 찬양하며 감사하고","reference":"느헤미야 12:24","category":"$undefined"},{"id":"12650","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":25,"text":"맛다냐와, 박부갸와, 오바댜와, 므술람과, 달몬과, 악굽은 다 문지기로서 반차대로 문 안의 곳간을 파수하였나니","reference":"느헤미야 12:25","category":"$undefined"},{"id":"12651","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":26,"text":"이상 모든 사람은 요사닥의 손자 예수아의 아들 요야김과 방백 느헤미야와 제사장 겸 서기관 에스라 때에 있었느니라","reference":"느헤미야 12:26","category":"$undefined"},{"id":"12652","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":27,"text":"예루살렘 성곽이 낙성되니 각처에서 레위 사람들을 찾아 예루살렘으로 데려다가 감사하며 노래하며 제금 치며 비파와 수금을 타며 즐거이 봉헌식을 행하려 하매","reference":"느헤미야 12:27","category":"$undefined"},{"id":"12653","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":28,"text":"이에 노래하는 자들이 예루살렘 사방 들과 느도바 사람의 동네에서 모여오고","reference":"느헤미야 12:28","category":"$undefined"},{"id":"12654","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":29,"text":"또 벧길갈과 게바와 아스마웹 들에서 모여 왔으니 이 노래하는 자들은 자기를 위하여 예루살렘 사방에 동네를 세웠음이라","reference":"느헤미야 12:29","category":"$undefined"},{"id":"12655","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":30,"text":"제사장들과 레위 사람들이 몸을 정결케 하고 또 백성과 성문과 성을 정결케 하니라","reference":"느헤미야 12:30","category":"$undefined"},{"id":"12656","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":31,"text":"이에 내가 유다의 방백들로 성 위에 오르게 하고 또 감사 찬송하는 자의 큰 무리를 두 떼로 나누어 성 위로 항렬을 지어가게 하는데 한 떼는 우편으로 분문을 향하여 가게 하니","reference":"느헤미야 12:31","category":"$undefined"},{"id":"12657","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":32,"text":"따르는 자는 호세야와 유다 방백의 절반이요","reference":"느헤미야 12:32","category":"$undefined"},{"id":"12658","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":33,"text":"또 아사랴와, 에스라와, 므술람과","reference":"느헤미야 12:33","category":"$undefined"},{"id":"12659","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":34,"text":"유다와, 베냐민과, 스마야와, 예레미야며","reference":"느헤미야 12:34","category":"$undefined"},{"id":"12660","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":35,"text":"또 제사장의 자손 몇이 나팔을 잡았으니 요나단의 아들 스마야의 손자 맛다냐의 증손, 미가야의 현손 삭굴의 오대손, 아삽의 육대손 스가랴와","reference":"느헤미야 12:35","category":"$undefined"},{"id":"12661","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":36,"text":"그 형제 스마야와, 아사렐과, 밀랄래와, 길랄래와, 마애와, 느다넬과, 유다와, 하나니라 다 하나님의 사람 다윗의 악기를 잡았고 학사 에스라가 앞서서","reference":"느헤미야 12:36","category":"$undefined"},{"id":"12662","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":37,"text":"샘문으로 말미암아 전진하여 성으로 올라 가는 곳에 이르러 다윗성의 층계로 올라가서 다윗의 궁 윗 길에서 동향하여 수문에 이르렀고","reference":"느헤미야 12:37","category":"$undefined"},{"id":"12663","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":38,"text":"감사 찬송하는 다른 떼는 저희를 마주 진행하는데 내가 백성의 절반으로 더불어 그 뒤를 따라 성 위로 행하여 풀무 망대 윗 길로 성 넓은 곳에 이르고","reference":"느헤미야 12:38","category":"$undefined"},{"id":"12664","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":39,"text":"에브라임 문 위로 말미암아 옛문과, 어문과, 하나넬 망대와, 함메아 망대를 지나 양문에 이르러 감옥 문에 그치매","reference":"느헤미야 12:39","category":"$undefined"},{"id":"12665","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":40,"text":"이에 감사 찬송하는 두 떼와 나와 민장의 절반은 하나님의 전에 섰고","reference":"느헤미야 12:40","category":"$undefined"},{"id":"12666","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":41,"text":"제사장 엘리아김과, 마아세야와, 미냐민과, 미가야와, 엘료에내와, 스가랴와, 하나냐는 다 나팔을 잡았고","reference":"느헤미야 12:41","category":"$undefined"},{"id":"12667","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":42,"text":"또 마아세야와, 스마야와, 엘르아살과, 웃시와, 여호하난과, 말기야와, 엘람과, 에셀이 함께 있으며 노래하는 자는 크게 찬송하였는데 그 감독은 예스라히야라","reference":"느헤미야 12:42","category":"$undefined"},{"id":"12668","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":43,"text":"이 날에 무리가 크게 제사를 드리고 심히 즐거워하였으니 이는 하나님이 크게 즐거워하게 하셨음이라 부녀와 어린 아이도 즐거워 하였으므로 예루살렘의 즐거워하는 소리가 멀리 들렸느니라","reference":"느헤미야 12:43","category":"$undefined"},{"id":"12669","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":44,"text":"그 날에 사람을 세워 곳간을 맡기고 제사장들과 레위 사람들에게 돌릴 것 곧 율법에 정한대로 거제물과 처음 익은 것과 십일조를 모든 성읍 밭에서 거두어 이 곳간을 쌓게 하였노니 이는 유다 사람이 섬기는 제사장들과 레위 사람들을 인하여 즐거워함을 인함이라","reference":"느헤미야 12:44","category":"$undefined"},{"id":"12670","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":45,"text":"저희는 하나님을 섬기는 일과 결례의 일을 힘썼으며 노래하는 자들과 문지기들도 그러하여 모두 다윗과 그 아들 솔로몬의 명을 좇아 행하였으니","reference":"느헤미야 12:45","category":"$undefined"},{"id":"12671","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":46,"text":"옛적 다윗과 아삽의 때에는 노래하는 자의 두목이 있어서 하나님께 찬송하는 노래와 감사하는 노래를 하였음이며","reference":"느헤미야 12:46","category":"$undefined"},{"id":"12672","book":"느헤미야","book_name":"느헤미야","chapter":12,"verse":47,"text":"스룹바벨과 느헤미야 때에는 온 이스라엘이 노래하는 자들과 문지기들에게 날마다 쓸 것을 주되 그 구별한 것을 레위 사람들에게 주고 레위 사람들은 그것을 또 구별하여 아론 자손에게 주었느니라","reference":"느헤미야 12:47","category":"$undefined"}],"bookSlug":"nehemiah"}]
