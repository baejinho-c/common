2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":13,"verses":[{"id":"12673","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":1,"text":"그날에 모세의 책을 낭독하여 기록하기를 암몬 사람과 모압 사람은 영영히 하나님의 회에 들어 오지 못하리니","reference":"느헤미야 13:1","category":"$undefined"},{"id":"12674","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":2,"text":"이는 저희가 양식과 물로 이스라엘 자손을 영접지 아니하고 도리어 발람에게 뇌물을 주어 저주하게 하였음이라 그러나 우리 하나님이 그 저주를 돌이켜 복이 되게 하였는지라","reference":"느헤미야 13:2","category":"$undefined"},{"id":"12675","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":3,"text":"백성이 이 율법을 듣고 곧 섞인 무리를 이스라엘 가운데서 몰수히 분리케 하였느니라","reference":"느헤미야 13:3","category":"$undefined"},{"id":"12676","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":4,"text":"이전에 우리 하나님의 전 골방을 맡은 제사장 엘리아십이 도비야와 연락이 있었으므로","reference":"느헤미야 13:4","category":"$undefined"},{"id":"12677","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":5,"text":"도비야를 위하여 한 큰 방을 갖추었으니 그 방은 원래 소제물과 유향과 또 기명과 레위 사람들과 노래하는 자들과 문지기들에게 십일조로 주는 곡물과 새 포도주와 기름과 또 제사장들에게 주는 거제물을 두는 곳이라","reference":"느헤미야 13:5","category":"$undefined"},{"id":"12678","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":6,"text":"그 때에는 내가 예루살렘에 있지 아니하였었느니라 바벨론 왕 아닥사스다 삼십 이년에 내가 왕에게 나아갔다가 며칠 후에 왕에게 말미를 청하고","reference":"느헤미야 13:6","category":"$undefined"},{"id":"12679","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":7,"text":"예루살렘에 이르러서야 엘리아십이 도비야를 위하여 하나님의 전뜰에 방을 갖춘 악한 일을 안지라","reference":"느헤미야 13:7","category":"$undefined"},{"id":"12680","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":8,"text":"내가 심히 근심하여 도비야의 세간을 그 방 밖으로 다 내어 던지고","reference":"느헤미야 13:8","category":"$undefined"},{"id":"12681","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":9,"text":"명하여 그 방을 정결케 하고 하나님의 전의 기명과 소제물과 유향을 다시 그리로 들여 놓았느니라","reference":"느헤미야 13:9","category":"$undefined"},{"id":"12682","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":10,"text":"내가 또 알아 본즉 레위 사람들의 받을 것을 주지 아니 하였으므로 그 직무를 행하는 레위 사람들과 노래하는 자들이 각각 그 전리로 도망하였기로","reference":"느헤미야 13:10","category":"$undefined"},{"id":"12683","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":11,"text":"내가 모든 민장을 꾸짖어 이르기를 `하나님의 전이 어찌하여 버린바 되었느냐 ?' 하고 곧 레위 사람을 불러 모아 다시 그 처소에 세웠더니","reference":"느헤미야 13:11","category":"$undefined"},{"id":"12684","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":12,"text":"이에 온 유다가 곡식과 새 포도주와 기름의 십일조를 가져다가 곳간에 들이므로","reference":"느헤미야 13:12","category":"$undefined"},{"id":"12685","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":13,"text":"내가 제사장 셀레먀와, 서기관 사독과, 레위 사람 브다야로 고지기를 삼고 맛다냐의 손자 삭굴의 아들 하난으로 버금을 삼았나니 이는 저희가 충직한 자로 인정됨이라 그 직분은 형제들에게 분배하는 일이였느니라","reference":"느헤미야 13:13","category":"$undefined"},{"id":"12686","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":14,"text":"내 하나님이여, 이 일을 인하여 나를 기억하옵소서 ! 내 하나님의 전과 그 모든 직무를 위하여 나의 행한 선한 일을 도말하지 마옵소서","reference":"느헤미야 13:14","category":"$undefined"},{"id":"12687","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":15,"text":"그 때에 내가 본즉 유다에게 어떤 사람이 안식일에 술틀을 밟고 곡식단을 나귀에 실어 운반하며 포도주와 포도와 무화과와 여러 가지 짐을 지고 안식일에 예루살렘에 들어와서 식물을 팔기로 그날에 내가 경계하였고","reference":"느헤미야 13:15","category":"$undefined"},{"id":"12688","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":16,"text":"또 두로 사람이 예루살렘에 거하며 물고기와 각양 물건을 가져다가 안식일에 유다 자손에게 예루살렘에서도 팔기로","reference":"느헤미야 13:16","category":"$undefined"},{"id":"12689","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":17,"text":"내가 유다 모든 귀인을 꾸짖어 이르기를 `너희가 어찌 이 악을 행하여 안식일을 범하느냐 ?","reference":"느헤미야 13:17","category":"$undefined"},{"id":"12690","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":18,"text":"너희 열조가 이같이 행하지 아니 하였느냐 ? 그러므로 우리 하나님이 이 모든 재앙으로 우리와 이 성읍에 내리신 것이 아니냐 ? 이제 너희가 오히려 안식일을 범하여 진노가 이스라엘에게 임함이 더욱 심하게 하는도다' 하고","reference":"느헤미야 13:18","category":"$undefined"},{"id":"12691","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":19,"text":"안식일 전 예루살렘 성문이 어두워 갈 때에 내가 명하여 `성문을 닫고 안식일이 지나기 전에는 열지 말라' 하고 내 종자 두어 사람을 성문마다 세워서 안식일에 아무 짐도 들어오지 못하게 하매","reference":"느헤미야 13:19","category":"$undefined"},{"id":"12692","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":20,"text":"장사들과 각양 물건 파는 자들이 한두번 예루살렘 성 밖에서 자므로","reference":"느헤미야 13:20","category":"$undefined"},{"id":"12693","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":21,"text":"내가 경계하여 이르기를 `너희가 어찌하여 성 밑에서 자느냐 ? 다시 이같이 하면 내가 잡으리라' 하였더니 그 후부터는 안식일에 저희가 다시 오지 아니하였느니라","reference":"느헤미야 13:21","category":"$undefined"},{"id":"12694","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":22,"text":"내가 또 레위 사람들을 명하여 `몸을 정결케 하고 와서 성문을 지켜서 안식일로 거룩하게 하라' 하였느니라 나의 하나님이여, 나를 위하여 이 일도 기억하옵시고 주의 큰 은혜대로 나를 아끼시옵소서 !","reference":"느헤미야 13:22","category":"$undefined"},{"id":"12695","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":23,"text":"그 때에 내가 또 본즉 유다 사람이 아스돗과 암몬과 모압 여인을 취하여 아내를 삼았는데","reference":"느헤미야 13:23","category":"$undefined"},{"id":"12696","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":24,"text":"그 자녀가 아스돗 방언을 절반쯤은 하여도 유다 방언은 못하니 그 하는 말이 각 족속의 방언이므로","reference":"느헤미야 13:24","category":"$undefined"},{"id":"12697","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":25,"text":"내가 책망하고 저주하며 두어 사람을 때리고 그 머리털을 뽑고 이르되 `너희는 너희 딸들로 저희 아들들에게 주지 말고 너희 아들들이나 너희를 위하여 저희 딸을 데려오지 않겠다고 하나님을 가리켜 맹세하라' 하고","reference":"느헤미야 13:25","category":"$undefined"},{"id":"12698","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":26,"text":"또 이르기를 `옛적에 이스라엘 왕 솔로몬이 이 일로 범죄하지 아니하였느냐 ? 저는 열국 중에 비길 왕이 없이 하나님의 사랑을 입은 자라 하나님이 저로 왕을 삼아 온 이스라엘을 다스리게 하셨으나 이방 여인이 저로 범죄케 하였나니","reference":"느헤미야 13:26","category":"$undefined"},{"id":"12699","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":27,"text":"너희가 이방 여인을 취하여 크게 악을 행하여 우리 하나님께 범죄하는 것을 우리가 어찌 용납하겠느냐","reference":"느헤미야 13:27","category":"$undefined"},{"id":"12700","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":28,"text":"대제사장 엘리아십의 손자 요야다의 아들 하나가 호론 사람 산발랏의 사위가 되었으므로 내가 쫓아내어 나를 떠나게 하였느니라'","reference":"느헤미야 13:28","category":"$undefined"},{"id":"12701","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":29,"text":"내 하나님이여, 저희가 제사장의 직분을 더럽히고 제사장의 직분과 레위 사람에 대한 언약을 어기었사오니 저희를 기억하옵소서","reference":"느헤미야 13:29","category":"$undefined"},{"id":"12702","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":30,"text":"이와 같이 저희로 이방 사람을 떠나게 하여 깨끗하게 하고 또 제사장과 레위 사람의 반열을 세워 각각 그 일을 맡게 하고","reference":"느헤미야 13:30","category":"$undefined"},{"id":"12703","book":"느헤미야","book_name":"느헤미야","chapter":13,"verse":31,"text":"또 정한 기한에 나무와 처음 익은 것을 드리게 하였사오니 내 하나님이여, 나를 기억하사 복을 주옵소서 !","reference":"느헤미야 13:31","category":"$undefined"}],"bookSlug":"nehemiah"}]
