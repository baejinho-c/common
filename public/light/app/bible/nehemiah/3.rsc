2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":3,"verses":[{"id":"12329","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":1,"text":"때에 대제사장 엘리아십이 그 형제 제사장들과 함께 일어나 양문을 건축하여 성별하고 문짝을 달고 또 성벽을 건축하여 함메아 망대에서부터 하나넬 망대까지 성별하였고","reference":"느헤미야 3:1","category":"$undefined"},{"id":"12330","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":2,"text":"그 다음은 여리고 사람들이 건축하였고 또 그 다음은 이므리의 아들 삭굴이 건축하였으며","reference":"느헤미야 3:2","category":"$undefined"},{"id":"12331","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":3,"text":"어문은 하스나아의 자손들이 건축하여 그 들보를 얹고 문짝을 달고 자물쇠와 빗장을 갖추었고","reference":"느헤미야 3:3","category":"$undefined"},{"id":"12332","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":4,"text":"그 다음은 학고스의 손자 우아의 아들 므레못이 중수하였고 그 다음은 므세사벨의 손자 베레갸의 아들 므술람이 중수하였고 그 다음은 바아나의 아들 사독이 중수하였고","reference":"느헤미야 3:4","category":"$undefined"},{"id":"12333","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":5,"text":"그 다음은 드고아 사람들이 중수하였으나 그 귀족들은 그 주의 역사에 담부치 아니하였으며","reference":"느헤미야 3:5","category":"$undefined"},{"id":"12334","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":6,"text":"옛 문은 바세아의 아들 요야다와 브소드야의 아들 므술람이 중수하여 그 들보를 얹고 문짝을 달고 자물쇠와 빗장을 갖추었고","reference":"느헤미야 3:6","category":"$undefined"},{"id":"12335","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":7,"text":"그 다음은 기브온 사람 믈라야와 메로놋 사람 야돈이 강 서편 총독의 관할에 속한 기브온 사람들과 미스바 사람들로 더불어 중수하였고","reference":"느헤미야 3:7","category":"$undefined"},{"id":"12336","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":8,"text":"그 다음은 금장색 할해야의 아들 웃시엘 등이 중수하였고 그 다음은 향품 장사 하나냐 등이 중수하되 저희가 예루살렘 넓은 성벽까지 하였고","reference":"느헤미야 3:8","category":"$undefined"},{"id":"12337","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":9,"text":"그 다음은 예루살렘 지방 절반을 다스리는 자 후르의 아들 르바야가 중수하였고","reference":"느헤미야 3:9","category":"$undefined"},{"id":"12338","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":10,"text":"하루맙의 아들 여다야는 자기 집과 마주 대한 곳을 중수하였고 그 다음은 하삽느야의 아들 핫두스가 중수하였고","reference":"느헤미야 3:10","category":"$undefined"},{"id":"12339","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":11,"text":"하림의 아들 말기야와 바핫모압의 아들 핫숩이 한 부분과 풀무망대를 중수하였고","reference":"느헤미야 3:11","category":"$undefined"},{"id":"12340","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":12,"text":"그 다음은 예루살렘 지방 절반을 다스리는 자 할로헤스의 아들 살룸과 그 딸들이 중수하였고","reference":"느헤미야 3:12","category":"$undefined"},{"id":"12341","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":13,"text":"골짜기 문은 하눈과 사노아 거민이 중수하여 문을 세우며 문짝을 달고 자물쇠와 빗장을 갖추고 또 분문까지 성벽 일천 규빗을 중수하였고","reference":"느헤미야 3:13","category":"$undefined"},{"id":"12342","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":14,"text":"분문은 벧학게렘 지방을 다스리는 레갑의 아들 말기야가 중수하여 문을 세우며 문짝을 달고 자물쇠와 빗장을 갖추었고","reference":"느헤미야 3:14","category":"$undefined"},{"id":"12343","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":15,"text":"샘문은 미스바 지방을 다스리는 골호세의 아들 살룬이 중수하여 문을 세우고 덮으며 문짝을 달며 자물쇠와 빗장을 갖추고 또 왕의 동산 근처 셀라 못가의 성벽을 중수하여 다윗성에서 내려오는 층계까지 이르렀고","reference":"느헤미야 3:15","category":"$undefined"},{"id":"12344","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":16,"text":"그 다음은 벧술 지방 절반을 다스리는 자 아스북의 아들 느헤미야가 중수하여 다윗의 묘실과 마주 대한곳에 이르고 또 파서 만든 못을 지나 용사의 집까지 이르렀고","reference":"느헤미야 3:16","category":"$undefined"},{"id":"12345","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":17,"text":"그 다음은 레위 사람 바니의 아들 르훔이 중수하였고 그 다음은 그일라 지방 절반을 다스리는 자 하사뱌가 그 지방을 대표하여 중수하였고","reference":"느헤미야 3:17","category":"$undefined"},{"id":"12346","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":18,"text":"그 다음은 그 형제 그일라 지방 절반을 다스리는 자 헤나닷의 아들 바왜가 중수하였고","reference":"느헤미야 3:18","category":"$undefined"},{"id":"12347","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":19,"text":"그 다음은 미스바를 다스리는 자 예수아의 아들 에셀이 한 부분을 중수하여 성 굽이에 있는 군기고 맞은편까지 이르렀고","reference":"느헤미야 3:19","category":"$undefined"},{"id":"12348","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":20,"text":"그 다음은 삽배의 아들 바룩이 한 부분을 힘써 중수하여 성 굽이에서부터 대제사장 엘리아십의 집 문에 이르렀고","reference":"느헤미야 3:20","category":"$undefined"},{"id":"12349","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":21,"text":"그 다음은 학고스의 손자 우리야의 아들 므레못이 한 부분을 중수하여 엘리아십의 집 문에서부터 엘리아십의 집 모퉁이에 이르렀고","reference":"느헤미야 3:21","category":"$undefined"},{"id":"12350","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":22,"text":"그 다음은 평지에 사는 제사장들이 중수하였고","reference":"느헤미야 3:22","category":"$undefined"},{"id":"12351","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":23,"text":"그 다음은 베냐민과 핫숩이 자기 집 맞은편 부분을 중수하였고 그 다음은 아나냐의 손자 마아세야의 아들 아사랴가 자기 집에서 가까운 부분을 중수하였고","reference":"느헤미야 3:23","category":"$undefined"},{"id":"12352","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":24,"text":"그 다음은 헤나닷의 아들 빈누이가 한 부분을 중수하되 아사랴의 집에서부터 성 굽이를 지나 성 모퉁이에 이르렀고","reference":"느헤미야 3:24","category":"$undefined"},{"id":"12353","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":25,"text":"우새의 아들 발랄은 성 굽이 맞은편과 왕의 윗 궁에서 내어민 망대 맞은편 곧 시위청에서 가까운 부분을 중수하였고 그 다음은 바로스의 아들 브다야가 중수하였고","reference":"느헤미야 3:25","category":"$undefined"},{"id":"12354","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":26,"text":"(때에 느디님 사람은 오벨에 거하여 동편 수문과 마주 대한 곳에서부터 내어민 망대까지 미쳤느니라)","reference":"느헤미야 3:26","category":"$undefined"},{"id":"12355","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":27,"text":"그 다음은 드고아 사람들이 한 부분을 중수하여 내어민 큰 망대와 마주 대한 곳에서부터 오벨 성벽까지 이르렀느니라","reference":"느헤미야 3:27","category":"$undefined"},{"id":"12356","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":28,"text":"마문 위로부터는 제사장들이 각각 자기집과 마주 대한 부분을 중수하였고","reference":"느헤미야 3:28","category":"$undefined"},{"id":"12357","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":29,"text":"그 다음은 임멜의 아들 사독이 자기 집과 마주 대한 부분을 중수하였고 그 다음은 동문지기 스가냐의 아들 스마야가 중수하였고","reference":"느헤미야 3:29","category":"$undefined"},{"id":"12358","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":30,"text":"그 다음은 셀레먀의 아들 하나냐와 살랍의 여섯째 아들 하눈이 한 부분을 중수하였고 그 다음은 베레갸의 아들 므술람이 자기 침방과 마주 대한 부분을 중수하였고","reference":"느헤미야 3:30","category":"$undefined"},{"id":"12359","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":31,"text":"그 다음은 금장색 말기야가 함밉갓 문과 마주 대한 부분을 중수하여 느디님 사람과 상고들의 집에서부터 성 모퉁이 누에 이르렀고","reference":"느헤미야 3:31","category":"$undefined"},{"id":"12360","book":"느헤미야","book_name":"느헤미야","chapter":3,"verse":32,"text":"성 모퉁이 누에서 양문까지는 금장색과 상고들이 중수하였느니라","reference":"느헤미야 3:32","category":"$undefined"}],"bookSlug":"nehemiah"}]
