2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":5,"verses":[{"id":"12384","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":1,"text":"때에 백성이 그 아내와 함께 크게 부르짖어 그 형제 유다 사람을 원망하는데","reference":"느헤미야 5:1","category":"$undefined"},{"id":"12385","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":2,"text":"혹은 말하기를 `우리와 우리 자녀가 많으니 곡식을 얻어 먹고 살아야 하겠다' 하고","reference":"느헤미야 5:2","category":"$undefined"},{"id":"12386","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":3,"text":"혹은 말하기를 `우리의 밭과 포도원과 집이라도 전당 잡히고 이 흉년을 위하여 곡식을 얻자' 하고","reference":"느헤미야 5:3","category":"$undefined"},{"id":"12387","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":4,"text":"혹은 말하기를 `우리는 밭과 포도원으로 돈을 빚내어 세금을 바쳤도다","reference":"느헤미야 5:4","category":"$undefined"},{"id":"12388","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":5,"text":"우리 육체도 우리 형제의 육체와 같고 우리 자녀도 저희 자녀 같거늘 이제 우리 자녀를 종으로 파는도다 우리 딸 중에 벌써 종된 자가 있으나 우리의 밭과 포도원이 이미 남의 것이 되었으니 속량할 힘이 없도다'","reference":"느헤미야 5:5","category":"$undefined"},{"id":"12389","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":6,"text":"내가 백성의 부르짖음과 이런 말을 듣고 크게 노하여","reference":"느헤미야 5:6","category":"$undefined"},{"id":"12390","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":7,"text":"중심에 계획하고 귀인과 민장을 꾸짖어 이르기를 `너희가 각기 형제에게 취리를 하는도다' 하고 대회를 열고 저희를 쳐서","reference":"느헤미야 5:7","category":"$undefined"},{"id":"12391","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":8,"text":"이르기를 `우리는 이방인의 손에 팔린 우리 형제 유다 사람들을 우리의 힘을 다하여 속량하였거늘 너희는 너희 형제를 팔고자 하느냐 ? 더구나 우리의 손에 팔리게 하겠느냐 ?' 하매 저희가 잠잠하여 말이 없기로","reference":"느헤미야 5:8","category":"$undefined"},{"id":"12392","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":9,"text":"내가 또 이르기를 `너희의 소위가 좋지 못하도다 우리 대적 이방사람의 비방을 생각하고 우리 하나님을 경외함에 행할 것이 아니냐 ?","reference":"느헤미야 5:9","category":"$undefined"},{"id":"12393","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":10,"text":"나와 내 형제와 종자들도 역시 돈과 곡식을 백성에게 취하여 주나니 우리가 그 이식 받기를 그치자","reference":"느헤미야 5:10","category":"$undefined"},{"id":"12394","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":11,"text":"그런즉 너희는 오늘이라도 그 밭과 포도원과 감람원과 집이며 취한 바 돈이나 곡식이나 새 포도주나 기름의 백분지 일을 돌려 보내라' 하였더니","reference":"느헤미야 5:11","category":"$undefined"},{"id":"12395","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":12,"text":"저희가 말하기를 `우리가 당신의 말씀대로 행하여 돌려 보내고 아무것도 요구하지 아니하리이다' 하기로 내가 제사장들을 불러 저희에게 그 말대로 행하리라는 맹세를 시키게 하고","reference":"느헤미야 5:12","category":"$undefined"},{"id":"12396","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":13,"text":"내가 옷자락을 떨치며 이르기를 `이 말대로 행치 아니하는 자는 하나님이 또한 이와 같이 그 집과 산업에서 떨치실지니 저는 곧 이렇게 떨쳐져 빌지로다' 하매 회중이 다 아멘 ! 하고 여호와를 찬송하고 백성들이 그 말한대로 행하였느니라","reference":"느헤미야 5:13","category":"$undefined"},{"id":"12397","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":14,"text":"내가 유다 땅 총독으로 세움을 받을 때 곧 아닥사스다왕 이십년부터 삼십 이년까지 십이년동안은 나와 내 형제가 총독의 녹을 먹지 아니하였느니라","reference":"느헤미야 5:14","category":"$undefined"},{"id":"12398","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":15,"text":"이전 총독들은 백성에게 토색하여 양식과 포도주와 또 은 사십 세겔을 취하였고 그 종자들도 백성을 압제하였으나 나는 하나님을 경외하므로 이같이 행치 아니하고","reference":"느헤미야 5:15","category":"$undefined"},{"id":"12399","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":16,"text":"도리어 이 성 역사에 힘을 다하며 땅을 사지 아니하였고 나의 모든 종자도 모여서 역사를 하였으며","reference":"느헤미야 5:16","category":"$undefined"},{"id":"12400","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":17,"text":"또 내 상에는 유다 사람들과 민장들 일백 오십인이 있고 그 외에도 우리 사면 이방인 중에서 우리에게 나아온 자들이 있었는데","reference":"느헤미야 5:17","category":"$undefined"},{"id":"12401","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":18,"text":"매일 나를 위하여 소 하나와 살진 양 여섯을 준비하며 닭도 많이 준비하고 열흘에 한 번씩은 각종 포도주를 갖추었나니 비록 이같이 하였을지라도 내가 총독의 녹을 요구하지 아니하였음은 백성의 부역이 중함이니라","reference":"느헤미야 5:18","category":"$undefined"},{"id":"12402","book":"느헤미야","book_name":"느헤미야","chapter":5,"verse":19,"text":"내 하나님이여, 내가 이 백성을 위하여 행한 모든 일을 생각하시고 내게 은혜를 베푸시옵소서 !","reference":"느헤미야 5:19","category":"$undefined"}],"bookSlug":"nehemiah"}]
