2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":6,"verses":[{"id":"12403","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":1,"text":"산발랏과 도비야와 아라비아 사람 게셈과 그 나머지 우리의 대적이 내가 성을 건축하여 그 퇴락한 곳을 남기지 아니하였다 함을 들었는데 내가 아직 성문에 문짝을 달지 못한 때라","reference":"느헤미야 6:1","category":"$undefined"},{"id":"12404","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":2,"text":"산발랏과 게셈이 내게 보내어 이르기를 `오라 ! 우리가 오노 평지 한 촌에서 서로 만나자' 하니 실상은 나를 해코자 함이라","reference":"느헤미야 6:2","category":"$undefined"},{"id":"12405","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":3,"text":"내가 곧 저희에게 사자들을 보내어 이르기를 `내가 이제 큰 역사를 하니 내려가지 못하겠노라 어찌하여 역사를 떠나 정지하게 하고 너희에게로 내려가겠느냐 ?' 하매","reference":"느헤미야 6:3","category":"$undefined"},{"id":"12406","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":4,"text":"저희가 네번이나 이같이 내게 보내되 나는 여전히 대답하였더니","reference":"느헤미야 6:4","category":"$undefined"},{"id":"12407","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":5,"text":"산발랏이 다섯번째는 그 종자의 손에 봉하지 않은 편지를 들려 내게 보내었는데","reference":"느헤미야 6:5","category":"$undefined"},{"id":"12408","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":6,"text":"그 글에 이르기를 이방 중에도 소문이 있고 가스무도 말하기를 네가 유다 사람들로 더불어 모반하려 하여 성을 건축한다 하나니 네가 그 말과 같이 왕이 되려 하는도다","reference":"느헤미야 6:6","category":"$undefined"},{"id":"12409","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":7,"text":"또 네가 선지자를 세워 예루살렘에서 너를 들어 선전하기를 유다에 왕이 있다 하게 하였으니 이 말이 왕에게 들릴지라 그런즉 너는 이제 오라 함께 의논하자 하였기로","reference":"느헤미야 6:7","category":"$undefined"},{"id":"12410","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":8,"text":"내가 보내어 저에게 이르기를 `너의 말한바 이런 일은 없는 일이요 네 마음에서 지어낸 것이라' 하였나니","reference":"느헤미야 6:8","category":"$undefined"},{"id":"12411","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":9,"text":"이는 저희가 다 우리를 두렵게 하고자 하여 말하기를 `저희 손이 피곤하여 역사를 정지하고 이루지 못하리라' 함이라 `이제 내 손을 힘있게 하옵소서 !' 하였노라","reference":"느헤미야 6:9","category":"$undefined"},{"id":"12412","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":10,"text":"이 후에 므헤다벨의 손자 들라야의 아들 스마야가 두문불출하기로 내가 그 집에 가니 저가 이르기를 저희가 너를 죽이러 올 터이니 우리가 하나님의 전으로 가서 외소 안에 있고 그 문을 닫자 저희가 필연 밤에 와서 너를 죽이리라 하기로","reference":"느헤미야 6:10","category":"$undefined"},{"id":"12413","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":11,"text":"내가 이르기를 `나같은 자가 어찌 도망하며 나같은 몸이면 누가 외소에 들어가서 생명을 보존하겠느냐 ? 나는 들어가지 않겠노라' 하고","reference":"느헤미야 6:11","category":"$undefined"},{"id":"12414","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":12,"text":"깨달은즉 저는 하나님의 보내신 바가 아니라 도비야와 산발랏에게 뇌물을 받고 내게 이런 예언을 함이라","reference":"느헤미야 6:12","category":"$undefined"},{"id":"12415","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":13,"text":"저희가 뇌물을 준 까닭은 나를 두렵게 하고 이렇게 함으로 범죄하게 하고 악한 말을 지어 나를 비방하려 함이었느니라","reference":"느헤미야 6:13","category":"$undefined"},{"id":"12416","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":14,"text":"내 하나님이여, 도비야와 산발랏과 여선지 노아댜와, 그 남은 선지자들 무릇 나를 두렵게 하고자 한 자의 소위를 기억하옵소서 ! 하였노라","reference":"느헤미야 6:14","category":"$undefined"},{"id":"12417","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":15,"text":"성 역사가 오십 이일만에 엘룰월 이십 오일에 끝나매","reference":"느헤미야 6:15","category":"$undefined"},{"id":"12418","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":16,"text":"우리 모든 대적과 사면 이방사람들이 이를 듣고 다 두려워하여 스스로 낙담하였으니 이는 이 역사를 우리 하나님이 이루신 것을 앎이니라","reference":"느헤미야 6:16","category":"$undefined"},{"id":"12419","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":17,"text":"그 때에 유다의 귀인들이 여러번 도비야에게 편지하였고 도비야의 편지도 저희에게 이르렀으니","reference":"느헤미야 6:17","category":"$undefined"},{"id":"12420","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":18,"text":"도비야는 아라의 아들 스가냐의 사위가 되었고 도비야의 아들 여호하난도 베레갸의 아들 므술람의 딸을 취하였으므로 유다에서 저와 동맹한 자가 많음이라","reference":"느헤미야 6:18","category":"$undefined"},{"id":"12421","book":"느헤미야","book_name":"느헤미야","chapter":6,"verse":19,"text":"저희들이 도비야의 선행을 내 앞에 말하고 또 나의 말도 저에게 전하매 도비야가 항상 내게 편지하여 나를 두렵게 하고자 하였느니라","reference":"느헤미야 6:19","category":"$undefined"}],"bookSlug":"nehemiah"}]
