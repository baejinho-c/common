2:["$","$L11",null,{"book":{"id":"nehemiah","name":"느헤미야","chapters":13,"testament":"old"},"chapter":7,"verses":[{"id":"12422","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":1,"text":"성이 건축되매 문짝을 달고 문지기와 노래하는 자들과 레위 사람들을 세운 후에","reference":"느헤미야 7:1","category":"$undefined"},{"id":"12423","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":2,"text":"내 아우 하나니와 영문의 관원 하나냐로 함께 예루살렘을 다스리게 하였는데 하나냐는 위인이 충성되어 하나님을 경외함이 무리에서 뛰어난자라","reference":"느헤미야 7:2","category":"$undefined"},{"id":"12424","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":3,"text":"내가 저희에게 이르기를 해가 높이 뜨기 전에는 예루살렘 성문을 열지 말고 아직 파수할 때에 곧 문을 닫고 빗장을 지르며 또 예루살렘 거민으로 각각 반차를 따라 파수하되 자기 집 맞은편을 지키게 하라 하였노니","reference":"느헤미야 7:3","category":"$undefined"},{"id":"12425","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":4,"text":"그 성은 광대하고 거민은 희소하여 가옥을 오히려 건축하지 못하였음이니라","reference":"느헤미야 7:4","category":"$undefined"},{"id":"12426","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":5,"text":"내 하나님이 내 마음을 감동하사 귀인들과 민장과 백성을 모아 보계대로 계수하게 하신고로 내가 처음으로 돌아온 자의 보계를 얻었는데 거기 기록한 것을 보면","reference":"느헤미야 7:5","category":"$undefined"},{"id":"12427","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":6,"text":"옛적에 바벨론 왕 느부갓네살에게 사로잡혀 갔던 자 중에서 놓임을 받고 예루살렘과 유다로 돌아와 각기 본성에 이른 자 곧","reference":"느헤미야 7:6","category":"$undefined"},{"id":"12428","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":7,"text":"스룹바벨과, 예수아와, 느헤미야와, 아사랴와, 라아마와, 나하마니와, 모르드개와, 빌산과, 미스베렛과, 비그왜와, 느훔과, 바아나 등과 함께 나온 이스라엘 백성의 명수가 이러하니라","reference":"느헤미야 7:7","category":"$undefined"},{"id":"12429","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":8,"text":"바로스 자손이 이천 일백 칠십 이명이요","reference":"느헤미야 7:8","category":"$undefined"},{"id":"12430","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":9,"text":"스바댜 자손이 삼백 칠십 이명이요","reference":"느헤미야 7:9","category":"$undefined"},{"id":"12431","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":10,"text":"아라 자손이 육백 오십 이명이요","reference":"느헤미야 7:10","category":"$undefined"},{"id":"12432","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":11,"text":"바핫모압 자손 곧 예수아와 요압 자손이 이천 팔백 십 팔명이요","reference":"느헤미야 7:11","category":"$undefined"},{"id":"12433","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":12,"text":"엘람 자손이 일천 이백 오십 사명이요","reference":"느헤미야 7:12","category":"$undefined"},{"id":"12434","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":13,"text":"삿두 자손이 팔백 사십 오명이요","reference":"느헤미야 7:13","category":"$undefined"},{"id":"12435","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":14,"text":"삭개 자손이 칠백 육십명이요","reference":"느헤미야 7:14","category":"$undefined"},{"id":"12436","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":15,"text":"빈누이 자손이 육백 사십 팔명이요","reference":"느헤미야 7:15","category":"$undefined"},{"id":"12437","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":16,"text":"브배 자손이 육백 이십 팔명이요","reference":"느헤미야 7:16","category":"$undefined"},{"id":"12438","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":17,"text":"아스갓 자손이 이천 삼백 이십 이명이요","reference":"느헤미야 7:17","category":"$undefined"},{"id":"12439","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":18,"text":"아도니감 자손이 육백 육십 칠명이요","reference":"느헤미야 7:18","category":"$undefined"},{"id":"12440","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":19,"text":"비그왜 자손이 이천 육십 칠명이요","reference":"느헤미야 7:19","category":"$undefined"},{"id":"12441","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":20,"text":"아딘 자손이 육백 오십 오명이요","reference":"느헤미야 7:20","category":"$undefined"},{"id":"12442","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":21,"text":"아델 자손 곧 히스기야 자손이 구십 팔명이요","reference":"느헤미야 7:21","category":"$undefined"},{"id":"12443","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":22,"text":"하숨 자손이 삼백 이십 팔명이요","reference":"느헤미야 7:22","category":"$undefined"},{"id":"12444","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":23,"text":"베새 자손이 삼백 이십 사명이요","reference":"느헤미야 7:23","category":"$undefined"},{"id":"12445","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":24,"text":"하립 자손이 일백 십 이명이요","reference":"느헤미야 7:24","category":"$undefined"},{"id":"12446","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":25,"text":"기브온 사람이 구십 오명이요","reference":"느헤미야 7:25","category":"$undefined"},{"id":"12447","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":26,"text":"베들레헴과 느도바 사람이 일백 팔십 팔명이요","reference":"느헤미야 7:26","category":"$undefined"},{"id":"12448","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":27,"text":"아나돗 사람이 일백 이십 팔명이요","reference":"느헤미야 7:27","category":"$undefined"},{"id":"12449","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":28,"text":"벧아스마웹 사람이 사십 이명이요","reference":"느헤미야 7:28","category":"$undefined"},{"id":"12450","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":29,"text":"기럇여아림과 그비라와 브에롯 사람이 칠백 사십 삼명이요","reference":"느헤미야 7:29","category":"$undefined"},{"id":"12451","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":30,"text":"라마와 게바 사람이 육백 이십 일명이요","reference":"느헤미야 7:30","category":"$undefined"},{"id":"12452","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":31,"text":"믹마스 사람이 일백 이십 이명이요","reference":"느헤미야 7:31","category":"$undefined"},{"id":"12453","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":32,"text":"벧엘과 아이 사람이 일백 이십 삼명이요","reference":"느헤미야 7:32","category":"$undefined"},{"id":"12454","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":33,"text":"기타 느보 사람이 오십 이명이요","reference":"느헤미야 7:33","category":"$undefined"},{"id":"12455","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":34,"text":"기타 엘람 자손이 일천 이백 오십 사명이요","reference":"느헤미야 7:34","category":"$undefined"},{"id":"12456","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":35,"text":"하림 자손이 삼백 이십명이요","reference":"느헤미야 7:35","category":"$undefined"},{"id":"12457","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":36,"text":"여리고 자손이 삼백 사십 오명이요","reference":"느헤미야 7:36","category":"$undefined"},{"id":"12458","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":37,"text":"로드와 하딧과 오노 자손이 칠백 이십 일명이요","reference":"느헤미야 7:37","category":"$undefined"},{"id":"12459","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":38,"text":"스나아 자손이 삼천 구백 삼십명이었느니라","reference":"느헤미야 7:38","category":"$undefined"},{"id":"12460","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":39,"text":"제사장들은 예수아의 집 여다야 자손이 구백 칠십 삼명이요","reference":"느헤미야 7:39","category":"$undefined"},{"id":"12461","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":40,"text":"임멜 자손이 일천 오십 이명이요","reference":"느헤미야 7:40","category":"$undefined"},{"id":"12462","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":41,"text":"바수훌 자손이 일천 이백 사십 칠명이요","reference":"느헤미야 7:41","category":"$undefined"},{"id":"12463","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":42,"text":"하림 자손이 일천 십 칠명이였느니라","reference":"느헤미야 7:42","category":"$undefined"},{"id":"12464","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":43,"text":"레위 사람들은 호드야 자손 곧 예수아와 갓미엘 자손이 칠십 사명이요","reference":"느헤미야 7:43","category":"$undefined"},{"id":"12465","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":44,"text":"노래하는 자들은 아삽 자손이 일백 사십 팔명이요","reference":"느헤미야 7:44","category":"$undefined"},{"id":"12466","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":45,"text":"문지기들은 살룸 자손과, 아델 자손과, 달문 자손과, 악굽 자손과, 하디다 자손과, 소배 자손이 모두 일백 삼십 팔명이었느니라","reference":"느헤미야 7:45","category":"$undefined"},{"id":"12467","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":46,"text":"느디님 사람들은 시하 자손과, 하수바 자손과, 답바옷 자손과","reference":"느헤미야 7:46","category":"$undefined"},{"id":"12468","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":47,"text":"게로스 자손과, 시아 자손과, 바돈 자손과, 르바나 자손과","reference":"느헤미야 7:47","category":"$undefined"},{"id":"12469","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":48,"text":"하가바 자손과, 살매 자손과","reference":"느헤미야 7:48","category":"$undefined"},{"id":"12470","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":49,"text":"하난 자손과, 깃델 자손과, 가할 자손과","reference":"느헤미야 7:49","category":"$undefined"},{"id":"12471","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":50,"text":"르아야 자손과, 르신 자손과, 느고다 자손과","reference":"느헤미야 7:50","category":"$undefined"},{"id":"12472","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":51,"text":"갓삼 자손과, 웃사 자손과, 바세아 자손과","reference":"느헤미야 7:51","category":"$undefined"},{"id":"12473","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":52,"text":"베새 자손과, 므우님 자손과, 느비스심 자손과","reference":"느헤미야 7:52","category":"$undefined"},{"id":"12474","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":53,"text":"박북 자손과, 하그바 자손과, 할훌 자손과","reference":"느헤미야 7:53","category":"$undefined"},{"id":"12475","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":54,"text":"바슬릿 자손과, 므히다 자손과, 하르사 자손과","reference":"느헤미야 7:54","category":"$undefined"},{"id":"12476","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":55,"text":"바르고스 자손과, 시스라 자손과, 데마 자손과","reference":"느헤미야 7:55","category":"$undefined"},{"id":"12477","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":56,"text":"느시야 자손과, 하디바 자손이었느니라","reference":"느헤미야 7:56","category":"$undefined"},{"id":"12478","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":57,"text":"솔로몬의 신복의 자손은 소대 자손과, 소베렛 자손과, 브리다 자손과","reference":"느헤미야 7:57","category":"$undefined"},{"id":"12479","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":58,"text":"야알라 자손과, 다르곤 자손과, 깃델 자손과","reference":"느헤미야 7:58","category":"$undefined"},{"id":"12480","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":59,"text":"스바댜 자손과, 핫딜 자손과, 보게렛하스바임 자손과, 아몬 자손이니","reference":"느헤미야 7:59","category":"$undefined"},{"id":"12481","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":60,"text":"모든 느디님 사람과 솔로몬의 신복의 자손이 삼백 구십 이명이었느니라","reference":"느헤미야 7:60","category":"$undefined"},{"id":"12482","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":61,"text":"델멜라와, 델하르사와, 그룹과, 앗돈과, 임멜로부터 올라온 자가 있으나 그 종족과 보계가 이스라엘에 속하였는지는 증거할 수 없으니","reference":"느헤미야 7:61","category":"$undefined"},{"id":"12483","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":62,"text":"저희는 들라야 자손과, 도비야 자손과, 느고다 자손이라 도합이 육백 사십 이명이요","reference":"느헤미야 7:62","category":"$undefined"},{"id":"12484","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":63,"text":"제사장 중에는 호바야 자손과 학고스 자손과 바르실래 자손이니 바르실래는 길르앗 사람 바르실래의 딸 중에 하나로 아내를 삼고 바르실래의 이름으로 이름한 자라","reference":"느헤미야 7:63","category":"$undefined"},{"id":"12485","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":64,"text":"이 사람들이 보계중에서 자기 이름을 찾아도 얻지 못한고로 저희를 부정하게 여겨 제사장의 직분을 행치 못하게 하고","reference":"느헤미야 7:64","category":"$undefined"},{"id":"12486","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":65,"text":"방백이 저희에게 명하여 `우림과 둠밈을 가진 제사장이 일어나기 전에는 지성물을 먹지 말라' 하였느니라","reference":"느헤미야 7:65","category":"$undefined"},{"id":"12487","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":66,"text":"온 회중의 합계가 사만 이천 삼백 육십명이요","reference":"느헤미야 7:66","category":"$undefined"},{"id":"12488","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":67,"text":"그 외에 노비가 칠천 삼백 삼십 칠명이요, 노래하는 남녀가 이백 사십 오명이요","reference":"느헤미야 7:67","category":"$undefined"},{"id":"12489","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":68,"text":"말이 칠백 삼십 육이요, 노새가 이백 사십 오요","reference":"느헤미야 7:68","category":"$undefined"},{"id":"12490","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":69,"text":"약대가 사백 삼십 오요, 나귀가 육천 칠백 이십이었느니라","reference":"느헤미야 7:69","category":"$undefined"},{"id":"12491","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":70,"text":"어떤 족장들은 역사를 위하여 보조하였고 방백은 금 일천 다릭과, 대접 오십과, 제사장의 의복 오백 삼십 벌을 보물 곳간에 드렸고","reference":"느헤미야 7:70","category":"$undefined"},{"id":"12492","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":71,"text":"또 어떤 족장들은 금 이만 다릭과 은 이천 이백 마네를 역사 곳간에 드렸고","reference":"느헤미야 7:71","category":"$undefined"},{"id":"12493","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":72,"text":"그 나머지 백성은 금 이만 다릭과 은 이천 마네와 제사장의 의복 육십 칠 벌을 드렸느니라","reference":"느헤미야 7:72","category":"$undefined"},{"id":"12494","book":"느헤미야","book_name":"느헤미야","chapter":7,"verse":73,"text":"이와 같이 제사장들과 레위 사람들과 문지기들과 노래하는 자들과 백성 몇명과 느디님 사람들과 온 이스라엘이 다 그 본성에 거하였느니라","reference":"느헤미야 7:73","category":"$undefined"}],"bookSlug":"nehemiah"}]
