2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":1,"verses":[{"id":"3606","book":"민수기","book_name":"민수기","chapter":1,"verse":1,"text":"이스라엘 자손이 애굽 땅에서 나온 후 제 이년 이월 일일에 여호와께서 시내 광야 회막에서 모세에게 일러 가라사대","reference":"민수기 1:1","category":"$undefined"},{"id":"3607","book":"민수기","book_name":"민수기","chapter":1,"verse":2,"text":"너희는 이스라엘 자손의 모든 회중 각 남자의 수를 그들의 가족과 종족을 따라 그 명수대로 계수할지니","reference":"민수기 1:2","category":"$undefined"},{"id":"3608","book":"민수기","book_name":"민수기","chapter":1,"verse":3,"text":"이스라엘 중 이십세 이상으로 싸움에 나갈만한 모든 자를 너와 아론은 그 군대대로 계수하되","reference":"민수기 1:3","category":"$undefined"},{"id":"3609","book":"민수기","book_name":"민수기","chapter":1,"verse":4,"text":"매 지파의 각기 종족의 두령 한 사람씩 너희와 함께 하라","reference":"민수기 1:4","category":"$undefined"},{"id":"3610","book":"민수기","book_name":"민수기","chapter":1,"verse":5,"text":"너희와 함께 설 사람들의 이름은 이러하니 르우벤에게서는 스데울의 아들 엘리술이요","reference":"민수기 1:5","category":"$undefined"},{"id":"3611","book":"민수기","book_name":"민수기","chapter":1,"verse":6,"text":"시므온에게서는 수리삿대의 아들 슬루미엘이요","reference":"민수기 1:6","category":"$undefined"},{"id":"3612","book":"민수기","book_name":"민수기","chapter":1,"verse":7,"text":"유다에게서는 암미나답의 아들 나손이요","reference":"민수기 1:7","category":"$undefined"},{"id":"3613","book":"민수기","book_name":"민수기","chapter":1,"verse":8,"text":"잇사갈에게서는 수리알의 아들 느다넬이요","reference":"민수기 1:8","category":"$undefined"},{"id":"3614","book":"민수기","book_name":"민수기","chapter":1,"verse":9,"text":"스불론에게서는 헬론의 아들 엘리압이요","reference":"민수기 1:9","category":"$undefined"},{"id":"3615","book":"민수기","book_name":"민수기","chapter":1,"verse":10,"text":"요셉 자손에게서는 에브라임에 암미훗의 아들 엘리사마와, 므낫세에 브다술의 아들 가말리엘이요","reference":"민수기 1:10","category":"$undefined"},{"id":"3616","book":"민수기","book_name":"민수기","chapter":1,"verse":11,"text":"베냐민에게서는 기드오니의 아들 아비단이요","reference":"민수기 1:11","category":"$undefined"},{"id":"3617","book":"민수기","book_name":"민수기","chapter":1,"verse":12,"text":"단에게서는 암미삿대의 아들 아히에셀이요","reference":"민수기 1:12","category":"$undefined"},{"id":"3618","book":"민수기","book_name":"민수기","chapter":1,"verse":13,"text":"아셀에게서는 오그란의 아들 바기엘이요","reference":"민수기 1:13","category":"$undefined"},{"id":"3619","book":"민수기","book_name":"민수기","chapter":1,"verse":14,"text":"갓에게서는 드우엘의 아들 엘리아삽이요","reference":"민수기 1:14","category":"$undefined"},{"id":"3620","book":"민수기","book_name":"민수기","chapter":1,"verse":15,"text":"납달리에게서는 에난의 아들 아히라니라 하시니","reference":"민수기 1:15","category":"$undefined"},{"id":"3621","book":"민수기","book_name":"민수기","chapter":1,"verse":16,"text":"그들은 회중에서 부름을 받은 자요 그 조상 지파의 족장으로서 이스라엘 천만인의 두령이라","reference":"민수기 1:16","category":"$undefined"},{"id":"3622","book":"민수기","book_name":"민수기","chapter":1,"verse":17,"text":"모세와 아론이 지명된 이 사람들을 데리고","reference":"민수기 1:17","category":"$undefined"},{"id":"3623","book":"민수기","book_name":"민수기","chapter":1,"verse":18,"text":"이월 일일에 온 회중을 모으니 그들이 각기 가족과 종족을 따라 이십세 이상으로 그 명수를 의지하여 자기 계통을 말하매","reference":"민수기 1:18","category":"$undefined"},{"id":"3624","book":"민수기","book_name":"민수기","chapter":1,"verse":19,"text":"여호와께서 모세에게 명하신 대로 그가 시내 광야에서 그들을 계수하였더라","reference":"민수기 1:19","category":"$undefined"},{"id":"3625","book":"민수기","book_name":"민수기","chapter":1,"verse":20,"text":"이스라엘의 장자 르우벤의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈만한 각 남자를 그 명수대로 다 계수하니","reference":"민수기 1:20","category":"$undefined"},{"id":"3626","book":"민수기","book_name":"민수기","chapter":1,"verse":21,"text":"르우벤 지파의 계수함을 입은 자가 사만 육천 오백명이었더라","reference":"민수기 1:21","category":"$undefined"},{"id":"3627","book":"민수기","book_name":"민수기","chapter":1,"verse":22,"text":"시드몬의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈만한 각 남자를 그 명수대로 다 계수하니","reference":"민수기 1:22","category":"$undefined"},{"id":"3628","book":"민수기","book_name":"민수기","chapter":1,"verse":23,"text":"시므온 지파의 계수함을 입은 자가 오만 구천 삼백명이었더라","reference":"민수기 1:23","category":"$undefined"},{"id":"3629","book":"민수기","book_name":"민수기","chapter":1,"verse":24,"text":"갓의 아들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:24","category":"$undefined"},{"id":"3630","book":"민수기","book_name":"민수기","chapter":1,"verse":25,"text":"갓 지파의 계수함을 입은 자가 사만 오천 육백 오십명이었더라","reference":"민수기 1:25","category":"$undefined"},{"id":"3631","book":"민수기","book_name":"민수기","chapter":1,"verse":26,"text":"유다의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:26","category":"$undefined"},{"id":"3632","book":"민수기","book_name":"민수기","chapter":1,"verse":27,"text":"유다 지파의 계수함을 입은자가 칠만 사천 육백명이었더라","reference":"민수기 1:27","category":"$undefined"},{"id":"3633","book":"민수기","book_name":"민수기","chapter":1,"verse":28,"text":"잇사갈의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:28","category":"$undefined"},{"id":"3634","book":"민수기","book_name":"민수기","chapter":1,"verse":29,"text":"잇사갈 지파의 계수함을 입은자가 오만 사천 사백명이었더라","reference":"민수기 1:29","category":"$undefined"},{"id":"3635","book":"민수기","book_name":"민수기","chapter":1,"verse":30,"text":"스불론의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:30","category":"$undefined"},{"id":"3636","book":"민수기","book_name":"민수기","chapter":1,"verse":31,"text":"스불론 지파의 계수함을 입은 자가 오만 칠천 사백명이었더라","reference":"민수기 1:31","category":"$undefined"},{"id":"3637","book":"민수기","book_name":"민수기","chapter":1,"verse":32,"text":"요셉의 아들 에브라임의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:32","category":"$undefined"},{"id":"3638","book":"민수기","book_name":"민수기","chapter":1,"verse":33,"text":"에브라임 지파의 계수함을 입은 자가 사만 오백명이었더라","reference":"민수기 1:33","category":"$undefined"},{"id":"3639","book":"민수기","book_name":"민수기","chapter":1,"verse":34,"text":"므낫세의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:34","category":"$undefined"},{"id":"3640","book":"민수기","book_name":"민수기","chapter":1,"verse":35,"text":"므낫세 지파의 계수함을 입은 자가 삼만 이천 이백명이었더라","reference":"민수기 1:35","category":"$undefined"},{"id":"3641","book":"민수기","book_name":"민수기","chapter":1,"verse":36,"text":"베냐민의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:36","category":"$undefined"},{"id":"3642","book":"민수기","book_name":"민수기","chapter":1,"verse":37,"text":"단의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:37","category":"$undefined"},{"id":"3643","book":"민수기","book_name":"민수기","chapter":1,"verse":38,"text":"베냐민 지파의 계수함을 입은 자가 삼만 오천 사백명이었더라","reference":"민수기 1:38","category":"$undefined"},{"id":"3644","book":"민수기","book_name":"민수기","chapter":1,"verse":39,"text":"단의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:39","category":"$undefined"},{"id":"3645","book":"민수기","book_name":"민수기","chapter":1,"verse":40,"text":"베냐민 지파의 계수함을 입은 자가 삼만 오천 사백명이었더라","reference":"민수기 1:40","category":"$undefined"},{"id":"3646","book":"민수기","book_name":"민수기","chapter":1,"verse":41,"text":"단 지파의 계수함을 입은 자가 육만 이천 칠백명이었더라","reference":"민수기 1:41","category":"$undefined"},{"id":"3647","book":"민수기","book_name":"민수기","chapter":1,"verse":42,"text":"아셀의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:42","category":"$undefined"},{"id":"3648","book":"민수기","book_name":"민수기","chapter":1,"verse":43,"text":"아셀 지파의 계수함을 입은 자가 사만 일천 오백명이었더라","reference":"민수기 1:43","category":"$undefined"},{"id":"3649","book":"민수기","book_name":"민수기","chapter":1,"verse":44,"text":"납달리의 아들들에게서 난 자를 그들의 가족과 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자를 그 명수대로 다 계수하니","reference":"민수기 1:44","category":"$undefined"},{"id":"3650","book":"민수기","book_name":"민수기","chapter":1,"verse":45,"text":"납달리 지파의 계수함을 입은 자가 오만 삼천 사백명이었더라","reference":"민수기 1:45","category":"$undefined"},{"id":"3651","book":"민수기","book_name":"민수기","chapter":1,"verse":46,"text":"이 계수함을 입은 자는 모세와 아론과 각기 이스라엘 종족을 대표한 족장 십 이인이 계수한 자라","reference":"민수기 1:46","category":"$undefined"},{"id":"3652","book":"민수기","book_name":"민수기","chapter":1,"verse":47,"text":"이같이 이스라엘 자손의 그 종족을 따라 이십세 이상으로 싸움에 나갈 만한 자가 이스라엘 중에서 다 계수함을 입었으니","reference":"민수기 1:47","category":"$undefined"},{"id":"3653","book":"민수기","book_name":"민수기","chapter":1,"verse":48,"text":"계수함을 입은 자의 총계가 육십만 삼천 오백 오십명이었더라","reference":"민수기 1:48","category":"$undefined"},{"id":"3654","book":"민수기","book_name":"민수기","chapter":1,"verse":49,"text":"오직 레위인은 그 조상의 지파대로 그 계수에 들지 아니하였으니","reference":"민수기 1:49","category":"$undefined"},{"id":"3655","book":"민수기","book_name":"민수기","chapter":1,"verse":50,"text":"이는 여호와께서 모세에게 일러 가라사대","reference":"민수기 1:50","category":"$undefined"},{"id":"3656","book":"민수기","book_name":"민수기","chapter":1,"verse":51,"text":"레위 지파만은 너는 계수치 말며 그들을 이스라엘 자손 계수중에 넣지 말고","reference":"민수기 1:51","category":"$undefined"},{"id":"3657","book":"민수기","book_name":"민수기","chapter":1,"verse":52,"text":"그들을 증거막과 그 모든 기구와 그 모든 부속품을 관리하게 하라","reference":"민수기 1:52","category":"$undefined"},{"id":"3658","book":"민수기","book_name":"민수기","chapter":1,"verse":53,"text":"그들은 그 장막과 그 모든 기구를 운반하며 거기서 봉사하며 장막 사면에 진을 칠지며","reference":"민수기 1:53","category":"$undefined"},{"id":"3659","book":"민수기","book_name":"민수기","chapter":1,"verse":54,"text":"장막을 운반할 때에는 레위인이 그것을 걷고 장막을 세울 때에는 레위인이 그것을 세울 것이요 외인이 가까이 오면 죽일지며 [ (Numbers 1:55) 레위인은 증거막 사면에 진을 쳐서 이스라엘 자손의 회중에게 진노가 임하지 않게 할 것이라 레위인은 증거막에 대한 책임을 지킬지니라 ! 하셨음이라 ] [ (Numbers 1:56) 이스라엘 자손이 그대로 행하되 여호와께서 모세에게 명하신 대로 행하였더라 ]","reference":"민수기 1:54","category":"$undefined"}],"bookSlug":"numbers"}]
