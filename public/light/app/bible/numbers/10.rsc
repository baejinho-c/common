2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":10,"verses":[{"id":"3990","book":"민수기","book_name":"민수기","chapter":10,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 10:1","category":"$undefined"},{"id":"3991","book":"민수기","book_name":"민수기","chapter":10,"verse":2,"text":"은나팔 둘을 만들되 쳐서 만들어서 그것으로 회중을 소집하며 진을 진행케 할 것이라","reference":"민수기 10:2","category":"$undefined"},{"id":"3992","book":"민수기","book_name":"민수기","chapter":10,"verse":3,"text":"두 나팔을 불 때에는 온 회중이 회막 문 앞에 모여서 네게로 나아올 것이요","reference":"민수기 10:3","category":"$undefined"},{"id":"3993","book":"민수기","book_name":"민수기","chapter":10,"verse":4,"text":"하나만 불 때에는 이스라엘 천부장된 족장들이 모여서 네게로 나아올 것이며","reference":"민수기 10:4","category":"$undefined"},{"id":"3994","book":"민수기","book_name":"민수기","chapter":10,"verse":5,"text":"너희가 그것을 울려 불 때에는 동편 진들이 진행할 것이고","reference":"민수기 10:5","category":"$undefined"},{"id":"3995","book":"민수기","book_name":"민수기","chapter":10,"verse":6,"text":"제 이차로 울려 불 때에는 남편 진들이 진행할 것이라 무릇 진행하려 할 때에는 나팔 소리를 울려 불 것이며","reference":"민수기 10:6","category":"$undefined"},{"id":"3996","book":"민수기","book_name":"민수기","chapter":10,"verse":7,"text":"또 회중을 모을 때에도 나팔을 불 것이나 소리를 울려 불지 말것이며","reference":"민수기 10:7","category":"$undefined"},{"id":"3997","book":"민수기","book_name":"민수기","chapter":10,"verse":8,"text":"그 나팔은 아론의 자손인 제사장들이 불지니 이는 너희 대대에 영원한 율례니라","reference":"민수기 10:8","category":"$undefined"},{"id":"3998","book":"민수기","book_name":"민수기","chapter":10,"verse":9,"text":"또 너희 땅에서 너희가 자기를 압박하는 대적을 치러 나갈 때에는 나팔을 울려 불지니 그리하면 너희 하나님 여호와가 너희를 기억하고 너희를 너희 대적에게서 구원하리라","reference":"민수기 10:9","category":"$undefined"},{"id":"3999","book":"민수기","book_name":"민수기","chapter":10,"verse":10,"text":"또 너희 희락의 날과 너희 정한 절기와 월삭에는 번제물의 위에와 화목제물의 위에 나팔을 불라 그로 말미암아 너희 하나님이 너희를 기억하리라 나는 너희 하나님 여호와니라 !","reference":"민수기 10:10","category":"$undefined"},{"id":"4000","book":"민수기","book_name":"민수기","chapter":10,"verse":11,"text":"제 이년 이월 이십일에 구름이 증거막에서 떠오르매","reference":"민수기 10:11","category":"$undefined"},{"id":"4001","book":"민수기","book_name":"민수기","chapter":10,"verse":12,"text":"이스라엘 자손이 시내 광야에서 출발하여 자기 길을 행하더니 바란 광야에 구름이 머무니라","reference":"민수기 10:12","category":"$undefined"},{"id":"4002","book":"민수기","book_name":"민수기","chapter":10,"verse":13,"text":"이와 같이 그들이 여호와께서 모세로 명하신 것을 좇아 진행하기를 시작하였는데","reference":"민수기 10:13","category":"$undefined"},{"id":"4003","book":"민수기","book_name":"민수기","chapter":10,"verse":14,"text":"수두로 유다 자손 진기에 속한 자들이 그 군대대로 진행하였으니 유다 군대는 암미나답의 아들 나손이 영솔하였고","reference":"민수기 10:14","category":"$undefined"},{"id":"4004","book":"민수기","book_name":"민수기","chapter":10,"verse":15,"text":"잇사갈 자손 지파의 군대는 수알의 아들 느다넬이 영솔하였고","reference":"민수기 10:15","category":"$undefined"},{"id":"4005","book":"민수기","book_name":"민수기","chapter":10,"verse":16,"text":"스불론 자손 지파의 군대는 헬론의 아들 엘리압이 영솔하였더라","reference":"민수기 10:16","category":"$undefined"},{"id":"4006","book":"민수기","book_name":"민수기","chapter":10,"verse":17,"text":"이에 성막을 걷으매 게르손 자손과 므라리 자손이 성막을 메고 발행하였으며","reference":"민수기 10:17","category":"$undefined"},{"id":"4007","book":"민수기","book_name":"민수기","chapter":10,"verse":18,"text":"다음으로 르우벤 진기에 속한 자들이 그 군대대로 발행하였으니 르우벤의 군대는 스데울의 아들 엘리술이 영솔하였고","reference":"민수기 10:18","category":"$undefined"},{"id":"4008","book":"민수기","book_name":"민수기","chapter":10,"verse":19,"text":"시므온 자손 지파의 군대는 수리삿대의 아들 슬루미엘이 영솔하였고","reference":"민수기 10:19","category":"$undefined"},{"id":"4009","book":"민수기","book_name":"민수기","chapter":10,"verse":20,"text":"갓 자손 지파의 군대는 드우엘의 아들 엘리아삽이 영솔하였더라","reference":"민수기 10:20","category":"$undefined"},{"id":"4010","book":"민수기","book_name":"민수기","chapter":10,"verse":21,"text":"고핫인은 성물을 메고 진행하였고 그들이 이르기 전에 성막을 세웠으며","reference":"민수기 10:21","category":"$undefined"},{"id":"4011","book":"민수기","book_name":"민수기","chapter":10,"verse":22,"text":"다음으로 에브라임 자손 진기에 속한 자들이 그 군대대로 진행하였으니 에브라임 군대는 암미훗의 아들 엘리사마가 영솔하였고","reference":"민수기 10:22","category":"$undefined"},{"id":"4012","book":"민수기","book_name":"민수기","chapter":10,"verse":23,"text":"므낫세 자손 지파의 군대는 브다술의 아들 가말리엘이 영솔하였고","reference":"민수기 10:23","category":"$undefined"},{"id":"4013","book":"민수기","book_name":"민수기","chapter":10,"verse":24,"text":"베냐민 자손 지파의 군대는 기드오니의 아들 아비단이 영솔하였더라","reference":"민수기 10:24","category":"$undefined"},{"id":"4014","book":"민수기","book_name":"민수기","chapter":10,"verse":25,"text":"다음으로 단 자손 진기에 속한 자들이 그 군대대로 진행하였으니 이 군대는 모든 진의 후진이었더라 단 군대는 암미삿대의 아들 아히에셀이 영솔하였고","reference":"민수기 10:25","category":"$undefined"},{"id":"4015","book":"민수기","book_name":"민수기","chapter":10,"verse":26,"text":"아셀 자손 지파의 군대는 오그란의 아들 바기엘이 영솔하였고","reference":"민수기 10:26","category":"$undefined"},{"id":"4016","book":"민수기","book_name":"민수기","chapter":10,"verse":27,"text":"납달리 자손 지파의 군대는 에난의 아들 아히라가 영솔하였더라","reference":"민수기 10:27","category":"$undefined"},{"id":"4017","book":"민수기","book_name":"민수기","chapter":10,"verse":28,"text":"모세가 가로되 `청컨대 우리를 떠나지 마소서 당신은 우리가 광야에서 어떻게 진 칠 것을 아나니 우리의 눈이 되리이다","reference":"민수기 10:28","category":"$undefined"},{"id":"4018","book":"민수기","book_name":"민수기","chapter":10,"verse":29,"text":"우리와 동행하면 여호와께서 우리에게 복을 내리시는 대로 우리도 당신에게 행하리이다'","reference":"민수기 10:29","category":"$undefined"},{"id":"4019","book":"민수기","book_name":"민수기","chapter":10,"verse":30,"text":"그들이 여호와의 산에서 떠나 삼일 길을 행할 때에 여호와의 언약궤가 그 삼일 길에 앞서 행하며 그들의 쉴 곳을 찾았고","reference":"민수기 10:30","category":"$undefined"},{"id":"4020","book":"민수기","book_name":"민수기","chapter":10,"verse":31,"text":"그들이 여호와의 산에서 떠나 삼일 길을 행할 때에 여호와의 언약궤가 그 삼일 길에 앞서 행하며 그들의 쉴 곳을 찾았고","reference":"민수기 10:31","category":"$undefined"},{"id":"4021","book":"민수기","book_name":"민수기","chapter":10,"verse":32,"text":"그들이 행진할때에 낮에는 여호와의 구름이 그 위에 덮였었더라","reference":"민수기 10:32","category":"$undefined"},{"id":"4022","book":"민수기","book_name":"민수기","chapter":10,"verse":33,"text":"궤가 떠날 때에는 모세가 가로되 `여호와여 ! 일어나사 주의 대적들을 흩으시고 주를 미워하는 자로 주의 앞에서 도망하게 하소서 !'하였고","reference":"민수기 10:33","category":"$undefined"},{"id":"4023","book":"민수기","book_name":"민수기","chapter":10,"verse":34,"text":"궤가 쉴 때에는 가로되 `여호와여 ! 이스라엘 천만인에게로 돌아오소서 !' 하였더라","reference":"민수기 10:34","category":"$undefined"},{"id":"4024","book":"민수기","book_name":"민수기","chapter":10,"verse":35,"text":"","reference":"민수기 10:35","category":"$undefined"},{"id":"4025","book":"민수기","book_name":"민수기","chapter":10,"verse":36,"text":"","reference":"민수기 10:36","category":"$undefined"}],"bookSlug":"numbers"}]
