2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":11,"verses":[{"id":"4026","book":"민수기","book_name":"민수기","chapter":11,"verse":1,"text":"백성이 여호와의 들으시기에 악한 말로 원망하매 여호와께서 들으시고 진노하사 여호와의 불로 그들 중에 붙어서 진 끝을 사르게 하시매","reference":"민수기 11:1","category":"$undefined"},{"id":"4027","book":"민수기","book_name":"민수기","chapter":11,"verse":2,"text":"백성이 모세에게 부르짖으므로 모세가 여호와께 기도하니 불이 꺼졌더라","reference":"민수기 11:2","category":"$undefined"},{"id":"4028","book":"민수기","book_name":"민수기","chapter":11,"verse":3,"text":"그곳 이름을 다베라라 칭하였으니 이는 여호와의 불이 그들 중에 붙은 연고였더라","reference":"민수기 11:3","category":"$undefined"},{"id":"4029","book":"민수기","book_name":"민수기","chapter":11,"verse":4,"text":"이스라엘 중에 섞어 사는 무리가 탐욕을 품으매 이스라엘 자손도 다시 울며 가로되 '누가 우리에게 고기를 주어 먹게 할꼬 ?","reference":"민수기 11:4","category":"$undefined"},{"id":"4030","book":"민수기","book_name":"민수기","chapter":11,"verse":5,"text":"우리가 애굽에 있을 때에는 값 없이 생선과 외와 수박과 부추와 파와 마늘들을 먹은 것이 생각나거늘","reference":"민수기 11:5","category":"$undefined"},{"id":"4031","book":"민수기","book_name":"민수기","chapter":11,"verse":6,"text":"이제는 우리 정력이 쇠약하되 이 만나 외에는 보이는 것이 아무 것도 없도다' 하니","reference":"민수기 11:6","category":"$undefined"},{"id":"4032","book":"민수기","book_name":"민수기","chapter":11,"verse":7,"text":"만나는 깟씨와 같고 모양은 진주와 같은 것이라","reference":"민수기 11:7","category":"$undefined"},{"id":"4033","book":"민수기","book_name":"민수기","chapter":11,"verse":8,"text":"백성이 두루 다니며 그것을 거두어 맷돌에 갈기도 하며 절구에 찧기도 하고 가마에 삶기도 하여 과자를 만들었으니 그 맛이 기름 섞은 과자맛 같았더라","reference":"민수기 11:8","category":"$undefined"},{"id":"4034","book":"민수기","book_name":"민수기","chapter":11,"verse":9,"text":"밤에 이슬이 진에 내릴 때에 만나도 같이 내렸더라","reference":"민수기 11:9","category":"$undefined"},{"id":"4035","book":"민수기","book_name":"민수기","chapter":11,"verse":10,"text":"백성의 온 가족들이 각기 장막 문에서 우는 것을 모세가 들으니라 이러므로 여호와의 진노가 심히 크고 모세도 기뻐하지 아니하여","reference":"민수기 11:10","category":"$undefined"},{"id":"4036","book":"민수기","book_name":"민수기","chapter":11,"verse":11,"text":"여호와께 여짜오되 `주께서 어찌하여 종을 괴롭게 하시나이까 ? 어찌하여 나로 주의 목전에 은혜를 입게 아니하시고 이 모든 백성을 내게 맡기사 나로 그 짐을 지게 하시나이까 ?","reference":"민수기 11:11","category":"$undefined"},{"id":"4037","book":"민수기","book_name":"민수기","chapter":11,"verse":12,"text":"이 모든 백성을 내가 잉태하였나이까 ? 내가 어찌 그들을 생산하였기에 주께서 나더러 양육하는 아비가 젖 먹는 아이를 품듯 그들을 품에 품고 주께서 그들의 열조에게 맹세하신 땅으로 가라 하시나이까 ?","reference":"민수기 11:12","category":"$undefined"},{"id":"4038","book":"민수기","book_name":"민수기","chapter":11,"verse":13,"text":"이 모든 백성에게 줄 고기를 내가 어디서 얻으리이까 ? 그들이 나를 향하여 울며 가로되 우리에게 고기를 주어 먹게 하라 하온즉","reference":"민수기 11:13","category":"$undefined"},{"id":"4039","book":"민수기","book_name":"민수기","chapter":11,"verse":14,"text":"책임이 심히 중하여 나 혼자는 이 모든 백성을 질 수 없나이다","reference":"민수기 11:14","category":"$undefined"},{"id":"4040","book":"민수기","book_name":"민수기","chapter":11,"verse":15,"text":"주께서 내게 이같이 행하실진대 구하옵나니 내게 은혜를 베푸사 즉시 나를 죽여 나로 나의 곤고함을 보지 않게 하옵소서'","reference":"민수기 11:15","category":"$undefined"},{"id":"4041","book":"민수기","book_name":"민수기","chapter":11,"verse":16,"text":"여호와께서 모세에게 이르시되 이스라엘 노인 중 백성의 장로와 유사되는 줄을 네가 아는 자 칠십인을 모아 데리고 회막 내 앞에 이르러 거기서 너와 함께 서게 하라","reference":"민수기 11:16","category":"$undefined"},{"id":"4042","book":"민수기","book_name":"민수기","chapter":11,"verse":17,"text":"내가 강림하여 거기서 너와 말하고 네게 임한 신을 그들에게도 임하게 하리니 그들이 너와 함께 백성의 짐을 담당하고 너 혼자 지지 아니하리라","reference":"민수기 11:17","category":"$undefined"},{"id":"4043","book":"민수기","book_name":"민수기","chapter":11,"verse":18,"text":"또 백성에게 이르기를 너희 몸을 거룩히 하여 내일 고기 먹기를 기다리라 너희가 울며 이르기를 누가 우리에게 고기를 주어 먹게할꼬 애굽에 있을 때가 우리에게 재미 있었다 하는 말이 여호와께 들렸으므로 여호와께서 너희에게 고기를 주어 먹게 하실 것이라","reference":"민수기 11:18","category":"$undefined"},{"id":"4044","book":"민수기","book_name":"민수기","chapter":11,"verse":19,"text":"하루나 이틀이나 닷새나 열흘이나 이십일만 먹을 뿐 아니라","reference":"민수기 11:19","category":"$undefined"},{"id":"4045","book":"민수기","book_name":"민수기","chapter":11,"verse":20,"text":"코에서 넘쳐서 싫어하기까지 일개월간을 먹게 하시리니 이는 너희가 너희 중에 거하시는 여호와를 멸시하고 그 앞에서 울며 이르기를 우리가 어찌하여 애굽에서 나왔던고 함이라 하라","reference":"민수기 11:20","category":"$undefined"},{"id":"4046","book":"민수기","book_name":"민수기","chapter":11,"verse":21,"text":"모세가 가로되 `나와 함께 있는 이 백성의 보행자가 육십 만명이온데 주의 말씀이 일개월간 고기를 주어 먹게 하겠다 하시오니","reference":"민수기 11:21","category":"$undefined"},{"id":"4047","book":"민수기","book_name":"민수기","chapter":11,"verse":22,"text":"그들을 위하여 양떼와 소떼를 잡은들 족하오며 바다의 모든 고기를 모은들 족하오리이까 ?'","reference":"민수기 11:22","category":"$undefined"},{"id":"4048","book":"민수기","book_name":"민수기","chapter":11,"verse":23,"text":"여호와께서 모세에게 이르시되 여호와의 손이 짧아졌느냐 ? 네가 이제 내 말이 네게 응하는 여부를 보리라","reference":"민수기 11:23","category":"$undefined"},{"id":"4049","book":"민수기","book_name":"민수기","chapter":11,"verse":24,"text":"모세가 나가서 여호와의 말씀을 백성에게 고하고 백성의 장로 칠십인을 모아 장막에 둘러 세우매","reference":"민수기 11:24","category":"$undefined"},{"id":"4050","book":"민수기","book_name":"민수기","chapter":11,"verse":25,"text":"여호와께서 구름 가운데 강림하사 모세에게 말씀하시고 그에게 임한 신을 칠십 장로에게도 임하게 하시니 신이 임하신 때에 그들이 예언을 하다가 다시는 아니하였더라","reference":"민수기 11:25","category":"$undefined"},{"id":"4051","book":"민수기","book_name":"민수기","chapter":11,"verse":26,"text":"그 녹명된 자 중 엘닷이라 하는 자와 메닷이라 하는 자 두 사람이 진에 머물고 회막에 나아가지 아니하였으나 그들에게도 신이 임하였으므로 진에서 예언한지라","reference":"민수기 11:26","category":"$undefined"},{"id":"4052","book":"민수기","book_name":"민수기","chapter":11,"verse":27,"text":"한 소년이 달려와서 모세에게 고하여 가로되 `엘닷과 메닷이 진 중에서 예언하더이다' 하매","reference":"민수기 11:27","category":"$undefined"},{"id":"4053","book":"민수기","book_name":"민수기","chapter":11,"verse":28,"text":"택한 자 중 한 사람 곧 모세를 섬기는 눈의 아들 여호수아가 말하여 가로되 '내 주 모세여 금하소서'","reference":"민수기 11:28","category":"$undefined"},{"id":"4054","book":"민수기","book_name":"민수기","chapter":11,"verse":29,"text":"모세가 그에게 이르되 `네가 나를 위하여 시기하느냐 ? 여호와께서 그 신을 그 모든 백성에게 주사 다 선지자 되게 하시기를 원하노라'","reference":"민수기 11:29","category":"$undefined"},{"id":"4055","book":"민수기","book_name":"민수기","chapter":11,"verse":30,"text":"모세와 이스라엘 장로들이 진중으로 돌아왔더라","reference":"민수기 11:30","category":"$undefined"},{"id":"4056","book":"민수기","book_name":"민수기","chapter":11,"verse":31,"text":"바람이 여호와에게로서 나와 바다에서부터 메추라기를 몰아 진곁 이편, 저편 곧 진 사방으로 각기 하룻길 되는 지면 위 두 규빗쯤에 내리게 한지라","reference":"민수기 11:31","category":"$undefined"},{"id":"4057","book":"민수기","book_name":"민수기","chapter":11,"verse":32,"text":"백성이 일어나 종일 종야와 그 이튿날 종일토록 메추라기를 모으니 적게 모은 자도 십 호멜이라 그들이 자기를 위하여 진 사면에 펴 두었더라","reference":"민수기 11:32","category":"$undefined"},{"id":"4058","book":"민수기","book_name":"민수기","chapter":11,"verse":33,"text":"고기가 아직 잇사이에 있어 씹히기 전에 여호와께서 백성에게 대하여 진노하사 심히 큰 재앙으로 치셨으므로","reference":"민수기 11:33","category":"$undefined"},{"id":"4059","book":"민수기","book_name":"민수기","chapter":11,"verse":34,"text":"그곳 이름을 [기브롯 핫다아와]라 칭하였으니 탐욕을 낸 백성을 거기 장사함이었더라","reference":"민수기 11:34","category":"$undefined"},{"id":"4060","book":"민수기","book_name":"민수기","chapter":11,"verse":35,"text":"백성이 기브롯 핫다아와에서 진행하여 하세롯에 이르러 거기 거하니라","reference":"민수기 11:35","category":"$undefined"}],"bookSlug":"numbers"}]
