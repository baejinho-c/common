2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":12,"verses":[{"id":"4061","book":"민수기","book_name":"민수기","chapter":12,"verse":1,"text":"모세가 구스 여자를 취하였더니 그 구스 여자를 취하였으므로 미리암과 아론이 모세를 비방하니라","reference":"민수기 12:1","category":"$undefined"},{"id":"4062","book":"민수기","book_name":"민수기","chapter":12,"verse":2,"text":"그들이 이르되 `여호와께서 모세와만 말씀하셨느냐 ? 우리와도 말씀하지 아니하셨느냐 ?' 하매 여호와께서 이 말을 들으셨더라","reference":"민수기 12:2","category":"$undefined"},{"id":"4063","book":"민수기","book_name":"민수기","chapter":12,"verse":3,"text":"이 사람 모세는 온유함이 지면의 모든 사람보다 승하더라","reference":"민수기 12:3","category":"$undefined"},{"id":"4064","book":"민수기","book_name":"민수기","chapter":12,"verse":4,"text":"여호와께서 갑자기 모세와 아론과 미리암에게 이르시되 너희 삼인은 회막으로 나아오라 하시니 그 삼인이 나아가매","reference":"민수기 12:4","category":"$undefined"},{"id":"4065","book":"민수기","book_name":"민수기","chapter":12,"verse":5,"text":"여호와께서 구름 기둥 가운데로서 강림하사 장막 문에 서시고 아론과 미리암을 부르시는지라 그 두 사람이 나아가매","reference":"민수기 12:5","category":"$undefined"},{"id":"4066","book":"민수기","book_name":"민수기","chapter":12,"verse":6,"text":"이르시되 내 말을 들으라 너희 중에 선지자가 있으면 나 여호와가 이상으로 나를 그에게 알리기도 하고 꿈으로 그와 말하기도 하거니와","reference":"민수기 12:6","category":"$undefined"},{"id":"4067","book":"민수기","book_name":"민수기","chapter":12,"verse":7,"text":"내 종 모세와는 그렇지 아니하니 그는 나의 온 집에 충성됨이라","reference":"민수기 12:7","category":"$undefined"},{"id":"4068","book":"민수기","book_name":"민수기","chapter":12,"verse":8,"text":"그와는 내가 대면하여 명백히 말하고 은밀한 말로 아니하며 그는 또 여호와의 형상을 보겠거늘 너희가 어찌하여 내 종 모세 비방하기를 두려워 아니하느냐 ?","reference":"민수기 12:8","category":"$undefined"},{"id":"4069","book":"민수기","book_name":"민수기","chapter":12,"verse":9,"text":"여호와께서 그들을 향하여 진노하시고 떠나시매","reference":"민수기 12:9","category":"$undefined"},{"id":"4070","book":"민수기","book_name":"민수기","chapter":12,"verse":10,"text":"구름이 장막 위에서 떠나갔고 미리암은 문둥병이 들려 눈과 같더라 아론이 미리암을 본즉 문둥병이 들었는지라","reference":"민수기 12:10","category":"$undefined"},{"id":"4071","book":"민수기","book_name":"민수기","chapter":12,"verse":11,"text":"아론이 이에 모세에게 이르되 `슬프다, 내 주여 ! 우리가 우매한 일을 하여 죄를 얻었으나 청컨대 그 허물을 우리에게 돌리지 마소서","reference":"민수기 12:11","category":"$undefined"},{"id":"4072","book":"민수기","book_name":"민수기","chapter":12,"verse":12,"text":"그로 살이 반이나 썩고 죽어서 모태에서 나온 자 같이 되게 마옵소서 !'","reference":"민수기 12:12","category":"$undefined"},{"id":"4073","book":"민수기","book_name":"민수기","chapter":12,"verse":13,"text":"모세가 여호와께 부르짖어 가로되 `하나님이여 ! 원컨대 그를 고쳐 주옵소서 !'","reference":"민수기 12:13","category":"$undefined"},{"id":"4074","book":"민수기","book_name":"민수기","chapter":12,"verse":14,"text":"여호와께서 모세에게 이르시되 그의 아비가 그의 얼굴에 침을 뱉았을 지라도 그가 칠일간 부끄러워 하지 않겠느냐 ? 그런즉 그를 진 밖에 칠일을 가두고 그 후에 들어오게 할지니라 하시니","reference":"민수기 12:14","category":"$undefined"},{"id":"4075","book":"민수기","book_name":"민수기","chapter":12,"verse":15,"text":"이에 미리암이 진 밖에 칠일동안 갇혔고 백성은 그를 다시 들어 오게 하기까지 진행치 아니하다가","reference":"민수기 12:15","category":"$undefined"},{"id":"4076","book":"민수기","book_name":"민수기","chapter":12,"verse":16,"text":"그 후에 백성이 하세롯에서 진행하여 바란 광야에 진을 치니라","reference":"민수기 12:16","category":"$undefined"}],"bookSlug":"numbers"}]
