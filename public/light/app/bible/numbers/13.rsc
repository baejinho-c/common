2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":13,"verses":[{"id":"4077","book":"민수기","book_name":"민수기","chapter":13,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 13:1","category":"$undefined"},{"id":"4078","book":"민수기","book_name":"민수기","chapter":13,"verse":2,"text":"사람을 보내어 내가 이스라엘 자손에게 주는 가나안 땅을 탐지하게 하되 그 종족의 각 지파 중에서 족장 된 자 한 사람씩 보내라","reference":"민수기 13:2","category":"$undefined"},{"id":"4079","book":"민수기","book_name":"민수기","chapter":13,"verse":3,"text":"모세가 여호와의 명을 좇아 바란 광야에서 그들을 보내었으니 그들은 다 이스라엘 자손의 두령된 사람이라","reference":"민수기 13:3","category":"$undefined"},{"id":"4080","book":"민수기","book_name":"민수기","chapter":13,"verse":4,"text":"그들의 이름은 이러하니라 르우벤 지파에서는 삭굴의 아들 삼무아요","reference":"민수기 13:4","category":"$undefined"},{"id":"4081","book":"민수기","book_name":"민수기","chapter":13,"verse":5,"text":"시므온 지파에서는 호리의 아들 사밧이요","reference":"민수기 13:5","category":"$undefined"},{"id":"4082","book":"민수기","book_name":"민수기","chapter":13,"verse":6,"text":"유다 지파에서는 여분네의 아들 갈렙이요","reference":"민수기 13:6","category":"$undefined"},{"id":"4083","book":"민수기","book_name":"민수기","chapter":13,"verse":7,"text":"잇사갈 지파에서는 요셉의 아들 이갈이요","reference":"민수기 13:7","category":"$undefined"},{"id":"4084","book":"민수기","book_name":"민수기","chapter":13,"verse":8,"text":"에브라임 지파에서는 눈의 아들 호세아요","reference":"민수기 13:8","category":"$undefined"},{"id":"4085","book":"민수기","book_name":"민수기","chapter":13,"verse":9,"text":"베냐민 지파에서는 라부의 아들 발디요","reference":"민수기 13:9","category":"$undefined"},{"id":"4086","book":"민수기","book_name":"민수기","chapter":13,"verse":10,"text":"스불론 지파에서는 소디의 아들 갓디엘이요","reference":"민수기 13:10","category":"$undefined"},{"id":"4087","book":"민수기","book_name":"민수기","chapter":13,"verse":11,"text":"요셉 지파 곧 므낫세 지파에서는 수시의 아들 갓디요","reference":"민수기 13:11","category":"$undefined"},{"id":"4088","book":"민수기","book_name":"민수기","chapter":13,"verse":12,"text":"단 지파에서는 그말리의 아들 암미엘이요","reference":"민수기 13:12","category":"$undefined"},{"id":"4089","book":"민수기","book_name":"민수기","chapter":13,"verse":13,"text":"아셀 지파에서는 미가엘의 아들 스둘이요","reference":"민수기 13:13","category":"$undefined"},{"id":"4090","book":"민수기","book_name":"민수기","chapter":13,"verse":14,"text":"납달리 지파에서는 웝시의 아들 나비요","reference":"민수기 13:14","category":"$undefined"},{"id":"4091","book":"민수기","book_name":"민수기","chapter":13,"verse":15,"text":"갓 지파에서는 마기의 아들 그우엘이니","reference":"민수기 13:15","category":"$undefined"},{"id":"4092","book":"민수기","book_name":"민수기","chapter":13,"verse":16,"text":"이는 모세가 땅을 탐지하러 보낸 자들의 이름이라 모세가 눈의 아들 호세아를 여호수아라 칭하였더라","reference":"민수기 13:16","category":"$undefined"},{"id":"4093","book":"민수기","book_name":"민수기","chapter":13,"verse":17,"text":"모세가 가나안 땅을 탐지하러 그들을 보내며 이르되 `너희는 남방길로 행하여 산지로 올라가서","reference":"민수기 13:17","category":"$undefined"},{"id":"4094","book":"민수기","book_name":"민수기","chapter":13,"verse":18,"text":"그 땅의 어떠함을 탐지하라 곧 그 땅 거민의 강약과 다소와","reference":"민수기 13:18","category":"$undefined"},{"id":"4095","book":"민수기","book_name":"민수기","chapter":13,"verse":19,"text":"그들의 거하는 땅의 호불호와 거하는 성읍이 진영인지 산성인지와","reference":"민수기 13:19","category":"$undefined"},{"id":"4096","book":"민수기","book_name":"민수기","chapter":13,"verse":20,"text":"토지의 후박과 수목의 유무니라 담대하라 또 그 땅 실과를 가져오라' 하니 그 때는 포도가 처음 익을 즈음이었더라","reference":"민수기 13:20","category":"$undefined"},{"id":"4097","book":"민수기","book_name":"민수기","chapter":13,"verse":21,"text":"이에 그들이 올라 가서 땅을 탐지하되 신 광야에서부터 하맛 어귀 르홉에 이르렀고","reference":"민수기 13:21","category":"$undefined"},{"id":"4098","book":"민수기","book_name":"민수기","chapter":13,"verse":22,"text":"또 남방으로 올라가서 헤브론에 이르렀으니 헤브론은 애굽 소안보다 칠년 전에 세운 곳이라 그 곳에 아낙 자손 아히만과 세새와 달매가 있었더라","reference":"민수기 13:22","category":"$undefined"},{"id":"4099","book":"민수기","book_name":"민수기","chapter":13,"verse":23,"text":"또 에스골 골짜기에 이르러 거기서 포도 한 송이 달린 가지를 베어 둘이 막대기에 꿰어 메고 또 석류와 무화과를 취하니라","reference":"민수기 13:23","category":"$undefined"},{"id":"4100","book":"민수기","book_name":"민수기","chapter":13,"verse":24,"text":"이스라엘 자손이 거기서 포도송이를 벤 고로 그 곳을 에스골 골짜기라 칭하였더라","reference":"민수기 13:24","category":"$undefined"},{"id":"4101","book":"민수기","book_name":"민수기","chapter":13,"verse":25,"text":"사십일 동안에 땅을 탐지하기를 마치고 돌아와","reference":"민수기 13:25","category":"$undefined"},{"id":"4102","book":"민수기","book_name":"민수기","chapter":13,"verse":26,"text":"바란 광야 가데스에 이르러 모세와 아론과 이스라엘 자손의 온 회중에게 나아와 그들에게 회보하고 그 땅 실과를 보이고","reference":"민수기 13:26","category":"$undefined"},{"id":"4103","book":"민수기","book_name":"민수기","chapter":13,"verse":27,"text":"모세에게 보고하여 가로되 `당신이 우리를 보낸 땅에 간즉 과연 젖과 꿀이 그 땅에 흐르고 이것은 그 땅의 실과니이다","reference":"민수기 13:27","category":"$undefined"},{"id":"4104","book":"민수기","book_name":"민수기","chapter":13,"verse":28,"text":"그러나 그 땅 거민은 강하고 성읍은 견고하고 심히 클 뿐 아니라 거기서 아낙 자손을 보았으며","reference":"민수기 13:28","category":"$undefined"},{"id":"4105","book":"민수기","book_name":"민수기","chapter":13,"verse":29,"text":"아말렉인은 남방 땅에 거하고 헷인과, 여부스인과, 아모리인은 산지에 거하고 가나안인은 해변과 요단 가에 거하더이다'","reference":"민수기 13:29","category":"$undefined"},{"id":"4106","book":"민수기","book_name":"민수기","chapter":13,"verse":30,"text":"갈렙이 모세 앞에서 백성을 안돈시켜 가로되 `우리가 곧 올라가서 그 땅을 취하자 능히 이기리라' 하나","reference":"민수기 13:30","category":"$undefined"},{"id":"4107","book":"민수기","book_name":"민수기","chapter":13,"verse":31,"text":"그와 함께 올라갔던 사람들은 가로되 `우리는 능히 올라가서 그 백성을 치지 못하리라 그들은 우리보다 강하니라' 하고","reference":"민수기 13:31","category":"$undefined"},{"id":"4108","book":"민수기","book_name":"민수기","chapter":13,"verse":32,"text":"이스라엘 자손 앞에서 그 탐지한 땅을 악평하여 가로되 `우리가 두루 다니며 탐지한 땅은 그 거민을 삼키는 땅이요 거기서 본 모든 백성은 신장이 장대한 자들이며","reference":"민수기 13:32","category":"$undefined"},{"id":"4109","book":"민수기","book_name":"민수기","chapter":13,"verse":33,"text":"거기서 또 네피림 후손 아낙 자손 대장부들을 보았나니 우리는 스스로 보기에도 메뚜기 같으니 그들의 보기에도 그와 같았을 것이니라'","reference":"민수기 13:33","category":"$undefined"}],"bookSlug":"numbers"}]
