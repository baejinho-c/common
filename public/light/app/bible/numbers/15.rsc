2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":15,"verses":[{"id":"4155","book":"민수기","book_name":"민수기","chapter":15,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 15:1","category":"$undefined"},{"id":"4156","book":"민수기","book_name":"민수기","chapter":15,"verse":2,"text":"이스라엘 자손에게 고하여 그들에게 이르라 너희가 내게 주어 거하게 할 땅에 들어가서","reference":"민수기 15:2","category":"$undefined"},{"id":"4157","book":"민수기","book_name":"민수기","chapter":15,"verse":3,"text":"여호와께 화제나 번제나 서원을 갚는 제나 낙헌제나 정한 절기제에 소나 양으로 여호와께 향기롭게 드릴 때에는","reference":"민수기 15:3","category":"$undefined"},{"id":"4158","book":"민수기","book_name":"민수기","chapter":15,"verse":4,"text":"그 예물을 드리는 자는 고운 가루 에바 십분지 일에 기름 한 힌의 사분지 일을 섞어 여호와께 소제로 드릴 것이며","reference":"민수기 15:4","category":"$undefined"},{"id":"4159","book":"민수기","book_name":"민수기","chapter":15,"verse":5,"text":"번제나 다른 제사로 드리는 제물이 어린 양이면 전제로 포도주 한 힌의 사분 일을 예비할 것이요","reference":"민수기 15:5","category":"$undefined"},{"id":"4160","book":"민수기","book_name":"민수기","chapter":15,"verse":6,"text":"수양이면 소제로 고운 가루 한 에바 십분지 이에 기름 한 힌의 삼분지 일을 섞어 예비하고","reference":"민수기 15:6","category":"$undefined"},{"id":"4161","book":"민수기","book_name":"민수기","chapter":15,"verse":7,"text":"전제로 포도주 한 힌의 삼분지 일을 드려 여호와 앞에 향기롭게 할 것이요","reference":"민수기 15:7","category":"$undefined"},{"id":"4162","book":"민수기","book_name":"민수기","chapter":15,"verse":8,"text":"번제로나 서원을 갚는 제로나 화목제로 수송아지를 예비하여 여호와께 드릴 때에는","reference":"민수기 15:8","category":"$undefined"},{"id":"4163","book":"민수기","book_name":"민수기","chapter":15,"verse":9,"text":"소제로 고운 가루 한 에바 십분지 삼에 기름 반 힌을 섞어 그 수송아지와 함께 드리고","reference":"민수기 15:9","category":"$undefined"},{"id":"4164","book":"민수기","book_name":"민수기","chapter":15,"verse":10,"text":"전제로 포도주 반 힌을 드려 여호와 앞에 향기로운 화제를 삼을지니라","reference":"민수기 15:10","category":"$undefined"},{"id":"4165","book":"민수기","book_name":"민수기","chapter":15,"verse":11,"text":"수송아지나 수양이나 어린 수양이나 어린 염소에는 그 마리 수마다 이 위와 같이 행하되","reference":"민수기 15:11","category":"$undefined"},{"id":"4166","book":"민수기","book_name":"민수기","chapter":15,"verse":12,"text":"너희 예비하는 수효를 따라 각기 수효에 맞게 하라","reference":"민수기 15:12","category":"$undefined"},{"id":"4167","book":"민수기","book_name":"민수기","chapter":15,"verse":13,"text":"무릇 본토 소생이 여호와께 향기로운 화제를 드릴 때에는 이 법대로 할 것이요","reference":"민수기 15:13","category":"$undefined"},{"id":"4168","book":"민수기","book_name":"민수기","chapter":15,"verse":14,"text":"너희 중에 우거하는 타국인이나 너희 중에 대대로 있는 자가 누구든지 여호와께 향기로운 화제를 드릴 때에는 너희 하는대로 그도 그리할 것이라","reference":"민수기 15:14","category":"$undefined"},{"id":"4169","book":"민수기","book_name":"민수기","chapter":15,"verse":15,"text":"회중 곧 너희나 우거하는 타국인이나 한 율례니 너희의 대대로 영원한 율례라 너희의 어떠한 대로 타국인도 여호와 앞에 그러하리라","reference":"민수기 15:15","category":"$undefined"},{"id":"4170","book":"민수기","book_name":"민수기","chapter":15,"verse":16,"text":"너희나 너희 중에 우거하는 타국인이나 한 법도, 한 규례니라","reference":"민수기 15:16","category":"$undefined"},{"id":"4171","book":"민수기","book_name":"민수기","chapter":15,"verse":17,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 15:17","category":"$undefined"},{"id":"4172","book":"민수기","book_name":"민수기","chapter":15,"verse":18,"text":"이스라엘 자손에게 고하여 이르라 너희가 나의 인도하는 땅에 들어가거든","reference":"민수기 15:18","category":"$undefined"},{"id":"4173","book":"민수기","book_name":"민수기","chapter":15,"verse":19,"text":"그 땅의 양식을 먹을 때에 여호와께 거제를 드리되","reference":"민수기 15:19","category":"$undefined"},{"id":"4174","book":"민수기","book_name":"민수기","chapter":15,"verse":20,"text":"너희의 처음 익은 곡식 가루 떡을 거제로 타작 마당의 거제같이 들어 드리라","reference":"민수기 15:20","category":"$undefined"},{"id":"4175","book":"민수기","book_name":"민수기","chapter":15,"verse":21,"text":"너희의 처음 익은 곡식 가루 떡을 대대에 여호와께 거제로 드릴지니라","reference":"민수기 15:21","category":"$undefined"},{"id":"4176","book":"민수기","book_name":"민수기","chapter":15,"verse":22,"text":"너희가 그릇 범죄하여 여호와가 모세에게 말한 이 모든 명령을 지키지 못하되","reference":"민수기 15:22","category":"$undefined"},{"id":"4177","book":"민수기","book_name":"민수기","chapter":15,"verse":23,"text":"곧 여호와가 모세로 너희에게 명한 모든 것을 여호와가 명한 날부터 이후 너희의 대대에 지키지 못하여","reference":"민수기 15:23","category":"$undefined"},{"id":"4178","book":"민수기","book_name":"민수기","chapter":15,"verse":24,"text":"회중이 부지중에 그릇 범죄하였거든 온 회중은 수송아지 하나를 여호와께 향기로운 화제로 드리고 규례대로 그 소제와 전제를 드리고 수염소 하나를 속죄제로 드릴 것이라","reference":"민수기 15:24","category":"$undefined"},{"id":"4179","book":"민수기","book_name":"민수기","chapter":15,"verse":25,"text":"제사장이 이스라엘 자손의 온 회중을 위하여 속죄하면 그들이 사함을 얻으리니 이는 그릇 범죄함이며 또 그 그릇 범죄함을 인하여 예물 곧 화제와 속죄제를 여호와께 드렸음이라","reference":"민수기 15:25","category":"$undefined"},{"id":"4180","book":"민수기","book_name":"민수기","chapter":15,"verse":26,"text":"이스라엘 자손의 온 회중과 그들 중에 우거하는 타국인도 사함을 얻을 것은 온 백성이 그릇 범죄하였음이니라","reference":"민수기 15:26","category":"$undefined"},{"id":"4181","book":"민수기","book_name":"민수기","chapter":15,"verse":27,"text":"만일 한 사람이 그릇 범죄하거든 일년 된 암염소로 속죄제를 드릴 것이요","reference":"민수기 15:27","category":"$undefined"},{"id":"4182","book":"민수기","book_name":"민수기","chapter":15,"verse":28,"text":"제사장은 그 그릇 범죄한 사람이 그릇하여 여호와 앞에 얻은 죄를 위하여 속죄하여 그 죄를 속할지니 그리하면 사함을 얻으리라 !","reference":"민수기 15:28","category":"$undefined"},{"id":"4183","book":"민수기","book_name":"민수기","chapter":15,"verse":29,"text":"이스라엘 자손 중 본토 소생이든지 그들 중에 우거하는 타국인이든지 무릇 그릇 범죄한 자에게 대한 법이 동일하거니와","reference":"민수기 15:29","category":"$undefined"},{"id":"4184","book":"민수기","book_name":"민수기","chapter":15,"verse":30,"text":"본토 소생이든지 타국인이든지 무릇 짐짓 무엇을 행하면 여호와를 훼방하는 자니 그 백성 중에서 끊쳐질 것이라","reference":"민수기 15:30","category":"$undefined"},{"id":"4185","book":"민수기","book_name":"민수기","chapter":15,"verse":31,"text":"그런 사람은 여호와의 말씀을 멸시하고 그 명령을 파괴하였은즉 그 죄악이 자기에게로 돌아가서 온전히 끊쳐지리라","reference":"민수기 15:31","category":"$undefined"},{"id":"4186","book":"민수기","book_name":"민수기","chapter":15,"verse":32,"text":"이스라엘 자손이 광야에 거할 때에 안식일에 어떤 사람이 나무하는 것을 발견한지라","reference":"민수기 15:32","category":"$undefined"},{"id":"4187","book":"민수기","book_name":"민수기","chapter":15,"verse":33,"text":"그 나무하는 자를 발견한 자들이 그를 모세와 아론과 온 회중의 앞으로 끌어 왔으나","reference":"민수기 15:33","category":"$undefined"},{"id":"4188","book":"민수기","book_name":"민수기","chapter":15,"verse":34,"text":"어떻게 처치할는지 지시하심을 받지 못한 고로 가두었더니","reference":"민수기 15:34","category":"$undefined"},{"id":"4189","book":"민수기","book_name":"민수기","chapter":15,"verse":35,"text":"여호와께서 모세에게 이르시되 그 사람을 반드시 죽일지니 온 회중이 진 밖에서 돌로 그를 칠지니라","reference":"민수기 15:35","category":"$undefined"},{"id":"4190","book":"민수기","book_name":"민수기","chapter":15,"verse":36,"text":"온 회중이 곧 그를 진 밖으로 끌어내어 돌로 그를 쳐 죽여서 여호와께서 모세에게 명하신 대로 하니라","reference":"민수기 15:36","category":"$undefined"},{"id":"4191","book":"민수기","book_name":"민수기","chapter":15,"verse":37,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 15:37","category":"$undefined"},{"id":"4192","book":"민수기","book_name":"민수기","chapter":15,"verse":38,"text":"이스라엘 자손에게 명하여 그들의 대대로 그 옷단 귀에 술을 만들고 청색 끈을 그 귀의 술에 더하라","reference":"민수기 15:38","category":"$undefined"},{"id":"4193","book":"민수기","book_name":"민수기","chapter":15,"verse":39,"text":"이 술은 너희로 보고 여호와의 모든 계명을 기억하여 준행하고 너희로 방종(放縱)케 하는 자기의 마음과 눈의 욕심을 좇지 않게 하기 위함이라","reference":"민수기 15:39","category":"$undefined"},{"id":"4194","book":"민수기","book_name":"민수기","chapter":15,"verse":40,"text":"그리하면 너희가 나의 모든 계명을 기억하고 준행하여 너희의 하나님 앞에 거룩하리라","reference":"민수기 15:40","category":"$undefined"},{"id":"4195","book":"민수기","book_name":"민수기","chapter":15,"verse":41,"text":"나는 너희의 하나님이 되려 하여 너희를 애굽 땅에서 인도하여 낸 여호와 너희 하나님이니라 나는 여호와 너희 하나님이니라 !","reference":"민수기 15:41","category":"$undefined"}],"bookSlug":"numbers"}]
