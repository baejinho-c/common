2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":17,"verses":[{"id":"4246","book":"민수기","book_name":"민수기","chapter":17,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 17:1","category":"$undefined"},{"id":"4247","book":"민수기","book_name":"민수기","chapter":17,"verse":2,"text":"너는 이스라엘 자손에게 고하여 그들 중에서 각 종족을 따라 지팡이 하나씩 취하되 곧 그들의 종족대로 그 모든 족장에게서 지팡이 열둘을 취하고 그 사람들의 이름을 각각 그 지팡이에 쓰되","reference":"민수기 17:2","category":"$undefined"},{"id":"4248","book":"민수기","book_name":"민수기","chapter":17,"verse":3,"text":"레위의 지팡이에는 아론의 이름을 쓰라 이는 그들의 종족의 각 두령이 지팡이 하나씩 있어야 할 것임이니라","reference":"민수기 17:3","category":"$undefined"},{"id":"4249","book":"민수기","book_name":"민수기","chapter":17,"verse":4,"text":"그 지팡이를 회막 안에서 내가 너희와 만나는 곳인 증거궤 앞에 두라","reference":"민수기 17:4","category":"$undefined"},{"id":"4250","book":"민수기","book_name":"민수기","chapter":17,"verse":5,"text":"내가 택한 자의 지팡이에는 싹이 나리니 이것으로 이스라엘 자손이 너희를 대하여 원망하는 말을 내 앞에서 그치게 하리라","reference":"민수기 17:5","category":"$undefined"},{"id":"4251","book":"민수기","book_name":"민수기","chapter":17,"verse":6,"text":"모세가 이스라엘 자손에게 고하매 그 족장들이 각기 종족대로 지팡이 하나씩 그에게 주었으니 그 지팡이 합이 열둘이라 그 중에 아론의 지팡이가 있었더라","reference":"민수기 17:6","category":"$undefined"},{"id":"4252","book":"민수기","book_name":"민수기","chapter":17,"verse":7,"text":"모세가 그 지팡이들을 증거의 장막 안 여호와 앞에 두었더라","reference":"민수기 17:7","category":"$undefined"},{"id":"4253","book":"민수기","book_name":"민수기","chapter":17,"verse":8,"text":"이튿날 모세가 증거의 장막 안에 들어가 본즉 레위집을 위하여 낸 아론의 지팡이에 움이 돋고 순이 나고 꽃이 피어서 살구 열매가 열렸더라","reference":"민수기 17:8","category":"$undefined"},{"id":"4254","book":"민수기","book_name":"민수기","chapter":17,"verse":9,"text":"모세가 그 지팡이 전부를 여호와 앞에서 이스라엘 모든 자손에게로 취하여 내매 그들이 보고 각각 자기 지팡이를 취하였더라","reference":"민수기 17:9","category":"$undefined"},{"id":"4255","book":"민수기","book_name":"민수기","chapter":17,"verse":10,"text":"여호와께서 또 모세에게 이르시되 아론의 지팡이는 증거궤 앞으로 도로 가져다가 거기 간직하여 패역한 자에 대한 표징이 되게 하여 그들로 내게 대한 원망을 그치고 죽지 않게 할지니라","reference":"민수기 17:10","category":"$undefined"},{"id":"4256","book":"민수기","book_name":"민수기","chapter":17,"verse":11,"text":"모세가 곧 그같이 하되 여호와께서 자기에게 명하신 대로 하였더라","reference":"민수기 17:11","category":"$undefined"},{"id":"4257","book":"민수기","book_name":"민수기","chapter":17,"verse":12,"text":"이스라엘 자손이 모세에게 말하여 가로되 `보소서 ! 우리는 죽게 되었나이다 ! 망하게 되었나이다 ! 다 망하게 되었나이다 !","reference":"민수기 17:12","category":"$undefined"},{"id":"4258","book":"민수기","book_name":"민수기","chapter":17,"verse":13,"text":"가까이 나아가는 자 곧 여호와의 성막에 가까이 나아가는 자마다 죽사오니 우리가 다 망하여야 하리이까 ?'","reference":"민수기 17:13","category":"$undefined"}],"bookSlug":"numbers"}]
