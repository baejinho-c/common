11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":18,"verses":[{"id":"4259","book":"민수기","book_name":"민수기","chapter":18,"verse":1,"text":"여호와께서 아론에게 이르시되 너와 네 아들들과 네 종족은 성소에 대한 죄를 함께 담당할 것이요 너와 네 아들들은 너희가 그 제사장 직분에 대한 죄를 함께 담당할 것이니라","reference":"민수기 18:1","category":"$undefined"},{"id":"4260","book":"민수기","book_name":"민수기","chapter":18,"verse":2,"text":"너는 네 형제 레위 지파 곧 네 조상의 지파를 데려다가 너와 합동시켜 너를 섬기게 하고 너와 네 아들들은 증거의 장막앞에 있을 것이니라","reference":"민수기 18:2","category":"$undefined"},{"id":"4261","book":"민수기","book_name":"민수기","chapter":18,"verse":3,"text":"레위인은 네 직무와 장막의 모든 직무를 지키려니와 성소의 기구와 단에는 가까이 못하리니 두렵건대 그들과 너희가 죽을까 하노라","reference":"민수기 18:3","category":"$undefined"},{"id":"4262","book":"민수기","book_name":"민수기","chapter":18,"verse":4,"text":"레위인은 너와 합동하여 장막의 모든 일과 회막의 직무를 지킬 것이요 외인은 너희에게 가까이 못할 것이니라","reference":"민수기 18:4","category":"$undefined"},{"id":"4263","book":"민수기","book_name":"민수기","chapter":18,"verse":5,"text":"이와 같이 너희는 성소의 직무와 단의 직무를 지키라 ! 그리하면 여호와의 진노가 다시는 이스라엘 자손에게 미치지 아니하리라","reference":"민수기 18:5","category":"$undefined"},{"id":"4264","book":"민수기","book_name":"민수기","chapter":18,"verse":6,"text":"보라, 내가 이스라엘 자손 중에서 너희 형제 레위인을 취하여 내게 돌리고 너희에게 선물로 주어 회막의 일을 하게 하였나니","reference":"민수기 18:6","category":"$undefined"},{"id":"4265","book":"민수기","book_name":"민수기","chapter":18,"verse":7,"text":"너와 네 아들들은 단과 장 안의 모든 일에 대하여 제사장의 직분을 지켜 섬기라 ! 내가 제사장의 직분을 너희에게 선물로 주었은즉 거기 가까이 하는 외인은 죽이울지니라","reference":"민수기 18:7","category":"$undefined"},{"id":"4266","book":"민수기","book_name":"민수기","chapter":18,"verse":8,"text":"여호와께서 또 아론에게 이르시되 보라, 내가 내 거제물 곧 이스라엘 자손의 거룩하게 한 모든 예물을 너로 주관하게 하고 네가 기름부음을 받았음을 인하여 그것을 너와 네 아들들에게 영영한 응식으로 주노라","reference":"민수기 18:8","category":"$undefined"},{"id":"4267","book":"민수기","book_name":"민수기","chapter":18,"verse":9,"text":"지성물 중에 불사르지 않은 것은 네 것이라 그들이 내게 드리는 모든 예물의 모든 소제와 속죄제와 속건 제물은 다 지극히 거룩한즉 너와 네 아들들에게 돌리리니","reference":"민수기 18:9","category":"$undefined"},{"id":"4268","book":"민수기","book_name":"민수기","chapter":18,"verse":10,"text":"지극히 거룩하게 여김으로 먹으라 이는 네게 성물인즉 남자들이 다 먹을지니라","reference":"민수기 18:10","category":"$undefined"},{"id":"4269","book":"민수기","book_name":"민수기","chapter":18,"verse":11,"text":"내게 돌릴 것이 이것이니 곧 이스라엘 자손의 드리는 거제물과 모든 요제물이라 내가 그것을 너와 네 자손에게 영영한 응식으로 주었은즉 네 집의 정결한 자마다 먹을 것이니라","reference":"민수기 18:11","category":"$undefined"},{"id":"4270","book":"민수기","book_name":"민수기","chapter":18,"verse":12,"text":"그들이 여호와께 드리는 첫 소산 곧 제일 좋은 기름과, 제일 좋은 포도주와, 곡식을 네게 주었은즉","reference":"민수기 18:12","category":"$undefined"},{"id":"4271","book":"민수기","book_name":"민수기","chapter":18,"verse":13,"text":"그들이 여호와께 드리는 그 땅 처음 익은 모든 열매는 네 것이니 네 집에 정결한 자마다 먹을 것이라","reference":"민수기 18:13","category":"$undefined"},{"id":"4272","book":"민수기","book_name":"민수기","chapter":18,"verse":14,"text":"이스라엘 중에서 특별히 드린 모든 것은 네 것이 되리라 !","reference":"민수기 18:14","category":"$undefined"},{"id":"4273","book":"민수기","book_name":"민수기","chapter":18,"verse":15,"text":"여호와께 드리는 모든 생물의 처음 나는 것은 사람이나 짐승이나 다 네 것이로되 사람의 처음 난 것은 반드시 대속할 것이요 부정한 짐승의 처음 난 것도 대속할 것이며","reference":"민수기 18:15","category":"$undefined"},{"id":"4274","book":"민수기","book_name":"민수기","chapter":18,"verse":16,"text":"그 사람을 속할 때에는 난지 일개월 이후에 네가 정한 대로 성소의 세겔을 따라 은 다섯 세겔로 속하라 한 세겔은 이십 게라니라","reference":"민수기 18:16","category":"$undefined"},{"id":"4275","book":"민수기","book_name":"민수기","chapter":18,"verse":17,"text":"오직 소의 처음 난 것이나 양의 처음 난 것이나 염소의 처음 난것은 속하지 말지니 그것들은 거룩한즉 그 피는 단에 뿌리고 그 기름은 불살라 여호와께 향기로운 화제로 드릴 것이며","reference":"민수기 18:17","category":"$undefined"},{"id":"4276","book":"민수기","book_name":"민수기","chapter":18,"verse":18,"text":"그 고기는 네게 돌릴지니 흔든 가슴과 우편 넓적다리 같이 네게 돌릴 것이니라","reference":"민수기 18:18","category":"$undefined"},{"id":"4277","book":"민수기","book_name":"민수기","chapter":18,"verse":19,"text":"이스라엘 자손이 여호와께 거제로 드리는 모든 성물은 내가 영영한 응식으로 너와 네 자녀에게 주노니 이는 여호와 앞에 너와 네 후손에게 변하지 않는 소금 언약이니라","reference":"민수기 18:19","category":"$undefined"},{"id":"4278","book":"민수기","book_name":"민수기","chapter":18,"verse":20,"text":"여호와께서 또 아론에게 이르시되 너는 이스라엘 자손의 땅의 기업도 없겠고 그들 중에 아무 분깃도 없을 것이나 나는 이스라엘 자손 중에 네 분깃이요 네 기업이니라","reference":"민수기 18:20","category":"$undefined"},{"id":"4279","book":"민수기","book_name":"민수기","chapter":18,"verse":21,"text":"내가 이스라엘의 십일조를 레위 자손에게 기업으로 다 주어서 그들의 하는 일 곧 회막에서 하는 일을 갚나니","reference":"민수기 18:21","category":"$undefined"},{"id":"4280","book":"민수기","book_name":"민수기","chapter":18,"verse":22,"text":"이후로는 이스라엘 자손이 회막에 가까이 말 것이라 죄를 당하여 죽을까 하노라","reference":"민수기 18:22","category":"$undefined"},{"id":"4281","book":"민수기","book_name":"민수기","chapter":18,"verse":23,"text":"오직 레위인은 회막에서 봉사하며 자기들의 죄를 담당할 것이요 이스라엘 자손 중에는 기업이 없을 것이니 이는 너희의 대대에 영원한 율례라","reference":"민수기 18:23","category":"$undefined"},{"id":"4282","book":"민수기","book_name":"민수기","chapter":18,"verse":24,"text":"이스라엘 자손이 여호와께 거제로 드리는 십일조를 레위인에게 기업으로 준 고로 내가 그들에 대하여 말하기를 이스라엘 자손 중에 기업이 없을 것이라 하였노라","reference":"민수기 18:24","category":"$undefined"},{"id":"4283","book":"민수기","book_name":"민수기","chapter":18,"verse":25,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 18:25","category":"$undefined"},{"id":"4284","book":"민수기","book_name":"민수기","chapter":18,"verse":26,"text":"너는 레위인에게 고하여 그에게 이르라 내가 이스라엘 자손에게 취하여 너희에게 기업으로 준 십일조를 너희가 그들에게서 취할 때에 그 십일조의 십일조를 거제로 여호와께 드릴 것이라","reference":"민수기 18:26","category":"$undefined"},{"id":"4285","book":"민수기","book_name":"민수기","chapter":18,"verse":27,"text":"내가 너희의 거제물을 타작 마당에서 받드는 곡물과 포도즙 틀에서 받드는 즙같이 여기리니","reference":"민수기 18:27","category":"$undefined"},{"id":"4286","book":"민수기","book_name":"민수기","chapter":18,"verse":28,"text":"너희는 이스라엘 자손에게서 받는 모든 것의 십일조 중에서 여호와께 거제로 드리고 여호와께 드린 그 거제물은 제사장 아론에게 돌리되","reference":"민수기 18:28","category":"$undefined"},{"id":"4287","book":"민수기","book_name":"민수기","chapter":18,"verse":29,"text":"너희의 받은 모든 예물 중에서 너희는 그 아름다운 것 곧 거룩하게 한 부분을 취하여 여호와께 거제로 드릴지니라","reference":"민수기 18:29","category":"$undefined"},{"id":"4288","book":"민수기","book_name":"민수기","chapter":18,"verse":30,"text":"이러므로 너는 그들에게 이르라 너희가 그 중에서 아름다운 것을 취하여 드리고 남은 것은 너희 레위인에게는 타작 마당의 소출과 포도즙 틀의 소출같이 되리니","reference":"민수기 18:30","category":"$undefined"},{"id":"4289","book":"민수기","book_name":"민수기","chapter":18,"verse":31,"text":"너희와 너희 권속이 어디서든지 이것을 먹을 수 있음은 이는 회막에서 일한 너희의 보수임이니라","reference":"민수기 18:31","category":"$undefined"},{"id":"4290","book":"민수기","book_name":"민수기","chapter":18,"verse":32,"text":"너희가 그 중 아름다운 것을 받들어 드린즉 이로 인하여 죄를 지지 아니할 것이라 너희는 이스라엘 자손의 성물을 더럽히지 말라 ! 그리하면 죽지 아니하리라","reference":"민수기 18:32","category":"$undefined"}],"bookSlug":"numbers"}]
