2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":19,"verses":[{"id":"4291","book":"민수기","book_name":"민수기","chapter":19,"verse":1,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"민수기 19:1","category":"$undefined"},{"id":"4292","book":"민수기","book_name":"민수기","chapter":19,"verse":2,"text":"여호와의 명하는 법의 율례를 이제 이르노니 이스라엘 자손에게 일러서 온전하여 흠이 없고 아직 멍에 메지 아니한 붉은 암송아지를 네게로 끌어 오게 하고","reference":"민수기 19:2","category":"$undefined"},{"id":"4293","book":"민수기","book_name":"민수기","chapter":19,"verse":3,"text":"너는 그것을 제사장 엘르아살에게 줄 것이요 그는 그것을 진 밖으로 끌어 내어서 자기 목전에서 잡게 할것이며","reference":"민수기 19:3","category":"$undefined"},{"id":"4294","book":"민수기","book_name":"민수기","chapter":19,"verse":4,"text":"제사장 엘르아살은 손가락에 그 피를 찍고 그 피를 회막 앞을 향하여 일곱번 뿌리고","reference":"민수기 19:4","category":"$undefined"},{"id":"4295","book":"민수기","book_name":"민수기","chapter":19,"verse":5,"text":"그 암소를 자기 목전에서 불사르게 하되 그 가죽과 고기와 피와 똥을 불사르게 하고","reference":"민수기 19:5","category":"$undefined"},{"id":"4296","book":"민수기","book_name":"민수기","chapter":19,"verse":6,"text":"동시에 제사장은 백향목과, 우슬초와, 홍색실을 취하여 암송아지를 사르는 불 가운데 던질 것이며","reference":"민수기 19:6","category":"$undefined"},{"id":"4297","book":"민수기","book_name":"민수기","chapter":19,"verse":7,"text":"제사장은 그 옷을 빨고 물로 몸을 씻은 후에 진에 들어갈 것이라 그는 저녁까지 부정하리라","reference":"민수기 19:7","category":"$undefined"},{"id":"4298","book":"민수기","book_name":"민수기","chapter":19,"verse":8,"text":"송아지를 불사른 자도 그 옷을 물로 빨고 물로 그 몸을 씻을 것이라 그도 저녁까지 부정하리라","reference":"민수기 19:8","category":"$undefined"},{"id":"4299","book":"민수기","book_name":"민수기","chapter":19,"verse":9,"text":"이에 정한 자가 암송아지의 재를 거두어 진 밖 정한 곳에 둘지니 이것은 이스라엘 자손 회중을 위하여 간직하였다가 부정을 깨끗케 하는 물을 만드는데 쓸 것이니 곧 속죄제니라","reference":"민수기 19:9","category":"$undefined"},{"id":"4300","book":"민수기","book_name":"민수기","chapter":19,"verse":10,"text":"암송아지의 재를 거둔 자도 그 옷을 빨 것이며 저녁까지 부정하리라 이는 이스라엘 자손과 그 중에 우거하는 외인에게 영원한 율례니라","reference":"민수기 19:10","category":"$undefined"},{"id":"4301","book":"민수기","book_name":"민수기","chapter":19,"verse":11,"text":"사람의 시체를 만진 자는 칠일을 부정하리니","reference":"민수기 19:11","category":"$undefined"},{"id":"4302","book":"민수기","book_name":"민수기","chapter":19,"verse":12,"text":"그는 제 삼일과 제 칠일에 이 잿물로 스스로 정결케 할 것이라 그리하면 정하려니와 제 삼일과 제 칠일에 스스로 정결케 아니하면 그냥 부정하니","reference":"민수기 19:12","category":"$undefined"},{"id":"4303","book":"민수기","book_name":"민수기","chapter":19,"verse":13,"text":"누구든지 죽은 사람의 시체를 만지고 스스로 정결케 아니하는 자는 여호와의 성막을 더럽힘이라 그가 이스라엘에서 끊쳐질 것은 정결케 하는 물을 그에게 뿌리지 아니하므로 깨끗케 되지 못하고 그 부정함이 있음이니라","reference":"민수기 19:13","category":"$undefined"},{"id":"4304","book":"민수기","book_name":"민수기","chapter":19,"verse":14,"text":"장막에서 사람이 죽을 때의 법은 이러하니 무릇 그 장막에 들어가는 자와 무릇 그 장막에 있는 자가 칠일 동안 부정할 것이며","reference":"민수기 19:14","category":"$undefined"},{"id":"4305","book":"민수기","book_name":"민수기","chapter":19,"verse":15,"text":"무릇 뚜껑을 열어 놓고 덮지 아니한 그릇도 부정하니라","reference":"민수기 19:15","category":"$undefined"},{"id":"4306","book":"민수기","book_name":"민수기","chapter":19,"verse":16,"text":"누구든지 들에서 칼에 죽이운 자나 시체나 사람의 뼈나 무덤을 만졌으면 칠일동안 부정하리니","reference":"민수기 19:16","category":"$undefined"},{"id":"4307","book":"민수기","book_name":"민수기","chapter":19,"verse":17,"text":"그 부정한 자를 위하여 죄를 깨끗하게 하려고 불사른 재를 취하여 흐르는 물과 함께 그릇에 담고","reference":"민수기 19:17","category":"$undefined"},{"id":"4308","book":"민수기","book_name":"민수기","chapter":19,"verse":18,"text":"정한 자가 우슬초를 취하여 그 물을 찍어서 장막과 그 모든 기구와 거기 있는 사람들에게 뿌리고 또 뼈나 죽임을 당한 자나 시체나 무덤을 만진 자에게 뿌리되","reference":"민수기 19:18","category":"$undefined"},{"id":"4309","book":"민수기","book_name":"민수기","chapter":19,"verse":19,"text":"그 정한 자가 제 삼일과 제 칠일에 그 부정한 자에게 뿌려서 제 칠일에 그를 정결케 할 것이며 그는 자기 옷을 빨고 물로 몸을 씻을 것이라 저녁이면 정하리라","reference":"민수기 19:19","category":"$undefined"},{"id":"4310","book":"민수기","book_name":"민수기","chapter":19,"verse":20,"text":"사람이 부정하고도 스스로 정결케 아니하면 여호와의 성소를 더럽힘이니 그러므로 총회 중에서 끊쳐질 것이니라 그는 정결케 하는 물로 뿌리움을 받지 아니하였은즉 부정하니라","reference":"민수기 19:20","category":"$undefined"},{"id":"4311","book":"민수기","book_name":"민수기","chapter":19,"verse":21,"text":"이는 그들의 영영한 율례니라 정결케 하는 물을 뿌린 자는 그 옷을 빨 것이며 정결케 하는 물을 만지는 자는 저녁까지 부정할 것이며","reference":"민수기 19:21","category":"$undefined"},{"id":"4312","book":"민수기","book_name":"민수기","chapter":19,"verse":22,"text":"부정한 자가 만진 것은 무엇이든지 부정할 것이며 그것을 만지는 자도 저녁까지 부정하리라","reference":"민수기 19:22","category":"$undefined"}],"bookSlug":"numbers"}]
