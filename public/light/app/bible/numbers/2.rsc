2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":2,"verses":[{"id":"3660","book":"민수기","book_name":"민수기","chapter":2,"verse":1,"text":"여호와께서 모세와 아론에게 일러 가라사대","reference":"민수기 2:1","category":"$undefined"},{"id":"3661","book":"민수기","book_name":"민수기","chapter":2,"verse":2,"text":"이스라엘 자손은 각각 그 기와 그 종족의 기호 곁에 진을 치되 회막을 사면으로 대하여 치라","reference":"민수기 2:2","category":"$undefined"},{"id":"3662","book":"민수기","book_name":"민수기","chapter":2,"verse":3,"text":"동방 해 돋는 편에 진 칠 자는 그 군대대로 유다의 진기에 속한자라 유다 자손의 족장은 암미나답의 아들 나손이요","reference":"민수기 2:3","category":"$undefined"},{"id":"3663","book":"민수기","book_name":"민수기","chapter":2,"verse":4,"text":"그 군대는 계수함을 입은 자가 칠만 사천 육백명이며","reference":"민수기 2:4","category":"$undefined"},{"id":"3664","book":"민수기","book_name":"민수기","chapter":2,"verse":5,"text":"그 곁에 진 칠 자는 잇사갈 지파라 잇사갈 자손의 족장은 수알의 아들 느다넬이요","reference":"민수기 2:5","category":"$undefined"},{"id":"3665","book":"민수기","book_name":"민수기","chapter":2,"verse":6,"text":"그 군대는 계수함을 입은 자 오만 사천 사백명이며","reference":"민수기 2:6","category":"$undefined"},{"id":"3666","book":"민수기","book_name":"민수기","chapter":2,"verse":7,"text":"또 스불론 지파라 스불론 자손의 족장은 헬론의 아들 엘리압이요","reference":"민수기 2:7","category":"$undefined"},{"id":"3667","book":"민수기","book_name":"민수기","chapter":2,"verse":8,"text":"그 군대는 계수함을 입은 자 오만 칠천 사백명이니","reference":"민수기 2:8","category":"$undefined"},{"id":"3668","book":"민수기","book_name":"민수기","chapter":2,"verse":9,"text":"유다 진에 속한 군대의 계수함을 입은 군대의 총계가 십 팔만 육천 사백명이라 그들은 제 일대로 진행할지니라","reference":"민수기 2:9","category":"$undefined"},{"id":"3669","book":"민수기","book_name":"민수기","chapter":2,"verse":10,"text":"남편에는 르우벤 군대의 진 기가 있을 것이라 르우벤 자손의 족장은 스데울의 아들 엘리술이요","reference":"민수기 2:10","category":"$undefined"},{"id":"3670","book":"민수기","book_name":"민수기","chapter":2,"verse":11,"text":"그 군대는 계수함을 입은 자 사만 육천 오백명이며","reference":"민수기 2:11","category":"$undefined"},{"id":"3671","book":"민수기","book_name":"민수기","chapter":2,"verse":12,"text":"그 곁에 진 칠 자는 시므온 지파라 시므온 자손의 족장은 수리삿대의 아들 슬루미엘이요","reference":"민수기 2:12","category":"$undefined"},{"id":"3672","book":"민수기","book_name":"민수기","chapter":2,"verse":13,"text":"그 군대는 계수함을 입은 자 오만 구천 삼백명이며","reference":"민수기 2:13","category":"$undefined"},{"id":"3673","book":"민수기","book_name":"민수기","chapter":2,"verse":14,"text":"또 갓 지파라 갓 자손의 족장은 르우엘의 아들 엘리아삽이요","reference":"민수기 2:14","category":"$undefined"},{"id":"3674","book":"민수기","book_name":"민수기","chapter":2,"verse":15,"text":"그 군대는 계수함을 입은 자 사만 오천 육백 오십명이니","reference":"민수기 2:15","category":"$undefined"},{"id":"3675","book":"민수기","book_name":"민수기","chapter":2,"verse":16,"text":"르우벤 진에 속한 계수함을 입은 군대의 총계가 십 오만 일천 사백 오십명이라 그들은 제 이대로 진행할지니라","reference":"민수기 2:16","category":"$undefined"},{"id":"3676","book":"민수기","book_name":"민수기","chapter":2,"verse":17,"text":"그 다음에 회막이 레위인의 진과 함께 모든 진의 중앙에 있어 진행하되 그들의 진 친 순서대로 각 사람은 그 위치에서 그 기를 따라 앞으로 행할지니라","reference":"민수기 2:17","category":"$undefined"},{"id":"3677","book":"민수기","book_name":"민수기","chapter":2,"verse":18,"text":"서편에는 에브라임의 군대의 진 기가 있을 것이라 에브라임 자손의 족장은 암미훗의 아들 엘리사마요","reference":"민수기 2:18","category":"$undefined"},{"id":"3678","book":"민수기","book_name":"민수기","chapter":2,"verse":19,"text":"그 군대는 계수함을 입은 자 사만 오백명이며","reference":"민수기 2:19","category":"$undefined"},{"id":"3679","book":"민수기","book_name":"민수기","chapter":2,"verse":20,"text":"그 곁에는 므낫세 지파가 있을 것이라 므낫세 자손의 족장은 브다술의 아들 가말리엘이요","reference":"민수기 2:20","category":"$undefined"},{"id":"3680","book":"민수기","book_name":"민수기","chapter":2,"verse":21,"text":"그 군대는 계수함을 입은 자 삼만 이천 이백명이며","reference":"민수기 2:21","category":"$undefined"},{"id":"3681","book":"민수기","book_name":"민수기","chapter":2,"verse":22,"text":"또 베냐민 지파라 베냐민 자손의 족장은 기드오니의 아들 아비단이요","reference":"민수기 2:22","category":"$undefined"},{"id":"3682","book":"민수기","book_name":"민수기","chapter":2,"verse":23,"text":"그 군대는 계수함을 입은 자 삼만 오천 사백명이니","reference":"민수기 2:23","category":"$undefined"},{"id":"3683","book":"민수기","book_name":"민수기","chapter":2,"verse":24,"text":"에브라임 진에 속한 계수함을 입은 군대의 총계가 십만 팔천 일백명이라 그들은 제 삼대로 진행할지니라","reference":"민수기 2:24","category":"$undefined"},{"id":"3684","book":"민수기","book_name":"민수기","chapter":2,"verse":25,"text":"북편에는 단 군대의 진 기가 있을 것이라 단 자손의 족장은 암미삿대의 아들 아히에셀이요","reference":"민수기 2:25","category":"$undefined"},{"id":"3685","book":"민수기","book_name":"민수기","chapter":2,"verse":26,"text":"그 군대는 계수함을 입은 자 육만 이천 칠백명이며","reference":"민수기 2:26","category":"$undefined"},{"id":"3686","book":"민수기","book_name":"민수기","chapter":2,"verse":27,"text":"그 곁에 진 칠 자는 아셀 지파라 아셀 자손의 족장은 오그란의 아들 바기엘이요","reference":"민수기 2:27","category":"$undefined"},{"id":"3687","book":"민수기","book_name":"민수기","chapter":2,"verse":28,"text":"그 군대는 계수함을 입은 자 사만 일천 오백명이며","reference":"민수기 2:28","category":"$undefined"},{"id":"3688","book":"민수기","book_name":"민수기","chapter":2,"verse":29,"text":"또 납달리 지파라 납달리 자손의 족장은 에난의 아들 아히라요","reference":"민수기 2:29","category":"$undefined"},{"id":"3689","book":"민수기","book_name":"민수기","chapter":2,"verse":30,"text":"그 군대는 계수함을 입은 자 오만 삼천 사백명이니","reference":"민수기 2:30","category":"$undefined"},{"id":"3690","book":"민수기","book_name":"민수기","chapter":2,"verse":31,"text":"단의 진에 속한 계수함을 입은 군대의 총계가 십 오만 칠천 육백명이라 그들은 기를 따라 후대로 진행할지니라 하시니라","reference":"민수기 2:31","category":"$undefined"},{"id":"3691","book":"민수기","book_name":"민수기","chapter":2,"verse":32,"text":"이상은 이스라엘 자손이 그 종족을 따라 계수함을 입은 자니 모든 진의 군대 곧 계수함을 입은 총계가 육십만 삼천 오백 오십명이었으며","reference":"민수기 2:32","category":"$undefined"},{"id":"3692","book":"민수기","book_name":"민수기","chapter":2,"verse":33,"text":"레위인은 이스라엘 자손과 함께 계수되지 아니하였으니 여호와께서 모세에게 명하심과 같았느니라","reference":"민수기 2:33","category":"$undefined"},{"id":"3693","book":"민수기","book_name":"민수기","chapter":2,"verse":34,"text":"이스라엘 자손이 여호와께서 모세에게 명하신대로 다 준행하여 각기 가족과 종족을 따르며 그 기를 따라 진 치기도 하며 진행하기도 하였더라","reference":"민수기 2:34","category":"$undefined"}],"bookSlug":"numbers"}]
