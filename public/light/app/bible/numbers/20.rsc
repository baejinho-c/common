2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":20,"verses":[{"id":"4313","book":"민수기","book_name":"민수기","chapter":20,"verse":1,"text":"정월에 이스라엘 자손 곧 온 회중이 신 광야에 이르러서 백성이 가데스에 거하더니 미리암이 거기서 죽으매 거기 장사하니라","reference":"민수기 20:1","category":"$undefined"},{"id":"4314","book":"민수기","book_name":"민수기","chapter":20,"verse":2,"text":"회중이 물이 없으므로 모여서 모세와 아론을 공박하니라","reference":"민수기 20:2","category":"$undefined"},{"id":"4315","book":"민수기","book_name":"민수기","chapter":20,"verse":3,"text":"백성이 모세와 다투어 말하여 가로되 `우리 형제들이 여호와 앞에서 죽을 때에 우리도 죽었더면 좋을 뻔 하였도다","reference":"민수기 20:3","category":"$undefined"},{"id":"4316","book":"민수기","book_name":"민수기","chapter":20,"verse":4,"text":"너희가 어찌하여 여호와의 총회를 이 광야로 인도하여 올려서 우리와 우리 짐승으로 다 여기서 죽게 하느냐 ?","reference":"민수기 20:4","category":"$undefined"},{"id":"4317","book":"민수기","book_name":"민수기","chapter":20,"verse":5,"text":"너희가 어찌하여 우리를 애굽에서 나오게 하여 이 악한 곳으로 인도하였느냐 ? 이 곳에는 파종할 곳이 없고, 무화과도 없고, 포도도 없고, 석류도 없고, 마실 물도 없도다'","reference":"민수기 20:5","category":"$undefined"},{"id":"4318","book":"민수기","book_name":"민수기","chapter":20,"verse":6,"text":"모세와 아론이 총회 앞을 떠나 회막 문에 이르러 엎드리매 여호와의 영광이 그들에게 나타나며","reference":"민수기 20:6","category":"$undefined"},{"id":"4319","book":"민수기","book_name":"민수기","chapter":20,"verse":7,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 20:7","category":"$undefined"},{"id":"4320","book":"민수기","book_name":"민수기","chapter":20,"verse":8,"text":"지팡이를 가지고 네 형 아론과 함께 회중을 모으고 그들의 목전에서 너희는 반석에게 명하여 물을 내라 하라 네가 그 반석으로 물을 내게 하여 회중과 그들의 짐승에게 마시울지니라","reference":"민수기 20:8","category":"$undefined"},{"id":"4321","book":"민수기","book_name":"민수기","chapter":20,"verse":9,"text":"모세가 그 명대로 여호와의 앞에서 지팡이를 취하니라","reference":"민수기 20:9","category":"$undefined"},{"id":"4322","book":"민수기","book_name":"민수기","chapter":20,"verse":10,"text":"모세와 아론이 총회를 그 반석 앞에 모으고 모세가 그들에게 이르되 패역한 너희여 들으라 우리가 너희를 위하여 이 반석에서 물을 내랴 하고","reference":"민수기 20:10","category":"$undefined"},{"id":"4323","book":"민수기","book_name":"민수기","chapter":20,"verse":11,"text":"그 손을 들어 그 지팡이로 반석을 두번 치매 물이 많이 솟아 나오므로 회중과 그들의 짐승이 마시니라","reference":"민수기 20:11","category":"$undefined"},{"id":"4324","book":"민수기","book_name":"민수기","chapter":20,"verse":12,"text":"여호와께서 모세와 아론에게 이르시되 너희가 나를 믿지 아니하고 이스라엘 자손의 목전에 나의 거룩함을 나타내지 아니한 고로 너희는 이 총회를 내가 그들에게 준 땅으로 인도하여 들이지 못하리라 하시니라","reference":"민수기 20:12","category":"$undefined"},{"id":"4325","book":"민수기","book_name":"민수기","chapter":20,"verse":13,"text":"이스라엘 자손이 여호와와 다투었으므로 이를 므리바 물이라 하니라 여호와께서 그들 중에서 그 거룩함을 나타내셨더라","reference":"민수기 20:13","category":"$undefined"},{"id":"4326","book":"민수기","book_name":"민수기","chapter":20,"verse":14,"text":"모세가 가데스에서 에돔 왕에게 사자를 보내며 이르되 `당신의 형제 이스라엘의 말에 우리의 당한 모든 고난을 당신도 아시거니와","reference":"민수기 20:14","category":"$undefined"},{"id":"4327","book":"민수기","book_name":"민수기","chapter":20,"verse":15,"text":"우리 열조가 애굽으로 내려갔으므로 우리가 애굽에 오래 거하였더니 애굽인이 우리 열조와 우리를 학대하였으므로","reference":"민수기 20:15","category":"$undefined"},{"id":"4328","book":"민수기","book_name":"민수기","chapter":20,"verse":16,"text":"우리가 여호와께 부르짖었더니 우리 소리를 들으시고 천사를 보내사 우리를 애굽에서 인도하여 내셨나이다 이제 우리가 당신의 변방 모퉁이 한 성읍 가데스에 있사오니","reference":"민수기 20:16","category":"$undefined"},{"id":"4329","book":"민수기","book_name":"민수기","chapter":20,"verse":17,"text":"청컨대 우리로 당신의 땅을 통과하게 하소서 우리가 밭으로나 포도원으로나 통과하지 아니하고 우물물도 공히 마시지 아니하고 우리가 왕의 대로로만 통과하고 당신의 지경에서 나가기까지 좌편으로나 우편으로 치우치지 아니하리이다 한다 하라' 하였더니","reference":"민수기 20:17","category":"$undefined"},{"id":"4330","book":"민수기","book_name":"민수기","chapter":20,"verse":18,"text":"에돔 왕이 대답하되 `너는 우리 가운데로 통과하지 못하리라 내가 나가서 칼로 너를 맞을까 염려하라'","reference":"민수기 20:18","category":"$undefined"},{"id":"4331","book":"민수기","book_name":"민수기","chapter":20,"verse":19,"text":"이스라엘 자손이 이르되 `우리가 대로로 통과하겠고 우리나 우리 짐승이 당신의 물을 마시면 그 값을 줄 것이라 우리가 도보로 통과할 뿐인즉 아무 일도 없으리이다' 하나","reference":"민수기 20:19","category":"$undefined"},{"id":"4332","book":"민수기","book_name":"민수기","chapter":20,"verse":20,"text":"그는 가로되 `너는 지나가지 못하리라' 하고 에돔 왕이 많은 백성을 거느리고 나와서 강한 손으로 막으니","reference":"민수기 20:20","category":"$undefined"},{"id":"4333","book":"민수기","book_name":"민수기","chapter":20,"verse":21,"text":"에돔 왕이 이같이 이스라엘의 그 경내로 통과함을 용납지 아니하므로 이스라엘이 그들에게서 돌이키니라","reference":"민수기 20:21","category":"$undefined"},{"id":"4334","book":"민수기","book_name":"민수기","chapter":20,"verse":22,"text":"이스라엘 자손 곧 온 회중이 가데스에서 진행하여 호르산에 이르렀더니","reference":"민수기 20:22","category":"$undefined"},{"id":"4335","book":"민수기","book_name":"민수기","chapter":20,"verse":23,"text":"여호와께서 에돔 땅 변경 호르산에서 모세와 아론에게 말씀하시니라 가라사대","reference":"민수기 20:23","category":"$undefined"},{"id":"4336","book":"민수기","book_name":"민수기","chapter":20,"verse":24,"text":"아론은 그 열조에게로 돌아가고 내가 이스라엘 자손에게 준 땅에는 들어가지 못하리니 이는 너희가 므리바 물에서 내 말을 거역한 연고니라","reference":"민수기 20:24","category":"$undefined"},{"id":"4337","book":"민수기","book_name":"민수기","chapter":20,"verse":25,"text":"너는 아론과 그 아들 엘르아살을 데리고 호르산에 올라","reference":"민수기 20:25","category":"$undefined"},{"id":"4338","book":"민수기","book_name":"민수기","chapter":20,"verse":26,"text":"아론의 옷을 벗겨 그 아들 엘르아살에게 입히라 아론은 거기서 죽어 그 열조에게로 돌아가리라","reference":"민수기 20:26","category":"$undefined"},{"id":"4339","book":"민수기","book_name":"민수기","chapter":20,"verse":27,"text":"모세가 여호와의 명을 좇아 그들과 함께 회중의 목전에서 호르산에 오르니라","reference":"민수기 20:27","category":"$undefined"},{"id":"4340","book":"민수기","book_name":"민수기","chapter":20,"verse":28,"text":"모세가 아론의 옷을 벗겨 그 아들 엘르아살에게 입히매 아론이 그 산꼭대기에서 죽으니라 모세와 엘르아살이 산에서 내려오니","reference":"민수기 20:28","category":"$undefined"},{"id":"4341","book":"민수기","book_name":"민수기","chapter":20,"verse":29,"text":"온 회중 곧 이스라엘 온 족속이 아론의 죽은 것을 보고 위하여 삼십일을 애곡하였더라","reference":"민수기 20:29","category":"$undefined"}],"bookSlug":"numbers"}]
