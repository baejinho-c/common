2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":21,"verses":[{"id":"4342","book":"민수기","book_name":"민수기","chapter":21,"verse":1,"text":"남방에 거하는 가나안 사람 곧 아랏의 왕이 이스라엘이 아다림 길로 온다 함을 듣고 이스라엘을 쳐서 그 중 몇 사람을 사로잡은","reference":"민수기 21:1","category":"$undefined"},{"id":"4343","book":"민수기","book_name":"민수기","chapter":21,"verse":2,"text":"이스라엘이 여호와께 서원하여 가로되 `주께서 만일 이 백성을 내 손에 붙이시면 내가 그들의 성읍을 다 멸하리이다'","reference":"민수기 21:2","category":"$undefined"},{"id":"4344","book":"민수기","book_name":"민수기","chapter":21,"verse":3,"text":"여호와께서 이스라엘의 소리를 들으시고 가나안 사람을 붙이시매 그들과 그 성읍을 다 멸하니라 그러므로 그 곳 이름을 [호르마]라 하였더라","reference":"민수기 21:3","category":"$undefined"},{"id":"4345","book":"민수기","book_name":"민수기","chapter":21,"verse":4,"text":"백성이 호르산에서 진행하여 홍해 길로 좇아 에돔 땅을 둘러 행하려 하였다가 길로 인하여 백성의 마음이 상하니라","reference":"민수기 21:4","category":"$undefined"},{"id":"4346","book":"민수기","book_name":"민수기","chapter":21,"verse":5,"text":"백성이 하나님과 모세를 향하여 원망하되 `어찌하여 우리를 애굽에서 인도하여 올려서 이 광야에서 죽게 하는고 이 곳에는 식물도 없고, 물도 없도다 우리 마음이 이 박한 식물을 싫어 하노라'하매","reference":"민수기 21:5","category":"$undefined"},{"id":"4347","book":"민수기","book_name":"민수기","chapter":21,"verse":6,"text":"여호와께서 불뱀들을 백성 중에 보내어 백성을 물게 하시므로 이스라엘 백성 중에 죽은 자가 많은지라","reference":"민수기 21:6","category":"$undefined"},{"id":"4348","book":"민수기","book_name":"민수기","chapter":21,"verse":7,"text":"백성이 모세에게 이르러 가로되 `우리가 여호와와 당신을 향하여 원망하므로 범죄하였사오니 여호와께 기도하여 이 뱀들을 우리에게서 떠나게 하소서 !' 모세가 백성을 위하여 기도하매","reference":"민수기 21:7","category":"$undefined"},{"id":"4349","book":"민수기","book_name":"민수기","chapter":21,"verse":8,"text":"여호와께서 모세에게 이르시되 불뱀을 만들어 장대 위에 달라 물린 자마다 그것을 보면 살리라 !","reference":"민수기 21:8","category":"$undefined"},{"id":"4350","book":"민수기","book_name":"민수기","chapter":21,"verse":9,"text":"모세가 놋뱀을 만들어 장대 위에 다니 뱀에게 물린 자마다 놋뱀을 쳐다 본즉 살더라","reference":"민수기 21:9","category":"$undefined"},{"id":"4351","book":"민수기","book_name":"민수기","chapter":21,"verse":10,"text":"이스라엘 자손이 진행하여 오봇에 진 쳤고","reference":"민수기 21:10","category":"$undefined"},{"id":"4352","book":"민수기","book_name":"민수기","chapter":21,"verse":11,"text":"오봇에서 진행하여 모압 앞 해 돋는 편 광야 이예아바림에 진 쳤고","reference":"민수기 21:11","category":"$undefined"},{"id":"4353","book":"민수기","book_name":"민수기","chapter":21,"verse":12,"text":"거기서 진행하여 세렛 골짜기에 진 쳤고","reference":"민수기 21:12","category":"$undefined"},{"id":"4354","book":"민수기","book_name":"민수기","chapter":21,"verse":13,"text":"거기서 진행하여 아모리인의 지경에서 흘러 나와서 광야에 이른 아르논 건너편에 진쳤으니 아르논은 모압과 아모리 사이에서 모압의 경계가 된 것이라","reference":"민수기 21:13","category":"$undefined"},{"id":"4355","book":"민수기","book_name":"민수기","chapter":21,"verse":14,"text":"이러므로 여호와의 전쟁기에 일렀으되 수바의 와헙과 아르논 골짜기와","reference":"민수기 21:14","category":"$undefined"},{"id":"4356","book":"민수기","book_name":"민수기","chapter":21,"verse":15,"text":"모든 골짜기의 비탈은 아르 고을을 향하여 기울어지고 모압의 경계에 닿았도다 하였더라","reference":"민수기 21:15","category":"$undefined"},{"id":"4357","book":"민수기","book_name":"민수기","chapter":21,"verse":16,"text":"거기서 브엘에 이르니 브엘은 여호와께서 모세에게 명하시기를 백성을 모으라 내가 그들에게 물을 주리라 하시던 우물이라","reference":"민수기 21:16","category":"$undefined"},{"id":"4358","book":"민수기","book_name":"민수기","chapter":21,"verse":17,"text":"그 때에 이스라엘이 노래하여 가로되 우물물아 솟아나라 ! 너희는 그것을 노래하라","reference":"민수기 21:17","category":"$undefined"},{"id":"4359","book":"민수기","book_name":"민수기","chapter":21,"verse":18,"text":"이 우물은 족장들이 팠고 백성의 귀인들이 홀과 지팡이로 판 것이로다 하였더라 광야에서 맛다나에 이르렀고","reference":"민수기 21:18","category":"$undefined"},{"id":"4360","book":"민수기","book_name":"민수기","chapter":21,"verse":19,"text":"맛다나에서 나할리엘에 이르렀고, 나할리엘에서 바못에 이르렀고","reference":"민수기 21:19","category":"$undefined"},{"id":"4361","book":"민수기","book_name":"민수기","chapter":21,"verse":20,"text":"바못에서 모압 들에 있는 골짜기에 이르러 광야가 내려다 보이는 비스가산 꼭대기에 이르렀더라","reference":"민수기 21:20","category":"$undefined"},{"id":"4362","book":"민수기","book_name":"민수기","chapter":21,"verse":21,"text":"이스라엘이 아모리 왕 시혼에게 사자를 보내어 가로되","reference":"민수기 21:21","category":"$undefined"},{"id":"4363","book":"민수기","book_name":"민수기","chapter":21,"verse":22,"text":"`우리로 당신의 땅을 통과하게 하소서 우리가 밭에든지 포도원에든지 들어가지 아니하며 우물물도 공히 마시지 아니하고 우리가 당신의 지경에서 다 나가기까지 왕의 대로로만 통행하리이다'하나","reference":"민수기 21:22","category":"$undefined"},{"id":"4364","book":"민수기","book_name":"민수기","chapter":21,"verse":23,"text":"시혼이 자기 지경으로 이스라엘의 통과함을 용납하지 아니하고 그 백성을 다 모아 이스라엘을 치러 광야로 나와서 야하스에 이르러 이스라엘을 치므로","reference":"민수기 21:23","category":"$undefined"},{"id":"4365","book":"민수기","book_name":"민수기","chapter":21,"verse":24,"text":"이스라엘이 칼날로 그들을 쳐서 파하고 그 땅을 아르논부터 얍복까지 점령하여 암몬 자손에게까지 미치니 암몬 자손의 경계는 견고하더라","reference":"민수기 21:24","category":"$undefined"},{"id":"4366","book":"민수기","book_name":"민수기","chapter":21,"verse":25,"text":"이스라엘이 이같이 그 모든 성읍을 취하고 그 아모리인의 모든 성읍을 취하고 그 아모리인의 모든 성읍 헤스본과 그 모든 촌락에 거하였으니","reference":"민수기 21:25","category":"$undefined"},{"id":"4367","book":"민수기","book_name":"민수기","chapter":21,"verse":26,"text":"헤스본은 아모리인의 왕 시혼의 도성이라 시혼이 모압 전왕을 치고 그 모든 땅을 아르논까지 그 손에서 탈취하였었더라","reference":"민수기 21:26","category":"$undefined"},{"id":"4368","book":"민수기","book_name":"민수기","chapter":21,"verse":27,"text":"그러므로 시인이 읊어 가로되 너희는 헤스본으로 올지어다 시혼의 성을 세워 견고히 할지어다","reference":"민수기 21:27","category":"$undefined"},{"id":"4369","book":"민수기","book_name":"민수기","chapter":21,"verse":28,"text":"헤스본에서 불이 나오며 시혼의 성에서 화염이 나와서 모압의 아르를 삼키며 아르논 높은 곳의 주인을 멸하였도다","reference":"민수기 21:28","category":"$undefined"},{"id":"4370","book":"민수기","book_name":"민수기","chapter":21,"verse":29,"text":"모압아 ! 네가 화를 당하였도다 그모스의 백성아 ! 네가 멸망하였도다 그가 그 아들들로 도망케 하였고 그 딸들로 아모리인의 왕 시혼의 포로가 되게 하였도다","reference":"민수기 21:29","category":"$undefined"},{"id":"4371","book":"민수기","book_name":"민수기","chapter":21,"verse":30,"text":"우리가 그들을 쏘아서 헤스본을 디본까지 멸하였고 메드바에 가까운 노바까지 황폐케 하였도다 하였더라","reference":"민수기 21:30","category":"$undefined"},{"id":"4372","book":"민수기","book_name":"민수기","chapter":21,"verse":31,"text":"이스라엘이 아모리인의 땅에 거하였더니","reference":"민수기 21:31","category":"$undefined"},{"id":"4373","book":"민수기","book_name":"민수기","chapter":21,"verse":32,"text":"모세가 또 보내어 야셀을 정탐케 하고 그 촌락들을 취하고 그 곳에 있던 아모리인을 몰아 내었더라","reference":"민수기 21:32","category":"$undefined"},{"id":"4374","book":"민수기","book_name":"민수기","chapter":21,"verse":33,"text":"돌이켜 바산 길로 올라가매 바산 왕 옥이 그 백성을 다 거느리고 나와서 그들을 맞아 에드레이에서 싸우려 하는지라","reference":"민수기 21:33","category":"$undefined"},{"id":"4375","book":"민수기","book_name":"민수기","chapter":21,"verse":34,"text":"여호와께서 모세에게 이르시되 그를 두려워 말라 ! 내가 그와 그 백성과 그 땅을 네 손에 붙였나니 너는 헤스본에 거하던 아모리인의 왕 시혼에게 행한 것같이 그에게도 행할지니라","reference":"민수기 21:34","category":"$undefined"},{"id":"4376","book":"민수기","book_name":"민수기","chapter":21,"verse":35,"text":"이에 그와 그 아들들과 그 백성을 다 쳐서 한 사람도 남기지 아니하고 그 땅을 점령하였더라","reference":"민수기 21:35","category":"$undefined"}],"bookSlug":"numbers"}]
