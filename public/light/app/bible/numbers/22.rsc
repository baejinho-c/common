2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":22,"verses":[{"id":"4377","book":"민수기","book_name":"민수기","chapter":22,"verse":1,"text":"이스라엘 자손이 또 진행하여 모압 평지에 진 쳤으니 요단 건너편 곧 여리고 맞은편이더라","reference":"민수기 22:1","category":"$undefined"},{"id":"4378","book":"민수기","book_name":"민수기","chapter":22,"verse":2,"text":"십볼의 아들 발락이 이스라엘이 아모리인에게 행한 모든 일을 보았으므로","reference":"민수기 22:2","category":"$undefined"},{"id":"4379","book":"민수기","book_name":"민수기","chapter":22,"verse":3,"text":"모압이 심히 두려워하였으니 이스라엘 백성의 많음을 인함이라 모압이 이스라엘 자손의 연고로 번민하여","reference":"민수기 22:3","category":"$undefined"},{"id":"4380","book":"민수기","book_name":"민수기","chapter":22,"verse":4,"text":"미디안 장로들에게 이르되 이제 이 무리가 소가 밭의 풀을 뜯어 먹음 같이 우리 사면에 있는 것을 다 뜯어 먹으리로다 하니 때에 십볼의 아들 발락이 모압 왕이었더라","reference":"민수기 22:4","category":"$undefined"},{"id":"4381","book":"민수기","book_name":"민수기","chapter":22,"verse":5,"text":"그가 사자를 브올의 아들 발람의 본향 강변 브돌에 보내어 발람을 부르게 하여 가로되 `보라, 한 민족이 애굽에서 나왔는데 그들이 지면에 덮여서 우리 맞은 편에 거하였고","reference":"민수기 22:5","category":"$undefined"},{"id":"4382","book":"민수기","book_name":"민수기","chapter":22,"verse":6,"text":"우리보다 강하니 청컨대 와서 나를 위하여 이 백성을 저주하라 내가 혹 쳐서 이기어 이 땅에서 몰아내리라 그대가 복을 비는 자는 복을 받고 저주하는 자는 저주를 받을 줄을 내가 앎이니라'","reference":"민수기 22:6","category":"$undefined"},{"id":"4383","book":"민수기","book_name":"민수기","chapter":22,"verse":7,"text":"모압 장로들과 미디안 장로들이 손에 복술의 예물을 가지고 떠나 발람에게 이르러 발락의 말로 그에게 고하매","reference":"민수기 22:7","category":"$undefined"},{"id":"4384","book":"민수기","book_name":"민수기","chapter":22,"verse":8,"text":"발람이 그들에게 이르되 `이 밤에 여기서 유숙하라 여호와께서 내게 이르시는 대로 너희에게 대답하리라' 모압 귀족들이 발람에게서 유하니라","reference":"민수기 22:8","category":"$undefined"},{"id":"4385","book":"민수기","book_name":"민수기","chapter":22,"verse":9,"text":"하나님이 발람에게 임하여 가라사대 너와 함께 한 이 사람들이 누구냐 ?","reference":"민수기 22:9","category":"$undefined"},{"id":"4386","book":"민수기","book_name":"민수기","chapter":22,"verse":10,"text":"발람이 하나님께 고하되 `모압 왕 십볼의 아들 발락이 내게 보낸 자라 이르기를","reference":"민수기 22:10","category":"$undefined"},{"id":"4387","book":"민수기","book_name":"민수기","chapter":22,"verse":11,"text":"보라 애굽에서 나온 민족이 있어 지면에 덮였으니 이제 와서 나를 위하여 그들을 저주하라 내가 혹 그들을 쳐서 몰아 낼 수 있으리라 하나이다'","reference":"민수기 22:11","category":"$undefined"},{"id":"4388","book":"민수기","book_name":"민수기","chapter":22,"verse":12,"text":"하나님이 발람에게 이르시되 너는 그들과 함께 가지도 말고 그 백성을 저주하지도 말라 그들은 복을 받은 자니라 !","reference":"민수기 22:12","category":"$undefined"},{"id":"4389","book":"민수기","book_name":"민수기","chapter":22,"verse":13,"text":"발람이 아침에 일어나서 발락의 귀족들에게 이르되 `너희는 너희 땅으로 돌아가라 내가 너희와 함께 가기를 여호와께서 허락지 아니하시느니라'","reference":"민수기 22:13","category":"$undefined"},{"id":"4390","book":"민수기","book_name":"민수기","chapter":22,"verse":14,"text":"모압 귀족들이 일어나 발락에게로 가서 고하되 `발람이 우리와 함께 오기를 거절하더이다'","reference":"민수기 22:14","category":"$undefined"},{"id":"4391","book":"민수기","book_name":"민수기","chapter":22,"verse":15,"text":"발락이 다시 그들보다 더 높은 귀족들을 더 많이 보내매","reference":"민수기 22:15","category":"$undefined"},{"id":"4392","book":"민수기","book_name":"민수기","chapter":22,"verse":16,"text":"그들이 발람에게로 나아가서 그에게 이르되 `십볼의 아들 발락의 말씀에 청컨대 아무것에도 거리끼지 말고 내게로 오라","reference":"민수기 22:16","category":"$undefined"},{"id":"4393","book":"민수기","book_name":"민수기","chapter":22,"verse":17,"text":"내가 그대를 높여 크게 존귀케 하고 그대가 내게 말하는 것은 무엇이든지 시행하리니 청컨대 와서 나를 위하여 이 백성을 저주하라 하시더이다'","reference":"민수기 22:17","category":"$undefined"},{"id":"4394","book":"민수기","book_name":"민수기","chapter":22,"verse":18,"text":"발람이 발락의 신하들에게 대답하여 가로되 `발락이 그 집에 은,금을 가득히 채워서 내게 줄지라도 내가 능히 여호와 내 하나님의 말씀을 어기어 덜하거나 더하지 못하겠노라","reference":"민수기 22:18","category":"$undefined"},{"id":"4395","book":"민수기","book_name":"민수기","chapter":22,"verse":19,"text":"그런즉 이제 너희도 이 밤에 여기서 유하라 여호와께서 내게 무슨 말씀을 더하실는지 알아 보리라","reference":"민수기 22:19","category":"$undefined"},{"id":"4396","book":"민수기","book_name":"민수기","chapter":22,"verse":20,"text":"밤에 하나님이 발람에게 임하여 이르시되 그 사람들이 너를 부르러 왔거든 일어나 함께 가라 그러나 내가 네게 이르는 말만 준행할지니라'","reference":"민수기 22:20","category":"$undefined"},{"id":"4397","book":"민수기","book_name":"민수기","chapter":22,"verse":21,"text":"발람이 아침에 일어나서 자기 나귀에 안장을 지우고 모압 귀족들과 함께 행하니","reference":"민수기 22:21","category":"$undefined"},{"id":"4398","book":"민수기","book_name":"민수기","chapter":22,"verse":22,"text":"그가 행함을 인하여 하나님이 진노하심으로 여호와의 사자가 그를 막으려고 길에 서니라 발람은 자기 나귀를 타고 그 두 종은 그와 함께 있더니","reference":"민수기 22:22","category":"$undefined"},{"id":"4399","book":"민수기","book_name":"민수기","chapter":22,"verse":23,"text":"나귀가 여호와의 사자가 칼을 빼어 손에 들고 길에 선 것을 보고 길에서 떠나 밭으로 들어간지라 발람이 나귀를 길로 돌이키려고 채찍질하니","reference":"민수기 22:23","category":"$undefined"},{"id":"4400","book":"민수기","book_name":"민수기","chapter":22,"verse":24,"text":"여호와의 사자는 포도원 사이 좁은 길에 섰고 좌우에는 담이 있더라","reference":"민수기 22:24","category":"$undefined"},{"id":"4401","book":"민수기","book_name":"민수기","chapter":22,"verse":25,"text":"나귀가 여호와의 사자를 보고 몸을 담에 대고 발람의 발을 그 담에 비비어 상하게 하매 발람이 다시 채찍질하니","reference":"민수기 22:25","category":"$undefined"},{"id":"4402","book":"민수기","book_name":"민수기","chapter":22,"verse":26,"text":"여호와의 사자가 더 나아가서 좌우로 피할 데 없는 좁은 곳에 선지라","reference":"민수기 22:26","category":"$undefined"},{"id":"4403","book":"민수기","book_name":"민수기","chapter":22,"verse":27,"text":"나귀가 여호와의 사자를 보고 발람의 밑에 엎드리니 발람이 노하여 자기 지팡이로 나귀를 때리는지라","reference":"민수기 22:27","category":"$undefined"},{"id":"4404","book":"민수기","book_name":"민수기","chapter":22,"verse":28,"text":"여호와께서 나귀 입을 여시니 발람에게 이르되 `내가 네게 무엇을 하였기에 나를 이같이 세 번을 때리느뇨 ?'","reference":"민수기 22:28","category":"$undefined"},{"id":"4405","book":"민수기","book_name":"민수기","chapter":22,"verse":29,"text":"발람이 나귀에게 말하되 `네가 나를 거역하는 연고니 내 손에 칼이 있었더면 곧 너를 죽였으리라'","reference":"민수기 22:29","category":"$undefined"},{"id":"4406","book":"민수기","book_name":"민수기","chapter":22,"verse":30,"text":"나귀가 발람에게 이르되 나는 네가 오늘까지 네 일생에 타는 나귀가 아니냐 내가 언제든지 네게 이같이 하는 행습이 있더냐 가로되 없었느니라","reference":"민수기 22:30","category":"$undefined"},{"id":"4407","book":"민수기","book_name":"민수기","chapter":22,"verse":31,"text":"때에 여호와께서 발람의 눈을 밝히시매 여호와의 사자가 손에 칼을 빼어 들고 길에 선 것을 보고 머리를 숙이고 엎드리니","reference":"민수기 22:31","category":"$undefined"},{"id":"4408","book":"민수기","book_name":"민수기","chapter":22,"verse":32,"text":"여호와의 사자가 그에게 이르되 `너는 어찌하여 네 나귀를 이같이 세번 때렸느냐 ? 보라, 네 길이 내 앞에 패역하므로 내가 너를 막으려고 나왔더니","reference":"민수기 22:32","category":"$undefined"},{"id":"4409","book":"민수기","book_name":"민수기","chapter":22,"verse":33,"text":"나귀가 나를 보고 이같이 세번을 돌이켜 내 앞에서 피하였느니라 나귀가 만일 돌이켜 나를 피하지 아니하였더면 내가 벌써 너를 죽이고 나귀는 살렸으리라'","reference":"민수기 22:33","category":"$undefined"},{"id":"4410","book":"민수기","book_name":"민수기","chapter":22,"verse":34,"text":"발람이 여호와의 사자에게 말씀하되 `내가 범죄하였나이다 당신이 나를 막으려고 길에 서신 줄을 내가 알지 못하였나이다 당신이 이를 기뻐하지 아니하시면 나는 돌아가겠나이다'","reference":"민수기 22:34","category":"$undefined"},{"id":"4411","book":"민수기","book_name":"민수기","chapter":22,"verse":35,"text":"여호와의 사자가 발람에게 이르되 `그 사람들과 함께 가라 내가 네게 이르는 말만 말할지니라' 발람이 발락의 귀족들과 함께 가니라","reference":"민수기 22:35","category":"$undefined"},{"id":"4412","book":"민수기","book_name":"민수기","chapter":22,"verse":36,"text":"발락이 발람의 온다 함을 듣고 모압 변경의 끝 아르논 가에 있는 성읍까지 가서 그를 영접하고","reference":"민수기 22:36","category":"$undefined"},{"id":"4413","book":"민수기","book_name":"민수기","chapter":22,"verse":37,"text":"발락이 발람에게 이르되 `내가 특별히 보내어 그대를 부르지 아니하였느냐 ? 그대가 어찌 내게 오지 아니하였느냐 ? 내가 어찌 그대를 높여 존귀케 하지 못하겠느냐 ?'","reference":"민수기 22:37","category":"$undefined"},{"id":"4414","book":"민수기","book_name":"민수기","chapter":22,"verse":38,"text":"발람이 발락에게 이르되 `내가 오기는 하였으나 무엇을 임의로 말할 수 있으리이까 ? 하나님이 내 입에 주시는 말씀 그것을 말할 뿐이니이다'","reference":"민수기 22:38","category":"$undefined"},{"id":"4415","book":"민수기","book_name":"민수기","chapter":22,"verse":39,"text":"발람이 발락과 동행하여 기럇후솟에 이르러서는","reference":"민수기 22:39","category":"$undefined"},{"id":"4416","book":"민수기","book_name":"민수기","chapter":22,"verse":40,"text":"발락이 우양을 잡아 발람과 그와 함께 한 귀족을 대접하였더라","reference":"민수기 22:40","category":"$undefined"},{"id":"4417","book":"민수기","book_name":"민수기","chapter":22,"verse":41,"text":"아침에 발락이 발람과 함께 하고 그를 인도하여 바알의 산당에 오르매 발람이 거기서 이스라엘 백성의 진 끝까지 보니라","reference":"민수기 22:41","category":"$undefined"}],"bookSlug":"numbers"}]
