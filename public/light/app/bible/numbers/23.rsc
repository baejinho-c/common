2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":23,"verses":[{"id":"4418","book":"민수기","book_name":"민수기","chapter":23,"verse":1,"text":"발람이 발락에게 이르되 `나를 위하여 여기 일곱 단을 쌓고 거기 수송아지 일곱과 수양 일곱을 준비하소서'하매","reference":"민수기 23:1","category":"$undefined"},{"id":"4419","book":"민수기","book_name":"민수기","chapter":23,"verse":2,"text":"발락이 발람의 말대로 준비한 후에 발락과 발람이 매 단에 수송아지 하나와 수양 하나를 드리니라","reference":"민수기 23:2","category":"$undefined"},{"id":"4420","book":"민수기","book_name":"민수기","chapter":23,"verse":3,"text":"발람이 발락에게 이르되 `당신의 번제물 곁에 서소서 나는 저리로 갈지라 여호와께서 혹시 오셔서 나를 만나시리니 그가 내게 지시하시는 것은 다 당신에게 고하리이다'하고 사태난 산에 이른즉","reference":"민수기 23:3","category":"$undefined"},{"id":"4421","book":"민수기","book_name":"민수기","chapter":23,"verse":4,"text":"하나님이 발람에게 임하시는지라 발람이 고하되 `내가 일곱단을 베풀고 매단에 수송아지 하나와 수양 하나를 드렸나이다'","reference":"민수기 23:4","category":"$undefined"},{"id":"4422","book":"민수기","book_name":"민수기","chapter":23,"verse":5,"text":"여호와께서 발람의 입에 말씀을 주어 가라사대 발락에게 돌아가서 이렇게 말할지어다","reference":"민수기 23:5","category":"$undefined"},{"id":"4423","book":"민수기","book_name":"민수기","chapter":23,"verse":6,"text":"그가 발락에게 돌아간즉 발락과 모압 모든 귀족이 번제물 곁에 함께 섰더라","reference":"민수기 23:6","category":"$undefined"},{"id":"4424","book":"민수기","book_name":"민수기","chapter":23,"verse":7,"text":"발람이 노래를 지어 가로되 발락이 나를 아람에서, 모압 왕이 동편 산에서 데려다가 이르기를 와서 나를 위하여 야곱을 저주하라, 와서 이스라엘을 꾸짖으라 하도다","reference":"민수기 23:7","category":"$undefined"},{"id":"4425","book":"민수기","book_name":"민수기","chapter":23,"verse":8,"text":"하나님이 저주치 않으신 자를 내 어찌 저주하며 여호와께서 꾸짖지 않으신 자를 내 어찌 꾸짖을꼬","reference":"민수기 23:8","category":"$undefined"},{"id":"4426","book":"민수기","book_name":"민수기","chapter":23,"verse":9,"text":"내가 바위 위에서 그들을 보며 작은 산에서 그들을 바라보니 이 백성은 홀로 처할 것이라 그를 열방 중의 하나로 여기지 않으리로다","reference":"민수기 23:9","category":"$undefined"},{"id":"4427","book":"민수기","book_name":"민수기","chapter":23,"verse":10,"text":"야곱의 티끌을 뉘 능히 계산하며 이스라엘 사분지 일을 뉘 능히 계수 할꼬 나는 의인의 죽음같이 죽기를 원하며 나의 종말이 그와 같기를 바라도다 하매","reference":"민수기 23:10","category":"$undefined"},{"id":"4428","book":"민수기","book_name":"민수기","chapter":23,"verse":11,"text":"발락이 발람에게 이르되 `그대가 어찌 내게 이같이 행하느냐 ? 나의 원수를 저주하라고 그대를 데려 왔거늘 그대가 온전히 축복하였도다'","reference":"민수기 23:11","category":"$undefined"},{"id":"4429","book":"민수기","book_name":"민수기","chapter":23,"verse":12,"text":"대답하여 가로되 `여호와께서 내 입에 주신 말씀을 내가 어찌 말하지 아니할 수 있으리이까 ?'","reference":"민수기 23:12","category":"$undefined"},{"id":"4430","book":"민수기","book_name":"민수기","chapter":23,"verse":13,"text":"발락이 가로되 `나와 함께 그들을 달리 볼 곳으로 가자 거기서는 그들을 다 보지 못하고 그 끝만 보리니 거기서 나를 위하여 그들을 저주하라'하고","reference":"민수기 23:13","category":"$undefined"},{"id":"4431","book":"민수기","book_name":"민수기","chapter":23,"verse":14,"text":"소빔 들로 인도하여 비스가 꼭대기에 이르러 일곱 단을 쌓고 매 단에 수송아지 하나와 수양 하나를 드리니","reference":"민수기 23:14","category":"$undefined"},{"id":"4432","book":"민수기","book_name":"민수기","chapter":23,"verse":15,"text":"발람이 발락에게 이르되 `내가 저기서 여호와를 만날 동안에 여기 당신의 번제물 곁에 서소서'하니라","reference":"민수기 23:15","category":"$undefined"},{"id":"4433","book":"민수기","book_name":"민수기","chapter":23,"verse":16,"text":"여호와께서 발람에게 임하사 그 입에 말씀을 주어 가라사대 발락에게로 돌아가서 이렇게 말할지니라","reference":"민수기 23:16","category":"$undefined"},{"id":"4434","book":"민수기","book_name":"민수기","chapter":23,"verse":17,"text":"발람이 와서 본즉 발락이 번제물 곁에 섰고 모압 귀족들이 함께 있더라 발락이 발람에게 이르되 '여호와께서 무슨 말씀을 하시더냐 ?'","reference":"민수기 23:17","category":"$undefined"},{"id":"4435","book":"민수기","book_name":"민수기","chapter":23,"verse":18,"text":"발람이 노래를 지어 가로되 `발락이여 ! 일어나 들을지어다 십볼의 아들이여 ! 나를 자세히 들으라","reference":"민수기 23:18","category":"$undefined"},{"id":"4436","book":"민수기","book_name":"민수기","chapter":23,"verse":19,"text":"하나님은 인생이 아니시니 식언치 않으시고 인자가 아니시니 후회가 없으시도다 어찌 그 말씀하신 바를 행치 않으시며 하신 말씀을 실행치 않으시랴","reference":"민수기 23:19","category":"$undefined"},{"id":"4437","book":"민수기","book_name":"민수기","chapter":23,"verse":20,"text":"내가 축복의 명을 받았으니 그가 하신 축복을 내가 돌이킬 수 없도다","reference":"민수기 23:20","category":"$undefined"},{"id":"4438","book":"민수기","book_name":"민수기","chapter":23,"verse":21,"text":"여호와는 야곱의 허물을 보지 아니하시며 이스라엘의 패역을 보지 아니하시는도다 여호와 그의 하나님이 그와 함께 계시니 왕을 부르는 소리가 그 중에 있도다","reference":"민수기 23:21","category":"$undefined"},{"id":"4439","book":"민수기","book_name":"민수기","chapter":23,"verse":22,"text":"하나님이 그들을 애굽에서 인도하여 내셨으니 그 힘이 들소와 같도다","reference":"민수기 23:22","category":"$undefined"},{"id":"4440","book":"민수기","book_name":"민수기","chapter":23,"verse":23,"text":"야곱을 해할 사술이 없고 이스라엘을 해할 복술이 없도다 이 때에 야곱과 이스라엘에 대하여 논할진대 하나님의 행하신 일이 어찌 그리 크뇨 하리로다","reference":"민수기 23:23","category":"$undefined"},{"id":"4441","book":"민수기","book_name":"민수기","chapter":23,"verse":24,"text":"백성이 암사자 같이 일어나고 수사자 같이 일어나서 움킨 것을 먹으며 죽인 피를 마시기 전에는 눕지 아니하리로다 하매","reference":"민수기 23:24","category":"$undefined"},{"id":"4442","book":"민수기","book_name":"민수기","chapter":23,"verse":25,"text":"발락이 발람에게 이르되 `그들을 저주하지도 말고 축복하지도 말라'","reference":"민수기 23:25","category":"$undefined"},{"id":"4443","book":"민수기","book_name":"민수기","chapter":23,"verse":26,"text":"발람이 발락에게 대답하여 가로되 `내가 당신에게 고하여 이르기를 여호와께서 말씀하신 것은 내가 그대로 하지 않을 수 없다고 하지 아니하더이까 ?'","reference":"민수기 23:26","category":"$undefined"},{"id":"4444","book":"민수기","book_name":"민수기","chapter":23,"verse":27,"text":"발락이 발람에게 또 이르되 오라 내가 너를 다른 곳으로 인도하리니 네가 거기서 나를 위하여 그들을 저주하기를 하나님이 혹시 기뻐하시리라 하고","reference":"민수기 23:27","category":"$undefined"},{"id":"4445","book":"민수기","book_name":"민수기","chapter":23,"verse":28,"text":"발락이 발람을 인도하여 광야가 내려다 보이는 브올산 꼭대기에 이르니","reference":"민수기 23:28","category":"$undefined"},{"id":"4446","book":"민수기","book_name":"민수기","chapter":23,"verse":29,"text":"발람이 발락에게 이르되 `나를 위하여 여기 일곱 단을 쌓고 거기 수송아지 일곱과 수양 일곱을 준비하소서'","reference":"민수기 23:29","category":"$undefined"},{"id":"4447","book":"민수기","book_name":"민수기","chapter":23,"verse":30,"text":"발락이 발람의 말대로 행하여 매 단에 수송아지 하나와 수양 하나를 드리니라","reference":"민수기 23:30","category":"$undefined"}],"bookSlug":"numbers"}]
