2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":24,"verses":[{"id":"4448","book":"민수기","book_name":"민수기","chapter":24,"verse":1,"text":"발람이 자기와 이스라엘을 축복하는 것을 여호와께서 선히 여기심을 보고 전과 같이 사술을 쓰지 아니하고 그 낯을 광야로 향하여","reference":"민수기 24:1","category":"$undefined"},{"id":"4449","book":"민수기","book_name":"민수기","chapter":24,"verse":2,"text":"눈을 들어 이스라엘이 그 지파대로 거하는 것을 보는 동시에 하나님의 신이 그 위에 임하신지라","reference":"민수기 24:2","category":"$undefined"},{"id":"4450","book":"민수기","book_name":"민수기","chapter":24,"verse":3,"text":"그가 노래를 지어 가로되 브올의 아들 발람이 말하며 눈을 감았던 자가 말하며","reference":"민수기 24:3","category":"$undefined"},{"id":"4451","book":"민수기","book_name":"민수기","chapter":24,"verse":4,"text":"하나님의 말씀을 듣는 자, 전능자의 이상을 보는 자, 엎드려서 눈을 뜬 자가 말하기를","reference":"민수기 24:4","category":"$undefined"},{"id":"4452","book":"민수기","book_name":"민수기","chapter":24,"verse":5,"text":"야곱이여 ! 네 장막이, 이스라엘이여 ! 네 거처가 어찌 그리 아름다운고","reference":"민수기 24:5","category":"$undefined"},{"id":"4453","book":"민수기","book_name":"민수기","chapter":24,"verse":6,"text":"그 벌어짐이 골짜기 같고 강 가의 동산 같으며 여호와의 심으신 침향목들 같고 물가의 백향목들 같도다","reference":"민수기 24:6","category":"$undefined"},{"id":"4454","book":"민수기","book_name":"민수기","chapter":24,"verse":7,"text":"그 통에서는 물이 넘치겠고 그 종자는 많은 물가에 있으리로다 그 왕이 아각보다 높으니 그 나라가 진흥하리로다","reference":"민수기 24:7","category":"$undefined"},{"id":"4455","book":"민수기","book_name":"민수기","chapter":24,"verse":8,"text":"하나님이 그를 애굽에서 인도하여 내셨으니 그 힘이 들소와 같도다 그 적국을 삼키고 그들의 뼈를 꺽으며 화살로 쏘아 꿰뚫으리로다","reference":"민수기 24:8","category":"$undefined"},{"id":"4456","book":"민수기","book_name":"민수기","chapter":24,"verse":9,"text":"꿇어 앉고 누움이 수사자와 같고 암사자와도 같으니 일으킨 자 누구이랴 너를 축복하는 자마다 복을 받을 것이요 너를 저주하는 자마다 저주를 받을지어다 !","reference":"민수기 24:9","category":"$undefined"},{"id":"4457","book":"민수기","book_name":"민수기","chapter":24,"verse":10,"text":"발락이 발람에게 노하여 손뼉을 치며 발람에게 말하되 `내가 그대를 부른 것은 내 원수를 저주하라 함이어늘 그대가 이같이 세번 그들을 축복하였도다","reference":"민수기 24:10","category":"$undefined"},{"id":"4458","book":"민수기","book_name":"민수기","chapter":24,"verse":11,"text":"그러므로 그대는 이제 그대의 곳으로 달려가라 내가 그대를 높여 심히 존귀케 하기로 뜻하였더니 여호와가 그대를 막아 존귀치 못하게 하셨도다'","reference":"민수기 24:11","category":"$undefined"},{"id":"4459","book":"민수기","book_name":"민수기","chapter":24,"verse":12,"text":"발람이 발락에게 이르되 `당신이 내게 보낸 사자들에게 내가 고하여 이르지 아니하였나이까 ?","reference":"민수기 24:12","category":"$undefined"},{"id":"4460","book":"민수기","book_name":"민수기","chapter":24,"verse":13,"text":"가령 발락이 그 집에 은,금을 가득히 채워서 내게 줄지라도 나는 여호와의 말씀을 어기고 선악간 임의로 행하지 못하고 여호와께서 말씀하신 대로 말하리라 하지 아니하였나이까 ?","reference":"민수기 24:13","category":"$undefined"},{"id":"4461","book":"민수기","book_name":"민수기","chapter":24,"verse":14,"text":"이제 나는 내 백성에게로 돌아가거니와 들으소서 내가 이 백성이 후일에 당신의 백성에게 어떻게 할 것을 당신에게 고하리이다'하고","reference":"민수기 24:14","category":"$undefined"},{"id":"4462","book":"민수기","book_name":"민수기","chapter":24,"verse":15,"text":"노래를 지어 가로되 브올의 아들 발람이 말하며 눈을 감았던 자가 말하며","reference":"민수기 24:15","category":"$undefined"},{"id":"4463","book":"민수기","book_name":"민수기","chapter":24,"verse":16,"text":"하나님의 말씀을 듣는 자가 말하며 지극히 높으신 자의 지식을 아는 자, 전능자의 이상을 보는 자, 엎드려서 눈을 뜬 자가 말하기를","reference":"민수기 24:16","category":"$undefined"},{"id":"4464","book":"민수기","book_name":"민수기","chapter":24,"verse":17,"text":"내가 그를 보아도 이 때의 일이 아니며 내가 그를 바라보아도 가까운 일이 아니로다 한 별이 야곱에게서 나오며 한 홀이 이스라엘에게서 일어나서 모압을 이 편에서, 저 편까지 파하고 또 소동하는 자식들을 다 멸하리로다","reference":"민수기 24:17","category":"$undefined"},{"id":"4465","book":"민수기","book_name":"민수기","chapter":24,"verse":18,"text":"그 원수 에돔은 그들의 산업이 되며, 그 원수 세일도 그들의 산업이 되고 그 동시에 이스라엘은 용감히 행동하리로다","reference":"민수기 24:18","category":"$undefined"},{"id":"4466","book":"민수기","book_name":"민수기","chapter":24,"verse":19,"text":"주권자가 야곱에게서 나서 남은 자들을 그 성읍에서 멸절하리로다 하고","reference":"민수기 24:19","category":"$undefined"},{"id":"4467","book":"민수기","book_name":"민수기","chapter":24,"verse":20,"text":"또 아말렉을 바라보며 노래를 지어 가로되 아말렉은 열국 중 으뜸이나 종말은 멸망에 이르리로다 하고","reference":"민수기 24:20","category":"$undefined"},{"id":"4468","book":"민수기","book_name":"민수기","chapter":24,"verse":21,"text":"또 가인 족속을 바라보며 노래를 지어 가로되 너의 거처가 견고하니 네 보금자리는 바위에 있도다","reference":"민수기 24:21","category":"$undefined"},{"id":"4469","book":"민수기","book_name":"민수기","chapter":24,"verse":22,"text":"그러나 가인이 쇠미하리니 나중에는 앗수르의 포로가 되리로다 하고","reference":"민수기 24:22","category":"$undefined"},{"id":"4470","book":"민수기","book_name":"민수기","chapter":24,"verse":23,"text":"또 노래를 지어 가로되 슬프다 하나님이 이 일을 행하시리니 그 때에 살 자가 누구이랴 ?","reference":"민수기 24:23","category":"$undefined"},{"id":"4471","book":"민수기","book_name":"민수기","chapter":24,"verse":24,"text":"깃딤 해변에서 배들이 와서 앗수르를 학대하며 에벨을 괴롭게 하리라마는 그도 멸망하리로다 하고","reference":"민수기 24:24","category":"$undefined"},{"id":"4472","book":"민수기","book_name":"민수기","chapter":24,"verse":25,"text":"발람이 일어나 자기 곳으로 돌아갔고 발락도 자기 길로 갔더라","reference":"민수기 24:25","category":"$undefined"}],"bookSlug":"numbers"}]
