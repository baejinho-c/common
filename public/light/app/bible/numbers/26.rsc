2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":26,"verses":[{"id":"4491","book":"민수기","book_name":"민수기","chapter":26,"verse":1,"text":"염병 후에 여호와께서 모세와 제사장 아론의 아들 엘르아살에게 일러 가라사대","reference":"민수기 26:1","category":"$undefined"},{"id":"4492","book":"민수기","book_name":"민수기","chapter":26,"verse":2,"text":"이스라엘 자손의 온 회중의 총수를 그 조상의 집을 따라 조사하되 이스라엘 중에 무릇 이십세 이상으로 능히 싸움에 나갈 만한 자를 계수하라 하시니","reference":"민수기 26:2","category":"$undefined"},{"id":"4493","book":"민수기","book_name":"민수기","chapter":26,"verse":3,"text":"모세와 제사장 엘르아살이 여리고 맞은편 요단 가 모압 평지에서 그들에게 고하여 가로되","reference":"민수기 26:3","category":"$undefined"},{"id":"4494","book":"민수기","book_name":"민수기","chapter":26,"verse":4,"text":"`여호와께서 애굽 땅에서 나온 모세와 이스라엘 자손에게 명하신대로 너희는 이십세 이상된 자를 계수하라' 하시니","reference":"민수기 26:4","category":"$undefined"},{"id":"4495","book":"민수기","book_name":"민수기","chapter":26,"verse":5,"text":"이스라엘의 장자는 르우벤이라 르우벤 자손은 하녹에게서 난 하녹 가족과, 발루에게서 난 발루 가족과","reference":"민수기 26:5","category":"$undefined"},{"id":"4496","book":"민수기","book_name":"민수기","chapter":26,"verse":6,"text":"헤스론에게서 난 헤스론 가족과, 갈미에게서 난 갈미 가족이니","reference":"민수기 26:6","category":"$undefined"},{"id":"4497","book":"민수기","book_name":"민수기","chapter":26,"verse":7,"text":"이는 르우벤 가족들이라 계수함을 입은 자가 사만 삼천 칠백 삼십명이요","reference":"민수기 26:7","category":"$undefined"},{"id":"4498","book":"민수기","book_name":"민수기","chapter":26,"verse":8,"text":"발루의 아들은 엘리압이요","reference":"민수기 26:8","category":"$undefined"},{"id":"4499","book":"민수기","book_name":"민수기","chapter":26,"verse":9,"text":"엘리압의 아들은 느무엘과, 다단과, 아비람이라 이 다단과, 아비람은 회중 가운데서 부름을 받은 자러니 고라의 무리에 들어가서 모세와 아론을 거스려 여호와께 패역할 때에","reference":"민수기 26:9","category":"$undefined"},{"id":"4500","book":"민수기","book_name":"민수기","chapter":26,"verse":10,"text":"땅이 그 입을 열어서 그 무리와 고라를 삼키매 그들이 죽었고 당시에 불이 이백 오십명을 삼켜 징계가 되게 하였으나","reference":"민수기 26:10","category":"$undefined"},{"id":"4501","book":"민수기","book_name":"민수기","chapter":26,"verse":11,"text":"그러나 고라의 아들들은 죽지 아니하였더라","reference":"민수기 26:11","category":"$undefined"},{"id":"4502","book":"민수기","book_name":"민수기","chapter":26,"verse":12,"text":"시므온 자손은 그 종족대로 이러하니 느무엘에게서 난 느무엘 가족과, 야민에게서 난 야민 가족과, 야긴에게서 난 야긴 가족과","reference":"민수기 26:12","category":"$undefined"},{"id":"4503","book":"민수기","book_name":"민수기","chapter":26,"verse":13,"text":"세라에게서 난 세라 가족과, 사울에게서 난 사울 가족이라","reference":"민수기 26:13","category":"$undefined"},{"id":"4504","book":"민수기","book_name":"민수기","chapter":26,"verse":14,"text":"이는 시므온 종족들이니 계수함을 입은 자가 이만 이천 이백명이었더라","reference":"민수기 26:14","category":"$undefined"},{"id":"4505","book":"민수기","book_name":"민수기","chapter":26,"verse":15,"text":"갓 자손은 그 종족대로 이러하니 스본에게서 난 스본 가족과, 학기에게서 난 학기 가족과, 수니에게서 난 수니 가족과","reference":"민수기 26:15","category":"$undefined"},{"id":"4506","book":"민수기","book_name":"민수기","chapter":26,"verse":16,"text":"오스니에게서 난 오스니 가족과, 에리에게서 난 에리 가족과","reference":"민수기 26:16","category":"$undefined"},{"id":"4507","book":"민수기","book_name":"민수기","chapter":26,"verse":17,"text":"아롯에게서 난 아롯 가족과, 아렐리에게서 난 아렐리 가족이라","reference":"민수기 26:17","category":"$undefined"},{"id":"4508","book":"민수기","book_name":"민수기","chapter":26,"verse":18,"text":"이는 갓 자손의 종족들이니 계수함을 입은 자가 사만 오백명이었더라","reference":"민수기 26:18","category":"$undefined"},{"id":"4509","book":"민수기","book_name":"민수기","chapter":26,"verse":19,"text":"유다의 아들은 에르와, 오난이라 이 에르와 오난은 가나안 땅에서 죽었고","reference":"민수기 26:19","category":"$undefined"},{"id":"4510","book":"민수기","book_name":"민수기","chapter":26,"verse":20,"text":"유다의 자손은 그 종족대로 이러하니 셀라에게서 난 셀라 가족과, 베레스에게서 난 베레스 가족과, 세라에게서 난 세라 가족이며","reference":"민수기 26:20","category":"$undefined"},{"id":"4511","book":"민수기","book_name":"민수기","chapter":26,"verse":21,"text":"또 베레스 자손은 이러하니 헤스론에게서 난 헤스론 가족과, 하물에게서 난 하물 가족이라","reference":"민수기 26:21","category":"$undefined"},{"id":"4512","book":"민수기","book_name":"민수기","chapter":26,"verse":22,"text":"이는 유다 종족들이니 계수함을 입은 자가 칠만 육천 오백명이었더라","reference":"민수기 26:22","category":"$undefined"},{"id":"4513","book":"민수기","book_name":"민수기","chapter":26,"verse":23,"text":"잇사갈 자손은 그 종족대로 이러하니 돌라에게서 난 돌라 가족과, 부와에게서 난 부니 가족과","reference":"민수기 26:23","category":"$undefined"},{"id":"4514","book":"민수기","book_name":"민수기","chapter":26,"verse":24,"text":"야숩에게서 난 야숩 가족과 시므론에게서 난 시므론 가족이라","reference":"민수기 26:24","category":"$undefined"},{"id":"4515","book":"민수기","book_name":"민수기","chapter":26,"verse":25,"text":"이는 잇사갈 종족들이니 계수함을 입은 자가 육만 사천 삼백명이었더라","reference":"민수기 26:25","category":"$undefined"},{"id":"4516","book":"민수기","book_name":"민수기","chapter":26,"verse":26,"text":"스불론 자손들은 그 종족대로 이러하니 세렛에게서 난 세렛 가족과, 엘론에게서 난 엘론 가족과, 얄르엘에게서 난 얄르엘 가족이라","reference":"민수기 26:26","category":"$undefined"},{"id":"4517","book":"민수기","book_name":"민수기","chapter":26,"verse":27,"text":"이는 스불론 종족들이니 계수함을 입은 자가 육만 오백명이었더라","reference":"민수기 26:27","category":"$undefined"},{"id":"4518","book":"민수기","book_name":"민수기","chapter":26,"verse":28,"text":"요셉의 아들들은 그 종족대로 므낫세와 에브라임이요","reference":"민수기 26:28","category":"$undefined"},{"id":"4519","book":"민수기","book_name":"민수기","chapter":26,"verse":29,"text":"므낫세의 자손 중 마길에게서 난 것은 마길 가족이라 마길이 길르앗을 낳았고 길르앗에게서 난 것은 길르앗 가족이라","reference":"민수기 26:29","category":"$undefined"},{"id":"4520","book":"민수기","book_name":"민수기","chapter":26,"verse":30,"text":"길르앗 자손은 이러하니 이에셀에게서 난 이에셀 가족과, 헬렉에게서 난 헬렉 가족과","reference":"민수기 26:30","category":"$undefined"},{"id":"4521","book":"민수기","book_name":"민수기","chapter":26,"verse":31,"text":"아스리엘에게서 난 아스리엘 가족과, 세겜에게서 난 세겜 가족과","reference":"민수기 26:31","category":"$undefined"},{"id":"4522","book":"민수기","book_name":"민수기","chapter":26,"verse":32,"text":"스미다에게서 난 스미다 가족과, 헤벨에게서 난 헤벨 가족이며","reference":"민수기 26:32","category":"$undefined"},{"id":"4523","book":"민수기","book_name":"민수기","chapter":26,"verse":33,"text":"헤벨의 아들 슬로브핫은 아들이 없고 딸 뿐이라 그 딸의 이름은 말라와, 노아와, 호글라와, 밀가와, 디르사니","reference":"민수기 26:33","category":"$undefined"},{"id":"4524","book":"민수기","book_name":"민수기","chapter":26,"verse":34,"text":"이는 므낫세의 종족들이라 계수함을 입은 자가 오만 이천 칠백명이었더라","reference":"민수기 26:34","category":"$undefined"},{"id":"4525","book":"민수기","book_name":"민수기","chapter":26,"verse":35,"text":"에브라임 자손은 그 종족대로 이러하니 수델라에게서 난 수델라 가족과, 베겔에게서 난 베겔 가족과, 다한에게서 난 다한 가족이며","reference":"민수기 26:35","category":"$undefined"},{"id":"4526","book":"민수기","book_name":"민수기","chapter":26,"verse":36,"text":"수델라 자손은 이러하니 에란에게서 난 에란 가족이라","reference":"민수기 26:36","category":"$undefined"},{"id":"4527","book":"민수기","book_name":"민수기","chapter":26,"verse":37,"text":"이는 에브라임 자손의 종족들이니 계수함을 입은 자가 삼만 이천 오백명이라 이상은 그 종족을 따른 요셉 자손이었더라","reference":"민수기 26:37","category":"$undefined"},{"id":"4528","book":"민수기","book_name":"민수기","chapter":26,"verse":38,"text":"베냐민 자손들은 그 종족대로 이러하니 벨라에게서 난 벨라 가족과, 아스벨에게서 난 아스벨 가족과, 아히람에게서 난 아히람 가족과","reference":"민수기 26:38","category":"$undefined"},{"id":"4529","book":"민수기","book_name":"민수기","chapter":26,"verse":39,"text":"스부밤에게서 난 스부밤 가족과, 후밤에게서 난 후밤 가족이며","reference":"민수기 26:39","category":"$undefined"},{"id":"4530","book":"민수기","book_name":"민수기","chapter":26,"verse":40,"text":"벨라의 아들은 아릇과, 나아만이라 아릇에게서 아릇 가족과, 나아만에게서 나아만 가족이 났으니","reference":"민수기 26:40","category":"$undefined"},{"id":"4531","book":"민수기","book_name":"민수기","chapter":26,"verse":41,"text":"이는 그들의 종족을 따른 베냐민 자손이라 계수함을 입은 자가 사만 오천 육백명이었더라","reference":"민수기 26:41","category":"$undefined"},{"id":"4532","book":"민수기","book_name":"민수기","chapter":26,"verse":42,"text":"단 자손은 그 종족대로 이러하니라 수함에게서 수함 가족이 났으니 이는 그들의 종족을 따른 단 가족들이라","reference":"민수기 26:42","category":"$undefined"},{"id":"4533","book":"민수기","book_name":"민수기","chapter":26,"verse":43,"text":"수함 모든 가족의 계수함을 입은 자가 육만 사천 사백명이었더라","reference":"민수기 26:43","category":"$undefined"},{"id":"4534","book":"민수기","book_name":"민수기","chapter":26,"verse":44,"text":"아셀 자손은 그 종족대로 이러하니 임나에게서 난 임나 가족과, 이스위에게서 난 이스위 가족과, 브리아에게서 난 브리아 가족이며","reference":"민수기 26:44","category":"$undefined"},{"id":"4535","book":"민수기","book_name":"민수기","chapter":26,"verse":45,"text":"브리아의 자손 중 헤벨에게서 난 헤벨 가족과, 말기엘에게서 난 말기엘 가족이며","reference":"민수기 26:45","category":"$undefined"},{"id":"4536","book":"민수기","book_name":"민수기","chapter":26,"verse":46,"text":"아셀의 딸의 이름은 세라라","reference":"민수기 26:46","category":"$undefined"},{"id":"4537","book":"민수기","book_name":"민수기","chapter":26,"verse":47,"text":"이는 아셀 자손의 종족들이니 계수함을 입은 자가 오만 삼천 사백명이었더라","reference":"민수기 26:47","category":"$undefined"},{"id":"4538","book":"민수기","book_name":"민수기","chapter":26,"verse":48,"text":"납달리 자손은 그 종족대로 이러하니 야셀에게서 난 야셀 가족과, 구니에게서 난 구니 가족과","reference":"민수기 26:48","category":"$undefined"},{"id":"4539","book":"민수기","book_name":"민수기","chapter":26,"verse":49,"text":"예셀에게서 난 예셀 가족과, 실렘에게서 난 실렘 가족이라","reference":"민수기 26:49","category":"$undefined"},{"id":"4540","book":"민수기","book_name":"민수기","chapter":26,"verse":50,"text":"이는 그 종족을 따른 납달리 가족들이니 계수함을 입은 자가 사만 오천 사백명이었더라","reference":"민수기 26:50","category":"$undefined"},{"id":"4541","book":"민수기","book_name":"민수기","chapter":26,"verse":51,"text":"이스라엘 자손의 계수함을 입은 자가 육십만 일천 칠백 삼십명이었더라","reference":"민수기 26:51","category":"$undefined"},{"id":"4542","book":"민수기","book_name":"민수기","chapter":26,"verse":52,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 26:52","category":"$undefined"},{"id":"4543","book":"민수기","book_name":"민수기","chapter":26,"verse":53,"text":"이 계수대로 땅을 나눠 주어 기업을 삼게 하라","reference":"민수기 26:53","category":"$undefined"},{"id":"4544","book":"민수기","book_name":"민수기","chapter":26,"verse":54,"text":"수가 많은 자에게는 기업을 많이 줄 것이요 수가 적은 자에게는 기업을 적게 줄 것이니 그들의 계수함을 입은 수대로 각기 기업을 주되","reference":"민수기 26:54","category":"$undefined"},{"id":"4545","book":"민수기","book_name":"민수기","chapter":26,"verse":55,"text":"오직 그 땅을 제비뽑아 나누어 그들의 조상 지파의 이름을 따라 얻게 할지니라","reference":"민수기 26:55","category":"$undefined"},{"id":"4546","book":"민수기","book_name":"민수기","chapter":26,"verse":56,"text":"그 다소를 물론하고 그 기업을 제비 뽑아 나눌지니라","reference":"민수기 26:56","category":"$undefined"},{"id":"4547","book":"민수기","book_name":"민수기","chapter":26,"verse":57,"text":"레위인의 계수함을 입은 자는 그 종족대로 이러하니 게르손에게서 난 게르손 가족과, 고핫에게서 난 고핫 가족과, 므라리에게서 난 므라리 가족이며","reference":"민수기 26:57","category":"$undefined"},{"id":"4548","book":"민수기","book_name":"민수기","chapter":26,"verse":58,"text":"레위 종족들은 이러하니 립니 가족과, 헤브론 가족과, 말리 가족과, 무시 가족과, 고라 가족이라, 고핫은 아므람을 낳았으며","reference":"민수기 26:58","category":"$undefined"},{"id":"4549","book":"민수기","book_name":"민수기","chapter":26,"verse":59,"text":"아므람의 처의 이름은 요게벳이니 레위의 딸이요 애굽에서 레위에게서 난 자라 그가 아므람에게서 아론과 모세와 그 누이 미리암을 낳았고","reference":"민수기 26:59","category":"$undefined"},{"id":"4550","book":"민수기","book_name":"민수기","chapter":26,"verse":60,"text":"아론에게서는 나답과, 아비후와, 엘르아살과, 이다말이 났더니","reference":"민수기 26:60","category":"$undefined"},{"id":"4551","book":"민수기","book_name":"민수기","chapter":26,"verse":61,"text":"나답과 아비후는 다른 불을 여호와 앞에 드리다가 죽었더라","reference":"민수기 26:61","category":"$undefined"},{"id":"4552","book":"민수기","book_name":"민수기","chapter":26,"verse":62,"text":"레위인의 일개월 이상으로 계수함을 입은 모든 남자가 이만 삼천명이었더라 그들은 이스라엘 자손 중 계수에 들지 아니하였으니 이는 이스라엘 자손 중에서 그들에게 준 기업이 없음이었더라","reference":"민수기 26:62","category":"$undefined"},{"id":"4553","book":"민수기","book_name":"민수기","chapter":26,"verse":63,"text":"이는 모세와 제사장 엘르아살의 계수한 자라 그들이 여리고 맞은편 요단 가 모압 평지에서 이스라엘 자손을 계수한 중에는","reference":"민수기 26:63","category":"$undefined"},{"id":"4554","book":"민수기","book_name":"민수기","chapter":26,"verse":64,"text":"모세와 제사장 아론이 시내 광야에서 계수한 이스라엘 자손은 한사람도 들지 못하였으니","reference":"민수기 26:64","category":"$undefined"},{"id":"4555","book":"민수기","book_name":"민수기","chapter":26,"verse":65,"text":"이는 여호와께서 그들에게 대하여 말씀하시기를 그들이 반드시 광야에서 죽으리라 하셨음이라 이러므로 여분네의 아들 갈렙과 눈의 아들 여호수아 외에는 한 사람도 남지 아니하였더라","reference":"민수기 26:65","category":"$undefined"}],"bookSlug":"numbers"}]
