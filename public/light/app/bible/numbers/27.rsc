2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":27,"verses":[{"id":"4556","book":"민수기","book_name":"민수기","chapter":27,"verse":1,"text":"요셉의 아들 므낫세 가족에 므낫세의 현손, 마길의 증손, 길르앗의 손자 헤벨의 아들 슬로브핫의 딸들이 나아왔으니 그 딸들의 이름은 말라와, 노아와, 호글라와, 밀가와, 디르사라","reference":"민수기 27:1","category":"$undefined"},{"id":"4557","book":"민수기","book_name":"민수기","chapter":27,"verse":2,"text":"그들이 회막 문에서 모세와 제사장 엘르아살과 족장들과 온 회중앞에 서서 가로되","reference":"민수기 27:2","category":"$undefined"},{"id":"4558","book":"민수기","book_name":"민수기","chapter":27,"verse":3,"text":"`우리 아버지가 광야에서 죽었으나 여호와를 거스려 모인 고라의 무리에 들지 아니하고 자기 죄에 죽었고 아들이 없나이다","reference":"민수기 27:3","category":"$undefined"},{"id":"4559","book":"민수기","book_name":"민수기","chapter":27,"verse":4,"text":"어찌하여 아들이 없다고 우리 아버지의 이름이 그 가족 중에서 삭제되리이까 ? 우리 아버지의 형제 중에서 우리에게 기업을 주소서' 하매","reference":"민수기 27:4","category":"$undefined"},{"id":"4560","book":"민수기","book_name":"민수기","chapter":27,"verse":5,"text":"모세가 그 사연을 여호와께 품하니라","reference":"민수기 27:5","category":"$undefined"},{"id":"4561","book":"민수기","book_name":"민수기","chapter":27,"verse":6,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 27:6","category":"$undefined"},{"id":"4562","book":"민수기","book_name":"민수기","chapter":27,"verse":7,"text":"슬로브핫 딸들의 말이 옳으니 너는 반드시 그들의 아비의 형제 중에서 그들에게 기업을 주어 얻게 하되 그 아비의 기업으로 그들에게 돌릴지니라","reference":"민수기 27:7","category":"$undefined"},{"id":"4563","book":"민수기","book_name":"민수기","chapter":27,"verse":8,"text":"너는 이스라엘 자손에게 고하여 이르기를 사람이 죽고 아들이 없거든 그 기업을 그 딸에게 돌릴 것이요","reference":"민수기 27:8","category":"$undefined"},{"id":"4564","book":"민수기","book_name":"민수기","chapter":27,"verse":9,"text":"딸도 없거든 그 기업을 그 형제에게 줄 것이요","reference":"민수기 27:9","category":"$undefined"},{"id":"4565","book":"민수기","book_name":"민수기","chapter":27,"verse":10,"text":"형제도 없거든 그 기업을 그 아비의 형제에게 줄 것이요","reference":"민수기 27:10","category":"$undefined"},{"id":"4566","book":"민수기","book_name":"민수기","chapter":27,"verse":11,"text":"그 아비의 형제도 없거든 그 기업을 가장 가까운 친족에게 주어 얻게 할지니라 하고 나 여호와가 너 모세에게 명한 대로 이스라엘 자손에게 판결의 율례가 되게 할지니라","reference":"민수기 27:11","category":"$undefined"},{"id":"4567","book":"민수기","book_name":"민수기","chapter":27,"verse":12,"text":"여호와께서 모세에게 이르시되 너는 이 아바림 산에 올라가서 내가 이스라엘 자손에게 준 땅을 바라보라","reference":"민수기 27:12","category":"$undefined"},{"id":"4568","book":"민수기","book_name":"민수기","chapter":27,"verse":13,"text":"본 후에는 네 형 아론의 돌아간 것같이 너도 조상에게로 돌아가리니","reference":"민수기 27:13","category":"$undefined"},{"id":"4569","book":"민수기","book_name":"민수기","chapter":27,"verse":14,"text":"이는 신 광야에서 회중이 분쟁할 제 너희가 내 명을 거역하고 그 물 가에서 나의 거룩함을 그들의 목전에 나타내지 아니하였음이니라 이 물은 신 광야 가데스의 므리바 물이니라","reference":"민수기 27:14","category":"$undefined"},{"id":"4570","book":"민수기","book_name":"민수기","chapter":27,"verse":15,"text":"모세가 여호와께 여짜와 가로되","reference":"민수기 27:15","category":"$undefined"},{"id":"4571","book":"민수기","book_name":"민수기","chapter":27,"verse":16,"text":"`여호와 모든 육체의 생명의 하나님이시여 ! 원컨대 한 사람을 이 회중 위에 세워서","reference":"민수기 27:16","category":"$undefined"},{"id":"4572","book":"민수기","book_name":"민수기","chapter":27,"verse":17,"text":"그로 그들 앞에 출입하며 그들을 인도하여 출입하게 하사 여호와의 회중으로 목자없는 양과 같이 되지 않게 하옵소서 !'","reference":"민수기 27:17","category":"$undefined"},{"id":"4573","book":"민수기","book_name":"민수기","chapter":27,"verse":18,"text":"여호와께서 모세에게 이르시되 눈의 아들 여호수아는 신에 감동된 자니 너는 데려다가 그에게 안수하고","reference":"민수기 27:18","category":"$undefined"},{"id":"4574","book":"민수기","book_name":"민수기","chapter":27,"verse":19,"text":"그를 제사장 엘르아살과 온 회중 앞에 세우고 그들의 목전에서 그에게 위탁하여","reference":"민수기 27:19","category":"$undefined"},{"id":"4575","book":"민수기","book_name":"민수기","chapter":27,"verse":20,"text":"네 존귀를 그에게 돌려 이스라엘 자손의 온 회중으로 그에게 복종하게 하라","reference":"민수기 27:20","category":"$undefined"},{"id":"4576","book":"민수기","book_name":"민수기","chapter":27,"verse":21,"text":"그는 제사장 엘르아살 앞에 설 것이요 엘르아살은 그를 위하여 우림의 판결법으로 여호와 앞에 물을 것이며 그와 온 이스라엘 자손 곧 온 회중은 엘르아살의 말을 좇아 나가며 들어올 것이니라","reference":"민수기 27:21","category":"$undefined"},{"id":"4577","book":"민수기","book_name":"민수기","chapter":27,"verse":22,"text":"모세가 여호와께서 자기에게 명하신 대로 하여 여호수아를 데려다가 제사장 엘르아살과 온 회중 앞에 세우고","reference":"민수기 27:22","category":"$undefined"},{"id":"4578","book":"민수기","book_name":"민수기","chapter":27,"verse":23,"text":"","reference":"민수기 27:23","category":"$undefined"}],"bookSlug":"numbers"}]
