2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":28,"verses":[{"id":"4579","book":"민수기","book_name":"민수기","chapter":28,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 28:1","category":"$undefined"},{"id":"4580","book":"민수기","book_name":"민수기","chapter":28,"verse":2,"text":"이스라엘 자손에게 명하여 그들에게 이르라 나의 예물, 나의 식물되는 화제, 나의 향기로운 것은 너희가 그 정한 시기에 삼가 내게 드릴지니라","reference":"민수기 28:2","category":"$undefined"},{"id":"4581","book":"민수기","book_name":"민수기","chapter":28,"verse":3,"text":"또 그들에게 이르라 너희가 여호와께 드릴 화제는 이러하니 일년되고 흠 없는 수양을 매일 둘씩 상번제로 드리되","reference":"민수기 28:3","category":"$undefined"},{"id":"4582","book":"민수기","book_name":"민수기","chapter":28,"verse":4,"text":"한 어린 양은 아침에 드리고, 한 어린 양은 해 질 때에 드릴 것이요","reference":"민수기 28:4","category":"$undefined"},{"id":"4583","book":"민수기","book_name":"민수기","chapter":28,"verse":5,"text":"또 고운 가루 에바 십분지 일에 빻아낸 기름 힌 사분지 일을 섞어서 소제로 드릴 것이니","reference":"민수기 28:5","category":"$undefined"},{"id":"4584","book":"민수기","book_name":"민수기","chapter":28,"verse":6,"text":"이는 시내산에서 정한 상번제로서 여호와께 드리는 향기로운 화제며","reference":"민수기 28:6","category":"$undefined"},{"id":"4585","book":"민수기","book_name":"민수기","chapter":28,"verse":7,"text":"또 그 전제는 어린 양 하나에 힌 사분지 일을 드리되 거룩한 곳에서 여호와께 독주의 전제를 부어 드릴 것이며","reference":"민수기 28:7","category":"$undefined"},{"id":"4586","book":"민수기","book_name":"민수기","chapter":28,"verse":8,"text":"해질 때에는 그 한 어린 양을 드리되 그 소제와 전제를 아침 것같이 여호와께 향기로운 화제로 드릴 것이니라","reference":"민수기 28:8","category":"$undefined"},{"id":"4587","book":"민수기","book_name":"민수기","chapter":28,"verse":9,"text":"안식일에는 일년 되고 흠 없는 수양 둘과 고운 가루 에바 십분지 이에 기름 섞은 소제와 그 전제를 드릴 것이니","reference":"민수기 28:9","category":"$undefined"},{"id":"4588","book":"민수기","book_name":"민수기","chapter":28,"verse":10,"text":"이는 매 안식일의 번제라 상번제와 그 전제 외에니라","reference":"민수기 28:10","category":"$undefined"},{"id":"4589","book":"민수기","book_name":"민수기","chapter":28,"verse":11,"text":"월삭에는 수송아지 둘과 수양 하나와 일년 되고 흠없는 수양 일곱으로 여호와께 번제를 드리되","reference":"민수기 28:11","category":"$undefined"},{"id":"4590","book":"민수기","book_name":"민수기","chapter":28,"verse":12,"text":"매 수송아지에는 고운 가루 에바 십분지 삼에, 기름 섞은 소제와 수양 하나에는 고운 가루 에바 십분지 이에 기름 섞은 소제와","reference":"민수기 28:12","category":"$undefined"},{"id":"4591","book":"민수기","book_name":"민수기","chapter":28,"verse":13,"text":"매 어린 양에는 고운 가루 에바 십분지 일에, 기름 섞은 소제를 향기로운 번제로 여호와께 화제로 드릴 것이며","reference":"민수기 28:13","category":"$undefined"},{"id":"4592","book":"민수기","book_name":"민수기","chapter":28,"verse":14,"text":"그 전제는 수송아지 하나에 포도주 반 힌이요, 수양 하나에 삼분지 일 힌이요 어린 양 하나에 사분지 일 힌이니 이는 일년 중 매 월삭의 번제며","reference":"민수기 28:14","category":"$undefined"},{"id":"4593","book":"민수기","book_name":"민수기","chapter":28,"verse":15,"text":"또 상번제와 그 전제 외에 수염소 하나를 속죄제로 여호와께 드릴 것이니라","reference":"민수기 28:15","category":"$undefined"},{"id":"4594","book":"민수기","book_name":"민수기","chapter":28,"verse":16,"text":"정월 십사일은 여호와의 유월절이며","reference":"민수기 28:16","category":"$undefined"},{"id":"4595","book":"민수기","book_name":"민수기","chapter":28,"verse":17,"text":"또 그달 십오일 부터는 절일이니 칠일동안 무교병을 먹을 것이며","reference":"민수기 28:17","category":"$undefined"},{"id":"4596","book":"민수기","book_name":"민수기","chapter":28,"verse":18,"text":"그 첫날에는 성회로 모일 것이요 아무 노동도 하지 말 것이며","reference":"민수기 28:18","category":"$undefined"},{"id":"4597","book":"민수기","book_name":"민수기","chapter":28,"verse":19,"text":"수송아지 둘과 수양 하나와 일년 된 수양 일곱을 다 흠없는 것으로 여호와께 화제를 드려 번제가 되게 할 것이며","reference":"민수기 28:19","category":"$undefined"},{"id":"4598","book":"민수기","book_name":"민수기","chapter":28,"verse":20,"text":"그 소제로는 고운 가루에 기름을 섞어서 쓰되 수송아지 하나에는 에바 십분지 삼이요 수양 하나에는 에바 십분지 이를 드리고","reference":"민수기 28:20","category":"$undefined"},{"id":"4599","book":"민수기","book_name":"민수기","chapter":28,"verse":21,"text":"어린 양 일곱에는 매 어린 양에 에바 십분지 일을 드릴 것이며","reference":"민수기 28:21","category":"$undefined"},{"id":"4600","book":"민수기","book_name":"민수기","chapter":28,"verse":22,"text":"또 너희를 속하기 위하여 수염소 하나로 속죄제를 드리되","reference":"민수기 28:22","category":"$undefined"},{"id":"4601","book":"민수기","book_name":"민수기","chapter":28,"verse":23,"text":"아침의 번제 곧 상번제 외에 그것들을 드릴 것이니라","reference":"민수기 28:23","category":"$undefined"},{"id":"4602","book":"민수기","book_name":"민수기","chapter":28,"verse":24,"text":"너희는 이 순서대로 칠일 동안 매일 여호와께 향기로운 화제의 식물을 드리되 상번제와 그 전제 외에 드릴 것이며","reference":"민수기 28:24","category":"$undefined"},{"id":"4603","book":"민수기","book_name":"민수기","chapter":28,"verse":25,"text":"제 칠일에는 성회로 모일 것이요 아무 노동도 하지 말 것이니라","reference":"민수기 28:25","category":"$undefined"},{"id":"4604","book":"민수기","book_name":"민수기","chapter":28,"verse":26,"text":"칠칠절 처음 익은 열매 드리는 날에 너희가 여호와께 새 소제를 드릴 때에도 성회로 모일 것이요 아무 노동도 하지 말 것이며","reference":"민수기 28:26","category":"$undefined"},{"id":"4605","book":"민수기","book_name":"민수기","chapter":28,"verse":27,"text":"수 송아지 둘과 수양 하나와 일년 된 수양 일곱으로 여호와께 향기로운 번제를 드릴 것이며","reference":"민수기 28:27","category":"$undefined"},{"id":"4606","book":"민수기","book_name":"민수기","chapter":28,"verse":28,"text":"그 소제로는 고운 가루에 기름을 섞어서 쓰되 매 수송아지에는 에바 십분지 삼이요, 수양 하나에는 에바 십분지 이요","reference":"민수기 28:28","category":"$undefined"},{"id":"4607","book":"민수기","book_name":"민수기","chapter":28,"verse":29,"text":"어린 양 일곱에는 매 어린 양에 에바 십분지 일을 드릴 것이며","reference":"민수기 28:29","category":"$undefined"},{"id":"4608","book":"민수기","book_name":"민수기","chapter":28,"verse":30,"text":"또 너희를 속하기 위하여 수염소 하나를 드리되","reference":"민수기 28:30","category":"$undefined"},{"id":"4609","book":"민수기","book_name":"민수기","chapter":28,"verse":31,"text":"너희는 다 흠 없는 것으로 상번제와 그 소제와 전제 외에 그것들을 드릴 것이니라","reference":"민수기 28:31","category":"$undefined"}],"bookSlug":"numbers"}]
