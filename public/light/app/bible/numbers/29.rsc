2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":29,"verses":[{"id":"4610","book":"민수기","book_name":"민수기","chapter":29,"verse":1,"text":"칠월에 이르러는 그 달 초일일에 성회로 모이고 아무 노동도 하지 말라 이는 너희가 나팔을 불 날이니라","reference":"민수기 29:1","category":"$undefined"},{"id":"4611","book":"민수기","book_name":"민수기","chapter":29,"verse":2,"text":"너희는 수송아지 하나와 수양 하나와 일년 되고 흠 없는 수양 일곱을 여호와께 향기로운 번제로 드릴 것이며","reference":"민수기 29:2","category":"$undefined"},{"id":"4612","book":"민수기","book_name":"민수기","chapter":29,"verse":3,"text":"그 소제로는 고운 가루에 기름을 섞어서 쓰되 수송아지에는 에바 십분지 삼이요, 수양에는 에바 십분지 이요","reference":"민수기 29:3","category":"$undefined"},{"id":"4613","book":"민수기","book_name":"민수기","chapter":29,"verse":4,"text":"어린 양 일곱에는 매 어린 양에 에바 십분지 일을 드릴 것이며","reference":"민수기 29:4","category":"$undefined"},{"id":"4614","book":"민수기","book_name":"민수기","chapter":29,"verse":5,"text":"또 너희를 속하기 위하여 수염소 하나를 속죄제로 드리되","reference":"민수기 29:5","category":"$undefined"},{"id":"4615","book":"민수기","book_name":"민수기","chapter":29,"verse":6,"text":"월삭의 번제와 그 소제와 상번제와 그 소제와 그 전제 외에 그 규례를 따라 향기로운 화제로 여호와께 드릴 것이니라","reference":"민수기 29:6","category":"$undefined"},{"id":"4616","book":"민수기","book_name":"민수기","chapter":29,"verse":7,"text":"칠월 십일에는 너희가 성회로 모일 것이요 마음을 괴롭게 하고 아무 노동도 하지 말 것이며","reference":"민수기 29:7","category":"$undefined"},{"id":"4617","book":"민수기","book_name":"민수기","chapter":29,"verse":8,"text":"너희는 수송아지 하나와 수양 하나와 일년 된 수양 일곱을 다 흠없는 것으로 여호와께 향기로운 번제를 드릴 것이며","reference":"민수기 29:8","category":"$undefined"},{"id":"4618","book":"민수기","book_name":"민수기","chapter":29,"verse":9,"text":"그 소제로는 고운 가루에 기름을 섞어서 쓰되 수송아지 하나에는 에바 십분지 삼이요, 수양 하나에는 에바 십분지 이요","reference":"민수기 29:9","category":"$undefined"},{"id":"4619","book":"민수기","book_name":"민수기","chapter":29,"verse":10,"text":"어린 양 일곱에는 매 어린 양에 에바 십분지 일을 드릴 것이며","reference":"민수기 29:10","category":"$undefined"},{"id":"4620","book":"민수기","book_name":"민수기","chapter":29,"verse":11,"text":"또 수염소 하나를 속죄제로 드릴 것이니 이는 속죄제와 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:11","category":"$undefined"},{"id":"4621","book":"민수기","book_name":"민수기","chapter":29,"verse":12,"text":"칠월 십오일에는 너희가 너희 성회로 모일 것이요 아무 노동도 하지 말 것이며 칠일 동안 여호와 앞에 절기를 지킬 것이라","reference":"민수기 29:12","category":"$undefined"},{"id":"4622","book":"민수기","book_name":"민수기","chapter":29,"verse":13,"text":"너희 번제로 여호와께 향기로운 화제를 드리되 수 송아지 열셋과 수양 둘과 일년된 수양 열 넷을 다 흠 없는 것으로 드릴 것이며","reference":"민수기 29:13","category":"$undefined"},{"id":"4623","book":"민수기","book_name":"민수기","chapter":29,"verse":14,"text":"그 소제로는 고운 가루에 기름을 섞어서 수송아지 열셋에는 각기 에바 십분지 삼이요, 수양 둘에는 각기 에바 십분지 이요","reference":"민수기 29:14","category":"$undefined"},{"id":"4624","book":"민수기","book_name":"민수기","chapter":29,"verse":15,"text":"어린 양 열넷에는 각기 에바 십분지 일을 드릴 것이며","reference":"민수기 29:15","category":"$undefined"},{"id":"4625","book":"민수기","book_name":"민수기","chapter":29,"verse":16,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:16","category":"$undefined"},{"id":"4626","book":"민수기","book_name":"민수기","chapter":29,"verse":17,"text":"둘째 날에는 수송아지 열둘과 수양 둘과 일년 되고 흠 없는 수양 열넷을 드릴 것이며","reference":"민수기 29:17","category":"$undefined"},{"id":"4627","book":"민수기","book_name":"민수기","chapter":29,"verse":18,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:18","category":"$undefined"},{"id":"4628","book":"민수기","book_name":"민수기","chapter":29,"verse":19,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전 제 외에니라","reference":"민수기 29:19","category":"$undefined"},{"id":"4629","book":"민수기","book_name":"민수기","chapter":29,"verse":20,"text":"세째 날에는 수송아지 열 하나와 수양 둘과 일년 되고 흠없는 수양 열넷을 드릴 것이며","reference":"민수기 29:20","category":"$undefined"},{"id":"4630","book":"민수기","book_name":"민수기","chapter":29,"verse":21,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:21","category":"$undefined"},{"id":"4631","book":"민수기","book_name":"민수기","chapter":29,"verse":22,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:22","category":"$undefined"},{"id":"4632","book":"민수기","book_name":"민수기","chapter":29,"verse":23,"text":"네째 날에는 수송아지 열과 수양 둘과 일년 되고 흠 없는 수양 열넷을 드릴 것이며","reference":"민수기 29:23","category":"$undefined"},{"id":"4633","book":"민수기","book_name":"민수기","chapter":29,"verse":24,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:24","category":"$undefined"},{"id":"4634","book":"민수기","book_name":"민수기","chapter":29,"verse":25,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:25","category":"$undefined"},{"id":"4635","book":"민수기","book_name":"민수기","chapter":29,"verse":26,"text":"다섯째 날에는 수송아지 아홉과 수양 둘과 일년 되고 흠없는 수양 열넷을 드릴 것이며","reference":"민수기 29:26","category":"$undefined"},{"id":"4636","book":"민수기","book_name":"민수기","chapter":29,"verse":27,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:27","category":"$undefined"},{"id":"4637","book":"민수기","book_name":"민수기","chapter":29,"verse":28,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:28","category":"$undefined"},{"id":"4638","book":"민수기","book_name":"민수기","chapter":29,"verse":29,"text":"여섯째 날에는 수송아지 여덟과 수양 둘과 일년 되고 흠없는 수양 열넷을 드릴 것이며","reference":"민수기 29:29","category":"$undefined"},{"id":"4639","book":"민수기","book_name":"민수기","chapter":29,"verse":30,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:30","category":"$undefined"},{"id":"4640","book":"민수기","book_name":"민수기","chapter":29,"verse":31,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:31","category":"$undefined"},{"id":"4641","book":"민수기","book_name":"민수기","chapter":29,"verse":32,"text":"일곱째 날에는 수송아지 일곱과 수양 둘과 일년 되고 흠 없는 수양 열넷을 드릴 것이며","reference":"민수기 29:32","category":"$undefined"},{"id":"4642","book":"민수기","book_name":"민수기","chapter":29,"verse":33,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:33","category":"$undefined"},{"id":"4643","book":"민수기","book_name":"민수기","chapter":29,"verse":34,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:34","category":"$undefined"},{"id":"4644","book":"민수기","book_name":"민수기","chapter":29,"verse":35,"text":"여덟째 날에는 거룩한 대회로 모일 것이요 아무 노동도 하지 말것이며","reference":"민수기 29:35","category":"$undefined"},{"id":"4645","book":"민수기","book_name":"민수기","chapter":29,"verse":36,"text":"번제로 여호와께 향기로운 화제를 드리되 수송아지 하나와 수양 하나와 일년 되고 흠 없는 수양 일곱을 드릴 것이며","reference":"민수기 29:36","category":"$undefined"},{"id":"4646","book":"민수기","book_name":"민수기","chapter":29,"verse":37,"text":"그 소제와 전제는 수송아지와 수양과 어린 양의 수효를 따라서 규례대로 할 것이며","reference":"민수기 29:37","category":"$undefined"},{"id":"4647","book":"민수기","book_name":"민수기","chapter":29,"verse":38,"text":"또 수염소 하나를 속죄제로 드릴지니 상번제와 그 소제와 그 전제 외에니라","reference":"민수기 29:38","category":"$undefined"},{"id":"4648","book":"민수기","book_name":"민수기","chapter":29,"verse":39,"text":"너희가 이 절기를 당하거든 여호와께 이같이 드릴지니 이는 너희 서원제나 낙헌제외에 번제, 소제, 전제, 화목제를 드릴 것이니라","reference":"민수기 29:39","category":"$undefined"},{"id":"4649","book":"민수기","book_name":"민수기","chapter":29,"verse":40,"text":"모세가 여호와께서 자기로 명하신 모든 일을 이스라엘 자손에게 고하니라","reference":"민수기 29:40","category":"$undefined"}],"bookSlug":"numbers"}]
