2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":3,"verses":[{"id":"3694","book":"민수기","book_name":"민수기","chapter":3,"verse":1,"text":"여호와께서 시내 산에서 모세와 말씀하실 때에 아론과 모세의 낳은 자가 이러하니라","reference":"민수기 3:1","category":"$undefined"},{"id":"3695","book":"민수기","book_name":"민수기","chapter":3,"verse":2,"text":"아론의 아들들의 이름은 장자는 나답이요, 다음은 아비후와, 엘르아살과, 이다말이니","reference":"민수기 3:2","category":"$undefined"},{"id":"3696","book":"민수기","book_name":"민수기","chapter":3,"verse":3,"text":"이는 아론의 아들들의 이름이며 그들은 기름을 발리우고 거룩히 구별되어 제사장 직분을 위임받은 제사장들이라","reference":"민수기 3:3","category":"$undefined"},{"id":"3697","book":"민수기","book_name":"민수기","chapter":3,"verse":4,"text":"나답과 아비후는 시내 광야에서 다른 불을 여호와 앞에 드리다가 여호와 앞에서 죽었고 무자하였고 엘리아살과, 이다말이 그 아비 아론 앞에서 제사장의 직분을 행하였더라","reference":"민수기 3:4","category":"$undefined"},{"id":"3698","book":"민수기","book_name":"민수기","chapter":3,"verse":5,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 3:5","category":"$undefined"},{"id":"3699","book":"민수기","book_name":"민수기","chapter":3,"verse":6,"text":"레위 지파로 나아와 제사장 아론 앞에 서서 그에게 시종하게 하라","reference":"민수기 3:6","category":"$undefined"},{"id":"3700","book":"민수기","book_name":"민수기","chapter":3,"verse":7,"text":"그들이 회막 앞에서 아론의 직무와 온 회중의 직무를 위하여 회막에서 시무하되","reference":"민수기 3:7","category":"$undefined"},{"id":"3701","book":"민수기","book_name":"민수기","chapter":3,"verse":8,"text":"곧 회막의 모든 기구를 수직하며 이스라엘 자손의 직무를 위하여 장막에서 시무할지니","reference":"민수기 3:8","category":"$undefined"},{"id":"3702","book":"민수기","book_name":"민수기","chapter":3,"verse":9,"text":"너는 레위인을 아론과 그 아들들에게 주라 그들은 이스라엘 자손중에서 아론에게 온전히 돌리운 자니라","reference":"민수기 3:9","category":"$undefined"},{"id":"3703","book":"민수기","book_name":"민수기","chapter":3,"verse":10,"text":"너는 아론과 그 아들들을 세워 제사장 직분을 행하게 하라 외인이 가까이 하면 죽임을 당할 것이니라","reference":"민수기 3:10","category":"$undefined"},{"id":"3704","book":"민수기","book_name":"민수기","chapter":3,"verse":11,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 3:11","category":"$undefined"},{"id":"3705","book":"민수기","book_name":"민수기","chapter":3,"verse":12,"text":"보라 내가 이스라엘 자손 중에서 레위인을 택하여 이스라엘 자손 중 모든 첫 태에 처음 난 자를 대신케 하였은즉 레위인은 내 것이라 !","reference":"민수기 3:12","category":"$undefined"},{"id":"3706","book":"민수기","book_name":"민수기","chapter":3,"verse":13,"text":"처음 난 자는 다 내 것임은 내가 애굽 땅에서 그 처음 난 자를 다 죽이던 날에 이스라엘의 처음 난 자는 사람이나 짐승을 다 거룩히 구별하였음이니 그들은 내 것이 될 것임이니라","reference":"민수기 3:13","category":"$undefined"},{"id":"3707","book":"민수기","book_name":"민수기","chapter":3,"verse":14,"text":"여호와께서 시내 광야에서 모세에게 일러 가라사대","reference":"민수기 3:14","category":"$undefined"},{"id":"3708","book":"민수기","book_name":"민수기","chapter":3,"verse":15,"text":"레위 자손을 그들의 종족과 가족을 따라 계수하되 일개월 이상의 남자를 다 계수하라","reference":"민수기 3:15","category":"$undefined"},{"id":"3709","book":"민수기","book_name":"민수기","chapter":3,"verse":16,"text":"모세가 여호와의 말씀을 좇아 그 명하신 대로 계수하니라","reference":"민수기 3:16","category":"$undefined"},{"id":"3710","book":"민수기","book_name":"민수기","chapter":3,"verse":17,"text":"레위의 아들들의 이름은 이러하니 게르손과, 고핫과, 므라리요","reference":"민수기 3:17","category":"$undefined"},{"id":"3711","book":"민수기","book_name":"민수기","chapter":3,"verse":18,"text":"게르손의 아들들의 이름은 그 가족대로 이러하니 립니와, 시므이요","reference":"민수기 3:18","category":"$undefined"},{"id":"3712","book":"민수기","book_name":"민수기","chapter":3,"verse":19,"text":"고핫의 아들들은 그 가족대로 이러하니 아므람과, 이스할과, 헤브론과, 웃시엘이요","reference":"민수기 3:19","category":"$undefined"},{"id":"3713","book":"민수기","book_name":"민수기","chapter":3,"verse":20,"text":"므라리의 아들들은 그 가족대로 말리와, 무시니 이는 그 종족대로된 레위인의 가족들이니라","reference":"민수기 3:20","category":"$undefined"},{"id":"3714","book":"민수기","book_name":"민수기","chapter":3,"verse":21,"text":"게르손에게서는 립니 가족과, 시므이 가족이 났으니 이들이 곧 게르손의 가족들이라","reference":"민수기 3:21","category":"$undefined"},{"id":"3715","book":"민수기","book_name":"민수기","chapter":3,"verse":22,"text":"계수함을 입은 자의 수효 곧 일개월 이상 남자의 수효 합계가 칠천 오백명이며","reference":"민수기 3:22","category":"$undefined"},{"id":"3716","book":"민수기","book_name":"민수기","chapter":3,"verse":23,"text":"게르손 가족들은 장막 뒤 곧 서편에 진을 칠 것이요","reference":"민수기 3:23","category":"$undefined"},{"id":"3717","book":"민수기","book_name":"민수기","chapter":3,"verse":24,"text":"라엘의 아들 엘리아삽은 게르손 사람의 종족의 족장이 될것이며","reference":"민수기 3:24","category":"$undefined"},{"id":"3718","book":"민수기","book_name":"민수기","chapter":3,"verse":25,"text":"게르손 자손의 회막에 대하여 맡을 것은 성막과, 장막과, 그 덮개와, 회막 문장과,","reference":"민수기 3:25","category":"$undefined"},{"id":"3719","book":"민수기","book_name":"민수기","chapter":3,"verse":26,"text":"뜰의 휘장과, 및 성막과, 단 사면에 있는 뜰의 문장과, 그 모든 것에 쓰는 줄들이니라","reference":"민수기 3:26","category":"$undefined"},{"id":"3720","book":"민수기","book_name":"민수기","chapter":3,"verse":27,"text":"고핫에게서는 아므람 가족과, 이스할 가족과, 헤브론 가족과, 웃시엘 가족이 났으니 이들이 곧 고핫 가족들이라","reference":"민수기 3:27","category":"$undefined"},{"id":"3721","book":"민수기","book_name":"민수기","chapter":3,"verse":28,"text":"계수함을 입은 일개월 이상 모든 남자의 수효가 팔천 육백명인데 성소를 맡을 것이며","reference":"민수기 3:28","category":"$undefined"},{"id":"3722","book":"민수기","book_name":"민수기","chapter":3,"verse":29,"text":"고핫 자손의 가족들은 성막 남편에 진을 칠 것이요","reference":"민수기 3:29","category":"$undefined"},{"id":"3723","book":"민수기","book_name":"민수기","chapter":3,"verse":30,"text":"웃시엘의 아들 엘리사반은 고핫 사람의 가족과, 종족의 족장이 될것이며","reference":"민수기 3:30","category":"$undefined"},{"id":"3724","book":"민수기","book_name":"민수기","chapter":3,"verse":31,"text":"그들의 맡을 것은 증거궤와, 상과, 등대와, 단들과, 성소에서 봉사하는데 쓰는 기구들과 휘장과 그것에 쓰는 모든 것이며","reference":"민수기 3:31","category":"$undefined"},{"id":"3725","book":"민수기","book_name":"민수기","chapter":3,"verse":32,"text":"제사장 아론의 아들 엘리아살은 레위인의 족장들의 어른이 되고 또 성소를 맡을 자를 통할할 것이니라","reference":"민수기 3:32","category":"$undefined"},{"id":"3726","book":"민수기","book_name":"민수기","chapter":3,"verse":33,"text":"므라리에게서는 말리 가족과 무시 가족이 났으니 이들이 곧 므라리 가족들이라","reference":"민수기 3:33","category":"$undefined"},{"id":"3727","book":"민수기","book_name":"민수기","chapter":3,"verse":34,"text":"그 계수함을 입은 자 곧 일개월 이상 남자의 수효 총계가 육천 이백명이며","reference":"민수기 3:34","category":"$undefined"},{"id":"3728","book":"민수기","book_name":"민수기","chapter":3,"verse":35,"text":"아비하일의 아들 수리엘이 므라리 가족과 종족의 족장이 될 것이요 이 가족은 장막 북편에 진을 칠 것이며","reference":"민수기 3:35","category":"$undefined"},{"id":"3729","book":"민수기","book_name":"민수기","chapter":3,"verse":36,"text":"므라리 자손의 맡을 것은 성막의 널판과, 그 띠와, 그 기둥과, 그 받침과, 그 모든 기구와, 그것에 쓰는 모든 것이며,","reference":"민수기 3:36","category":"$undefined"},{"id":"3730","book":"민수기","book_name":"민수기","chapter":3,"verse":37,"text":"뜰 사면 기둥과, 그 받침과, 그 말뚝과, 그 줄들이니라","reference":"민수기 3:37","category":"$undefined"},{"id":"3731","book":"민수기","book_name":"민수기","chapter":3,"verse":38,"text":"장막 앞 동편 곧 회막 앞 해 돋는 편에는 모세와, 아론과, 아론의 아들들이 진을 치고 이스라엘 자손의 직무를 대신하여 성소의 직무를 지킬 것이며 외인이 가까이 하면 죽일지니라 !","reference":"민수기 3:38","category":"$undefined"},{"id":"3732","book":"민수기","book_name":"민수기","chapter":3,"verse":39,"text":"모세와 아론이 여호와의 명을 좇아 레위인을 각 가족대로 계수한즉 일개월 이상 남자의 수효가 이만 이천명이었더라","reference":"민수기 3:39","category":"$undefined"},{"id":"3733","book":"민수기","book_name":"민수기","chapter":3,"verse":40,"text":"여호와께서 또 모세에게 이르시되 이스라엘 자손의 처음 난 남자를 일개월 이상으로 다 계수하여 그 명수를 기록하라","reference":"민수기 3:40","category":"$undefined"},{"id":"3734","book":"민수기","book_name":"민수기","chapter":3,"verse":41,"text":"나는 여호와라 ! 이스라엘 자손 중 모든 처음 난 자의 대신에 레위인을 내게 돌리고 또 이스라엘 자손의 가축 중 모든 처음 난 것의 대신에 레위인의 가축을 내게 돌리라","reference":"민수기 3:41","category":"$undefined"},{"id":"3735","book":"민수기","book_name":"민수기","chapter":3,"verse":42,"text":"모세가 여호와께서 자기에게 명하신 대로 이스라엘 자손 중 모든 처음 난 자를 계수하니","reference":"민수기 3:42","category":"$undefined"},{"id":"3736","book":"민수기","book_name":"민수기","chapter":3,"verse":43,"text":"일개월 이상으로 계수함을 입은 처음 난 남자의 명수의 총계가 이만 이천 이백 칠십 삼명이었더라","reference":"민수기 3:43","category":"$undefined"},{"id":"3737","book":"민수기","book_name":"민수기","chapter":3,"verse":44,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 3:44","category":"$undefined"},{"id":"3738","book":"민수기","book_name":"민수기","chapter":3,"verse":45,"text":"이스라엘 자손 중 모든 처음 난 자의 대신에 레위인을 취하고 또 그들의 가축 대신에 레위인의 가축을 취하라 레위인은 내 것이라 나는 여호와니라 !","reference":"민수기 3:45","category":"$undefined"},{"id":"3739","book":"민수기","book_name":"민수기","chapter":3,"verse":46,"text":"이스라엘 자손의 처음 난 자가 레위인보다 이백 칠십 삼인이 더 한즉 속하기 위하여","reference":"민수기 3:46","category":"$undefined"},{"id":"3740","book":"민수기","book_name":"민수기","chapter":3,"verse":47,"text":"매명에 오세겔씩 취하되 성소의 세겔대로 취하라 한 세겔은 이십 게라니라","reference":"민수기 3:47","category":"$undefined"},{"id":"3741","book":"민수기","book_name":"민수기","chapter":3,"verse":48,"text":"그 더한 자의 속전을 아론과 그 아들들에게 줄 것이니라","reference":"민수기 3:48","category":"$undefined"},{"id":"3742","book":"민수기","book_name":"민수기","chapter":3,"verse":49,"text":"모세가 레위인으로 대속한 이외의 사람들에게서 속전을 받았으니","reference":"민수기 3:49","category":"$undefined"},{"id":"3743","book":"민수기","book_name":"민수기","chapter":3,"verse":50,"text":"곧 이스라엘 자손의 처음 난 자에게서 받은 돈이 성소의 세겔대로 일천 삼백 육십 오 세겔이라","reference":"민수기 3:50","category":"$undefined"},{"id":"3744","book":"민수기","book_name":"민수기","chapter":3,"verse":51,"text":"이 속전을 여호와의 말씀대로 아론과 그 아들들에게 주었으니 여호와께서 모세에게 명하심과 같았느니라","reference":"민수기 3:51","category":"$undefined"}],"bookSlug":"numbers"}]
