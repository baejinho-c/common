2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":30,"verses":[{"id":"4650","book":"민수기","book_name":"민수기","chapter":30,"verse":1,"text":"모세가 이스라엘 자손 지파의 두령들에게 일러 가로되 여호와의 명령이 이러하니라","reference":"민수기 30:1","category":"$undefined"},{"id":"4651","book":"민수기","book_name":"민수기","chapter":30,"verse":2,"text":"사람이 여호와께 서원하였거나 마음을 제어하기로 서약하였거든 파약하지 말고 그 입에서 나온 대로 다 행할 것이니라","reference":"민수기 30:2","category":"$undefined"},{"id":"4652","book":"민수기","book_name":"민수기","chapter":30,"verse":3,"text":"또 여자가 만일 어려서 그 아비 집에 있을 때에 여호와께 서원한 일이나 스스로 제어하려 한 일이 있다 하자","reference":"민수기 30:3","category":"$undefined"},{"id":"4653","book":"민수기","book_name":"민수기","chapter":30,"verse":4,"text":"그 아비가 그의 서원이나 그 마음을 제어하려는 서약을 듣고도 그에게 아무 말이 없으면 그 모든 서원을 행할 것이요 그 마음을 제어하려는 서약을 지킬 것이니라","reference":"민수기 30:4","category":"$undefined"},{"id":"4654","book":"민수기","book_name":"민수기","chapter":30,"verse":5,"text":"그러나 그 아비가 그것을 듣는 날에 허락지 아니하면 그 서원과 마음을 제어하려던 서약이 이루지 못할 것이니 그 아비가 허락지 아니하였은즉 여호와께서 사하시리라","reference":"민수기 30:5","category":"$undefined"},{"id":"4655","book":"민수기","book_name":"민수기","chapter":30,"verse":6,"text":"또 혹시 남편을 맞을 때에 서원이나 마음을 제어 하려는 서약을 경솔히 그 입에서 발하였다 하자","reference":"민수기 30:6","category":"$undefined"},{"id":"4656","book":"민수기","book_name":"민수기","chapter":30,"verse":7,"text":"그 남편이 그것을 듣고 그 듣는 날에 그에게 아무 말이 없으면 그 서원을 행할 것이요 그 마음을 제어하려는 서약을 지킬 것이니라","reference":"민수기 30:7","category":"$undefined"},{"id":"4657","book":"민수기","book_name":"민수기","chapter":30,"verse":8,"text":"그러나 그 남편이 그것을 듣는 날에 허락지 아니하면 그 서원과 마음을 제어하려고 경솔히 입술에서 발한 서약이 무효될 것이니 여호와께서 그 여자를 사하시리라","reference":"민수기 30:8","category":"$undefined"},{"id":"4658","book":"민수기","book_name":"민수기","chapter":30,"verse":9,"text":"과부나 이혼당한 여자의 서원이나 무릇 그 마음을 제어하려는 서약은 지킬 것이니라","reference":"민수기 30:9","category":"$undefined"},{"id":"4659","book":"민수기","book_name":"민수기","chapter":30,"verse":10,"text":"부녀가 혹시 그 남편의 집에 있어 서원을 하였다든지 마음을 제어하려고 서약하였다 하자","reference":"민수기 30:10","category":"$undefined"},{"id":"4660","book":"민수기","book_name":"민수기","chapter":30,"verse":11,"text":"그 남편이 그것을 듣고도 아무 말이 없고 금함이 없으면 그 서원은 무릇 행할 것이요 그 마음을 제어하려는 서약은 무릇 지킬 것이니라","reference":"민수기 30:11","category":"$undefined"},{"id":"4661","book":"민수기","book_name":"민수기","chapter":30,"verse":12,"text":"그러나 그 남편이 그것을 듣는 날에 무효케 하면 그 서원과 마음을 제어하려던 일에 대하여 입술에서 낸 것을 무엇이든지 이루지 못하나니 그 남편이 그것을 무효케 하였은즉 여호와께서 그 부녀를 사하시느니라","reference":"민수기 30:12","category":"$undefined"},{"id":"4662","book":"민수기","book_name":"민수기","chapter":30,"verse":13,"text":"무릇 서원과 무릇 마음을 괴롭게 하려는 서약은 그 남편이 그것을 지키게도 할 수 있고 무효케도 할 수 있나니","reference":"민수기 30:13","category":"$undefined"},{"id":"4663","book":"민수기","book_name":"민수기","chapter":30,"verse":14,"text":"그 남편이 일향 말이 없으면 아내의 서원과 스스로 제어하려는 일을 지키게 하는 것이니 이는 그가 그것을 들을 때에 그 아내에게 아무 말도 아니하였으므로 지키게 됨이니라","reference":"민수기 30:14","category":"$undefined"},{"id":"4664","book":"민수기","book_name":"민수기","chapter":30,"verse":15,"text":"그러나 그 남편이 들은 지 얼마 후에 그것을 무효케 하면 그가 아내의 죄를 담당할 것이니라","reference":"민수기 30:15","category":"$undefined"},{"id":"4665","book":"민수기","book_name":"민수기","chapter":30,"verse":16,"text":"이는 여호와께서 모세에게 명하신 율례니 남편이 아내에게, 아비가 자기 집에 있는 유년 여자에게 대한 것이니라","reference":"민수기 30:16","category":"$undefined"}],"bookSlug":"numbers"}]
