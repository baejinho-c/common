2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":31,"verses":[{"id":"4666","book":"민수기","book_name":"민수기","chapter":31,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 31:1","category":"$undefined"},{"id":"4667","book":"민수기","book_name":"민수기","chapter":31,"verse":2,"text":"이스라엘 자손의 원수를 미디안에게 갚으라 그 후에 네가 네 조상에게로 돌아가리라","reference":"민수기 31:2","category":"$undefined"},{"id":"4668","book":"민수기","book_name":"민수기","chapter":31,"verse":3,"text":"모세가 백성에게 일러 가로되 `너희 중에서 사람을 택하여 싸움에 나갈 준비를 시키고 미디안을 치러 보내어서 여호와의 원수를 미디안에게 갚되","reference":"민수기 31:3","category":"$undefined"},{"id":"4669","book":"민수기","book_name":"민수기","chapter":31,"verse":4,"text":"이스라엘 모든 지파에 대하여 각 지파에서 일천인씩을 싸움에 보낼지니라' 하매","reference":"민수기 31:4","category":"$undefined"},{"id":"4670","book":"민수기","book_name":"민수기","chapter":31,"verse":5,"text":"매 지파에서 일천인씩 이스라엘 천만인 중에서 일만 이천인을 택하여 무장을 시킨지라","reference":"민수기 31:5","category":"$undefined"},{"id":"4671","book":"민수기","book_name":"민수기","chapter":31,"verse":6,"text":"모세가 매 지파에 일천인씩 싸움에 보내되 제사장 엘르아살의 아들 비느하스에게 성소의 기구와 신호 나팔을 들려서 그들과 함께 싸움에 보내매","reference":"민수기 31:6","category":"$undefined"},{"id":"4672","book":"민수기","book_name":"민수기","chapter":31,"verse":7,"text":"그들이 여호와께서 모세에게 명하신 대로 미디안을 쳐서 그 남자를 다 죽였고","reference":"민수기 31:7","category":"$undefined"},{"id":"4673","book":"민수기","book_name":"민수기","chapter":31,"verse":8,"text":"그 죽인 자 외에 미디안의 다섯 왕을 죽였으니 미디안의 왕들은 에위와, 레겜과, 수르와, 후르와, 레바이며 또 브올의 아들 발람을 칼로 죽였더라","reference":"민수기 31:8","category":"$undefined"},{"id":"4674","book":"민수기","book_name":"민수기","chapter":31,"verse":9,"text":"이스라엘 자손이 미디안의 부녀들과 그 아이들을 사로잡고 그 가축과 양떼와 재물을 다 탈취하고","reference":"민수기 31:9","category":"$undefined"},{"id":"4675","book":"민수기","book_name":"민수기","chapter":31,"verse":10,"text":"그 거처하는 성읍들과 촌락을 다 불사르고","reference":"민수기 31:10","category":"$undefined"},{"id":"4676","book":"민수기","book_name":"민수기","chapter":31,"verse":11,"text":"탈취한 것, 노략한 것, 사람과, 짐승을 다 취하니라","reference":"민수기 31:11","category":"$undefined"},{"id":"4677","book":"민수기","book_name":"민수기","chapter":31,"verse":12,"text":"그들이 사로잡은 자와 노략한 것과 탈취한 것을 가지고 여리고 맞은편 요단 가 모압 평지의 진에 이르러 모세와 제사장 엘르아살과 이스라엘 자손의 회중에게로 나아오니라","reference":"민수기 31:12","category":"$undefined"},{"id":"4678","book":"민수기","book_name":"민수기","chapter":31,"verse":13,"text":"모세와 제사장 엘르아살과 회중의 족장들이 다 진 밖에 나가서 영접하다가","reference":"민수기 31:13","category":"$undefined"},{"id":"4679","book":"민수기","book_name":"민수기","chapter":31,"verse":14,"text":"모세가 군대의 장관 곧 싸움에서 돌아온 천부장들과 백부장들에게 노하니라","reference":"민수기 31:14","category":"$undefined"},{"id":"4680","book":"민수기","book_name":"민수기","chapter":31,"verse":15,"text":"모세가 그들에게 이르되 너희가 여자들을 다 살려두었느냐 ?","reference":"민수기 31:15","category":"$undefined"},{"id":"4681","book":"민수기","book_name":"민수기","chapter":31,"verse":16,"text":"보라 이들이 발람의 꾀를 좇아 이스라엘 자손으로 브올의 사건에 여호와 앞에 범죄케 하여 여호와의 회중에 염병이 일어나게 하였느니라","reference":"민수기 31:16","category":"$undefined"},{"id":"4682","book":"민수기","book_name":"민수기","chapter":31,"verse":17,"text":"그러므로 아이들 중에 남자는 다 죽이고 남자와 동침하여 사내를 안 여자는 다 죽이고","reference":"민수기 31:17","category":"$undefined"},{"id":"4683","book":"민수기","book_name":"민수기","chapter":31,"verse":18,"text":"남자와 동침하지 아니하여 사내를 알지 못하는 여자들은 다 너희를 위하여 살려둘 것이니라","reference":"민수기 31:18","category":"$undefined"},{"id":"4684","book":"민수기","book_name":"민수기","chapter":31,"verse":19,"text":"너희는 칠일동안 진 밖에 주둔하라 무릇 살인자나 죽임을 당한 시체를 만진 자나 제 삼일과 제 칠일에 몸을 깨끗케 하고 너희의 포로도 깨끗케 할 것이며","reference":"민수기 31:19","category":"$undefined"},{"id":"4685","book":"민수기","book_name":"민수기","chapter":31,"verse":20,"text":"무릇 의복과 무릇 가죽으로 만든 것과 무릇 염소 털로 만든 것과 무릇 나무로 만든 것을 다 깨끗케 할지니라","reference":"민수기 31:20","category":"$undefined"},{"id":"4686","book":"민수기","book_name":"민수기","chapter":31,"verse":21,"text":"제사장 엘르아살이 싸움에 나갔던 군인들에게 이르되 `이는 여호와께서 모세에게 명하신 법률이니라","reference":"민수기 31:21","category":"$undefined"},{"id":"4687","book":"민수기","book_name":"민수기","chapter":31,"verse":22,"text":"금, 은, 동, 철과 상납과 납의","reference":"민수기 31:22","category":"$undefined"},{"id":"4688","book":"민수기","book_name":"민수기","chapter":31,"verse":23,"text":"무릇 불에 견딜 만한 물건은 불을 지나게 하라 그리하면 깨끗하려니와 오히려 정결케 하는 물로 그것을 깨끗케 할 것이며 무릇 불에 견디지 못할 모든 것은 물을 지나게 할 것이니라","reference":"민수기 31:23","category":"$undefined"},{"id":"4689","book":"민수기","book_name":"민수기","chapter":31,"verse":24,"text":"너희는 제 칠일에 옷을 빨아서 깨끗케 한 후에 진에 들어 올지니라'","reference":"민수기 31:24","category":"$undefined"},{"id":"4690","book":"민수기","book_name":"민수기","chapter":31,"verse":25,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 31:25","category":"$undefined"},{"id":"4691","book":"민수기","book_name":"민수기","chapter":31,"verse":26,"text":"너는 제사장 엘르아살과 회중의 족장들을 더불어 이 탈취한 사람과 짐승을 계수하고","reference":"민수기 31:26","category":"$undefined"},{"id":"4692","book":"민수기","book_name":"민수기","chapter":31,"verse":27,"text":"그 얻은 물건을 반분하여 그 절반은 싸움에 나갔던 군인들에게 주고 절반은 회중에게 주고","reference":"민수기 31:27","category":"$undefined"},{"id":"4693","book":"민수기","book_name":"민수기","chapter":31,"verse":28,"text":"싸움에 나갔던 군인들로는 사람이나 소나 나귀나 양떼의 오백분지 일을 여호와께 드리게 하되","reference":"민수기 31:28","category":"$undefined"},{"id":"4694","book":"민수기","book_name":"민수기","chapter":31,"verse":29,"text":"곧 이를 그들의 절반에서 취하여 여호와의 거제로 제사장 엘르아살에게 주고","reference":"민수기 31:29","category":"$undefined"},{"id":"4695","book":"민수기","book_name":"민수기","chapter":31,"verse":30,"text":"또 이스라엘 자손의 얻은 절반에서는 사람이나 소나 나귀나 양떼나 각종 짐승을 오십분지 일을 취하여 여호와의 성막을 맡은 레위인에게 주라","reference":"민수기 31:30","category":"$undefined"},{"id":"4696","book":"민수기","book_name":"민수기","chapter":31,"verse":31,"text":"모세와 제사장 엘르아살이 여호와께서 모세에게 명하신 대로 하니라","reference":"민수기 31:31","category":"$undefined"},{"id":"4697","book":"민수기","book_name":"민수기","chapter":31,"verse":32,"text":"그 탈취물 곧 군인들의 다른 탈취물 외에 양이 육십 칠만 오천이요","reference":"민수기 31:32","category":"$undefined"},{"id":"4698","book":"민수기","book_name":"민수기","chapter":31,"verse":33,"text":"소가 칠만 이천이요","reference":"민수기 31:33","category":"$undefined"},{"id":"4699","book":"민수기","book_name":"민수기","chapter":31,"verse":34,"text":"나귀가 육만 일천이요","reference":"민수기 31:34","category":"$undefined"},{"id":"4700","book":"민수기","book_name":"민수기","chapter":31,"verse":35,"text":"사람은 남자와 동침하지 아니하여서 사내를 알지 못하는 여자가 도합 삼만 이천이니","reference":"민수기 31:35","category":"$undefined"},{"id":"4701","book":"민수기","book_name":"민수기","chapter":31,"verse":36,"text":"그 절반 곧 싸움에 나갔던 자들의 소유가 양이 삼십 삼만 칠천 오백이라","reference":"민수기 31:36","category":"$undefined"},{"id":"4702","book":"민수기","book_name":"민수기","chapter":31,"verse":37,"text":"여호와께 세로 드린 양이 육백 칠십 오요","reference":"민수기 31:37","category":"$undefined"},{"id":"4703","book":"민수기","book_name":"민수기","chapter":31,"verse":38,"text":"소가 삼만 육천이라 그 중에서 여호와께 세로 드린 것이 칠십 이두요","reference":"민수기 31:38","category":"$undefined"},{"id":"4704","book":"민수기","book_name":"민수기","chapter":31,"verse":39,"text":"나귀가 삼만 오백이라 그 중에서 여호와께 세로 드린 것이 육십 일이요","reference":"민수기 31:39","category":"$undefined"},{"id":"4705","book":"민수기","book_name":"민수기","chapter":31,"verse":40,"text":"사람이 일만 육천이라 그 중에서 여호와께 세로 드린 자가 삼십 이명이니","reference":"민수기 31:40","category":"$undefined"},{"id":"4706","book":"민수기","book_name":"민수기","chapter":31,"verse":41,"text":"여호와께 거제의 세로 드린 것을 모세가 제사장 엘르아살에게 주었으니 여호와께서 모세에게 명하심과 같았더라","reference":"민수기 31:41","category":"$undefined"},{"id":"4707","book":"민수기","book_name":"민수기","chapter":31,"verse":42,"text":"모세가 싸움에 나갔던 자에게서 나누어 취하여 이스라엘 자손에게 준 절반","reference":"민수기 31:42","category":"$undefined"},{"id":"4708","book":"민수기","book_name":"민수기","chapter":31,"verse":43,"text":"곧 회중의 얻은 절반은 양이 삼십 삼만 칠천 오백이요","reference":"민수기 31:43","category":"$undefined"},{"id":"4709","book":"민수기","book_name":"민수기","chapter":31,"verse":44,"text":"소가 삼만 육천이요","reference":"민수기 31:44","category":"$undefined"},{"id":"4710","book":"민수기","book_name":"민수기","chapter":31,"verse":45,"text":"나귀가 삼만 오백이요","reference":"민수기 31:45","category":"$undefined"},{"id":"4711","book":"민수기","book_name":"민수기","chapter":31,"verse":46,"text":"사람이 일만 육천이라","reference":"민수기 31:46","category":"$undefined"},{"id":"4712","book":"민수기","book_name":"민수기","chapter":31,"verse":47,"text":"이스라엘 자손의 그 절반에서 모세가 사람이나 짐승의 오십분지 일을 취하여 여호와의 장막을 맡은 레위인에게 주었으니 여호와께서 모세에게 명하심과 같았더라","reference":"민수기 31:47","category":"$undefined"},{"id":"4713","book":"민수기","book_name":"민수기","chapter":31,"verse":48,"text":"군대의 장관들 곧 천부장과 백부장들이 모세에게 나아와서","reference":"민수기 31:48","category":"$undefined"},{"id":"4714","book":"민수기","book_name":"민수기","chapter":31,"verse":49,"text":"그에게 고하되 `당신의 종들의 영솔한 군인을 계수한즉 우리 중 한 사람도 축나지 아니하였기로","reference":"민수기 31:49","category":"$undefined"},{"id":"4715","book":"민수기","book_name":"민수기","chapter":31,"verse":50,"text":"우리 각 사람의 얻은 바 금 패물 곧 발목고리, 손목고리, 인장반지, 귀고리, 팔고리들을 여호와의 예물로 우리의 생명을 위하여 여호와 앞에 속죄하려고 가져왔나이다'","reference":"민수기 31:50","category":"$undefined"},{"id":"4716","book":"민수기","book_name":"민수기","chapter":31,"verse":51,"text":"모세와 제사장 엘르아살이 그들에게서 그 금으로 만든 모든 패물을 취한즉","reference":"민수기 31:51","category":"$undefined"},{"id":"4717","book":"민수기","book_name":"민수기","chapter":31,"verse":52,"text":"천부장과 백부장들이 여호와께 드린 거제의 금의 도합이 일만 육천 칠백 오십 세겔이니","reference":"민수기 31:52","category":"$undefined"},{"id":"4718","book":"민수기","book_name":"민수기","chapter":31,"verse":53,"text":"군인들이 각기 자기를 위하여 탈취한 것이라","reference":"민수기 31:53","category":"$undefined"},{"id":"4719","book":"민수기","book_name":"민수기","chapter":31,"verse":54,"text":"모세와 제사장 엘르아살이 천부장과 백부장들에게서 금을 취하여 회막에 드려서 여호와 앞에 이스라엘 자손의 기념을 삼았더라","reference":"민수기 31:54","category":"$undefined"}],"bookSlug":"numbers"}]
