2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":32,"verses":[{"id":"4720","book":"민수기","book_name":"민수기","chapter":32,"verse":1,"text":"르우벤 자손과 갓 자손은 심히 많은 가축 떼가 있었더라 그들이 야셀 땅과 길르앗 땅을 본즉 그 곳은 가축에 적당한 곳인지라","reference":"민수기 32:1","category":"$undefined"},{"id":"4721","book":"민수기","book_name":"민수기","chapter":32,"verse":2,"text":"갓 자손과 르우벤 자손이 와서 모세와 제사장 엘르아살과 회중 족장들에게 말하여 가로되","reference":"민수기 32:2","category":"$undefined"},{"id":"4722","book":"민수기","book_name":"민수기","chapter":32,"verse":3,"text":"`아다롯과, 디본과, 야셀과, 니므라와, 헤스본과, 엘르알레와, 스밤과, 느보와, 브온","reference":"민수기 32:3","category":"$undefined"},{"id":"4723","book":"민수기","book_name":"민수기","chapter":32,"verse":4,"text":"곧 여호와께서 이스라엘 회중 앞에서 쳐서 멸하신 땅은 가축에 적당한 곳이요 당신의 종들에게는 가축이 있나이다'","reference":"민수기 32:4","category":"$undefined"},{"id":"4724","book":"민수기","book_name":"민수기","chapter":32,"verse":5,"text":"또 가로되 `우리가 만일 당신에게 은혜를 입었으면 이 땅을 당신의 종들에게 산업으로 주시고 우리로 요단을 건너지 않게 하소서'","reference":"민수기 32:5","category":"$undefined"},{"id":"4725","book":"민수기","book_name":"민수기","chapter":32,"verse":6,"text":"모세가 갓 자손과 르우벤 자손에게 이르되 `너희 형제들은 싸우러 가거늘 너희는 여기 앉았고자 하느냐 ?","reference":"민수기 32:6","category":"$undefined"},{"id":"4726","book":"민수기","book_name":"민수기","chapter":32,"verse":7,"text":"너희가 어찌하여 이스라엘 자손으로 낙심케 하여서 여호와께서 그들에게 주신 땅으로 건너갈 수 없게 하려느냐 ?","reference":"민수기 32:7","category":"$undefined"},{"id":"4727","book":"민수기","book_name":"민수기","chapter":32,"verse":8,"text":"너희 열조도 내가 가데스바네아에서 그 땅을 보라고 보내었을 때에 그리하였었나니","reference":"민수기 32:8","category":"$undefined"},{"id":"4728","book":"민수기","book_name":"민수기","chapter":32,"verse":9,"text":"그들이 에스골 골짜기에 올라가서 그 땅을 보고 이스라엘 자손으로 낙심케 하여서 여호와께서 그들에게 주신 땅으로 갈 수 없게 하였었느니라","reference":"민수기 32:9","category":"$undefined"},{"id":"4729","book":"민수기","book_name":"민수기","chapter":32,"verse":10,"text":"그때에 여호와께서 진노하사 맹세하여 가라사대","reference":"민수기 32:10","category":"$undefined"},{"id":"4730","book":"민수기","book_name":"민수기","chapter":32,"verse":11,"text":"애굽에서 나온 자들의 이십세 이상으로는 한 사람도 내가 아브라함과 이삭과 야곱에게 맹세한 땅을 정녕히 보지 못하리니 이는 그들이 나를 온전히 순종치 아니하였음이니라","reference":"민수기 32:11","category":"$undefined"},{"id":"4731","book":"민수기","book_name":"민수기","chapter":32,"verse":12,"text":"다만 그나스 사람 여분네의 아들 갈렙과 눈의 아들 여호수아는 볼 것은 여호와를 온전히 순종하였음이니라 하시고","reference":"민수기 32:12","category":"$undefined"},{"id":"4732","book":"민수기","book_name":"민수기","chapter":32,"verse":13,"text":"여호와께서 이스라엘에게 진노하사 그들로 사십년 동안 광야에 유리하게 하심으로 여호와의 목전에 악을 행한 그 세대가 필경은 다 소멸하였느니라","reference":"민수기 32:13","category":"$undefined"},{"id":"4733","book":"민수기","book_name":"민수기","chapter":32,"verse":14,"text":"보라, 너희는 너희의 열조를 계대하여 일어난 죄인의 종류로서 이스라엘을 향하신 여호와의 노를 더욱 심하게 하는도다","reference":"민수기 32:14","category":"$undefined"},{"id":"4734","book":"민수기","book_name":"민수기","chapter":32,"verse":15,"text":"너희가 만일 돌이켜 여호와를 떠나면 여호와께서 또 이 백성을 광야에 버리시리니 그리하면 너희가 이 모든 백성을 멸망시키리라'","reference":"민수기 32:15","category":"$undefined"},{"id":"4735","book":"민수기","book_name":"민수기","chapter":32,"verse":16,"text":"그들이 모세에게 가까이 나아와 가로되 `우리가 이 곳에 우리 가축을 위하여 우리를 짓고 우리 유아들을 위하여 성읍을 건축하고","reference":"민수기 32:16","category":"$undefined"},{"id":"4736","book":"민수기","book_name":"민수기","chapter":32,"verse":17,"text":"이 땅 거민의 연고로 우리 유아들로 그 견고한 성읍에 거하게 한후에 우리는 무장하고 이스라엘 자손을 그 곳으로 인도하기까지 그들의 앞에 행하고","reference":"민수기 32:17","category":"$undefined"},{"id":"4737","book":"민수기","book_name":"민수기","chapter":32,"verse":18,"text":"이스라엘 자손이 각기 기업을 얻기까지 우리 집으로 돌아오지 아니하겠사오며","reference":"민수기 32:18","category":"$undefined"},{"id":"4738","book":"민수기","book_name":"민수기","chapter":32,"verse":19,"text":"우리는 요단 이편 곧 동편에서 산업을 얻었사오니 그들과 함께 요단 저편에서는 기업을 얻지 아니하겠나이다'","reference":"민수기 32:19","category":"$undefined"},{"id":"4739","book":"민수기","book_name":"민수기","chapter":32,"verse":20,"text":"모세가 그들에게 이르되 `너희가 만일 이 일을 행하여 무장하고 여호와 앞에서 가서 싸우되","reference":"민수기 32:20","category":"$undefined"},{"id":"4740","book":"민수기","book_name":"민수기","chapter":32,"verse":21,"text":"너희가 다 무장하고 여호와 앞에서 요단을 건너가서 여호와께서 그 원수를 자기 앞에서 쫓아내시고","reference":"민수기 32:21","category":"$undefined"},{"id":"4741","book":"민수기","book_name":"민수기","chapter":32,"verse":22,"text":"그 땅으로 여호와 앞에 복종케 하시기까지 싸우면 여호와의 앞에서나 이스라엘의 앞에서나 무죄히 돌아오겠고 이 땅은 여호와 앞에서 너희의 산업이 되리라마는","reference":"민수기 32:22","category":"$undefined"},{"id":"4742","book":"민수기","book_name":"민수기","chapter":32,"verse":23,"text":"너희가 만일 그같이 아니하면 여호와께 범죄함이니 너희 죄가 정녕 너희를 찾아낼 줄알라","reference":"민수기 32:23","category":"$undefined"},{"id":"4743","book":"민수기","book_name":"민수기","chapter":32,"verse":24,"text":"너희는 유아들을 위하여 성읍을 건축하고 양을 위하여 우리를 지으라 그리하고 너희 입에서 낸 대로 행하라'","reference":"민수기 32:24","category":"$undefined"},{"id":"4744","book":"민수기","book_name":"민수기","chapter":32,"verse":25,"text":"갓 자손과 르우벤 자손이 모세에게 대답하여 가로되 `우리 주의 명대로 종들이 행할 것이라","reference":"민수기 32:25","category":"$undefined"},{"id":"4745","book":"민수기","book_name":"민수기","chapter":32,"verse":26,"text":"우리의 어린 자와 아내와 양떼와 모든 가축은 이곳 길르앗 성읍 들에 두고","reference":"민수기 32:26","category":"$undefined"},{"id":"4746","book":"민수기","book_name":"민수기","chapter":32,"verse":27,"text":"우리 주의 말씀대로 종들은 무장하고 여호와 앞에서 다 건너가서 싸우리이다'","reference":"민수기 32:27","category":"$undefined"},{"id":"4747","book":"민수기","book_name":"민수기","chapter":32,"verse":28,"text":"이에 모세가 그들에게 대하여 제사장 엘르아살과 눈의 아들 여호수아와 이스라엘 자손 지파의 두령들에게 명하니라","reference":"민수기 32:28","category":"$undefined"},{"id":"4748","book":"민수기","book_name":"민수기","chapter":32,"verse":29,"text":"모세가 그들에게 이르되 `갓 자손과 르우벤 자손이 만일 각기 무장하고 너희와 함께 요단을 건너가서 여호와 앞에서 싸워서 그 땅이 너희 앞에 항복하기에 이르거든 길르앗 땅을 그들에게 산업으로 줄 것이니라","reference":"민수기 32:29","category":"$undefined"},{"id":"4749","book":"민수기","book_name":"민수기","chapter":32,"verse":30,"text":"그러나 그들이 만일 너희와 함께 무장하고 건너지 아니하거든 가나안 땅에서 너희 중에 산업을 줄 것이니라'","reference":"민수기 32:30","category":"$undefined"},{"id":"4750","book":"민수기","book_name":"민수기","chapter":32,"verse":31,"text":"갓 자손과 르우벤 자손이 대답하여 가로되 `여호와께서 당신의 종들에게 명하신 대로 우리가 행할 것이라","reference":"민수기 32:31","category":"$undefined"},{"id":"4751","book":"민수기","book_name":"민수기","chapter":32,"verse":32,"text":"우리가 무장하고 여호와 앞에서 가나안 땅에 건너가서 요단 이편으로 우리의 산업이 되게 하리이다'","reference":"민수기 32:32","category":"$undefined"},{"id":"4752","book":"민수기","book_name":"민수기","chapter":32,"verse":33,"text":"모세가 갓 자손과 르우벤 자손과 요셉의 아들 므낫세 반 지파에게 아모리인의 왕 시혼의 국토와 바산 왕 옥의 국토를 주되 곧 그 나라와 그 경내 성읍들과 그 성읍들의 사면 땅을 그들에게 주매","reference":"민수기 32:33","category":"$undefined"},{"id":"4753","book":"민수기","book_name":"민수기","chapter":32,"verse":34,"text":"갓 자손은 디본과, 아다롯과, 아로엘과","reference":"민수기 32:34","category":"$undefined"},{"id":"4754","book":"민수기","book_name":"민수기","chapter":32,"verse":35,"text":"아다롯소반과, 야셀과, 욕브하와","reference":"민수기 32:35","category":"$undefined"},{"id":"4755","book":"민수기","book_name":"민수기","chapter":32,"verse":36,"text":"벧니므라와, 벧하란들의 견고한 성읍을 건축하였고 또 양을 위하여 우리를 지었으며","reference":"민수기 32:36","category":"$undefined"},{"id":"4756","book":"민수기","book_name":"민수기","chapter":32,"verse":37,"text":"르우벤 자손은 헤스본과, 엘르알레와, 기랴다임과","reference":"민수기 32:37","category":"$undefined"},{"id":"4757","book":"민수기","book_name":"민수기","chapter":32,"verse":38,"text":"느보와 바알므온들을 건축하고 그 이름을 고쳤고 또 십마를 건축하고 건축한 성읍들에 새 이름을 주었고","reference":"민수기 32:38","category":"$undefined"},{"id":"4758","book":"민수기","book_name":"민수기","chapter":32,"verse":39,"text":"므낫세의 아들 마길의 자손은 가서 길르앗을 쳐서 취하고 거기 있는 아모리인을 쫓아내매","reference":"민수기 32:39","category":"$undefined"},{"id":"4759","book":"민수기","book_name":"민수기","chapter":32,"verse":40,"text":"모세가 길르앗을 므낫세의 아들 마길에게 주매 그가 거기 거하였고","reference":"민수기 32:40","category":"$undefined"},{"id":"4760","book":"민수기","book_name":"민수기","chapter":32,"verse":41,"text":"므낫세의 아들 야일은 가서 그 촌락들을 취하고 [하봇야일]이라 칭하였으며","reference":"민수기 32:41","category":"$undefined"},{"id":"4761","book":"민수기","book_name":"민수기","chapter":32,"verse":42,"text":"노바는 가서 그낫과 그 향촌을 취하고 자기 이름을 따라서 [노바]라 칭하였더라","reference":"민수기 32:42","category":"$undefined"}],"bookSlug":"numbers"}]
