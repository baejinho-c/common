2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":33,"verses":[{"id":"4762","book":"민수기","book_name":"민수기","chapter":33,"verse":1,"text":"이스라엘 자손이 모세와 아론의 관할하에 그 항오대로 애굽 땅에서 나오던 때의 노정이 이러하니라","reference":"민수기 33:1","category":"$undefined"},{"id":"4763","book":"민수기","book_name":"민수기","chapter":33,"verse":2,"text":"모세가 여호와의 명대로 그 노정을 따라 그 진행한 것을 기록하였으니 그 진행한 대로 그 노정은 이러하니라","reference":"민수기 33:2","category":"$undefined"},{"id":"4764","book":"민수기","book_name":"민수기","chapter":33,"verse":3,"text":"그들이 정월 십오일에 라암셋에서 발행하였으니 곧 유월절 다음날이라 이스라엘 자손이 애굽 모든 사람의 목전에서 큰 권능으로 나왔으니","reference":"민수기 33:3","category":"$undefined"},{"id":"4765","book":"민수기","book_name":"민수기","chapter":33,"verse":4,"text":"애굽인은 여호와께서 그들 중에 치신 그 모든 장자를 장사하는 때라 여호와께서 그들의 신들에게도 벌을 주셨더라","reference":"민수기 33:4","category":"$undefined"},{"id":"4766","book":"민수기","book_name":"민수기","chapter":33,"verse":5,"text":"이스라엘 자손이 라암셋에서 발행하여 숙곳에 진 쳤고","reference":"민수기 33:5","category":"$undefined"},{"id":"4767","book":"민수기","book_name":"민수기","chapter":33,"verse":6,"text":"숙곳에서 발행하여 광야 끝 에담에 진 쳤고","reference":"민수기 33:6","category":"$undefined"},{"id":"4768","book":"민수기","book_name":"민수기","chapter":33,"verse":7,"text":"에담에서 발행하여 바알스본 앞 비하히롯으로 돌아가서 믹돌 앞에 진 쳤고","reference":"민수기 33:7","category":"$undefined"},{"id":"4769","book":"민수기","book_name":"민수기","chapter":33,"verse":8,"text":"하히롯 앞에서 발행하여 바다 가운데로 지나 광야에 이르고 에담 광야로 삼일 길쯤 들어가서 마라에 진 쳤고","reference":"민수기 33:8","category":"$undefined"},{"id":"4770","book":"민수기","book_name":"민수기","chapter":33,"verse":9,"text":"마라에서 발행하여 엘림에 이르니 엘림에는 샘물 열 둘과 종려 칠십 주가 있으므로 거기 진 쳤고","reference":"민수기 33:9","category":"$undefined"},{"id":"4771","book":"민수기","book_name":"민수기","chapter":33,"verse":10,"text":"엘림에서 발행하여 홍해 가에 진 쳤고","reference":"민수기 33:10","category":"$undefined"},{"id":"4772","book":"민수기","book_name":"민수기","chapter":33,"verse":11,"text":"홍해 가에서 발행하여 신 광야에 진 쳤고","reference":"민수기 33:11","category":"$undefined"},{"id":"4773","book":"민수기","book_name":"민수기","chapter":33,"verse":12,"text":"신 광야에서 발행하여","reference":"민수기 33:12","category":"$undefined"},{"id":"4774","book":"민수기","book_name":"민수기","chapter":33,"verse":13,"text":"돕 가에 진 쳤고 돕가에서 발행하여 알루스에 진 쳤고","reference":"민수기 33:13","category":"$undefined"},{"id":"4775","book":"민수기","book_name":"민수기","chapter":33,"verse":14,"text":"알루스에서 발행하여 르비딤에 진 쳤는데 거기는 백성의 마실 물이 없었더라","reference":"민수기 33:14","category":"$undefined"},{"id":"4776","book":"민수기","book_name":"민수기","chapter":33,"verse":15,"text":"르비딤에서 발행하여 시내 광야에 진 쳤고","reference":"민수기 33:15","category":"$undefined"},{"id":"4777","book":"민수기","book_name":"민수기","chapter":33,"verse":16,"text":"시내 광야에서 발행하여 기브롯핫다아와에 진 쳤고","reference":"민수기 33:16","category":"$undefined"},{"id":"4778","book":"민수기","book_name":"민수기","chapter":33,"verse":17,"text":"기브롯핫다아와에서 발행하여 하세롯에 진 쳤고","reference":"민수기 33:17","category":"$undefined"},{"id":"4779","book":"민수기","book_name":"민수기","chapter":33,"verse":18,"text":"하세롯에서 발행하여 릿마에 진 쳤고","reference":"민수기 33:18","category":"$undefined"},{"id":"4780","book":"민수기","book_name":"민수기","chapter":33,"verse":19,"text":"릿마에서 발행하여 림몬베레스에 진 쳤고","reference":"민수기 33:19","category":"$undefined"},{"id":"4781","book":"민수기","book_name":"민수기","chapter":33,"verse":20,"text":"림몬베레스에서 발행하여 립나에 진 쳤고","reference":"민수기 33:20","category":"$undefined"},{"id":"4782","book":"민수기","book_name":"민수기","chapter":33,"verse":21,"text":"립나에서 발행하여 릿사에 진 쳤고","reference":"민수기 33:21","category":"$undefined"},{"id":"4783","book":"민수기","book_name":"민수기","chapter":33,"verse":22,"text":"릿사에서 발행하여 그헬라다에 진 쳤고","reference":"민수기 33:22","category":"$undefined"},{"id":"4784","book":"민수기","book_name":"민수기","chapter":33,"verse":23,"text":"그헬라다에서 발행하여 세벨산에 진 쳤고","reference":"민수기 33:23","category":"$undefined"},{"id":"4785","book":"민수기","book_name":"민수기","chapter":33,"verse":24,"text":"세벨산에서 발행하여 하라다에 진 쳤고","reference":"민수기 33:24","category":"$undefined"},{"id":"4786","book":"민수기","book_name":"민수기","chapter":33,"verse":25,"text":"하라다에서 발행하여 막헬롯에 진 쳤고","reference":"민수기 33:25","category":"$undefined"},{"id":"4787","book":"민수기","book_name":"민수기","chapter":33,"verse":26,"text":"막헬롯에서 발행하여 다핫에 진 쳤고","reference":"민수기 33:26","category":"$undefined"},{"id":"4788","book":"민수기","book_name":"민수기","chapter":33,"verse":27,"text":"다핫에서 발행하여 데라에 진 쳤고","reference":"민수기 33:27","category":"$undefined"},{"id":"4789","book":"민수기","book_name":"민수기","chapter":33,"verse":28,"text":"데라에서 발행하여 밋가에 진 쳤고","reference":"민수기 33:28","category":"$undefined"},{"id":"4790","book":"민수기","book_name":"민수기","chapter":33,"verse":29,"text":"밋가에서 발행하여 하스모나에 진 쳤고","reference":"민수기 33:29","category":"$undefined"},{"id":"4791","book":"민수기","book_name":"민수기","chapter":33,"verse":30,"text":"하스모나에서 발행하여 모세롯에 진 쳤고","reference":"민수기 33:30","category":"$undefined"},{"id":"4792","book":"민수기","book_name":"민수기","chapter":33,"verse":31,"text":"모세롯에서 발행하여 브네야아간에 진 쳤고","reference":"민수기 33:31","category":"$undefined"},{"id":"4793","book":"민수기","book_name":"민수기","chapter":33,"verse":32,"text":"브네야아간에서 발행하여 홀하깃갓에 진 쳤고","reference":"민수기 33:32","category":"$undefined"},{"id":"4794","book":"민수기","book_name":"민수기","chapter":33,"verse":33,"text":"홀하깃갓에서 발행하여 욧바다에 진 쳤고","reference":"민수기 33:33","category":"$undefined"},{"id":"4795","book":"민수기","book_name":"민수기","chapter":33,"verse":34,"text":"욧바다에서 발행하여 아브로나에 진 쳤고","reference":"민수기 33:34","category":"$undefined"},{"id":"4796","book":"민수기","book_name":"민수기","chapter":33,"verse":35,"text":"아브로나에서 발행하여 에시온게벨에 진 쳤고","reference":"민수기 33:35","category":"$undefined"},{"id":"4797","book":"민수기","book_name":"민수기","chapter":33,"verse":36,"text":"에시온게벨에서 발행하여 신 광야 곧 가데스에 진 쳤고","reference":"민수기 33:36","category":"$undefined"},{"id":"4798","book":"민수기","book_name":"민수기","chapter":33,"verse":37,"text":"가데스에서 발행하여 에돔 국경 호르산에 진 쳤더라","reference":"민수기 33:37","category":"$undefined"},{"id":"4799","book":"민수기","book_name":"민수기","chapter":33,"verse":38,"text":"이스라엘 자손이 애굽 땅에서 나온 지 사십년 오월 일일에 제사장 아론이 여호와의 명으로 호르산에 올라가 거기서 죽었으니","reference":"민수기 33:38","category":"$undefined"},{"id":"4800","book":"민수기","book_name":"민수기","chapter":33,"verse":39,"text":"아론이 호르산에서 죽던 때에 나이 일백 이십 삼세이었더라","reference":"민수기 33:39","category":"$undefined"},{"id":"4801","book":"민수기","book_name":"민수기","chapter":33,"verse":40,"text":"가나안 땅 남방에 거한 가나안 사람 아랏 왕이 이스라엘의 옴을 들었더라","reference":"민수기 33:40","category":"$undefined"},{"id":"4802","book":"민수기","book_name":"민수기","chapter":33,"verse":41,"text":"그들이 호르산에서 발행하여 살모나에 진 쳤고","reference":"민수기 33:41","category":"$undefined"},{"id":"4803","book":"민수기","book_name":"민수기","chapter":33,"verse":42,"text":"살모나에서 발행하여 부논에 진 쳤고","reference":"민수기 33:42","category":"$undefined"},{"id":"4804","book":"민수기","book_name":"민수기","chapter":33,"verse":43,"text":"부논에서 발행하여 오봇에 진 쳤고","reference":"민수기 33:43","category":"$undefined"},{"id":"4805","book":"민수기","book_name":"민수기","chapter":33,"verse":44,"text":"오봇에서 발행하여 모압 변경 이예아바림에 진 쳤고","reference":"민수기 33:44","category":"$undefined"},{"id":"4806","book":"민수기","book_name":"민수기","chapter":33,"verse":45,"text":"이임에서 발행하여 디본갓에 진 쳤고","reference":"민수기 33:45","category":"$undefined"},{"id":"4807","book":"민수기","book_name":"민수기","chapter":33,"verse":46,"text":"디본갓에서 발행하여 알몬디블라다임에 진 쳤고","reference":"민수기 33:46","category":"$undefined"},{"id":"4808","book":"민수기","book_name":"민수기","chapter":33,"verse":47,"text":"알몬디블라다임에서 발행하여 느보 앞 아바림 산에 진 쳤고","reference":"민수기 33:47","category":"$undefined"},{"id":"4809","book":"민수기","book_name":"민수기","chapter":33,"verse":48,"text":"아바림 산에서 발행하여 여리고 맞은편 요단 가 모압 평지에 진쳤으니","reference":"민수기 33:48","category":"$undefined"},{"id":"4810","book":"민수기","book_name":"민수기","chapter":33,"verse":49,"text":"요단 가 모압 평지의 진이 벧여시못에서부터 아벨싯딤에 미쳤었더라","reference":"민수기 33:49","category":"$undefined"},{"id":"4811","book":"민수기","book_name":"민수기","chapter":33,"verse":50,"text":"여리고 맞은편 요단 가 모압 평지에서 여호와께서 모세에게 일러 가라사대","reference":"민수기 33:50","category":"$undefined"},{"id":"4812","book":"민수기","book_name":"민수기","chapter":33,"verse":51,"text":"이스라엘 자손에게 말하여 그들에게 이르라 너희가 요단을 건너 가나안 땅에 들어가거든","reference":"민수기 33:51","category":"$undefined"},{"id":"4813","book":"민수기","book_name":"민수기","chapter":33,"verse":52,"text":"그 땅 거민을 너희 앞에서 다 몰아내고 그 새긴 석상과 부어 만든 우상을 다 파멸하며 산당을 다 훼파하고","reference":"민수기 33:52","category":"$undefined"},{"id":"4814","book":"민수기","book_name":"민수기","chapter":33,"verse":53,"text":"그 땅을 취하여 거기 거하라 내가 그 땅을 너희 산업으로 너희에게 주었음이라","reference":"민수기 33:53","category":"$undefined"},{"id":"4815","book":"민수기","book_name":"민수기","chapter":33,"verse":54,"text":"너희의 가족을 따라서 그 땅을 제비뽑아 나눌 것이니 수가 많으면 많은 기업을 주고 적으면 적은 기업을 주되 각기 제비뽑힌 대로 그 소유가 될 것인즉 너희 열조의 지파를 따라 기업을 얻을 것이니라","reference":"민수기 33:54","category":"$undefined"},{"id":"4816","book":"민수기","book_name":"민수기","chapter":33,"verse":55,"text":"너희가 만일 그 땅 거민을 너희 앞에서 몰아내지 아니하면 너희의 남겨둔 자가 너희의 눈에 가시와 너희의 옆구리에 찌르는 것이 되어 너희 거하는 땅에서 너희를 괴롭게 할 것이요","reference":"민수기 33:55","category":"$undefined"},{"id":"4817","book":"민수기","book_name":"민수기","chapter":33,"verse":56,"text":"나는 그들에게 행하기로 생각한 것을 너희에게 행하리라","reference":"민수기 33:56","category":"$undefined"}],"bookSlug":"numbers"}]
