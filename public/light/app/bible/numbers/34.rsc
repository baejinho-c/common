2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":34,"verses":[{"id":"4818","book":"민수기","book_name":"민수기","chapter":34,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 34:1","category":"$undefined"},{"id":"4819","book":"민수기","book_name":"민수기","chapter":34,"verse":2,"text":"너는 이스라엘 자손에게 명하여 그들에게 이르라 너희가 가나안 땅에 들어가는 때에 그 땅은 너희의 기업이 되리니 곧 가나안 사방 지경이라","reference":"민수기 34:2","category":"$undefined"},{"id":"4820","book":"민수기","book_name":"민수기","chapter":34,"verse":3,"text":"너희 남방은 에돔 곁에 접근한 신 광야니 너희 남편 경계는 동편으로 염해 끝에서 시작하여","reference":"민수기 34:3","category":"$undefined"},{"id":"4821","book":"민수기","book_name":"민수기","chapter":34,"verse":4,"text":"돌아서 아그람빔 언덕 남편에 이르고 신을 지나 가데스바네아 남방에 이르고 또 하살아달을 지나 아스몬에 이르고","reference":"민수기 34:4","category":"$undefined"},{"id":"4822","book":"민수기","book_name":"민수기","chapter":34,"verse":5,"text":"아스몬에서 돌아서 애굽 시내를 지나 바다까지 이르느니라","reference":"민수기 34:5","category":"$undefined"},{"id":"4823","book":"민수기","book_name":"민수기","chapter":34,"verse":6,"text":"서편 경계는 대해가 경계가 되나니 이는 너희의 서편 경계니라","reference":"민수기 34:6","category":"$undefined"},{"id":"4824","book":"민수기","book_name":"민수기","chapter":34,"verse":7,"text":"북편 경계는 이러하니 대해에서부터 호르산까지 긋고","reference":"민수기 34:7","category":"$undefined"},{"id":"4825","book":"민수기","book_name":"민수기","chapter":34,"verse":8,"text":"호르산에서 그어 하맛 어귀에 이르러 스닷에 미치고","reference":"민수기 34:8","category":"$undefined"},{"id":"4826","book":"민수기","book_name":"민수기","chapter":34,"verse":9,"text":"그 경계가 또 시브론을 지나 하살에난에 미치나니 이는 너희 북편 경계니라","reference":"민수기 34:9","category":"$undefined"},{"id":"4827","book":"민수기","book_name":"민수기","chapter":34,"verse":10,"text":"너희의 동편 경계는 하살에난에서 그어 스밤에 이르고","reference":"민수기 34:10","category":"$undefined"},{"id":"4828","book":"민수기","book_name":"민수기","chapter":34,"verse":11,"text":"그 경계가 또 스밤에서 리블라로 내려가서 아인 동편에 이르고 또 내려가서 긴네렛 동편 해변에 미치고","reference":"민수기 34:11","category":"$undefined"},{"id":"4829","book":"민수기","book_name":"민수기","chapter":34,"verse":12,"text":"그 경계가 또 요단으로 내려가서 염해에 미치나니 너희 땅의 사방 경계가 이러하니라","reference":"민수기 34:12","category":"$undefined"},{"id":"4830","book":"민수기","book_name":"민수기","chapter":34,"verse":13,"text":"모세가 이스라엘 자손에게 명하여 가로되 `이는 너희가 제비뽑아 얻을 땅이라 여호와께서 이것을 아홉 지파와 반 지파에게 주라고 명하셨나니","reference":"민수기 34:13","category":"$undefined"},{"id":"4831","book":"민수기","book_name":"민수기","chapter":34,"verse":14,"text":"이는 르우벤 자손의 지파와 갓 자손의 지파가 함께 그들의 종족대로 그 기업을 받았고 므낫세의 반 지파도 기업을 받았음이라","reference":"민수기 34:14","category":"$undefined"},{"id":"4832","book":"민수기","book_name":"민수기","chapter":34,"verse":15,"text":"이 두 지파와 반 지파가 여리고 맞은편 요단 건너편 곧 해 돋는 편에서 그 기업을 받았느니라'","reference":"민수기 34:15","category":"$undefined"},{"id":"4833","book":"민수기","book_name":"민수기","chapter":34,"verse":16,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 34:16","category":"$undefined"},{"id":"4834","book":"민수기","book_name":"민수기","chapter":34,"verse":17,"text":"너희에게 땅을 기업으로 나눈 자의 이름이 이러하니 제사장 엘르아살과 눈의 아들 여호수아니라","reference":"민수기 34:17","category":"$undefined"},{"id":"4835","book":"민수기","book_name":"민수기","chapter":34,"verse":18,"text":"너희가 또 기업의 땅을 나누기 위하여 매 지파에 한 족장씩 택하라","reference":"민수기 34:18","category":"$undefined"},{"id":"4836","book":"민수기","book_name":"민수기","chapter":34,"verse":19,"text":"그 사람들의 이름은 이러하니 유다 지파에서는 여분네의 아들 갈렙이요","reference":"민수기 34:19","category":"$undefined"},{"id":"4837","book":"민수기","book_name":"민수기","chapter":34,"verse":20,"text":"시므온 지파에서는 암미훗의 아들 스므엘이요","reference":"민수기 34:20","category":"$undefined"},{"id":"4838","book":"민수기","book_name":"민수기","chapter":34,"verse":21,"text":"베냐민 지파에서는 기슬론의 아들 엘리닷이요","reference":"민수기 34:21","category":"$undefined"},{"id":"4839","book":"민수기","book_name":"민수기","chapter":34,"verse":22,"text":"단 자손의 지파의 족장 요글리의 아들 북기요","reference":"민수기 34:22","category":"$undefined"},{"id":"4840","book":"민수기","book_name":"민수기","chapter":34,"verse":23,"text":"요셉 자손 중 므낫세 자손 지파의 족장 에봇의 아들 한니엘이요","reference":"민수기 34:23","category":"$undefined"},{"id":"4841","book":"민수기","book_name":"민수기","chapter":34,"verse":24,"text":"에브라임 자손 지파의 족장 십단의 아들 그므엘이요","reference":"민수기 34:24","category":"$undefined"},{"id":"4842","book":"민수기","book_name":"민수기","chapter":34,"verse":25,"text":"스블론 자손 지파의 족장 바르삭의 아들 엘리사반이요","reference":"민수기 34:25","category":"$undefined"},{"id":"4843","book":"민수기","book_name":"민수기","chapter":34,"verse":26,"text":"잇사갈 자손 지파의 족장 앗산의 아들 발디엘이요","reference":"민수기 34:26","category":"$undefined"},{"id":"4844","book":"민수기","book_name":"민수기","chapter":34,"verse":27,"text":"아셀 자손 지파의 족장 슬로미의 아들 아히훗이요","reference":"민수기 34:27","category":"$undefined"},{"id":"4845","book":"민수기","book_name":"민수기","chapter":34,"verse":28,"text":"납달리 자손 지파의 족장 암미훗의 아들 브다헬이니라 하셨으니","reference":"민수기 34:28","category":"$undefined"},{"id":"4846","book":"민수기","book_name":"민수기","chapter":34,"verse":29,"text":"여호와께서 명하사 가나안 땅에서 이스라엘 자손에게 기업을 나누게 하신 자들이 이러하였더라","reference":"민수기 34:29","category":"$undefined"}],"bookSlug":"numbers"}]
