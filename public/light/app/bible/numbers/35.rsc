2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":35,"verses":[{"id":"4847","book":"민수기","book_name":"민수기","chapter":35,"verse":1,"text":"여호와께서 여리고 맞은편 요단 가 모압 평지에서 모세에게 일러 가라사대","reference":"민수기 35:1","category":"$undefined"},{"id":"4848","book":"민수기","book_name":"민수기","chapter":35,"verse":2,"text":"이스라엘 자손에게 명하여 그들의 얻은 기업에서 레위인에게 거할 성읍들을 주게 하고 너희는 또 그 성읍 사면의 들을 레위인에게 주어서","reference":"민수기 35:2","category":"$undefined"},{"id":"4849","book":"민수기","book_name":"민수기","chapter":35,"verse":3,"text":"성읍으로는 그들의 거처가 되게 하고 들로는 그들의 가축과 물산과 짐승들을 둘 곳이 되게 할 것이라","reference":"민수기 35:3","category":"$undefined"},{"id":"4850","book":"민수기","book_name":"민수기","chapter":35,"verse":4,"text":"너희가 레위인에게 줄 성읍들의 들은 성벽에서부터 밖으로 사면 이천 규빗이라","reference":"민수기 35:4","category":"$undefined"},{"id":"4851","book":"민수기","book_name":"민수기","chapter":35,"verse":5,"text":"성을 중앙에 두고 성 밖 동편으로 이천 규빗, 남편으로 이천 규빗서 편으로 이천 규빗,북편으로 이천 규빗을 측량할지니 이는 그 들의 성읍의 들이며","reference":"민수기 35:5","category":"$undefined"},{"id":"4852","book":"민수기","book_name":"민수기","chapter":35,"verse":6,"text":"너희가 레위인에게 줄 성읍은 살인자로 피케 할 도피성으로 여섯 성읍이요, 그 외에 사십 이 성읍이라","reference":"민수기 35:6","category":"$undefined"},{"id":"4853","book":"민수기","book_name":"민수기","chapter":35,"verse":7,"text":"너희가 레위인에게 모두 사십 팔 성읍을 주고 그 들도 함께 주되","reference":"민수기 35:7","category":"$undefined"},{"id":"4854","book":"민수기","book_name":"민수기","chapter":35,"verse":8,"text":"이스라엘 자손의 산업에서 레위인에게 너희가 성읍을 줄 때에 많이 얻은 자에게서는 많이 취하여 주고 적게 얻은 자에게서는 적게 취하여 줄 것이라 각기 얻은 산업을 따라서 그 성읍들을 레위인에게 줄지니라","reference":"민수기 35:8","category":"$undefined"},{"id":"4855","book":"민수기","book_name":"민수기","chapter":35,"verse":9,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 35:9","category":"$undefined"},{"id":"4856","book":"민수기","book_name":"민수기","chapter":35,"verse":10,"text":"이스라엘 자손에게 말하여 그들에게 이르라 너희가 요단을 건너 가나안 땅에 들어 가거든","reference":"민수기 35:10","category":"$undefined"},{"id":"4857","book":"민수기","book_name":"민수기","chapter":35,"verse":11,"text":"너희를 위하여 성읍을 도피성으로 정하여 그릇 살인한 자로 그리로 피하게 하라","reference":"민수기 35:11","category":"$undefined"},{"id":"4858","book":"민수기","book_name":"민수기","chapter":35,"verse":12,"text":"이는 너희가 보수할 자에게서 도피하는 성을 삼아 살인자가 회중앞에 서서 판결을 받기까지 죽지 않게 하기 위함이니라","reference":"민수기 35:12","category":"$undefined"},{"id":"4859","book":"민수기","book_name":"민수기","chapter":35,"verse":13,"text":"너희가 줄 성읍 중에 여섯으로 도피성이 되게 하되","reference":"민수기 35:13","category":"$undefined"},{"id":"4860","book":"민수기","book_name":"민수기","chapter":35,"verse":14,"text":"세 성읍은 요단 이 편에서 주고 세 성읍은 가나안 땅에서 주어 도피성이 되게 하라","reference":"민수기 35:14","category":"$undefined"},{"id":"4861","book":"민수기","book_name":"민수기","chapter":35,"verse":15,"text":"이 여섯 성읍은 이스라엘 자손과 타국인과 이스라엘 중에 우거하는 자의 도피성이 되리니 무릇 그릇 살인한 자가 그리로 도피할 수 있으리라","reference":"민수기 35:15","category":"$undefined"},{"id":"4862","book":"민수기","book_name":"민수기","chapter":35,"verse":16,"text":"만일 철 연장으로 사람을 쳐죽이면 이는 고살한 자니 그 고살자를 반드시 죽일 것이요","reference":"민수기 35:16","category":"$undefined"},{"id":"4863","book":"민수기","book_name":"민수기","chapter":35,"verse":17,"text":"만일 사람을 죽일 만한 돌을 손에 들고 사람을 쳐죽이면 이는 고살한 자니 그 고살자를 반드시 죽일 것이요","reference":"민수기 35:17","category":"$undefined"},{"id":"4864","book":"민수기","book_name":"민수기","chapter":35,"verse":18,"text":"만일 사람을 죽일 만한 나무 연장을 손에 들고 사람을 쳐죽이면 이는 고살한 자니 그 고살자를 반드시 죽일 것이니라","reference":"민수기 35:18","category":"$undefined"},{"id":"4865","book":"민수기","book_name":"민수기","chapter":35,"verse":19,"text":"피를 보수하는 자가 그 고살자를 친히 죽일 것이니 그를 만나거든 죽일 것이요","reference":"민수기 35:19","category":"$undefined"},{"id":"4866","book":"민수기","book_name":"민수기","chapter":35,"verse":20,"text":"만일 미워하는 까닭에 밀쳐 죽이거나 기회를 엿보아 무엇을 던져 죽이거나","reference":"민수기 35:20","category":"$undefined"},{"id":"4867","book":"민수기","book_name":"민수기","chapter":35,"verse":21,"text":"원한으로 인하여 손으로 쳐죽이면 그 친 자를 반드시 죽일 것이니 이는 고살하였음이라 피를 보수하는 자가 그 고살자를 만나거든 죽일 것이니라","reference":"민수기 35:21","category":"$undefined"},{"id":"4868","book":"민수기","book_name":"민수기","chapter":35,"verse":22,"text":"원한 없이 우연히 사람을 밀치거나 기회를 엿봄이 없이 무엇을 던지거나","reference":"민수기 35:22","category":"$undefined"},{"id":"4869","book":"민수기","book_name":"민수기","chapter":35,"verse":23,"text":"보지 못하고 사람을 죽일 만한 돌을 던져서 죽였다 하자 이는 원한도 없고 해하려 한 것도 아닌즉","reference":"민수기 35:23","category":"$undefined"},{"id":"4870","book":"민수기","book_name":"민수기","chapter":35,"verse":24,"text":"회중이 친 자와 피를 보수하는 자 간에 이 규례대로 판결하여","reference":"민수기 35:24","category":"$undefined"},{"id":"4871","book":"민수기","book_name":"민수기","chapter":35,"verse":25,"text":"피를 보수하는 자의 손에서 살인자를 건져내어 그가 피하였던 도피성으로 돌려 보낼 것이요 그는 거룩한 기름 부음을 받은 대제사장의 죽기까지 거기 거할 것이니라","reference":"민수기 35:25","category":"$undefined"},{"id":"4872","book":"민수기","book_name":"민수기","chapter":35,"verse":26,"text":"그러나 살인자가 어느 때든지 그 피하였던 도피성 지경 밖에 나갔다 하자","reference":"민수기 35:26","category":"$undefined"},{"id":"4873","book":"민수기","book_name":"민수기","chapter":35,"verse":27,"text":"피를 보수하는 자가 도피성 지경 밖에서 그 살인자를 만나 죽일지라도 위하여 피흘린 죄가 없나니","reference":"민수기 35:27","category":"$undefined"},{"id":"4874","book":"민수기","book_name":"민수기","chapter":35,"verse":28,"text":"이는 살인자가 대제사장의 죽기까지 그 도피성에 유하였을 것임이라 대제사장의 죽은 후에는 그 살인자가 자기의 산업의 땅으로 돌아갈 수 있느니라","reference":"민수기 35:28","category":"$undefined"},{"id":"4875","book":"민수기","book_name":"민수기","chapter":35,"verse":29,"text":"이는 너희 대대로 거하는 곳에서 판단하는 율례라","reference":"민수기 35:29","category":"$undefined"},{"id":"4876","book":"민수기","book_name":"민수기","chapter":35,"verse":30,"text":"무릇 사람을 죽인 자 곧 고살자를 증인들의 말을 따라서 죽일 것이나 한 증인의 증거만 따라서 죽이지 말 것이요","reference":"민수기 35:30","category":"$undefined"},{"id":"4877","book":"민수기","book_name":"민수기","chapter":35,"verse":31,"text":"살인죄를 범한 고살자의 생명의 속전을 받지 말고 반드시 죽일 것이며","reference":"민수기 35:31","category":"$undefined"},{"id":"4878","book":"민수기","book_name":"민수기","chapter":35,"verse":32,"text":"또 도피성에 피한 자를 대제사장의 죽기 전에는 속전을 받고 그의 땅으로 돌아가 거하게 하지 말 것이니라","reference":"민수기 35:32","category":"$undefined"},{"id":"4879","book":"민수기","book_name":"민수기","chapter":35,"verse":33,"text":"너희는 거하는 땅을 더럽히지 말라 피는 땅을 더럽히나니 피 흘림을 받은 땅은 이를 흘리게 한 자의 피가 아니면 속할 수 없느니라","reference":"민수기 35:33","category":"$undefined"},{"id":"4880","book":"민수기","book_name":"민수기","chapter":35,"verse":34,"text":"너희는 너희 거하는 땅 곧 나의 거하는 땅을 더럽히지 말라 나 여호와가 이스라엘 자손 중에 거함이니라","reference":"민수기 35:34","category":"$undefined"}],"bookSlug":"numbers"}]
