2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":36,"verses":[{"id":"4881","book":"민수기","book_name":"민수기","chapter":36,"verse":1,"text":"요셉 자손의 자손 중 므낫세의 손자 마길의 아들 길르앗 자손 가족의 두령들이 나아와 모세와 이스라엘 자손의 두령된 족장들 앞에 말하여","reference":"민수기 36:1","category":"$undefined"},{"id":"4882","book":"민수기","book_name":"민수기","chapter":36,"verse":2,"text":"가로되 `여호와께서 우리 주에게 명하사 이스라엘 자손에게 그 기업의 땅을 제비뽑아 주게 하셨고 여호와께서 또 우리 주에게 명하사 우리 형제 슬로브핫의 기업으로 그 딸들에게 주게 하였은즉","reference":"민수기 36:2","category":"$undefined"},{"id":"4883","book":"민수기","book_name":"민수기","chapter":36,"verse":3,"text":"그들이 만일 이스라엘 자손의 다른 지파 남자들에게 시집가면 그들의 기업은 우리 조상의 기업에서 감삭되고 그들의 속할 그 지파의 기업에 첨가되리니 그러면 우리 제비뽑은 기업에서 감삭될 것이요","reference":"민수기 36:3","category":"$undefined"},{"id":"4884","book":"민수기","book_name":"민수기","chapter":36,"verse":4,"text":"이스라엘 자손의 희년을 당하여 그 기업이 그가 속한 지파에 첨가될 것이라 그런즉 그들의 기업은 우리 조상 지파의 기업에서 아주 감삭되리이다'","reference":"민수기 36:4","category":"$undefined"},{"id":"4885","book":"민수기","book_name":"민수기","chapter":36,"verse":5,"text":"모세가 여호와의 말씀으로 이스라엘에게 명하여 가로되 `요셉 자손 지파의 말이 옳도다","reference":"민수기 36:5","category":"$undefined"},{"id":"4886","book":"민수기","book_name":"민수기","chapter":36,"verse":6,"text":"슬로브핫의 딸들에게 대한 여호와의 명이 이러하니라 이르시되 슬로브핫의 딸들은 마음대로 시집가려니와 오직 그 조상 지파의 가족에게로만 시집갈지니","reference":"민수기 36:6","category":"$undefined"},{"id":"4887","book":"민수기","book_name":"민수기","chapter":36,"verse":7,"text":"그리하면 이스라엘 자손의 기업이 이 지파에서 저 지파로 옮기지 않고 이스라엘 자손이 다 각기 조상 지파의 기업을 지킬 것이니라 하셨나니","reference":"민수기 36:7","category":"$undefined"},{"id":"4888","book":"민수기","book_name":"민수기","chapter":36,"verse":8,"text":"이스라엘 자손의 지파 중 무릇 그 기업을 이은 딸들은 자기 조상지파 가족되는 사람에게로 시집갈 것이라 그리하면 이스라엘 자손이 각기 조상의 기업을 보존하게 되어서","reference":"민수기 36:8","category":"$undefined"},{"id":"4889","book":"민수기","book_name":"민수기","chapter":36,"verse":9,"text":"그 기업으로 이 지파에서 저 지파로 옮기게 하지 아니하고 이스라엘 자손 지파가 각각 자기 기업을 지키리라'","reference":"민수기 36:9","category":"$undefined"},{"id":"4890","book":"민수기","book_name":"민수기","chapter":36,"verse":10,"text":"슬로브핫의 딸들이 여호와께서 모세에게 명하신 대로 행하니라","reference":"민수기 36:10","category":"$undefined"},{"id":"4891","book":"민수기","book_name":"민수기","chapter":36,"verse":11,"text":"슬로브핫의 딸 말라와 디르사와 호글라와 밀가와 노아가 다 그 아비 형제의 아들들에게로 시집가되","reference":"민수기 36:11","category":"$undefined"},{"id":"4892","book":"민수기","book_name":"민수기","chapter":36,"verse":12,"text":"그들이 요셉의 아들 므낫세 자손의 가족에게로 시집 간고로 그 기업이 그 아비 가족의 지파에 여전히 있었더라","reference":"민수기 36:12","category":"$undefined"},{"id":"4893","book":"민수기","book_name":"민수기","chapter":36,"verse":13,"text":"이는 여리고 맞은편 요단가 모압 평지에서 여호와께서 모세로 이스라엘 자손에게 명하신 명령과 규례니라","reference":"민수기 36:13","category":"$undefined"}],"bookSlug":"numbers"}]
