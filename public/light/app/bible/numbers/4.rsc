2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":4,"verses":[{"id":"3745","book":"민수기","book_name":"민수기","chapter":4,"verse":1,"text":"여호와께서 또 모세와 아론에게 일러 가라사대","reference":"민수기 4:1","category":"$undefined"},{"id":"3746","book":"민수기","book_name":"민수기","chapter":4,"verse":2,"text":"레위 자손 중에서 고핫 자손을 그들의 가족과 종족을 따라 총계할지니","reference":"민수기 4:2","category":"$undefined"},{"id":"3747","book":"민수기","book_name":"민수기","chapter":4,"verse":3,"text":"곧 삼십세 이상으로 오십세까지 회막의 일을 하기 위하여 그 역사에 참가할 만한 모든 자를 계수하라","reference":"민수기 4:3","category":"$undefined"},{"id":"3748","book":"민수기","book_name":"민수기","chapter":4,"verse":4,"text":"고핫 자손의 회막 안 지성물에 대하여 할 일은 이러하니라","reference":"민수기 4:4","category":"$undefined"},{"id":"3749","book":"민수기","book_name":"민수기","chapter":4,"verse":5,"text":"행진할 때에 아론과 그 아들들이 들어가서 간 막는 장을 걷어 증거궤를 덮고","reference":"민수기 4:5","category":"$undefined"},{"id":"3750","book":"민수기","book_name":"민수기","chapter":4,"verse":6,"text":"그 위에 해달의 가죽으로 덮고 그 위에 순청색 보자기를 덮은후에 그 채를 꿰고","reference":"민수기 4:6","category":"$undefined"},{"id":"3751","book":"민수기","book_name":"민수기","chapter":4,"verse":7,"text":"또 진설병의 상에 청색 보자기를 펴고 대접들과, 숟가락들과, 주발들과, 붓는 잔들을 그 위에 두고 또 항상 진설하는 떡을 그 위에 두고","reference":"민수기 4:7","category":"$undefined"},{"id":"3752","book":"민수기","book_name":"민수기","chapter":4,"verse":8,"text":"홍색 보자기를 그 위에 펴고 그것을 해달의 가죽 덮개로 덮은후에 그 채를 꿰고","reference":"민수기 4:8","category":"$undefined"},{"id":"3753","book":"민수기","book_name":"민수기","chapter":4,"verse":9,"text":"또 청색 보자기를 취하여 등대와, 그 등잔들과, 그 불집게들과, 불똥 그릇들과, 그 쓰는 바 모든 기름 그릇을 덮고","reference":"민수기 4:9","category":"$undefined"},{"id":"3754","book":"민수기","book_name":"민수기","chapter":4,"verse":10,"text":"등대와 그 모든 기구를 해달의 가죽 덮개 안에 넣어 메는 틀위에 두고","reference":"민수기 4:10","category":"$undefined"},{"id":"3755","book":"민수기","book_name":"민수기","chapter":4,"verse":11,"text":"또 금단 위에 청색 보자기를 펴고 해달의 가죽 덮개로 덮고 그 채를 꿰고","reference":"민수기 4:11","category":"$undefined"},{"id":"3756","book":"민수기","book_name":"민수기","chapter":4,"verse":12,"text":"또 성소에서 봉사하는 데 쓰는 모든 기명을 취하여 청색 보자기에 싸서 해달의 가죽 덮개로 덮어 메는 틀 위에 두고","reference":"민수기 4:12","category":"$undefined"},{"id":"3757","book":"민수기","book_name":"민수기","chapter":4,"verse":13,"text":"또 단의 재를 버리고 그 단 위에 자색 보자기를 펴고","reference":"민수기 4:13","category":"$undefined"},{"id":"3758","book":"민수기","book_name":"민수기","chapter":4,"verse":14,"text":"봉사하는 데 쓰는 모든 기구 곧 불 옮기는 그릇들과, 고기 갈고리들과, 부삽들과, 대야들과, 단의 모든 기구를 두고 해달의 가죽 덮개를 그 위에 덮고 그 채를 꿸 것이며","reference":"민수기 4:14","category":"$undefined"},{"id":"3759","book":"민수기","book_name":"민수기","chapter":4,"verse":15,"text":"행진할 때에 아론과 그 아들들이 성소와 성소의 모든 기구 덮기를 필하거든 고핫 자손이 와서 멜 것이니라 그러나 성물은 만지지 말지니 죽을까 하노라 회막 물건 중에서 이것들은 고핫 자손이 멜 것이며","reference":"민수기 4:15","category":"$undefined"},{"id":"3760","book":"민수기","book_name":"민수기","chapter":4,"verse":16,"text":"제사장 아론의 아들 엘르아살의 맡을 것은 등유와, 분향할 향품과, 항상 드리는 소제물과, 관유며, 또 장막의 전체와, 그 중에 있는 모든 것과, 성소와, 그 모든 기구니라","reference":"민수기 4:16","category":"$undefined"},{"id":"3761","book":"민수기","book_name":"민수기","chapter":4,"verse":17,"text":"여호와께서 또 모세와 아론에게 일러 가라사대","reference":"민수기 4:17","category":"$undefined"},{"id":"3762","book":"민수기","book_name":"민수기","chapter":4,"verse":18,"text":"너희는 고핫 족속의 지파를 레위인 중에서 끊어지게 말지니","reference":"민수기 4:18","category":"$undefined"},{"id":"3763","book":"민수기","book_name":"민수기","chapter":4,"verse":19,"text":"그들이 지성물에 접근할 때에 그 생명을 보존하고 죽지 않게 하기 위하여 너희는 이같이 하여 아론과 그 아들들이 들어가서 각 사람에게 그 할 일과 그 멜 것을 지휘할지니라","reference":"민수기 4:19","category":"$undefined"},{"id":"3764","book":"민수기","book_name":"민수기","chapter":4,"verse":20,"text":"그들은 잠시라도 들어가서 성소를 보지 말것은 죽을까 함이니라","reference":"민수기 4:20","category":"$undefined"},{"id":"3765","book":"민수기","book_name":"민수기","chapter":4,"verse":21,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 4:21","category":"$undefined"},{"id":"3766","book":"민수기","book_name":"민수기","chapter":4,"verse":22,"text":"게르손 자손도 그 종족과 가족을 따라 총계하되","reference":"민수기 4:22","category":"$undefined"},{"id":"3767","book":"민수기","book_name":"민수기","chapter":4,"verse":23,"text":"삼십세 이상으로 오십세까지 회막 봉사에 입참하여 일할 만한 모든 자를 계수하라","reference":"민수기 4:23","category":"$undefined"},{"id":"3768","book":"민수기","book_name":"민수기","chapter":4,"verse":24,"text":"게르손 가족의 할 일과 멜 것은 이러하니","reference":"민수기 4:24","category":"$undefined"},{"id":"3769","book":"민수기","book_name":"민수기","chapter":4,"verse":25,"text":"곧 그들은 성막의 앙장들과, 회막과, 그 덮개와, 그 위의 해달의 가죽 덮개와, 회막 문장을 메이며","reference":"민수기 4:25","category":"$undefined"},{"id":"3770","book":"민수기","book_name":"민수기","chapter":4,"verse":26,"text":"뜰의 휘장과, 및 성막과, 단 사면에 있는 뜰의 문장과, 그 줄들과, 그것에 사용하는 모든 기구를 메이며 이 모든 것을 어떻게 맡아 처리할 것이라","reference":"민수기 4:26","category":"$undefined"},{"id":"3771","book":"민수기","book_name":"민수기","chapter":4,"verse":27,"text":"게르손 자손은 그 모든 일 곧 멜 것과 처리할 것에 아론과 그 아들들의 명대로 할 것이니 너희는 그들의 멜 짐을 그들에게 맡길 것이니라","reference":"민수기 4:27","category":"$undefined"},{"id":"3772","book":"민수기","book_name":"민수기","chapter":4,"verse":28,"text":"게르손 자손의 가족들이 회막에서 할 일이 이러하며 그들의 직무는 제사장 아론의 아들 이다말이 감독할지니라","reference":"민수기 4:28","category":"$undefined"},{"id":"3773","book":"민수기","book_name":"민수기","chapter":4,"verse":29,"text":"너는 므라리 자손도 그 가족과 종족을 따라 계수하되","reference":"민수기 4:29","category":"$undefined"},{"id":"3774","book":"민수기","book_name":"민수기","chapter":4,"verse":30,"text":"삼십세 이상으로 오십세까지 회막 봉사에 입참하여 일할 만한 모든 자를 계수하라","reference":"민수기 4:30","category":"$undefined"},{"id":"3775","book":"민수기","book_name":"민수기","chapter":4,"verse":31,"text":"그들이 직무를 따라 회막에서 할 모든 일 곧 그 멜 것이 이러하니 곧 장막의 널판들과, 그 띠들과, 그 기둥들과, 그 받침들과,","reference":"민수기 4:31","category":"$undefined"},{"id":"3776","book":"민수기","book_name":"민수기","chapter":4,"verse":32,"text":"뜰 사면 기둥들과, 그 받침들과, 그 말뚝들과, 그 줄들과, 그 모든 기구들과, 무릇 그것에 쓰는 것이라 너희는 그들의 맡아 멜 모든 기구의 명목을 지정하라","reference":"민수기 4:32","category":"$undefined"},{"id":"3777","book":"민수기","book_name":"민수기","chapter":4,"verse":33,"text":"이는 제사장 아론의 아들 이다말의 수하에 있을 므라리 자손의 가족들이 그 모든 사무대로 회막에서 행할 일이니라","reference":"민수기 4:33","category":"$undefined"},{"id":"3778","book":"민수기","book_name":"민수기","chapter":4,"verse":34,"text":"모세와 아론과 회중의 족장들이 고핫 자손들을 그 가족과 종족대로 계수하니","reference":"민수기 4:34","category":"$undefined"},{"id":"3779","book":"민수기","book_name":"민수기","chapter":4,"verse":35,"text":"삼십세 이상으로 오십세까지 회막 봉사에 입참하여 일할 만한 모든 자","reference":"민수기 4:35","category":"$undefined"},{"id":"3780","book":"민수기","book_name":"민수기","chapter":4,"verse":36,"text":"곧 그 가족대로 계수함을 입은 자가 이천 칠백 오십이니","reference":"민수기 4:36","category":"$undefined"},{"id":"3781","book":"민수기","book_name":"민수기","chapter":4,"verse":37,"text":"이는 모세와 아론이 여호와께서 모세로 명하신 대로 회막에서 종사하는 고핫인의 모든 가족 중 계수한 자니라","reference":"민수기 4:37","category":"$undefined"},{"id":"3782","book":"민수기","book_name":"민수기","chapter":4,"verse":38,"text":"게르손 자손의 그 가족과 종족을 따라 계수함을 입은 자는","reference":"민수기 4:38","category":"$undefined"},{"id":"3783","book":"민수기","book_name":"민수기","chapter":4,"verse":39,"text":"삼십세 이상으로 오십세까지 회막 봉사에 입참하여 일할 만한 모든 자라","reference":"민수기 4:39","category":"$undefined"},{"id":"3784","book":"민수기","book_name":"민수기","chapter":4,"verse":40,"text":"그 가족과 종족을 따라 계수함을 입은 자가 이천 육백 삼십명이니","reference":"민수기 4:40","category":"$undefined"},{"id":"3785","book":"민수기","book_name":"민수기","chapter":4,"verse":41,"text":"이는 모세와 아론이 여호와의 명대로 회막에서 종사하는 게르손 자손의 모든 가족 중 계수한 자니라","reference":"민수기 4:41","category":"$undefined"},{"id":"3786","book":"민수기","book_name":"민수기","chapter":4,"verse":42,"text":"므라리 자손의 가족 중 그 가족과 종족을 따라 계수함을 입은 자는","reference":"민수기 4:42","category":"$undefined"},{"id":"3787","book":"민수기","book_name":"민수기","chapter":4,"verse":43,"text":"삼십세 이상으로 오십세까지 회막 봉사에 입참하여 일할 만한 모든 자라","reference":"민수기 4:43","category":"$undefined"},{"id":"3788","book":"민수기","book_name":"민수기","chapter":4,"verse":44,"text":"그 가족을 따라 계수함을 입은 자가 삼천 이백명이니","reference":"민수기 4:44","category":"$undefined"},{"id":"3789","book":"민수기","book_name":"민수기","chapter":4,"verse":45,"text":"이는 모세와 아론이 여호와께서 모세로 명하신 대로 므라리 자손들의 가족 중 계수한 자니라","reference":"민수기 4:45","category":"$undefined"},{"id":"3790","book":"민수기","book_name":"민수기","chapter":4,"verse":46,"text":"모세와 아론과 이스라엘 족장들이 레위인을 그 가족과 종족대로 다 계수하니","reference":"민수기 4:46","category":"$undefined"},{"id":"3791","book":"민수기","book_name":"민수기","chapter":4,"verse":47,"text":"삼십세 이상으로 오십세까지 회막 봉사와 메는 일에 입참하여 일할 만한 모든 자","reference":"민수기 4:47","category":"$undefined"},{"id":"3792","book":"민수기","book_name":"민수기","chapter":4,"verse":48,"text":"곧 그 계수함을 입은 자가 팔천 오백 팔십명이라","reference":"민수기 4:48","category":"$undefined"},{"id":"3793","book":"민수기","book_name":"민수기","chapter":4,"verse":49,"text":"그들이 그 할 일과 멜일을 따라 모세에게 계수함을 입었으되 여호와께서 모세에게 명하신 대로 그들이 계수함을 입었더라","reference":"민수기 4:49","category":"$undefined"}],"bookSlug":"numbers"}]
