2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":5,"verses":[{"id":"3794","book":"민수기","book_name":"민수기","chapter":5,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 5:1","category":"$undefined"},{"id":"3795","book":"민수기","book_name":"민수기","chapter":5,"verse":2,"text":"이스라엘 자손에게 명하여 모든 문둥병 환자와 유출병이 있는 자와 주검으로 부정케 된 자를 다 진 밖으로 내어 보내되","reference":"민수기 5:2","category":"$undefined"},{"id":"3796","book":"민수기","book_name":"민수기","chapter":5,"verse":3,"text":"무론 남녀하고 다 진 밖으로 내어 보내어 그들로 진을 더럽히게 말라 내가 그 진 가운데 거하느니라 하시매","reference":"민수기 5:3","category":"$undefined"},{"id":"3797","book":"민수기","book_name":"민수기","chapter":5,"verse":4,"text":"이스라엘 자손이 그같이 행하여 그들을 진 밖으로 내어 보내었으니 곧 여호와께서 모세에게 이르신대로 이스라엘 자손이 행하였더라","reference":"민수기 5:4","category":"$undefined"},{"id":"3798","book":"민수기","book_name":"민수기","chapter":5,"verse":5,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 5:5","category":"$undefined"},{"id":"3799","book":"민수기","book_name":"민수기","chapter":5,"verse":6,"text":"이스라엘 자손에게 이르라 남자나 여자나 사람들이 범하는 죄를 범하여 여호와께 패역하여 그 몸에 죄를 얻거든","reference":"민수기 5:6","category":"$undefined"},{"id":"3800","book":"민수기","book_name":"민수기","chapter":5,"verse":7,"text":"그 지은 죄를 자복하고 그 죄 값을 온전히 갚되 오분지 일을 더하여 그가 죄를 얻었던 그 본주에게 돌려 줄 것이요","reference":"민수기 5:7","category":"$undefined"},{"id":"3801","book":"민수기","book_name":"민수기","chapter":5,"verse":8,"text":"만일 죄 값을 받을 만한 친족이 없거든 그 죄 값을 여호와께 드려 제사장에게로 돌릴 것이니 이는 그를 위하여 속죄할 수양 외에 돌릴 것이니라","reference":"민수기 5:8","category":"$undefined"},{"id":"3802","book":"민수기","book_name":"민수기","chapter":5,"verse":9,"text":"이스라엘 자손의 거제로 제사장에게 가져 오는 모든 성물은 그의 것이 될 것이라","reference":"민수기 5:9","category":"$undefined"},{"id":"3803","book":"민수기","book_name":"민수기","chapter":5,"verse":10,"text":"각 사람의 구별한 물건은 그의 것이 되나니 누구든지 제사장에게 주는 것은 그의 것이 되느니라","reference":"민수기 5:10","category":"$undefined"},{"id":"3804","book":"민수기","book_name":"민수기","chapter":5,"verse":11,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 5:11","category":"$undefined"},{"id":"3805","book":"민수기","book_name":"민수기","chapter":5,"verse":12,"text":"이스라엘 자손에게 고하여 그들에게 이르라 만일 어떤 사람의 아내가 실행하여 남편에게 범죄하여","reference":"민수기 5:12","category":"$undefined"},{"id":"3806","book":"민수기","book_name":"민수기","chapter":5,"verse":13,"text":"타인과 정교를 하였으나 그 남편의 눈에 숨겨 드러나지 아니하였고 그 여자의 더러워진 일에 증인도 없고 그가 잡히지 아니하였어도","reference":"민수기 5:13","category":"$undefined"},{"id":"3807","book":"민수기","book_name":"민수기","chapter":5,"verse":14,"text":"그 더러워짐을 인하여 남편이 의심이 생겨서 그 아내를 의심하든지 또는 아내가 더럽히지 아니하였어도 그 남편이 의심이 생겨서그 아내를 의심하거든","reference":"민수기 5:14","category":"$undefined"},{"id":"3808","book":"민수기","book_name":"민수기","chapter":5,"verse":15,"text":"그 아내를 데리고 제사장에게로 가서 그를 위하여 보리 가루 에바 십분지 일을 예물로 드리되 그것에 기름도 붓지 말고 유향도 두지 말라 이는 의심의 소제요 생각하게 하는 소제니 곧 죄악을 생각하게 하는 것이니라","reference":"민수기 5:15","category":"$undefined"},{"id":"3809","book":"민수기","book_name":"민수기","chapter":5,"verse":16,"text":"제사장은 그 여인으로 가까이 오게 하여 여호와 앞에 세우고","reference":"민수기 5:16","category":"$undefined"},{"id":"3810","book":"민수기","book_name":"민수기","chapter":5,"verse":17,"text":"토기에 거룩한 물을 담고 성막 바닥의 티끌을 취하여 물에 넣고","reference":"민수기 5:17","category":"$undefined"},{"id":"3811","book":"민수기","book_name":"민수기","chapter":5,"verse":18,"text":"여인을 여호와 앞에 세우고 그 머리를 풀게 하고 생각하게 하는 소제물 곧 의심의 소제물을 그 두 손에 두고 제사장은 저주가 되게 할 쓴 물을 자기 손에 들고","reference":"민수기 5:18","category":"$undefined"},{"id":"3812","book":"민수기","book_name":"민수기","chapter":5,"verse":19,"text":"여인에게 맹세시켜 그에게 이르기를 네가 네 남편을 두고 실행하여 사람과 동침하여 더럽힌 일이 없으면 저주가 되게 하는 이 쓴물의 해독을 면하리라","reference":"민수기 5:19","category":"$undefined"},{"id":"3813","book":"민수기","book_name":"민수기","chapter":5,"verse":20,"text":"그러나 네가 네 남편을 두고 실행하여 더럽혀서 네 남편 아닌 사람과 동침하였으면","reference":"민수기 5:20","category":"$undefined"},{"id":"3814","book":"민수기","book_name":"민수기","chapter":5,"verse":21,"text":"제사장이 그 여인으로 저주의 맹세를 하게 하고 그 여인에게 말할지니라 여호와께서 네 넓적다리로 떨어지고 네 배로 부어서 너로 네 백성 중에 저줏거리, 맹셋거리가 되게 하실지라","reference":"민수기 5:21","category":"$undefined"},{"id":"3815","book":"민수기","book_name":"민수기","chapter":5,"verse":22,"text":"이 저주가 되게 하는 이 물이 네 창자에 들어 가서 네 배로 붓게하고 네 넓적다리로 떨어지게 하리라 할 것이요 여인은 아멘, 아멘 할지니라","reference":"민수기 5:22","category":"$undefined"},{"id":"3816","book":"민수기","book_name":"민수기","chapter":5,"verse":23,"text":"제사장이 저주의 말을 두루마리에 써서 그 글자를 그 쓴 물에 빨아 넣고","reference":"민수기 5:23","category":"$undefined"},{"id":"3817","book":"민수기","book_name":"민수기","chapter":5,"verse":24,"text":"여인으로 그 저주가 되게 하는 쓴 물을 마시게 할지니 그 저주가 되게 하는 물이 그 속에 들어가서 쓰리라","reference":"민수기 5:24","category":"$undefined"},{"id":"3818","book":"민수기","book_name":"민수기","chapter":5,"verse":25,"text":"제사장이 먼저 그 여인의 손에서 의심의 소제물을 취하여 그 소제물을 여호와 앞에 흔들고 가지고 단으로 가서","reference":"민수기 5:25","category":"$undefined"},{"id":"3819","book":"민수기","book_name":"민수기","chapter":5,"verse":26,"text":"그 소제물 중에서 기념으로 한 움큼을 취하여 단 위에 소화하고 그 후에 여인에게 그 물을 마시울지라","reference":"민수기 5:26","category":"$undefined"},{"id":"3820","book":"민수기","book_name":"민수기","chapter":5,"verse":27,"text":"그 물을 마시운 후에 만일 여인이 몸을 더럽혀서 그 남편에게 범죄하였으면 그 저주가 되게 하는 물이 그의 속에 들어가서 쓰게 되어 그 배가 부으며 그 넓적다리가 떨어지리니 그 여인이 백성 중에서 저줏거리가 될 것이니라","reference":"민수기 5:27","category":"$undefined"},{"id":"3821","book":"민수기","book_name":"민수기","chapter":5,"verse":28,"text":"그러나 여인이 더럽힌 일이 없고 정결하면 해를 받지 않고 잉태하리라","reference":"민수기 5:28","category":"$undefined"},{"id":"3822","book":"민수기","book_name":"민수기","chapter":5,"verse":29,"text":"이는 의심의 법이니 아내가 그 남편을 두고 실행하여 더럽힌 때나","reference":"민수기 5:29","category":"$undefined"},{"id":"3823","book":"민수기","book_name":"민수기","chapter":5,"verse":30,"text":"또는 그 남편이 의심이 생겨서 그 아내를 의심할 때에 그 여인을 여호와 앞에 두고 제사장이 이 법대로 행할 것이라","reference":"민수기 5:30","category":"$undefined"},{"id":"3824","book":"민수기","book_name":"민수기","chapter":5,"verse":31,"text":"남편은 무죄할 것이요 여인은 죄가 있으면 당하리라","reference":"민수기 5:31","category":"$undefined"}],"bookSlug":"numbers"}]
