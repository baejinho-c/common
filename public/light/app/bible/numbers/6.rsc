2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":6,"verses":[{"id":"3825","book":"민수기","book_name":"민수기","chapter":6,"verse":1,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 6:1","category":"$undefined"},{"id":"3826","book":"민수기","book_name":"민수기","chapter":6,"verse":2,"text":"이스라엘 자손에게 고하여 그들에게 이르라 남자나 여자가 특별한 서원 곧 나실인의 서원을 하고 자기 몸을 구별하여 여호와께 드리거든","reference":"민수기 6:2","category":"$undefined"},{"id":"3827","book":"민수기","book_name":"민수기","chapter":6,"verse":3,"text":"포도주와 독주를 멀리하며 포도주의 초나 독주의 초를 마시지 말며 포도즙도 마시지 말며 생포도나 건포도도 먹지 말지니","reference":"민수기 6:3","category":"$undefined"},{"id":"3828","book":"민수기","book_name":"민수기","chapter":6,"verse":4,"text":"자기 몸을 구별하는 모든 날 동안에는 포도나무 소산은 씨나 껍질이라도 먹지말지며","reference":"민수기 6:4","category":"$undefined"},{"id":"3829","book":"민수기","book_name":"민수기","chapter":6,"verse":5,"text":"그 서원을 하고 구별하는 모든 날 동안은 삭도를 도무지 그 머리에 대지 말 것이라 자기 몸을 구별하여 여호와께 드리는 날이 차기까지 그는 거룩한즉 그 머리털을 길게 자라게 할 것이며","reference":"민수기 6:5","category":"$undefined"},{"id":"3830","book":"민수기","book_name":"민수기","chapter":6,"verse":6,"text":"자기 몸을 구별하여 여호와께 드리는 모든 날 동안은 시체를 가까이 하지 말 것이요","reference":"민수기 6:6","category":"$undefined"},{"id":"3831","book":"민수기","book_name":"민수기","chapter":6,"verse":7,"text":"그 부모 형제 자매가 죽은 때에라도 그로 인하여 더럽히지 말것이니 이는 자기 몸을 구별하여 하나님께 드리는 표가 그 머리에 있음이라","reference":"민수기 6:7","category":"$undefined"},{"id":"3832","book":"민수기","book_name":"민수기","chapter":6,"verse":8,"text":"자기 몸을 구별하는 모든 날 동안 그는 여호와께 거룩한 자니라","reference":"민수기 6:8","category":"$undefined"},{"id":"3833","book":"민수기","book_name":"민수기","chapter":6,"verse":9,"text":"누가 홀연히 그 곁에서 죽어서 스스로 구별한 자의 머리를 더럽히거든 그 몸을 정결케 하는 날에 머리를 밀 것이니 곧 제 칠일에 밀 것이며","reference":"민수기 6:9","category":"$undefined"},{"id":"3834","book":"민수기","book_name":"민수기","chapter":6,"verse":10,"text":"제 팔일에 산비둘기 두 마리나 집비둘기 새끼 두 마리를 가지고 회막 문에 와서 제사장에게 줄 것이요","reference":"민수기 6:10","category":"$undefined"},{"id":"3835","book":"민수기","book_name":"민수기","chapter":6,"verse":11,"text":"제사장은 그 하나를 속죄제물로, 하나를 번제물로 드려서 그의 시체로 인하여 얻은 죄를 속하고 또 그는 당일에 그의 머리를 성결케 할 것이며","reference":"민수기 6:11","category":"$undefined"},{"id":"3836","book":"민수기","book_name":"민수기","chapter":6,"verse":12,"text":"자기 몸을 구별하여 여호와께 드릴 날을 새로 정하고 일년 된 수양을 가져다가 속건제로 드릴지니라 자기 몸을 구별한 때에 그 몸을 더렵혔은즉 지나간 날은 무효니라","reference":"민수기 6:12","category":"$undefined"},{"id":"3837","book":"민수기","book_name":"민수기","chapter":6,"verse":13,"text":"나실인의 법은 이러하니라 자기 몸을 구별한 날이 차면 그 사람을 회막 문으로 데리고 갈 것이요","reference":"민수기 6:13","category":"$undefined"},{"id":"3838","book":"민수기","book_name":"민수기","chapter":6,"verse":14,"text":"그는 여호와께 예물을 드리되 번제물로 일년 된 흠 없는 수양 하나와 속죄제물로 일년 된 흠 없는 어린 암양 하나와 화목제물로 흠 없는 수양 하나와","reference":"민수기 6:14","category":"$undefined"},{"id":"3839","book":"민수기","book_name":"민수기","chapter":6,"verse":15,"text":"무교병 한 광주리와 고운 가루에 기름 섞은 과자들과 기름 바른 무교전병들과 그 소제물과 전제물을 드릴 것이요","reference":"민수기 6:15","category":"$undefined"},{"id":"3840","book":"민수기","book_name":"민수기","chapter":6,"verse":16,"text":"제사장은 그것들을 여호와 앞에 가져다가 속죄제와 번제를 드리고","reference":"민수기 6:16","category":"$undefined"},{"id":"3841","book":"민수기","book_name":"민수기","chapter":6,"verse":17,"text":"화목제물로 수양에 무교병 한 광주리를 아울러 여호와께 드리고 그 소제와 전제를 드릴 것이요","reference":"민수기 6:17","category":"$undefined"},{"id":"3842","book":"민수기","book_name":"민수기","chapter":6,"verse":18,"text":"자기 몸을 구별한 나실인은 회막 문에서 그 머리털을 밀고 그것을 화목제물 밑에 있는 불에 둘지며","reference":"민수기 6:18","category":"$undefined"},{"id":"3843","book":"민수기","book_name":"민수기","chapter":6,"verse":19,"text":"자기 몸을 구별한 나실인이 그 머리털을 민 후에 제사장이 삶은 수양의 어깨와 광주리 가운데 무교병 하나와 무교전병 하나를 취하여 나실인의 두 손에 두고","reference":"민수기 6:19","category":"$undefined"},{"id":"3844","book":"민수기","book_name":"민수기","chapter":6,"verse":20,"text":"여호와 앞에 요제로 흔들 것이며 그것과 흔든 가슴과 든 넓적다리는 성물이라 다 제사장에게 돌릴 것이니라 그 후에는 나실인이 포도주를 마실 수 있느니라","reference":"민수기 6:20","category":"$undefined"},{"id":"3845","book":"민수기","book_name":"민수기","chapter":6,"verse":21,"text":"이는 곧 서원한 나실인이 자기 몸을 구별한 일로 인하여 여호와께 예물을 드림과 행할 법이며 이 외에도 힘이 미치는 대로 하려니와 그 서원 한대로 자기 몸을 구별하는 법을 따라 할 것이니라","reference":"민수기 6:21","category":"$undefined"},{"id":"3846","book":"민수기","book_name":"민수기","chapter":6,"verse":22,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 6:22","category":"$undefined"},{"id":"3847","book":"민수기","book_name":"민수기","chapter":6,"verse":23,"text":"아론과 그 아들들에게 고하여 이르기를 너희는 이스라엘 자손을 위하여 이렇게 축복하여 이르되","reference":"민수기 6:23","category":"$undefined"},{"id":"3848","book":"민수기","book_name":"민수기","chapter":6,"verse":24,"text":"여호와는 네게 복을 주시고 너를 지키시기를 원하며","reference":"민수기 6:24","category":"$undefined"},{"id":"3849","book":"민수기","book_name":"민수기","chapter":6,"verse":25,"text":"여호와는 그 얼굴로 네게 비취사 은혜 베푸시기를 원하며","reference":"민수기 6:25","category":"$undefined"},{"id":"3850","book":"민수기","book_name":"민수기","chapter":6,"verse":26,"text":"여호와는 그 얼굴을 네게로 향하여 드사 평강주시기를 원하노라 할지니라 하라","reference":"민수기 6:26","category":"$undefined"},{"id":"3851","book":"민수기","book_name":"민수기","chapter":6,"verse":27,"text":"그들은 이같이 내 이름으로 이스라엘 자손에게 축복할지니 내가 그들에게 복을 주리라 !","reference":"민수기 6:27","category":"$undefined"}],"bookSlug":"numbers"}]
