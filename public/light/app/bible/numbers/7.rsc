2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":7,"verses":[{"id":"3852","book":"민수기","book_name":"민수기","chapter":7,"verse":1,"text":"모세가 장막 세우기를 필하고 그것에 기름을 발라 거룩히 구별하고 또 그 모든 기구와 단과 그 모든 기구에 기름을 발라 거룩히 구별한 날에","reference":"민수기 7:1","category":"$undefined"},{"id":"3853","book":"민수기","book_name":"민수기","chapter":7,"verse":2,"text":"이스라엘 족장들 곧 그들의 종족의 두령들이요 그 지파의 족장으로서 그 계수함을 입은 자의 감독된 자들이 예물을 드렸으니","reference":"민수기 7:2","category":"$undefined"},{"id":"3854","book":"민수기","book_name":"민수기","chapter":7,"verse":3,"text":"그들의 여호와께 드린 예물은 덮개 있는 수레 여섯과 소 열 둘이니 족장 둘에 수레가 하나씩이요 하나에 소가 하나씩이라 그것들을 장막 앞에 드린지라","reference":"민수기 7:3","category":"$undefined"},{"id":"3855","book":"민수기","book_name":"민수기","chapter":7,"verse":4,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 7:4","category":"$undefined"},{"id":"3856","book":"민수기","book_name":"민수기","chapter":7,"verse":5,"text":"그것을 그들에게서 받아 레위인에게 주어 각기 직임대로 회막 봉사에 쓰게 할지니라","reference":"민수기 7:5","category":"$undefined"},{"id":"3857","book":"민수기","book_name":"민수기","chapter":7,"verse":6,"text":"모세가 수레와 소를 받아 레위인에게 주었으니","reference":"민수기 7:6","category":"$undefined"},{"id":"3858","book":"민수기","book_name":"민수기","chapter":7,"verse":7,"text":"곧 게르손 자손들에게는 그 직임대로 수레 둘과, 소 넷을 주었고","reference":"민수기 7:7","category":"$undefined"},{"id":"3859","book":"민수기","book_name":"민수기","chapter":7,"verse":8,"text":"므라리 자손들에게는 그 직임대로 수레 넷과, 소 여덟을 주고 제사장 아론의 아들 이다말로 감독케 하였으나","reference":"민수기 7:8","category":"$undefined"},{"id":"3860","book":"민수기","book_name":"민수기","chapter":7,"verse":9,"text":"고핫 자손에게는 주지 아니하였으니 그들의 성소의 직임은 그 어깨로 메는 일을 하는 까닭이었더라","reference":"민수기 7:9","category":"$undefined"},{"id":"3861","book":"민수기","book_name":"민수기","chapter":7,"verse":10,"text":"단에 기름을 바르던 날에 족장들이 단의 봉헌을 위하여 예물을 가져다가 그 예물을 단 앞에 드리니라","reference":"민수기 7:10","category":"$undefined"},{"id":"3862","book":"민수기","book_name":"민수기","chapter":7,"verse":11,"text":"여호와께서 모세에게 이르시기를 족장들은 하루 한 사람씩 단의 봉헌 예물을 드릴지니라 하셨더라","reference":"민수기 7:11","category":"$undefined"},{"id":"3863","book":"민수기","book_name":"민수기","chapter":7,"verse":12,"text":"제 일일에 예물을 드린 자는 유다 지파 암미나답의 아들 나손이라","reference":"민수기 7:12","category":"$undefined"},{"id":"3864","book":"민수기","book_name":"민수기","chapter":7,"verse":13,"text":"그 예물은 성소의 세겔대로 일백 삼십 세겔중 은반 하나와 칠십 세겔중 은바리 하나라 이 두 그릇에는 소제물로 기름 섞은 고운 가루를 채웠고","reference":"민수기 7:13","category":"$undefined"},{"id":"3865","book":"민수기","book_name":"민수기","chapter":7,"verse":14,"text":"또 십 세겔중 금숟가락 하나라 그것에는 향을 채웠고","reference":"민수기 7:14","category":"$undefined"},{"id":"3866","book":"민수기","book_name":"민수기","chapter":7,"verse":15,"text":"또 번제물로 수송아지 하나와, 수양 하나와, 일년 된 어린 수양 하나이며","reference":"민수기 7:15","category":"$undefined"},{"id":"3867","book":"민수기","book_name":"민수기","chapter":7,"verse":16,"text":"속죄제물로 수염소 하나이며","reference":"민수기 7:16","category":"$undefined"},{"id":"3868","book":"민수기","book_name":"민수기","chapter":7,"verse":17,"text":"화목제물로 소 둘과, 수양 다섯과, 수염소 다섯과, 일년 된 어린 수양 다섯이라 이는 암미나답의 아들 나손의 예물이었더라","reference":"민수기 7:17","category":"$undefined"},{"id":"3869","book":"민수기","book_name":"민수기","chapter":7,"verse":18,"text":"제 이일에는 잇사갈의 족장 수알의 아들 느다넬이 드렸으니","reference":"민수기 7:18","category":"$undefined"},{"id":"3870","book":"민수기","book_name":"민수기","chapter":7,"verse":19,"text":"그 드린 예물도 성소의 세겔대로 일백 삼십 세겔중 은반 하나와, 칠십 세겔중 은바리 하나라 이 두 그릇에는 소제물로 기름 섞은 고운 가루를 채웠고","reference":"민수기 7:19","category":"$undefined"},{"id":"3871","book":"민수기","book_name":"민수기","chapter":7,"verse":20,"text":"또 십 세겔중 금숟가락 하나라 그것에는 향을 채웠고","reference":"민수기 7:20","category":"$undefined"},{"id":"3872","book":"민수기","book_name":"민수기","chapter":7,"verse":21,"text":"또 번제물로 수송아지 하나와, 수양 하나와, 일년 된 어린 수양 하나이며","reference":"민수기 7:21","category":"$undefined"},{"id":"3873","book":"민수기","book_name":"민수기","chapter":7,"verse":22,"text":"속죄제물로 수염소 하나이며","reference":"민수기 7:22","category":"$undefined"},{"id":"3874","book":"민수기","book_name":"민수기","chapter":7,"verse":23,"text":"화목제물로 소 둘과, 수양 다섯과 수염소 다섯과, 일년된 어린 수양 다섯이라 이는 수알의 아들 느다넬의 예물이었더라","r