2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":8,"verses":[{"id":"3941","book":"민수기","book_name":"민수기","chapter":8,"verse":1,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 8:1","category":"$undefined"},{"id":"3942","book":"민수기","book_name":"민수기","chapter":8,"verse":2,"text":"아론에게 고하여 이르라 등을 켤 때에는 일곱 등잔을 등대 앞으로 비취게 할지니라 하시매","reference":"민수기 8:2","category":"$undefined"},{"id":"3943","book":"민수기","book_name":"민수기","chapter":8,"verse":3,"text":"아론이 그리하여 등불을 등대 앞으로 비취도록 켰으니 여호와께서 모세에게 명하심과 같았더라","reference":"민수기 8:3","category":"$undefined"},{"id":"3944","book":"민수기","book_name":"민수기","chapter":8,"verse":4,"text":"이 등대의 제도는 이러하니 곧 금을 쳐서 만든 것인데 밑판에서 그 꽃까지 쳐서 만든 것이라 모세가 여호와께서 자기에게 보이신 식양을 따라 이 등대를 만들었더라","reference":"민수기 8:4","category":"$undefined"},{"id":"3945","book":"민수기","book_name":"민수기","chapter":8,"verse":5,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 8:5","category":"$undefined"},{"id":"3946","book":"민수기","book_name":"민수기","chapter":8,"verse":6,"text":"이스라엘 자손 중에서 레위인을 취하여 정결케 하라","reference":"민수기 8:6","category":"$undefined"},{"id":"3947","book":"민수기","book_name":"민수기","chapter":8,"verse":7,"text":"너는 이같이 하여 그들을 정결케 하되 곧 속죄의 물로 그들에게 뿌리고 그들로 그 전신을 삭도로 밀게 하고 그 의복을 빨게 하여 몸을 정결케 하고","reference":"민수기 8:7","category":"$undefined"},{"id":"3948","book":"민수기","book_name":"민수기","chapter":8,"verse":8,"text":"또 그들로 수송아지 하나를 번제물로, 기름 섞은 고운 가루를 그 소제물로 취하게 하고 그 외에 너는 또 수송아지 하나를 속죄물로 취하고","reference":"민수기 8:8","category":"$undefined"},{"id":"3949","book":"민수기","book_name":"민수기","chapter":8,"verse":9,"text":"레위인을 회막 앞에 나오게 하고 이스라엘 자손의 온 회중을 모으고","reference":"민수기 8:9","category":"$undefined"},{"id":"3950","book":"민수기","book_name":"민수기","chapter":8,"verse":10,"text":"레위인을 여호와 앞에 나오게 하고 이스라엘 자손으로 그들에게 안수케 한 후에","reference":"민수기 8:10","category":"$undefined"},{"id":"3951","book":"민수기","book_name":"민수기","chapter":8,"verse":11,"text":"아론이 이스라엘 자손을 위하여 레위인을 요제로 여호와 앞에 드릴지니 이는 그들로 여호와를 봉사케 하기 위함이라","reference":"민수기 8:11","category":"$undefined"},{"id":"3952","book":"민수기","book_name":"민수기","chapter":8,"verse":12,"text":"레위인으로 수송아지들의 머리를 안수케 하고 네가 그 하나는 속죄제물로 하나는 번제물로 여호와께 드려 레위인을 속죄하고","reference":"민수기 8:12","category":"$undefined"},{"id":"3953","book":"민수기","book_name":"민수기","chapter":8,"verse":13,"text":"레위인을 아론과 그 아들들 앞에 세워 여호와께 요제로 드릴지니라","reference":"민수기 8:13","category":"$undefined"},{"id":"3954","book":"민수기","book_name":"민수기","chapter":8,"verse":14,"text":"너는 이같이 이스라엘 자손 중에서 레위인을 구별하라 그리하면 그들이 내게 속할 것이라","reference":"민수기 8:14","category":"$undefined"},{"id":"3955","book":"민수기","book_name":"민수기","chapter":8,"verse":15,"text":"네가 그들을 정결케 하여 요제로 드린 후에 그들이 회막에 들어가서 봉사할 것이니라","reference":"민수기 8:15","category":"$undefined"},{"id":"3956","book":"민수기","book_name":"민수기","chapter":8,"verse":16,"text":"그들은 이스라엘 자손 중에서 내게 온전히 드린바 된 자라 이스라엘 자손 중 일절 초태생 곧 모든 처음 난 자의 대신으로 내가 그들을 취하였나니","reference":"민수기 8:16","category":"$undefined"},{"id":"3957","book":"민수기","book_name":"민수기","chapter":8,"verse":17,"text":"이스라엘 자손 중에 처음 난 것은 사람이든지 짐승이든지 다 내게 속하였음은 내가 애굽 땅에서 그 모든 처음 난 자를 치던 날 에 내가 그들을 내게 구별하였음이라","reference":"민수기 8:17","category":"$undefined"},{"id":"3958","book":"민수기","book_name":"민수기","chapter":8,"verse":18,"text":"이러므로 내가 이스라엘 자손 중 모든 처음 난 자의 대신으로 레위인을 취하였느니라","reference":"민수기 8:18","category":"$undefined"},{"id":"3959","book":"민수기","book_name":"민수기","chapter":8,"verse":19,"text":"내가 이스라엘 자손 중에서 레위인을 취하여 그들을 아론과 그 아들들에게 선물로 주어서 그들로 회막에서 이스라엘 자손을 대신하여 봉사하게 하며 또 이스라엘 자손을 위하여 속죄하게 하였나니 이는 이스라엘 자손이 성소에 가까이 할 때에 그들 중에 재앙이 없게 하려하였음이니라","reference":"민수기 8:19","category":"$undefined"},{"id":"3960","book":"민수기","book_name":"민수기","chapter":8,"verse":20,"text":"모세와 아론과 이스라엘 자손의 온 회중이 여호와께서 레위인에게 대하여 모세에게 명하신 것을 다 좇아 레위인에게 행하였으되 곧 이스라엘 자손이 그와 같이 그들에게 행하였더라","reference":"민수기 8:20","category":"$undefined"},{"id":"3961","book":"민수기","book_name":"민수기","chapter":8,"verse":21,"text":"레위인이 이에 죄에서 스스로 깨끗케 하고 그 옷을 빨매 아론이 그들을 여호와 앞에 요제로 드리고 그가 또 그들을 위하여 속죄 하여 정결케 한","reference":"민수기 8:21","category":"$undefined"},{"id":"3962","book":"민수기","book_name":"민수기","chapter":8,"verse":22,"text":"후에 레위인이 회막에 들어가서 아론과 그 아들들의 앞에서 봉사하니라 여호와께서 레위인의 일에 대하여 모세에게 명하신 것을 좇아 그와 같이 그들에게 행하였더라","reference":"민수기 8:22","category":"$undefined"},{"id":"3963","book":"민수기","book_name":"민수기","chapter":8,"verse":23,"text":"여호와께서 또 모세에게 일러 가라사대","reference":"민수기 8:23","category":"$undefined"},{"id":"3964","book":"민수기","book_name":"민수기","chapter":8,"verse":24,"text":"레위인은 이같이 할지니 곧 이십 오세 이상으로는 회막에 들어와서 봉사하여 일할 것이요","reference":"민수기 8:24","category":"$undefined"},{"id":"3965","book":"민수기","book_name":"민수기","chapter":8,"verse":25,"text":"오십세부터는 그 일을 쉬어 봉사하지 아니할 것이나","reference":"민수기 8:25","category":"$undefined"},{"id":"3966","book":"민수기","book_name":"민수기","chapter":8,"verse":26,"text":"그 형제와 함께 회막에서 모시는 직무를 지킬 것이요 일하지 아니할 것이라 너는 레위인의 직무에 대하여 이같이 할지니라","reference":"민수기 8:26","category":"$undefined"}],"bookSlug":"numbers"}]
