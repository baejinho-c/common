2:["$","$L11",null,{"book":{"id":"numbers","name":"민수기","chapters":36,"testament":"old"},"chapter":9,"verses":[{"id":"3967","book":"민수기","book_name":"민수기","chapter":9,"verse":1,"text":"애굽 땅에서 나온 다음 해 정월에 여호와께서 시내 광야에서 모세에게 일러 가라사대","reference":"민수기 9:1","category":"$undefined"},{"id":"3968","book":"민수기","book_name":"민수기","chapter":9,"verse":2,"text":"이스라엘 자손으로 유월절을 그 정기에 지키게 하라","reference":"민수기 9:2","category":"$undefined"},{"id":"3969","book":"민수기","book_name":"민수기","chapter":9,"verse":3,"text":"그 정기 곧 이달 십 사일 해질 때에 너희는 그것을 지키되 그 모든 율례와 그 모든 규례대로 지킬지니라 !","reference":"민수기 9:3","category":"$undefined"},{"id":"3970","book":"민수기","book_name":"민수기","chapter":9,"verse":4,"text":"모세가 이스라엘 자손에게 명하여 유월절을 지키라 ! 하매","reference":"민수기 9:4","category":"$undefined"},{"id":"3971","book":"민수기","book_name":"민수기","chapter":9,"verse":5,"text":"그들이 정월 십사일 해 질 때에 시내 광야에서 유월절을 지켰으되 이스라엘 자손이 여호와께서 모세에게 명하신 것을 다 좇아 행하였더라","reference":"민수기 9:5","category":"$undefined"},{"id":"3972","book":"민수기","book_name":"민수기","chapter":9,"verse":6,"text":"때에 사람의 시체로 인하여 부정케 되어서 유월절을 지킬 수 없는 사람들이 있었는데 그들이 당일에 모세와 아론 앞에 이르러","reference":"민수기 9:6","category":"$undefined"},{"id":"3973","book":"민수기","book_name":"민수기","chapter":9,"verse":7,"text":"그에게 이르되 `우리가 사람의 시체로 인하여 부정케 되었거니와 우리를 금지하여 이스라엘 자손과 함께 정기에 여호와께 예물을 드리지 못하게 하심은 어찜이니이까 ?'","reference":"민수기 9:7","category":"$undefined"},{"id":"3974","book":"민수기","book_name":"민수기","chapter":9,"verse":8,"text":"모세가 그들에게 이르되 `기다리라 여호와께서 너희에게 대하여 어떻게 명하시는지 내가 들으리라'","reference":"민수기 9:8","category":"$undefined"},{"id":"3975","book":"민수기","book_name":"민수기","chapter":9,"verse":9,"text":"여호와께서 모세에게 일러 가라사대","reference":"민수기 9:9","category":"$undefined"},{"id":"3976","book":"민수기","book_name":"민수기","chapter":9,"verse":10,"text":"이스라엘 자손에게 일러 고하여 이르라 너희나 너희 후손 중에 시체로 인하여 부정케 되든지 먼 여행 중에 있든지 할지라도 다 여호와 앞에 마땅히 유월절을 지키되","reference":"민수기 9:10","category":"$undefined"},{"id":"3977","book":"민수기","book_name":"민수기","chapter":9,"verse":11,"text":"이월 십사일 해 질 때에 그것을 지켜서 어린 양에 무교병과 쓴 나물을 아울러 먹을 것이요","reference":"민수기 9:11","category":"$undefined"},{"id":"3978","book":"민수기","book_name":"민수기","chapter":9,"verse":12,"text":"아침까지 그것을 조금도 남겨 두지 말며 그 뼈를 하나도 꺽지 말아서 유월절 모든 율례대로 지킬 것이니라","reference":"민수기 9:12","category":"$undefined"},{"id":"3979","book":"민수기","book_name":"민수기","chapter":9,"verse":13,"text":"그러나 사람이 정결도 하고 여행 중에도 있지 아니하면서 유월절을 지키지 아니하는 자는 그 백성중에서 끊쳐지리니 이런 사람은그 정기에 여호와께 예물을 드리지 아니하였은즉 그 죄를 당할지며","reference":"민수기 9:13","category":"$undefined"},{"id":"3980","book":"민수기","book_name":"민수기","chapter":9,"verse":14,"text":"만일 타국인이 너희 중에 우거하여 여호와 앞에 유월절을 지키고자 하면 유월절 율례대로 그 규례를 따라서 행할지니 우거한 자에게나 본토인에게나 그 율례는 동일할 것이니라","reference":"민수기 9:14","category":"$undefined"},{"id":"3981","book":"민수기","book_name":"민수기","chapter":9,"verse":15,"text":"성막을 세운 날에 구름이 성막 곧 증거막을 덮었고 저녁이 되면 성막 위에 불 모양 같은 것이 나타나서 아침까지 이르렀으되","reference":"민수기 9:15","category":"$undefined"},{"id":"3982","book":"민수기","book_name":"민수기","chapter":9,"verse":16,"text":"항상 그러하여 낮에는 구름이 그것을 덮었고 밤에는 불 모양이 있었는데","reference":"민수기 9:16","category":"$undefined"},{"id":"3983","book":"민수기","book_name":"민수기","chapter":9,"verse":17,"text":"구름이 성막에서 떠오르는 때에는 이스라엘 자손이 곧 진행하였고 구름이 머무는 곳에 이스라엘 자손이 진을 쳤으니","reference":"민수기 9:17","category":"$undefined"},{"id":"3984","book":"민수기","book_name":"민수기","chapter":9,"verse":18,"text":"이스라엘 자손이 여호와의 명을 좇아 진행하였고 여호와의 명을 좇아 진을 쳤으며 구름이 성막 위에 머무는 동안에는 그들이 유진하였고","reference":"민수기 9:18","category":"$undefined"},{"id":"3985","book":"민수기","book_name":"민수기","chapter":9,"verse":19,"text":"구름이 장막 위에 머무는 날이 오랠 때에는 이스라엘 자손이 여호와의 명을 지켜 진행치 아니하였으며","reference":"민수기 9:19","category":"$undefined"},{"id":"3986","book":"민수기","book_name":"민수기","chapter":9,"verse":20,"text":"혹시 구름이 장막 위에 머무는 날이 적을 때에도 그들이 다만 여호와의 명을 좇아 유진하고 여호와의 명을 좇아 진행하였으며","reference":"민수기 9:20","category":"$undefined"},{"id":"3987","book":"민수기","book_name":"민수기","chapter":9,"verse":21,"text":"혹시 구름이 저녁부터 아침까지 있다가 아침에 그 구름이 떠오를때에는 그들이 진행하였고 구름이 밤낮 있다가 떠 오르면 곧 진행하였으며","reference":"민수기 9:21","category":"$undefined"},{"id":"3988","book":"민수기","book_name":"민수기","chapter":9,"verse":22,"text":"이틀이든지, 한달이든지, 일년이든지, 구름이 성막 위에 머물러 있을 동안에는 이스라엘 자손이 유진하고 진행치 아니하다가 떠오르면 진행하였으니","reference":"민수기 9:22","category":"$undefined"},{"id":"3989","book":"민수기","book_name":"민수기","chapter":9,"verse":23,"text":"곧 그들이 여호와의 명을 좇아 진을 치며 여호와의 명을 좇아 진행하고 또 모세로 전하신 여호와의 명을 따라 여호와의 직임을 지켰더라","reference":"민수기 9:23","category":"$undefined"}],"bookSlug":"numbers"}]
