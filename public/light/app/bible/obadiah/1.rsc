2:["$","$L11",null,{"book":{"id":"obadiah","name":"오바댜","chapters":1,"testament":"old"},"chapter":1,"verses":[{"id":"22512","book":"오바댜","book_name":"오바댜","chapter":1,"verse":1,"text":"오바댜의 묵시라 주 여호와께서 에돔에 대하여 이같이 말씀하시니라 우리가 여호와께로 말미암아 소식을 들었나니 곧 사자가 열국 중에 보내심을 받고 이르기를 너희는 일어날지어다 우리가 일어나서 그로 더불어 싸우자 하는 것이니라","reference":"오바댜 1:1","category":"$undefined"},{"id":"22513","book":"오바댜","book_name":"오바댜","chapter":1,"verse":2,"text":"여호와께서 가라사대 내가 너를 열국 중에 미약하게 하였으므로 네가 크게 멸시를 받느니라","reference":"오바댜 1:2","category":"$undefined"},{"id":"22514","book":"오바댜","book_name":"오바댜","chapter":1,"verse":3,"text":"바위 틈에 거하며 높은 곳에 사는 자여 네가 중심에 이르기를 누가 능히 나를 땅에 끌어내리겠느냐 ? 하니 너의 중심의 교만이 너를 속였도다","reference":"오바댜 1:3","category":"$undefined"},{"id":"22515","book":"오바댜","book_name":"오바댜","chapter":1,"verse":4,"text":"네가 독수리처럼 높이 오르며 별 사이에 깃들일지라도 내가 거기서 너를 끌어내리리라 나 여호와가 말하였느니라","reference":"오바댜 1:4","category":"$undefined"},{"id":"22516","book":"오바댜","book_name":"오바댜","chapter":1,"verse":5,"text":"혹시 도적이 네게 이르렀으며 강도가 밤중에 네게 이르렀을지라도 그 마음에 만족하게 취하면 그치지 아니하였겠느냐 ? 혹시 포도를 따는 자가 네게 이르렀을지라도 그것을 얼마쯤 남기지 아니하였겠느냐 ? 네가 어찌 그리 망하였는고","reference":"오바댜 1:5","category":"$undefined"},{"id":"22517","book":"오바댜","book_name":"오바댜","chapter":1,"verse":6,"text":"에서가 어찌 그리 수탐되었으며 그 감춘 보물이 어찌 그리 수탐되었는고","reference":"오바댜 1:6","category":"$undefined"},{"id":"22518","book":"오바댜","book_name":"오바댜","chapter":1,"verse":7,"text":"너와 약조한 자들이 다 너를 쫓아 변경에 이르게 하며 너와 화목하던 자들이 너를 속이고 이기며 네 식물을 먹는 자들이 네 아래 함정을 베푸니 네 마음에 지각이 없음이로다","reference":"오바댜 1:7","category":"$undefined"},{"id":"22519","book":"오바댜","book_name":"오바댜","chapter":1,"verse":8,"text":"나 여호와가 말하노라 그 날에 내가 에돔에서 지혜 있는 자를 멸하며 에서의 산에서 지각있는 자를 멸하지 아니하겠느냐 ?","reference":"오바댜 1:8","category":"$undefined"},{"id":"22520","book":"오바댜","book_name":"오바댜","chapter":1,"verse":9,"text":"드만아 네 용사들이 놀랄 것이라 이로 인하여 에서의 산의 거민이 살륙을 당하여 다 멸절되리라","reference":"오바댜 1:9","category":"$undefined"},{"id":"22521","book":"오바댜","book_name":"오바댜","chapter":1,"verse":10,"text":"네가 네 형제 야곱에게 행한 포학을 인하여 수욕을 입고 영원히 멸절되리라","reference":"오바댜 1:10","category":"$undefined"},{"id":"22522","book":"오바댜","book_name":"오바댜","chapter":1,"verse":11,"text":"네가 멀리 섰던 날 곧 이방인이 그의 재물을 늑탈하며 외국인이 그의 성문에 들어가서 예루살렘을 얻기 위하여 제비뽑던 날에 너도 그들 중 한 사람 같았었느니라","reference":"오바댜 1:11","category":"$undefined"},{"id":"22523","book":"오바댜","book_name":"오바댜","chapter":1,"verse":12,"text":"네가 형제의 날 곧 그 재앙의 날에 방관할 것이 아니며 그 고난의 날에 네가 입을 크게 벌릴 것이 아니라","reference":"오바댜 1:12","category":"$undefined"},{"id":"22524","book":"오바댜","book_name":"오바댜","chapter":1,"verse":13,"text":"내 백성이 환난을 당하는 날에 네가 그 성문에 들어가지 않을 것이며 환난을 당하는 날에 네가 그 고난을 방관하지 않을 것이며 환난을 당하는 날에 네가 그 재물에 손을 대지 않을 것이며","reference":"오바댜 1:13","category":"$undefined"},{"id":"22525","book":"오바댜","book_name":"오바댜","chapter":1,"verse":14,"text":"사거리에 서서 그 도망하는 자를 막지 않을 것이며 고난의 날에 그 남은 자를 대적에게 붙이지 않을 것이니라","reference":"오바댜 1:14","category":"$undefined"},{"id":"22526","book":"오바댜","book_name":"오바댜","chapter":1,"verse":15,"text":"여호와의 만국을 벌할 날이 가까왔나니 너의 행한대로 너도 받을 것인즉 너의 행한 것이 네 머리로 돌아갈 것이라","reference":"오바댜 1:15","category":"$undefined"},{"id":"22527","book":"오바댜","book_name":"오바댜","chapter":1,"verse":16,"text":"너희가 내 성산에서 마신 것 같이 만국인이 항상 마시리니 곧 마시고 삼켜서 본래 없던 것 같이 되리라","reference":"오바댜 1:16","category":"$undefined"},{"id":"22528","book":"오바댜","book_name":"오바댜","chapter":1,"verse":17,"text":"오직 시온산에서 피할 자가 있으리니 그산이 거룩할 것이요 야곱 족속은 자기 기업을 누릴 것이며","reference":"오바댜 1:17","category":"$undefined"},{"id":"22529","book":"오바댜","book_name":"오바댜","chapter":1,"verse":18,"text":"야곱 족속은 불이 될 것이요 요셉 족속은 불꽃이 될 것이며 에서 족속은 초개가 될 것이라 그들이 그의 위에 붙어서 그를 사를 것인즉 에서 족속에 남은 자가 없으리니 이는 여호와께서 말씀하셨음이니라","reference":"오바댜 1:18","category":"$undefined"},{"id":"22530","book":"오바댜","book_name":"오바댜","chapter":1,"verse":19,"text":"남방 사람은 에서의 산을 얻을 것이며 평지 사람은 블레셋을 얻을 것이요 또 그들이 에브라임의 들과 사마리아의 들을 얻을 것이며 베냐민은 길르앗을 얻을 것이며","reference":"오바댜 1:19","category":"$undefined"},{"id":"22531","book":"오바댜","book_name":"오바댜","chapter":1,"verse":20,"text":"사로잡혔던 이스라엘의 뭇 자손은 가나안 사람에게 속한 땅을 사르밧까지 얻을 것이며 예루살렘의 사로잡혔던 자 곧 스바랏에 있는 자는 남방의 성읍들을 얻을 것이니라","reference":"오바댜 1:20","category":"$undefined"},{"id":"22532","book":"오바댜","book_name":"오바댜","chapter":1,"verse":21,"text":"구원자들이 시온산에 올라와서 에서의 산을 심판하리니 나라가 여호와께 속하리라","reference":"오바댜 1:21","category":"$undefined"}],"bookSlug":"obadiah"}]
