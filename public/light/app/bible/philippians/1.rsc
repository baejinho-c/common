2:["$","$L11",null,{"book":{"id":"philippians","name":"빌립보서","chapters":4,"testament":"new"},"chapter":1,"verses":[{"id":"29363","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":1,"text":"그리스도 예수의 종 바울과 디모데는 그리스도 예수 안에서 빌립보에 사는 모든 성도와 또는 감독들과 집사들에게 편지하노니","reference":"빌립보서 1:1","category":"$undefined"},{"id":"29364","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":2,"text":"하나님 우리 아버지와 주 예수 그리스도에게로서 은혜와 평강이 너희에게 있을지어다","reference":"빌립보서 1:2","category":"$undefined"},{"id":"29365","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":3,"text":"내가 너희를 생각할 때마다 나의 하나님께 감사하며","reference":"빌립보서 1:3","category":"$undefined"},{"id":"29366","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":4,"text":"간구할 때마다 너희 무리를 위하여 기쁨으로 항상 간구함은","reference":"빌립보서 1:4","category":"$undefined"},{"id":"29367","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":5,"text":"첫날부터 이제까지 복음에서 너희가 교제함을 인함이라","reference":"빌립보서 1:5","category":"$undefined"},{"id":"29368","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":6,"text":"너희 속에 착한 일을 시작하신 이가 그리스도 예수의 날까지 이루실 줄을 우리가 확신하노라","reference":"빌립보서 1:6","category":"$undefined"},{"id":"29369","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":7,"text":"내가 너희 무리를 위하여 이와 같이 생각하는 것이 마땅하니 이는 너희가 내 마음에 있음이며 나의 매임과 복음을 변명함과 확정함에 너희가 다 나와 함께 은혜에 참예한 자가 됨이라","reference":"빌립보서 1:7","category":"$undefined"},{"id":"29370","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":8,"text":"내가 예수 그리스도의 심장으로 너희 무리를 어떻게 사모하는지 하나님이 내 증인이시니라","reference":"빌립보서 1:8","category":"$undefined"},{"id":"29371","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":9,"text":"내가 기도하노라 너희 사랑을 지식과 모든 총명으로 점점 더 풍성하게 하사","reference":"빌립보서 1:9","category":"$undefined"},{"id":"29372","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":10,"text":"너희로 지극히 선한 것을 분별하며 또 진실하여 허물 없이 그리스도의 날까지 이르고","reference":"빌립보서 1:10","category":"$undefined"},{"id":"29373","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":11,"text":"예수 그리스도로 말미암아 의의 열매가 가득하여 하나님의 영광과 찬송이 되게 하시기를 구하노라","reference":"빌립보서 1:11","category":"$undefined"},{"id":"29374","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":12,"text":"형제들아 나의 당한 일이 도리어 복음의 진보가 된 줄을 너희가 알기를 원하노라","reference":"빌립보서 1:12","category":"$undefined"},{"id":"29375","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":13,"text":"이러므로 나의 매임이 그리스도 안에서 온 시위대 안과 기타 모든 사람에게 나타났으니","reference":"빌립보서 1:13","category":"$undefined"},{"id":"29376","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":14,"text":"형제 중 다수가 나의 매임을 인하여 주 안에서 신뢰하므로 겁 없이 하나님의 말씀을 더욱 담대히 말하게 되었느니라","reference":"빌립보서 1:14","category":"$undefined"},{"id":"29377","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":15,"text":"어떤 이들은 투기와 분쟁으로 어떤 이들은 착한 뜻으로 그리스도를 전파하나니","reference":"빌립보서 1:15","category":"$undefined"},{"id":"29378","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":16,"text":"이들은 내가 복음을 변명하기 위하여 세우심을 받은 줄 알고 사랑으로 하나","reference":"빌립보서 1:16","category":"$undefined"},{"id":"29379","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":17,"text":"저들은 나의 매임에 괴로움을 더하게 할 줄로 생각하여 순전치 못하게 다툼으로 그리스도를 전파하느니라","reference":"빌립보서 1:17","category":"$undefined"},{"id":"29380","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":18,"text":"그러면 무엇이뇨 ? 외모로 하나 참으로 하나 무슨 방도로 하든지 전파되는 것은 그리스도니 이로써 내가 기뻐하고 또한 기뻐하리라","reference":"빌립보서 1:18","category":"$undefined"},{"id":"29381","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":19,"text":"이것이 너희 간구와 예수 그리스도의 성령의 도우심으로 내 구원에 이르게 할 줄 아는고로","reference":"빌립보서 1:19","category":"$undefined"},{"id":"29382","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":20,"text":"나의 간절한 기대와 소망을 따라 아무 일에든지 부끄럽지 아니하고 오직 전과 같이 이제도 온전히 담대하여 살든지 죽든지 내 몸에서 그리스도가 존귀히 되게 하려 하나니","reference":"빌립보서 1:20","category":"$undefined"},{"id":"29383","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":21,"text":"이는 내게 사는 것이 그리스도니 죽는 것도 유익함이니라","reference":"빌립보서 1:21","category":"$undefined"},{"id":"29384","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":22,"text":"그러나 만일 육신으로 사는 이것이 내 일의 열매일진대 무엇을 가릴는지 나는 알지 못하노라","reference":"빌립보서 1:22","category":"$undefined"},{"id":"29385","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":23,"text":"내가 그 두 사이에 끼였으니 떠나서 그리스도와 함께 있을 욕망을 가진 이것이 더욱 좋으나","reference":"빌립보서 1:23","category":"$undefined"},{"id":"29386","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":24,"text":"그러나 내가 육신에 거하는 것이 너희를 위하여 더 유익하리라","reference":"빌립보서 1:24","category":"$undefined"},{"id":"29387","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":25,"text":"내가 살 것과 너희 믿음의 진보와 기쁨을 위하여 너희 무리와 함께 거할 이것을 확실히 아노니","reference":"빌립보서 1:25","category":"$undefined"},{"id":"29388","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":26,"text":"내가 다시 너희와 같이 있음으로 그리스도 예수 안에서 너희 자랑이 나를 인하여 풍성하게 하려 함이라","reference":"빌립보서 1:26","category":"$undefined"},{"id":"29389","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":27,"text":"오직 너희는 그리스도 복음에 합당하게 생활하라 이는 내가 너희를 가 보나 떠나 있으나 너희가 일심으로 서서 한 뜻으로 복음의 신앙을 위하여 협력하는 것과","reference":"빌립보서 1:27","category":"$undefined"},{"id":"29390","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":28,"text":"아무 일에든지 대적하는 자를 인하여 두려워하지 아니하는 이 일을 듣고자 함이라 이것이 저희에게는 멸망의 빙거요 너희에게는 구원의 빙거니 이는 하나님께로부터 난 것이니라","reference":"빌립보서 1:28","category":"$undefined"},{"id":"29391","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":29,"text":"그리스도를 위하여 너희에게 은혜를 주신 것은 다만 그를 믿을 뿐 아니라 또한 그를 위하여 고난도 받게 하심이라","reference":"빌립보서 1:29","category":"$undefined"},{"id":"29392","book":"빌립보서","book_name":"빌립보서","chapter":1,"verse":30,"text":"너희에게도 같은 싸움이 있으니 너희가 내 안에서 본 바요 이제도 내 안에서 듣는 바니라","reference":"빌립보서 1:30","category":"$undefined"}],"bookSlug":"philippians"}]
