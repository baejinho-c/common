2:["$","$L11",null,{"book":{"id":"philippians","name":"빌립보서","chapters":4,"testament":"new"},"chapter":2,"verses":[{"id":"29393","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":1,"text":"그러므로 그리스도 안에 무슨 권면이나 사랑에 무슨 위로나 성령의 무슨 교제나 긍휼이나 자비가 있거든","reference":"빌립보서 2:1","category":"$undefined"},{"id":"29394","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":2,"text":"마음을 같이 하여 같은 사랑을 가지고 뜻을 합하며 한 마음을 품어","reference":"빌립보서 2:2","category":"$undefined"},{"id":"29395","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":3,"text":"아무 일에든지 다툼이나 허영으로 하지 말고 오직 겸손한 마음으로 각각 자기보다 남을 낫게 여기고","reference":"빌립보서 2:3","category":"$undefined"},{"id":"29396","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":4,"text":"각각 자기 일을 돌아볼 뿐더러 또한 각각 다른 사람들의 일을 돌아보아 나의 기쁨을 충만케 하라","reference":"빌립보서 2:4","category":"$undefined"},{"id":"29397","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":5,"text":"너희 안에 이 마음을 품으라 ! 곧 그리스도 예수의 마음이니","reference":"빌립보서 2:5","category":"$undefined"},{"id":"29398","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":6,"text":"그는 근본 하나님의 본체시나 하나님과 동등됨을 취할 것으로 여기지 아니하시고","reference":"빌립보서 2:6","category":"$undefined"},{"id":"29399","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":7,"text":"오히려 자기를 비어 종의 형체를 가져 사람들과 같이 되었고","reference":"빌립보서 2:7","category":"$undefined"},{"id":"29400","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":8,"text":"사람의 모양으로 나타나셨으매 자기를 낮추시고 죽기까지 복종하셨으니 곧 십자가에 죽으심이라","reference":"빌립보서 2:8","category":"$undefined"},{"id":"29401","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":9,"text":"이러므로 하나님이 그를 지극히 높여 모든 이름 위에 뛰어난 이름을 주사","reference":"빌립보서 2:9","category":"$undefined"},{"id":"29402","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":10,"text":"하늘에 있는 자들과 땅에 있는 자들과 땅 아래 있는 자들로 모든 무릎을 예수의 이름에 꿇게 하시고","reference":"빌립보서 2:10","category":"$undefined"},{"id":"29403","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":11,"text":"모든 입으로 예수 그리스도를 주라 시인하여 하나님 아버지께 영광을 돌리게 하셨느니라","reference":"빌립보서 2:11","category":"$undefined"},{"id":"29404","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":12,"text":"그러므로 나의 사랑하는 자들아 너희가 나 있을 때 뿐 아니라 더욱 지금 나 없을 때에도 항상 복종하여 두렵고 떨림으로 너희 구원을 이루라","reference":"빌립보서 2:12","category":"$undefined"},{"id":"29405","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":13,"text":"너희 안에서 행하시는 이는 하나님이시니 자기의 기쁘신 뜻을 위하여 너희로 소원을 두고 행하게 하시나니","reference":"빌립보서 2:13","category":"$undefined"},{"id":"29406","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":14,"text":"모든 일을 원망과 시비가 없이 하라","reference":"빌립보서 2:14","category":"$undefined"},{"id":"29407","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":15,"text":"이는 너희가 흠이 없고 순전하여 어그러지고 거스리는 세대 가운데서 하나님의 흠 없는 자녀로 세상에서 그들 가운데 빛들로 나타내며","reference":"빌립보서 2:15","category":"$undefined"},{"id":"29408","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":16,"text":"생명의 말씀을 밝혀 나의 달음질도 헛되지 아니하고 수고도 헛되지 아니함으로 그리스도의 날에 나로 자랑할 것이 있게 하려 함이라","reference":"빌립보서 2:16","category":"$undefined"},{"id":"29409","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":17,"text":"만일 너희 믿음의 제물과 봉사 위에 내가 나를 관제로 드릴지라도 나는 기뻐하고 너희 무리와 함께 기뻐하리니","reference":"빌립보서 2:17","category":"$undefined"},{"id":"29410","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":18,"text":"이와 같이 너희도 기뻐하고 나와 함께 기뻐하라","reference":"빌립보서 2:18","category":"$undefined"},{"id":"29411","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":19,"text":"내가 디모데를 속히 너희에게 보내기를 주 안에서 바람은 너희 사정을 앎으로 안위를 받으려 함이니","reference":"빌립보서 2:19","category":"$undefined"},{"id":"29412","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":20,"text":"이는 뜻을 같이 하여 너희 사정을 진실히 생각할 자가 이 밖에 내게 없음이라","reference":"빌립보서 2:20","category":"$undefined"},{"id":"29413","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":21,"text":"저희가 다 자기 일을 구하고 그리스도 예수의 일을 구하지 아니하되","reference":"빌립보서 2:21","category":"$undefined"},{"id":"29414","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":22,"text":"디모데의 연단을 너희가 아나니 자식이 아비에게 함같이 나와 함께 복음을 위하여 수고하였느니라","reference":"빌립보서 2:22","category":"$undefined"},{"id":"29415","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":23,"text":"그러므로 내가 내 일이 어떻게 될 것을 보아서 곧 이 사람을 보내기를 바라고","reference":"빌립보서 2:23","category":"$undefined"},{"id":"29416","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":24,"text":"나도 속히 가기를 주 안에서 확신하노라","reference":"빌립보서 2:24","category":"$undefined"},{"id":"29417","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":25,"text":"그러나 에바브로디도를 너희에게 보내는 것이 필요한 줄로 생각하노니 그는 나의 형제요 함께 수고하고 함께 군사 된 자요 너희 사자로 나의 쓸 것을 돕는 자라","reference":"빌립보서 2:25","category":"$undefined"},{"id":"29418","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":26,"text":"그가 너희 무리를 간절히 사모하고 자기 병든 것을 너희가 들은 줄을 알고 심히 근심한지라","reference":"빌립보서 2:26","category":"$undefined"},{"id":"29419","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":27,"text":"저가 병들어 죽게 되었으나 하나님이 저를 긍휼히 여기셨고 저 뿐 아니라 또 나를 긍휼히 여기사 내 근심 위에 근심을 면하게 하셨느니라","reference":"빌립보서 2:27","category":"$undefined"},{"id":"29420","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":28,"text":"그러므로 내가 더욱 급히 저를 보낸 것은 너희로 저를 다시 보고 기뻐하게 하며 내 근심도 덜려 함이니","reference":"빌립보서 2:28","category":"$undefined"},{"id":"29421","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":29,"text":"이러므로 너희가 주 안에서 모든 기쁨으로 저를 영접하고 또 이와 같은 자들을 존귀히 여기라","reference":"빌립보서 2:29","category":"$undefined"},{"id":"29422","book":"빌립보서","book_name":"빌립보서","chapter":2,"verse":30,"text":"저가 그리스도의 일을 위하여 죽기에 이르러도 자기 목숨을 돌아보지 아니한 것은 나를 섬기는 너희의 일에 부족함을 채우려 함이니라","reference":"빌립보서 2:30","category":"$undefined"}],"bookSlug":"philippians"}]
