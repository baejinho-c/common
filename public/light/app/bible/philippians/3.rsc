2:["$","$L11",null,{"book":{"id":"philippians","name":"빌립보서","chapters":4,"testament":"new"},"chapter":3,"verses":[{"id":"29423","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":1,"text":"종말로 나의 형제들아 주 안에서 기뻐하라 ! 너희에게 같은 말을 쓰는 것이 내게는 수고로움이 없고 너희에게는 안전하니라","reference":"빌립보서 3:1","category":"$undefined"},{"id":"29424","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":2,"text":"개들을 삼가고 행악하는 자들을 삼가고 손할례당을 삼가라","reference":"빌립보서 3:2","category":"$undefined"},{"id":"29425","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":3,"text":"하나님의 성령으로 봉사하며 그리스도 예수로 자랑하고 육체를 신뢰하지 아니하는 우리가 곧 할례당이라","reference":"빌립보서 3:3","category":"$undefined"},{"id":"29426","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":4,"text":"그러나 나도 육체를 신뢰할 만하니 만일 누구든지 다른 이가 육체를 신뢰할 것이 있는 줄로 생각하면 나는 더욱 그러하리니","reference":"빌립보서 3:4","category":"$undefined"},{"id":"29427","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":5,"text":"내가 팔일 만에 할례를 받고 이스라엘의 족속이요 베냐민의 지파요 히브리인 중의 히브리인이요 율법으로는 바리새인이요","reference":"빌립보서 3:5","category":"$undefined"},{"id":"29428","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":6,"text":"열심으로는 교회를 핍박하고 율법의 의로는 흠이 없는 자로라","reference":"빌립보서 3:6","category":"$undefined"},{"id":"29429","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":7,"text":"그러나 무엇이든지 내게 유익하던 것을 내가 그리스도를 위하여 다 해로 여길 뿐더러","reference":"빌립보서 3:7","category":"$undefined"},{"id":"29430","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":8,"text":"또한 모든 것을 해로 여김은 내 주 그리스도 예수를 아는 지식이 가장 고상함을 인함이라 내가 그를 위하여 모든 것을 잃어버리고 배설물로 여김은 그리스도를 얻고","reference":"빌립보서 3:8","category":"$undefined"},{"id":"29431","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":9,"text":"그 안에서 발견되려 함이니 내가 가진 의는 율법에서 난 것이 아니요 오직 그리스도를 믿음으로 말미암은 것이니 곧 믿음으로 하나님께로서 난 의라","reference":"빌립보서 3:9","category":"$undefined"},{"id":"29432","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":10,"text":"내가 그리스도와 그 부활의 권능과 그 고난에 참예함을 알려하여 그의 죽으심을 본받아","reference":"빌립보서 3:10","category":"$undefined"},{"id":"29433","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":11,"text":"어찌하든지 죽은 자 가운데서 부활에 이르려 하노니","reference":"빌립보서 3:11","category":"$undefined"},{"id":"29434","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":12,"text":"내가 이미 얻었다 함도 아니요 온전히 이루었다 함도 아니라 오직 내가 그리스도 예수께 잡힌 바 된 그것을 잡으려고 좇아가노라","reference":"빌립보서 3:12","category":"$undefined"},{"id":"29435","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":13,"text":"형제들아 나는 아직 내가 잡은 줄로 여기지 아니하고 오직 한 일, 즉 뒤에 있는 것은 잊어버리고 앞에 있는 것을 잡으려고","reference":"빌립보서 3:13","category":"$undefined"},{"id":"29436","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":14,"text":"푯대를 향하여 그리스도 예수 안에서 하나님이 위에서 부르신 부름의 상을 위하여 좇아가노라","reference":"빌립보서 3:14","category":"$undefined"},{"id":"29437","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":15,"text":"그러므로 누구든지 우리 온전히 이룬 자들은 이렇게 생각할지니 만일 무슨 일에 너희가 달리 생각하면 하나님이 이것도 너희에게 나타내시리라","reference":"빌립보서 3:15","category":"$undefined"},{"id":"29438","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":16,"text":"오직 우리가 어디까지 이르렀든지 그대로 행할 것이라","reference":"빌립보서 3:16","category":"$undefined"},{"id":"29439","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":17,"text":"형제들아 너희는 함께 나를 본받으라 또 우리로 본을 삼은 것같이 그대로 행하는 자들을 보이라","reference":"빌립보서 3:17","category":"$undefined"},{"id":"29440","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":18,"text":"내가 여러 번 너희에게 말하였거니와 이제도 눈물을 흘리며 말하노니 여러 사람들이 그리스도 십자가의 원수로 행하느니라","reference":"빌립보서 3:18","category":"$undefined"},{"id":"29441","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":19,"text":"저희의 마침은 멸망이요 저희의 신은 배요 그 영광은 저희의 부끄러움에 있고 땅의 일을 생각하는 자라","reference":"빌립보서 3:19","category":"$undefined"},{"id":"29442","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":20,"text":"오직 우리의 시민권은 하늘에 있는지라 거기로서 구원하는 자 곧 주 예수 그리스도를 기다리노니","reference":"빌립보서 3:20","category":"$undefined"},{"id":"29443","book":"빌립보서","book_name":"빌립보서","chapter":3,"verse":21,"text":"그가 만물을 자기에게 복종케 하실 수 있는 자의 역사로 우리의 낮은 몸을 자기 영광의 몸의 형체와 같이 변케 하시리라","reference":"빌립보서 3:21","category":"$undefined"}],"bookSlug":"philippians"}]
