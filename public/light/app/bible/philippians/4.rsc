2:["$","$L11",null,{"book":{"id":"philippians","name":"빌립보서","chapters":4,"testament":"new"},"chapter":4,"verses":[{"id":"29444","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":1,"text":"그러므로 나의 사랑하고 사모하는 형제들,나의 기쁨이요 면류관인 사랑하는 자들아 이와 같이 주 안에 서라","reference":"빌립보서 4:1","category":"$undefined"},{"id":"29445","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":2,"text":"내가 유오디아를 권하고 순두게를 권하노니 주 안에서 같은 마음을 품으라","reference":"빌립보서 4:2","category":"$undefined"},{"id":"29446","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":3,"text":"또 참으로 나와 멍에를 같이 한 자 네게 구하노니 복음에 나와 함께 힘쓰던 저 부녀들을 돕고 또한 글레멘드와 그 위에 나의 동역자들을 도우라 그 이름들이 생명책에 있느니라","reference":"빌립보서 4:3","category":"$undefined"},{"id":"29447","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":4,"text":"주 안에서 항상 기뻐하라 ! 내가 다시 말하노니 기뻐하라 !","reference":"빌립보서 4:4","category":"$undefined"},{"id":"29448","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":5,"text":"너희 관용을 모든 사람에게 알게 하라 주께서 가까우시니라","reference":"빌립보서 4:5","category":"$undefined"},{"id":"29449","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":6,"text":"아무 것도 염려하지 말고 오직 모든 일에 기도와 간구로 너희 구할 것을 감사함으로 하나님께 아뢰라","reference":"빌립보서 4:6","category":"$undefined"},{"id":"29450","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":7,"text":"그리하면 모든 지각에 뛰어난 하나님의 평강이 그리스도 예수 안에서 너희 마음과 생각을 지키시리라","reference":"빌립보서 4:7","category":"$undefined"},{"id":"29451","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":8,"text":"종말로 형제들아 무엇에든지 참되며, 무엇에든지 경건하며, 무엇에든지 옳으며, 무엇에든지 정결하며, 무엇에든지 사랑할 만하며, 무엇에든지 칭찬할 만하며, 무슨 덕이 있든지, 무슨 기림이 있든지, 이것들을 생각하라 !","reference":"빌립보서 4:8","category":"$undefined"},{"id":"29452","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":9,"text":"너희는 내게 배우고 받고 듣고 본 바를 행하라 그리하면 평강의 하나님이 너희와 함께 계시리라","reference":"빌립보서 4:9","category":"$undefined"},{"id":"29453","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":10,"text":"내가 주 안에서 크게 기뻐함은 너희가 나를 생각하던 것이 이제 다시 싹이 남이니 너희가 또한 이를 위하여 생각은 하였으나 기회가 없었느니라","reference":"빌립보서 4:10","category":"$undefined"},{"id":"29454","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":11,"text":"내가 궁핍하므로 말하는 것이 아니라 어떠한 형편에든지 내가 자족하기를 배웠노니","reference":"빌립보서 4:11","category":"$undefined"},{"id":"29455","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":12,"text":"내가 비천에 처할 줄도 알고 풍부에 처할 줄도 알아 모든 일에 배부르며 배고픔과 풍부와 궁핍에도 일체의 비결을 배웠노라","reference":"빌립보서 4:12","category":"$undefined"},{"id":"29456","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":13,"text":"내게 능력 주시는 자 안에서 내가 모든 것을 할 수 있느니라 !","reference":"빌립보서 4:13","category":"$undefined"},{"id":"29457","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":14,"text":"그러나 너희가 내 괴로움에 함께 참예하였으니 잘하였도다","reference":"빌립보서 4:14","category":"$undefined"},{"id":"29458","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":15,"text":"빌립보 사람들아 ! 너희도 알거니와 복음의 시초에 내가 마게도냐를 떠날 때에 주고 받는 내 일에 참예한 교회가 너희 외에 아무도 없었느니라","reference":"빌립보서 4:15","category":"$undefined"},{"id":"29459","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":16,"text":"데살로니가에 있을 때에도 너희가 한 번 두 번 나의 쓸 것을 보내었도다","reference":"빌립보서 4:16","category":"$undefined"},{"id":"29460","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":17,"text":"내가 선물을 구함이 아니요 오직 너희에게 유익하도록 과실이 번성하기를 구함이라","reference":"빌립보서 4:17","category":"$undefined"},{"id":"29461","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":18,"text":"내게는 모든 것이 있고 또 풍부한지라 에바브로디도 편에 너희의 준 것을 받으므로 내가 풍족하니 이는 받으실 만한 향기로운 제물이요 하나님을 기쁘시게 한 것이라","reference":"빌립보서 4:18","category":"$undefined"},{"id":"29462","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":19,"text":"나의 하나님이 그리스도 예수 안에서 영광 가운데 그 풍성한 대로 너희 모든 쓸 것을 채우시리라","reference":"빌립보서 4:19","category":"$undefined"},{"id":"29463","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":20,"text":"하나님 곧 우리 아버지께 세세 무궁토록 영광을 돌릴지어다 아멘","reference":"빌립보서 4:20","category":"$undefined"},{"id":"29464","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":21,"text":"그리스도 예수 안에 있는 성도에게 각각 문안하라 나와 함께 있는 형제들이 너희에게 문안하고","reference":"빌립보서 4:21","category":"$undefined"},{"id":"29465","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":22,"text":"모든 성도들이 너희에게 문안하되 특별히 가이사 집 사람 중 몇이니라","reference":"빌립보서 4:22","category":"$undefined"},{"id":"29466","book":"빌립보서","book_name":"빌립보서","chapter":4,"verse":23,"text":"주 예수 그리스도의 은혜가 너희 심령에 있을지어다","reference":"빌립보서 4:23","category":"$undefined"}],"bookSlug":"philippians"}]
