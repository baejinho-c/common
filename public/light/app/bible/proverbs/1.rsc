2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":1,"verses":[{"id":"16402","book":"잠언","book_name":"잠언","chapter":1,"verse":1,"text":"다윗의 아들 이스라엘 왕 솔로몬의 잠언이라","reference":"잠언 1:1","category":"$undefined"},{"id":"16403","book":"잠언","book_name":"잠언","chapter":1,"verse":2,"text":"이는 지혜와 훈계를 알게 하며 명철의 말씀을 깨닫게 하며","reference":"잠언 1:2","category":"$undefined"},{"id":"16404","book":"잠언","book_name":"잠언","chapter":1,"verse":3,"text":"지혜롭게, 의롭게, 공평하게, 정직하게, 행할 일에 대하여 훈계를 받게 하며","reference":"잠언 1:3","category":"$undefined"},{"id":"16405","book":"잠언","book_name":"잠언","chapter":1,"verse":4,"text":"어리석은 자로 슬기롭게 하며 젊은 자에게 지식과 근신함을 주기 위한 것이니","reference":"잠언 1:4","category":"$undefined"},{"id":"16406","book":"잠언","book_name":"잠언","chapter":1,"verse":5,"text":"지혜있는 자는 듣고 학식이 더할 것이요 명철한 자는 모략을 얻을 것이라","reference":"잠언 1:5","category":"$undefined"},{"id":"16407","book":"잠언","book_name":"잠언","chapter":1,"verse":6,"text":"잠언과 비유와 지혜있는 자의 말과 그 오묘한 말을 깨달으리라","reference":"잠언 1:6","category":"$undefined"},{"id":"16408","book":"잠언","book_name":"잠언","chapter":1,"verse":7,"text":"여호와를 경외하는 것이 지식의 근본이어늘 미련한 자는 지혜와 훈계를 멸시하느니라","reference":"잠언 1:7","category":"$undefined"},{"id":"16409","book":"잠언","book_name":"잠언","chapter":1,"verse":8,"text":"내 아들아 네 아비의 훈계를 들으며 네 어미의 법을 떠나지 말라","reference":"잠언 1:8","category":"$undefined"},{"id":"16410","book":"잠언","book_name":"잠언","chapter":1,"verse":9,"text":"이는 네 머리의 아름다운 관이요 네 목의 금사슬이니라","reference":"잠언 1:9","category":"$undefined"},{"id":"16411","book":"잠언","book_name":"잠언","chapter":1,"verse":10,"text":"내 아들아 악한 자가 너를 꾈지라도 좇지 말라","reference":"잠언 1:10","category":"$undefined"},{"id":"16412","book":"잠언","book_name":"잠언","chapter":1,"verse":11,"text":"내 아들아 악한 자가 너를 꾈지라도 좇지 말라","reference":"잠언 1:11","category":"$undefined"},{"id":"16413","book":"잠언","book_name":"잠언","chapter":1,"verse":12,"text":"그들이 네게 말하기를 우리와 함께 가자 우리가 가만히 엎드렸다가 사람의 피를 흘리자 죄없는 자를 까닭없이 숨어 기다리다가","reference":"잠언 1:12","category":"$undefined"},{"id":"16414","book":"잠언","book_name":"잠언","chapter":1,"verse":13,"text":"음부 같이 그들을 산 채로 삼키며 무덤에 내려가는 자 같게 통으로 삼키자","reference":"잠언 1:13","category":"$undefined"},{"id":"16415","book":"잠언","book_name":"잠언","chapter":1,"verse":14,"text":"우리가 온갖 보화를 얻으며 빼앗은 것으로 우리 집에 채우리니","reference":"잠언 1:14","category":"$undefined"},{"id":"16416","book":"잠언","book_name":"잠언","chapter":1,"verse":15,"text":"너는 우리와 함께 제비를 뽑고 우리가 함께 전대 하나만 두자 할지라도","reference":"잠언 1:15","category":"$undefined"},{"id":"16417","book":"잠언","book_name":"잠언","chapter":1,"verse":16,"text":"내 아들아 그들과 함께 길에 다니지 말라 네 발을 금하여 그 길을 밟지 말라","reference":"잠언 1:16","category":"$undefined"},{"id":"16418","book":"잠언","book_name":"잠언","chapter":1,"verse":17,"text":"대저 그 발은 악으로 달려가며 피를 흘리는 데 빠름이니라","reference":"잠언 1:17","category":"$undefined"},{"id":"16419","book":"잠언","book_name":"잠언","chapter":1,"verse":18,"text":"무릇 새가 그물 치는 것을 보면 헛 일이겠거늘","reference":"잠언 1:18","category":"$undefined"},{"id":"16420","book":"잠언","book_name":"잠언","chapter":1,"verse":19,"text":"그들의 가만히 엎드림은 자기의 피를 흘릴 뿐이요 숨어 기다림은 자기의 생명을 해할 뿐이니","reference":"잠언 1:19","category":"$undefined"},{"id":"16421","book":"잠언","book_name":"잠언","chapter":1,"verse":20,"text":"무릇 이를 탐하는 자의 길은 다 이러하여 자기의 생명을 잃게 하느니라","reference":"잠언 1:20","category":"$undefined"},{"id":"16422","book":"잠언","book_name":"잠언","chapter":1,"verse":21,"text":"지혜가 길거리에서 부르며 광장에서 소리를 높이며","reference":"잠언 1:21","category":"$undefined"},{"id":"16423","book":"잠언","book_name":"잠언","chapter":1,"verse":22,"text":"훤화하는 길 머리에서 소리를 지르며 성문 어귀와 성중에서 그 소리를 발하여 가로되","reference":"잠언 1:22","category":"$undefined"},{"id":"16424","book":"잠언","book_name":"잠언","chapter":1,"verse":23,"text":"너희 어리석은 자들은 어리석음을 좋아하며 거만한 자들은 거만을 기뻐하며 미련한 자들은 지식을 미워하니 어느 때까지 하겠느냐","reference":"잠언 1:23","category":"$undefined"},{"id":"16425","book":"잠언","book_name":"잠언","chapter":1,"verse":24,"text":"나의 책망을 듣고 돌이키라 보라 내가 나의 신을 너희에게 부어주며 나의 말을 너희에게 보이리라","reference":"잠언 1:24","category":"$undefined"},{"id":"16426","book":"잠언","book_name":"잠언","chapter":1,"verse":25,"text":"내가 부를지라도 너희가 듣기 싫어 하였고 내가 손을 펼지라도 돌아보는 자가 없었고","reference":"잠언 1:25","category":"$undefined"},{"id":"16427","book":"잠언","book_name":"잠언","chapter":1,"verse":26,"text":"도리어 나의 모든 교훈을 멸시하며 나의 책망을 받지 아니하였은즉","reference":"잠언 1:26","category":"$undefined"},{"id":"16428","book":"잠언","book_name":"잠언","chapter":1,"verse":27,"text":"너희가 재앙을 만날 때에 내가 웃을 것이며 너희에게 두려움이 임할 때에 내가 비웃으리라","reference":"잠언 1:27","category":"$undefined"},{"id":"16429","book":"잠언","book_name":"잠언","chapter":1,"verse":28,"text":"너희의 두려움이 광풍같이 임하겠고 너희의 재앙이 폭풍같이 임하리니","reference":"잠언 1:28","category":"$undefined"},{"id":"16430","book":"잠언","book_name":"잠언","chapter":1,"verse":29,"text":"그 때에 너희가 나를 부르리라 그래도 내가 대답지 아니하겠고 부지런히 나를 찾으리라 그래도 나를 만나지 못하리니","reference":"잠언 1:29","category":"$undefined"},{"id":"16431","book":"잠언","book_name":"잠언","chapter":1,"verse":30,"text":"대저 너희가 지식을 미워하며 여호와 경외하기를 즐거워하지 아니하며","reference":"잠언 1:30","category":"$undefined"},{"id":"16432","book":"잠언","book_name":"잠언","chapter":1,"verse":31,"text":"나의 교훈을 받지 아니하고 나의 모든 책망을 업신여겼음이라","reference":"잠언 1:31","category":"$undefined"},{"id":"16433","book":"잠언","book_name":"잠언","chapter":1,"verse":32,"text":"그러므로 자기 행위의 열매를 먹으며 자기 꾀에 배부르리라","reference":"잠언 1:32","category":"$undefined"},{"id":"16434","book":"잠언","book_name":"잠언","chapter":1,"verse":33,"text":"어리석은 자의 퇴보는 자기를 죽이며 미련한 자의 안일은 자기를 멸망시키려니와 [ (Proverbs 1:34) 오직 나를 듣는 자는 안연히 살며 재앙의 두려움이 없이 평안하리라 ]","reference":"잠언 1:33","category":"$undefined"}],"bookSlug":"proverbs"}]
