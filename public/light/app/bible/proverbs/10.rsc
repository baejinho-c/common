2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":10,"verses":[{"id":"16658","book":"잠언","book_name":"잠언","chapter":10,"verse":1,"text":"솔로몬의 잠언이라 지혜로운 아들은 아비로 기쁘게 하거니와 미련한 아들은 어미의 근심이니라","reference":"잠언 10:1","category":"$undefined"},{"id":"16659","book":"잠언","book_name":"잠언","chapter":10,"verse":2,"text":"불의의 재물은 무익하여도 의리는 죽음에서 건지느니라","reference":"잠언 10:2","category":"$undefined"},{"id":"16660","book":"잠언","book_name":"잠언","chapter":10,"verse":3,"text":"여호와께서 의인의 영혼은 주리지 않게 하시나 악인의 소욕은 물리치시느니라","reference":"잠언 10:3","category":"$undefined"},{"id":"16661","book":"잠언","book_name":"잠언","chapter":10,"verse":4,"text":"손을 게으르게 놀리는 자는 가난하게 되고 손이 부지런한 자는 부하게 되느니라","reference":"잠언 10:4","category":"$undefined"},{"id":"16662","book":"잠언","book_name":"잠언","chapter":10,"verse":5,"text":"여름에 거두는 자는 지혜로운 아들이나 추수 때에 자는 자는 부끄러움을 끼치는 아들이니라","reference":"잠언 10:5","category":"$undefined"},{"id":"16663","book":"잠언","book_name":"잠언","chapter":10,"verse":6,"text":"의인의 머리에는 복이 임하거늘 악인의 입은 독을 머금었느니라","reference":"잠언 10:6","category":"$undefined"},{"id":"16664","book":"잠언","book_name":"잠언","chapter":10,"verse":7,"text":"의인을 기념할 때에는 칭찬하거니와 악인의 이름은 썩으리라","reference":"잠언 10:7","category":"$undefined"},{"id":"16665","book":"잠언","book_name":"잠언","chapter":10,"verse":8,"text":"마음이 지혜로운 자는 명령을 받거니와 입이 미련한 자는 패망하리라","reference":"잠언 10:8","category":"$undefined"},{"id":"16666","book":"잠언","book_name":"잠언","chapter":10,"verse":9,"text":"바른 길로 행하는 자는 걸음이 평안하려니와 굽은 길로 행하는 자는 드러나리라","reference":"잠언 10:9","category":"$undefined"},{"id":"16667","book":"잠언","book_name":"잠언","chapter":10,"verse":10,"text":"의인의 입은 생명의 샘이라도 악인의 입은 독을 머금었느니라","reference":"잠언 10:10","category":"$undefined"},{"id":"16668","book":"잠언","book_name":"잠언","chapter":10,"verse":11,"text":"미움은 다툼을 일으켜도 사랑은 모든 허물을 가리우느니라","reference":"잠언 10:11","category":"$undefined"},{"id":"16669","book":"잠언","book_name":"잠언","chapter":10,"verse":12,"text":"지혜로운 자는 지식을 간직하거니와 미련한 자의 입은 멸망에 가까우니라","reference":"잠언 10:12","category":"$undefined"},{"id":"16670","book":"잠언","book_name":"잠언","chapter":10,"verse":13,"text":"부자의 재물은 그의 견고한 성이요 가난한 자의 궁핍은 그의 패망이니라","reference":"잠언 10:13","category":"$undefined"},{"id":"16671","book":"잠언","book_name":"잠언","chapter":10,"verse":14,"text":"의인의 수고는 생명에 이르고 악인의 소득은 죄에 이르느니라","reference":"잠언 10:14","category":"$undefined"},{"id":"16672","book":"잠언","book_name":"잠언","chapter":10,"verse":15,"text":"훈계를 지키는 자는 생명길로 행하여도 징계를 버리는 자는 그릇 가느니라","reference":"잠언 10:15","category":"$undefined"},{"id":"16673","book":"잠언","book_name":"잠언","chapter":10,"verse":16,"text":"미워함을 감추는 자는 거짓의 입술을 가진 자요 참소하는 자는 미련한 자니라","reference":"잠언 10:16","category":"$undefined"},{"id":"16674","book":"잠언","book_name":"잠언","chapter":10,"verse":17,"text":"말이 많으면 허물을 면키 어려우나 그 입술을 제어하는 자는 지혜가 있느니라","reference":"잠언 10:17","category":"$undefined"},{"id":"16675","book":"잠언","book_name":"잠언","chapter":10,"verse":18,"text":"의인의 혀는 천은과 같거니와 악인의 마음은 가치가 적으니라","reference":"잠언 10:18","category":"$undefined"},{"id":"16676","book":"잠언","book_name":"잠언","chapter":10,"verse":19,"text":"의인의 입술은 여러 사람을 교육하나 미련한 자는 지식이 없으므로 죽느니라","reference":"잠언 10:19","category":"$undefined"},{"id":"16677","book":"잠언","book_name":"잠언","chapter":10,"verse":20,"text":"여호와께서 복을 주시므로 사람으로 부하게 하시고 근심을 겸하여 주지 아니하시느니라","reference":"잠언 10:20","category":"$undefined"},{"id":"16678","book":"잠언","book_name":"잠언","chapter":10,"verse":21,"text":"미련한 자는 행악으로 낙을 삼는 것 같이 명철한 자는 지혜로 낙을 삼느니라","reference":"잠언 10:21","category":"$undefined"},{"id":"16679","book":"잠언","book_name":"잠언","chapter":10,"verse":22,"text":"악인에게는 그의 두려워하는 것이 임하거니와 의인은 그 원하는 것이 이루어지느니라","reference":"잠언 10:22","category":"$undefined"},{"id":"16680","book":"잠언","book_name":"잠언","chapter":10,"verse":23,"text":"회리바람이 지나가면 악인은 없어져도 의인은 영원한 기초 같으니라","reference":"잠언 10:23","category":"$undefined"},{"id":"16681","book":"잠언","book_name":"잠언","chapter":10,"verse":24,"text":"게으른 자는 그 부리는 사람에게 마치 이에 초 같고 눈에 연기 같으니라","reference":"잠언 10:24","category":"$undefined"},{"id":"16682","book":"잠언","book_name":"잠언","chapter":10,"verse":25,"text":"여호와를 경외하면 장수하느니라 그러나 악인의 연세는 짧아지느니라","reference":"잠언 10:25","category":"$undefined"},{"id":"16683","book":"잠언","book_name":"잠언","chapter":10,"verse":26,"text":"의인의 소망은 즐거움을 이루어도 악인의 소망은 끊어지느니라","reference":"잠언 10:26","category":"$undefined"},{"id":"16684","book":"잠언","book_name":"잠언","chapter":10,"verse":27,"text":"여호와의 도가 정직한 자에게는 산성이요 행악하는 자에게는 멸망이니라","reference":"잠언 10:27","category":"$undefined"},{"id":"16685","book":"잠언","book_name":"잠언","chapter":10,"verse":28,"text":"의인은 영영히 이동되지 아니하여도 악인은 땅에 거하지 못하게 되느니라","reference":"잠언 10:28","category":"$undefined"},{"id":"16686","book":"잠언","book_name":"잠언","chapter":10,"verse":29,"text":"의인의 입은 지혜를 내어도 패역한 혀는 베임을 당할 것이니라","reference":"잠언 10:29","category":"$undefined"},{"id":"16687","book":"잠언","book_name":"잠언","chapter":10,"verse":30,"text":"의인의 입술은 기쁘게 할 것을 알거늘 악인의 입은 패역을 말하느니라","reference":"잠언 10:30","category":"$undefined"},{"id":"16688","book":"잠언","book_name":"잠언","chapter":10,"verse":31,"text":"","reference":"잠언 10:31","category":"$undefined"},{"id":"16689","book":"잠언","book_name":"잠언","chapter":10,"verse":32,"text":"","reference":"잠언 10:32","category":"$undefined"}],"bookSlug":"proverbs"}]
