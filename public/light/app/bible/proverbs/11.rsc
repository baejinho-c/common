2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":11,"verses":[{"id":"16690","book":"잠언","book_name":"잠언","chapter":11,"verse":1,"text":"속이는 저울은 여호와께서 미워하셔도 공평한 추는 그가 기뻐하시느니라","reference":"잠언 11:1","category":"$undefined"},{"id":"16691","book":"잠언","book_name":"잠언","chapter":11,"verse":2,"text":"교만이 오면 욕도 오거니와 겸손한 자에게는 지혜가 있느니라","reference":"잠언 11:2","category":"$undefined"},{"id":"16692","book":"잠언","book_name":"잠언","chapter":11,"verse":3,"text":"정직한 자의 성실은 자기를 인도하거니와 사특한 자의 패역은 자기를 망케하느니라","reference":"잠언 11:3","category":"$undefined"},{"id":"16693","book":"잠언","book_name":"잠언","chapter":11,"verse":4,"text":"재물은 진노하시는 날에 무익하나 의리는 죽음을 면케 하느니라","reference":"잠언 11:4","category":"$undefined"},{"id":"16694","book":"잠언","book_name":"잠언","chapter":11,"verse":5,"text":"완전한 자는 그 의로 인하여 그 길이 곧게 되려니와 악한 자는 그 악을 인하여 넘어지리라","reference":"잠언 11:5","category":"$undefined"},{"id":"16695","book":"잠언","book_name":"잠언","chapter":11,"verse":6,"text":"악인은 죽을 때에 그 소망이 끊어지나니 불의의 소망이 없어지느니라","reference":"잠언 11:6","category":"$undefined"},{"id":"16696","book":"잠언","book_name":"잠언","chapter":11,"verse":7,"text":"의인은 환난에서 구원을 얻고 악인은 와서 그를 대신하느니라","reference":"잠언 11:7","category":"$undefined"},{"id":"16697","book":"잠언","book_name":"잠언","chapter":11,"verse":8,"text":"사특한 자는 입으로 그 이웃을 망하게 하여도 의인은 그 지식으로 말미암아 구원을 얻느니라","reference":"잠언 11:8","category":"$undefined"},{"id":"16698","book":"잠언","book_name":"잠언","chapter":11,"verse":9,"text":"의인이 형통하면 성읍이 즐거워하고 악인이 패망하면 기뻐 외치느니라","reference":"잠언 11:9","category":"$undefined"},{"id":"16699","book":"잠언","book_name":"잠언","chapter":11,"verse":10,"text":"성읍은 정직한 자의 축원을 인하여 진흥하고 악한 자의 입을 인하여 무너지느니라","reference":"잠언 11:10","category":"$undefined"},{"id":"16700","book":"잠언","book_name":"잠언","chapter":11,"verse":11,"text":"지혜 없는 자는 그 이웃을 멸시하나 명철한 자는 잠잠하느니라","reference":"잠언 11:11","category":"$undefined"},{"id":"16701","book":"잠언","book_name":"잠언","chapter":11,"verse":12,"text":"두루 다니며 한담하는 자는 남의 비밀을 누설하나 마음이 신실한 자는 그런 것을 숨기느니라","reference":"잠언 11:12","category":"$undefined"},{"id":"16702","book":"잠언","book_name":"잠언","chapter":11,"verse":13,"text":"도략이 없으면 백성이 망하여도 모사가 많으면 평안을 누리느니라","reference":"잠언 11:13","category":"$undefined"},{"id":"16703","book":"잠언","book_name":"잠언","chapter":11,"verse":14,"text":"타인을 위하여 보증이 되는 자는 손해를 당하여도 보증이 되기를 싫어하는 자는 평안하니라","reference":"잠언 11:14","category":"$undefined"},{"id":"16704","book":"잠언","book_name":"잠언","chapter":11,"verse":15,"text":"유덕한 여자는 존영을 얻고 근면한 남자는 재물을 얻느니라","reference":"잠언 11:15","category":"$undefined"},{"id":"16705","book":"잠언","book_name":"잠언","chapter":11,"verse":16,"text":"인자한 자는 자기의 영혼을 이롭게 하고 잔인한 자는 자기의 몸을 해롭게 하느니라","reference":"잠언 11:16","category":"$undefined"},{"id":"16706","book":"잠언","book_name":"잠언","chapter":11,"verse":17,"text":"악인의 삯은 허무하되 의를 뿌린 자의 상은 확실하니라","reference":"잠언 11:17","category":"$undefined"},{"id":"16707","book":"잠언","book_name":"잠언","chapter":11,"verse":18,"text":"의를 굳게 지키는 자는 생명에 이르고 악을 따르는 자는 사망에 이르느니라","reference":"잠언 11:18","category":"$undefined"},{"id":"16708","book":"잠언","book_name":"잠언","chapter":11,"verse":19,"text":"마음이 패려한 자는 여호와의 미움을 받아도 행위가 온전한 자는 그의 기뻐하심을 받느니라","reference":"잠언 11:19","category":"$undefined"},{"id":"16709","book":"잠언","book_name":"잠언","chapter":11,"verse":20,"text":"악인은 피차 손을 잡을지라도 벌을 면치 못할 것이나 의인의 자손은 구원을 얻으리라","reference":"잠언 11:20","category":"$undefined"},{"id":"16710","book":"잠언","book_name":"잠언","chapter":11,"verse":21,"text":"아름다운 여인이 삼가지 아니하는 것은 마치 돼지 코에 금고리 같으니라","reference":"잠언 11:21","category":"$undefined"},{"id":"16711","book":"잠언","book_name":"잠언","chapter":11,"verse":22,"text":"의인의 소원은 오직 선하나 악인의 소망은 진노를 이루느니라","reference":"잠언 11:22","category":"$undefined"},{"id":"16712","book":"잠언","book_name":"잠언","chapter":11,"verse":23,"text":"흩어 구제하여도 더욱 부하게 되는 일이 있나니 과도히 아껴도 가난하게 될 뿐이니라","reference":"잠언 11:23","category":"$undefined"},{"id":"16713","book":"잠언","book_name":"잠언","chapter":11,"verse":24,"text":"구제를 좋아하는 자는 풍족하여질 것이요 남을 윤택하게 하는 자는 윤택하여지리라","reference":"잠언 11:24","category":"$undefined"},{"id":"16714","book":"잠언","book_name":"잠언","chapter":11,"verse":25,"text":"곡식을 내지 아니하는 자는 백성에게 저주를 받을 것이나 파는 자는 그 머리에 복이 임하리라","reference":"잠언 11:25","category":"$undefined"},{"id":"16715","book":"잠언","book_name":"잠언","chapter":11,"verse":26,"text":"선을 간절히 구하는 자는 은총을 얻으려니와 악을 더듬어 찾는 자에게는 악이 임하리라","reference":"잠언 11:26","category":"$undefined"},{"id":"16716","book":"잠언","book_name":"잠언","chapter":11,"verse":27,"text":"자기의 재물을 의지하는 자는 패망하려니와 의인은 푸른 잎사귀 같아서 번성하리라","reference":"잠언 11:27","category":"$undefined"},{"id":"16717","book":"잠언","book_name":"잠언","chapter":11,"verse":28,"text":"자기 집을 해롭게 하는 자의 소득은 바람이라 미련한 자는 마음이 지혜로운 자의 종이 되리라","reference":"잠언 11:28","category":"$undefined"},{"id":"16718","book":"잠언","book_name":"잠언","chapter":11,"verse":29,"text":"의인의 열매는 생명나무라 지혜로운 자는 사람을 얻느니라","reference":"잠언 11:29","category":"$undefined"},{"id":"16719","book":"잠언","book_name":"잠언","chapter":11,"verse":30,"text":"보라 의인이라도 이 세상에서 보응을 받겠거든 하물며 악인과 죄인이리요","reference":"잠언 11:30","category":"$undefined"},{"id":"16720","book":"잠언","book_name":"잠언","chapter":11,"verse":31,"text":"","reference":"잠언 11:31","category":"$undefined"}],"bookSlug":"proverbs"}]
