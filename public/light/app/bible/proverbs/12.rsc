2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":12,"verses":[{"id":"16721","book":"잠언","book_name":"잠언","chapter":12,"verse":1,"text":"훈계를 좋아하는 자는 지식을 좋아하나니 징계를 싫어하는 자는 짐승과 같으니라","reference":"잠언 12:1","category":"$undefined"},{"id":"16722","book":"잠언","book_name":"잠언","chapter":12,"verse":2,"text":"선인은 여호와께 은총을 받으려니와 악을 꾀하는 자는 정죄하심을 받으리이다","reference":"잠언 12:2","category":"$undefined"},{"id":"16723","book":"잠언","book_name":"잠언","chapter":12,"verse":3,"text":"사람이 악으로 굳게 서지 못하나니 의인의 뿌리는 움직이지 아니하느니라","reference":"잠언 12:3","category":"$undefined"},{"id":"16724","book":"잠언","book_name":"잠언","chapter":12,"verse":4,"text":"어진 여인은 그 지아비의 면류관이나 욕을 끼치는 여인은 그 지아비로 뼈가 썩음 같게 하느니라","reference":"잠언 12:4","category":"$undefined"},{"id":"16725","book":"잠언","book_name":"잠언","chapter":12,"verse":5,"text":"의인의 생각은 공직하여도 악인의 도모는 궤휼이니라","reference":"잠언 12:5","category":"$undefined"},{"id":"16726","book":"잠언","book_name":"잠언","chapter":12,"verse":6,"text":"악인의 말은 사람을 엿보아 피를 흘리자 하는 것이어니와 정직한 자의 입은 사람을 구원하느니라","reference":"잠언 12:6","category":"$undefined"},{"id":"16727","book":"잠언","book_name":"잠언","chapter":12,"verse":7,"text":"악인은 엎드러져서 소멸되려니와 의인의 집은 서 있으리라","reference":"잠언 12:7","category":"$undefined"},{"id":"16728","book":"잠언","book_name":"잠언","chapter":12,"verse":8,"text":"사람은 그 지혜대로 칭찬을 받으려니와 마음이 패려한 자는 멸시를 받으리라","reference":"잠언 12:8","category":"$undefined"},{"id":"16729","book":"잠언","book_name":"잠언","chapter":12,"verse":9,"text":"비천히 여김을 받을지라도 종을 부리는 자는 스스로 높은 체 하고도 음식이 핍절한 자보다 나으니라","reference":"잠언 12:9","category":"$undefined"},{"id":"16730","book":"잠언","book_name":"잠언","chapter":12,"verse":10,"text":"의인은 그 육축의 생명을 돌아보나 악인의 긍휼은 잔인이니라","reference":"잠언 12:10","category":"$undefined"},{"id":"16731","book":"잠언","book_name":"잠언","chapter":12,"verse":11,"text":"자기의 토지를 경작하는 자는 먹을 것이 많거니와 방탕한 것을 따르는 자는 지혜가 없느니라","reference":"잠언 12:11","category":"$undefined"},{"id":"16732","book":"잠언","book_name":"잠언","chapter":12,"verse":12,"text":"악인은 불의의 이를 탐하나 의인은 그 뿌리로 말미암아 결실하느니라","reference":"잠언 12:12","category":"$undefined"},{"id":"16733","book":"잠언","book_name":"잠언","chapter":12,"verse":13,"text":"악인은 입술의 허물로 인하여 그물에 걸려도 의인은 환난에서 벗어나느니라","reference":"잠언 12:13","category":"$undefined"},{"id":"16734","book":"잠언","book_name":"잠언","chapter":12,"verse":14,"text":"사람은 입의 열매로 인하여 복록에 족하며 그 손의 행하는 대로 자기가 받느니라","reference":"잠언 12:14","category":"$undefined"},{"id":"16735","book":"잠언","book_name":"잠언","chapter":12,"verse":15,"text":"미련한 자는 자기 행위를 바른 줄로 여기나 지혜로운 자는 권고를 듣느니라","reference":"잠언 12:15","category":"$undefined"},{"id":"16736","book":"잠언","book_name":"잠언","chapter":12,"verse":16,"text":"미련한 자는 분노를 당장에 나타내거니와 슬기로운 자는 수욕을 참느니라","reference":"잠언 12:16","category":"$undefined"},{"id":"16737","book":"잠언","book_name":"잠언","chapter":12,"verse":17,"text":"진리를 말하는 자는 의를 나타내어도 거짓 증인은 궤휼을 말하느니라","reference":"잠언 12:17","category":"$undefined"},{"id":"16738","book":"잠언","book_name":"잠언","chapter":12,"verse":18,"text":"혹은 칼로 찌름 같이 함부로 말하거니와 지혜로운 자의 혀는 양약 같으니라","reference":"잠언 12:18","category":"$undefined"},{"id":"16739","book":"잠언","book_name":"잠언","chapter":12,"verse":19,"text":"진실한 입술은 영원히 보존되거니와 거짓 혀는 눈 깜짝일 동안만 있을 뿐이니라","reference":"잠언 12:19","category":"$undefined"},{"id":"16740","book":"잠언","book_name":"잠언","chapter":12,"verse":20,"text":"악을 꾀하는 자의 마음에는 궤휼이 있고 화평을 논하는 자에게는 희락이 있느니라","reference":"잠언 12:20","category":"$undefined"},{"id":"16741","book":"잠언","book_name":"잠언","chapter":12,"verse":21,"text":"의인에게는 아무 재앙도 임하지 아니하려니와 악인에게는 앙화가 가득하리라","reference":"잠언 12:21","category":"$undefined"},{"id":"16742","book":"잠언","book_name":"잠언","chapter":12,"verse":22,"text":"거짓 입술은 여호와께 미움을 받아도 진실히 행하는 자는 그의 기뻐하심을 받느니라","reference":"잠언 12:22","category":"$undefined"},{"id":"16743","book":"잠언","book_name":"잠언","chapter":12,"verse":23,"text":"슬기로운 자는 지식을 감추어 두어도 미련한 자의 마음은 미련한 것을 전파하느니라","reference":"잠언 12:23","category":"$undefined"},{"id":"16744","book":"잠언","book_name":"잠언","chapter":12,"verse":24,"text":"부지런한 자의 손은 사람을 다스리게 되어도 게으른 자는 부림을 받느니라","reference":"잠언 12:24","category":"$undefined"},{"id":"16745","book":"잠언","book_name":"잠언","chapter":12,"verse":25,"text":"근심이 사람의 마음에 있으면 그것으로 번뇌케 하나 선한 말은 그것을 즐겁게 하느니라","reference":"잠언 12:25","category":"$undefined"},{"id":"16746","book":"잠언","book_name":"잠언","chapter":12,"verse":26,"text":"의인은 그 이웃의 인도자가 되나 악인의 소행은 자기를 미혹하게 하느니라","reference":"잠언 12:26","category":"$undefined"},{"id":"16747","book":"잠언","book_name":"잠언","chapter":12,"verse":27,"text":"게으른 자는 그 잡을 것도 사냥하지 아니하나니 사람의 부귀는 부지런한 것이니라","reference":"잠언 12:27","category":"$undefined"},{"id":"16748","book":"잠언","book_name":"잠언","chapter":12,"verse":28,"text":"의로운 길에 생명이 있나니 그 길에는 사망이 없느니라","reference":"잠언 12:28","category":"$undefined"}],"bookSlug":"proverbs"}]
