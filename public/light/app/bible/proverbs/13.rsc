2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":13,"verses":[{"id":"16749","book":"잠언","book_name":"잠언","chapter":13,"verse":1,"text":"지혜로운 아들은 아비의 훈계를 들으나 거만한 자는 꾸지람을 즐겨 듣지 아니하느니라","reference":"잠언 13:1","category":"$undefined"},{"id":"16750","book":"잠언","book_name":"잠언","chapter":13,"verse":2,"text":"사람은 입의 열매로 인하여 복록을 누리거니와 마음이 궤사한 자는 강포를 당하느니라","reference":"잠언 13:2","category":"$undefined"},{"id":"16751","book":"잠언","book_name":"잠언","chapter":13,"verse":3,"text":"입을 지키는 자는 그 생명을 보전하나 입술을 크게 벌리는 자에게는 멸망이 오느니라","reference":"잠언 13:3","category":"$undefined"},{"id":"16752","book":"잠언","book_name":"잠언","chapter":13,"verse":4,"text":"게으른 자는 마음으로 원하여도 얻지 못하나 부지런한 자의 마음은 풍족함을 얻느니라","reference":"잠언 13:4","category":"$undefined"},{"id":"16753","book":"잠언","book_name":"잠언","chapter":13,"verse":5,"text":"의인은 거짓말을 미워하나 악인은 행위가 흉악하여 부끄러운 데 이르느니라","reference":"잠언 13:5","category":"$undefined"},{"id":"16754","book":"잠언","book_name":"잠언","chapter":13,"verse":6,"text":"의는 행실이 정직한 자를 보호하고 악은 죄인을 패망케 하느니라","reference":"잠언 13:6","category":"$undefined"},{"id":"16755","book":"잠언","book_name":"잠언","chapter":13,"verse":7,"text":"스스로 부한 체 하여도 아무 것도 없는 자가 있고 스스로 가난한체 하여도 재물이 많은 자가 있느니라","reference":"잠언 13:7","category":"$undefined"},{"id":"16756","book":"잠언","book_name":"잠언","chapter":13,"verse":8,"text":"사람의 재물이 그 생명을 속할 수는 있으나 가난한 자는 협박을 받을 일이 없느니라","reference":"잠언 13:8","category":"$undefined"},{"id":"16757","book":"잠언","book_name":"잠언","chapter":13,"verse":9,"text":"의인의 빛은 환하게 빛나고 악인의 등불은 꺼지느니라","reference":"잠언 13:9","category":"$undefined"},{"id":"16758","book":"잠언","book_name":"잠언","chapter":13,"verse":10,"text":"교만에서는 다툼만 일어날 뿐이라 권면을 듣는 자는 지혜가 있느니라 망령되이 얻은 재물은 줄어가고 손으로 모은 것은 늘어가느니라","reference":"잠언 13:10","category":"$undefined"},{"id":"16759","book":"잠언","book_name":"잠언","chapter":13,"verse":11,"text":"소망이 더디 이루게 되면 그것이 마음을 상하게 하나니 소원이 이루는 것은 곧 생명나무니라","reference":"잠언 13:11","category":"$undefined"},{"id":"16760","book":"잠언","book_name":"잠언","chapter":13,"verse":12,"text":"말씀을 멸시하는 자는 패망을 이루고 계명을 두려워하는 자는 상을 얻느니라","reference":"잠언 13:12","category":"$undefined"},{"id":"16761","book":"잠언","book_name":"잠언","chapter":13,"verse":13,"text":"지혜 있는 자의 교훈은 생명의 샘이라 사람으로 사망의 그물을 벗어나게 하느니라","reference":"잠언 13:13","category":"$undefined"},{"id":"16762","book":"잠언","book_name":"잠언","chapter":13,"verse":14,"text":"선한 지혜는 은혜를 베푸나 궤사한 자의 길은 험하니라","reference":"잠언 13:14","category":"$undefined"},{"id":"16763","book":"잠언","book_name":"잠언","chapter":13,"verse":15,"text":"무릇 슬기로운 자는 지식으로 행하여도 미련한 자는 자기의 미련한 것을 나타내느니라","reference":"잠언 13:15","category":"$undefined"},{"id":"16764","book":"잠언","book_name":"잠언","chapter":13,"verse":16,"text":"악한 사자는 재앙에 빠져도 충성된 사신은 양약이 되느니라","reference":"잠언 13:16","category":"$undefined"},{"id":"16765","book":"잠언","book_name":"잠언","chapter":13,"verse":17,"text":"훈계를 저버리는 자에게는 궁핍과 수욕이 이르거니와 경계를 지키는 자는 존영을 얻느니라","reference":"잠언 13:17","category":"$undefined"},{"id":"16766","book":"잠언","book_name":"잠언","chapter":13,"verse":18,"text":"소원을 성취하면 마음에 달아도 미련한 자는 악에서 떠나기를 싫어하느니라","reference":"잠언 13:18","category":"$undefined"},{"id":"16767","book":"잠언","book_name":"잠언","chapter":13,"verse":19,"text":"지혜로운 자와 동행하면 지혜를 얻고 미련한 자와 사귀면 해를 받느니라","reference":"잠언 13:19","category":"$undefined"},{"id":"16768","book":"잠언","book_name":"잠언","chapter":13,"verse":20,"text":"재앙은 죄인을 따르고 선한 보응은 의인에게 이르느니라","reference":"잠언 13:20","category":"$undefined"},{"id":"16769","book":"잠언","book_name":"잠언","chapter":13,"verse":21,"text":"선인은 그 산업을 자자 손손에게 끼쳐도 죄인의 재물은 의인을 위하여 쌓이느니라","reference":"잠언 13:21","category":"$undefined"},{"id":"16770","book":"잠언","book_name":"잠언","chapter":13,"verse":22,"text":"가난한 자는 밭을 경작하므로 양식이 많아지거늘 혹 불의로 인하여 가산을 탕패하는 자가 있느니라","reference":"잠언 13:22","category":"$undefined"},{"id":"16771","book":"잠언","book_name":"잠언","chapter":13,"verse":23,"text":"초달을 차마 못하는 자는 그 자식을 미워함이라 자식을 사랑하는 자는 근실히 징계하느니라","reference":"잠언 13:23","category":"$undefined"},{"id":"16772","book":"잠언","book_name":"잠언","chapter":13,"verse":24,"text":"의인은 포식하여도 악인의 배는 주리느니라","reference":"잠언 13:24","category":"$undefined"},{"id":"16773","book":"잠언","book_name":"잠언","chapter":13,"verse":25,"text":"","reference":"잠언 13:25","category":"$undefined"}],"bookSlug":"proverbs"}]
