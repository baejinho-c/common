2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":14,"verses":[{"id":"16774","book":"잠언","book_name":"잠언","chapter":14,"verse":1,"text":"무릇 지혜로운 여인은 그 집을 세우되 미련한 여인은 자기 손으로 그것을 허느니라","reference":"잠언 14:1","category":"$undefined"},{"id":"16775","book":"잠언","book_name":"잠언","chapter":14,"verse":2,"text":"정직하게 행하는 자는 여호와를 경외하여도 패역하게 행하는 자는 여호와를 경멸히 여기느니라","reference":"잠언 14:2","category":"$undefined"},{"id":"16776","book":"잠언","book_name":"잠언","chapter":14,"verse":3,"text":"미련한 자는 교만하여 입으로 매를 자청하고 지혜로운 자는 입술로 스스로 보전하느니라","reference":"잠언 14:3","category":"$undefined"},{"id":"16777","book":"잠언","book_name":"잠언","chapter":14,"verse":4,"text":"소가 없으면 구유는 깨끗하려니와 소의 힘으로 얻는 것이 많으니라","reference":"잠언 14:4","category":"$undefined"},{"id":"16778","book":"잠언","book_name":"잠언","chapter":14,"verse":5,"text":"신실한 증인은 거짓말을 아니하여도 거짓 증인은 거짓말을 뱉느니라","reference":"잠언 14:5","category":"$undefined"},{"id":"16779","book":"잠언","book_name":"잠언","chapter":14,"verse":6,"text":"거만한 자는 지혜를 구하여도 얻지 못하거니와 명철한 자는 지식 얻기가 쉬우니라","reference":"잠언 14:6","category":"$undefined"},{"id":"16780","book":"잠언","book_name":"잠언","chapter":14,"verse":7,"text":"너는 미련한 자의 앞을 떠나라 그 입술에 지식 있음을 보지 못함이니라","reference":"잠언 14:7","category":"$undefined"},{"id":"16781","book":"잠언","book_name":"잠언","chapter":14,"verse":8,"text":"슬기로운 자의 지혜는 자기의 길을 아는 것이라도 미련한 자의 어리석음은 속이는 것이니라","reference":"잠언 14:8","category":"$undefined"},{"id":"16782","book":"잠언","book_name":"잠언","chapter":14,"verse":9,"text":"미련한 자는 죄를 심상히 여겨도 정직한 자 중에는 은혜가 있느니라","reference":"잠언 14:9","category":"$undefined"},{"id":"16783","book":"잠언","book_name":"잠언","chapter":14,"verse":10,"text":"마음의 고통은 자기가 알고 마음의 즐거움도 타인이 참예하지 못하느니라","reference":"잠언 14:10","category":"$undefined"},{"id":"16784","book":"잠언","book_name":"잠언","chapter":14,"verse":11,"text":"악한 자의 집은 망하겠고 정직한 자의 장막은 흥하리라","reference":"잠언 14:11","category":"$undefined"},{"id":"16785","book":"잠언","book_name":"잠언","chapter":14,"verse":12,"text":"어떤 길은 사람의 보기에 바르나 필경은 사망의 길이니라","reference":"잠언 14:12","category":"$undefined"},{"id":"16786","book":"잠언","book_name":"잠언","chapter":14,"verse":13,"text":"웃을 때에도 마음에 슬픔이 있고 즐거움의 끝에도 근심이 있느니라","reference":"잠언 14:13","category":"$undefined"},{"id":"16787","book":"잠언","book_name":"잠언","chapter":14,"verse":14,"text":"마음이 패려한 자는 자기 행위로 보응이 만족하겠고 선한 사람도 자기의 행위로 그러하리라","reference":"잠언 14:14","category":"$undefined"},{"id":"16788","book":"잠언","book_name":"잠언","chapter":14,"verse":15,"text":"어리석은 자는 온갖 말을 믿으나 슬기로운 자는 그 행동을 삼가느니라","reference":"잠언 14:15","category":"$undefined"},{"id":"16789","book":"잠언","book_name":"잠언","chapter":14,"verse":16,"text":"지혜로운 자는 두려워하여 악을 떠나나 어리석은 자는 방자하여 스스로 믿느니라","reference":"잠언 14:16","category":"$undefined"},{"id":"16790","book":"잠언","book_name":"잠언","chapter":14,"verse":17,"text":"노하기를 속히 하는 자는 어리석은 일을 행하고 악한 계교를 꾀하는 자는 미움을 받느니라","reference":"잠언 14:17","category":"$undefined"},{"id":"16791","book":"잠언","book_name":"잠언","chapter":14,"verse":18,"text":"어리석은 자는 어리석음으로 기업을 삼아도 슬기로운 자는 지식으로 면류관을 삼느니라","reference":"잠언 14:18","category":"$undefined"},{"id":"16792","book":"잠언","book_name":"잠언","chapter":14,"verse":19,"text":"악인은 선인 앞에 엎드리고 불의자는 의인의 문에 엎드리느니라","reference":"잠언 14:19","category":"$undefined"},{"id":"16793","book":"잠언","book_name":"잠언","chapter":14,"verse":20,"text":"가난한 자는 그 이웃에게도 미움을 받게 되나 부요한 자는 친구가 많으니라","reference":"잠언 14:20","category":"$undefined"},{"id":"16794","book":"잠언","book_name":"잠언","chapter":14,"verse":21,"text":"그 이웃을 업신여기는 자는 죄를 범하는 자요 빈곤한 자를 불쌍히 여기는 자는 복이 있는 자니라","reference":"잠언 14:21","category":"$undefined"},{"id":"16795","book":"잠언","book_name":"잠언","chapter":14,"verse":22,"text":"악을 도모하는 자는 그릇 가는 것이 아니냐 선을 도모하는 자에게는 인자와 진리가 있으리라","reference":"잠언 14:22","category":"$undefined"},{"id":"16796","book":"잠언","book_name":"잠언","chapter":14,"verse":23,"text":"모든 수고에는 이익이 있어도 입술의 말은 궁핍을 이룰 뿐이니라","reference":"잠언 14:23","category":"$undefined"},{"id":"16797","book":"잠언","book_name":"잠언","chapter":14,"verse":24,"text":"지혜로운 자의 재물은 그의 면류관이요 미련한 자의 소유는 다만 그 미련한 것이니라","reference":"잠언 14:24","category":"$undefined"},{"id":"16798","book":"잠언","book_name":"잠언","chapter":14,"verse":25,"text":"진실한 증인은 사람의 생명을 구원하여도 거짓말을 뱉는 사람은 속이느니라","reference":"잠언 14:25","category":"$undefined"},{"id":"16799","book":"잠언","book_name":"잠언","chapter":14,"verse":26,"text":"여호와를 경외하는 자에게는 견고한 의뢰가 있나니 그 자녀들에게 피난처가 있으리라","reference":"잠언 14:26","category":"$undefined"},{"id":"16800","book":"잠언","book_name":"잠언","chapter":14,"verse":27,"text":"여호와를 경외하는 것은 생명의 샘이라 사망의 그물에서 벗어나게 하느니라","reference":"잠언 14:27","category":"$undefined"},{"id":"16801","book":"잠언","book_name":"잠언","chapter":14,"verse":28,"text":"백성이 많은 것은 왕의 영광이요 백성이 적은 것은 주권자의 패망이니라","reference":"잠언 14:28","category":"$undefined"},{"id":"16802","book":"잠언","book_name":"잠언","chapter":14,"verse":29,"text":"노하기를 더디 하는 자는 크게 명철하여도 마음이 조급한 자는 어리석음을 나타내느니라","reference":"잠언 14:29","category":"$undefined"},{"id":"16803","book":"잠언","book_name":"잠언","chapter":14,"verse":30,"text":"마음의 화평은 육신의 생명이나 시기는 뼈의 썩음이니라","reference":"잠언 14:30","category":"$undefined"},{"id":"16804","book":"잠언","book_name":"잠언","chapter":14,"verse":31,"text":"가난한 사람을 학대하는 자는 그를 지으신 이를 멸시하는 자요 궁핍한 사람을 불쌍히 여기는 자는 주를 존경하는 자니라","reference":"잠언 14:31","category":"$undefined"},{"id":"16805","book":"잠언","book_name":"잠언","chapter":14,"verse":32,"text":"악인은 그 환난에 엎드러져도 의인은 그 죽음에도 소망이 있느니라","reference":"잠언 14:32","category":"$undefined"},{"id":"16806","book":"잠언","book_name":"잠언","chapter":14,"verse":33,"text":"지혜는 명철한 자의 마음에 머물거니와 미련한 자의 속에 있는 것은 나타나느니라","reference":"잠언 14:33","category":"$undefined"},{"id":"16807","book":"잠언","book_name":"잠언","chapter":14,"verse":34,"text":"의는 나라로 영화롭게 하고 죄는 백성을 욕되게 하느니라","reference":"잠언 14:34","category":"$undefined"},{"id":"16808","book":"잠언","book_name":"잠언","chapter":14,"verse":35,"text":"슬기롭게 행하는 신하는 왕의 은총을 입고 욕을 끼치는 신하는 그의 진노를 당하느니라","reference":"잠언 14:35","category":"$undefined"}],"bookSlug":"proverbs"}]
