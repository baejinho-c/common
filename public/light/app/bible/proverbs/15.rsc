2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":15,"verses":[{"id":"16809","book":"잠언","book_name":"잠언","chapter":15,"verse":1,"text":"유순한 대답은 분노를 쉬게 하여도 과격한 말은 노를 격동하느니라","reference":"잠언 15:1","category":"$undefined"},{"id":"16810","book":"잠언","book_name":"잠언","chapter":15,"verse":2,"text":"지혜 있는 자의 혀는 지식을 선히 베풀고 미련한 자의 입은 미련한 것을 쏟느니라","reference":"잠언 15:2","category":"$undefined"},{"id":"16811","book":"잠언","book_name":"잠언","chapter":15,"verse":3,"text":"여호와의 눈은 어디서든지 악인과 선인을 감찰하시느니라","reference":"잠언 15:3","category":"$undefined"},{"id":"16812","book":"잠언","book_name":"잠언","chapter":15,"verse":4,"text":"온량한 혀는 곧 생명나무라도 패려한 혀는 마음을 상하게 하느니라","reference":"잠언 15:4","category":"$undefined"},{"id":"16813","book":"잠언","book_name":"잠언","chapter":15,"verse":5,"text":"아비의 훈계를 업신여기는 자는 미련한 자요 경계를 받는 자는 슬기를 얻을 자니라","reference":"잠언 15:5","category":"$undefined"},{"id":"16814","book":"잠언","book_name":"잠언","chapter":15,"verse":6,"text":"의인의 집에는 많은 보물이 있어도 악인의 소득은 고통이 되느니라","reference":"잠언 15:6","category":"$undefined"},{"id":"16815","book":"잠언","book_name":"잠언","chapter":15,"verse":7,"text":"지혜로운 자의 입술은 지식을 전파하여도 미련한 자의 마음은 정함이 없느니라","reference":"잠언 15:7","category":"$undefined"},{"id":"16816","book":"잠언","book_name":"잠언","chapter":15,"verse":8,"text":"악인의 제사는 여호와께서 미워하셔도 정직한 자의 기도는 그가 기뻐하시느니라","reference":"잠언 15:8","category":"$undefined"},{"id":"16817","book":"잠언","book_name":"잠언","chapter":15,"verse":9,"text":"악인의 길은 여호와께서 미워하셔도 의를 따라가는 자는 그가 사랑하시느니라","reference":"잠언 15:9","category":"$undefined"},{"id":"16818","book":"잠언","book_name":"잠언","chapter":15,"verse":10,"text":"도를 배반하는 자는 엄한 징계를 받을 것이요 견책을 싫어하는 자는 죽을 것이니라","reference":"잠언 15:10","category":"$undefined"},{"id":"16819","book":"잠언","book_name":"잠언","chapter":15,"verse":11,"text":"음부와 유명도 여호와의 앞에 드러나거든 하물며 인생의 마음이리요","reference":"잠언 15:11","category":"$undefined"},{"id":"16820","book":"잠언","book_name":"잠언","chapter":15,"verse":12,"text":"거만한 자는 견책 받기를 좋아하지 아니하며 지혜 있는 자에게로 가지도 아니하느니라","reference":"잠언 15:12","category":"$undefined"},{"id":"16821","book":"잠언","book_name":"잠언","chapter":15,"verse":13,"text":"마음의 즐거움은 얼굴을 빛나게 하여도 마음의 근심은 심령을 상하게 하느니라","reference":"잠언 15:13","category":"$undefined"},{"id":"16822","book":"잠언","book_name":"잠언","chapter":15,"verse":14,"text":"명철한 자의 마음은 지식을 요구하고 미련한 자의 입은 미련한 것을 즐기느니라","reference":"잠언 15:14","category":"$undefined"},{"id":"16823","book":"잠언","book_name":"잠언","chapter":15,"verse":15,"text":"고난 받는 자는 그 날이 다 험악하나 마음이 즐거운자는 항상 잔치하느니라","reference":"잠언 15:15","category":"$undefined"},{"id":"16824","book":"잠언","book_name":"잠언","chapter":15,"verse":16,"text":"가산이 적어도 여호와를 경외하는 것이 크게 부하고 번뇌하는 것보다 나으니라","reference":"잠언 15:16","category":"$undefined"},{"id":"16825","book":"잠언","book_name":"잠언","chapter":15,"verse":17,"text":"여간 채소를 먹으며 서로 사랑하는 것이 살진 소를 먹으며 서로 미워하는 것보다 나으니라","reference":"잠언 15:17","category":"$undefined"},{"id":"16826","book":"잠언","book_name":"잠언","chapter":15,"verse":18,"text":"분을 쉽게 내는 자는 다툼을 일으켜도 노하기를 더디하는 자는 시비를 그치게 하느니라","reference":"잠언 15:18","category":"$undefined"},{"id":"16827","book":"잠언","book_name":"잠언","chapter":15,"verse":19,"text":"게으른 자의 길은 가시울타리 같으나 정직한 자의 길은 대로니라","reference":"잠언 15:19","category":"$undefined"},{"id":"16828","book":"잠언","book_name":"잠언","chapter":15,"verse":20,"text":"지혜로운 아들은 아비를 즐겁게 하여도 미련한 자는 어미를 업신여기느니라","reference":"잠언 15:20","category":"$undefined"},{"id":"16829","book":"잠언","book_name":"잠언","chapter":15,"verse":21,"text":"무지한 자는 미련한 것을 즐겨하여도 명철한 자는 그 길을 바르게 하느니라","reference":"잠언 15:21","category":"$undefined"},{"id":"16830","book":"잠언","book_name":"잠언","chapter":15,"verse":22,"text":"의논이 없으면 경영이 파하고 모사가 많으면 경영이 성립하느니라","reference":"잠언 15:22","category":"$undefined"},{"id":"16831","book":"잠언","book_name":"잠언","chapter":15,"verse":23,"text":"사람은 그 입의 대답으로 말미암아 기쁨을 얻나니 때에 맞은 말이 얼마나 아름다운고","reference":"잠언 15:23","category":"$undefined"},{"id":"16832","book":"잠언","book_name":"잠언","chapter":15,"verse":24,"text":"지혜로운 자는 위로 향한 생명길로 말미암음으로 그 아래 있는 음부를 떠나게 되느니라","reference":"잠언 15:24","category":"$undefined"},{"id":"16833","book":"잠언","book_name":"잠언","chapter":15,"verse":25,"text":"여호와는 교만한 자의 집을 허시며 과부의 지계를 정하시느니라","reference":"잠언 15:25","category":"$undefined"},{"id":"16834","book":"잠언","book_name":"잠언","chapter":15,"verse":26,"text":"악한 꾀는 여호와의 미워하시는 것이라도 선한 말은 정결하니라","reference":"잠언 15:26","category":"$undefined"},{"id":"16835","book":"잠언","book_name":"잠언","chapter":15,"verse":27,"text":"이를 탐하는 자는 자기 집을 해롭게 하나 뇌물을 싫어하는 자는 사느니라","reference":"잠언 15:27","category":"$undefined"},{"id":"16836","book":"잠언","book_name":"잠언","chapter":15,"verse":28,"text":"의인의 마음은 대답할 말을 깊이 생각하여도 악인의 입은 악을 쏟느니라","reference":"잠언 15:28","category":"$undefined"},{"id":"16837","book":"잠언","book_name":"잠언","chapter":15,"verse":29,"text":"여호와는 악인을 멀리 하시고 의인의 기도를 들으시느니라","reference":"잠언 15:29","category":"$undefined"},{"id":"16838","book":"잠언","book_name":"잠언","chapter":15,"verse":30,"text":"눈의 밝은 것은 마음을 기쁘게 하고 좋은 기별은 뼈를 윤택하게 하느니라","reference":"잠언 15:30","category":"$undefined"},{"id":"16839","book":"잠언","book_name":"잠언","chapter":15,"verse":31,"text":"생명의 경계를 듣는 귀는 지혜로운 자 가운데 있느니라","reference":"잠언 15:31","category":"$undefined"},{"id":"16840","book":"잠언","book_name":"잠언","chapter":15,"verse":32,"text":"훈계 받기를 싫어하는 자는 자기의 영혼을 경히 여김이라 견책을 달게 받는 자는 지식을 얻느니라","reference":"잠언 15:32","category":"$undefined"},{"id":"16841","book":"잠언","book_name":"잠언","chapter":15,"verse":33,"text":"여호와를 경외하는 것은 지혜의 훈계라 겸손은 존귀의 앞잡이니라","reference":"잠언 15:33","category":"$undefined"}],"bookSlug":"proverbs"}]
