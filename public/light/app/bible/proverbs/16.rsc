2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":16,"verses":[{"id":"16842","book":"잠언","book_name":"잠언","chapter":16,"verse":1,"text":"마음의 경영은 사람에게 있어도 말의 응답은 여호와께로서 나느니라","reference":"잠언 16:1","category":"$undefined"},{"id":"16843","book":"잠언","book_name":"잠언","chapter":16,"verse":2,"text":"사람의 행위가 자기 보기에는 모두 깨끗하여도 여호와는 심령을 감찰하시느니라","reference":"잠언 16:2","category":"$undefined"},{"id":"16844","book":"잠언","book_name":"잠언","chapter":16,"verse":3,"text":"너의 행사를 여호와께 맡기라 그리하면 너의 경영하는 것이 이루리라","reference":"잠언 16:3","category":"$undefined"},{"id":"16845","book":"잠언","book_name":"잠언","chapter":16,"verse":4,"text":"여호와께서 온갖 것을 그 씌움에 적당하게 지으셨나니 악인도 악한 날에 적당하게 하셨느니라","reference":"잠언 16:4","category":"$undefined"},{"id":"16846","book":"잠언","book_name":"잠언","chapter":16,"verse":5,"text":"무릇 마음이 교만한 자를 여호와께서 미워하시나니 피차 손을 잡을지라도 벌을 면치 못하리라","reference":"잠언 16:5","category":"$undefined"},{"id":"16847","book":"잠언","book_name":"잠언","chapter":16,"verse":6,"text":"인자와 진리로 인하여 죄악이 속하게 되고 여호와를 경외함으로 인하여 악에서 떠나게 되느니라","reference":"잠언 16:6","category":"$undefined"},{"id":"16848","book":"잠언","book_name":"잠언","chapter":16,"verse":7,"text":"사람의 행위가 여호와를 기쁘시게 하면 그 사람의 원수라도 그로 더불어 화목하게 하시느니라","reference":"잠언 16:7","category":"$undefined"},{"id":"16849","book":"잠언","book_name":"잠언","chapter":16,"verse":8,"text":"적은 소득이 의를 겸하면 많은 소득이 불의를 겸한 것보다 나으니라","reference":"잠언 16:8","category":"$undefined"},{"id":"16850","book":"잠언","book_name":"잠언","chapter":16,"verse":9,"text":"사람이 마음으로 자기의 길을 계획할지라도 그 걸음을 인도하는 자는 여호와시니라","reference":"잠언 16:9","category":"$undefined"},{"id":"16851","book":"잠언","book_name":"잠언","chapter":16,"verse":10,"text":"하나님의 말씀이 왕의 입술에 있은즉 재판할 때에 그 입이 그릇하지 아니하리라","reference":"잠언 16:10","category":"$undefined"},{"id":"16852","book":"잠언","book_name":"잠언","chapter":16,"verse":11,"text":"공평한 간칭과 명칭은 여호와의 것이요 주머니 속의 추돌들도 다 그의 지으신 것이니라","reference":"잠언 16:11","category":"$undefined"},{"id":"16853","book":"잠언","book_name":"잠언","chapter":16,"verse":12,"text":"악을 행하는 것은 왕의 미워할 바니 이는 그 보좌가 공의로 말미암아 굳게 섬이니라","reference":"잠언 16:12","category":"$undefined"},{"id":"16854","book":"잠언","book_name":"잠언","chapter":16,"verse":13,"text":"의로운 입술은 왕들의 기뻐하는 것이요 정직히 말하는 자는 그들의 사랑을 입느니라","reference":"잠언 16:13","category":"$undefined"},{"id":"16855","book":"잠언","book_name":"잠언","chapter":16,"verse":14,"text":"왕의 진노는 살륙의 사자와 같아도 지혜로운 사람은 그것을 쉬게하리라","reference":"잠언 16:14","category":"$undefined"},{"id":"16856","book":"잠언","book_name":"잠언","chapter":16,"verse":15,"text":"왕의 희색에 생명이 있나니 그 은택이 늦은 비를 내리는 구름과 같으니라","reference":"잠언 16:15","category":"$undefined"},{"id":"16857","book":"잠언","book_name":"잠언","chapter":16,"verse":16,"text":"지혜를 얻는 것이 금을 얻는 것보다 얼마나 나은고 명철을 얻는 것이 은을 얻는 것보다 더욱 나으니라","reference":"잠언 16:16","category":"$undefined"},{"id":"16858","book":"잠언","book_name":"잠언","chapter":16,"verse":17,"text":"악을 떠나는 것은 정직한 사람의 대로니 그 길을 지키는 자는 자기의 영혼을 보전하느니라","reference":"잠언 16:17","category":"$undefined"},{"id":"16859","book":"잠언","book_name":"잠언","chapter":16,"verse":18,"text":"교만은 패망의 선봉이요 거만한 마음은 넘어짐의 앞잡이니라","reference":"잠언 16:18","category":"$undefined"},{"id":"16860","book":"잠언","book_name":"잠언","chapter":16,"verse":19,"text":"겸손한 자와 함께하여 마음을 낮추는 것이 교만한 자와 함께 하여 탈취물을 나누는 것보다 나으니라","reference":"잠언 16:19","category":"$undefined"},{"id":"16861","book":"잠언","book_name":"잠언","chapter":16,"verse":20,"text":"삼가 말씀에 주의하는 자는 좋은 것을 얻나니 여호와를 의지하는 자가 복이 있느니라","reference":"잠언 16:20","category":"$undefined"},{"id":"16862","book":"잠언","book_name":"잠언","chapter":16,"verse":21,"text":"마음이 지혜로운 자가 명철하다 일컬음을 받고 입이 선한 자가 남의 학식을 더하게 하느니라","reference":"잠언 16:21","category":"$undefined"},{"id":"16863","book":"잠언","book_name":"잠언","chapter":16,"verse":22,"text":"명철한 자에게는 그 명철이 생명의 샘이 되거니와 미련한 자에게는 그 미련한 것이 징계가 되느니라","reference":"잠언 16:22","category":"$undefined"},{"id":"16864","book":"잠언","book_name":"잠언","chapter":16,"verse":23,"text":"지혜로운 자의 마음은 그 입을 슬기롭게 하고 또 그 입술에 지식을 더하느니라","reference":"잠언 16:23","category":"$undefined"},{"id":"16865","book":"잠언","book_name":"잠언","chapter":16,"verse":24,"text":"선한 말은 꿀송이 같아서 마음에 달고 뼈에 양약이 되느니라","reference":"잠언 16:24","category":"$undefined"},{"id":"16866","book":"잠언","book_name":"잠언","chapter":16,"verse":25,"text":"어떤 길은 사람의 보기에 바르나 필경은 사망의 길이니라","reference":"잠언 16:25","category":"$undefined"},{"id":"16867","book":"잠언","book_name":"잠언","chapter":16,"verse":26,"text":"노력하는 자는 식욕을 인하여 애쓰나니 이는 그 입이 자기를 독촉함이니라","reference":"잠언 16:26","category":"$undefined"},{"id":"16868","book":"잠언","book_name":"잠언","chapter":16,"verse":27,"text":"불량한 자는 악을 꾀하나니 그 입술에는 맹렬한 불 같은 것이 있느니라","reference":"잠언 16:27","category":"$undefined"},{"id":"16869","book":"잠언","book_name":"잠언","chapter":16,"verse":28,"text":"패려한 자는 다툼을 일으키고 말장이는 친한 벗을 이간하느니라","reference":"잠언 16:28","category":"$undefined"},{"id":"16870","book":"잠언","book_name":"잠언","chapter":16,"verse":29,"text":"강포한 사람은 그 이웃을 꾀어 불선한 길로 인도하느니라","reference":"잠언 16:29","category":"$undefined"},{"id":"16871","book":"잠언","book_name":"잠언","chapter":16,"verse":30,"text":"눈을 감는 자는 패역한 일을 도모하며 입술을 닫는 자는 악한 일을 이루느니라","reference":"잠언 16:30","category":"$undefined"},{"id":"16872","book":"잠언","book_name":"잠언","chapter":16,"verse":31,"text":"백발은 영화의 면류관이라 의로운 길에서 얻으리라","reference":"잠언 16:31","category":"$undefined"},{"id":"16873","book":"잠언","book_name":"잠언","chapter":16,"verse":32,"text":"노하기를 더디하는 자는 용사보다 낫고 자기의 마음을 다스리는 자는 성을 빼앗는 자보다 나으니라","reference":"잠언 16:32","category":"$undefined"},{"id":"16874","book":"잠언","book_name":"잠언","chapter":16,"verse":33,"text":"사람이 제비는 뽑으나 일을 작정하기는 여호와께 있느니라","reference":"잠언 16:33","category":"$undefined"}],"bookSlug":"proverbs"}]
