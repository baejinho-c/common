2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":17,"verses":[{"id":"16875","book":"잠언","book_name":"잠언","chapter":17,"verse":1,"text":"마른 떡 한 조각만 있고도 화목하는 것이 육선이 집에 가득하고 다투는 것보다 나으니라","reference":"잠언 17:1","category":"$undefined"},{"id":"16876","book":"잠언","book_name":"잠언","chapter":17,"verse":2,"text":"슬기로운 종은 주인의 부끄러움을 끼치는 아들을 다스리겠고 또 그 아들들 중에서 유업을 나눠 얻으리라","reference":"잠언 17:2","category":"$undefined"},{"id":"16877","book":"잠언","book_name":"잠언","chapter":17,"verse":3,"text":"도가니는 은을,풀무는 금을 연단하거니와 여호와는 마음을 연단 하시느니라","reference":"잠언 17:3","category":"$undefined"},{"id":"16878","book":"잠언","book_name":"잠언","chapter":17,"verse":4,"text":"악을 행하는 자는 궤사한 입술을 잘 듣고 거짓말을 하는 자는 악한 혀에 귀를 기울이느니라","reference":"잠언 17:4","category":"$undefined"},{"id":"16879","book":"잠언","book_name":"잠언","chapter":17,"verse":5,"text":"가난한 자를 조롱하는 자는 이를 지으신 주를 멸시하는 자요 사람의 재앙을 기뻐하는 자는 형벌을 면치 못할 자니라","reference":"잠언 17:5","category":"$undefined"},{"id":"16880","book":"잠언","book_name":"잠언","chapter":17,"verse":6,"text":"손자는 노인의 면류관이요 아비는 자식의 영화니라","reference":"잠언 17:6","category":"$undefined"},{"id":"16881","book":"잠언","book_name":"잠언","chapter":17,"verse":7,"text":"분외의 말을 하는 것도 미련한 자에게 합당치 아니하거든 하물며 거짓말을 하는 것이 존귀한 자에게 합당하겠느냐","reference":"잠언 17:7","category":"$undefined"},{"id":"16882","book":"잠언","book_name":"잠언","chapter":17,"verse":8,"text":"뇌물은 임자의 보기에 보석 같은즉 어디로 향하든지 형통케 하느니라","reference":"잠언 17:8","category":"$undefined"},{"id":"16883","book":"잠언","book_name":"잠언","chapter":17,"verse":9,"text":"허물을 덮어 주는 자는 사랑을 구하는 자요 그것을 거듭 말하는 자는 친한 벗을 이간하는 자니라","reference":"잠언 17:9","category":"$undefined"},{"id":"16884","book":"잠언","book_name":"잠언","chapter":17,"verse":10,"text":"한 마디로 총명한 자를 경계하는 것이 매 백개로 미련한 자를 때리는 것보다 더욱 깊이 박이느니라","reference":"잠언 17:10","category":"$undefined"},{"id":"16885","book":"잠언","book_name":"잠언","chapter":17,"verse":11,"text":"악한 자는 반역만 힘쓰나니 그러므로 그에게 잔인한 사자가 보냄을 입으리라","reference":"잠언 17:11","category":"$undefined"},{"id":"16886","book":"잠언","book_name":"잠언","chapter":17,"verse":12,"text":"차라리 새끼 빼앗긴 암콤을 만날지언정 미련한 일을 행하는 미련한 자를 만나지 말 것이니라","reference":"잠언 17:12","category":"$undefined"},{"id":"16887","book":"잠언","book_name":"잠언","chapter":17,"verse":13,"text":"누구든지 악으로 선을 갚으면 악이 그 집을 떠나지 아니하리라","reference":"잠언 17:13","category":"$undefined"},{"id":"16888","book":"잠언","book_name":"잠언","chapter":17,"verse":14,"text":"다투는 시작은 방축에서 물이 새는 것 같은즉 싸움이 일어나기 전에 시비를 그칠 것이니라","reference":"잠언 17:14","category":"$undefined"},{"id":"16889","book":"잠언","book_name":"잠언","chapter":17,"verse":15,"text":"악인을 의롭다 하며 의인을 악하다 하는 이 두 자는 다 여호와의 미워하심을 입느니라","reference":"잠언 17:15","category":"$undefined"},{"id":"16890","book":"잠언","book_name":"잠언","chapter":17,"verse":16,"text":"미련한 자는 무지하거늘 손에 값을 가지고 지혜를 사려 함은 어찜인고","reference":"잠언 17:16","category":"$undefined"},{"id":"16891","book":"잠언","book_name":"잠언","chapter":17,"verse":17,"text":"친구는 사랑이 끊이지 아니하고 형제는 위급한 때까지 위하여 났느니라","reference":"잠언 17:17","category":"$undefined"},{"id":"16892","book":"잠언","book_name":"잠언","chapter":17,"verse":18,"text":"지혜없는 자는 남의 손을 잡고 그 이웃 앞에서 보증이 되느니라","reference":"잠언 17:18","category":"$undefined"},{"id":"16893","book":"잠언","book_name":"잠언","chapter":17,"verse":19,"text":"다툼을 좋아하는 자는 죄과를 좋아하는 자요 자기 문을 높이는 자는 파괴를 구하는 자니라","reference":"잠언 17:19","category":"$undefined"},{"id":"16894","book":"잠언","book_name":"잠언","chapter":17,"verse":20,"text":"마음이 사특한 자는 복을 얻지 못하고 혀가 패역한 자는 재앙에 빠지느니라","reference":"잠언 17:20","category":"$undefined"},{"id":"16895","book":"잠언","book_name":"잠언","chapter":17,"verse":21,"text":"미련한 자를 낳는 자는 근심을 당하나니 미련한 자의 아비는 낙이 없느니라","reference":"잠언 17:21","category":"$undefined"},{"id":"16896","book":"잠언","book_name":"잠언","chapter":17,"verse":22,"text":"마음의 즐거움은 양약이라도 심령의 근심은 뼈로 마르게 하느니라","reference":"잠언 17:22","category":"$undefined"},{"id":"16897","book":"잠언","book_name":"잠언","chapter":17,"verse":23,"text":"악인은 사람의 품에서 뇌물을 받고 재판을 굽게 하느니라","reference":"잠언 17:23","category":"$undefined"},{"id":"16898","book":"잠언","book_name":"잠언","chapter":17,"verse":24,"text":"지혜는 명철한 자의 앞에 있거늘 미련한 자는 눈을 땅 끝에 두느니라","reference":"잠언 17:24","category":"$undefined"},{"id":"16899","book":"잠언","book_name":"잠언","chapter":17,"verse":25,"text":"미련한 아들은 그 아비의 근심이 되고 그 어미의 고통이 되느니라","reference":"잠언 17:25","category":"$undefined"},{"id":"16900","book":"잠언","book_name":"잠언","chapter":17,"verse":26,"text":"의인을 벌하는 것과 귀인을 정직하다고 때리는 것이 선치 못하니라","reference":"잠언 17:26","category":"$undefined"},{"id":"16901","book":"잠언","book_name":"잠언","chapter":17,"verse":27,"text":"말을 아끼는 자는 지식이 있고 성품이 안존한 자는 명철하니라","reference":"잠언 17:27","category":"$undefined"},{"id":"16902","book":"잠언","book_name":"잠언","chapter":17,"verse":28,"text":"미련한 자라도 잠잠하면 지혜로운 자로 여기우고 그 입술을 닫히면 슬기로운 자로 여기우느니라","reference":"잠언 17:28","category":"$undefined"}],"bookSlug":"proverbs"}]
