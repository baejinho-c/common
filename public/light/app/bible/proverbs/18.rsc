2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":18,"verses":[{"id":"16903","book":"잠언","book_name":"잠언","chapter":18,"verse":1,"text":"무리에게서 스스로 나뉘는 자는 자기 소욕을 따르는 자라 온갖 참 지혜를 배척하느니라","reference":"잠언 18:1","category":"$undefined"},{"id":"16904","book":"잠언","book_name":"잠언","chapter":18,"verse":2,"text":"미련한 자는 명철을 기뻐하지 아니하고 자기의 의사를 드러내기만 기뻐하느니라","reference":"잠언 18:2","category":"$undefined"},{"id":"16905","book":"잠언","book_name":"잠언","chapter":18,"verse":3,"text":"악한 자가 이를 때에는 멸시도 따라오고 부끄러운 것이 이를 때에는 능욕도 함께 오느니라","reference":"잠언 18:3","category":"$undefined"},{"id":"16906","book":"잠언","book_name":"잠언","chapter":18,"verse":4,"text":"명철한 사람의 입의 말은 깊은 물과 같고 지혜의 샘은 솟쳐 흐르는 내와 같으니라","reference":"잠언 18:4","category":"$undefined"},{"id":"16907","book":"잠언","book_name":"잠언","chapter":18,"verse":5,"text":"악인을 두호하는 것과 재판할 때에 의인을 억울하게 하는 것이 선하지 아니하니라","reference":"잠언 18:5","category":"$undefined"},{"id":"16908","book":"잠언","book_name":"잠언","chapter":18,"verse":6,"text":"미련한 자의 입술은 다툼을 일으키고 그 입은 매를 자청하느니라","reference":"잠언 18:6","category":"$undefined"},{"id":"16909","book":"잠언","book_name":"잠언","chapter":18,"verse":7,"text":"미련한 자의 입은 그의 멸망이 되고 그 입술은 그의 영혼의 그물이 되느니라","reference":"잠언 18:7","category":"$undefined"},{"id":"16910","book":"잠언","book_name":"잠언","chapter":18,"verse":8,"text":"남의 말하기를 좋아하는 자의 말은 별식과 같아서 뱃 속 깊은 데로 내려가느니라","reference":"잠언 18:8","category":"$undefined"},{"id":"16911","book":"잠언","book_name":"잠언","chapter":18,"verse":9,"text":"자기의 일을 게을리 하는 자는 패가 하는 자의 형제니라","reference":"잠언 18:9","category":"$undefined"},{"id":"16912","book":"잠언","book_name":"잠언","chapter":18,"verse":10,"text":"여호와의 이름은 견고한 망대라 의인은 그리로 달려가서 안전함을 얻느니라","reference":"잠언 18:10","category":"$undefined"},{"id":"16913","book":"잠언","book_name":"잠언","chapter":18,"verse":11,"text":"부자의 재물은 그의 견고한 성이라 그가 높은 성벽 같이 여기느니라","reference":"잠언 18:11","category":"$undefined"},{"id":"16914","book":"잠언","book_name":"잠언","chapter":18,"verse":12,"text":"사람의 마음의 교만은 멸망의 선봉이요 겸손은 존귀의 앞잡이니라","reference":"잠언 18:12","category":"$undefined"},{"id":"16915","book":"잠언","book_name":"잠언","chapter":18,"verse":13,"text":"사연을 듣기 전에 대답하는 자는 미련하여 욕을 당하느니라","reference":"잠언 18:13","category":"$undefined"},{"id":"16916","book":"잠언","book_name":"잠언","chapter":18,"verse":14,"text":"사람의 심령은 그 병을 능히 이기려니와 심령이 상하면 그것을 누가 일으키겠느냐","reference":"잠언 18:14","category":"$undefined"},{"id":"16917","book":"잠언","book_name":"잠언","chapter":18,"verse":15,"text":"명철한 자의 마음은 지식을 얻고 지혜로운 자의 귀는 지식을 구하느니라","reference":"잠언 18:15","category":"$undefined"},{"id":"16918","book":"잠언","book_name":"잠언","chapter":18,"verse":16,"text":"선물은 그 사람의 길을 너그럽게 하며 또 존귀한 자의 앞으로 그를 인도하느니라","reference":"잠언 18:16","category":"$undefined"},{"id":"16919","book":"잠언","book_name":"잠언","chapter":18,"verse":17,"text":"송사에 원고의 말이 바른 것 같으나 그 피고가 와서 밝히느니라","reference":"잠언 18:17","category":"$undefined"},{"id":"16920","book":"잠언","book_name":"잠언","chapter":18,"verse":18,"text":"제비 뽑는 것은 다툼을 그치게 하여 강한 자 사이에 해결케 하느니라","reference":"잠언 18:18","category":"$undefined"},{"id":"16921","book":"잠언","book_name":"잠언","chapter":18,"verse":19,"text":"노엽게 한 형제와 화목하기가 견고한 성을 취하기 보다 어려운즉 이러한 다툼은 산성 문빗장 같으니라","reference":"잠언 18:19","category":"$undefined"},{"id":"16922","book":"잠언","book_name":"잠언","chapter":18,"verse":20,"text":"사람은 입에서 나오는 열매로 하여 배가 부르게 되나니 곧 그 입술에서 나는 것으로하여 만족케 되느니라","reference":"잠언 18:20","category":"$undefined"},{"id":"16923","book":"잠언","book_name":"잠언","chapter":18,"verse":21,"text":"죽고 사는 것이 혀의 권세에 달렸나니 혀를 쓰기 좋아하는 자는 그 열매를 먹으리라","reference":"잠언 18:21","category":"$undefined"},{"id":"16924","book":"잠언","book_name":"잠언","chapter":18,"verse":22,"text":"아내를 얻는 자는 복을 얻고 여호와께 은총을 받는 자니라","reference":"잠언 18:22","category":"$undefined"},{"id":"16925","book":"잠언","book_name":"잠언","chapter":18,"verse":23,"text":"가난한 자는 간절한 말로 구하여도 부자는 엄한 말로 대답하느니라","reference":"잠언 18:23","category":"$undefined"},{"id":"16926","book":"잠언","book_name":"잠언","chapter":18,"verse":24,"text":"많은 친구를 얻는 자는 해를 당하게 되거니와 어떤 친구는 형제보다 친밀하니라","reference":"잠언 18:24","category":"$undefined"}],"bookSlug":"proverbs"}]
