2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":19,"verses":[{"id":"16927","book":"잠언","book_name":"잠언","chapter":19,"verse":1,"text":"성실히 행하는 가난한 자는 입술이 패려하고 미련한 자 보다 나으니라","reference":"잠언 19:1","category":"$undefined"},{"id":"16928","book":"잠언","book_name":"잠언","chapter":19,"verse":2,"text":"지식 없는 소원은 선치 못하고 발이 급한 사람은 그릇하느니라","reference":"잠언 19:2","category":"$undefined"},{"id":"16929","book":"잠언","book_name":"잠언","chapter":19,"verse":3,"text":"사람이 미련하므로 자기 길을 굽게 하고 마음으로 여호와를 원망하느니라","reference":"잠언 19:3","category":"$undefined"},{"id":"16930","book":"잠언","book_name":"잠언","chapter":19,"verse":4,"text":"재물은 많은 친구를 더하게 하나 가난한즉 친구가 끊어지느니라","reference":"잠언 19:4","category":"$undefined"},{"id":"16931","book":"잠언","book_name":"잠언","chapter":19,"verse":5,"text":"거짓 증인은 벌을 면치 못할 것이요 거짓말을 내는 자도 피치 못하리라","reference":"잠언 19:5","category":"$undefined"},{"id":"16932","book":"잠언","book_name":"잠언","chapter":19,"verse":6,"text":"너그러운 사람에게는 은혜를 구하는 자가 많고 선물을 주기를 좋아하는 자에게는 사람마다 친구가 되느니라","reference":"잠언 19:6","category":"$undefined"},{"id":"16933","book":"잠언","book_name":"잠언","chapter":19,"verse":7,"text":"가난한 자는 그 형제들에게도 미움을 받거든 하물며 친구야 그를 멀리 아니하겠느냐 따라가며 말하려 할지라도 그들이 없어졌으 리라","reference":"잠언 19:7","category":"$undefined"},{"id":"16934","book":"잠언","book_name":"잠언","chapter":19,"verse":8,"text":"지혜를 얻는 자는 자기 영혼을 사랑하고 명철을 지키는 자는 복을 얻느니라","reference":"잠언 19:8","category":"$undefined"},{"id":"16935","book":"잠언","book_name":"잠언","chapter":19,"verse":9,"text":"거짓 증인은 벌을 면치 못할 것이요 거짓말을 내는 자는 망할 것이니라","reference":"잠언 19:9","category":"$undefined"},{"id":"16936","book":"잠언","book_name":"잠언","chapter":19,"verse":10,"text":"미련한 자가 사치하는 것이 적당치 못하거든 하물며 종이 방백을 다스림이랴","reference":"잠언 19:10","category":"$undefined"},{"id":"16937","book":"잠언","book_name":"잠언","chapter":19,"verse":11,"text":"노하기를 더디하는 것이 사람의 슬기요 허물을 용서하는 것이 자기의 영광이니라","reference":"잠언 19:11","category":"$undefined"},{"id":"16938","book":"잠언","book_name":"잠언","chapter":19,"verse":12,"text":"왕의 노함은 사자의 부르짖음 같고 그의 은택은 풀 위에 이슬 같으니라","reference":"잠언 19:12","category":"$undefined"},{"id":"16939","book":"잠언","book_name":"잠언","chapter":19,"verse":13,"text":"미련한 아들은 그 아비의 재앙이요 다투는 아내는 이어 떨어지는 물방울이니라","reference":"잠언 19:13","category":"$undefined"},{"id":"16940","book":"잠언","book_name":"잠언","chapter":19,"verse":14,"text":"집과 재물은 조상에게서 상속하거니와 슬기로운 아내는 여호와께로서 말미암느니라","reference":"잠언 19:14","category":"$undefined"},{"id":"16941","book":"잠언","book_name":"잠언","chapter":19,"verse":15,"text":"게으름이 사람으로 깊이 잠들게 하나니 해태한 사람은 주릴 것이니라","reference":"잠언 19:15","category":"$undefined"},{"id":"16942","book":"잠언","book_name":"잠언","chapter":19,"verse":16,"text":"계명을 지키는 자는 자기의 영혼을 지키거니와 그 행실을 삼가지 아니하는 자는 죽으리라","reference":"잠언 19:16","category":"$undefined"},{"id":"16943","book":"잠언","book_name":"잠언","chapter":19,"verse":17,"text":"가난한 자를 불쌍히 여기는 것은 여호와께 꾸이는 것이니 그 선행을 갚아 주시리라","reference":"잠언 19:17","category":"$undefined"},{"id":"16944","book":"잠언","book_name":"잠언","chapter":19,"verse":18,"text":"네가 네 아들에게 소망이 있은즉 그를 징계하고 죽일 마음은 두지 말지니라","reference":"잠언 19:18","category":"$undefined"},{"id":"16945","book":"잠언","book_name":"잠언","chapter":19,"verse":19,"text":"노하기를 맹렬히 하는 자는 벌을 받을 것이라 네가 그를 건져 주면 다시 건져 주게 되리라","reference":"잠언 19:19","category":"$undefined"},{"id":"16946","book":"잠언","book_name":"잠언","chapter":19,"verse":20,"text":"너는 권고를 들으며 훈계를 받으라 그리하면 네가 필경은 지혜롭게 되리라","reference":"잠언 19:20","category":"$undefined"},{"id":"16947","book":"잠언","book_name":"잠언","chapter":19,"verse":21,"text":"사람의 마음에는 많은 계획이 있어도 오직 여호와의 뜻이 완전히 서리라","reference":"잠언 19:21","category":"$undefined"},{"id":"16948","book":"잠언","book_name":"잠언","chapter":19,"verse":22,"text":"사람은 그 인자함으로 남에게 사모함을 받느니라 가난한 자는 거짓말하는 자보다 나으니라","reference":"잠언 19:22","category":"$undefined"},{"id":"16949","book":"잠언","book_name":"잠언","chapter":19,"verse":23,"text":"여호와를 경외하는 것은 사람으로 생명에 이르게 하는 것이라 경외하는 자는 족하게 지내고 재앙을 만나지 아니하느니라","reference":"잠언 19:23","category":"$undefined"},{"id":"16950","book":"잠언","book_name":"잠언","chapter":19,"verse":24,"text":"게으른 자는 그 손을 그릇에 넣고도 입으로 올리기를 괴로와하느니라","reference":"잠언 19:24","category":"$undefined"},{"id":"16951","book":"잠언","book_name":"잠언","chapter":19,"verse":25,"text":"거만한 자를 때리라 그리하면 어리석은 자도 경성하리라 명철한 자를 견책하라 그리하면 그가 지식을 얻으리라","reference":"잠언 19:25","category":"$undefined"},{"id":"16952","book":"잠언","book_name":"잠언","chapter":19,"verse":26,"text":"아비를 구박하고 어미를 쫓아 내는 자는 부끄러움을 끼치며 능욕을 부르는 자식이니라","reference":"잠언 19:26","category":"$undefined"},{"id":"16953","book":"잠언","book_name":"잠언","chapter":19,"verse":27,"text":"내 아들아 지식의 말씀에서 떠나게 하는 교훈을 듣지 말지니라","reference":"잠언 19:27","category":"$undefined"},{"id":"16954","book":"잠언","book_name":"잠언","chapter":19,"verse":28,"text":"망령된 증인은 공의를 업신여기고 악인의 입은 죄악을 삼키느니라","reference":"잠언 19:28","category":"$undefined"},{"id":"16955","book":"잠언","book_name":"잠언","chapter":19,"verse":29,"text":"심판은 거만한 자를 위하여 예비된 것이요 채찍은 어리석은 자의 등을 위하여 예비된 것이니라","reference":"잠언 19:29","category":"$undefined"}],"bookSlug":"proverbs"}]
