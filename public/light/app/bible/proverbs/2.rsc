2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":2,"verses":[{"id":"16435","book":"잠언","book_name":"잠언","chapter":2,"verse":1,"text":"내 아들아 네가 만일 나의 말을 받으며 나의 계명을 네게 간직하며","reference":"잠언 2:1","category":"$undefined"},{"id":"16436","book":"잠언","book_name":"잠언","chapter":2,"verse":2,"text":"네 귀를 지혜에 기울이며 네 마음을 명철에 두며","reference":"잠언 2:2","category":"$undefined"},{"id":"16437","book":"잠언","book_name":"잠언","chapter":2,"verse":3,"text":"지식을 불러 구하며 명철을 얻으려고 소리를 높이며","reference":"잠언 2:3","category":"$undefined"},{"id":"16438","book":"잠언","book_name":"잠언","chapter":2,"verse":4,"text":"은을 구하는 것 같이 그것을 구하며 감추인 보배를 찾는 것 같이 그것을 찾으면","reference":"잠언 2:4","category":"$undefined"},{"id":"16439","book":"잠언","book_name":"잠언","chapter":2,"verse":5,"text":"여호와 경외하기를 깨달으며 하나님을 알게 되리니","reference":"잠언 2:5","category":"$undefined"},{"id":"16440","book":"잠언","book_name":"잠언","chapter":2,"verse":6,"text":"대저 여호와는 지혜를 주시며 지식과 명철을 그 입에서 내심이며","reference":"잠언 2:6","category":"$undefined"},{"id":"16441","book":"잠언","book_name":"잠언","chapter":2,"verse":7,"text":"그는 정직한 자를 위하여 완전한 지혜를 예비하시며 행실이 온전한 자에게 방패가 되시나니","reference":"잠언 2:7","category":"$undefined"},{"id":"16442","book":"잠언","book_name":"잠언","chapter":2,"verse":8,"text":"대저 그는 공평의 길을 보호하시며 그 성도들의 길을 보전하려 하심이니라","reference":"잠언 2:8","category":"$undefined"},{"id":"16443","book":"잠언","book_name":"잠언","chapter":2,"verse":9,"text":"그런즉 네가 공의와 공평과 정직 곧 모든 선한 길을 깨달을 것이라","reference":"잠언 2:9","category":"$undefined"},{"id":"16444","book":"잠언","book_name":"잠언","chapter":2,"verse":10,"text":"곧 지혜가 네 마음에 들어가며 지식이 네 영혼에 즐겁게 될 것이요","reference":"잠언 2:10","category":"$undefined"},{"id":"16445","book":"잠언","book_name":"잠언","chapter":2,"verse":11,"text":"근신이 너를 지키며 명철이 너를 보호하여","reference":"잠언 2:11","category":"$undefined"},{"id":"16446","book":"잠언","book_name":"잠언","chapter":2,"verse":12,"text":"악한 자의 길과 패역을 말하는 자에게서 건져내리라","reference":"잠언 2:12","category":"$undefined"},{"id":"16447","book":"잠언","book_name":"잠언","chapter":2,"verse":13,"text":"이 무리는 정직한 길을 떠나 어두운 길로 행하며","reference":"잠언 2:13","category":"$undefined"},{"id":"16448","book":"잠언","book_name":"잠언","chapter":2,"verse":14,"text":"행악하기를 기뻐하며 악인의 패역을 즐거워하나니","reference":"잠언 2:14","category":"$undefined"},{"id":"16449","book":"잠언","book_name":"잠언","chapter":2,"verse":15,"text":"그 길은 구부러지고 그 행위는 패역하리라","reference":"잠언 2:15","category":"$undefined"},{"id":"16450","book":"잠언","book_name":"잠언","chapter":2,"verse":16,"text":"지혜가 또 너를 음녀에게서, 말로 호리는 이방 계집에게서 구원하리니","reference":"잠언 2:16","category":"$undefined"},{"id":"16451","book":"잠언","book_name":"잠언","chapter":2,"verse":17,"text":"그는 소시의 짝을 버리며 그 하나님의 언약을 잊어버린자라","reference":"잠언 2:17","category":"$undefined"},{"id":"16452","book":"잠언","book_name":"잠언","chapter":2,"verse":18,"text":"그 집은 사망으로, 그 길은 음부로 기울어졌나니","reference":"잠언 2:18","category":"$undefined"},{"id":"16453","book":"잠언","book_name":"잠언","chapter":2,"verse":19,"text":"누구든지 그에게로 가는 자는 돌아오지 못하며 또 생명길을 얻지 못하느니라","reference":"잠언 2:19","category":"$undefined"},{"id":"16454","book":"잠언","book_name":"잠언","chapter":2,"verse":20,"text":"지혜가 너로 선한 자의 길로 행하게 하며 또 의인의 길을 지키게 하리니","reference":"잠언 2:20","category":"$undefined"},{"id":"16455","book":"잠언","book_name":"잠언","chapter":2,"verse":21,"text":"대저 정직한 자는 땅에 거하며 완전한 자는 땅에 남아 있으리라","reference":"잠언 2:21","category":"$undefined"},{"id":"16456","book":"잠언","book_name":"잠언","chapter":2,"verse":22,"text":"그러나 악인은 땅에서 끊어지겠고 궤휼한 자는 땅에서 뽑히리라","reference":"잠언 2:22","category":"$undefined"}],"bookSlug":"proverbs"}]
