2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":20,"verses":[{"id":"16956","book":"잠언","book_name":"잠언","chapter":20,"verse":1,"text":"포도주는 거만케 하는 것이요 독주는 떠들게 하는 것이라 무릇 이에 미혹되는 자에게는 지혜가 없느니라","reference":"잠언 20:1","category":"$undefined"},{"id":"16957","book":"잠언","book_name":"잠언","chapter":20,"verse":2,"text":"왕의 진노는 사자의 부르짖음 같으니 그를 노하게 하는 것은 자기의 생명을 해하는 것이니라","reference":"잠언 20:2","category":"$undefined"},{"id":"16958","book":"잠언","book_name":"잠언","chapter":20,"verse":3,"text":"다툼을 멀리 하는 것이 사람에게 영광이어늘 미련한 자마다 다툼을 일으키느니라","reference":"잠언 20:3","category":"$undefined"},{"id":"16959","book":"잠언","book_name":"잠언","chapter":20,"verse":4,"text":"게으른 자는 가을에 밭 갈지 아니하나니 그러므로 거둘 때에는 구걸할지라도 얻지 못하리라","reference":"잠언 20:4","category":"$undefined"},{"id":"16960","book":"잠언","book_name":"잠언","chapter":20,"verse":5,"text":"사람의 마음에 있는 모략은 깊은 물 같으니라 그럴찌라도 명철한 사람은 그것을 길어 내느니라","reference":"잠언 20:5","category":"$undefined"},{"id":"16961","book":"잠언","book_name":"잠언","chapter":20,"verse":6,"text":"많은 사람은 각기 자기의 인자함을 자랑하나니 충성된 자를 누가 만날 수 있으랴","reference":"잠언 20:6","category":"$undefined"},{"id":"16962","book":"잠언","book_name":"잠언","chapter":20,"verse":7,"text":"완전히 행하는 자가 의인이라 그 후손에게 복이 있느니라","reference":"잠언 20:7","category":"$undefined"},{"id":"16963","book":"잠언","book_name":"잠언","chapter":20,"verse":8,"text":"심판 자리에 앉은 왕은 그 눈으로 모든 악을 흩어지게 하느니라","reference":"잠언 20:8","category":"$undefined"},{"id":"16964","book":"잠언","book_name":"잠언","chapter":20,"verse":9,"text":"내가 내 마음을 정하게 하였다,내 죄를 깨끗하게 하였다 할 자가 누구뇨","reference":"잠언 20:9","category":"$undefined"},{"id":"16965","book":"잠언","book_name":"잠언","chapter":20,"verse":10,"text":"한결 같지 않은 저울 추와 말은 다 여호와께서 미워하시느니라","reference":"잠언 20:10","category":"$undefined"},{"id":"16966","book":"잠언","book_name":"잠언","chapter":20,"verse":11,"text":"비록 아이라도 그 동작으로 자기의 품행의 청결하며 정직한 여부를 나타내느니라","reference":"잠언 20:11","category":"$undefined"},{"id":"16967","book":"잠언","book_name":"잠언","chapter":20,"verse":12,"text":"듣는 귀와 보는 눈은 다 여호와의 지으신 것이니라","reference":"잠언 20:12","category":"$undefined"},{"id":"16968","book":"잠언","book_name":"잠언","chapter":20,"verse":13,"text":"너는 잠자기를 좋아하지 말라 네가 빈궁하게 될까 두려우니라 네 눈을 뜨라 그리하면 양식에 족하리라","reference":"잠언 20:13","category":"$undefined"},{"id":"16969","book":"잠언","book_name":"잠언","chapter":20,"verse":14,"text":"사는 자가 물건이 좋지 못하다 좋지 못하다 하다가 돌아간 후에는 자랑하느니라","reference":"잠언 20:14","category":"$undefined"},{"id":"16970","book":"잠언","book_name":"잠언","chapter":20,"verse":15,"text":"세상에 금도 있고 진주도 많거니와 지혜로운 입술이 더욱 귀한 보배니라","reference":"잠언 20:15","category":"$undefined"},{"id":"16971","book":"잠언","book_name":"잠언","chapter":20,"verse":16,"text":"타인을 위하여 보증이 된 자의 옷을 취하라 외인들의 보증이 된자는 그 몸을 볼모 잡힐지니라","reference":"잠언 20:16","category":"$undefined"},{"id":"16972","book":"잠언","book_name":"잠언","chapter":20,"verse":17,"text":"속이고 취한 식물은 맛이 좋은듯하나 후에는 그 입에 모래가 가득하게 되리라","reference":"잠언 20:17","category":"$undefined"},{"id":"16973","book":"잠언","book_name":"잠언","chapter":20,"verse":18,"text":"무릇 경영은 의논함으로 성취하나니 모략을 베풀고 전쟁할지니라","reference":"잠언 20:18","category":"$undefined"},{"id":"16974","book":"잠언","book_name":"잠언","chapter":20,"verse":19,"text":"두루 다니며 한담하는 자는 남의 비밀를 누설하니니 입술을 벌린 자를 사귀지 말지니라","reference":"잠언 20:19","category":"$undefined"},{"id":"16975","book":"잠언","book_name":"잠언","chapter":20,"verse":20,"text":"자기의 아비나 어미를 저주하는 자는 그 등불이 유암중에 꺼짐을 당하리라","reference":"잠언 20:20","category":"$undefined"},{"id":"16976","book":"잠언","book_name":"잠언","chapter":20,"verse":21,"text":"처음에 속히 잡은 산업은 마침내 복이 되지 아니하느니라","reference":"잠언 20:21","category":"$undefined"},{"id":"16977","book":"잠언","book_name":"잠언","chapter":20,"verse":22,"text":"너는 악을 갚겠다 말하지 말고 여호와를 기다리라 그가 너를 구원하시리라","reference":"잠언 20:22","category":"$undefined"},{"id":"16978","book":"잠언","book_name":"잠언","chapter":20,"verse":23,"text":"한결 같지 않은 저울 추는 여호와의 미워하시는 것이요 속이는 저울은 좋지 못한 것이니라","reference":"잠언 20:23","category":"$undefined"},{"id":"16979","book":"잠언","book_name":"잠언","chapter":20,"verse":24,"text":"사람의 걸음은 여호와께로서 말미암나니 사람이 어찌 자기의 길을 알 수 있으랴","reference":"잠언 20:24","category":"$undefined"},{"id":"16980","book":"잠언","book_name":"잠언","chapter":20,"verse":25,"text":"함부로 이 물건을 거룩하다하여 서원하고 그 후에 살피면 그 것이 그물이 되느니라","reference":"잠언 20:25","category":"$undefined"},{"id":"16981","book":"잠언","book_name":"잠언","chapter":20,"verse":26,"text":"지혜로운 왕은 악인을 키질하며 타작하는 바퀴로 그 위에 굴리느니라","reference":"잠언 20:26","category":"$undefined"},{"id":"16982","book":"잠언","book_name":"잠언","chapter":20,"verse":27,"text":"사람의 영혼은 여호와의 등불이라 사람의 깊은 속을 살피느니라","reference":"잠언 20:27","category":"$undefined"},{"id":"16983","book":"잠언","book_name":"잠언","chapter":20,"verse":28,"text":"왕은 인자와 진리로 스스로 보호하고 그 위도 인자함으로 말미암아 견고하니라","reference":"잠언 20:28","category":"$undefined"},{"id":"16984","book":"잠언","book_name":"잠언","chapter":20,"verse":29,"text":"젊은 자의 영화는 그 힘이요 늙은 자의 아름다운 것은 백발이니라","reference":"잠언 20:29","category":"$undefined"},{"id":"16985","book":"잠언","book_name":"잠언","chapter":20,"verse":30,"text":"상하게 때리는 것이 악을 없이 하나니 매는 사람의 속에 깊이 들어가느니라","reference":"잠언 20:30","category":"$undefined"}],"bookSlug":"proverbs"}]
