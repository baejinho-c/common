2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":21,"verses":[{"id":"16986","book":"잠언","book_name":"잠언","chapter":21,"verse":1,"text":"왕의 마음이 여호와의 손에 있음이 마치 보의 물과 같아서 그가 임의로 인도하시느니라","reference":"잠언 21:1","category":"$undefined"},{"id":"16987","book":"잠언","book_name":"잠언","chapter":21,"verse":2,"text":"사람의 행위가 자기 보기에는 모두 정직하여도 여호와는 심령을 감찰하시느니라","reference":"잠언 21:2","category":"$undefined"},{"id":"16988","book":"잠언","book_name":"잠언","chapter":21,"verse":3,"text":"의와 공평을 행하는 것은 제사 드리는 것보다 여호와께서 기쁘게 여기시느니라","reference":"잠언 21:3","category":"$undefined"},{"id":"16989","book":"잠언","book_name":"잠언","chapter":21,"verse":4,"text":"눈이 높은 것과 마음이 교만한 것과 악인의 형통한 것은 다 죄니라","reference":"잠언 21:4","category":"$undefined"},{"id":"16990","book":"잠언","book_name":"잠언","chapter":21,"verse":5,"text":"부지런한 자의 경영은 풍부함에 이를 것이나 조급한 자는 궁핍함에 이를 따름이니라","reference":"잠언 21:5","category":"$undefined"},{"id":"16991","book":"잠언","book_name":"잠언","chapter":21,"verse":6,"text":"속이는 말로 재물을 모으는 것은 죽음을 구하는 것이라 곧 불려 다니는 안개니라","reference":"잠언 21:6","category":"$undefined"},{"id":"16992","book":"잠언","book_name":"잠언","chapter":21,"verse":7,"text":"악인의 강포는 자기를 소멸하나니 이는 공의 행하기를 싫어함이니라","reference":"잠언 21:7","category":"$undefined"},{"id":"16993","book":"잠언","book_name":"잠언","chapter":21,"verse":8,"text":"죄를 크게 범한 자의 길은 심히 구부러지고 깨끗한 자의 길은 곧으니라","reference":"잠언 21:8","category":"$undefined"},{"id":"16994","book":"잠언","book_name":"잠언","chapter":21,"verse":9,"text":"다투는 여인과 함께 큰 집에서 나는 것보다 움막에서 혼자 사는 것이 나으니라","reference":"잠언 21:9","category":"$undefined"},{"id":"16995","book":"잠언","book_name":"잠언","chapter":21,"verse":10,"text":"악인의 마음은 남의 재앙을 원하나니 그 이웃도 그 앞에서 은혜를 입지 못하느니라","reference":"잠언 21:10","category":"$undefined"},{"id":"16996","book":"잠언","book_name":"잠언","chapter":21,"verse":11,"text":"거만한 자가 벌을 받으면 어리석은 자는 경성하겠고 지혜로운 자가 교훈을 받으면 지식이 더 하리라","reference":"잠언 21:11","category":"$undefined"},{"id":"16997","book":"잠언","book_name":"잠언","chapter":21,"verse":12,"text":"의로우신 자는 악인의 집을 감찰하시고 악인을 환난에 던지시느니라","reference":"잠언 21:12","category":"$undefined"},{"id":"16998","book":"잠언","book_name":"잠언","chapter":21,"verse":13,"text":"귀를 막아 가난한 자의 부르짖는 소리를 듣지 아니하면 자기의 부르짖을 때에도 들을 자가 없으리라","reference":"잠언 21:13","category":"$undefined"},{"id":"16999","book":"잠언","book_name":"잠언","chapter":21,"verse":14,"text":"은밀한 선물은 노를 쉬게 하고 품의 뇌물은 맹렬한 분을 그치게 하느니라","reference":"잠언 21:14","category":"$undefined"},{"id":"17000","book":"잠언","book_name":"잠언","chapter":21,"verse":15,"text":"공의를 행하는 것이 의인에게는 즐거움이요 죄인에게는 패망이니라","reference":"잠언 21:15","category":"$undefined"},{"id":"17001","book":"잠언","book_name":"잠언","chapter":21,"verse":16,"text":"명철의 길을 떠난 사람은 사망의 회중에 거하리라","reference":"잠언 21:16","category":"$undefined"},{"id":"17002","book":"잠언","book_name":"잠언","chapter":21,"verse":17,"text":"연락을 좋아하는 자는 가난하게 되고 술과 기름을 좋아하는 자는 부하게 되지 못하느니라","reference":"잠언 21:17","category":"$undefined"},{"id":"17003","book":"잠언","book_name":"잠언","chapter":21,"verse":18,"text":"악인은 의인의 대속이 되고 궤사한 자는 정직한 자의 대신이 되느니라","reference":"잠언 21:18","category":"$undefined"},{"id":"17004","book":"잠언","book_name":"잠언","chapter":21,"verse":19,"text":"다투며 성내는 여인과 함께 사는 것보다 광야에서 혼자 사는 것이 나으니라","reference":"잠언 21:19","category":"$undefined"},{"id":"17005","book":"잠언","book_name":"잠언","chapter":21,"verse":20,"text":"지혜있는 자의 집에는 귀한 보배와 기름이 있으나 미련한 자는 이것을 다 삼켜버리느니라","reference":"잠언 21:20","category":"$undefined"},{"id":"17006","book":"잠언","book_name":"잠언","chapter":21,"verse":21,"text":"의와 인자를 따라 구하는 자는 생명과 의와 영광을 얻느니라","reference":"잠언 21:21","category":"$undefined"},{"id":"17007","book":"잠언","book_name":"잠언","chapter":21,"verse":22,"text":"지혜로운 자는 용사의 성에 올라가서 그 성의 견고히 의뢰하는 것을 파하느니라","reference":"잠언 21:22","category":"$undefined"},{"id":"17008","book":"잠언","book_name":"잠언","chapter":21,"verse":23,"text":"입과 혀를 지키는 자는 그 영혼을 환난에서 보전하느니라","reference":"잠언 21:23","category":"$undefined"},{"id":"17009","book":"잠언","book_name":"잠언","chapter":21,"verse":24,"text":"무례하고 교만한 자를 이름하여 망령된 자라 하나니 이는 넘치는 교만으로 행함이니라","reference":"잠언 21:24","category":"$undefined"},{"id":"17010","book":"잠언","book_name":"잠언","chapter":21,"verse":25,"text":"게으른 자의 정욕이 그를 죽이나니 이는 그 손으로 일하기를 싫어 함이니라","reference":"잠언 21:25","category":"$undefined"},{"id":"17011","book":"잠언","book_name":"잠언","chapter":21,"verse":26,"text":"어떤 자는 종일토록 탐하기만 하나 의인은 아끼지 아니하고 시제하느니라","reference":"잠언 21:26","category":"$undefined"},{"id":"17012","book":"잠언","book_name":"잠언","chapter":21,"verse":27,"text":"악인의 제물은 본래 가증하거든 하물며 악한 뜻으로 드리는 것이랴","reference":"잠언 21:27","category":"$undefined"},{"id":"17013","book":"잠언","book_name":"잠언","chapter":21,"verse":28,"text":"거짓 증인은 패망하려니와 확실한 증인의 말은 힘이 있느니라","reference":"잠언 21:28","category":"$undefined"},{"id":"17014","book":"잠언","book_name":"잠언","chapter":21,"verse":29,"text":"악인은 그 얼굴을 굳게 하나 정직한 자는 그 행위를 삼가느니라","reference":"잠언 21:29","category":"$undefined"},{"id":"17015","book":"잠언","book_name":"잠언","chapter":21,"verse":30,"text":"지혜로도 명철로도 모략으로도 여호와를 당치 못하느니라","reference":"잠언 21:30","category":"$undefined"},{"id":"17016","book":"잠언","book_name":"잠언","chapter":21,"verse":31,"text":"싸울 날을 위하여 마병을 예비하거니와 이김은 여호와께 있느니라","reference":"잠언 21:31","category":"$undefined"}],"bookSlug":"proverbs"}]
