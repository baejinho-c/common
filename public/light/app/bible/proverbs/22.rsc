2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":22,"verses":[{"id":"17017","book":"잠언","book_name":"잠언","chapter":22,"verse":1,"text":"많은 재물보다 명예를 택할 것이요 은이나 금보다 은총을 더욱 택할 것이니라","reference":"잠언 22:1","category":"$undefined"},{"id":"17018","book":"잠언","book_name":"잠언","chapter":22,"verse":2,"text":"빈부가 섞여 살거니와 무릇 그들을 지으신 이는 여호와시니라","reference":"잠언 22:2","category":"$undefined"},{"id":"17019","book":"잠언","book_name":"잠언","chapter":22,"verse":3,"text":"슬기로운 자는 재앙을 보면 숨어 피하여도 어리석은 자들은 나아가다가 해를 받느니라","reference":"잠언 22:3","category":"$undefined"},{"id":"17020","book":"잠언","book_name":"잠언","chapter":22,"verse":4,"text":"겸손과 여호와를 경외함의 보응은 재물과 영광과 생명이니라","reference":"잠언 22:4","category":"$undefined"},{"id":"17021","book":"잠언","book_name":"잠언","chapter":22,"verse":5,"text":"패역한 자의 길에는 가시와 올무가 있거니와 영혼을 지키는 자는 이를 멀리 하느니라","reference":"잠언 22:5","category":"$undefined"},{"id":"17022","book":"잠언","book_name":"잠언","chapter":22,"verse":6,"text":"마땅히 행할 길을 아이에게 가르치라 그리하면 늙어도 그것을 떠나지 아니하리라","reference":"잠언 22:6","category":"$undefined"},{"id":"17023","book":"잠언","book_name":"잠언","chapter":22,"verse":7,"text":"부자는 가난한 자를 주관하고 빚진 자는 채주의 종이 되느니라","reference":"잠언 22:7","category":"$undefined"},{"id":"17024","book":"잠언","book_name":"잠언","chapter":22,"verse":8,"text":"악을 뿌리는 자는 재앙을 거두리니 그 분노의 기세가 쇠하리라","reference":"잠언 22:8","category":"$undefined"},{"id":"17025","book":"잠언","book_name":"잠언","chapter":22,"verse":9,"text":"선한 눈을 가진 자는 복을 받으리니 이는 양식을 가난한 자에게 줌이니라","reference":"잠언 22:9","category":"$undefined"},{"id":"17026","book":"잠언","book_name":"잠언","chapter":22,"verse":10,"text":"거만한 자를 쫓아내면 다툼이 쉬고 싸움과 수욕이 그치느니라","reference":"잠언 22:10","category":"$undefined"},{"id":"17027","book":"잠언","book_name":"잠언","chapter":22,"verse":11,"text":"마음의 정결을 사모하는 자의 입술에는 덕이 있으므로 임금이 그의 친구가 되느니라","reference":"잠언 22:11","category":"$undefined"},{"id":"17028","book":"잠언","book_name":"잠언","chapter":22,"verse":12,"text":"여호와께서는 지식있는 자를 그 눈으로 지키시나 궤사한 자의 말은 패하게 하시느니라","reference":"잠언 22:12","category":"$undefined"},{"id":"17029","book":"잠언","book_name":"잠언","chapter":22,"verse":13,"text":"게으른 자는 말하기를 사자가 밖에 있은즉 내가 나가면 거리에서 찢기겠다 하느니라","reference":"잠언 22:13","category":"$undefined"},{"id":"17030","book":"잠언","book_name":"잠언","chapter":22,"verse":14,"text":"음녀의 입은 깊은 함정이라 여호와의 노를 당한 자는 거기 빠지리라","reference":"잠언 22:14","category":"$undefined"},{"id":"17031","book":"잠언","book_name":"잠언","chapter":22,"verse":15,"text":"아이의 마음에는 미련한 것이 얽혔으나 징계하는 채찍이 이를 멀리 쫓아내리라","reference":"잠언 22:15","category":"$undefined"},{"id":"17032","book":"잠언","book_name":"잠언","chapter":22,"verse":16,"text":"이를 얻으려고 가난한 자를 학대하는 자와 부자에게 주는 자는 가난하여질 뿐이니라","reference":"잠언 22:16","category":"$undefined"},{"id":"17033","book":"잠언","book_name":"잠언","chapter":22,"verse":17,"text":"너는 귀를 기울여 지혜있는 자의 말씀을 들으며 내 지식에 마음을 둘지어다","reference":"잠언 22:17","category":"$undefined"},{"id":"17034","book":"잠언","book_name":"잠언","chapter":22,"verse":18,"text":"이것을 네 속에 보존하며 네 입술에 있게 함이 아름다우니라","reference":"잠언 22:18","category":"$undefined"},{"id":"17035","book":"잠언","book_name":"잠언","chapter":22,"verse":19,"text":"내가 너로 여호와를 의뢰하게 하려 하여 이것을 오늘 특별히 네게 알게 하였노니","reference":"잠언 22:19","category":"$undefined"},{"id":"17036","book":"잠언","book_name":"잠언","chapter":22,"verse":20,"text":"내가 모략과 지식의 아름다운 것을 기록하여","reference":"잠언 22:20","category":"$undefined"},{"id":"17037","book":"잠언","book_name":"잠언","chapter":22,"verse":21,"text":"너로 진리의 확실한 말씀을 깨닫게 하며 또 너를 보내는 자에게 진리의 말씀으로 회답하게 하려 함이 아니냐","reference":"잠언 22:21","category":"$undefined"},{"id":"17038","book":"잠언","book_name":"잠언","chapter":22,"verse":22,"text":"약한 자를 약하다고 탈취하지 말며 곤고한 자를 성문에서 압제하지 말라","reference":"잠언 22:22","category":"$undefined"},{"id":"17039","book":"잠언","book_name":"잠언","chapter":22,"verse":23,"text":"대저 여호와께서 신원하여 주시고 또 그를 노략하는 자의 생명을 빼앗으시리라","reference":"잠언 22:23","category":"$undefined"},{"id":"17040","book":"잠언","book_name":"잠언","chapter":22,"verse":24,"text":"노를 품는 자와 사귀지 말며 울분한 자와 동행하지 말지니","reference":"잠언 22:24","category":"$undefined"},{"id":"17041","book":"잠언","book_name":"잠언","chapter":22,"verse":25,"text":"그 행위를 본받아서 네 영혼을 올무에 빠칠까 두려움이니라","reference":"잠언 22:25","category":"$undefined"},{"id":"17042","book":"잠언","book_name":"잠언","chapter":22,"verse":26,"text":"너는 사람으로 더불어 손을 잡지 말며 남의 빚에 보증이 되지 말라","reference":"잠언 22:26","category":"$undefined"},{"id":"17043","book":"잠언","book_name":"잠언","chapter":22,"verse":27,"text":"만일 갚을 것이 없으면 네 누운 침상도 빼앗길 것이라 네가 어찌 그리하겠느냐","reference":"잠언 22:27","category":"$undefined"},{"id":"17044","book":"잠언","book_name":"잠언","chapter":22,"verse":28,"text":"네 선조의 세운 옛 지계석을 옮기지 말지니라","reference":"잠언 22:28","category":"$undefined"},{"id":"17045","book":"잠언","book_name":"잠언","chapter":22,"verse":29,"text":"네가 자기 사업에 근실한 사람을 보았느냐 이러한 사람은 왕 앞에 설 것이요 천한 자 앞에 서지 아니하리라","reference":"잠언 22:29","category":"$undefined"}],"bookSlug":"proverbs"}]
