2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":23,"verses":[{"id":"17046","book":"잠언","book_name":"잠언","chapter":23,"verse":1,"text":"네가 관원과 함께 앉아 음식을 먹게 되거든 삼가 네 앞에 있는 자가 누구인지 생각하며","reference":"잠언 23:1","category":"$undefined"},{"id":"17047","book":"잠언","book_name":"잠언","chapter":23,"verse":2,"text":"네가 만일 탐식자여든 네 목에 칼을 둘 것이니라","reference":"잠언 23:2","category":"$undefined"},{"id":"17048","book":"잠언","book_name":"잠언","chapter":23,"verse":3,"text":"그 진찬을 탐하지 말라 그것은 간사하게 베푼 식물이니라","reference":"잠언 23:3","category":"$undefined"},{"id":"17049","book":"잠언","book_name":"잠언","chapter":23,"verse":4,"text":"부자 되기에 애쓰지 말고 네 사사로운 지혜를 버릴지어다","reference":"잠언 23:4","category":"$undefined"},{"id":"17050","book":"잠언","book_name":"잠언","chapter":23,"verse":5,"text":"네가 어찌 허무한 것에 주목하겠느냐 정녕히 재물은 날개를 내어 하늘에 나는 독수리처럼 날아가리라","reference":"잠언 23:5","category":"$undefined"},{"id":"17051","book":"잠언","book_name":"잠언","chapter":23,"verse":6,"text":"악한 눈이 있는 자의 음식을 먹지 말며 그 진찬을 탐하지 말지어다","reference":"잠언 23:6","category":"$undefined"},{"id":"17052","book":"잠언","book_name":"잠언","chapter":23,"verse":7,"text":"대저 그 마음의 생각이 어떠하면 그 위인도 그러한즉 그가 너더러 먹고 마시라 할지라도 그 마음은 너와 함께하지 아니함이라","reference":"잠언 23:7","category":"$undefined"},{"id":"17053","book":"잠언","book_name":"잠언","chapter":23,"verse":8,"text":"네가 조금 먹은 것도 토하겠고 네 아름다운 말도 헛된 데로 돌아가리라","reference":"잠언 23:8","category":"$undefined"},{"id":"17054","book":"잠언","book_name":"잠언","chapter":23,"verse":9,"text":"미련한 자의 귀에 말하지 말지니 이는 그가 네 지혜로운 말을 업신여길 것임이니라","reference":"잠언 23:9","category":"$undefined"},{"id":"17055","book":"잠언","book_name":"잠언","chapter":23,"verse":10,"text":"옛 지계석을 옮기지 말며 외로운 자식의 밭을 침범하지 말찌어다","reference":"잠언 23:10","category":"$undefined"},{"id":"17056","book":"잠언","book_name":"잠언","chapter":23,"verse":11,"text":"대저 그들의 구속자는 강하시니 너를 대적하사 그 원을 펴시리라","reference":"잠언 23:11","category":"$undefined"},{"id":"17057","book":"잠언","book_name":"잠언","chapter":23,"verse":12,"text":"훈계에 착심하며 지식의 말씀에 귀를 기울이라","reference":"잠언 23:12","category":"$undefined"},{"id":"17058","book":"잠언","book_name":"잠언","chapter":23,"verse":13,"text":"아이를 훈계하지 아니치 말라 채찍으로 그를 때릴지라도 죽지 아니하리라","reference":"잠언 23:13","category":"$undefined"},{"id":"17059","book":"잠언","book_name":"잠언","chapter":23,"verse":14,"text":"그를 채찍으로 때리면 그 영혼을 음부에서 구원하리라","reference":"잠언 23:14","category":"$undefined"},{"id":"17060","book":"잠언","book_name":"잠언","chapter":23,"verse":15,"text":"내 아들아 만일 네 마음이 지혜로우면 나 곧 내 마음이 즐겁겠고","reference":"잠언 23:15","category":"$undefined"},{"id":"17061","book":"잠언","book_name":"잠언","chapter":23,"verse":16,"text":"만일 네 입술이 정직을 말하면 내 속이 유쾌하리라","reference":"잠언 23:16","category":"$undefined"},{"id":"17062","book":"잠언","book_name":"잠언","chapter":23,"verse":17,"text":"네 마음으로 죄인의 형통을 부러워하지 말고 항상 여호와를 경외하라","reference":"잠언 23:17","category":"$undefined"},{"id":"17063","book":"잠언","book_name":"잠언","chapter":23,"verse":18,"text":"정녕히 네 장래가 있겠고 네 소망이 끊어지지 아니하리라","reference":"잠언 23:18","category":"$undefined"},{"id":"17064","book":"잠언","book_name":"잠언","chapter":23,"verse":19,"text":"내 아들아 너는 듣고 지혜를 얻어 네 마음을 정로로 인도할지니라","reference":"잠언 23:19","category":"$undefined"},{"id":"17065","book":"잠언","book_name":"잠언","chapter":23,"verse":20,"text":"술을 즐겨하는 자와 고기를 탐하는 자로 더불어 사귀지 말라","reference":"잠언 23:20","category":"$undefined"},{"id":"17066","book":"잠언","book_name":"잠언","chapter":23,"verse":21,"text":"술 취하고 탐식하는 자는 가난하여질 것이요 잠 자기를 즐겨하는 자는 해어진 옷을 입을 것임이니라","reference":"잠언 23:21","category":"$undefined"},{"id":"17067","book":"잠언","book_name":"잠언","chapter":23,"verse":22,"text":"너 낳은 아비에게 청종하고 네 늙은 어미를 경히 여기지 말지니라","reference":"잠언 23:22","category":"$undefined"},{"id":"17068","book":"잠언","book_name":"잠언","chapter":23,"verse":23,"text":"진리를 사고서 팔지 말며 지혜와 훈계와 명철도 그리할지니라","reference":"잠언 23:23","category":"$undefined"},{"id":"17069","book":"잠언","book_name":"잠언","chapter":23,"verse":24,"text":"의인의 아비는 크게 즐거울 것이요 지혜로운 자식을 낳은 자는 그를 인하여 즐거울 것이니라","reference":"잠언 23:24","category":"$undefined"},{"id":"17070","book":"잠언","book_name":"잠언","chapter":23,"verse":25,"text":"네 부모를 즐겁게 하며 너 낳은 어미를 기쁘게 하라","reference":"잠언 23:25","category":"$undefined"},{"id":"17071","book":"잠언","book_name":"잠언","chapter":23,"verse":26,"text":"내 아들아 네 마음을 내게 주며 네 눈으로 내 길을 즐거워할지어다","reference":"잠언 23:26","category":"$undefined"},{"id":"17072","book":"잠언","book_name":"잠언","chapter":23,"verse":27,"text":"대저 음녀는 깊은 구렁이요 이방 여인은 좁은 함정이라","reference":"잠언 23:27","category":"$undefined"},{"id":"17073","book":"잠언","book_name":"잠언","chapter":23,"verse":28,"text":"그는 강도 같이 매복하며 인간에 궤사한 자가 많아지게 하느니라","reference":"잠언 23:28","category":"$undefined"},{"id":"17074","book":"잠언","book_name":"잠언","chapter":23,"verse":29,"text":"재앙이 뉘게 있느뇨 근심이 뉘게 있느뇨 분쟁이 뉘게 있느뇨 원망이 뉘게 있느뇨 까닭 없는 창상이 뉘게 있느뇨 붉은 눈이 뉘게 있느뇨","reference":"잠언 23:29","category":"$undefined"},{"id":"17075","book":"잠언","book_name":"잠언","chapter":23,"verse":30,"text":"술에 잠긴 자에게 있고 혼합한 술을 구하러 다니는 자에게 있느니라","reference":"잠언 23:30","category":"$undefined"},{"id":"17076","book":"잠언","book_name":"잠언","chapter":23,"verse":31,"text":"포도주는 붉고 잔에서 번쩍이며 순하게 내려가나니 너는 그것을 보지도 말지어다","reference":"잠언 23:31","category":"$undefined"},{"id":"17077","book":"잠언","book_name":"잠언","chapter":23,"verse":32,"text":"이것이 마침내 뱀 같이 물 것이요 독사 같이 쏠 것이며","reference":"잠언 23:32","category":"$undefined"},{"id":"17078","book":"잠언","book_name":"잠언","chapter":23,"verse":33,"text":"또 네 눈에는 괴이한 것이 보일 것이요 네 마음은 망령된 것을 발할 것이며","reference":"잠언 23:33","category":"$undefined"},{"id":"17079","book":"잠언","book_name":"잠언","chapter":23,"verse":34,"text":"너는 바다 가운데 누운 자 같을 것이요 돛대 위에 누운 자 같을 것이며","reference":"잠언 23:34","category":"$undefined"},{"id":"17080","book":"잠언","book_name":"잠언","chapter":23,"verse":35,"text":"네가 스스로 말하기를 사람이 나를 때려도 나는 아프지 아니하고 나를 상하게 하여도 내게 감각이 없도다 내가 언제나 깰까 다시 술을 찾겠다 하리라","reference":"잠언 23:35","category":"$undefined"}],"bookSlug":"proverbs"}]
