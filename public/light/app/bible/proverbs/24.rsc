2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":24,"verses":[{"id":"17081","book":"잠언","book_name":"잠언","chapter":24,"verse":1,"text":"너는 악인의 형통을 부러워하지 말며 그와 함께 있기도 원하지 말지어다","reference":"잠언 24:1","category":"$undefined"},{"id":"17082","book":"잠언","book_name":"잠언","chapter":24,"verse":2,"text":"그들의 마음은 강포를 품고 그 입술은 잔해를 말함이니라","reference":"잠언 24:2","category":"$undefined"},{"id":"17083","book":"잠언","book_name":"잠언","chapter":24,"verse":3,"text":"집은 지혜로 말미암아 건축되고 명철로 말미암아 견고히 되며","reference":"잠언 24:3","category":"$undefined"},{"id":"17084","book":"잠언","book_name":"잠언","chapter":24,"verse":4,"text":"또 방들은 지식으로 말미암아 각종 귀하고 아름다운 보배로 채우게 되느니라","reference":"잠언 24:4","category":"$undefined"},{"id":"17085","book":"잠언","book_name":"잠언","chapter":24,"verse":5,"text":"지혜 있는 자는 강하고 지식 있는 자는 힘을 더하나니","reference":"잠언 24:5","category":"$undefined"},{"id":"17086","book":"잠언","book_name":"잠언","chapter":24,"verse":6,"text":"너는 모략으로 싸우라 승리는 모사가 많음에 있느니라","reference":"잠언 24:6","category":"$undefined"},{"id":"17087","book":"잠언","book_name":"잠언","chapter":24,"verse":7,"text":"지혜는 너무 높아서 미련한 자의 미치지 못할 것이므로 그는 성문에서 입을 열지 못하느니라","reference":"잠언 24:7","category":"$undefined"},{"id":"17088","book":"잠언","book_name":"잠언","chapter":24,"verse":8,"text":"악을 행하기를 꾀하는 자를 일컬어 사특한 자라 하느니라","reference":"잠언 24:8","category":"$undefined"},{"id":"17089","book":"잠언","book_name":"잠언","chapter":24,"verse":9,"text":"미련한 자의 생각은 죄요 거만한 자는 사람의 미움을 받느니라","reference":"잠언 24:9","category":"$undefined"},{"id":"17090","book":"잠언","book_name":"잠언","chapter":24,"verse":10,"text":"네가 만일 환난날에 낙담하면 네 힘의 미약함을 보임이니라","reference":"잠언 24:10","category":"$undefined"},{"id":"17091","book":"잠언","book_name":"잠언","chapter":24,"verse":11,"text":"너는 사망으로 끌려가는 자를 건져주며 살륙을 당하게 된 자를 구원하지 아니치 말라","reference":"잠언 24:11","category":"$undefined"},{"id":"17092","book":"잠언","book_name":"잠언","chapter":24,"verse":12,"text":"네가 말하기를 나는 그것을 알지 못하였노라 할지라도 마음을 저울질 하시는 이가 어찌 통찰하지 못하시겠으며 네 영혼을 지키시는 이가 어찌 알지 못하시겠느냐 그가 각 사람의 행위대로 보응하시리라","reference":"잠언 24:12","category":"$undefined"},{"id":"17093","book":"잠언","book_name":"잠언","chapter":24,"verse":13,"text":"내 아들아 꿀을 먹으라 이것이 좋으니라 송이꿀을 먹으라 이것이 네 입에 다니라","reference":"잠언 24:13","category":"$undefined"},{"id":"17094","book":"잠언","book_name":"잠언","chapter":24,"verse":14,"text":"지혜가 네 영혼에게 이와 같은 줄을 알라 이것을 얻으면 정녕히 네 장래가 있겠고 네 소망이 끊어지지 아니하리라","reference":"잠언 24:14","category":"$undefined"},{"id":"17095","book":"잠언","book_name":"잠언","chapter":24,"verse":15,"text":"악한 자여 의인의 집을 엿보지 말며 그 쉬는 처소를 헐지 말지니라","reference":"잠언 24:15","category":"$undefined"},{"id":"17096","book":"잠언","book_name":"잠언","chapter":24,"verse":16,"text":"대저 의인은 일곱번 넘어질지라도 다시 일어나려니와 악인은 재앙으로 인하여 엎드러지느니라","reference":"잠언 24:16","category":"$undefined"},{"id":"17097","book":"잠언","book_name":"잠언","chapter":24,"verse":17,"text":"네 원수가 넘어질 때에 즐거워하지 말며 그가 엎드러질 때에 마음에 기뻐하지 말라","reference":"잠언 24:17","category":"$undefined"},{"id":"17098","book":"잠언","book_name":"잠언","chapter":24,"verse":18,"text":"여호와께서 이것을 보시고 기뻐 아니하사 그 진노를 그에게서 옮기실까 두려우니라","reference":"잠언 24:18","category":"$undefined"},{"id":"17099","book":"잠언","book_name":"잠언","chapter":24,"verse":19,"text":"너는 행악자의 득의함을 인하여 분을 품지 말며 악인의 형통을 부러워하지 말라","reference":"잠언 24:19","category":"$undefined"},{"id":"17100","book":"잠언","book_name":"잠언","chapter":24,"verse":20,"text":"대저 행악자는 장래가 없겠고 악인의 등불은 꺼지리라","reference":"잠언 24:20","category":"$undefined"},{"id":"17101","book":"잠언","book_name":"잠언","chapter":24,"verse":21,"text":"내 아들아 여호와와 왕을 경외하고 반역자로 더불어 사귀지 말라","reference":"잠언 24:21","category":"$undefined"},{"id":"17102","book":"잠언","book_name":"잠언","chapter":24,"verse":22,"text":"대저 그들의 재앙은 속히 임하리니 이 두 자의 멸망을 누가 알랴","reference":"잠언 24:22","category":"$undefined"},{"id":"17103","book":"잠언","book_name":"잠언","chapter":24,"verse":23,"text":"이것도 지혜로운 자의 말씀이라 재판할 때에 낯을 보아주는 것이옳지 못하니라","reference":"잠언 24:23","category":"$undefined"},{"id":"17104","book":"잠언","book_name":"잠언","chapter":24,"verse":24,"text":"무릇 악인더러 옳다 하는 자는 백성에게 저주를 받을 것이요 국민에게 미움을 받으려니와","reference":"잠언 24:24","category":"$undefined"},{"id":"17105","book":"잠언","book_name":"잠언","chapter":24,"verse":25,"text":"오직 그를 견책하는 자는 기쁨을 얻을 것이요 또 좋은 복을 받으리라","reference":"잠언 24:25","category":"$undefined"},{"id":"17106","book":"잠언","book_name":"잠언","chapter":24,"verse":26,"text":"적당한 말로 대답함은 입맞춤과 같으니라","reference":"잠언 24:26","category":"$undefined"},{"id":"17107","book":"잠언","book_name":"잠언","chapter":24,"verse":27,"text":"네 일을 밖에서 다스리며 밭에서 예비하고 그 후에 네 집을 세울지니라","reference":"잠언 24:27","category":"$undefined"},{"id":"17108","book":"잠언","book_name":"잠언","chapter":24,"verse":28,"text":"너는 까닭없이 네 이웃을 쳐서 증인이 되지 말며 네 입술로 속이지 말지니라","reference":"잠언 24:28","category":"$undefined"},{"id":"17109","book":"잠언","book_name":"잠언","chapter":24,"verse":29,"text":"너는 그가 내게 행함 같이 나도 그에게 행하여 그 행한대로 갚겠다 말하지 말지니라","reference":"잠언 24:29","category":"$undefined"},{"id":"17110","book":"잠언","book_name":"잠언","chapter":24,"verse":30,"text":"내가 증왕에 게으른 자의 밭과 지혜 없는 자의 포도원을 지나며 본즉","reference":"잠언 24:30","category":"$undefined"},{"id":"17111","book":"잠언","book_name":"잠언","chapter":24,"verse":31,"text":"가시덤불이 퍼졌으며 거친 풀이 지면에 덮였고 돌담이 무너졌기로","reference":"잠언 24:31","category":"$undefined"},{"id":"17112","book":"잠언","book_name":"잠언","chapter":24,"verse":32,"text":"내가 보고 생각이 깊었고 내가 보고 훈계를 받았었노라","reference":"잠언 24:32","category":"$undefined"},{"id":"17113","book":"잠언","book_name":"잠언","chapter":24,"verse":33,"text":"네가 좀더 자자, 좀더 졸자, 손을 모으고 좀더 눕자 하니 네 빈궁이 강도 같이 오며","reference":"잠언 24:33","category":"$undefined"},{"id":"17114","book":"잠언","book_name":"잠언","chapter":24,"verse":34,"text":"네 곤핍이 군사 같이 이르리라","reference":"잠언 24:34","category":"$undefined"}],"bookSlug":"proverbs"}]
