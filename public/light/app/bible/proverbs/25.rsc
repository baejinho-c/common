2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":25,"verses":[{"id":"17115","book":"잠언","book_name":"잠언","chapter":25,"verse":1,"text":"이것도 솔로몬의 잠언이요 유다 왕 히스기야의 신하들의 편집한 것이니라","reference":"잠언 25:1","category":"$undefined"},{"id":"17116","book":"잠언","book_name":"잠언","chapter":25,"verse":2,"text":"일을 숨기는 것은 하나님의 영화요 일을 살피는 것은 왕의 영화니라","reference":"잠언 25:2","category":"$undefined"},{"id":"17117","book":"잠언","book_name":"잠언","chapter":25,"verse":3,"text":"하늘의 높음과 땅의 깊음 같이 왕의 마음은 헤아릴 수 없느니라","reference":"잠언 25:3","category":"$undefined"},{"id":"17118","book":"잠언","book_name":"잠언","chapter":25,"verse":4,"text":"은에서 찌끼를 제하라 그리하면 장색의 쓸만한 그릇이 나올 것이요","reference":"잠언 25:4","category":"$undefined"},{"id":"17119","book":"잠언","book_name":"잠언","chapter":25,"verse":5,"text":"왕 앞에서 악한 자를 제하라 그리하면 그 위가 의로 말미암아 견고히 서리라","reference":"잠언 25:5","category":"$undefined"},{"id":"17120","book":"잠언","book_name":"잠언","chapter":25,"verse":6,"text":"왕 앞에서 스스로 높은 체 하지말며 대인의 자리에 서지 말라","reference":"잠언 25:6","category":"$undefined"},{"id":"17121","book":"잠언","book_name":"잠언","chapter":25,"verse":7,"text":"이는 사람이 너더러 이리로 올라오라 하는 것이 네 눈에 보이는 귀인 앞에서 저리로 내려가라 하는 것보다 나음이니라","reference":"잠언 25:7","category":"$undefined"},{"id":"17122","book":"잠언","book_name":"잠언","chapter":25,"verse":8,"text":"너는 급거히 나가서 다투지 말라 마침내 네가 이웃에게 욕을 보게 될 때에 네가 어찌 할 줄을 알지 못할까 두려우니라","reference":"잠언 25:8","category":"$undefined"},{"id":"17123","book":"잠언","book_name":"잠언","chapter":25,"verse":9,"text":"너는 이웃과 다투거든 변론만 하고 남의 은밀한 일을 누설하지 말라","reference":"잠언 25:9","category":"$undefined"},{"id":"17124","book":"잠언","book_name":"잠언","chapter":25,"verse":10,"text":"듣는 자가 너를 꾸짖을 터이요 또 수욕이 네게서 떠나지 아니할까 두려우니라","reference":"잠언 25:10","category":"$undefined"},{"id":"17125","book":"잠언","book_name":"잠언","chapter":25,"verse":11,"text":"경우에 합당한 말은 아로새긴 은쟁반에 금사과니라","reference":"잠언 25:11","category":"$undefined"},{"id":"17126","book":"잠언","book_name":"잠언","chapter":25,"verse":12,"text":"슬기로운 자의 책망은 청종하는 귀에 금고리와 정금 장식이니라","reference":"잠언 25:12","category":"$undefined"},{"id":"17127","book":"잠언","book_name":"잠언","chapter":25,"verse":13,"text":"충성된 사자는 그를 보낸 이에게 마치 추수하는 날에 얼음 냉수같아서 능히 그 주인의 마음을 시원케 하느니라","reference":"잠언 25:13","category":"$undefined"},{"id":"17128","book":"잠언","book_name":"잠언","chapter":25,"verse":14,"text":"선물한다고 거짓 자랑하는 자는 비 없는 구름과 바람 같으니라","reference":"잠언 25:14","category":"$undefined"},{"id":"17129","book":"잠언","book_name":"잠언","chapter":25,"verse":15,"text":"오래 참으면 관원이 그 말을 용납하나니 부드러운 혀는 뼈를 꺾느니라","reference":"잠언 25:15","category":"$undefined"},{"id":"17130","book":"잠언","book_name":"잠언","chapter":25,"verse":16,"text":"너는 꿀을 만나거든 족하리만큼 먹으라 과식하므로 토할까 두려우니라","reference":"잠언 25:16","category":"$undefined"},{"id":"17131","book":"잠언","book_name":"잠언","chapter":25,"verse":17,"text":"너는 이웃집에 자주 다니지 말라 그가 너를 싫어하며 미워할까 두려우니라","reference":"잠언 25:17","category":"$undefined"},{"id":"17132","book":"잠언","book_name":"잠언","chapter":25,"verse":18,"text":"그 이웃을 쳐서 거짓 증거하는 사람은 방망이요 칼이요 뾰족한 살이니라","reference":"잠언 25:18","category":"$undefined"},{"id":"17133","book":"잠언","book_name":"잠언","chapter":25,"verse":19,"text":"환난날에 진실치 못한 자를 의뢰하는 의뢰는 부러진 이와 위골된 발 같으니라","reference":"잠언 25:19","category":"$undefined"},{"id":"17134","book":"잠언","book_name":"잠언","chapter":25,"verse":20,"text":"마음이 상한 자에게 노래하는 것은 추운 날에 옷을 벗음 같고 쏘다 위에 초를 부음 같으니라","reference":"잠언 25:20","category":"$undefined"},{"id":"17135","book":"잠언","book_name":"잠언","chapter":25,"verse":21,"text":"네 원수가 배고파하거든 식물을 먹이고 목말라하거든 물을 마시우라","reference":"잠언 25:21","category":"$undefined"},{"id":"17136","book":"잠언","book_name":"잠언","chapter":25,"verse":22,"text":"그리하는 것은 핀 숯으로 그의 머리에 놓는 것과 일반이요 여호와께서는 네게 상을 주시리라","reference":"잠언 25:22","category":"$undefined"},{"id":"17137","book":"잠언","book_name":"잠언","chapter":25,"verse":23,"text":"북풍이 비를 일으킴 같이 참소하는 혀는 사람의 얼굴에 분을 일으키느니라","reference":"잠언 25:23","category":"$undefined"},{"id":"17138","book":"잠언","book_name":"잠언","chapter":25,"verse":24,"text":"다투는 여인과 함께 큰 집에서 사는 것보다 움막에서 혼자 사는 것이 나으니라","reference":"잠언 25:24","category":"$undefined"},{"id":"17139","book":"잠언","book_name":"잠언","chapter":25,"verse":25,"text":"먼 땅에서 오는 좋은 기별은 목마른 사람에게 냉수 같으니라","reference":"잠언 25:25","category":"$undefined"},{"id":"17140","book":"잠언","book_name":"잠언","chapter":25,"verse":26,"text":"의인이 악인 앞에 굴복하는 것은 우물의 흐리어짐과 샘의 더러워 짐 같으니라","reference":"잠언 25:26","category":"$undefined"},{"id":"17141","book":"잠언","book_name":"잠언","chapter":25,"verse":27,"text":"꿀을 많이 먹는 것이 좋지 못하고 자기의 영예를 구하는 것이 헛되니라","reference":"잠언 25:27","category":"$undefined"},{"id":"17142","book":"잠언","book_name":"잠언","chapter":25,"verse":28,"text":"자기의 마음을 제어하지 아니하는 자는 성읍이 무너지고 성벽이 없는 것 같으니라","reference":"잠언 25:28","category":"$undefined"}],"bookSlug":"proverbs"}]
