2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":26,"verses":[{"id":"17143","book":"잠언","book_name":"잠언","chapter":26,"verse":1,"text":"미련한 자에게는 영예가 적당하지 아니하니 마치 여름에 눈오는 것과 추수 때에 비오는 것 같으니라","reference":"잠언 26:1","category":"$undefined"},{"id":"17144","book":"잠언","book_name":"잠언","chapter":26,"verse":2,"text":"까닭 없는 저주는 참새의 떠도는 것과 제비의 날아가는 것 같이 이르지 아니하느니라","reference":"잠언 26:2","category":"$undefined"},{"id":"17145","book":"잠언","book_name":"잠언","chapter":26,"verse":3,"text":"말에게는 채찍이요 나귀에게는 자갈이요 미련한 자의 등에는 막대기니라","reference":"잠언 26:3","category":"$undefined"},{"id":"17146","book":"잠언","book_name":"잠언","chapter":26,"verse":4,"text":"미련한 자의 어리석은 것을 따라 대답하지 말라 두렵건대 네가 그와 같을까 하노라","reference":"잠언 26:4","category":"$undefined"},{"id":"17147","book":"잠언","book_name":"잠언","chapter":26,"verse":5,"text":"미련한 자의 어리석은 것을 따라 그에게 대답하라 두렵건대 그가 스스로 지혜롭게 여길까 하노라","reference":"잠언 26:5","category":"$undefined"},{"id":"17148","book":"잠언","book_name":"잠언","chapter":26,"verse":6,"text":"미련한 자 편에 기별하는 것은 자기의 발을 베어 버림이라 해를 받느니라","reference":"잠언 26:6","category":"$undefined"},{"id":"17149","book":"잠언","book_name":"잠언","chapter":26,"verse":7,"text":"저는 자의 다리는 힘 없이 달렸나니 미련한 자의 입의 잠언도 그러하니라","reference":"잠언 26:7","category":"$undefined"},{"id":"17150","book":"잠언","book_name":"잠언","chapter":26,"verse":8,"text":"미련한 자에게 영예를 주는 것은 돌을 물매에 매는 것과 같으니라","reference":"잠언 26:8","category":"$undefined"},{"id":"17151","book":"잠언","book_name":"잠언","chapter":26,"verse":9,"text":"미련한 자의 입의 잠언은 술 취한 자의 손에 든 가시나무 같으니라","reference":"잠언 26:9","category":"$undefined"},{"id":"17152","book":"잠언","book_name":"잠언","chapter":26,"verse":10,"text":"장인이 온갖 것을 만들지라도 미련한 자를 고용하는 것은 지나가는 자를 고용함과 같으니라","reference":"잠언 26:10","category":"$undefined"},{"id":"17153","book":"잠언","book_name":"잠언","chapter":26,"verse":11,"text":"개가 그 토한 것을 도로 먹는 것 같이 미련한 자는 그 미련한 것을 거듭 행하느니라","reference":"잠언 26:11","category":"$undefined"},{"id":"17154","book":"잠언","book_name":"잠언","chapter":26,"verse":12,"text":"네가 스스로 지혜롭게 여기는 자를 보느냐 그보다 미련한 자에게 오히려 바랄 것이 있느니라","reference":"잠언 26:12","category":"$undefined"},{"id":"17155","book":"잠언","book_name":"잠언","chapter":26,"verse":13,"text":"게으른 자는 길에 사자가 있다 거리에 사자가 있다 하느니라","reference":"잠언 26:13","category":"$undefined"},{"id":"17156","book":"잠언","book_name":"잠언","chapter":26,"verse":14,"text":"문짝이 돌쩌귀를 따라서 도는 것 같이 게으른 자는 침상에서 구으느니라","reference":"잠언 26:14","category":"$undefined"},{"id":"17157","book":"잠언","book_name":"잠언","chapter":26,"verse":15,"text":"게으른 자는 그 손을 그릇에 넣고도 입으로 올리기를 괴로와하느니라","reference":"잠언 26:15","category":"$undefined"},{"id":"17158","book":"잠언","book_name":"잠언","chapter":26,"verse":16,"text":"게으른 자는 선히 대답하는 사람 일곱보다 자기를 지혜롭게 여기느니라","reference":"잠언 26:16","category":"$undefined"},{"id":"17159","book":"잠언","book_name":"잠언","chapter":26,"verse":17,"text":"길로 지나다가 자기에게 상관없는 다툼을 간섭하는 자는 개 귀를 잡는 자와 같으니라","reference":"잠언 26:17","category":"$undefined"},{"id":"17160","book":"잠언","book_name":"잠언","chapter":26,"verse":18,"text":"횃불을 던지며 살을 쏘아서 사람을 죽이는 미친 사람이 있나니","reference":"잠언 26:18","category":"$undefined"},{"id":"17161","book":"잠언","book_name":"잠언","chapter":26,"verse":19,"text":"자기 이웃을 속이고 말하기를 내가 희롱하였노라 하는 자도 그러하니라","reference":"잠언 26:19","category":"$undefined"},{"id":"17162","book":"잠언","book_name":"잠언","chapter":26,"verse":20,"text":"나무가 다하면 불이 꺼지고 말장이가 없어지면 다툼이 쉬느니라","reference":"잠언 26:20","category":"$undefined"},{"id":"17163","book":"잠언","book_name":"잠언","chapter":26,"verse":21,"text":"숯불 위에 숯을 더하는 것과 타는 불에 나무를 더하는 것 같이 다툼을 좋아하는 자는 시비를 일으키느니라","reference":"잠언 26:21","category":"$undefined"},{"id":"17164","book":"잠언","book_name":"잠언","chapter":26,"verse":22,"text":"남의 말하기를 좋아하는 자의 말은 별식과 같아서 뱃 속 깊은 데로 내려가느니라","reference":"잠언 26:22","category":"$undefined"},{"id":"17165","book":"잠언","book_name":"잠언","chapter":26,"verse":23,"text":"온유한 입술에 악한 마음은 낮은 은을 입힌 토기니라","reference":"잠언 26:23","category":"$undefined"},{"id":"17166","book":"잠언","book_name":"잠언","chapter":26,"verse":24,"text":"감정있는 자는 입술로는 꾸미고 속에는 궤휼을 품나니","reference":"잠언 26:24","category":"$undefined"},{"id":"17167","book":"잠언","book_name":"잠언","chapter":26,"verse":25,"text":"그 말이 좋을지라도 믿지 말 것은 그 마음에 일곱 가지 가증한 것이 있음이라","reference":"잠언 26:25","category":"$undefined"},{"id":"17168","book":"잠언","book_name":"잠언","chapter":26,"verse":26,"text":"궤휼로 그 감정을 감출지라도 그 악이 회중 앞에 드러나리라","reference":"잠언 26:26","category":"$undefined"},{"id":"17169","book":"잠언","book_name":"잠언","chapter":26,"verse":27,"text":"함정을 파는 자는 그것에 빠질 것이요 돌을 굴리는 자는 도리어 그것에 치이리라","reference":"잠언 26:27","category":"$undefined"},{"id":"17170","book":"잠언","book_name":"잠언","chapter":26,"verse":28,"text":"거짓말하는 자는 자기의 해한 자를 미워하고 아첨하는 입은 패망을 일으키느니라","reference":"잠언 26:28","category":"$undefined"}],"bookSlug":"proverbs"}]
