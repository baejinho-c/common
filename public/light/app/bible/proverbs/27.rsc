2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":27,"verses":[{"id":"17171","book":"잠언","book_name":"잠언","chapter":27,"verse":1,"text":"너는 내일 일을 자랑하지 말라 하루 동안에 무슨 일이 날는지 네가 알 수 없음이니라","reference":"잠언 27:1","category":"$undefined"},{"id":"17172","book":"잠언","book_name":"잠언","chapter":27,"verse":2,"text":"타인으로 너를 칭찬하게 하고 네 입으로는 말며 외인으로 너를 칭찬하게 하고 네 입술로는 말지니라","reference":"잠언 27:2","category":"$undefined"},{"id":"17173","book":"잠언","book_name":"잠언","chapter":27,"verse":3,"text":"돌은 무겁고 모래도 가볍지 아니하거니와 미련한 자의 분노는 이 둘보다 무거우니라","reference":"잠언 27:3","category":"$undefined"},{"id":"17174","book":"잠언","book_name":"잠언","chapter":27,"verse":4,"text":"분은 잔인하고 노는 창수 같거니와 투기 앞에야 누가 서리요","reference":"잠언 27:4","category":"$undefined"},{"id":"17175","book":"잠언","book_name":"잠언","chapter":27,"verse":5,"text":"면책은 숨은 사랑보다 나으니라","reference":"잠언 27:5","category":"$undefined"},{"id":"17176","book":"잠언","book_name":"잠언","chapter":27,"verse":6,"text":"친구의 통책은 충성에서 말미암은 것이나 원수의 자주 입맞춤은 거짓에서 난 것이니라","reference":"잠언 27:6","category":"$undefined"},{"id":"17177","book":"잠언","book_name":"잠언","chapter":27,"verse":7,"text":"배부른 자는 꿀이라도 싫어하고 주린 자에게는 쓴 것이라도 다니라","reference":"잠언 27:7","category":"$undefined"},{"id":"17178","book":"잠언","book_name":"잠언","chapter":27,"verse":8,"text":"본향을 떠나 유리하는 사람은 보금자리를 떠나 떠도는 새와 같으니라","reference":"잠언 27:8","category":"$undefined"},{"id":"17179","book":"잠언","book_name":"잠언","chapter":27,"verse":9,"text":"기름과 향이 사람의 마음을 즐겁게 하나니 친구의 충성된 권고가 이와 같이 아름다우니라","reference":"잠언 27:9","category":"$undefined"},{"id":"17180","book":"잠언","book_name":"잠언","chapter":27,"verse":10,"text":"네 친구와 네 아비의 친구를 버리지 말며 네 환난날에 형제의 집에 들어가지 말지어다 가까운 이웃이 먼 형제보다 나으니라","reference":"잠언 27:10","category":"$undefined"},{"id":"17181","book":"잠언","book_name":"잠언","chapter":27,"verse":11,"text":"내 아들아 지혜를 얻고 내 마음을 기쁘게 하라 그리하면 나를 비방하는 자에게 내가 대답할 수 있겠노라","reference":"잠언 27:11","category":"$undefined"},{"id":"17182","book":"잠언","book_name":"잠언","chapter":27,"verse":12,"text":"슬기로운 자는 재앙을 보면 숨어 피하여도 어리석은 자들은 나아가다가 해를 받느니라","reference":"잠언 27:12","category":"$undefined"},{"id":"17183","book":"잠언","book_name":"잠언","chapter":27,"verse":13,"text":"타인을 위하여 보증이 된 자의 옷을 취하라 외인들의 보증이 된자는 그 몸을 볼모로 잡힐지니라","reference":"잠언 27:13","category":"$undefined"},{"id":"17184","book":"잠언","book_name":"잠언","chapter":27,"verse":14,"text":"이른 아침에 큰 소리로 그 이웃을 축복하면 도리어 저주 같이 여기게 되리라","reference":"잠언 27:14","category":"$undefined"},{"id":"17185","book":"잠언","book_name":"잠언","chapter":27,"verse":15,"text":"다투는 부녀는 비오는 날에 이어 떨어지는 물방울이라","reference":"잠언 27:15","category":"$undefined"},{"id":"17186","book":"잠언","book_name":"잠언","chapter":27,"verse":16,"text":"그를 제어하기가 바람을 제어하는 것 같고 오른손으로 기름을 움키는 것 같으니라","reference":"잠언 27:16","category":"$undefined"},{"id":"17187","book":"잠언","book_name":"잠언","chapter":27,"verse":17,"text":"철이 철을 날카롭게 하는 것 같이 사람이 그 친구의 얼굴을 빛나게 하느니라","reference":"잠언 27:17","category":"$undefined"},{"id":"17188","book":"잠언","book_name":"잠언","chapter":27,"verse":18,"text":"무화과나무를 지키는 자는 그 과실을 먹고 자기 주인을 시종하는 자는 영화를 얻느니라","reference":"잠언 27:18","category":"$undefined"},{"id":"17189","book":"잠언","book_name":"잠언","chapter":27,"verse":19,"text":"물에 비취이면 얼굴이 서로 같은 것 같이 사람의 마음도 서로 비취느니라","reference":"잠언 27:19","category":"$undefined"},{"id":"17190","book":"잠언","book_name":"잠언","chapter":27,"verse":20,"text":"음부와 유명은 만족함이 없고 사람의 눈도 만족함이 없느니라","reference":"잠언 27:20","category":"$undefined"},{"id":"17191","book":"잠언","book_name":"잠언","chapter":27,"verse":21,"text":"도가니로 은을, 풀무로 금을, 칭찬으로 사람을 시련하느니라","reference":"잠언 27:21","category":"$undefined"},{"id":"17192","book":"잠언","book_name":"잠언","chapter":27,"verse":22,"text":"미련한 자를 곡물과 함께 절구에 넣고 공이로 찧을지라도 그의 미련은 벗어지지 아니하느니라","reference":"잠언 27:22","category":"$undefined"},{"id":"17193","book":"잠언","book_name":"잠언","chapter":27,"verse":23,"text":"네 양떼의 형편을 부지런히 살피며 네 소떼에 마음을 두라","reference":"잠언 27:23","category":"$undefined"},{"id":"17194","book":"잠언","book_name":"잠언","chapter":27,"verse":24,"text":"대저 재물은 영영히 있지 못하나니 면류관이 어찌 대대에 있으랴","reference":"잠언 27:24","category":"$undefined"},{"id":"17195","book":"잠언","book_name":"잠언","chapter":27,"verse":25,"text":"풀을 벤 후에는 새로 움이 돋나니 산에서 꼴을 거둘 것이니라","reference":"잠언 27:25","category":"$undefined"},{"id":"17196","book":"잠언","book_name":"잠언","chapter":27,"verse":26,"text":"어린 양의 털은 네 옷이 되며 염소는 밭을 사는 값이 되며","reference":"잠언 27:26","category":"$undefined"},{"id":"17197","book":"잠언","book_name":"잠언","chapter":27,"verse":27,"text":"염소의 젖은 넉넉하여 너와 네 집 사람의 식물이 되며 네 여종의 먹을 것이 되느니라","reference":"잠언 27:27","category":"$undefined"}],"bookSlug":"proverbs"}]
