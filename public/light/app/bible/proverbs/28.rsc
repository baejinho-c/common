2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":28,"verses":[{"id":"17198","book":"잠언","book_name":"잠언","chapter":28,"verse":1,"text":"악인은 쫓아 오는 자가 없어도 도망하나 의인은 사자 같이 담대하니라","reference":"잠언 28:1","category":"$undefined"},{"id":"17199","book":"잠언","book_name":"잠언","chapter":28,"verse":2,"text":"나라는 죄가 있으면 주관자가 많아져도 명철과 지식 있는 사람으로 말미암아 장구하게 되느니라","reference":"잠언 28:2","category":"$undefined"},{"id":"17200","book":"잠언","book_name":"잠언","chapter":28,"verse":3,"text":"가난한 자를 학대하는 가난한 자는 곡식을 남기지 아니하는 폭우같으니라","reference":"잠언 28:3","category":"$undefined"},{"id":"17201","book":"잠언","book_name":"잠언","chapter":28,"verse":4,"text":"율법을 버린 자는 악인을 칭찬하나 율법을 지키는 자는 악인을 대적하느니라","reference":"잠언 28:4","category":"$undefined"},{"id":"17202","book":"잠언","book_name":"잠언","chapter":28,"verse":5,"text":"악인은 공의를 깨닫지 못하나 여호와를 찾는 자는 모든 것을 깨닫느니라","reference":"잠언 28:5","category":"$undefined"},{"id":"17203","book":"잠언","book_name":"잠언","chapter":28,"verse":6,"text":"성실히 행하는 가난한 자는 사곡히 행하는 부자보다 나으니라","reference":"잠언 28:6","category":"$undefined"},{"id":"17204","book":"잠언","book_name":"잠언","chapter":28,"verse":7,"text":"율법을 지키는 자는 지혜로운 아들이요 탐식자를 사귀는 자는 아비를 욕되게 하는 자니라","reference":"잠언 28:7","category":"$undefined"},{"id":"17205","book":"잠언","book_name":"잠언","chapter":28,"verse":8,"text":"중한 변리로 자기 재산을 많아지게 하는 것은 가난한 사람 불쌍히 여기는 자를 위하여 그 재산을 저축하는 것이니라","reference":"잠언 28:8","category":"$undefined"},{"id":"17206","book":"잠언","book_name":"잠언","chapter":28,"verse":9,"text":"사람이 귀를 돌이키고 율법을 듣지 아니하면 그의 기도도 가증하니라","reference":"잠언 28:9","category":"$undefined"},{"id":"17207","book":"잠언","book_name":"잠언","chapter":28,"verse":10,"text":"정직한 자를 악한 길로 유인하는 자는 스스로 자기 함정에 빠져도 성실한 자는 복을 얻느니라","reference":"잠언 28:10","category":"$undefined"},{"id":"17208","book":"잠언","book_name":"잠언","chapter":28,"verse":11,"text":"부자는 자기를 지혜롭게 여겨도 명철한 가난한 자는 그를 살펴 아느니라","reference":"잠언 28:11","category":"$undefined"},{"id":"17209","book":"잠언","book_name":"잠언","chapter":28,"verse":12,"text":"의인이 득의하면 큰 영화가 있고 악인이 일어나면 사람이 숨느니라","reference":"잠언 28:12","category":"$undefined"},{"id":"17210","book":"잠언","book_name":"잠언","chapter":28,"verse":13,"text":"자기의 죄를 숨기는 자는 형통치 못하나 죄를 자복하고 버리는 자는 불쌍히 여김을 받으리라","reference":"잠언 28:13","category":"$undefined"},{"id":"17211","book":"잠언","book_name":"잠언","chapter":28,"verse":14,"text":"항상 경외하는 자는 복되거니와 마음을 강퍅하게 하는 자는 재앙에 빠지리라","reference":"잠언 28:14","category":"$undefined"},{"id":"17212","book":"잠언","book_name":"잠언","chapter":28,"verse":15,"text":"가난한 백성을 압제하는 악한 관원은 부르짖는 사자와 주린 곰 같으니라","reference":"잠언 28:15","category":"$undefined"},{"id":"17213","book":"잠언","book_name":"잠언","chapter":28,"verse":16,"text":"무지한 치리자는 포학을 크게 행하거니와 탐욕을 미워하는 자는 장수하리라","reference":"잠언 28:16","category":"$undefined"},{"id":"17214","book":"잠언","book_name":"잠언","chapter":28,"verse":17,"text":"사람의 피를 흘린 자는 함정으로 달려갈 것이니 그를 막지 말지니라","reference":"잠언 28:17","category":"$undefined"},{"id":"17215","book":"잠언","book_name":"잠언","chapter":28,"verse":18,"text":"성실히 행하는 자는 구원을 얻을 것이나 사곡히 행하는 자는 곧 넘어지리라","reference":"잠언 28:18","category":"$undefined"},{"id":"17216","book":"잠언","book_name":"잠언","chapter":28,"verse":19,"text":"자기의 토지를 경작하는 자는 먹을 것이 많으려니와 방탕을 좇는 자는 궁핍함이 많으리라","reference":"잠언 28:19","category":"$undefined"},{"id":"17217","book":"잠언","book_name":"잠언","chapter":28,"verse":20,"text":"충성된 자는 복이 많아도 속히 부하고자 하는 자는 형벌을 면치 못하리라","reference":"잠언 28:20","category":"$undefined"},{"id":"17218","book":"잠언","book_name":"잠언","chapter":28,"verse":21,"text":"사람의 낯을 보아주는 것이 좋지 못하고 한 조각 떡을 인하여 범법하는 것도 그러하니라","reference":"잠언 28:21","category":"$undefined"},{"id":"17219","book":"잠언","book_name":"잠언","chapter":28,"verse":22,"text":"악한 눈이 있는 자는 재물을 얻기에만 급하고 빈궁이 자기에게로 임할 줄은 알지 못하느니라","reference":"잠언 28:22","category":"$undefined"},{"id":"17220","book":"잠언","book_name":"잠언","chapter":28,"verse":23,"text":"사람을 경책하는 자는 혀로 아첨하는 자보다 나중에 더욱 사랑을 받느니라","reference":"잠언 28:23","category":"$undefined"},{"id":"17221","book":"잠언","book_name":"잠언","chapter":28,"verse":24,"text":"부모의 물건을 도적질하고 죄가 아니라 하는 자는 멸망케 하는 자의 동류니라","reference":"잠언 28:24","category":"$undefined"},{"id":"17222","book":"잠언","book_name":"잠언","chapter":28,"verse":25,"text":"마음이 탐하는 자는 다툼을 일으키나 여호와를 의지하는 자는 풍족하게 되느니라","reference":"잠언 28:25","category":"$undefined"},{"id":"17223","book":"잠언","book_name":"잠언","chapter":28,"verse":26,"text":"자기의 마음을 믿는 자는 미련한 자요 지혜롭게 행하는 자는 구원을 얻을 자니라","reference":"잠언 28:26","category":"$undefined"},{"id":"17224","book":"잠언","book_name":"잠언","chapter":28,"verse":27,"text":"가난한 자를 구제하는 자는 궁핍하지 아니 하려니와 못본체 하는 자에게는 저주가 많으리라","reference":"잠언 28:27","category":"$undefined"},{"id":"17225","book":"잠언","book_name":"잠언","chapter":28,"verse":28,"text":"악인이 일어나면 사람이 숨고 그가 멸망하면 의인이 많아지느니라","reference":"잠언 28:28","category":"$undefined"}],"bookSlug":"proverbs"}]
