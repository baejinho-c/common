2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":29,"verses":[{"id":"17226","book":"잠언","book_name":"잠언","chapter":29,"verse":1,"text":"자주 책망을 받으면서도 목이 곧은 사람은 갑자기 패망을 당하고 피하지 못하리라","reference":"잠언 29:1","category":"$undefined"},{"id":"17227","book":"잠언","book_name":"잠언","chapter":29,"verse":2,"text":"의인이 많아지면 백성이 즐거워하고 악인이 권세를 잡으면 백성이 탄식하느니라","reference":"잠언 29:2","category":"$undefined"},{"id":"17228","book":"잠언","book_name":"잠언","chapter":29,"verse":3,"text":"지혜를 사모하는 자는 아비를 즐겁게 하여도 창기를 사귀는 자는 재물을 없이 하느니라","reference":"잠언 29:3","category":"$undefined"},{"id":"17229","book":"잠언","book_name":"잠언","chapter":29,"verse":4,"text":"왕은 공의로 나라를 견고케 하나 뇌물을 억지로 내게 하는 자는 나라를 멸망시키느니라","reference":"잠언 29:4","category":"$undefined"},{"id":"17230","book":"잠언","book_name":"잠언","chapter":29,"verse":5,"text":"이웃에게 아첨하는 것은 그의 발 앞에 그물을 치는 것이니라","reference":"잠언 29:5","category":"$undefined"},{"id":"17231","book":"잠언","book_name":"잠언","chapter":29,"verse":6,"text":"악인의 범죄하는 것은 스스로 올무가 되게 하는 것이나 의인은 노래하고 기뻐하느니라","reference":"잠언 29:6","category":"$undefined"},{"id":"17232","book":"잠언","book_name":"잠언","chapter":29,"verse":7,"text":"의인은 가난한 자의 사정을 알아 주나 악인은 알아 줄 지식이 없느니라","reference":"잠언 29:7","category":"$undefined"},{"id":"17233","book":"잠언","book_name":"잠언","chapter":29,"verse":8,"text":"모만한 자는 성읍을 요란케 하여도 슬기로운 자는 노를 그치게 하느니라","reference":"잠언 29:8","category":"$undefined"},{"id":"17234","book":"잠언","book_name":"잠언","chapter":29,"verse":9,"text":"지혜로운 자와 미련한 자가 다투면 지혜로운 자가 노하든지 웃든지 그 다툼이 그침이 없느니라","reference":"잠언 29:9","category":"$undefined"},{"id":"17235","book":"잠언","book_name":"잠언","chapter":29,"verse":10,"text":"피 흘리기를 좋아하는 자는 온전한 자를 미워하고 정직한 자의 생명을 찾느니라","reference":"잠언 29:10","category":"$undefined"},{"id":"17236","book":"잠언","book_name":"잠언","chapter":29,"verse":11,"text":"어리석은 자는 그 노를 다 드러내어도 지혜로운 자는 그 노를 억제하느니라","reference":"잠언 29:11","category":"$undefined"},{"id":"17237","book":"잠언","book_name":"잠언","chapter":29,"verse":12,"text":"관원이 거짓말을 신청하면 그 하인은 다 악하니라","reference":"잠언 29:12","category":"$undefined"},{"id":"17238","book":"잠언","book_name":"잠언","chapter":29,"verse":13,"text":"가난한 자와 포학한 자가 섞여 살거니와 여호와께서는 그들의 눈에 빛을 주시느니라","reference":"잠언 29:13","category":"$undefined"},{"id":"17239","book":"잠언","book_name":"잠언","chapter":29,"verse":14,"text":"왕이 가난한 자를 성실히 신원하면 그 위가 영원히 견고하리라","reference":"잠언 29:14","category":"$undefined"},{"id":"17240","book":"잠언","book_name":"잠언","chapter":29,"verse":15,"text":"채찍과 꾸지람이 지혜를 주거늘 임의로 하게 버려두면 그 자식은 어미를 욕되게 하느니라","reference":"잠언 29:15","category":"$undefined"},{"id":"17241","book":"잠언","book_name":"잠언","chapter":29,"verse":16,"text":"악인이 많아지면 죄도 많아지나니 의인은 그들의 망함을 보리라","reference":"잠언 29:16","category":"$undefined"},{"id":"17242","book":"잠언","book_name":"잠언","chapter":29,"verse":17,"text":"네 자식을 징계하라 그리하면 그가 너를 평안하게 하겠고 또 네 마음에 기쁨을 주리라","reference":"잠언 29:17","category":"$undefined"},{"id":"17243","book":"잠언","book_name":"잠언","chapter":29,"verse":18,"text":"묵시가 없으면 백성이 방자히 행하거니와 율법을 지키는 자는 복이 있느니라","reference":"잠언 29:18","category":"$undefined"},{"id":"17244","book":"잠언","book_name":"잠언","chapter":29,"verse":19,"text":"종은 말로만 하면 고치지 아니하나니 이는 그가 알고도 청종치 아니함이니라","reference":"잠언 29:19","category":"$undefined"},{"id":"17245","book":"잠언","book_name":"잠언","chapter":29,"verse":20,"text":"네가 언어에 조급한 사람을 보느냐 그보다 미련한 자에게 오히려 바랄 것이 있느니라","reference":"잠언 29:20","category":"$undefined"},{"id":"17246","book":"잠언","book_name":"잠언","chapter":29,"verse":21,"text":"종을 어렸을 때부터 곱게 양육하면 그가 나중에는 자식인 체하리라","reference":"잠언 29:21","category":"$undefined"},{"id":"17247","book":"잠언","book_name":"잠언","chapter":29,"verse":22,"text":"노하는 자는 다툼을 일으키고 분하여 하는 자는 범죄함이 많으니라","reference":"잠언 29:22","category":"$undefined"},{"id":"17248","book":"잠언","book_name":"잠언","chapter":29,"verse":23,"text":"사람이 교만하면 낮아지게 되겠고 마음이 겸손하면 영예를 얻으리라","reference":"잠언 29:23","category":"$undefined"},{"id":"17249","book":"잠언","book_name":"잠언","chapter":29,"verse":24,"text":"도적과 짝하는 자는 자기의 영혼을 미워하는 자라 그는 맹세함을 들어도 직고하지 아니하느니라","reference":"잠언 29:24","category":"$undefined"},{"id":"17250","book":"잠언","book_name":"잠언","chapter":29,"verse":25,"text":"사람을 두려워하면 올무에 걸리게 되거니와 여호와를 의지하는 자는 안전하리라","reference":"잠언 29:25","category":"$undefined"},{"id":"17251","book":"잠언","book_name":"잠언","chapter":29,"verse":26,"text":"주권자에게 은혜를 구하는 자가 많으나 사람의 일의 작정은 여호와께로 말미암느니라","reference":"잠언 29:26","category":"$undefined"},{"id":"17252","book":"잠언","book_name":"잠언","chapter":29,"verse":27,"text":"불의한 자는 의인에게 미움을 받고 정직한 자는 악인에게 미움을 받느니라","reference":"잠언 29:27","category":"$undefined"}],"bookSlug":"proverbs"}]
