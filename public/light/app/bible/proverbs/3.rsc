2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":3,"verses":[{"id":"16457","book":"잠언","book_name":"잠언","chapter":3,"verse":1,"text":"내 아들아 나의 법을 잊어버리지 말고 네 마음으로 나의 명령을 지키라","reference":"잠언 3:1","category":"$undefined"},{"id":"16458","book":"잠언","book_name":"잠언","chapter":3,"verse":2,"text":"그리하면 그것이 너로 장수하여 많은 해를 누리게 하며 평강을 더하게 하리라","reference":"잠언 3:2","category":"$undefined"},{"id":"16459","book":"잠언","book_name":"잠언","chapter":3,"verse":3,"text":"인자와 진리로 네게서 떠나지 않게 하고 그것을 네 목에 매며 네 마음판에 새기라","reference":"잠언 3:3","category":"$undefined"},{"id":"16460","book":"잠언","book_name":"잠언","chapter":3,"verse":4,"text":"그리하면 네가 하나님과 사람 앞에서 은총과 귀중히 여김을 받으리라","reference":"잠언 3:4","category":"$undefined"},{"id":"16461","book":"잠언","book_name":"잠언","chapter":3,"verse":5,"text":"너는 마음을 다하여 여호와를 의뢰하고 네 명철을 의지하지 말라","reference":"잠언 3:5","category":"$undefined"},{"id":"16462","book":"잠언","book_name":"잠언","chapter":3,"verse":6,"text":"너는 범사에 그를 인정하라 ! 그리하면 네 길을 지도하시리라","reference":"잠언 3:6","category":"$undefined"},{"id":"16463","book":"잠언","book_name":"잠언","chapter":3,"verse":7,"text":"스스로 지혜롭게 여기지 말지어다 여호와를 경외하며 악을 떠날지어다","reference":"잠언 3:7","category":"$undefined"},{"id":"16464","book":"잠언","book_name":"잠언","chapter":3,"verse":8,"text":"이것이 네 몸에 양약이 되어 네 골수로 윤택하게 하리라","reference":"잠언 3:8","category":"$undefined"},{"id":"16465","book":"잠언","book_name":"잠언","chapter":3,"verse":9,"text":"네 재물과 네 소산물의 처음 익은 열매로 여호와를 공경하라","reference":"잠언 3:9","category":"$undefined"},{"id":"16466","book":"잠언","book_name":"잠언","chapter":3,"verse":10,"text":"그리하면 네 창고가 가득히 차고 네 즙틀에 새 포도즙이 넘치리라","reference":"잠언 3:10","category":"$undefined"},{"id":"16467","book":"잠언","book_name":"잠언","chapter":3,"verse":11,"text":"내 아들아 여호와의 징계를 경히 여기지 말라 그 꾸지람을 싫어하지 말라","reference":"잠언 3:11","category":"$undefined"},{"id":"16468","book":"잠언","book_name":"잠언","chapter":3,"verse":12,"text":"대저 여호와께서 그 사랑하시는 자를 징계하시기를 마치 아비가 그 기뻐하는 아들을 징계함 같이 하시느니라","reference":"잠언 3:12","category":"$undefined"},{"id":"16469","book":"잠언","book_name":"잠언","chapter":3,"verse":13,"text":"지혜를 얻은 자와 명철을 얻은 자는 복이 있나니","reference":"잠언 3:13","category":"$undefined"},{"id":"16470","book":"잠언","book_name":"잠언","chapter":3,"verse":14,"text":"이는 지혜를 얻는 것이 은을 얻는 것보다 낫고 그 이익이 정금보다 나음이니라","reference":"잠언 3:14","category":"$undefined"},{"id":"16471","book":"잠언","book_name":"잠언","chapter":3,"verse":15,"text":"지혜는 진주보다 귀하니 너의 사모하는 모든 것으로 이에 비교할수 없도다","reference":"잠언 3:15","category":"$undefined"},{"id":"16472","book":"잠언","book_name":"잠언","chapter":3,"verse":16,"text":"그 우편 손에는 장수가 있고, 그 좌편 손에는 부귀가 있나니","reference":"잠언 3:16","category":"$undefined"},{"id":"16473","book":"잠언","book_name":"잠언","chapter":3,"verse":17,"text":"그 길은 즐거운 길이요 그 첩경은 다 평강이니라","reference":"잠언 3:17","category":"$undefined"},{"id":"16474","book":"잠언","book_name":"잠언","chapter":3,"verse":18,"text":"지혜는 그 얻은 자에게 생명나무라 지혜를 가진 자는 복되도다","reference":"잠언 3:18","category":"$undefined"},{"id":"16475","book":"잠언","book_name":"잠언","chapter":3,"verse":19,"text":"여호와께서는 지혜로 땅을 세우셨으며 명철로 하늘을 굳게 펴셨고","reference":"잠언 3:19","category":"$undefined"},{"id":"16476","book":"잠언","book_name":"잠언","chapter":3,"verse":20,"text":"그 지식으로 해양이 갈라지게 하셨으며 공중에서 이슬이 내리게 하셨느니라","reference":"잠언 3:20","category":"$undefined"},{"id":"16477","book":"잠언","book_name":"잠언","chapter":3,"verse":21,"text":"내 아들아 완전한 지혜와 근신을 지키고 이것들로 네 눈 앞에서 떠나지 않게 하라","reference":"잠언 3:21","category":"$undefined"},{"id":"16478","book":"잠언","book_name":"잠언","chapter":3,"verse":22,"text":"그리하면 그것이 네 영혼의 생명이 되며 네 목에 장식이 되리니","reference":"잠언 3:22","category":"$undefined"},{"id":"16479","book":"잠언","book_name":"잠언","chapter":3,"verse":23,"text":"네가 네 길을 안연히 행하겠고 네 발이 거치지 아니하겠으며","reference":"잠언 3:23","category":"$undefined"},{"id":"16480","book":"잠언","book_name":"잠언","chapter":3,"verse":24,"text":"네가 누울 때에 두려워하지 아니하겠고 네가 누운즉 네 잠이 달리로다","reference":"잠언 3:24","category":"$undefined"},{"id":"16481","book":"잠언","book_name":"잠언","chapter":3,"verse":25,"text":"너는 창졸간의 두려움이나 악인의 멸망이 임할 때나 두려워하지말라","reference":"잠언 3:25","category":"$undefined"},{"id":"16482","book":"잠언","book_name":"잠언","chapter":3,"verse":26,"text":"대저 여호와는 너의 의지할 자이시라 네 발을 지켜 걸리지 않게 하시리라","reference":"잠언 3:26","category":"$undefined"},{"id":"16483","book":"잠언","book_name":"잠언","chapter":3,"verse":27,"text":"네 손이 선을 베풀 힘이 있거든 마땅히 받을 자에게 베풀기를 아끼지 말며","reference":"잠언 3:27","category":"$undefined"},{"id":"16484","book":"잠언","book_name":"잠언","chapter":3,"verse":28,"text":"네게 있거든 이웃에게 이르기를 갔다가 다시 오라 내일 주겠노라 하지 말며","reference":"잠언 3:28","category":"$undefined"},{"id":"16485","book":"잠언","book_name":"잠언","chapter":3,"verse":29,"text":"네 이웃이 네 곁에서 안연히 살거든 그를 모해하지 말며","reference":"잠언 3:29","category":"$undefined"},{"id":"16486","book":"잠언","book_name":"잠언","chapter":3,"verse":30,"text":"사람이 네게 악을 행하지 아니하였거든 까닭없이 더불어 다투지말며","reference":"잠언 3:30","category":"$undefined"},{"id":"16487","book":"잠언","book_name":"잠언","chapter":3,"verse":31,"text":"포학한 자를 부러워하지 말며 그 아무 행위든지 좇지 말라","reference":"잠언 3:31","category":"$undefined"},{"id":"16488","book":"잠언","book_name":"잠언","chapter":3,"verse":32,"text":"대저 패역한 자는 여호와의 미워하심을 입거니와 정직한 자에게는 그의 교통하심이 있으며","reference":"잠언 3:32","category":"$undefined"},{"id":"16489","book":"잠언","book_name":"잠언","chapter":3,"verse":33,"text":"악인의 집에는 여호와의 저주가 있거니와 의인의 집에는 복이 있느니라","reference":"잠언 3:33","category":"$undefined"},{"id":"16490","book":"잠언","book_name":"잠언","chapter":3,"verse":34,"text":"진실로 그는 거만한 자를 비웃으시며 겸손한 자에게 은혜를 베푸시나니","reference":"잠언 3:34","category":"$undefined"},{"id":"16491","book":"잠언","book_name":"잠언","chapter":3,"verse":35,"text":"지혜로운 자는 영광을 기업으로 받거니와 미련한 자의 현달함은 욕이 되느니라","reference":"잠언 3:35","category":"$undefined"}],"bookSlug":"proverbs"}]
