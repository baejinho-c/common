11:I[1873,["9203","static/chunks/9203-996b4ec42a4109b3.js","2972","static/chunks/2972-9bb10279b4b15167.js","5920","static/chunks/5920-1440aceac5f52f98.js","6678","static/chunks/6678-c14eef17aa65bcf8.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-fccd9fb1d2a90f99.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":30,"verses":[{"id":"17253","book":"잠언","book_name":"잠언","chapter":30,"verse":1,"text":"이 말씀은 야게의 아들 아굴의 잠언이니 그가 이디엘과 우갈에게 이른 것이니라","reference":"잠언 30:1","category":"$undefined"},{"id":"17254","book":"잠언","book_name":"잠언","chapter":30,"verse":2,"text":"나는 다른 사람에게 비하면 짐승이라 내게는 사람의 총명이 있지아니하니라","reference":"잠언 30:2","category":"$undefined"},{"id":"17255","book":"잠언","book_name":"잠언","chapter":30,"verse":3,"text":"나는 지혜를 배우지 못하였고 또 거룩하신 자를 아는 지식이 없거니와","reference":"잠언 30:3","category":"$undefined"},{"id":"17256","book":"잠언","book_name":"잠언","chapter":30,"verse":4,"text":"하늘에 올라갔다가 내려온 자가 누구인지, 바람을 그 장중에 모은 자가 누구인지, 물을 옷에 싼자가 누구인지, 땅의 모든 끝을 정한 자가 누구인지, 그 이름이 무엇인지, 그 아들의 이름이 무엇인지 너는 아느냐 ?","reference":"잠언 30:4","category":"$undefined"},{"id":"17257","book":"잠언","book_name":"잠언","chapter":30,"verse":5,"text":"하나님의 말씀은 다 순전하며 하나님은 그를 의지하는 자의 방패시니라","reference":"잠언 30:5","category":"$undefined"},{"id":"17258","book":"잠언","book_name":"잠언","chapter":30,"verse":6,"text":"너는 그 말씀에 더하지 말라 그가 너를 책망하시겠고 너는 거짓말 하는 자가 될까 두려우니라","reference":"잠언 30:6","category":"$undefined"},{"id":"17259","book":"잠언","book_name":"잠언","chapter":30,"verse":7,"text":"내가 두 가지 일을 주께 구하였사오니 나의 죽기 전에 주시옵소서","reference":"잠언 30:7","category":"$undefined"},{"id":"17260","book":"잠언","book_name":"잠언","chapter":30,"verse":8,"text":"곧 허탄과 거짓말을 내게서 멀리 하옵시며 나로 가난하게도 마옵시고 부하게도 마옵시고 오직 필요한 양식으로 내게 먹이시옵소서","reference":"잠언 30:8","category":"$undefined"},{"id":"17261","book":"잠언","book_name":"잠언","chapter":30,"verse":9,"text":"혹 내가 배불러서 하나님을 모른다 여호와가 누구냐 할까 하오며 혹 내가 가난하여 도적질하고 내 하나님의 이름을 욕되게 할까 두려워함이니이다","reference":"잠언 30:9","category":"$undefined"},{"id":"17262","book":"잠언","book_name":"잠언","chapter":30,"verse":10,"text":"너는 종을 그 상전에게 훼방하지 말라 그가 너를 저주하겠고 너는 죄책을 당할까 두려우니라","reference":"잠언 30:10","category":"$undefined"},{"id":"17263","book":"잠언","book_name":"잠언","chapter":30,"verse":11,"text":"아비를 저주하며 어미를 축복하지 아니하는 무리가 있느니라","reference":"잠언 30:11","category":"$undefined"},{"id":"17264","book":"잠언","book_name":"잠언","chapter":30,"verse":12,"text":"스스로 깨끗한 자로 여기면서 오히려 그 더러운 것을 씻지 아니하는 무리가 있느니라","reference":"잠언 30:12","category":"$undefined"},{"id":"17265","book":"잠언","book_name":"잠언","chapter":30,"verse":13,"text":"눈이 심히 높으며 그 눈꺼풀이 높이 들린 무리가 있느니라","reference":"잠언 30:13","category":"$undefined"},{"id":"17266","book":"잠언","book_name":"잠언","chapter":30,"verse":14,"text":"앞니는 장검 같고 어금니는 군도 같아서 가난한 자를 땅에서 삼키며 궁핍한 자를 사람 중에서 삼키는 무리가 있느니라","reference":"잠언 30:14","category":"$undefined"},{"id":"17267","book":"잠언","book_name":"잠언","chapter":30,"verse":15,"text":"거머리에게는 두 딸이 있어 다고, 다고 하느니라 족한 줄을 알지 못하여 족하다 하지 아니하는 것 서넛이 있나니","reference":"잠언 30:15","category":"$undefined"},{"id":"17268","book":"잠언","book_name":"잠언","chapter":30,"verse":16,"text":"곧 음부와 아이 배지 못하는 태와 물로 채울 수 없는 땅과 족하다 하지 아니하는 불이니라","reference":"잠언 30:16","category":"$undefined"},{"id":"17269","book":"잠언","book_name":"잠언","chapter":30,"verse":17,"text":"아비를 조롱하며 어미 순종하기를 싫어하는 자의 눈은 골짜기의 까마귀에게 쪼이고 독수리 새끼에게 먹히리라","reference":"잠언 30:17","category":"$undefined"},{"id":"17270","book":"잠언","book_name":"잠언","chapter":30,"verse":18,"text":"내가 심히 기이히 여기고도 깨닫지 못하는 것 서넛이 있나니","reference":"잠언 30:18","category":"$undefined"},{"id":"17271","book":"잠언","book_name":"잠언","chapter":30,"verse":19,"text":"곧 공중에 날아 다니는 독수리의 자취와 바다로 지나다니는 배의 자취와 남자가 여자와 함께 한 자취며","reference":"잠언 30:19","category":"$undefined"},{"id":"17272","book":"잠언","book_name":"잠언","chapter":30,"verse":20,"text":"음녀의 자취도 그러하니라 그가 먹고 그 입을 씻음 같이 말하기를 내가 악을 행치 아니하였다 하느니라","reference":"잠언 30:20","category":"$undefined"},{"id":"17273","book":"잠언","book_name":"잠언","chapter":30,"verse":21,"text":"세상을 진동시키며 세상으로 견딜 수 없게 하는 것 서넛이 있나니","reference":"잠언 30:21","category":"$undefined"},{"id":"17274","book":"잠언","book_name":"잠언","chapter":30,"verse":22,"text":"곧 종이 임금된 것과 미련한 자가 배부른 것과","reference":"잠언 30:22","category":"$undefined"},{"id":"17275","book":"잠언","book_name":"잠언","chapter":30,"verse":23,"text":"꺼림을 받는 계집이 시집간 것과 계집 종이 주모를 이은 것이니라","reference":"잠언 30:23","category":"$undefined"},{"id":"17276","book":"잠언","book_name":"잠언","chapter":30,"verse":24,"text":"땅에 작고도 가장 지혜로운 것 넷이 있나니","reference":"잠언 30:24","category":"$undefined"},{"id":"17277","book":"잠언","book_name":"잠언","chapter":30,"verse":25,"text":"곧 힘이 없는 종류로되 먹을 것을 여름에 예비하는 개미와","reference":"잠언 30:25","category":"$undefined"},{"id":"17278","book":"잠언","book_name":"잠언","chapter":30,"verse":26,"text":"약한 종류로되 집을 바위 사이에 짓는 사반과","reference":"잠언 30:26","category":"$undefined"},{"id":"17279","book":"잠언","book_name":"잠언","chapter":30,"verse":27,"text":"임군이 없으되 다 떼를 지어 나아가는 메뚜기와","reference":"잠언 30:27","category":"$undefined"},{"id":"17280","book":"잠언","book_name":"잠언","chapter":30,"verse":28,"text":"손에 잡힐만하여도 왕궁에 있는 도마뱀이니라","reference":"잠언 30:28","category":"$undefined"},{"id":"17281","book":"잠언","book_name":"잠언","chapter":30,"verse":29,"text":"잘 걸으며 위풍 있게 다니는 것 서넛이 있나니","reference":"잠언 30:29","category":"$undefined"},{"id":"17282","book":"잠언","book_name":"잠언","chapter":30,"verse":30,"text":"곧 짐승 중에 가장 강하여 아무 짐승 앞에서도 물러가지 아니하는 사자와","reference":"잠언 30:30","category":"$undefined"},{"id":"17283","book":"잠언","book_name":"잠언","chapter":30,"verse":31,"text":"사냥개와 수염소와 및 당할 수 없는 왕이니라","reference":"잠언 30:31","category":"$undefined"},{"id":"17284","book":"잠언","book_name":"잠언","chapter":30,"verse":32,"text":"사냥개와 수염소와 및 당할 수 없는 왕이니라","reference":"잠언 30:32","category":"$undefined"},{"id":"17285","book":"잠언","book_name":"잠언","chapter":30,"verse":33,"text":"대저 젖을 저으면 뻐터가 되고 코를 비틀면 피가 나는 것 같이 노를 격동하면 다툼이 남이니라","reference":"잠언 30:33","category":"$undefined"}],"bookSlug":"proverbs"}]
