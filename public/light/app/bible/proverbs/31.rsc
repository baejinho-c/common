11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":31,"verses":[{"id":"17286","book":"잠언","book_name":"잠언","chapter":31,"verse":1,"text":"르무엘왕의 말씀한바 곧 그 어머니가 그를 훈계한 잠언이라","reference":"잠언 31:1","category":"$undefined"},{"id":"17287","book":"잠언","book_name":"잠언","chapter":31,"verse":2,"text":"내 아들아 내가 무엇을 말할꼬 내 태에서 난 아들아 내가 무엇을 말할꼬 서원대로 얻은 아들아 내가 무엇을 말할꼬","reference":"잠언 31:2","category":"$undefined"},{"id":"17288","book":"잠언","book_name":"잠언","chapter":31,"verse":3,"text":"네 힘을 여자들에게 쓰지 말며 왕들을 멸망시키는 일을 행치 말지어다","reference":"잠언 31:3","category":"$undefined"},{"id":"17289","book":"잠언","book_name":"잠언","chapter":31,"verse":4,"text":"르무엘아 포도주를 마시는 것이 왕에게 마땅치 아니하고 왕에게 마땅치 아니하며 독주를 찾는 것이 주권자에게 마땅치 않도다","reference":"잠언 31:4","category":"$undefined"},{"id":"17290","book":"잠언","book_name":"잠언","chapter":31,"verse":5,"text":"술을 마시다가 법을 잊어버리고 모든 간곤한 백성에게 공의를 굽게 할까 두려우니라","reference":"잠언 31:5","category":"$undefined"},{"id":"17291","book":"잠언","book_name":"잠언","chapter":31,"verse":6,"text":"독주는 죽게된 자에게, 포도주는 마음에 근심하는 자에게 줄지어다","reference":"잠언 31:6","category":"$undefined"},{"id":"17292","book":"잠언","book_name":"잠언","chapter":31,"verse":7,"text":"그는 마시고 빈궁한 것을 잊어버리겠고 다시 그 고통을 기억지 아니하리라","reference":"잠언 31:7","category":"$undefined"},{"id":"17293","book":"잠언","book_name":"잠언","chapter":31,"verse":8,"text":"너는 벙어리와 고독한 자의 송사를 위하여 입을 열지니라","reference":"잠언 31:8","category":"$undefined"},{"id":"17294","book":"잠언","book_name":"잠언","chapter":31,"verse":9,"text":"너는 입을 열어 공의로 재판하여 간곤한 자와 궁핍한 자를 신원할지니라","reference":"잠언 31:9","category":"$undefined"},{"id":"17295","book":"잠언","book_name":"잠언","chapter":31,"verse":10,"text":"누가 현숙한 여인을 찾아 얻겠느냐 그 값은 진주보다 더 하니라","reference":"잠언 31:10","category":"$undefined"},{"id":"17296","book":"잠언","book_name":"잠언","chapter":31,"verse":11,"text":"그런 자의 남편의 마음은 그를 믿나니 산업이 핍절치 아니하겠으며","reference":"잠언 31:11","category":"$undefined"},{"id":"17297","book":"잠언","book_name":"잠언","chapter":31,"verse":12,"text":"그런 자는 살아 있는 동안에 그 남편에게 선을 행하고 악을 행치아니하느니라","reference":"잠언 31:12","category":"$undefined"},{"id":"17298","book":"잠언","book_name":"잠언","chapter":31,"verse":13,"text":"그는 양털과 삼을 구하여 부지런히 손으로 일하며","reference":"잠언 31:13","category":"$undefined"},{"id":"17299","book":"잠언","book_name":"잠언","chapter":31,"verse":14,"text":"상고의 배와 같아서 먼 데서 양식을 가져오며","reference":"잠언 31:14","category":"$undefined"},{"id":"17300","book":"잠언","book_name":"잠언","chapter":31,"verse":15,"text":"밤이 새기 전에 일어나서 그 집 사람에게 식물을 나눠주며 여종에게 일을 정하여 맡기며","reference":"잠언 31:15","category":"$undefined"},{"id":"17301","book":"잠언","book_name":"잠언","chapter":31,"verse":16,"text":"밭을 간품하여 사며 그 손으로 번 것을 가지고 포도원을 심으며","reference":"잠언 31:16","category":"$undefined"},{"id":"17302","book":"잠언","book_name":"잠언","chapter":31,"verse":17,"text":"힘으로 허리를 묶으며 그 팔을 강하게 하며","reference":"잠언 31:17","category":"$undefined"},{"id":"17303","book":"잠언","book_name":"잠언","chapter":31,"verse":18,"text":"자기의 무역하는 것이 이로운 줄을 깨닫고 밤에 등불을 끄지 아니하고","reference":"잠언 31:18","category":"$undefined"},{"id":"17304","book":"잠언","book_name":"잠언","chapter":31,"verse":19,"text":"손으로 솜뭉치를 들고 손가락으로 가락을 잡으며","reference":"잠언 31:19","category":"$undefined"},{"id":"17305","book":"잠언","book_name":"잠언","chapter":31,"verse":20,"text":"그는 간곤한 자에게 손을 펴며 궁핍한 자를 위하여 손을 내밀며","reference":"잠언 31:20","category":"$undefined"},{"id":"17306","book":"잠언","book_name":"잠언","chapter":31,"verse":21,"text":"그 집 사람들은 다 홍색 옷을 입었으므로 눈이 와도 그는 집 사람을 위하여 두려워하지 아니하며","reference":"잠언 31:21","category":"$undefined"},{"id":"17307","book":"잠언","book_name":"잠언","chapter":31,"verse":22,"text":"그는 자기를 위하여 아름다운 방석을 지으며 세마포와 자색 옷을 입으며","reference":"잠언 31:22","category":"$undefined"},{"id":"17308","book":"잠언","book_name":"잠언","chapter":31,"verse":23,"text":"그 남편은 그 땅의 장로로 더불어 성문에 앉으며 사람의 아는 바가 되며","reference":"잠언 31:23","category":"$undefined"},{"id":"17309","book":"잠언","book_name":"잠언","chapter":31,"verse":24,"text":"그는 베로 옷을 지어 팔며 띠를 만들어 상고에게 맡기며","reference":"잠언 31:24","category":"$undefined"},{"id":"17310","book":"잠언","book_name":"잠언","chapter":31,"verse":25,"text":"능력과 존귀로 옷을 삼고 후일을 웃으며","reference":"잠언 31:25","category":"$undefined"},{"id":"17311","book":"잠언","book_name":"잠언","chapter":31,"verse":26,"text":"입을 열어 지혜를 베풀며 그 혀로 인애의 법을 말하며","reference":"잠언 31:26","category":"$undefined"},{"id":"17312","book":"잠언","book_name":"잠언","chapter":31,"verse":27,"text":"그 집안 일을 보살피고 게을리 얻은 양식을 먹지 아니하나니","reference":"잠언 31:27","category":"$undefined"},{"id":"17313","book":"잠언","book_name":"잠언","chapter":31,"verse":28,"text":"그 자식들은 일어나 사례하며 그 남편은 칭찬하기를","reference":"잠언 31:28","category":"$undefined"},{"id":"17314","book":"잠언","book_name":"잠언","chapter":31,"verse":29,"text":"덕행 있는 여자가 많으나 그대는 여러 여자보다 뛰어난다 하느니라","reference":"잠언 31:29","category":"$undefined"},{"id":"17315","book":"잠언","book_name":"잠언","chapter":31,"verse":30,"text":"고운 것도 거짓되고 아름다운 것도 헛되나 오직 여호와를 경외하는 여자는 칭찬을 받을 것이라","reference":"잠언 31:30","category":"$undefined"},{"id":"17316","book":"잠언","book_name":"잠언","chapter":31,"verse":31,"text":"그 손의 열매가 그에게로 돌아갈 것이요 그 행한 일을 인하여 성문에서 칭찬을 받으리라","reference":"잠언 31:31","category":"$undefined"}],"bookSlug":"proverbs"}]
