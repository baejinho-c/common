2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":4,"verses":[{"id":"16492","book":"잠언","book_name":"잠언","chapter":4,"verse":1,"text":"아들들아 아비의 훈계를 들으며 명철을 얻기에 주의하라","reference":"잠언 4:1","category":"$undefined"},{"id":"16493","book":"잠언","book_name":"잠언","chapter":4,"verse":2,"text":"내가 선한 도리를 너희에게 전하노니 내 법을 떠나지 말라","reference":"잠언 4:2","category":"$undefined"},{"id":"16494","book":"잠언","book_name":"잠언","chapter":4,"verse":3,"text":"나도 내 아버지에게 아들이었었으며 내 어머니 보기에 유약한 외아들이었었노라","reference":"잠언 4:3","category":"$undefined"},{"id":"16495","book":"잠언","book_name":"잠언","chapter":4,"verse":4,"text":"아버지가 내게 가르쳐 이르기를 내 말을 네 마음에 두라 내 명령을 지키라 그리하면 살리라","reference":"잠언 4:4","category":"$undefined"},{"id":"16496","book":"잠언","book_name":"잠언","chapter":4,"verse":5,"text":"지혜를 얻으며 명철을 얻으라 내 입의 말을 잊지 말며 어기지 말라","reference":"잠언 4:5","category":"$undefined"},{"id":"16497","book":"잠언","book_name":"잠언","chapter":4,"verse":6,"text":"지혜를 버리지 말라 그가 너를 보호하리라 그를 사랑하라 그가 너를 지키리라","reference":"잠언 4:6","category":"$undefined"},{"id":"16498","book":"잠언","book_name":"잠언","chapter":4,"verse":7,"text":"지혜가 제일이니 지혜를 얻으라 ! 무릇 너의 얻은 것을 가져 명철을 얻을지니라","reference":"잠언 4:7","category":"$undefined"},{"id":"16499","book":"잠언","book_name":"잠언","chapter":4,"verse":8,"text":"그를 높이라 그리하면 그가 너를 높이 들리라 만일 그를 품으면 그가 너를 영화롭게 하리라","reference":"잠언 4:8","category":"$undefined"},{"id":"16500","book":"잠언","book_name":"잠언","chapter":4,"verse":9,"text":"그가 아름다운 관을 네 머리에 두겠고 영화로운 면류관을 네게 주리라 하였느니라","reference":"잠언 4:9","category":"$undefined"},{"id":"16501","book":"잠언","book_name":"잠언","chapter":4,"verse":10,"text":"내 아들아 들으라 내 말을 받으라 ! 그리하면 네 생명의 해가 길리라","reference":"잠언 4:10","category":"$undefined"},{"id":"16502","book":"잠언","book_name":"잠언","chapter":4,"verse":11,"text":"내가 지혜로운 길로 네게 가르쳤으며 정직한 첩경으로 너를 인도하였은즉","reference":"잠언 4:11","category":"$undefined"},{"id":"16503","book":"잠언","book_name":"잠언","chapter":4,"verse":12,"text":"다닐 때에 네 걸음이 곤란하지 아니하겠고 달려갈 때에 실족하지 아니하리라","reference":"잠언 4:12","category":"$undefined"},{"id":"16504","book":"잠언","book_name":"잠언","chapter":4,"verse":13,"text":"훈계를 굳게 잡아 놓치지 말고 지키라 이것이 네 생명이니라","reference":"잠언 4:13","category":"$undefined"},{"id":"16505","book":"잠언","book_name":"잠언","chapter":4,"verse":14,"text":"사특한 자의 첩경에 들어가지 말며 악인의 길로 다니지 말지어다","reference":"잠언 4:14","category":"$undefined"},{"id":"16506","book":"잠언","book_name":"잠언","chapter":4,"verse":15,"text":"그 길을 피하고 지나가지 말며 돌이켜 떠나갈지어다","reference":"잠언 4:15","category":"$undefined"},{"id":"16507","book":"잠언","book_name":"잠언","chapter":4,"verse":16,"text":"그들은 악을 행하지 못하면 자지 못하며 사람을 넘어뜨리지 못하면 잠이 오지 아니하며","reference":"잠언 4:16","category":"$undefined"},{"id":"16508","book":"잠언","book_name":"잠언","chapter":4,"verse":17,"text":"불의의 떡을 먹으며 강포의 술을 마심이니라","reference":"잠언 4:17","category":"$undefined"},{"id":"16509","book":"잠언","book_name":"잠언","chapter":4,"verse":18,"text":"의인의 길은 돋는 햇볕 같아서 점점 빛나서 원만한 광명에 이르거니와","reference":"잠언 4:18","category":"$undefined"},{"id":"16510","book":"잠언","book_name":"잠언","chapter":4,"verse":19,"text":"악인의 길은 어둠 같아서 그가 거쳐 넘어져도 그것이 무엇인지 깨닫지 못하느니라","reference":"잠언 4:19","category":"$undefined"},{"id":"16511","book":"잠언","book_name":"잠언","chapter":4,"verse":20,"text":"내 아들아 내 말에 주의하며 나의 이르는 것에 네 귀를 기울이라","reference":"잠언 4:20","category":"$undefined"},{"id":"16512","book":"잠언","book_name":"잠언","chapter":4,"verse":21,"text":"그것을 네 눈에서 떠나게 말며 네 마음 속에 지키라","reference":"잠언 4:21","category":"$undefined"},{"id":"16513","book":"잠언","book_name":"잠언","chapter":4,"verse":22,"text":"그것은 얻는 자에게 생명이 되며 그 온 육체의 건강이 됨이니라","reference":"잠언 4:22","category":"$undefined"},{"id":"16514","book":"잠언","book_name":"잠언","chapter":4,"verse":23,"text":"무릇 지킬만한 것보다 더욱 네 마음을 지키라 생명의 근원이 이에서 남이니라","reference":"잠언 4:23","category":"$undefined"},{"id":"16515","book":"잠언","book_name":"잠언","chapter":4,"verse":24,"text":"궤휼을 네 입에서 버리며 사곡을 네 입술에서 멀리하라","reference":"잠언 4:24","category":"$undefined"},{"id":"16516","book":"잠언","book_name":"잠언","chapter":4,"verse":25,"text":"네 눈은 바로 보며 네 눈꺼풀은 네 앞을 곧게 살펴","reference":"잠언 4:25","category":"$undefined"},{"id":"16517","book":"잠언","book_name":"잠언","chapter":4,"verse":26,"text":"네 발의 행할 첩경을 평탄케 하며 네 모든 길을 든든히 하라","reference":"잠언 4:26","category":"$undefined"},{"id":"16518","book":"잠언","book_name":"잠언","chapter":4,"verse":27,"text":"우편으로나 좌편으로나 치우치지 말고 네 발을 악에서 떠나게 하라","reference":"잠언 4:27","category":"$undefined"}],"bookSlug":"proverbs"}]
