2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":5,"verses":[{"id":"16519","book":"잠언","book_name":"잠언","chapter":5,"verse":1,"text":"내 아들아 내 지혜에 주의하며 내 명철에 네 귀를 기울여서","reference":"잠언 5:1","category":"$undefined"},{"id":"16520","book":"잠언","book_name":"잠언","chapter":5,"verse":2,"text":"근신을 지키며 네 입술로 지식을 지키도록 하라","reference":"잠언 5:2","category":"$undefined"},{"id":"16521","book":"잠언","book_name":"잠언","chapter":5,"verse":3,"text":"대저 음녀의 입술은 꿀을 떨어뜨리며 그 입은 기름보다 미끄러우나","reference":"잠언 5:3","category":"$undefined"},{"id":"16522","book":"잠언","book_name":"잠언","chapter":5,"verse":4,"text":"나중은 쑥 같이 쓰고 두 날 가진 칼같이 날카로우며","reference":"잠언 5:4","category":"$undefined"},{"id":"16523","book":"잠언","book_name":"잠언","chapter":5,"verse":5,"text":"그 발은 사지로 내려가며 그 걸음은 음부로 나아가나니","reference":"잠언 5:5","category":"$undefined"},{"id":"16524","book":"잠언","book_name":"잠언","chapter":5,"verse":6,"text":"그는 생명의 평탄한 길을 찾지 못하며 자기 길이 든든치 못하여 그것을 깨닫지 못하느니라","reference":"잠언 5:6","category":"$undefined"},{"id":"16525","book":"잠언","book_name":"잠언","chapter":5,"verse":7,"text":"그런즉 아들들아 나를 들으며 내 입의 말을 버리지 말고","reference":"잠언 5:7","category":"$undefined"},{"id":"16526","book":"잠언","book_name":"잠언","chapter":5,"verse":8,"text":"네 길을 그에게서 멀리하라 그 집 문에도 가까이 가지 말라","reference":"잠언 5:8","category":"$undefined"},{"id":"16527","book":"잠언","book_name":"잠언","chapter":5,"verse":9,"text":"두렵건대 네 존영이 남에게 잃어버리게 되며 네 수한이 잔포자에게 빼앗기게 될까 하노라","reference":"잠언 5:9","category":"$undefined"},{"id":"16528","book":"잠언","book_name":"잠언","chapter":5,"verse":10,"text":"두렵건대 타인이 네 재물로 충족하게 되며 네 수고한 것이 외인의 집에 있게 될까 하노라","reference":"잠언 5:10","category":"$undefined"},{"id":"16529","book":"잠언","book_name":"잠언","chapter":5,"verse":11,"text":"두렵건대 마지막에 이르러 네 몸 네 육체가 쇠패할 때에 네가 한탄하여","reference":"잠언 5:11","category":"$undefined"},{"id":"16530","book":"잠언","book_name":"잠언","chapter":5,"verse":12,"text":"말하기를 내가 어찌하여 훈계를 싫어하며 내 마음이 꾸지람을 가벼이 여기고","reference":"잠언 5:12","category":"$undefined"},{"id":"16531","book":"잠언","book_name":"잠언","chapter":5,"verse":13,"text":"내 선생의 목소리를 청종치 아니하며 나를 가르치는 이에게 귀를 기울이지 아니하였던고","reference":"잠언 5:13","category":"$undefined"},{"id":"16532","book":"잠언","book_name":"잠언","chapter":5,"verse":14,"text":"많은 무리들이 모인 중에서 모든 악에 거의 빠지게 되었었노라 하게 될까 하노라","reference":"잠언 5:14","category":"$undefined"},{"id":"16533","book":"잠언","book_name":"잠언","chapter":5,"verse":15,"text":"너는 네 우물에서 물을 마시며 네 샘에서 흐르는 물을 마시라","reference":"잠언 5:15","category":"$undefined"},{"id":"16534","book":"잠언","book_name":"잠언","chapter":5,"verse":16,"text":"어찌하여 네 샘물을 집 밖으로 넘치게 하겠으며 네 도랑물을 거리로 흘러가게 하겠느냐","reference":"잠언 5:16","category":"$undefined"},{"id":"16535","book":"잠언","book_name":"잠언","chapter":5,"verse":17,"text":"그 물로 네게만 있게 하고 타인으로 더불어 그것을 나누지 말라","reference":"잠언 5:17","category":"$undefined"},{"id":"16536","book":"잠언","book_name":"잠언","chapter":5,"verse":18,"text":"네 샘으로 복되게 하라 ! 네가 젊어서 취한 아내를 즐거워하라","reference":"잠언 5:18","category":"$undefined"},{"id":"16537","book":"잠언","book_name":"잠언","chapter":5,"verse":19,"text":"그는 사랑스러운 암사슴 같고 아름다운 암노루 같으니 너는 그 품을 항상 족하게 여기며 그 사랑을 항상 연모하라","reference":"잠언 5:19","category":"$undefined"},{"id":"16538","book":"잠언","book_name":"잠언","chapter":5,"verse":20,"text":"내 아들아 어찌하여 음녀를 연모하겠으며 어찌하여 이방 계집의 가슴을 안겠느냐","reference":"잠언 5:20","category":"$undefined"},{"id":"16539","book":"잠언","book_name":"잠언","chapter":5,"verse":21,"text":"대저 사람의 길은 여호와의 눈 앞에 있나니 그가 그 모든 길을 평탄케 하시느니라","reference":"잠언 5:21","category":"$undefined"},{"id":"16540","book":"잠언","book_name":"잠언","chapter":5,"verse":22,"text":"악인은 자기의 악에 걸리며 그 죄의 줄에 매이나니","reference":"잠언 5:22","category":"$undefined"},{"id":"16541","book":"잠언","book_name":"잠언","chapter":5,"verse":23,"text":"그는 훈계를 받지 아니함을 인하여 죽겠고 미련함이 많음을 인하여 혼미하게 되느니라","reference":"잠언 5:23","category":"$undefined"}],"bookSlug":"proverbs"}]
