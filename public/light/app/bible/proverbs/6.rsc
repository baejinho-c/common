11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":6,"verses":[{"id":"16542","book":"잠언","book_name":"잠언","chapter":6,"verse":1,"text":"내 아들아 네가 만일 이웃을 위하여 담보하며 타인을 위하여 보증하였으면","reference":"잠언 6:1","category":"$undefined"},{"id":"16543","book":"잠언","book_name":"잠언","chapter":6,"verse":2,"text":"네 입의 말로 네가 얽혔으며 네 입의 말로 인하여 잡히게 되었느니라","reference":"잠언 6:2","category":"$undefined"},{"id":"16544","book":"잠언","book_name":"잠언","chapter":6,"verse":3,"text":"내 아들아 네가 네 이웃의 손에 빠졌은즉 이같이 하라 너는 곧 가서 겸손히 네 이웃에게 간구하여 스스로 구원하되","reference":"잠언 6:3","category":"$undefined"},{"id":"16545","book":"잠언","book_name":"잠언","chapter":6,"verse":4,"text":"네 눈으로 잠들게 하지 말며 눈꺼풀로 감기게 하지 말고","reference":"잠언 6:4","category":"$undefined"},{"id":"16546","book":"잠언","book_name":"잠언","chapter":6,"verse":5,"text":"노루가 사냥군의 손에서 벗어나는 것 같이 새가 그물 치는 자의 손에서 벗어나는 것 같이 스스로 구원하라","reference":"잠언 6:5","category":"$undefined"},{"id":"16547","book":"잠언","book_name":"잠언","chapter":6,"verse":6,"text":"게으른 자여 개미에게로 가서 그 하는 것을 보고 지혜를 얻으라","reference":"잠언 6:6","category":"$undefined"},{"id":"16548","book":"잠언","book_name":"잠언","chapter":6,"verse":7,"text":"개미는 두령도 없고 간역자도 없고 주권자도 없으되","reference":"잠언 6:7","category":"$undefined"},{"id":"16549","book":"잠언","book_name":"잠언","chapter":6,"verse":8,"text":"먹을 것을 여름 동안에 예비하며 추수 때에 양식을 모으느니라","reference":"잠언 6:8","category":"$undefined"},{"id":"16550","book":"잠언","book_name":"잠언","chapter":6,"verse":9,"text":"게으른 자여 네가 어느 때까지 눕겠느냐 ? 네가 어느 때에 잠이 깨어 일어나겠느나 ?","reference":"잠언 6:9","category":"$undefined"},{"id":"16551","book":"잠언","book_name":"잠언","chapter":6,"verse":10,"text":"좀더 자자, 좀더 졸자, 손을 모으고 좀더 눕자 하면","reference":"잠언 6:10","category":"$undefined"},{"id":"16552","book":"잠언","book_name":"잠언","chapter":6,"verse":11,"text":"네 빈궁이 강도 같이 오며 네 곤핍이 군사 같이 이르리라","reference":"잠언 6:11","category":"$undefined"},{"id":"16553","book":"잠언","book_name":"잠언","chapter":6,"verse":12,"text":"불량하고 악한 자는 그 행동에 궤휼한 입을 벌리며","reference":"잠언 6:12","category":"$undefined"},{"id":"16554","book":"잠언","book_name":"잠언","chapter":6,"verse":13,"text":"눈짓을 하며 발로 뜻을 보이며 손가락질로 알게 하며","reference":"잠언 6:13","category":"$undefined"},{"id":"16555","book":"잠언","book_name":"잠언","chapter":6,"verse":14,"text":"그 마음에 패역을 품으며 항상 악을 꾀하여 다툼을 일으키는 자라","reference":"잠언 6:14","category":"$undefined"},{"id":"16556","book":"잠언","book_name":"잠언","chapter":6,"verse":15,"text":"그러므로 그 재앙이 갑자기 임한즉 도움을 얻지 못하고 당장에 패망하리라","reference":"잠언 6:15","category":"$undefined"},{"id":"16557","book":"잠언","book_name":"잠언","chapter":6,"verse":16,"text":"여호와의 미워하시는 것 곧 그 마음에 싫어하시는 것이 육 칠 가지니","reference":"잠언 6:16","category":"$undefined"},{"id":"16558","book":"잠언","book_name":"잠언","chapter":6,"verse":17,"text":"곧 교만한 눈과, 거짓된 혀와, 무죄한 자의 피를 흘리는 손과,","reference":"잠언 6:17","category":"$undefined"},{"id":"16559","book":"잠언","book_name":"잠언","chapter":6,"verse":18,"text":"악한 계교를 꾀하는 마음과, 빨리 악으로 달려가는 발과,","reference":"잠언 6:18","category":"$undefined"},{"id":"16560","book":"잠언","book_name":"잠언","chapter":6,"verse":19,"text":"거짓을 말하는 망령된 증인과, 및 형제 사이를 이간하는 자니라","reference":"잠언 6:19","category":"$undefined"},{"id":"16561","book":"잠언","book_name":"잠언","chapter":6,"verse":20,"text":"내 아들아 네 아비의 명령을 지키며 네 어미의 법을 떠나지 말고","reference":"잠언 6:20","category":"$undefined"},{"id":"16562","book":"잠언","book_name":"잠언","chapter":6,"verse":21,"text":"그것을 항상 네 마음에 새기며 네 목에 매라","reference":"잠언 6:21","category":"$undefined"},{"id":"16563","book":"잠언","book_name":"잠언","chapter":6,"verse":22,"text":"그것이 너의 다닐 때에 너를 인도하며 너의 잘 때에 너를 보호하며 너의 깰 때에 너로 더불어 말하리니","reference":"잠언 6:22","category":"$undefined"},{"id":"16564","book":"잠언","book_name":"잠언","chapter":6,"verse":23,"text":"대저 명령은 등불이요 법은 빛이요 훈계의 책망은 곧 생명의 길이라","reference":"잠언 6:23","category":"$undefined"},{"id":"16565","book":"잠언","book_name":"잠언","chapter":6,"verse":24,"text":"이것이 너를 지켜서 악한 계집에게,이방 계집의 혀로 호리는 말에 빠지지 않게 하리라","reference":"잠언 6:24","category":"$undefined"},{"id":"16566","book":"잠언","book_name":"잠언","chapter":6,"verse":25,"text":"네 마음에 그 아름다운 색을 탐하지 말며 그 눈꺼풀에 홀리지 말라","reference":"잠언 6:25","category":"$undefined"},{"id":"16567","book":"잠언","book_name":"잠언","chapter":6,"verse":26,"text":"음녀로 인하여 사람이 한조각 떡만 남게 됨이며 음란한 계집은 귀한 생명을 사냥함이니라","reference":"잠언 6:26","category":"$undefined"},{"id":"16568","book":"잠언","book_name":"잠언","chapter":6,"verse":27,"text":"사람이 불을 품에 품고야 어찌 그 옷이 타지 아니하겠으며","reference":"잠언 6:27","category":"$undefined"},{"id":"16569","book":"잠언","book_name":"잠언","chapter":6,"verse":28,"text":"사람이 숯불을 밟고야 어찌 그 발이 데지 아니하겠느냐 ?","reference":"잠언 6:28","category":"$undefined"},{"id":"16570","book":"잠언","book_name":"잠언","chapter":6,"verse":29,"text":"남의 아내와 통간하는 자도 이와 같을 것이라 무릇 그를 만지기만 하는 자도 죄 없게 되지 아니하리라","reference":"잠언 6:29","category":"$undefined"},{"id":"16571","book":"잠언","book_name":"잠언","chapter":6,"verse":30,"text":"도적이 만일 주릴 때에 배를 채우려고 도적질하면 사람이 그를 멸시치는 아니하려니와","reference":"잠언 6:30","category":"$undefined"},{"id":"16572","book":"잠언","book_name":"잠언","chapter":6,"verse":31,"text":"들키면 칠배를 갚아야 하리니 심지어 자기 집에 있는 것을 다 내어주게 되리라","reference":"잠언 6:31","category":"$undefined"},{"id":"16573","book":"잠언","book_name":"잠언","chapter":6,"verse":32,"text":"부녀와 간음하는 자는 무지한 자라 이것을 행하는 자는 자기의 영혼을 망하게 하며","reference":"잠언 6:32","category":"$undefined"},{"id":"16574","book":"잠언","book_name":"잠언","chapter":6,"verse":33,"text":"상함과 능욕을 받고 부끄러움을 씻을 수 없게 되나니","reference":"잠언 6:33","category":"$undefined"},{"id":"16575","book":"잠언","book_name":"잠언","chapter":6,"verse":34,"text":"그 남편이 투기함으로 분노하여 원수를 갚는 날에 용서하지 아니하고","reference":"잠언 6:34","category":"$undefined"},{"id":"16576","book":"잠언","book_name":"잠언","chapter":6,"verse":35,"text":"아무 벌금도 돌아 보지 아니하며 많은 선물을 줄지라도 듣지 아니하리라","reference":"잠언 6:35","category":"$undefined"}],"bookSlug":"proverbs"}]
