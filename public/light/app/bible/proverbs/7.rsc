2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":7,"verses":[{"id":"16577","book":"잠언","book_name":"잠언","chapter":7,"verse":1,"text":"내 아들아 내 말을 지키며 내 명령을 네게 간직하라","reference":"잠언 7:1","category":"$undefined"},{"id":"16578","book":"잠언","book_name":"잠언","chapter":7,"verse":2,"text":"내 명령을 지켜서 살며 내 법을 네 눈동자처럼 지키라 !","reference":"잠언 7:2","category":"$undefined"},{"id":"16579","book":"잠언","book_name":"잠언","chapter":7,"verse":3,"text":"이것을 네 손가락에 매며 이것을 네 마음판에 새기라","reference":"잠언 7:3","category":"$undefined"},{"id":"16580","book":"잠언","book_name":"잠언","chapter":7,"verse":4,"text":"지혜에게 너는 내 누이라 하며 명철에게 너는 내 친족이라 하라","reference":"잠언 7:4","category":"$undefined"},{"id":"16581","book":"잠언","book_name":"잠언","chapter":7,"verse":5,"text":"그리하면 이것이 너를 지켜서 음녀에게,말로 호리는 이방 계집에게 빠지지 않게 하리라","reference":"잠언 7:5","category":"$undefined"},{"id":"16582","book":"잠언","book_name":"잠언","chapter":7,"verse":6,"text":"내가 내 집 들창으로, 살창으로 내어다 보다가","reference":"잠언 7:6","category":"$undefined"},{"id":"16583","book":"잠언","book_name":"잠언","chapter":7,"verse":7,"text":"어리석은자 중에, 소년 중에 한 지혜 없는 자를 보았노라","reference":"잠언 7:7","category":"$undefined"},{"id":"16584","book":"잠언","book_name":"잠언","chapter":7,"verse":8,"text":"그가 거리를 지나 음녀의 골목 모퉁이로 가까이 하여 그 집으로 들어가는데","reference":"잠언 7:8","category":"$undefined"},{"id":"16585","book":"잠언","book_name":"잠언","chapter":7,"verse":9,"text":"저물 때, 황혼 때, 깊은밤 흑암 중에라","reference":"잠언 7:9","category":"$undefined"},{"id":"16586","book":"잠언","book_name":"잠언","chapter":7,"verse":10,"text":"그 때에 기생의 옷을 입은 간교한 계집이 그를 맞으니","reference":"잠언 7:10","category":"$undefined"},{"id":"16587","book":"잠언","book_name":"잠언","chapter":7,"verse":11,"text":"이 계집은 떠들며 완패하며 그 발이 집에 머물지 아니하여","reference":"잠언 7:11","category":"$undefined"},{"id":"16588","book":"잠언","book_name":"잠언","chapter":7,"verse":12,"text":"어떤 때에는 거리, 어떤 때에는 광장 모퉁이, 모퉁이에 서서 사람을 기다리는 자라","reference":"잠언 7:12","category":"$undefined"},{"id":"16589","book":"잠언","book_name":"잠언","chapter":7,"verse":13,"text":"그 계집이 그를 붙잡고 입을 맞추며 부끄러움을 모르는 얼굴로 말하되","reference":"잠언 7:13","category":"$undefined"},{"id":"16590","book":"잠언","book_name":"잠언","chapter":7,"verse":14,"text":"내가 화목제를 드려서 서원한 것을 오늘날 갚았노라","reference":"잠언 7:14","category":"$undefined"},{"id":"16591","book":"잠언","book_name":"잠언","chapter":7,"verse":15,"text":"이러므로 내가 너를 맞으려고 나와서 네 얼굴을 찾다가 너를 만났도다","reference":"잠언 7:15","category":"$undefined"},{"id":"16592","book":"잠언","book_name":"잠언","chapter":7,"verse":16,"text":"내 침상에는 화문 요와 애굽의 문채 있는 이불을 폈고","reference":"잠언 7:16","category":"$undefined"},{"id":"16593","book":"잠언","book_name":"잠언","chapter":7,"verse":17,"text":"몰약과 침향과 계피를 뿌렸노라","reference":"잠언 7:17","category":"$undefined"},{"id":"16594","book":"잠언","book_name":"잠언","chapter":7,"verse":18,"text":"오라, 우리가 아침까지 흡족하게 서로 사랑하며 사랑함으로 희락하자","reference":"잠언 7:18","category":"$undefined"},{"id":"16595","book":"잠언","book_name":"잠언","chapter":7,"verse":19,"text":"남편은 집을 떠나 먼 길을 갔는데","reference":"잠언 7:19","category":"$undefined"},{"id":"16596","book":"잠언","book_name":"잠언","chapter":7,"verse":20,"text":"은 주머니를 가졌은즉 보름에나 집에 돌아오리라 하여","reference":"잠언 7:20","category":"$undefined"},{"id":"16597","book":"잠언","book_name":"잠언","chapter":7,"verse":21,"text":"여러가지 고운 말로 혹하게 하며 입술의 호리는 말로 꾀므로","reference":"잠언 7:21","category":"$undefined"},{"id":"16598","book":"잠언","book_name":"잠언","chapter":7,"verse":22,"text":"소년이 곧 그를 따랐으니 소가 푸주로 가는 것 같고 미련한 자가 벌을 받으려고 쇠사슬에 매이러 가는 것과 일반이라","reference":"잠언 7:22","category":"$undefined"},{"id":"16599","book":"잠언","book_name":"잠언","chapter":7,"verse":23,"text":"필경은 살이 그 간을 뚫기까지에 이를 것이라 새가 빨리 그물로 들어가되 그 생명을 잃어버릴 줄을 알지 못함과 일반이니라","reference":"잠언 7:23","category":"$undefined"},{"id":"16600","book":"잠언","book_name":"잠언","chapter":7,"verse":24,"text":"아들들아 나를 듣고 내 입의 말에 주의하라","reference":"잠언 7:24","category":"$undefined"},{"id":"16601","book":"잠언","book_name":"잠언","chapter":7,"verse":25,"text":"네 마음이 음녀의 길로 치우치지 말며 그 길에 미혹지 말지어다","reference":"잠언 7:25","category":"$undefined"},{"id":"16602","book":"잠언","book_name":"잠언","chapter":7,"verse":26,"text":"대저 그가 많은 사람을 상하여 엎드러지게 하였나니 그에게 죽은자가 허다하니라","reference":"잠언 7:26","category":"$undefined"},{"id":"16603","book":"잠언","book_name":"잠언","chapter":7,"verse":27,"text":"그 집은 음부의 길이라 사망의 방으로 내려가느니라","reference":"잠언 7:27","category":"$undefined"}],"bookSlug":"proverbs"}]
