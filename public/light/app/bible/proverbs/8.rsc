2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":8,"verses":[{"id":"16604","book":"잠언","book_name":"잠언","chapter":8,"verse":1,"text":"지혜가 부르지 아니하느냐 명철이 소리를 높이지 아니하느냐","reference":"잠언 8:1","category":"$undefined"},{"id":"16605","book":"잠언","book_name":"잠언","chapter":8,"verse":2,"text":"그가 길가의 높은 곳과 사거리에 서며","reference":"잠언 8:2","category":"$undefined"},{"id":"16606","book":"잠언","book_name":"잠언","chapter":8,"verse":3,"text":"성문 곁과 문 어귀와 여러 출입하는 문에서 불러 가로되","reference":"잠언 8:3","category":"$undefined"},{"id":"16607","book":"잠언","book_name":"잠언","chapter":8,"verse":4,"text":"사람들아 내가 너희를 부르며 내가 인자들에게 소리를 높이노라","reference":"잠언 8:4","category":"$undefined"},{"id":"16608","book":"잠언","book_name":"잠언","chapter":8,"verse":5,"text":"어리석은 자들아 너희는 명철할지니라 미련한 자들아 너희는 마음이 밝을지니라 너희는 들을지어다","reference":"잠언 8:5","category":"$undefined"},{"id":"16609","book":"잠언","book_name":"잠언","chapter":8,"verse":6,"text":"내가 가장 선한 것을 말하리라 내 입술을 열어 정직을 내리라","reference":"잠언 8:6","category":"$undefined"},{"id":"16610","book":"잠언","book_name":"잠언","chapter":8,"verse":7,"text":"내 입은 진리를 말하며 내 입술은 악을 미워하느니라","reference":"잠언 8:7","category":"$undefined"},{"id":"16611","book":"잠언","book_name":"잠언","chapter":8,"verse":8,"text":"내 입의 말은 다 의로운즉 그 가운데 굽은 것과 패역한 것이 없나니","reference":"잠언 8:8","category":"$undefined"},{"id":"16612","book":"잠언","book_name":"잠언","chapter":8,"verse":9,"text":"이는 다 총명 있는 자의 밝히 아는 바요 지식 얻은 자의 정직히 여기는 바니라","reference":"잠언 8:9","category":"$undefined"},{"id":"16613","book":"잠언","book_name":"잠언","chapter":8,"verse":10,"text":"너희가 은을 받지 말고 나의 훈계를 받으며 정금보다 지식을 얻으라","reference":"잠언 8:10","category":"$undefined"},{"id":"16614","book":"잠언","book_name":"잠언","chapter":8,"verse":11,"text":"대저 지혜는 진주보다 나으므로 무릇 원하는 것을 이에 비교할 수 없음이니라","reference":"잠언 8:11","category":"$undefined"},{"id":"16615","book":"잠언","book_name":"잠언","chapter":8,"verse":12,"text":"나 지혜는 명철로 주소를 삼으며 지식과 근신을 찾아 얻나니","reference":"잠언 8:12","category":"$undefined"},{"id":"16616","book":"잠언","book_name":"잠언","chapter":8,"verse":13,"text":"여호와를 경외하는 것은 악을 미워하는 것이라 나는 교만과 거만과 악한 행실과 패역한 입을 미워하느니라","reference":"잠언 8:13","category":"$undefined"},{"id":"16617","book":"잠언","book_name":"잠언","chapter":8,"verse":14,"text":"내게는 도략과 참 지식이 있으며 나는 명철이라 내게 능력이 있으므로","reference":"잠언 8:14","category":"$undefined"},{"id":"16618","book":"잠언","book_name":"잠언","chapter":8,"verse":15,"text":"나로 말미암아 왕들이 치리하며 방백들이 공의를 세우며","reference":"잠언 8:15","category":"$undefined"},{"id":"16619","book":"잠언","book_name":"잠언","chapter":8,"verse":16,"text":"나로 말미암아 재상과 존귀한 자 곧 세상의 모든 재판관들이 다스리느니라","reference":"잠언 8:16","category":"$undefined"},{"id":"16620","book":"잠언","book_name":"잠언","chapter":8,"verse":17,"text":"나를 사랑하는 자들이 나의 사랑을 입으며 나를 간절히 찾는 자가 나를 만날 것이니라","reference":"잠언 8:17","category":"$undefined"},{"id":"16621","book":"잠언","book_name":"잠언","chapter":8,"verse":18,"text":"부귀가 내게 있고 장구한 재물과 의도 그러하니라","reference":"잠언 8:18","category":"$undefined"},{"id":"16622","book":"잠언","book_name":"잠언","chapter":8,"verse":19,"text":"내 열매는 금이나 정금보다 나으며 내 소득은 천은보다 나으니라","reference":"잠언 8:19","category":"$undefined"},{"id":"16623","book":"잠언","book_name":"잠언","chapter":8,"verse":20,"text":"나는 의로운 길로 행하며 공평한 길 가운데로 다니나니","reference":"잠언 8:20","category":"$undefined"},{"id":"16624","book":"잠언","book_name":"잠언","chapter":8,"verse":21,"text":"이는 나를 사랑하는 자로 재물을 얻어서 그 곳간에 채우게 하려함이니라","reference":"잠언 8:21","category":"$undefined"},{"id":"16625","book":"잠언","book_name":"잠언","chapter":8,"verse":22,"text":"[사37:26]","reference":"잠언 8:22","category":"$undefined"},{"id":"16626","book":"잠언","book_name":"잠언","chapter":8,"verse":23,"text":"여호와께서 그 조화의 시작 곧 태초에 일하시기 전에 나를 가지셨으며","reference":"잠언 8:23","category":"$undefined"},{"id":"16627","book":"잠언","book_name":"잠언","chapter":8,"verse":24,"text":"만세 전부터 상고부터, 땅이 생기기 전부터, 내가 세움을 입었나니","reference":"잠언 8:24","category":"$undefined"},{"id":"16628","book":"잠언","book_name":"잠언","chapter":8,"verse":25,"text":"아직 바다가 생기지 아니하였고 큰 샘들이 있기 전에 내가 이미났으며","reference":"잠언 8:25","category":"$undefined"},{"id":"16629","book":"잠언","book_name":"잠언","chapter":8,"verse":26,"text":"산이 세우심을 입기 전에 언덕이 생기기 전에 내가 이미 났으니","reference":"잠언 8:26","category":"$undefined"},{"id":"16630","book":"잠언","book_name":"잠언","chapter":8,"verse":27,"text":"하나님이 아직 땅도 들도 세상 진토의 근원도 짓지 아니하셨을 때에라","reference":"잠언 8:27","category":"$undefined"},{"id":"16631","book":"잠언","book_name":"잠언","chapter":8,"verse":28,"text":"그가 하늘을 지으시며 궁창으로 해면에 두르실 때에 내가 거기 있었고","reference":"잠언 8:28","category":"$undefined"},{"id":"16632","book":"잠언","book_name":"잠언","chapter":8,"verse":29,"text":"그가 위로 구름 하늘을 견고하게 하시며 바다의 샘들을 힘 있게하시며","reference":"잠언 8:29","category":"$undefined"},{"id":"16633","book":"잠언","book_name":"잠언","chapter":8,"verse":30,"text":"바다의 한계를 정하여 물로 명령을 거스리지 못하게 하시며 또 땅의 기초를 정하실 때에","reference":"잠언 8:30","category":"$undefined"},{"id":"16634","book":"잠언","book_name":"잠언","chapter":8,"verse":31,"text":"내가 그 곁에 있어서 창조자가 되어 날마다 그 기뻐하신 바가 되었으며 항상 그 앞에서 즐거워하였으며","reference":"잠언 8:31","category":"$undefined"},{"id":"16635","book":"잠언","book_name":"잠언","chapter":8,"verse":32,"text":"사람이 거처할 땅에서 즐거워하며 인자들을 기뻐하였었느니라","reference":"잠언 8:32","category":"$undefined"},{"id":"16636","book":"잠언","book_name":"잠언","chapter":8,"verse":33,"text":"아들들아 이제 내게 들으라 내 도를 지키는 자가 복이 있느니라","reference":"잠언 8:33","category":"$undefined"},{"id":"16637","book":"잠언","book_name":"잠언","chapter":8,"verse":34,"text":"훈계를 들어서 지혜를 얻으라 그것을 버리지 말라","reference":"잠언 8:34","category":"$undefined"},{"id":"16638","book":"잠언","book_name":"잠언","chapter":8,"verse":35,"text":"누구든지 내게 들으며 날마다 내 문 곁에서 기다리며 문설주 옆에서 기다리는 자는 복이 있나니","reference":"잠언 8:35","category":"$undefined"},{"id":"16639","book":"잠언","book_name":"잠언","chapter":8,"verse":36,"text":"대저 나를 얻는 자는 생명을 얻고 여호와께 은총을 얻을 것임이니라 [ (Proverbs 8:37) 그러나 나를 잃는 자는 자기의 영혼을 해하는 자라 무릇 나를 미워하는 자는 사망을 사랑하느니라 ]","reference":"잠언 8:36","category":"$undefined"}],"bookSlug":"proverbs"}]
