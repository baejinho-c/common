2:["$","$L11",null,{"book":{"id":"proverbs","name":"잠언","chapters":31,"testament":"old"},"chapter":9,"verses":[{"id":"16640","book":"잠언","book_name":"잠언","chapter":9,"verse":1,"text":"지혜가 그 집을 짓고 일곱 기둥을 다듬고","reference":"잠언 9:1","category":"$undefined"},{"id":"16641","book":"잠언","book_name":"잠언","chapter":9,"verse":2,"text":"짐승을 잡으며 포도주를 혼합하여 상을 갖추고","reference":"잠언 9:2","category":"$undefined"},{"id":"16642","book":"잠언","book_name":"잠언","chapter":9,"verse":3,"text":"그 여종을 보내어 성중 높은 곳에서 불러 이르기를","reference":"잠언 9:3","category":"$undefined"},{"id":"16643","book":"잠언","book_name":"잠언","chapter":9,"verse":4,"text":"무릇 어리석은 자는 이리로 돌이키라 또 지혜 없는 자에게 이르기를","reference":"잠언 9:4","category":"$undefined"},{"id":"16644","book":"잠언","book_name":"잠언","chapter":9,"verse":5,"text":"너는 와서 내 식물을 먹으며 내 혼합한 포도주를 마시고","reference":"잠언 9:5","category":"$undefined"},{"id":"16645","book":"잠언","book_name":"잠언","chapter":9,"verse":6,"text":"어리석음을 버리고 생명을 얻으라 명철의 길을 행하라 하느니라","reference":"잠언 9:6","category":"$undefined"},{"id":"16646","book":"잠언","book_name":"잠언","chapter":9,"verse":7,"text":"거만한 자를 징계하는 자는 도리어 능욕을 받고 악인을 책망하는 자는 도리어 흠을 잡히느니라","reference":"잠언 9:7","category":"$undefined"},{"id":"16647","book":"잠언","book_name":"잠언","chapter":9,"verse":8,"text":"거만한 자를 책망하지 말라 그가 너를 미워할까 두려우니라 지혜있는 자를 책망하라 그가 너를 사랑하리라","reference":"잠언 9:8","category":"$undefined"},{"id":"16648","book":"잠언","book_name":"잠언","chapter":9,"verse":9,"text":"지혜 있는 자에게 교훈을 더하라 그가 더욱 지혜로와질 것이요 의로운 사람을 가르치라 그의 학식이 더하리라","reference":"잠언 9:9","category":"$undefined"},{"id":"16649","book":"잠언","book_name":"잠언","chapter":9,"verse":10,"text":"여호와를 경외하는 것이 지혜의 근본이요 거룩하신 자를 아는 것이 명철이니라","reference":"잠언 9:10","category":"$undefined"},{"id":"16650","book":"잠언","book_name":"잠언","chapter":9,"verse":11,"text":"나 지혜로 말미암아 네 날이 많아질 것이요 네 생명의 해가 더하리라","reference":"잠언 9:11","category":"$undefined"},{"id":"16651","book":"잠언","book_name":"잠언","chapter":9,"verse":12,"text":"네가 만일 지혜로우면 그 지혜가 네게 유익할 것이나 네가 만일 거만하면 너 홀로 해를 당하리라","reference":"잠언 9:12","category":"$undefined"},{"id":"16652","book":"잠언","book_name":"잠언","chapter":9,"verse":13,"text":"미련한 계집이 떠들며 어리석어서 아무 것도 알지 못하고","reference":"잠언 9:13","category":"$undefined"},{"id":"16653","book":"잠언","book_name":"잠언","chapter":9,"verse":14,"text":"자기 집 문에 앉으며 성읍 높은 곳에 있는 자리에 앉아서","reference":"잠언 9:14","category":"$undefined"},{"id":"16654","book":"잠언","book_name":"잠언","chapter":9,"verse":15,"text":"자기 길을 바로 가는 행객을 불러 이르되","reference":"잠언 9:15","category":"$undefined"},{"id":"16655","book":"잠언","book_name":"잠언","chapter":9,"verse":16,"text":"무릇 어리석은 자는 이리로 돌이키라 또 지혜없는 자에게 이르기를","reference":"잠언 9:16","category":"$undefined"},{"id":"16656","book":"잠언","book_name":"잠언","chapter":9,"verse":17,"text":"도적질한 물이 달고 몰래 먹는 떡이 맛이 있다 하는도다","reference":"잠언 9:17","category":"$undefined"},{"id":"16657","book":"잠언","book_name":"잠언","chapter":9,"verse":18,"text":"오직 그 어리석은 자는 죽은 자가 그의 곳에 있는 것과 그의 객들이 음부 깊은 곳에 있는 것을 알지 못하느니라","reference":"잠언 9:18","category":"$undefined"}],"bookSlug":"proverbs"}]
