2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":105,"verses":[{"id":"15608","book":"시편","book_name":"시편","chapter":105,"verse":1,"text":"여호와께 감사하며 그 이름을 불러 아뢰며 그 행사를 만민 중에 알게 할지어다","reference":"시편 105:1","category":"$undefined"},{"id":"15609","book":"시편","book_name":"시편","chapter":105,"verse":2,"text":"그에게 노래하며 그를 찬양하며 그의 모든 기사를 말할지어다","reference":"시편 105:2","category":"$undefined"},{"id":"15610","book":"시편","book_name":"시편","chapter":105,"verse":3,"text":"그 성호를 자랑하라 무릇 여호와를 구하는 자는 마음이 즐거울지로다","reference":"시편 105:3","category":"$undefined"},{"id":"15611","book":"시편","book_name":"시편","chapter":105,"verse":4,"text":"여호와와 그 능력을 구할지어다 그 얼굴을 항상 구할지어다","reference":"시편 105:4","category":"$undefined"},{"id":"15612","book":"시편","book_name":"시편","chapter":105,"verse":5,"text":"그 종 아브라함의 후손 곧 택하신 야곱의 자손 너희는 그의 행하신 기사와 그 이적과 그 입의 판단을 기억할지어다","reference":"시편 105:5","category":"$undefined"},{"id":"15613","book":"시편","book_name":"시편","chapter":105,"verse":6,"text":"(5절과 같음)","reference":"시편 105:6","category":"$undefined"},{"id":"15614","book":"시편","book_name":"시편","chapter":105,"verse":7,"text":"그는 여호와 우리 하나님이시라 그의 판단이 온 땅에 있도다","reference":"시편 105:7","category":"$undefined"},{"id":"15615","book":"시편","book_name":"시편","chapter":105,"verse":8,"text":"그는 그 언약 곧 천대에 명하신 말씀을 영원히 기억하셨으니","reference":"시편 105:8","category":"$undefined"},{"id":"15616","book":"시편","book_name":"시편","chapter":105,"verse":9,"text":"이것은 아브라함에게 하신 언약이며 이삭에게 하신 맹세며","reference":"시편 105:9","category":"$undefined"},{"id":"15617","book":"시편","book_name":"시편","chapter":105,"verse":10,"text":"야곱에게 세우신 율례 곧 이스라엘에게 하신 영영한 언약이라","reference":"시편 105:10","category":"$undefined"},{"id":"15618","book":"시편","book_name":"시편","chapter":105,"verse":11,"text":"이르시기를 내가 가나안 땅을 네게 주어 너희 기업의 지경이 되게 하리라 하셨도다","reference":"시편 105:11","category":"$undefined"},{"id":"15619","book":"시편","book_name":"시편","chapter":105,"verse":12,"text":"때에 저희 인수가 적어 매우 영성하며 그 땅에 객이 되어","reference":"시편 105:12","category":"$undefined"},{"id":"15620","book":"시편","book_name":"시편","chapter":105,"verse":13,"text":"이 족속에게서 저 족속에게로, 이 나라에서 다른 민족에게로 유리하였도다","reference":"시편 105:13","category":"$undefined"},{"id":"15621","book":"시편","book_name":"시편","chapter":105,"verse":14,"text":"사람이 그들을 해하기를 용납지 아니하시고 그들의 연고로 열왕을 꾸짖어","reference":"시편 105:14","category":"$undefined"},{"id":"15622","book":"시편","book_name":"시편","chapter":105,"verse":15,"text":"이르시기를 나의 기름 부은 자를 만지지 말며 나의 선지자를 상하지 말라 하셨도다","reference":"시편 105:15","category":"$undefined"},{"id":"15623","book":"시편","book_name":"시편","chapter":105,"verse":16,"text":"그가 또 기근을 불러 그 땅에 임하게 하여 그 의뢰하는 양식을 다 끊으셨도다","reference":"시편 105:16","category":"$undefined"},{"id":"15624","book":"시편","book_name":"시편","chapter":105,"verse":17,"text":"한 사람을 앞서 보내셨음이여 요셉이 종으로 팔렸도다","reference":"시편 105:17","category":"$undefined"},{"id":"15625","book":"시편","book_name":"시편","chapter":105,"verse":18,"text":"그 발이 착고에 상하며 그 몸이 쇠사슬에 매였으니","reference":"시편 105:18","category":"$undefined"},{"id":"15626","book":"시편","book_name":"시편","chapter":105,"verse":19,"text":"곧 여호와의 말씀이 응할 때까지라 그 말씀이 저를 단련하였도다","reference":"시편 105:19","category":"$undefined"},{"id":"15627","book":"시편","book_name":"시편","chapter":105,"verse":20,"text":"왕이 사람을 보내어 저를 방석함이여 열방의 통치자가 저로 자유케 하였도다","reference":"시편 105:20","category":"$undefined"},{"id":"15628","book":"시편","book_name":"시편","chapter":105,"verse":21,"text":"저로 그 집의 주관자를 삼아 그 모든 소유를 관리케 하고","reference":"시편 105:21","category":"$undefined"},{"id":"15629","book":"시편","book_name":"시편","chapter":105,"verse":22,"text":"임의로 백관을 제어하며 지혜로 장로들을 교훈하게 하였도다","reference":"시편 105:22","category":"$undefined"},{"id":"15630","book":"시편","book_name":"시편","chapter":105,"verse":23,"text":"이에 이스라엘이 애굽에 들어감이여 야곱이 함 땅에 객이 되었도다","reference":"시편 105:23","category":"$undefined"},{"id":"15631","book":"시편","book_name":"시편","chapter":105,"verse":24,"text":"여호와께서 그 백성을 크게 번성케 하사 그들의 대적보다 강하게 하셨으며","reference":"시편 105:24","category":"$undefined"},{"id":"15632","book":"시편","book_name":"시편","chapter":105,"verse":25,"text":"또 저희 마음을 변하여 그 백성을 미워하게 하시며 그 종들에게 교활히 행하게 하셨도다","reference":"시편 105:25","category":"$undefined"},{"id":"15633","book":"시편","book_name":"시편","chapter":105,"verse":26,"text":"또 그 종 모세와 그 택하신 아론을 보내시니","reference":"시편 105:26","category":"$undefined"},{"id":"15634","book":"시편","book_name":"시편","chapter":105,"verse":27,"text":"저희가 그 백성 중에 여호와의 표징을 보이고 함 땅에서 기사를 행하였도다","reference":"시편 105:27","category":"$undefined"},{"id":"15635","book":"시편","book_name":"시편","chapter":105,"verse":28,"text":"여호와께서 흑암을 보내사 어둡게 하시니 그 말씀을 어기지 아니하였도다","reference":"시편 105:28","category":"$undefined"},{"id":"15636","book":"시편","book_name":"시편","chapter":105,"verse":29,"text":"저희 물을 변하여 피가 되게 하사 저희 물고기를 죽이셨도다","reference":"시편 105:29","category":"$undefined"},{"id":"15637","book":"시편","book_name":"시편","chapter":105,"verse":30,"text":"그 땅에 개구리가 번성하여 왕의 궁실에도 있었도다","reference":"시편 105:30","category":"$undefined"},{"id":"15638","book":"시편","book_name":"시편","chapter":105,"verse":31,"text":"여호와께서 말씀 하신즉 파리떼가 오며 저희 사경에 이가 생겼도다","reference":"시편 105:31","category":"$undefined"},{"id":"15639","book":"시편","book_name":"시편","chapter":105,"verse":32,"text":"비 대신 우박을 내리시며 저희 땅에 화염을 내리셨도다","reference":"시편 105:32","category":"$undefined"},{"id":"15640","book":"시편","book_name":"시편","chapter":105,"verse":33,"text":"저희 포도나무와 무화과나무를 치시며 저희 사경의 나무를 찍으셨도다","reference":"시편 105:33","category":"$undefined"},{"id":"15641","book":"시편","book_name":"시편","chapter":105,"verse":34,"text":"여호와께서 말씀하신즉 황충과 무수한 메뚜기가 이르러","reference":"시편 105:34","category":"$undefined"},{"id":"15642","book":"시편","book_name":"시편","chapter":105,"verse":35,"text":"저희 땅에 모든 채소를 먹으며 그 밭에 열매를 먹었도다","reference":"시편 105:35","category":"$undefined"},{"id":"15643","book":"시편","book_name":"시편","chapter":105,"verse":36,"text":"여호와께서 또 저희 땅의 모든 장자를 치시니 곧 저희 모든 기력의 시작이로다","reference":"시편 105:36","category":"$undefined"},{"id":"15644","book":"시편","book_name":"시편","chapter":105,"verse":37,"text":"그들을 인도하여 은금을 가지고 나오게 하시니 그 지파 중에 약한 자가 하나도 없었도다","reference":"시편 105:37","category":"$undefined"},{"id":"15645","book":"시편","book_name":"시편","chapter":105,"verse":38,"text":"그들의 떠날 때에 애굽이 기뻐하였으니 저희가 그들을 두려워함이로다","reference":"시편 105:38","category":"$undefined"},{"id":"15646","book":"시편","book_name":"시편","chapter":105,"verse":39,"text":"여호와께서 구름을 펴사 덮개를 삼으시고 밤에 불로 밝히셨으며","reference":"시편 105:39","category":"$undefined"},{"id":"15647","book":"시편","book_name":"시편","chapter":105,"verse":40,"text":"그들이 구한즉 메추라기로 오게 하시며 또 하늘 양식으로 그들을 만족케 하셨도다","reference":"시편 105:40","category":"$undefined"},{"id":"15648","book":"시편","book_name":"시편","chapter":105,"verse":41,"text":"반석을 가르신즉 물이 흘러나서 마른 땅에 강 같이 흘렀으니","reference":"시편 105:41","category":"$undefined"},{"id":"15649","book":"시편","book_name":"시편","chapter":105,"verse":42,"text":"이는 그 거룩한 말씀과 그 종 아브라함을 기억하셨음이로다","reference":"시편 105:42","category":"$undefined"},{"id":"15650","book":"시편","book_name":"시편","chapter":105,"verse":43,"text":"그 백성으로 즐거이 나오게 하시며 그 택한 자로 노래하며 나오게 하시고","reference":"시편 105:43","category":"$undefined"},{"id":"15651","book":"시편","book_name":"시편","chapter":105,"verse":44,"text":"열방의 땅을 저희에게 주시며 민족들의 수고한 것을 소유로 취하게 하셨으니","reference":"시편 105:44","category":"$undefined"},{"id":"15652","book":"시편","book_name":"시편","chapter":105,"verse":45,"text":"이는 저희로 그 율례를 지키며 그 법을 좇게 하려 하심이로다 할렐루야 !","reference":"시편 105:45","category":"$undefined"}],"bookSlug":"psalms"}]
