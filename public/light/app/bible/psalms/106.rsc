2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":106,"verses":[{"id":"15653","book":"시편","book_name":"시편","chapter":106,"verse":1,"text":"할렐루야 ! 여호와께 감사하라 그는 선하시며 그 인자하심이 영원함이로다","reference":"시편 106:1","category":"$undefined"},{"id":"15654","book":"시편","book_name":"시편","chapter":106,"verse":2,"text":"뉘 능히 여호와의 능하신 사적을 전파하며 그 영예를 다 광포할꼬","reference":"시편 106:2","category":"$undefined"},{"id":"15655","book":"시편","book_name":"시편","chapter":106,"verse":3,"text":"공의를 지키는 자들과 항상 의를 행하는 자는 복이 있도다","reference":"시편 106:3","category":"$undefined"},{"id":"15656","book":"시편","book_name":"시편","chapter":106,"verse":4,"text":"여호와여, 주의 백성에게 베푸시는 은혜로 나를 기억하시며 주의 구원으로 나를 권고하사","reference":"시편 106:4","category":"$undefined"},{"id":"15657","book":"시편","book_name":"시편","chapter":106,"verse":5,"text":"나로 주의 택하신 자의 형통함을 보고 주의 나라의 기업으로 즐거워하게 하시며 주의 기업과 함께 자랑하게 하소서","reference":"시편 106:5","category":"$undefined"},{"id":"15658","book":"시편","book_name":"시편","chapter":106,"verse":6,"text":"우리가 열조와 함께 범죄하여 사특을 행하며 악을 지었나이다","reference":"시편 106:6","category":"$undefined"},{"id":"15659","book":"시편","book_name":"시편","chapter":106,"verse":7,"text":"우리 열조가 애굽에서 주의 기사를 깨닫지 못하며 주의 많은 인자를 기억지 아니하고 바다 곧 홍해에서 거역하였나이다","reference":"시편 106:7","category":"$undefined"},{"id":"15660","book":"시편","book_name":"시편","chapter":106,"verse":8,"text":"그러나 여호와께서 자기 이름을 위하여 저희를 구원하셨으니 그 큰 권능을 알게 하려 하심이로다","reference":"시편 106:8","category":"$undefined"},{"id":"15661","book":"시편","book_name":"시편","chapter":106,"verse":9,"text":"이에 홍해를 꾸짖으시니 곧 마르매 저희를 인도하여 바다 지나기를 광야를 지남 같게 하사","reference":"시편 106:9","category":"$undefined"},{"id":"15662","book":"시편","book_name":"시편","chapter":106,"verse":10,"text":"저희를 그 미워하는 자의 손에서 구원하시며 그 원수의 손에서 구속하셨고","reference":"시편 106:10","category":"$undefined"},{"id":"15663","book":"시편","book_name":"시편","chapter":106,"verse":11,"text":"저희 대적은 물이 덮으매 하나도 남지 아니하였도다","reference":"시편 106:11","category":"$undefined"},{"id":"15664","book":"시편","book_name":"시편","chapter":106,"verse":12,"text":"이에 저희가 그 말씀을 믿고 그 찬송을 불렀도다","reference":"시편 106:12","category":"$undefined"},{"id":"15665","book":"시편","book_name":"시편","chapter":106,"verse":13,"text":"저희가 미구에 그 행사를 잊어버리며 그 가르침을 기다리지 아니하고","reference":"시편 106:13","category":"$undefined"},{"id":"15666","book":"시편","book_name":"시편","chapter":106,"verse":14,"text":"광야에서 욕심을 크게 발하며 사막에서 하나님을 시험하였도다","reference":"시편 106:14","category":"$undefined"},{"id":"15667","book":"시편","book_name":"시편","chapter":106,"verse":15,"text":"여호와께서 저희의 요구한 것을 주셨을지라도 그 영혼을 파리하게 하셨도다","reference":"시편 106:15","category":"$undefined"},{"id":"15668","book":"시편","book_name":"시편","chapter":106,"verse":16,"text":"저희가 진에서 모세와 여호와의 성도 아론을 질투하매","reference":"시편 106:16","category":"$undefined"},{"id":"15669","book":"시편","book_name":"시편","chapter":106,"verse":17,"text":"땅이 갈라져 다단을 삼키며 아비람의 당을 덮었으며","reference":"시편 106:17","category":"$undefined"},{"id":"15670","book":"시편","book_name":"시편","chapter":106,"verse":18,"text":"불이 그 당 중에 붙음이여 화염이 악인을 살랐도다","reference":"시편 106:18","category":"$undefined"},{"id":"15671","book":"시편","book_name":"시편","chapter":106,"verse":19,"text":"저희가 호렙에서 송아지를 만들고 부어 만든 우상을 숭배하여","reference":"시편 106:19","category":"$undefined"},{"id":"15672","book":"시편","book_name":"시편","chapter":106,"verse":20,"text":"자기 영광을 풀 먹는 소의 형상으로 바꾸었도다","reference":"시편 106:20","category":"$undefined"},{"id":"15673","book":"시편","book_name":"시편","chapter":106,"verse":21,"text":"애굽에서 큰 일을 행하신 그 구원자 하나님을 저희가 잊었나니","reference":"시편 106:21","category":"$undefined"},{"id":"15674","book":"시편","book_name":"시편","chapter":106,"verse":22,"text":"그는 함 땅에서 기사와 홍해에서 놀랄 일을 행하신 자로다","reference":"시편 106:22","category":"$undefined"},{"id":"15675","book":"시편","book_name":"시편","chapter":106,"verse":23,"text":"그러므로 여호와께서 저희를 멸하리라 하셨으나 그 택하신 모세가 그 결렬된 중에서 그 앞에 서서 그 노를 돌이켜 멸하시지 않 게 하였도다","reference":"시편 106:23","category":"$undefined"},{"id":"15676","book":"시편","book_name":"시편","chapter":106,"verse":24,"text":"저희가 낙토를 멸시하며 그 말씀을 믿지 아니하고","reference":"시편 106:24","category":"$undefined"},{"id":"15677","book":"시편","book_name":"시편","chapter":106,"verse":25,"text":"저희 장막에서 원망하며 여호와의 말씀을 청종치 아니하였도다","reference":"시편 106:25","category":"$undefined"},{"id":"15678","book":"시편","book_name":"시편","chapter":106,"verse":26,"text":"이러므로 저가 맹세하시기를 저희로 광야에 엎더지게 하고","reference":"시편 106:26","category":"$undefined"},{"id":"15679","book":"시편","book_name":"시편","chapter":106,"verse":27,"text":"또 그 후손을 열방 중에 엎드러뜨리며 각지에 흩어지게 하리라 하셨도다","reference":"시편 106:27","category":"$undefined"},{"id":"15680","book":"시편","book_name":"시편","chapter":106,"verse":28,"text":"저희가 또 바알브올과 연합하여 죽은 자에게 제사한 음식을 먹어서","reference":"시편 106:28","category":"$undefined"},{"id":"15681","book":"시편","book_name":"시편","chapter":106,"verse":29,"text":"그 행위로 주를 격노케 함을 인하여 재앙이 그 중에 유행하였도다","reference":"시편 106:29","category":"$undefined"},{"id":"15682","book":"시편","book_name":"시편","chapter":106,"verse":30,"text":"때에 비느하스가 일어나 처벌하니 이에 재앙이 그쳤도다","reference":"시편 106:30","category":"$undefined"},{"id":"15683","book":"시편","book_name":"시편","chapter":106,"verse":31,"text":"이 일을 저에게 의로 정하였으니 대대로 무궁하리로다","reference":"시편 106:31","category":"$undefined"},{"id":"15684","book":"시편","book_name":"시편","chapter":106,"verse":32,"text":"저희가 또 므리바 물에서 여호와를 노하시게 하였으므로 저희로 인하여 얼이 모세에게 미쳤나니","reference":"시편 106:32","category":"$undefined"},{"id":"15685","book":"시편","book_name":"시편","chapter":106,"verse":33,"text":"이는 저희가 그 심령을 거역함을 인하여 모세가 그 입술로 망령되이 말하였음이로다","reference":"시편 106:33","category":"$undefined"},{"id":"15686","book":"시편","book_name":"시편","chapter":106,"verse":34,"text":"저희가 여호와의 명을 좇지 아니하여 이족들을 멸하지 아니하고","reference":"시편 106:34","category":"$undefined"},{"id":"15687","book":"시편","book_name":"시편","chapter":106,"verse":35,"text":"열방과 섞여서 그 행위를 배우며","reference":"시편 106:35","category":"$undefined"},{"id":"15688","book":"시편","book_name":"시편","chapter":106,"verse":36,"text":"그 우상들을 섬기므로 그것이 저희에게 올무가 되었도다","reference":"시편 106:36","category":"$undefined"},{"id":"15689","book":"시편","book_name":"시편","chapter":106,"verse":37,"text":"저희가 그 자녀로 사신에게 제사하였도다","reference":"시편 106:37","category":"$undefined"},{"id":"15690","book":"시편","book_name":"시편","chapter":106,"verse":38,"text":"무죄한 피 곧 저희 자녀의 피를 흘려 가나안 우상에게 제사하므로 그 땅이 피에 더러웠도다","reference":"시편 106:38","category":"$undefined"},{"id":"15691","book":"시편","book_name":"시편","chapter":106,"verse":39,"text":"저희는 그 행위로 더러워지며 그 행동이 음탕하도다","reference":"시편 106:39","category":"$undefined"},{"id":"15692","book":"시편","book_name":"시편","chapter":106,"verse":40,"text":"그러므로 여호와께서 자기 백성에게 맹렬히 노하시며 자기 기업을 미워하사","reference":"시편 106:40","category":"$undefined"},{"id":"15693","book":"시편","book_name":"시편","chapter":106,"verse":41,"text":"저희를 열방의 손에 붙이시매 저희를 미워하는 자들이 저희를 치리 하였도다","reference":"시편 106:41","category":"$undefined"},{"id":"15694","book":"시편","book_name":"시편","chapter":106,"verse":42,"text":"저희가 원수들의 압박을 받고 그 수하에 복종케 되었도다","reference":"시편 106:42","category":"$undefined"},{"id":"15695","book":"시편","book_name":"시편","chapter":106,"verse":43,"text":"여호와께서 여러 번 저희를 건지시나 저희가 꾀로 거역하며 자기 죄악으로 인하여 낮아짐을 당하였도다","reference":"시편 106:43","category":"$undefined"},{"id":"15696","book":"시편","book_name":"시편","chapter":106,"verse":44,"text":"그러나 여호와께서 저희의 부르짖음을 들으실 때에 그 고통을 권고하시며","reference":"시편 106:44","category":"$undefined"},{"id":"15697","book":"시편","book_name":"시편","chapter":106,"verse":45,"text":"저희를 위하여 그 언약을 기억하시고 그 많은 인자하심을 따라 뜻을 돌이키사","reference":"시편 106:45","category":"$undefined"},{"id":"15698","book":"시편","book_name":"시편","chapter":106,"verse":46,"text":"저희로 사로잡은 모든 자에게서 긍휼히 여김을 받게 하셨도다","reference":"시편 106:46","category":"$undefined"},{"id":"15699","book":"시편","book_name":"시편","chapter":106,"verse":47,"text":"여호와 우리 하나님이여, 우리를 구원하사 열방 중에서 모으시고 우리로 주의 성호를 감사하며 주의 영예를 찬양하게 하소서","reference":"시편 106:47","category":"$undefined"},{"id":"15700","book":"시편","book_name":"시편","chapter":106,"verse":48,"text":"여호와 이스라엘의 하나님을 영원부터 영원까지 찬양할지어다 ! 모든 백성들아 아멘 할지어다 할렐루야","reference":"시편 106:48","category":"$undefined"}],"bookSlug":"psalms"}]
