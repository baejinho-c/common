2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":107,"verses":[{"id":"15701","book":"시편","book_name":"시편","chapter":107,"verse":1,"text":"여호와께 감사하라 ! 그는 선하시며 그 인자하심이 영원함이로다","reference":"시편 107:1","category":"$undefined"},{"id":"15702","book":"시편","book_name":"시편","chapter":107,"verse":2,"text":"여호와께 구속함을 받은 자는 이같이 말할지어다 여호와께서 대적의 손에서 저희를 구속하사","reference":"시편 107:2","category":"$undefined"},{"id":"15703","book":"시편","book_name":"시편","chapter":107,"verse":3,"text":"동서 남북 각 지방에서부터 모으셨도다","reference":"시편 107:3","category":"$undefined"},{"id":"15704","book":"시편","book_name":"시편","chapter":107,"verse":4,"text":"저희가 광야 사막 길에서 방황하며 거할 성을 찾지 못하고","reference":"시편 107:4","category":"$undefined"},{"id":"15705","book":"시편","book_name":"시편","chapter":107,"verse":5,"text":"주리고 목마름으로 그 영혼이 속에서 피곤하였도다","reference":"시편 107:5","category":"$undefined"},{"id":"15706","book":"시편","book_name":"시편","chapter":107,"verse":6,"text":"이에 저희가 그 근심 중에 여호와께 부르짖으매 그 고통에서 건지시고","reference":"시편 107:6","category":"$undefined"},{"id":"15707","book":"시편","book_name":"시편","chapter":107,"verse":7,"text":"또 바른 길로 인도하사 거할 성에 이르게 하셨도다","reference":"시편 107:7","category":"$undefined"},{"id":"15708","book":"시편","book_name":"시편","chapter":107,"verse":8,"text":"여호와의 인자하심과 인생에게 행하신 기이한 일을 인하여 그를 찬송할지로다","reference":"시편 107:8","category":"$undefined"},{"id":"15709","book":"시편","book_name":"시편","chapter":107,"verse":9,"text":"저가 사모하는 영혼을 만족케 하시며 주린 영혼에게 좋은 것으로 채워주심이로다","reference":"시편 107:9","category":"$undefined"},{"id":"15710","book":"시편","book_name":"시편","chapter":107,"verse":10,"text":"사람이 흑암과 사망의 그늘에 앉으며 곤고와 쇠사슬에 매임은","reference":"시편 107:10","category":"$undefined"},{"id":"15711","book":"시편","book_name":"시편","chapter":107,"verse":11,"text":"하나님의 말씀을 거역하며 지존자의 뜻을 멸시함이라","reference":"시편 107:11","category":"$undefined"},{"id":"15712","book":"시편","book_name":"시편","chapter":107,"verse":12,"text":"그러므로 수고로 저희 마음을 낮추셨으니 저희가 엎드러져도 돕는 자가 없었도다","reference":"시편 107:12","category":"$undefined"},{"id":"15713","book":"시편","book_name":"시편","chapter":107,"verse":13,"text":"이에 저희가 그 근심 중에 여호와께 부르짖으매 그 고통에서 구원하시되","reference":"시편 107:13","category":"$undefined"},{"id":"15714","book":"시편","book_name":"시편","chapter":107,"verse":14,"text":"흑암과 사망의 그늘에서 인도하여 내시고 그 얽은 줄을 끊으셨도다","reference":"시편 107:14","category":"$undefined"},{"id":"15715","book":"시편","book_name":"시편","chapter":107,"verse":15,"text":"여호와의 인자하심과 인생에게 행하신 기이한 일을 인하여 그를 찬송할지로다","reference":"시편 107:15","category":"$undefined"},{"id":"15716","book":"시편","book_name":"시편","chapter":107,"verse":16,"text":"저가 놋문을 깨뜨리시며 쇠빗장을 꺾으셨음이로다","reference":"시편 107:16","category":"$undefined"},{"id":"15717","book":"시편","book_name":"시편","chapter":107,"verse":17,"text":"미련한 자는 저희 범과와 죄악의 연고로 곤난을 당하매","reference":"시편 107:17","category":"$undefined"},{"id":"15718","book":"시편","book_name":"시편","chapter":107,"verse":18,"text":"저희 혼이 각종 식물을 싫어하여 사망의 문에 가깝도다","reference":"시편 107:18","category":"$undefined"},{"id":"15719","book":"시편","book_name":"시편","chapter":107,"verse":19,"text":"이에 저희가 그 근심 중에서 여호와께 부르짖으매 그 고통에서 구원하시되","reference":"시편 107:19","category":"$undefined"},{"id":"15720","book":"시편","book_name":"시편","chapter":107,"verse":20,"text":"저가 그 말씀을 보내어 저희를 고치사 위경에서 건지시는도다","reference":"시편 107:20","category":"$undefined"},{"id":"15721","book":"시편","book_name":"시편","chapter":107,"verse":21,"text":"여호와의 인자하심과 인생에게 행하신 기이한 일을 인하여 그를 찬송할지로다","reference":"시편 107:21","category":"$undefined"},{"id":"15722","book":"시편","book_name":"시편","chapter":107,"verse":22,"text":"감사제를 드리며 노래하여 그 행사를 선포할지로다","reference":"시편 107:22","category":"$undefined"},{"id":"15723","book":"시편","book_name":"시편","chapter":107,"verse":23,"text":"선척을 바다에 띄우며 큰 물에서 영업하는 자는","reference":"시편 107:23","category":"$undefined"},{"id":"15724","book":"시편","book_name":"시편","chapter":107,"verse":24,"text":"여호와의 행사와 그 기사를 바다에서 보나니","reference":"시편 107:24","category":"$undefined"},{"id":"15725","book":"시편","book_name":"시편","chapter":107,"verse":25,"text":"여호와께서 명하신즉 광풍이 일어나서 바다 물결을 일으키는도다","reference":"시편 107:25","category":"$undefined"},{"id":"15726","book":"시편","book_name":"시편","chapter":107,"verse":26,"text":"저희가 하늘에 올랐다가 깊은 곳에 내리니 그 위험을 인하여 그 영혼이 녹는도다","reference":"시편 107:26","category":"$undefined"},{"id":"15727","book":"시편","book_name":"시편","chapter":107,"verse":27,"text":"저희가 이리 저리 구르며 취한 자 같이 비틀거리니 지각이 혼돈하도다","reference":"시편 107:27","category":"$undefined"},{"id":"15728","book":"시편","book_name":"시편","chapter":107,"verse":28,"text":"이에 저희가 그 근심 중에서 여호와께 부르짖으매 그 고통에서 인도하여 내시고","reference":"시편 107:28","category":"$undefined"},{"id":"15729","book":"시편","book_name":"시편","chapter":107,"verse":29,"text":"광풍을 평정히 하사 물결로 잔잔케 하시는도다","reference":"시편 107:29","category":"$undefined"},{"id":"15730","book":"시편","book_name":"시편","chapter":107,"verse":30,"text":"저희가 평온함을 인하여 기뻐하는 중에 여호와께서 저희를 소원의 항구로 인도하시는도다","reference":"시편 107:30","category":"$undefined"},{"id":"15731","book":"시편","book_name":"시편","chapter":107,"verse":31,"text":"여호와의 인자하심과 인생에게 행하신 기이한 일을 인하여 그를 찬송할지로다","reference":"시편 107:31","category":"$undefined"},{"id":"15732","book":"시편","book_name":"시편","chapter":107,"verse":32,"text":"백성의 회에서 저를 높이며 장로들의 자리에서 저를 찬송할지로다","reference":"시편 107:32","category":"$undefined"},{"id":"15733","book":"시편","book_name":"시편","chapter":107,"verse":33,"text":"여호와께서는 강을 변하여 광야가 되게 하시며 샘으로 마른 땅이되게 하시며","reference":"시편 107:33","category":"$undefined"},{"id":"15734","book":"시편","book_name":"시편","chapter":107,"verse":34,"text":"그 거민의 악을 인하여 옥토로 염밭이 되게 하시며","reference":"시편 107:34","category":"$undefined"},{"id":"15735","book":"시편","book_name":"시편","chapter":107,"verse":35,"text":"또 광야를 변하여 못이 되게 하시며 마른 땅으로 샘물이 되게 하시고","reference":"시편 107:35","category":"$undefined"},{"id":"15736","book":"시편","book_name":"시편","chapter":107,"verse":36,"text":"주린 자로 거기 거하게 하사 저희로 거할 성을 예비케 하시고","reference":"시편 107:36","category":"$undefined"},{"id":"15737","book":"시편","book_name":"시편","chapter":107,"verse":37,"text":"밭에 파종하며 포도원을 재배하여 소산을 취케 하시며","reference":"시편 107:37","category":"$undefined"},{"id":"15738","book":"시편","book_name":"시편","chapter":107,"verse":38,"text":"또 복을 주사 저희로 크게 번성케 하시고 그 가축이 감소치 않게 하실지라도","reference":"시편 107:38","category":"$undefined"},{"id":"15739","book":"시편","book_name":"시편","chapter":107,"verse":39,"text":"다시 압박과 곤란과 우환을 인하여 저희로 감소하여 비굴하게 하시는도다","reference":"시편 107:39","category":"$undefined"},{"id":"15740","book":"시편","book_name":"시편","chapter":107,"verse":40,"text":"여호와께서는 방백들에게 능욕을 부으시고 길 없는 황야에서 유리케 하시나","reference":"시편 107:40","category":"$undefined"},{"id":"15741","book":"시편","book_name":"시편","chapter":107,"verse":41,"text":"궁핍한 자는 곤란에서 높이 드시고 그 가족을 양무리 같게 하시나니","reference":"시편 107:41","category":"$undefined"},{"id":"15742","book":"시편","book_name":"시편","chapter":107,"verse":42,"text":"정직한 자는 보고 기뻐하며 모든 악인은 자기 입을 봉하리로다","reference":"시편 107:42","category":"$undefined"},{"id":"15743","book":"시편","book_name":"시편","chapter":107,"verse":43,"text":"지혜 있는 자들은 이 일에 주의하고 여호와의 인자하심을 깨달으리로다","reference":"시편 107:43","category":"$undefined"}],"bookSlug":"psalms"}]
