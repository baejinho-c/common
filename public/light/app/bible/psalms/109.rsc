2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":109,"verses":[{"id":"15757","book":"시편","book_name":"시편","chapter":109,"verse":1,"text":"(다윗의 시. 영장으로 한 노래) 나의 찬송하는 하나님이여, 잠잠하지 마옵소서","reference":"시편 109:1","category":"$undefined"},{"id":"15758","book":"시편","book_name":"시편","chapter":109,"verse":2,"text":"대저 저희가 악한 입과 궤사한 입을 열어 나를 치며 거짓된 혀로 내게 말하며","reference":"시편 109:2","category":"$undefined"},{"id":"15759","book":"시편","book_name":"시편","chapter":109,"verse":3,"text":"또 미워하는 말로 나를 두르고 무고히 나를 공격하였나이다","reference":"시편 109:3","category":"$undefined"},{"id":"15760","book":"시편","book_name":"시편","chapter":109,"verse":4,"text":"나는 사랑하나 저희는 도리어 나를 대적하니 나는 기도할 뿐이라","reference":"시편 109:4","category":"$undefined"},{"id":"15761","book":"시편","book_name":"시편","chapter":109,"verse":5,"text":"저희가 악으로 나의 선을 갚으며 미워함으로 나의 사랑을 갚았사오니","reference":"시편 109:5","category":"$undefined"},{"id":"15762","book":"시편","book_name":"시편","chapter":109,"verse":6,"text":"악인으로 저를 제어하게 하시며 대적으로 그 오른편에 서게 하소서","reference":"시편 109:6","category":"$undefined"},{"id":"15763","book":"시편","book_name":"시편","chapter":109,"verse":7,"text":"저가 판단을 받을 때에 죄를 지고 나오게 하시며 그 기도가 죄로 변케 하시며","reference":"시편 109:7","category":"$undefined"},{"id":"15764","book":"시편","book_name":"시편","chapter":109,"verse":8,"text":"그 년수를 단촉케 하시며 그 직분을 타인이 취하게 하시며","reference":"시편 109:8","category":"$undefined"},{"id":"15765","book":"시편","book_name":"시편","chapter":109,"verse":9,"text":"그 자녀는 고아가 되고 그 아내는 과부가 되며","reference":"시편 109:9","category":"$undefined"},{"id":"15766","book":"시편","book_name":"시편","chapter":109,"verse":10,"text":"그 자녀가 유리 구걸하며 그 황폐한 집을 떠나 빌어먹게 하소서","reference":"시편 109:10","category":"$undefined"},{"id":"15767","book":"시편","book_name":"시편","chapter":109,"verse":11,"text":"고리대금하는 자로 저의 소유를 다 취하게 하시며 저의 수고한 것을 외인이 탈취하게 하시며","reference":"시편 109:11","category":"$undefined"},{"id":"15768","book":"시편","book_name":"시편","chapter":109,"verse":12,"text":"저에게 은혜를 계속할 자가 없게 하시며 그 고아를 연휼할 자도 없게 하시며","reference":"시편 109:12","category":"$undefined"},{"id":"15769","book":"시편","book_name":"시편","chapter":109,"verse":13,"text":"그 후사가 끊어지게 하시며 후대에 저희 이름이 도말되게 하소서","reference":"시편 109:13","category":"$undefined"},{"id":"15770","book":"시편","book_name":"시편","chapter":109,"verse":14,"text":"여호와는 그 열조의 죄악을 기억하시며 그 어미의 죄를 도말하지마시고","reference":"시편 109:14","category":"$undefined"},{"id":"15771","book":"시편","book_name":"시편","chapter":109,"verse":15,"text":"그 죄악을 항상 여호와 앞에 있게 하사 저희 기념을 땅에서 끊으소서","reference":"시편 109:15","category":"$undefined"},{"id":"15772","book":"시편","book_name":"시편","chapter":109,"verse":16,"text":"저가 긍휼히 여길 일을 생각지 아니하고 가난하고 궁핍한 자와 마음이 상한 자를 핍박하여 죽이려 한 연고니이다","reference":"시편 109:16","category":"$undefined"},{"id":"15773","book":"시편","book_name":"시편","chapter":109,"verse":17,"text":"저가 저주하기를 좋아하더니 그것이 자기에게 임하고 축복하기를 기뻐 아니하더니 복이 저를 멀리 떠났으며","reference":"시편 109:17","category":"$undefined"},{"id":"15774","book":"시편","book_name":"시편","chapter":109,"verse":18,"text":"또 저주하기를 옷 입듯하더니 저주가 물같이 그 내부에 들어가며 기름 같이 그 뼈에 들어갔나이다","reference":"시편 109:18","category":"$undefined"},{"id":"15775","book":"시편","book_name":"시편","chapter":109,"verse":19,"text":"저주가 그 입는 옷 같고 항상 띠는 띠와 같게 하소서","reference":"시편 109:19","category":"$undefined"},{"id":"15776","book":"시편","book_name":"시편","chapter":109,"verse":20,"text":"이는 대적 곧 내 영혼을 대적하여 악담하는 자가 여호와께 받는 보응이니이다","reference":"시편 109:20","category":"$undefined"},{"id":"15777","book":"시편","book_name":"시편","chapter":109,"verse":21,"text":"주 여호와여, 주의 이름을 인하여 나를 선대하시며 주의 인자하심이 선함을 인하여 나를 건지소서","reference":"시편 109:21","category":"$undefined"},{"id":"15778","book":"시편","book_name":"시편","chapter":109,"verse":22,"text":"나는 가난하고 궁핍하여 중심이 상함이니이다","reference":"시편 109:22","category":"$undefined"},{"id":"15779","book":"시편","book_name":"시편","chapter":109,"verse":23,"text":"나의 가는 것은 석양 그림자 같고 또 메뚜기 같이 불려가오며","reference":"시편 109:23","category":"$undefined"},{"id":"15780","book":"시편","book_name":"시편","chapter":109,"verse":24,"text":"금식함을 인하여 내 무릎은 약하고 내 육체는 수척하오며","reference":"시편 109:24","category":"$undefined"},{"id":"15781","book":"시편","book_name":"시편","chapter":109,"verse":25,"text":"나는 또 저희의 훼방거리라 저희가 나를 본즉 머리를 흔드나이다","reference":"시편 109:25","category":"$undefined"},{"id":"15782","book":"시편","book_name":"시편","chapter":109,"verse":26,"text":"여호와 나의 하나님이여, 나를 도우시며 주의 인자하심을 좇아 나를 구원하소서","reference":"시편 109:26","category":"$undefined"},{"id":"15783","book":"시편","book_name":"시편","chapter":109,"verse":27,"text":"이것이 주의 손인 줄을 저희로 알게 하소서 여호와께서 이를 행하셨나이다","reference":"시편 109:27","category":"$undefined"},{"id":"15784","book":"시편","book_name":"시편","chapter":109,"verse":28,"text":"저희는 저주하여도 주는 내게 복을 주소서 ! 저희는 일어날 때에 수치를 당할지라도 주의 종은 즐거워하리이다","reference":"시편 109:28","category":"$undefined"},{"id":"15785","book":"시편","book_name":"시편","chapter":109,"verse":29,"text":"나의 대적으로 욕을 옷입듯하게 하시며 자기 수치를 겉옷 같이 입게 하소서","reference":"시편 109:29","category":"$undefined"},{"id":"15786","book":"시편","book_name":"시편","chapter":109,"verse":30,"text":"내가 입으로 여호와께 크게 감사하며 무리 중에서 찬송하리니","reference":"시편 109:30","category":"$undefined"},{"id":"15787","book":"시편","book_name":"시편","chapter":109,"verse":31,"text":"저가 궁핍한 자의 우편에 서사 그 영혼을 판단하려 하는 자에게 구원하실 것임이로다","reference":"시편 109:31","category":"$undefined"}],"bookSlug":"psalms"}]
