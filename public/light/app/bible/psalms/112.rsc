2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":112,"verses":[{"id":"15805","book":"시편","book_name":"시편","chapter":112,"verse":1,"text":"할렐루야 ! 여호와를 경외하며 그 계명을 크게 즐거워하는 자는 복이 있도다","reference":"시편 112:1","category":"$undefined"},{"id":"15806","book":"시편","book_name":"시편","chapter":112,"verse":2,"text":"그 후손이 땅에서 강성함이여 정직자의 후대가 복이 있으리로다","reference":"시편 112:2","category":"$undefined"},{"id":"15807","book":"시편","book_name":"시편","chapter":112,"verse":3,"text":"부요와 재물이 그 집에 있음이여 그 의가 영원히 있으리로다","reference":"시편 112:3","category":"$undefined"},{"id":"15808","book":"시편","book_name":"시편","chapter":112,"verse":4,"text":"정직한 자에게는 흑암 중에 빛이 일어나나니 그는 어질고 자비하고 의로운 자로다","reference":"시편 112:4","category":"$undefined"},{"id":"15809","book":"시편","book_name":"시편","chapter":112,"verse":5,"text":"은혜를 베풀며 꾸이는 자는 잘 되나니 그 일을 공의로 하리로다","reference":"시편 112:5","category":"$undefined"},{"id":"15810","book":"시편","book_name":"시편","chapter":112,"verse":6,"text":"저가 영영히 요동치 아니함이여 의인은 영원히 기념하게 되리로다","reference":"시편 112:6","category":"$undefined"},{"id":"15811","book":"시편","book_name":"시편","chapter":112,"verse":7,"text":"그는 흉한 소식을 두려워 아니함이여, 여호와를 의뢰하고 그 마음을 굳게 정하였도다","reference":"시편 112:7","category":"$undefined"},{"id":"15812","book":"시편","book_name":"시편","chapter":112,"verse":8,"text":"그 마음이 견고하여 두려워 아니할 것이라 그 대적의 받는 보응을 필경 보리로다","reference":"시편 112:8","category":"$undefined"},{"id":"15813","book":"시편","book_name":"시편","chapter":112,"verse":9,"text":"저가 재물을 흩어 빈궁한 자에게 주었으니 그 의가 영원히 있고 그 뿔이 영화로이 들리리로다","reference":"시편 112:9","category":"$undefined"},{"id":"15814","book":"시편","book_name":"시편","chapter":112,"verse":10,"text":"악인은 이를 보고 한하여 이를 갈면서 소멸하리니 악인의 소욕은 멸망하리로다","reference":"시편 112:10","category":"$undefined"}],"bookSlug":"psalms"}]
