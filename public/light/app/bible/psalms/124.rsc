2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":124,"verses":[{"id":"16104","book":"시편","book_name":"시편","chapter":124,"verse":1,"text":"(다윗의 곧 성전에 올라가는 노래) 이스라엘은 이제 말하기를 여호와께서 우리 편에 계시지 아니하고","reference":"시편 124:1","category":"$undefined"},{"id":"16105","book":"시편","book_name":"시편","chapter":124,"verse":2,"text":"사람들이 우리를 치러 일어날 때에 여호와께서 우리 편에 계시지 아니하셨더면","reference":"시편 124:2","category":"$undefined"},{"id":"16106","book":"시편","book_name":"시편","chapter":124,"verse":3,"text":"그 때에 저희의 노가 우리를 대하여 맹렬하여 우리를 산 채로 삼켰을 것이며","reference":"시편 124:3","category":"$undefined"},{"id":"16107","book":"시편","book_name":"시편","chapter":124,"verse":4,"text":"그 때에 물이 우리를 엄몰하며 시내가 우리 영혼을 잠갔을 것이며","reference":"시편 124:4","category":"$undefined"},{"id":"16108","book":"시편","book_name":"시편","chapter":124,"verse":5,"text":"그 때에 넘치는 물이 우리 영혼을 잠갔을 것이라 할 것이로다","reference":"시편 124:5","category":"$undefined"},{"id":"16109","book":"시편","book_name":"시편","chapter":124,"verse":6,"text":"우리를 저희 이에 주어 씹히지 않게 하신 여호와를 찬송할지로다 !","reference":"시편 124:6","category":"$undefined"},{"id":"16110","book":"시편","book_name":"시편","chapter":124,"verse":7,"text":"우리 혼이 새가 사냥군의 올무에서 벗어남 같이 되었나니 올무가 끊어지므로 우리가 벗어났도다","reference":"시편 124:7","category":"$undefined"},{"id":"16111","book":"시편","book_name":"시편","chapter":124,"verse":8,"text":"우리의 도움은 천지를 지으신 여호와의 이름에 있도다","reference":"시편 124:8","category":"$undefined"}],"bookSlug":"psalms"}]
