2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":132,"verses":[{"id":"16153","book":"시편","book_name":"시편","chapter":132,"verse":1,"text":"(성전에 올라가는 노래) 여호와여, 다윗을 위하여 그의 모든 근심한 것을 기억하소서","reference":"시편 132:1","category":"$undefined"},{"id":"16154","book":"시편","book_name":"시편","chapter":132,"verse":2,"text":"저가 여호와께 맹세하며 야곱의 전능자에게 서원하기를","reference":"시편 132:2","category":"$undefined"},{"id":"16155","book":"시편","book_name":"시편","chapter":132,"verse":3,"text":"내가 실로 나의 거하는 장막에 들어가지 아니하며 내 침상에 오르지 아니하며","reference":"시편 132:3","category":"$undefined"},{"id":"16156","book":"시편","book_name":"시편","chapter":132,"verse":4,"text":"내 눈으로 잠들게 아니하며 내 눈꺼풀로 졸게 아니하기를","reference":"시편 132:4","category":"$undefined"},{"id":"16157","book":"시편","book_name":"시편","chapter":132,"verse":5,"text":"여호와의 처소 곧 야곱의 전능자의 성막을 발견하기까지 하리라 하였나이다","reference":"시편 132:5","category":"$undefined"},{"id":"16158","book":"시편","book_name":"시편","chapter":132,"verse":6,"text":"우리가 그것이 에브라다에 있다 함을 들었더니 나무 밭에서 찾았도다","reference":"시편 132:6","category":"$undefined"},{"id":"16159","book":"시편","book_name":"시편","chapter":132,"verse":7,"text":"우리가 그의 성막에 들어가서 그 발등상 앞에서 경배하리로다","reference":"시편 132:7","category":"$undefined"},{"id":"16160","book":"시편","book_name":"시편","chapter":132,"verse":8,"text":"여호와여, 일어나사 주의 권능의 궤와 함께 평안한 곳으로 들어가소서","reference":"시편 132:8","category":"$undefined"},{"id":"16161","book":"시편","book_name":"시편","chapter":132,"verse":9,"text":"주의 제사장들은 의를 입고 주의 성도들은 즐거이 외칠지어다","reference":"시편 132:9","category":"$undefined"},{"id":"16162","book":"시편","book_name":"시편","chapter":132,"verse":10,"text":"주의 종 다윗을 위하여 주의 기름 받은 자의 얼굴을 물리치지 마옵소서","reference":"시편 132:10","category":"$undefined"},{"id":"16163","book":"시편","book_name":"시편","chapter":132,"verse":11,"text":"여호와께서 다윗에게 성실히 맹세하셨으니 변치 아니하실지라 이르시기를 네 몸의 소생을 네 위에 둘지라","reference":"시편 132:11","category":"$undefined"},{"id":"16164","book":"시편","book_name":"시편","chapter":132,"verse":12,"text":"네 자손이 내 언약과 저희에게 교훈하는 내 증거를 지킬진대 저희 후손도 영원히 네 위에 앉으리라 하셨도다","reference":"시편 132:12","category":"$undefined"},{"id":"16165","book":"시편","book_name":"시편","chapter":132,"verse":13,"text":"여호와께서 시온을 택하시고 자기 거처를 삼고자 하여 이르시기를","reference":"시편 132:13","category":"$undefined"},{"id":"16166","book":"시편","book_name":"시편","chapter":132,"verse":14,"text":"이는 나의 영원히 쉴 곳이라 내가 여기 거할 것은 이를 원하였음이로다","reference":"시편 132:14","category":"$undefined"},{"id":"16167","book":"시편","book_name":"시편","chapter":132,"verse":15,"text":"내가 이 성의 식료품에 풍족히 복을 주고 양식으로 그 빈민을 만족케 하리로다","reference":"시편 132:15","category":"$undefined"},{"id":"16168","book":"시편","book_name":"시편","chapter":132,"verse":16,"text":"내가 그 제사장들에게 구원으로 입히리니 그 성도들은 즐거움으로 외치리로다","reference":"시편 132:16","category":"$undefined"},{"id":"16169","book":"시편","book_name":"시편","chapter":132,"verse":17,"text":"내가 거기서 다윗에게 뿔이 나게 할 것이라 내가 내 기름 부은 자를 위하여 등을 예비하였도다","reference":"시편 132:17","category":"$undefined"},{"id":"16170","book":"시편","book_name":"시편","chapter":132,"verse":18,"text":"내가 저의 원수에게는 수치로 입히고 저에게는 면류관이 빛나게 하리라 하셨도다","reference":"시편 132:18","category":"$undefined"}],"bookSlug":"psalms"}]
