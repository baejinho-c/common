2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":136,"verses":[{"id":"16198","book":"시편","book_name":"시편","chapter":136,"verse":1,"text":"여호와께 감사하라 ! 그는 선하시며 그 인자하심이 영원함이로다","reference":"시편 136:1","category":"$undefined"},{"id":"16199","book":"시편","book_name":"시편","chapter":136,"verse":2,"text":"모든 신에 뛰어나신 하나님께 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:2","category":"$undefined"},{"id":"16200","book":"시편","book_name":"시편","chapter":136,"verse":3,"text":"모든 주에 뛰어나신 주께 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:3","category":"$undefined"},{"id":"16201","book":"시편","book_name":"시편","chapter":136,"verse":4,"text":"홀로 큰 기사를 행하시는 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:4","category":"$undefined"},{"id":"16202","book":"시편","book_name":"시편","chapter":136,"verse":5,"text":"지혜로 하늘을 지으신 이에게 감사하라 ! 그 인자하심이 영원함이 로다","reference":"시편 136:5","category":"$undefined"},{"id":"16203","book":"시편","book_name":"시편","chapter":136,"verse":6,"text":"땅을 물 위에 펴신이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:6","category":"$undefined"},{"id":"16204","book":"시편","book_name":"시편","chapter":136,"verse":7,"text":"큰 빛들을 지으신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:7","category":"$undefined"},{"id":"16205","book":"시편","book_name":"시편","chapter":136,"verse":8,"text":"해로 낮을 주관케 하신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:8","category":"$undefined"},{"id":"16206","book":"시편","book_name":"시편","chapter":136,"verse":9,"text":"달과 별들로 밤을 주관케 하신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:9","category":"$undefined"},{"id":"16207","book":"시편","book_name":"시편","chapter":136,"verse":10,"text":"애굽의 장자를 치신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:10","category":"$undefined"},{"id":"16208","book":"시편","book_name":"시편","chapter":136,"verse":11,"text":"이스라엘을 저희 중에서 인도하여 내신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:11","category":"$undefined"},{"id":"16209","book":"시편","book_name":"시편","chapter":136,"verse":12,"text":"강한 손과 펴신 팔로 인도하여 내신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:12","category":"$undefined"},{"id":"16210","book":"시편","book_name":"시편","chapter":136,"verse":13,"text":"홍해를 가르신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:13","category":"$undefined"},{"id":"16211","book":"시편","book_name":"시편","chapter":136,"verse":14,"text":"이스라엘로 그 가운데로 통과케 하신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:14","category":"$undefined"},{"id":"16212","book":"시편","book_name":"시편","chapter":136,"verse":15,"text":"바로와 그 군대를 홍해에 엎드러뜨리 신이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:15","category":"$undefined"},{"id":"16213","book":"시편","book_name":"시편","chapter":136,"verse":16,"text":"그 백성을 인도하여 광야로 통과케 하신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:16","category":"$undefined"},{"id":"16214","book":"시편","book_name":"시편","chapter":136,"verse":17,"text":"큰 왕들을 치신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:17","category":"$undefined"},{"id":"16215","book":"시편","book_name":"시편","chapter":136,"verse":18,"text":"유명한 왕들을 죽이신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:18","category":"$undefined"},{"id":"16216","book":"시편","book_name":"시편","chapter":136,"verse":19,"text":"아모리인의 왕 시혼을 죽이신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:19","category":"$undefined"},{"id":"16217","book":"시편","book_name":"시편","chapter":136,"verse":20,"text":"바산 왕 옥을 죽이신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:20","category":"$undefined"},{"id":"16218","book":"시편","book_name":"시편","chapter":136,"verse":21,"text":"저희의 땅을 기업으로 주신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:21","category":"$undefined"},{"id":"16219","book":"시편","book_name":"시편","chapter":136,"verse":22,"text":"곧 그 종 이스라엘에게 기업으로 주신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:22","category":"$undefined"},{"id":"16220","book":"시편","book_name":"시편","chapter":136,"verse":23,"text":"우리를 비천한 데서 기념하신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:23","category":"$undefined"},{"id":"16221","book":"시편","book_name":"시편","chapter":136,"verse":24,"text":"우리를 우리 대적에게서 건지신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:24","category":"$undefined"},{"id":"16222","book":"시편","book_name":"시편","chapter":136,"verse":25,"text":"모든 육체에게 식물을 주신 이에게 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:25","category":"$undefined"},{"id":"16223","book":"시편","book_name":"시편","chapter":136,"verse":26,"text":"하늘의 하나님께 감사하라 ! 그 인자하심이 영원함이로다","reference":"시편 136:26","category":"$undefined"}],"bookSlug":"psalms"}]
