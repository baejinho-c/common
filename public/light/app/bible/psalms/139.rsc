2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":139,"verses":[{"id":"16241","book":"시편","book_name":"시편","chapter":139,"verse":1,"text":"(다윗의 시. 영장으로 한 노래) 여호와여, 주께서 나를 감찰하시고 아셨나이다","reference":"시편 139:1","category":"$undefined"},{"id":"16242","book":"시편","book_name":"시편","chapter":139,"verse":2,"text":"주께서 나의 앉고 일어섬을 아시며 멀리서도 나의 생각을 통촉하시오며","reference":"시편 139:2","category":"$undefined"},{"id":"16243","book":"시편","book_name":"시편","chapter":139,"verse":3,"text":"나의 길과 눕는 것을 감찰하시며 나의 모든 행위를 익히 아시오니","reference":"시편 139:3","category":"$undefined"},{"id":"16244","book":"시편","book_name":"시편","chapter":139,"verse":4,"text":"여호와여, 내 혀의 말을 알지 못하시는 것이 하나도 없으시니이다","reference":"시편 139:4","category":"$undefined"},{"id":"16245","book":"시편","book_name":"시편","chapter":139,"verse":5,"text":"주께서 나의 전후를 두르시며 내게 안수하셨나이다","reference":"시편 139:5","category":"$undefined"},{"id":"16246","book":"시편","book_name":"시편","chapter":139,"verse":6,"text":"이 지식이 내게 너무 기이하니 높아서 내가 능히 미치지 못하나이다","reference":"시편 139:6","category":"$undefined"},{"id":"16247","book":"시편","book_name":"시편","chapter":139,"verse":7,"text":"내가 주의 신을 떠나 어디로 가며 주의 앞에서 어디로 피하리이까","reference":"시편 139:7","category":"$undefined"},{"id":"16248","book":"시편","book_name":"시편","chapter":139,"verse":8,"text":"내가 하늘에 올라갈지라도 거기 계시며 음부에 내 자리를 펼지라도 거기 계시니이다","reference":"시편 139:8","category":"$undefined"},{"id":"16249","book":"시편","book_name":"시편","chapter":139,"verse":9,"text":"내가 새벽 날개를 치며 바다 끝에 가서 거할지라도","reference":"시편 139:9","category":"$undefined"},{"id":"16250","book":"시편","book_name":"시편","chapter":139,"verse":10,"text":"곧 거기서도 주의 손이 나를 인도하시며 주의 오른손이 나를 붙드시리이다","reference":"시편 139:10","category":"$undefined"},{"id":"16251","book":"시편","book_name":"시편","chapter":139,"verse":11,"text":"내가 혹시 말하기를 흑암이 정녕 나를 덮고 나를 두른 빛은 밤이 되리라 할지라도","reference":"시편 139:11","category":"$undefined"},{"id":"16252","book":"시편","book_name":"시편","chapter":139,"verse":12,"text":"주에게서는 흑암이 숨기지 못하며 밤이 낮과 같이 비취나니 주에게는 흑암과 빛이 일반이니이다","reference":"시편 139:12","category":"$undefined"},{"id":"16253","book":"시편","book_name":"시편","chapter":139,"verse":13,"text":"주께서 내 장부를 지으시며 나의 모태에서 나를 조직하셨나이다","reference":"시편 139:13","category":"$undefined"},{"id":"16254","book":"시편","book_name":"시편","chapter":139,"verse":14,"text":"내가 주께 감사하옴은 나를 지으심이 신묘막측하심이라 주의 행사가 기이함을 내 영혼이 잘 아나이다","reference":"시편 139:14","category":"$undefined"},{"id":"16255","book":"시편","book_name":"시편","chapter":139,"verse":15,"text":"내가 은밀한 데서 지음을 받고 땅의 깊은 곳에서 기이하게 지음을 받은 때에 나의 형체가 주의 앞에 숨기우지 못하였나이다","reference":"시편 139:15","category":"$undefined"},{"id":"16256","book":"시편","book_name":"시편","chapter":139,"verse":16,"text":"내 형질이 이루기 전에 주의 눈이 보셨으며 나를 위하여 정한 날이 하나도 되기 전에 주의 책에 다 기록이 되었나이다","reference":"시편 139:16","category":"$undefined"},{"id":"16257","book":"시편","book_name":"시편","chapter":139,"verse":17,"text":"하나님이여, 주의 생각이 내게 어찌 그리 보배로우신지요 그 수가 어찌 그리 많은지요","reference":"시편 139:17","category":"$undefined"},{"id":"16258","book":"시편","book_name":"시편","chapter":139,"verse":18,"text":"내가 세려고 할지라도 그 수가 모래보다 많도소이다 내가 깰 때에도 오히려 주와 함께 있나이다","reference":"시편 139:18","category":"$undefined"},{"id":"16259","book":"시편","book_name":"시편","chapter":139,"verse":19,"text":"하나님이여, 주께서 정녕히 악인을 죽이시리이다 피흘리기를 즐기는 자들아 나를 떠날지어다","reference":"시편 139:19","category":"$undefined"},{"id":"16260","book":"시편","book_name":"시편","chapter":139,"verse":20,"text":"저희가 주를 대하여 악하게 말하며 주의 원수들이 헛되이 주의 이름을 칭하나이다","reference":"시편 139:20","category":"$undefined"},{"id":"16261","book":"시편","book_name":"시편","chapter":139,"verse":21,"text":"여호와여, 내가 주를 미워하는 자를 미워하지 아니하오며 주를 치러 일어나는 자를 한하지 아니하나이까","reference":"시편 139:21","category":"$undefined"},{"id":"16262","book":"시편","book_name":"시편","chapter":139,"verse":22,"text":"내가 저희를 심히 미워하니 저희는 나의 원수니이다","reference":"시편 139:22","category":"$undefined"},{"id":"16263","book":"시편","book_name":"시편","chapter":139,"verse":23,"text":"하나님이여, 나를 살피사 내 마음을 아시며 나를 시험하사 내 뜻을 아옵소서","reference":"시편 139:23","category":"$undefined"},{"id":"16264","book":"시편","book_name":"시편","chapter":139,"verse":24,"text":"내게 무슨 악한 행위가 있나 보시고 나를 영원한 길로 인도하소서","reference":"시편 139:24","category":"$undefined"}],"bookSlug":"psalms"}]
