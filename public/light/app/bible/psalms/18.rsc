2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":18,"verses":[{"id":"14120","book":"시편","book_name":"시편","chapter":18,"verse":1,"text":"(여호와의 종 다윗의 시. 영장으로 한 노래. 여호와께서 다윗을 그 모든 원수와 사울의 손에서 구원하신 날에 다윗이 이 노래의 말로 여호와께 아뢰어 가로되) 나의 힘이 되신 여호와여, 내가 주를 사랑하나이다","reference":"시편 18:1","category":"$undefined"},{"id":"14121","book":"시편","book_name":"시편","chapter":18,"verse":2,"text":"여호와는 나의 반석이시요, 나의 요새시요, 나를 건지시는 자시요, 나의 하나님이시요, 나의 피할 바위시요, 나의 방패시요, 나의 구원의 뿔이시요, 나의 산성이시로다","reference":"시편 18:2","category":"$undefined"},{"id":"14122","book":"시편","book_name":"시편","chapter":18,"verse":3,"text":"내가 찬송 받으실 여호와께 아뢰리니 내 원수들에게서 구원을 얻으리로다","reference":"시편 18:3","category":"$undefined"},{"id":"14123","book":"시편","book_name":"시편","chapter":18,"verse":4,"text":"사망의 줄이 나를 얽고 불의의 창수가 나를 두렵게 하였으며","reference":"시편 18:4","category":"$undefined"},{"id":"14124","book":"시편","book_name":"시편","chapter":18,"verse":5,"text":"음부의 줄이 나를 두르고 사망의 올무가 내게 이르렀도다","reference":"시편 18:5","category":"$undefined"},{"id":"14125","book":"시편","book_name":"시편","chapter":18,"verse":6,"text":"내가 환난에서 여호와께 아뢰며 나의 하나님께 부르짖었더니 저가 그 전에서 내 소리를 들으심이여 그 앞에서 나의 부르짖음이 그 귀에 들렸도다","reference":"시편 18:6","category":"$undefined"},{"id":"14126","book":"시편","book_name":"시편","chapter":18,"verse":7,"text":"이에 땅이 진동하고 산의 터도 요동하였으니 그의 진노를 인함이로다","reference":"시편 18:7","category":"$undefined"},{"id":"14127","book":"시편","book_name":"시편","chapter":18,"verse":8,"text":"그 코에서 연기가 오르고 입에서 불이 나와 사름이여 그 불에 숯이 피었도다","reference":"시편 18:8","category":"$undefined"},{"id":"14128","book":"시편","book_name":"시편","chapter":18,"verse":9,"text":"저가 또 하늘을 드리우시고 강림하시니 그 발 아래는 어둑캄캄하도다","reference":"시편 18:9","category":"$undefined"},{"id":"14129","book":"시편","book_name":"시편","chapter":18,"verse":10,"text":"그룹을 타고 날으심이여 바람 날개로 높이 뜨셨도다","reference":"시편 18:10","category":"$undefined"},{"id":"14130","book":"시편","book_name":"시편","chapter":18,"verse":11,"text":"저가 흑암으로 그 숨는 곳을 삼으사 장막 같이 자기를 두르게 하심이여 곧 물의 흑암과 공중의 빽빽한 구름으로 그리하시도다","reference":"시편 18:11","category":"$undefined"},{"id":"14131","book":"시편","book_name":"시편","chapter":18,"verse":12,"text":"그 앞에 광채로 인하여 빽빽한 구름이 지나며 우박과 숯불이 내리도다","reference":"시편 18:12","category":"$undefined"},{"id":"14132","book":"시편","book_name":"시편","chapter":18,"verse":13,"text":"여호와께서 하늘에서 뇌성을 발하시고 지존하신 자가 음성을 내시며 우박과 숯불이 내리도다","reference":"시편 18:13","category":"$undefined"},{"id":"14133","book":"시편","book_name":"시편","chapter":18,"verse":14,"text":"그 살을 날려 저희를 흩으심이여 많은 번개로 파하셨도다","reference":"시편 18:14","category":"$undefined"},{"id":"14134","book":"시편","book_name":"시편","chapter":18,"verse":15,"text":"이럴 때에 여호와의 꾸지람과 콧김을 인하여 물밑이 드러나고 세상의 터가 나타났도다","reference":"시편 18:15","category":"$undefined"},{"id":"14135","book":"시편","book_name":"시편","chapter":18,"verse":16,"text":"저가 위에서 보내사 나를 취하심이여 많은 물에서 나를 건져 내셨도다","reference":"시편 18:16","category":"$undefined"},{"id":"14136","book":"시편","book_name":"시편","chapter":18,"verse":17,"text":"나를 강한 원수와 미워하는 자에게서 건지셨음이여 저희는 나보다 힘센 연고로다","reference":"시편 18:17","category":"$undefined"},{"id":"14137","book":"시편","book_name":"시편","chapter":18,"verse":18,"text":"저희가 나의 재앙의 날에 내게 이르렀으나 여호와께서 나의 의지가 되셨도다","reference":"시편 18:18","category":"$undefined"},{"id":"14138","book":"시편","book_name":"시편","chapter":18,"verse":19,"text":"나를 또 넓은 곳으로 인도하시고 나를 기뻐하심으로 구원하셨도다","reference":"시편 18:19","category":"$undefined"},{"id":"14139","book":"시편","book_name":"시편","chapter":18,"verse":20,"text":"여호와께서 내 의를 따라 상 주시며 내 손의 깨끗함을 좇아 갚으셨으니","reference":"시편 18:20","category":"$undefined"},{"id":"14140","book":"시편","book_name":"시편","chapter":18,"verse":21,"text":"이는 내가 여호와의 도를 지키고 악하게 내 하나님을 떠나지 아니 하였으며","reference":"시편 18:21","category":"$undefined"},{"id":"14141","book":"시편","book_name":"시편","chapter":18,"verse":22,"text":"그 모든 규례가 내 앞에 있고 내게서 그 율례를 버리지 아니하였음이로다","reference":"시편 18:22","category":"$undefined"},{"id":"14142","book":"시편","book_name":"시편","chapter":18,"verse":23,"text":"내가 또한 그 앞에 완전하여 나의 죄악에서 스스로 지켰나니","reference":"시편 18:23","category":"$undefined"},{"id":"14143","book":"시편","book_name":"시편","chapter":18,"verse":24,"text":"그러므로 여호와께서 내 의를 따라 갚으시되 그 목전에 내 손의 깨끗한대로 내게 갚으셨도다","reference":"시편 18:24","category":"$undefined"},{"id":"14144","book":"시편","book_name":"시편","chapter":18,"verse":25,"text":"자비한 자에게는 주의 자비하심을 나타내시며 완전한 자에게는 주의 완전하심을 보이시며","reference":"시편 18:25","category":"$undefined"},{"id":"14145","book":"시편","book_name":"시편","chapter":18,"verse":26,"text":"깨끗한 자에게는 주의 깨끗하심을 보이시며 사특한 자에게는 주의 거스리심을 보이시리니","reference":"시편 18:26","category":"$undefined"},{"id":"14146","book":"시편","book_name":"시편","chapter":18,"verse":27,"text":"주께서 곤고한 백성은 구원하시고 교만한 눈은 낮추시리이다","reference":"시편 18:27","category":"$undefined"},{"id":"14147","book":"시편","book_name":"시편","chapter":18,"verse":28,"text":"주께서 나의 등불을 켜심이여, 여호와 내 하나님이 내 흑암을 밝히시리이다","reference":"시편 18:28","category":"$undefined"},{"id":"14148","book":"시편","book_name":"시편","chapter":18,"verse":29,"text":"내가 주를 의뢰하고 적군에 달리며 내 하나님을 의지하고 담을 뛰어 넘나이다","reference":"시편 18:29","category":"$undefined"},{"id":"14149","book":"시편","book_name":"시편","chapter":18,"verse":30,"text":"하나님의 도는 완전하고 여호와의 말씀은 정미하니 저는 자기에게 피하는 모든 자의 방패시로다","reference":"시편 18:30","category":"$undefined"},{"id":"14150","book":"시편","book_name":"시편","chapter":18,"verse":31,"text":"여호와 외에 누가 하나님이며 우리 하나님 외에 누가 반석이뇨","reference":"시편 18:31","category":"$undefined"},{"id":"14151","book":"시편","book_name":"시편","chapter":18,"verse":32,"text":"이 하나님이 힘으로 내게 띠 띠우시며 내 길을 완전케 하시며","reference":"시편 18:32","category":"$undefined"},{"id":"14152","book":"시편","book_name":"시편","chapter":18,"verse":33,"text":"나의 발로 암사슴 발 같게 하시며 나를 나의 높은 곳에 세우시며","reference":"시편 18:33","category":"$undefined"},{"id":"14153","book":"시편","book_name":"시편","chapter":18,"verse":34,"text":"내 손을 가르쳐 싸우게 하시니 내 팔이 놋 활을 당기도다","reference":"시편 18:34","category":"$undefined"},{"id":"14154","book":"시편","book_name":"시편","chapter":18,"verse":35,"text":"주께서 또 주의 구원하는 방패를 내게 주시며 주의 오른손이 나를 붙들고 주의 온유함이 나를 크게 하셨나이다","reference":"시편 18:35","category":"$undefined"},{"id":"14155","book":"시편","book_name":"시편","chapter":18,"verse":36,"text":"내 걸음을 넓게 하셨고 나로 실족지 않게 하셨나이다","reference":"시편 18:36","category":"$undefined"},{"id":"14156","book":"시편","book_name":"시편","chapter":18,"verse":37,"text":"내가 내 원수를 따라 미치리니 저희가 망하기 전에는 돌이키지 아니하리이다","reference":"시편 18:37","category":"$undefined"},{"id":"14157","book":"시편","book_name":"시편","chapter":18,"verse":38,"text":"내가 저희를 쳐서 능히 일어나지 못하게 하리니 저희가 내 발 아래 엎드러지리이다","reference":"시편 18:38","category":"$undefined"},{"id":"14158","book":"시편","book_name":"시편","chapter":18,"verse":39,"text":"대저 주께서 나로 전쟁케 하려고 능력으로 내게 띠 띠우사 일어나 나를 치는 자로 내게 굴복케 하셨나이다","reference":"시편 18:39","category":"$undefined"},{"id":"14159","book":"시편","book_name":"시편","chapter":18,"verse":40,"text":"주께서 또 내 원수들로 등을 내게로 향하게 하시고 나로 나를 미워 하는 자를 끊어버리게 하셨나이다","reference":"시편 18:40","category":"$undefined"},{"id":"14160","book":"시편","book_name":"시편","chapter":18,"verse":41,"text":"저희가 부르짖으나 구원할 자가 없었고 여호와께 부르짖어도 대답지 아니하셨나이다","reference":"시편 18:41","category":"$undefined"},{"id":"14161","book":"시편","book_name":"시편","chapter":18,"verse":42,"text":"내가 저희를 바람 앞에 티끌 같이 부숴뜨리고 거리의 진흙 같이 쏟아 버렸나이다","reference":"시편 18:42","category":"$undefined"},{"id":"14162","book":"시편","book_name":"시편","chapter":18,"verse":43,"text":"주께서 나를 백성의 다툼에서 건지시고 열방의 으뜸을 삼으셨으니 내가 알지 못하는 백성이 나를 섬기리이다","reference":"시편 18:43","category":"$undefined"},{"id":"14163","book":"시편","book_name":"시편","chapter":18,"verse":44,"text":"저희가 내 풍성을 들은 즉시로 내게 순복함이여 이방인들이 내게 복종하리로다","reference":"시편 18:44","category":"$undefined"},{"id":"14164","book":"시편","book_name":"시편","chapter":18,"verse":45,"text":"이방인들이 쇠미하여 그 견고한 곳에서 떨며 나오리로다","reference":"시편 18:45","category":"$undefined"},{"id":"14165","book":"시편","book_name":"시편","chapter":18,"verse":46,"text":"여호와는 생존하시니 나의 반석을 찬송하며 내 구원의 하나님을 높일지로다","reference":"시편 18:46","category":"$undefined"},{"id":"14166","book":"시편","book_name":"시편","chapter":18,"verse":47,"text":"이 하나님이 나를 위하여 보수하시고 민족들로 내게 복종케 하시도다","reference":"시편 18:47","category":"$undefined"},{"id":"14167","book":"시편","book_name":"시편","chapter":18,"verse":48,"text":"주께서 나를 내 원수들에게서 구조하시니 주께서 실로 나를 대적하는 자의 위에 나를 드시고 나를 강포한 자에게서 건지시나이다","reference":"시편 18:48","category":"$undefined"},{"id":"14168","book":"시편","book_name":"시편","chapter":18,"verse":49,"text":"여호와여, 이러므로 내가 열방 중에서 주께 감사하며 주의 이름을 찬송하리이다","reference":"시편 18:49","category":"$undefined"},{"id":"14169","book":"시편","book_name":"시편","chapter":18,"verse":50,"text":"여호와께서 그 왕에게 큰 구원을 주시며 기름 부음 받은 자에게 인자를 베푸심이여 영영토록 다윗과 그 후손에게로다","reference":"시편 18:50","category":"$undefined"}],"bookSlug":"psalms"}]
