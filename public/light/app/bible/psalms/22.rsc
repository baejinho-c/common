2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":22,"verses":[{"id":"14206","book":"시편","book_name":"시편","chapter":22,"verse":1,"text":"(다윗의 시. 영장으로 아앨렛샤할에 맞춘 노래) 내 하나님이여, 내 하나님이여, 어찌 나를 버리셨나이까 ? 어찌 나를 멀리하여 돕지 아니하옵시며 내 신음하는 소리를 듣지 아니하시나이까 ?","reference":"시편 22:1","category":"$undefined"},{"id":"14207","book":"시편","book_name":"시편","chapter":22,"verse":2,"text":"내 하나님이여, 내가 낮에도 부르짖고 밤에도 잠잠치 아니하오나 응답지 아니하시나이다","reference":"시편 22:2","category":"$undefined"},{"id":"14208","book":"시편","book_name":"시편","chapter":22,"verse":3,"text":"이스라엘의 찬송 중에 거하시는 주여, 주는 거룩하시니이다","reference":"시편 22:3","category":"$undefined"},{"id":"14209","book":"시편","book_name":"시편","chapter":22,"verse":4,"text":"우리 열조가 주께 의뢰하였고 의뢰하였으므로 저희를 건지셨나이다","reference":"시편 22:4","category":"$undefined"},{"id":"14210","book":"시편","book_name":"시편","chapter":22,"verse":5,"text":"저희가 주께 부르짖어 구원을 얻고 주께 의뢰하여 수치를 당치 아니하였나이다","reference":"시편 22:5","category":"$undefined"},{"id":"14211","book":"시편","book_name":"시편","chapter":22,"verse":6,"text":"나는 벌레요 사람이 아니라 사람의 훼방거리요 백성의 조롱거리니이다","reference":"시편 22:6","category":"$undefined"},{"id":"14212","book":"시편","book_name":"시편","chapter":22,"verse":7,"text":"나를 보는 자는 다 비웃으며 입술을 비쭉이고 머리를 흔들며 말하되","reference":"시편 22:7","category":"$undefined"},{"id":"14213","book":"시편","book_name":"시편","chapter":22,"verse":8,"text":"저가 여호와께 의탁하니 구원하실걸, 저를 기뻐하시니 건지실걸 하나이다","reference":"시편 22:8","category":"$undefined"},{"id":"14214","book":"시편","book_name":"시편","chapter":22,"verse":9,"text":"오직 주께서 나를 모태에서 나오게 하시고 내 모친의 젖을 먹을때에 의지하게 하셨나이다","reference":"시편 22:9","category":"$undefined"},{"id":"14215","book":"시편","book_name":"시편","chapter":22,"verse":10,"text":"내가 날 때부터 주께 맡긴바 되었고 모태에서 나올 때부터 주는 내 하나님이 되셨사오니","reference":"시편 22:10","category":"$undefined"},{"id":"14216","book":"시편","book_name":"시편","chapter":22,"verse":11,"text":"나를 멀리하지 마옵소서 환난이 가깝고 도울 자 없나이다","reference":"시편 22:11","category":"$undefined"},{"id":"14217","book":"시편","book_name":"시편","chapter":22,"verse":12,"text":"많은 황소가 나를 에워싸며 바산의 힘센 소들이 나를 둘렀으며","reference":"시편 22:12","category":"$undefined"},{"id":"14218","book":"시편","book_name":"시편","chapter":22,"verse":13,"text":"내게 그 입을 벌림이 찢고 부르짖는 사자 같으니이다","reference":"시편 22:13","category":"$undefined"},{"id":"14219","book":"시편","book_name":"시편","chapter":22,"verse":14,"text":"나는 물같이 쏟아졌으며 내 모든 뼈는 어그러졌으며 내 마음은 촛밀 같아서 내 속에서 녹았으며","reference":"시편 22:14","category":"$undefined"},{"id":"14220","book":"시편","book_name":"시편","chapter":22,"verse":15,"text":"내 힘이 말라 질그릇 조각 같고 내 혀가 잇틀에 붙었나이다 주께서 또 나를 사망의 진토에 두셨나이다","reference":"시편 22:15","category":"$undefined"},{"id":"14221","book":"시편","book_name":"시편","chapter":22,"verse":16,"text":"개들이 나를 에워쌌으며 악한 무리가 나를 둘러 내 수족을 찔렀나이다","reference":"시편 22:16","category":"$undefined"},{"id":"14222","book":"시편","book_name":"시편","chapter":22,"verse":17,"text":"내가 내 모든 뼈를 셀 수 있나이다 저희가 나를 주목하여 보고","reference":"시편 22:17","category":"$undefined"},{"id":"14223","book":"시편","book_name":"시편","chapter":22,"verse":18,"text":"내 겉옷을 나누며 속옷을 제비뽑나이다","reference":"시편 22:18","category":"$undefined"},{"id":"14224","book":"시편","book_name":"시편","chapter":22,"verse":19,"text":"여호와여, 멀리하지 마옵소서 나의 힘이시여, 속히 나를 도우소서","reference":"시편 22:19","category":"$undefined"},{"id":"14225","book":"시편","book_name":"시편","chapter":22,"verse":20,"text":"내 영혼을 칼에서 건지시며 내 유일한 것을 개의 세력에서 구하소서","reference":"시편 22:20","category":"$undefined"},{"id":"14226","book":"시편","book_name":"시편","chapter":22,"verse":21,"text":"나를 사자 입에서 구하소서 주께서 내게 응락하시고 들소 뿔에서 구원하셨나이다","reference":"시편 22:21","category":"$undefined"},{"id":"14227","book":"시편","book_name":"시편","chapter":22,"verse":22,"text":"내가 주의 이름을 형제에게 선포하고 회중에서 주를 찬송하리이다","reference":"시편 22:22","category":"$undefined"},{"id":"14228","book":"시편","book_name":"시편","chapter":22,"verse":23,"text":"여호와를 두려워하는 너희여, 그를 찬송할지어다 야곱의 모든 자손이여, 그에게 영광을 돌릴지어다 너희 이스라엘 모든 자손이여, 그를 경외할지어다","reference":"시편 22:23","category":"$undefined"},{"id":"14229","book":"시편","book_name":"시편","chapter":22,"verse":24,"text":"그는 곤고한 자의 곤고를 멸시하거나 싫어하지 아니하시며 그 얼굴을 저에게서 숨기지 아니하시고 부르짖을 때에 들으셨도다","reference":"시편 22:24","category":"$undefined"},{"id":"14230","book":"시편","book_name":"시편","chapter":22,"verse":25,"text":"대회 중에 나의 찬송은 주께로서 온 것이니 주를 경외하는 자 앞에서 나의 서원을 갚으리이다","reference":"시편 22:25","category":"$undefined"},{"id":"14231","book":"시편","book_name":"시편","chapter":22,"verse":26,"text":"겸손한 자는 먹고 배부를 것이며 여호와를 찾는 자는 그를 찬송할 것이라 너희 마음은 영원히 살지어다","reference":"시편 22:26","category":"$undefined"},{"id":"14232","book":"시편","book_name":"시편","chapter":22,"verse":27,"text":"땅의 모든 끝이 여호와를 기억하고 돌아오며 열방의 모든 족속이 주의 앞에 경배하리니","reference":"시편 22:27","category":"$undefined"},{"id":"14233","book":"시편","book_name":"시편","chapter":22,"verse":28,"text":"나라는 여호와의 것이요 여호와는 열방의 주재심이로다","reference":"시편 22:28","category":"$undefined"},{"id":"14234","book":"시편","book_name":"시편","chapter":22,"verse":29,"text":"세상의 모든 풍비한 자가 먹고 경배할 것이요 진토에 내려가는 자 곧 자기 영혼을 살리지 못할 자도 다 그 앞에 절하리로다","reference":"시편 22:29","category":"$undefined"},{"id":"14235","book":"시편","book_name":"시편","chapter":22,"verse":30,"text":"후손이 그를 봉사할 것이요 대대에 주를 전할 것이며","reference":"시편 22:30","category":"$undefined"},{"id":"14236","book":"시편","book_name":"시편","chapter":22,"verse":31,"text":"와서 그 공의를 장차 날 백성에게 전함이여 주께서 이를 행하셨다 할 것이로다","reference":"시편 22:31","category":"$undefined"}],"bookSlug":"psalms"}]
