2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":26,"verses":[{"id":"14275","book":"시편","book_name":"시편","chapter":26,"verse":1,"text":"(다윗의 시) 내가 나의 완전함에 행하였사오며 요동치 아니하고 여호와를 의지하였사오니 여호와여, 나를 판단하소서","reference":"시편 26:1","category":"$undefined"},{"id":"14276","book":"시편","book_name":"시편","chapter":26,"verse":2,"text":"여호와여, 나를 살피시고 시험하사 내 뜻과 내 마음을 단련하소서","reference":"시편 26:2","category":"$undefined"},{"id":"14277","book":"시편","book_name":"시편","chapter":26,"verse":3,"text":"주의 인자하심이 내 목전에 있나이다 내가 주의 진리 중에 행하여","reference":"시편 26:3","category":"$undefined"},{"id":"14278","book":"시편","book_name":"시편","chapter":26,"verse":4,"text":"허망한 사람과 같이 앉지 아니하였사오니 간사한 자와 동행치도 아니하리이다","reference":"시편 26:4","category":"$undefined"},{"id":"14279","book":"시편","book_name":"시편","chapter":26,"verse":5,"text":"내가 행악자의 집회를 미워하오니 악한 자와 같이 앉지 아니하리이다","reference":"시편 26:5","category":"$undefined"},{"id":"14280","book":"시편","book_name":"시편","chapter":26,"verse":6,"text":"여호와여, 내가 무죄하므로 손을 씻고 주의 단에 두루 다니며","reference":"시편 26:6","category":"$undefined"},{"id":"14281","book":"시편","book_name":"시편","chapter":26,"verse":7,"text":"감사의 소리를 들리고 주의 기이한 모든 일을 이르리이다","reference":"시편 26:7","category":"$undefined"},{"id":"14282","book":"시편","book_name":"시편","chapter":26,"verse":8,"text":"여호와여, 내가 주의 계신 집과 주의 영광이 거하는 곳을 사랑하오니","reference":"시편 26:8","category":"$undefined"},{"id":"14283","book":"시편","book_name":"시편","chapter":26,"verse":9,"text":"내 영혼을 죄인과 함께 내 생명을 살인자와 함께 거두지 마소서","reference":"시편 26:9","category":"$undefined"},{"id":"14284","book":"시편","book_name":"시편","chapter":26,"verse":10,"text":"저희 손에 악특함이 있고 그 오른손에 뇌물이 가득하오나","reference":"시편 26:10","category":"$undefined"},{"id":"14285","book":"시편","book_name":"시편","chapter":26,"verse":11,"text":"나는 나의 완전함에 행하오리니 나를 구속하시고 긍휼히 여기소서","reference":"시편 26:11","category":"$undefined"},{"id":"14286","book":"시편","book_name":"시편","chapter":26,"verse":12,"text":"내 발이 평탄한 데 섰사오니 회중에서 여호와를 송축하리이다","reference":"시편 26:12","category":"$undefined"}],"bookSlug":"psalms"}]
