2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":28,"verses":[{"id":"14301","book":"시편","book_name":"시편","chapter":28,"verse":1,"text":"(다윗의 시) 여호와여, 내가 주께 부르짖으오니 나의 반석이여, 내게 귀를 막지마소서 주께서 내게 잠잠하시면 내가 무덤에 내려가는 자와 같을까 하나이다","reference":"시편 28:1","category":"$undefined"},{"id":"14302","book":"시편","book_name":"시편","chapter":28,"verse":2,"text":"내가 주의 성소를 향하여 나의 손을 들고 주께 부르짖을 때에 나의 간구하는 소리를 들으소서","reference":"시편 28:2","category":"$undefined"},{"id":"14303","book":"시편","book_name":"시편","chapter":28,"verse":3,"text":"악인과 행악하는 자와 함께 나를 끌지 마옵소서 저희는 그 이웃에게 화평을 말하나 그 마음에는 악독이 있나이다","reference":"시편 28:3","category":"$undefined"},{"id":"14304","book":"시편","book_name":"시편","chapter":28,"verse":4,"text":"저희의 행사와 그 행위의 악한대로 갚으시며 저희 손의 지은대로 갚아 그 마땅히 받을 것으로 보응하소서","reference":"시편 28:4","category":"$undefined"},{"id":"14305","book":"시편","book_name":"시편","chapter":28,"verse":5,"text":"저희는 여호와의 행하신 일과 손으로 지으신 것을 생각지 아니하므로 여호와께서 저희를 파괴하고 건설치 아니하시리로다","reference":"시편 28:5","category":"$undefined"},{"id":"14306","book":"시편","book_name":"시편","chapter":28,"verse":6,"text":"여호와를 찬송함이여, 내 간구하는 소리를 들으심이로다","reference":"시편 28:6","category":"$undefined"},{"id":"14307","book":"시편","book_name":"시편","chapter":28,"verse":7,"text":"여호와는 나의 힘과 나의 방패시니 내 마음이 저를 의지하여 도움을 얻었도다 그러므로 내 마음이 크게 기뻐하며 내 노래로 저를 찬송하리로다","reference":"시편 28:7","category":"$undefined"},{"id":"14308","book":"시편","book_name":"시편","chapter":28,"verse":8,"text":"여호와는 저희의 힘이시요 그 기름 부음 받은 자의 구원의 산성이시로다","reference":"시편 28:8","category":"$undefined"},{"id":"14309","book":"시편","book_name":"시편","chapter":28,"verse":9,"text":"주의 백성을 구원하시며 주의 산업에 복을 주시고 또 저희의 목자가 되사 영원토록 드십소서","reference":"시편 28:9","category":"$undefined"}],"bookSlug":"psalms"}]
