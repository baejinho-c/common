2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":34,"verses":[{"id":"14390","book":"시편","book_name":"시편","chapter":34,"verse":1,"text":"(다윗이 아비멜렉 앞에서 미친체하다가 쫓겨나서 지은 시) 내가 여호와를 항상 송축함이여, 그를 송축함이 내 입에 계속하리로다","reference":"시편 34:1","category":"$undefined"},{"id":"14391","book":"시편","book_name":"시편","chapter":34,"verse":2,"text":"내 영혼이 여호와로 자랑하리니 곤고한 자가 이를 듣고 기뻐하리로다","reference":"시편 34:2","category":"$undefined"},{"id":"14392","book":"시편","book_name":"시편","chapter":34,"verse":3,"text":"나와 함께 여호와를 광대하시다 하며 함께 그 이름을 높이세","reference":"시편 34:3","category":"$undefined"},{"id":"14393","book":"시편","book_name":"시편","chapter":34,"verse":4,"text":"내가 여호와께 구하매 내게 응답하시고 내 모든 두려움에서 나를 건지셨도다","reference":"시편 34:4","category":"$undefined"},{"id":"14394","book":"시편","book_name":"시편","chapter":34,"verse":5,"text":"저희가 주를 앙망하고 광채를 입었으니 그 얼굴이 영영히 부끄럽지 아니하리로다","reference":"시편 34:5","category":"$undefined"},{"id":"14395","book":"시편","book_name":"시편","chapter":34,"verse":6,"text":"이 곤고한 자가 부르짖으매 여호와께서 들으시고 그 모든 환난에서 구원하셨도다","reference":"시편 34:6","category":"$undefined"},{"id":"14396","book":"시편","book_name":"시편","chapter":34,"verse":7,"text":"여호와의 사자가 주를 경외하는 자를 둘러 진치고 저희를 건지시는도다","reference":"시편 34:7","category":"$undefined"},{"id":"14397","book":"시편","book_name":"시편","chapter":34,"verse":8,"text":"너희는 여호와의 선하심을 맛보아 알지어다 ! 그에게 피하는 자는 복이 있도다","reference":"시편 34:8","category":"$undefined"},{"id":"14398","book":"시편","book_name":"시편","chapter":34,"verse":9,"text":"너희 성도들아 여호와를 경외하라 ! 저를 경외하는 자에게는 부족함이 없도다","reference":"시편 34:9","category":"$undefined"},{"id":"14399","book":"시편","book_name":"시편","chapter":34,"verse":10,"text":"젊은 사자는 궁핍하여 주릴지라도 여호와를 찾는 자는 모든 좋은 것에 부족함이 없으리로다","reference":"시편 34:10","category":"$undefined"},{"id":"14400","book":"시편","book_name":"시편","chapter":34,"verse":11,"text":"너희 소자들아 와서 내게 들으라 내가 여호와를 경외함을 너희에게 가르치리로다","reference":"시편 34:11","category":"$undefined"},{"id":"14401","book":"시편","book_name":"시편","chapter":34,"verse":12,"text":"생명을 사모하고 장수하여 복 받기를 원하는 사람이 누구뇨","reference":"시편 34:12","category":"$undefined"},{"id":"14402","book":"시편","book_name":"시편","chapter":34,"verse":13,"text":"네 혀를 악에서 금하며 네 입술을 궤사한 말에서 금할지어다","reference":"시편 34:13","category":"$undefined"},{"id":"14403","book":"시편","book_name":"시편","chapter":34,"verse":14,"text":"악을 버리고 선을 행하며 화평을 찾아 따를지어다","reference":"시편 34:14","category":"$undefined"},{"id":"14404","book":"시편","book_name":"시편","chapter":34,"verse":15,"text":"여호와의 눈은 의인을 향하시고 그 귀는 저희 부르짖음에 기울이시는도다","reference":"시편 34:15","category":"$undefined"},{"id":"14405","book":"시편","book_name":"시편","chapter":34,"verse":16,"text":"여호와의 얼굴은 행악하는 자를 대하사 저희의 자취를 땅에서 끊으려 하시는도다","reference":"시편 34:16","category":"$undefined"},{"id":"14406","book":"시편","book_name":"시편","chapter":34,"verse":17,"text":"의인이 외치매 여호와께서 들으시고 저희의 모든 환난에서 건지셨도다","reference":"시편 34:17","category":"$undefined"},{"id":"14407","book":"시편","book_name":"시편","chapter":34,"verse":18,"text":"여호와는 마음이 상한 자에게 가까이 하시고 중심에 통회하는 자를 구원하시는도다","reference":"시편 34:18","category":"$undefined"},{"id":"14408","book":"시편","book_name":"시편","chapter":34,"verse":19,"text":"의인은 고난이 많으나 여호와께서 그 모든 고난에서 건지시는도다","reference":"시편 34:19","category":"$undefined"},{"id":"14409","book":"시편","book_name":"시편","chapter":34,"verse":20,"text":"그 모든 뼈를 보호하심이여 그 중에 하나도 꺽이지 아니하도다","reference":"시편 34:20","category":"$undefined"},{"id":"14410","book":"시편","book_name":"시편","chapter":34,"verse":21,"text":"악이 악인을 죽일 것이라 의인을 미워하는 자는 죄를 받으리로다","reference":"시편 34:21","category":"$undefined"},{"id":"14411","book":"시편","book_name":"시편","chapter":34,"verse":22,"text":"여호와께서 그 종들의 영혼을 구속하시나니 저에게 피하는 자는 다 죄를 받지 아니하리로다","reference":"시편 34:22","category":"$undefined"}],"bookSlug":"psalms"}]
