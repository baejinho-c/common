2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":35,"verses":[{"id":"14412","book":"시편","book_name":"시편","chapter":35,"verse":1,"text":"(다윗의 시) 여호와여, 나와 다투는 자와 다투시고 나와 싸우는 자와 싸우소서","reference":"시편 35:1","category":"$undefined"},{"id":"14413","book":"시편","book_name":"시편","chapter":35,"verse":2,"text":"방패와 손 방패를 잡으시고 일어나 나를 도우소서","reference":"시편 35:2","category":"$undefined"},{"id":"14414","book":"시편","book_name":"시편","chapter":35,"verse":3,"text":"창을 빼사 나를 쫓는 자의 길을 막으시고 또 내 영혼에게 나는 네 구원이라 이르소서","reference":"시편 35:3","category":"$undefined"},{"id":"14415","book":"시편","book_name":"시편","chapter":35,"verse":4,"text":"내 생명을 찾는 자로 부끄러워 수치를 당케 하시며 나를 상해하려 하는 자로 물러가 낭패케 하소서","reference":"시편 35:4","category":"$undefined"},{"id":"14416","book":"시편","book_name":"시편","chapter":35,"verse":5,"text":"저희로 바람 앞에 겨와 같게 하시고 여호와의 사자로 몰아내소서","reference":"시편 35:5","category":"$undefined"},{"id":"14417","book":"시편","book_name":"시편","chapter":35,"verse":6,"text":"저희 길을 어둡고 미끄럽게 하시고 여호와의 사자로 저희를 따르게 하소서","reference":"시편 35:6","category":"$undefined"},{"id":"14418","book":"시편","book_name":"시편","chapter":35,"verse":7,"text":"저희가 무고히 나를 잡으려고 그 그물을 웅덩이에 숨기며 무고히 내 생명을 해하려고 함정을 팠사오니","reference":"시편 35:7","category":"$undefined"},{"id":"14419","book":"시편","book_name":"시편","chapter":35,"verse":8,"text":"멸망으로 졸지에 저에게 임하게 하시며 그 숨긴 그물에 스스로 잡히게 하시며 멸망 중에 떨어지게 하소서","reference":"시편 35:8","category":"$undefined"},{"id":"14420","book":"시편","book_name":"시편","chapter":35,"verse":9,"text":"내 영혼이 여호와를 즐거워함이여 그 구원을 기뻐하리로다","reference":"시편 35:9","category":"$undefined"},{"id":"14421","book":"시편","book_name":"시편","chapter":35,"verse":10,"text":"내 모든 뼈가 이르기를 여호와와 같은 자 누구리요 그는 가난한 자를 그보다 강한 자에게서 건지시고 가난하고 궁핍한 자를 노략하는 자에게서 건지시는 이라 하리로다","reference":"시편 35:10","category":"$undefined"},{"id":"14422","book":"시편","book_name":"시편","chapter":35,"verse":11,"text":"불의한 증인이 일어나서 내가 알지 못하는 일로 내게 힐문하며","reference":"시편 35:11","category":"$undefined"},{"id":"14423","book":"시편","book_name":"시편","chapter":35,"verse":12,"text":"내게 선을 악으로 갚아 나의 영혼을 외롭게 하나","reference":"시편 35:12","category":"$undefined"},{"id":"14424","book":"시편","book_name":"시편","chapter":35,"verse":13,"text":"나는 저희가 병 들었을 떼에 굵은 베옷을 입으며 금식하여 내 영혼을 괴롭게 하였더니 내 기도가 내 품으로 돌아왔도다","reference":"시편 35:13","category":"$undefined"},{"id":"14425","book":"시편","book_name":"시편","chapter":35,"verse":14,"text":"내가 나의 친구와 형제에게 행함 같이 저희에게 행하였으며 내가 굽히고 슬퍼하기를 모친을 곡함 같이 하였도다","reference":"시편 35:14","category":"$undefined"},{"id":"14426","book":"시편","book_name":"시편","chapter":35,"verse":15,"text":"오직 내가 환난을 당하매 저희가 기뻐하여 서로 모임이여 비류가 나의 알지 못하는 중에 모여 나를 치며 찢기를 마지 아니하도다","reference":"시편 35:15","category":"$undefined"},{"id":"14427","book":"시편","book_name":"시편","chapter":35,"verse":16,"text":"저희는 연회에서 망령되이 조롱하는 자 같이 나를 향하여 그 이를 갈도다","reference":"시편 35:16","category":"$undefined"},{"id":"14428","book":"시편","book_name":"시편","chapter":35,"verse":17,"text":"주여 어느 때까지 관망하시리이까 ? 내 영혼을 저 멸망자에게서 구원하시며 내 유일한 것을 사자들에게서 건지소서","reference":"시편 35:17","category":"$undefined"},{"id":"14429","book":"시편","book_name":"시편","chapter":35,"verse":18,"text":"내가 대회 중에서 주께 감사하며 많은 백성 중에서 주를 찬송하리이다","reference":"시편 35:18","category":"$undefined"},{"id":"14430","book":"시편","book_name":"시편","chapter":35,"verse":19,"text":"무리하게 나의 원수된 자로 나를 인하여 기뻐하지 못하게 하시며 무고히 나를 미워하는 자로 눈짓하지 못하게 하소서","reference":"시편 35:19","category":"$undefined"},{"id":"14431","book":"시편","book_name":"시편","chapter":35,"verse":20,"text":"대저 저희는 화평을 말하지 아니하고 평안히 땅에 거하는 자를 거짓말로 모해하며","reference":"시편 35:20","category":"$undefined"},{"id":"14432","book":"시편","book_name":"시편","chapter":35,"verse":21,"text":"또 저희가 나를 향하여 입을 크게 벌리고 하하, 우리가 목도하였다 하나이다","reference":"시편 35:21","category":"$undefined"},{"id":"14433","book":"시편","book_name":"시편","chapter":35,"verse":22,"text":"여호와여, 주께서 이를 보셨사오니 잠잠하지 마옵소서 주여, 나를 멀리하지 마옵소서","reference":"시편 35:22","category":"$undefined"},{"id":"14434","book":"시편","book_name":"시편","chapter":35,"verse":23,"text":"나의 하나님 나의 주여, 떨치고 깨셔서 나를 공판하시며 나의 송사를 다스리소서","reference":"시편 35:23","category":"$undefined"},{"id":"14435","book":"시편","book_name":"시편","chapter":35,"verse":24,"text":"여호와 나의 하나님이여, 주의 공의대로 나를 판단하사 저희로 나를 인하여 기뻐하지 못하게 하소서","reference":"시편 35:24","category":"$undefined"},{"id":"14436","book":"시편","book_name":"시편","chapter":35,"verse":25,"text":"저희로 그 마음에 이르기를 아하, 소원 성취하였다 하지 못하게 하시며 우리가 저를 삼켰다 하지 못하게 하소서","reference":"시편 35:25","category":"$undefined"},{"id":"14437","book":"시편","book_name":"시편","chapter":35,"verse":26,"text":"나의 해를 기뻐하는 자들로 부끄러워 낭패하게 하시며 나를 향하여 자긍하는 자로 수치와 욕을 당케 하소서","reference":"시편 35:26","category":"$undefined"},{"id":"14438","book":"시편","book_name":"시편","chapter":35,"verse":27,"text":"나의 의를 즐거워하는 자로 기꺼이 부르고 즐겁게 하시며 그 종의 형통을 기뻐하시는 여호와는 광대하시다 하는 말을 저희로 항상 하게 하소서","reference":"시편 35:27","category":"$undefined"},{"id":"14439","book":"시편","book_name":"시편","chapter":35,"verse":28,"text":"나의 혀가 주의 의를 말하며 종일토록 주를 찬송하리이다","reference":"시편 35:28","category":"$undefined"}],"bookSlug":"psalms"}]
