2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":37,"verses":[{"id":"14452","book":"시편","book_name":"시편","chapter":37,"verse":1,"text":"(다윗의 시) 행악자를 인하여 불평하여 하지 말며 불의를 행하는 자를 투기하지 말지어다","reference":"시편 37:1","category":"$undefined"},{"id":"14453","book":"시편","book_name":"시편","chapter":37,"verse":2,"text":"저희는 풀과 같이 속히 베임을 볼 것이며 푸른 채소 같이 쇠잔할 것임이로다","reference":"시편 37:2","category":"$undefined"},{"id":"14454","book":"시편","book_name":"시편","chapter":37,"verse":3,"text":"여호와를 의뢰하여 선을 행하라 ! 땅에 거하여 그의 성실로 식물을 삼을지어다","reference":"시편 37:3","category":"$undefined"},{"id":"14455","book":"시편","book_name":"시편","chapter":37,"verse":4,"text":"또 여호와를 기뻐하라 ! 저가 네 마음의 소원을 이루어 주시리로다","reference":"시편 37:4","category":"$undefined"},{"id":"14456","book":"시편","book_name":"시편","chapter":37,"verse":5,"text":"너의 길을 여호와께 맡기라 ! 저를 의지하면 저가 이루시고","reference":"시편 37:5","category":"$undefined"},{"id":"14457","book":"시편","book_name":"시편","chapter":37,"verse":6,"text":"네 의를 빛같이 나타내시며 네 공의를 정오의 빛같이 하시리로다","reference":"시편 37:6","category":"$undefined"},{"id":"14458","book":"시편","book_name":"시편","chapter":37,"verse":7,"text":"여호와 앞에 잠잠하고 참아 기다리라 ! 자기 길이 형통하며 악한 꾀를 이루는 자를 인하여 불평하여 말지어다","reference":"시편 37:7","category":"$undefined"},{"id":"14459","book":"시편","book_name":"시편","chapter":37,"verse":8,"text":"분을 그치고 노를 버리라 불평하여 말라 행악에 치우칠 뿐이라","reference":"시편 37:8","category":"$undefined"},{"id":"14460","book":"시편","book_name":"시편","chapter":37,"verse":9,"text":"대저 행악하는 자는 끊어질 것이나 여호와를 기대하는 자는 땅을 차지하리로다","reference":"시편 37:9","category":"$undefined"},{"id":"14461","book":"시편","book_name":"시편","chapter":37,"verse":10,"text":"잠시 후에 악인이 없어지리니 네가 그곳을 자세히 살필지라도 없으리로다","reference":"시편 37:10","category":"$undefined"},{"id":"14462","book":"시편","book_name":"시편","chapter":37,"verse":11,"text":"오직 온유한 자는 땅을 차지하며 풍부한 화평으로 즐기리로다","reference":"시편 37:11","category":"$undefined"},{"id":"14463","book":"시편","book_name":"시편","chapter":37,"verse":12,"text":"악인이 의인 치기를 꾀하고 향하여 그 이를 가는도다","reference":"시편 37:12","category":"$undefined"},{"id":"14464","book":"시편","book_name":"시편","chapter":37,"verse":13,"text":"주께서 저를 웃으시리니 그 날의 이름을 보심이로다","reference":"시편 37:13","category":"$undefined"},{"id":"14465","book":"시편","book_name":"시편","chapter":37,"verse":14,"text":"악인이 칼을 빼고 활을 당기어 가난하고 궁핍한 자를 엎드러뜨리며 행위가 정직한 자를 죽이고자 하나","reference":"시편 37:14","category":"$undefined"},{"id":"14466","book":"시편","book_name":"시편","chapter":37,"verse":15,"text":"그 칼은 자기의 마음을 찌르고 그 활은 부러지리로다","reference":"시편 37:15","category":"$undefined"},{"id":"14467","book":"시편","book_name":"시편","chapter":37,"verse":16,"text":"의인의 적은 소유가 많은 악인의 풍부함보다 승하도다","reference":"시편 37:16","category":"$undefined"},{"id":"14468","book":"시편","book_name":"시편","chapter":37,"verse":17,"text":"악인의 팔은 부러지나 의인은 여호와께서 붙드시는도다","reference":"시편 37:17","category":"$undefined"},{"id":"14469","book":"시편","book_name":"시편","chapter":37,"verse":18,"text":"여호와께서 완전한 자의 날을 아시니 저희 기업은 영원하리로다","reference":"시편 37:18","category":"$undefined"},{"id":"14470","book":"시편","book_name":"시편","chapter":37,"verse":19,"text":"저희는 환난 때에 부끄럽지 아니하며 기근의 날에도 풍족하려니와","reference":"시편 37:19","category":"$undefined"},{"id":"14471","book":"시편","book_name":"시편","chapter":37,"verse":20,"text":"악인은 멸망하고 여호와의 원수는 어린 양의 기름 같이 타서 연기되어 없어지리로다","reference":"시편 37:20","category":"$undefined"},{"id":"14472","book":"시편","book_name":"시편","chapter":37,"verse":21,"text":"악인은 꾸고 갚지 아니하나 의인은 은혜를 베풀고 주는도다","reference":"시편 37:21","category":"$undefined"},{"id":"14473","book":"시편","book_name":"시편","chapter":37,"verse":22,"text":"주의 복을 받은 자는 땅을 차지하고 주의 저주를 받은 자는 끊어지리로다","reference":"시편 37:22","category":"$undefined"},{"id":"14474","book":"시편","book_name":"시편","chapter":37,"verse":23,"text":"여호와께서 사람의 걸음을 정하시고 그 길을 기뻐하시나니","reference":"시편 37:23","category":"$undefined"},{"id":"14475","book":"시편","book_name":"시편","chapter":37,"verse":24,"text":"저는 넘어지나 아주 엎드러지지 아니함은 여호와께서 손으로 붙드심이로다","reference":"시편 37:24","category":"$undefined"},{"id":"14476","book":"시편","book_name":"시편","chapter":37,"verse":25,"text":"내가 어려서부터 늙기까지 의인이 버림을 당하거나 그 자손이 걸식함을 보지 못하였도다","reference":"시편 37:25","category":"$undefined"},{"id":"14477","book":"시편","book_name":"시편","chapter":37,"verse":26,"text":"저는 종일토록 은혜를 베풀고 꾸어 주니 그 자손이 복을 받는도다","reference":"시편 37:26","category":"$undefined"},{"id":"14478","book":"시편","book_name":"시편","chapter":37,"verse":27,"text":"악에서 떠나 선을 행하라 ! 그리하면 영영히 거하리니","reference":"시편 37:27","category":"$undefined"},{"id":"14479","book":"시편","book_name":"시편","chapter":37,"verse":28,"text":"여호와께서 공의를 사랑하시고 그 성도를 버리지 아니하심이로다 저희는 영영히 보호를 받으나 악인의 자손은 끊어지리로다","reference":"시편 37:28","category":"$undefined"},{"id":"14480","book":"시편","book_name":"시편","chapter":37,"verse":29,"text":"의인이 땅을 차지함이여 거기 영영히 거하리로다","reference":"시편 37:29","category":"$undefined"},{"id":"14481","book":"시편","book_name":"시편","chapter":37,"verse":30,"text":"의인의 입은 지혜를 말하고 그 혀는 공의를 이르며","reference":"시편 37:30","category":"$undefined"},{"id":"14482","book":"시편","book_name":"시편","chapter":37,"verse":31,"text":"그 마음에는 하나님의 법이 있으니 그 걸음에 실족함이 없으리로다","reference":"시편 37:31","category":"$undefined"},{"id":"14483","book":"시편","book_name":"시편","chapter":37,"verse":32,"text":"악인이 의인을 엿보아 살해할 기회를 찾으나","reference":"시편 37:32","category":"$undefined"},{"id":"14484","book":"시편","book_name":"시편","chapter":37,"verse":33,"text":"여호와는 저를 그 손에 버려두지 아니하시고 재판 때에도 정죄치 아니하시리로다","reference":"시편 37:33","category":"$undefined"},{"id":"14485","book":"시편","book_name":"시편","chapter":37,"verse":34,"text":"여호와를 바라고 그 도를 지키라 ! 그리하면 너를 들어 땅을 차지하게 하실 것이라 악인이 끊어질 때에 네가 목도하리로다","reference":"시편 37:34","category":"$undefined"},{"id":"14486","book":"시편","book_name":"시편","chapter":37,"verse":35,"text":"내가 악인의 큰 세력을 본즉 그 본토에 선 푸른 나무의 무성함 같으나","reference":"시편 37:35","category":"$undefined"},{"id":"14487","book":"시편","book_name":"시편","chapter":37,"verse":36,"text":"사람이 지날 때에 저가 없어졌으니 내가 찾아도 발견치 못하였도다","reference":"시편 37:36","category":"$undefined"},{"id":"14488","book":"시편","book_name":"시편","chapter":37,"verse":37,"text":"완전한 사람을 살피고 정직한 자를 볼지어다 화평한 자의 결국은 평안이로다","reference":"시편 37:37","category":"$undefined"},{"id":"14489","book":"시편","book_name":"시편","chapter":37,"verse":38,"text":"범죄자들은 함께 멸망하리니 악인의 결국은 끊어질 것이나","reference":"시편 37:38","category":"$undefined"},{"id":"14490","book":"시편","book_name":"시편","chapter":37,"verse":39,"text":"의인의 구원은 여호와께 있으니 그는 환난 때에 저희 산성이시로다","reference":"시편 37:39","category":"$undefined"},{"id":"14491","book":"시편","book_name":"시편","chapter":37,"verse":40,"text":"여호와께서 저희를 도와 건지시되 악인에게서 건져 구원하심은 그를 의지한 연고로다","reference":"시편 37:40","category":"$undefined"}],"bookSlug":"psalms"}]
