2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":38,"verses":[{"id":"14492","book":"시편","book_name":"시편","chapter":38,"verse":1,"text":"(다윗의 기념케 하는 시) 여호와여, 주의 노로 나를 책하지 마시고 분노로 나를 징계치 마소서","reference":"시편 38:1","category":"$undefined"},{"id":"14493","book":"시편","book_name":"시편","chapter":38,"verse":2,"text":"주의 살이 나를 찌르고 주의 손이 나를 심히 누르시나이다","reference":"시편 38:2","category":"$undefined"},{"id":"14494","book":"시편","book_name":"시편","chapter":38,"verse":3,"text":"주의 진노로 인하여 내 살에 성한 곳이 없사오며 나의 죄로 인하여 내 뼈에 평안함이 없나이다","reference":"시편 38:3","category":"$undefined"},{"id":"14495","book":"시편","book_name":"시편","chapter":38,"verse":4,"text":"내 죄악이 내 머리에 넘쳐서 무거운 짐 같으니 감당할 수 없나이다","reference":"시편 38:4","category":"$undefined"},{"id":"14496","book":"시편","book_name":"시편","chapter":38,"verse":5,"text":"내 상처가 썩어 악취가 나오니 나의 우매한 연고로소이다","reference":"시편 38:5","category":"$undefined"},{"id":"14497","book":"시편","book_name":"시편","chapter":38,"verse":6,"text":"내가 아프고 심히 구부러졌으며 종일토록 슬픈 중에 다니나이다","reference":"시편 38:6","category":"$undefined"},{"id":"14498","book":"시편","book_name":"시편","chapter":38,"verse":7,"text":"내 허리에 열기가 가득하고 내 살에 성한 곳이 없나이다","reference":"시편 38:7","category":"$undefined"},{"id":"14499","book":"시편","book_name":"시편","chapter":38,"verse":8,"text":"내가 피곤하고 심히 상하였으매 마음이 불안하여 신음하나이다","reference":"시편 38:8","category":"$undefined"},{"id":"14500","book":"시편","book_name":"시편","chapter":38,"verse":9,"text":"주여 나의 모든 소원이 주의 앞에 있사오며 나의 탄식이 주의 앞에 감추이지 아니하나이다","reference":"시편 38:9","category":"$undefined"},{"id":"14501","book":"시편","book_name":"시편","chapter":38,"verse":10,"text":"내 심장이 뛰고 내 기력이 쇠하여 내 눈의 빛도 나를 떠났나이다","reference":"시편 38:10","category":"$undefined"},{"id":"14502","book":"시편","book_name":"시편","chapter":38,"verse":11,"text":"나의 사랑하는 자와 나의 친구들이 나의 상처를 멀리하고 나의 친척들도 멀리 섰나이다","reference":"시편 38:11","category":"$undefined"},{"id":"14503","book":"시편","book_name":"시편","chapter":38,"verse":12,"text":"내 생명을 찾는 자가 올무를 놓고 나를 해하려는 자가 괴악한 일을 말하여 종일토록 궤계를 도모하오나","reference":"시편 38:12","category":"$undefined"},{"id":"14504","book":"시편","book_name":"시편","chapter":38,"verse":13,"text":"나는 귀먹은 자 같이 듣지 아니하고 벙어리 같이 입을 열지 아니하오니","reference":"시편 38:13","category":"$undefined"},{"id":"14505","book":"시편","book_name":"시편","chapter":38,"verse":14,"text":"나는 듣지 못하는 자 같아서 입에는 변박함이 없나이다","reference":"시편 38:14","category":"$undefined"},{"id":"14506","book":"시편","book_name":"시편","chapter":38,"verse":15,"text":"여호와여, 내가 주를 바랐사오니 내 주 하나님이 내게 응락하시리이다","reference":"시편 38:15","category":"$undefined"},{"id":"14507","book":"시편","book_name":"시편","chapter":38,"verse":16,"text":"내가 말하기를 두렵건대 저희가 내게 대하여 기뻐하며 내가 실족할 때에 나를 향하여 망자존대할까 하였나이다","reference":"시편 38:16","category":"$undefined"},{"id":"14508","book":"시편","book_name":"시편","chapter":38,"verse":17,"text":"내가 넘어지게 되었고 나의 근심이 항상 내 앞에 있사오니 내 죄악을 고하고 내 죄를 슬퍼함이니이다","reference":"시편 38:17","category":"$undefined"},{"id":"14509","book":"시편","book_name":"시편","chapter":38,"verse":18,"text":"내 원수가 활발하며 강하고 무리하게 나를 미워하는 자가 무수하오며","reference":"시편 38:18","category":"$undefined"},{"id":"14510","book":"시편","book_name":"시편","chapter":38,"verse":19,"text":"또 악으로 선을 갚는 자들이 내가 선을 좇는 연고로 나를 대적하나이다","reference":"시편 38:19","category":"$undefined"},{"id":"14511","book":"시편","book_name":"시편","chapter":38,"verse":20,"text":"여호와여, 나를 버리지 마소서 나의 하나님이여, 나를 멀리하지 마소서","reference":"시편 38:20","category":"$undefined"},{"id":"14512","book":"시편","book_name":"시편","chapter":38,"verse":21,"text":"","reference":"시편 38:21","category":"$undefined"},{"id":"14513","book":"시편","book_name":"시편","chapter":38,"verse":22,"text":"","reference":"시편 38:22","category":"$undefined"}],"bookSlug":"psalms"}]
