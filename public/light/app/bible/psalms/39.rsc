2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":39,"verses":[{"id":"14514","book":"시편","book_name":"시편","chapter":39,"verse":1,"text":"(다윗의 시. 영장 여두둔으로 한 노래) 내가 말하기를 나의 행위를 조심하여 내 혀로 범죄치 아니하리니 악인이 내 앞에 있을 때에 내가 내 입에 자갈을 먹이리라 하였도다","reference":"시편 39:1","category":"$undefined"},{"id":"14515","book":"시편","book_name":"시편","chapter":39,"verse":2,"text":"내가 잠잠하여 선한 말도 발하지 아니하니 나의 근심이 더 심하도다","reference":"시편 39:2","category":"$undefined"},{"id":"14516","book":"시편","book_name":"시편","chapter":39,"verse":3,"text":"내 마음이 내 속에서 뜨거워서 묵상할 때에 화가 발하니 나의 혀로 말하기를","reference":"시편 39:3","category":"$undefined"},{"id":"14517","book":"시편","book_name":"시편","chapter":39,"verse":4,"text":"여호와여, 나의 종말과 연한의 어떠함을 알게 하사 나로 나의 연약함을 알게 하소서","reference":"시편 39:4","category":"$undefined"},{"id":"14518","book":"시편","book_name":"시편","chapter":39,"verse":5,"text":"주께서 나의 날을 손 넓이만큼 되게 하시매 나의 일생이 주의 앞에는 없는 것 같사오니 사람마다 그 든든히 선 때도 진실로 허사뿐이니이다 (셀라)","reference":"시편 39:5","category":"$undefined"},{"id":"14519","book":"시편","book_name":"시편","chapter":39,"verse":6,"text":"진실로 각 사람은 그림자 같이 다니고 헛된 일에 분요하며 재물을 쌓으나 누가 취할는지 알지 못하나이다","reference":"시편 39:6","category":"$undefined"},{"id":"14520","book":"시편","book_name":"시편","chapter":39,"verse":7,"text":"주여, 내가 무엇을 바라리요 나의 소망은 주께 있나이다","reference":"시편 39:7","category":"$undefined"},{"id":"14521","book":"시편","book_name":"시편","chapter":39,"verse":8,"text":"나를 모든 죄과에서 건지시며 우매한 자에게 욕을 보지 않게 하소서","reference":"시편 39:8","category":"$undefined"},{"id":"14522","book":"시편","book_name":"시편","chapter":39,"verse":9,"text":"내가 잠잠하고 입을 열지 아니하옴은 주께서 이를 행하신 연고니이다","reference":"시편 39:9","category":"$undefined"},{"id":"14523","book":"시편","book_name":"시편","chapter":39,"verse":10,"text":"주의 징책을 나에게서 옮기소서 주의 손이 치심으로 내가 쇠망하였나이다","reference":"시편 39:10","category":"$undefined"},{"id":"14524","book":"시편","book_name":"시편","chapter":39,"verse":11,"text":"주께서 죄악을 견책하사 사람을 징계하실 때에 그 영화를 좀 먹음같이 소멸하게 하시니 참으로 각 사람은 허사 뿐이니이다 (셀라)","reference":"시편 39:11","category":"$undefined"},{"id":"14525","book":"시편","book_name":"시편","chapter":39,"verse":12,"text":"여호와여, 나의 기도를 들으시며 나의 부르짖음에 귀를 기울이소서 내가 눈물 흘릴 때에 잠잠하지 마옵소서 대저 나는 주께 객이 되고 거류자가 됨이 나의 모든 열조 같으니이다","reference":"시편 39:12","category":"$undefined"},{"id":"14526","book":"시편","book_name":"시편","chapter":39,"verse":13,"text":"주는 나를 용서하사 내가 떠나 없어지기 전에 나의 건강을 회복시키소서","reference":"시편 39:13","category":"$undefined"}],"bookSlug":"psalms"}]
