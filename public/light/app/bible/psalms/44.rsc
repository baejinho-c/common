11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":44,"verses":[{"id":"14573","book":"시편","book_name":"시편","chapter":44,"verse":1,"text":"(고라 자손의 마스길. 영장으로 한 노래) 하나님이여, 주께서 우리 열조의 날 곧 옛날에 행하신 일을 저희가 우리에게 이르매 우리 귀로 들었나이다","reference":"시편 44:1","category":"$undefined"},{"id":"14574","book":"시편","book_name":"시편","chapter":44,"verse":2,"text":"주께서 주의 손으로 열방을 쫓으시고 열조를 심으시며 주께서 민족들은 괴롭게 하시고 열조는 번성케 하셨나이다","reference":"시편 44:2","category":"$undefined"},{"id":"14575","book":"시편","book_name":"시편","chapter":44,"verse":3,"text":"저희가 자기 칼로 땅을 얻어 차지함이 아니요 저희 팔이 저희를 구원함도 아니라 오직 주의 오른손과 팔과 얼굴의 빛으로 하셨으니 주께서 저희를 기뻐하신 연고니이다","reference":"시편 44:3","category":"$undefined"},{"id":"14576","book":"시편","book_name":"시편","chapter":44,"verse":4,"text":"하나님이여, 주는 나의 왕이시니 야곱에게 구원을 베푸소서","reference":"시편 44:4","category":"$undefined"},{"id":"14577","book":"시편","book_name":"시편","chapter":44,"verse":5,"text":"우리가 주를 의지하여 우리 대적을 누르고 우리를 치려 일어나는 자를 주의 이름으로 밟으리이다","reference":"시편 44:5","category":"$undefined"},{"id":"14578","book":"시편","book_name":"시편","chapter":44,"verse":6,"text":"나는 내 활을 의지하지 아니할 것이라 내 칼도 나를 구원치 못하리이다","reference":"시편 44:6","category":"$undefined"},{"id":"14579","book":"시편","book_name":"시편","chapter":44,"verse":7,"text":"오직 주께서 우리를 우리 대적에게서 구원하시고 우리를 미워하는 자로 수치를 당케 하셨나이다","reference":"시편 44:7","category":"$undefined"},{"id":"14580","book":"시편","book_name":"시편","chapter":44,"verse":8,"text":"우리가 종일 하나님으로 자랑하였나이다 우리가 하나님의 이름을 영영히 감사하리이다 (셀라)","reference":"시편 44:8","category":"$undefined"},{"id":"14581","book":"시편","book_name":"시편","chapter":44,"verse":9,"text":"그러나 이제는 주께서 우리를 버려 욕을 당케 하시고 우리 군대와 함께 나아가지 아니하시나이다","reference":"시편 44:9","category":"$undefined"},{"id":"14582","book":"시편","book_name":"시편","chapter":44,"verse":10,"text":"주께서 우리를 대적에게서 돌아서게 하시니 우리를 미워하는 자가 자기를 위하여 탈취하였나이다","reference":"시편 44:10","category":"$undefined"},{"id":"14583","book":"시편","book_name":"시편","chapter":44,"verse":11,"text":"주께서 우리로 먹힐 양 같게 하시고 열방 중에 흩으셨나이다","reference":"시편 44:11","category":"$undefined"},{"id":"14584","book":"시편","book_name":"시편","chapter":44,"verse":12,"text":"주께서 주의 백성을 무료로 파심이여 저희 값으로 이익을 얻지 못하셨나이다","reference":"시편 44:12","category":"$undefined"},{"id":"14585","book":"시편","book_name":"시편","chapter":44,"verse":13,"text":"주께서 우리로 이웃에게 욕을 당케 하시니 둘러 있는 자가 조소하고 조롱하나이다","reference":"시편 44:13","category":"$undefined"},{"id":"14586","book":"시편","book_name":"시편","chapter":44,"verse":14,"text":"주께서 우리로 열방 중에 말거리가 되게 하시며 민족 중에서 머리 흔듦을 당케 하셨나이다","reference":"시편 44:14","category":"$undefined"},{"id":"14587","book":"시편","book_name":"시편","chapter":44,"verse":15,"text":"나의 능욕이 종일 내 앞에 있으며 수치가 내 얼굴을 덮었으니","reference":"시편 44:15","category":"$undefined"},{"id":"14588","book":"시편","book_name":"시편","chapter":44,"verse":16,"text":"나를 비방하고 후욕하는 소리를 인함이요 나의 원수와 보수자의 연고니이다","reference":"시편 44:16","category":"$undefined"},{"id":"14589","book":"시편","book_name":"시편","chapter":44,"verse":17,"text":"이 모든 일이 우리에게 임하였으나 우리가 주를 잊지 아니하며 주의 언약을 어기지 아니하였나이다","reference":"시편 44:17","category":"$undefined"},{"id":"14590","book":"시편","book_name":"시편","chapter":44,"verse":18,"text":"우리 마음이 퇴축지 아니하고 우리 걸음도 주의 길을 떠나지 아니하였으나","reference":"시편 44:18","category":"$undefined"},{"id":"14591","book":"시편","book_name":"시편","chapter":44,"verse":19,"text":"주께서 우리를 시랑의 처소에서 심히 상해하시고 우리를 사망의 그늘로 덮으셨나이다","reference":"시편 44:19","category":"$undefined"},{"id":"14592","book":"시편","book_name":"시편","chapter":44,"verse":20,"text":"우리가 우리 하나님의 이름을 잊어버렸거나 우리 손을 이방 신에게 향하여 폈더면","reference":"시편 44:20","category":"$undefined"},{"id":"14593","book":"시편","book_name":"시편","chapter":44,"verse":21,"text":"하나님이 이를 더듬어 내지 아니하셨으리이까 ? 대저 주는 마음의 비밀을 아시나이다","reference":"시편 44:21","category":"$undefined"},{"id":"14594","book":"시편","book_name":"시편","chapter":44,"verse":22,"text":"우리가 종일 주를 위하여 죽임을 당케 되며 도살할 양같이 여김을 받았나이다","reference":"시편 44:22","category":"$undefined"},{"id":"14595","book":"시편","book_name":"시편","chapter":44,"verse":23,"text":"주여, 깨소서 어찌하여 주무시나이까 ? 일어나시고 우리를 영영히 버리지 마소서","reference":"시편 44:23","category":"$undefined"},{"id":"14596","book":"시편","book_name":"시편","chapter":44,"verse":24,"text":"어찌하여 주의 얼굴을 가리우시고 우리 고난과 압제를 잊으시나이까 ?","reference":"시편 44:24","category":"$undefined"},{"id":"14597","book":"시편","book_name":"시편","chapter":44,"verse":25,"text":"우리 영혼은 진토에 구푸리고 우리 몸은 땅에 붙었나이다","reference":"시편 44:25","category":"$undefined"},{"id":"14598","book":"시편","book_name":"시편","chapter":44,"verse":26,"text":"일어나 우리를 도우소서 주의 인자하심을 인하여 우리를 구속하소서","reference":"시편 44:26","category":"$undefined"}],"bookSlug":"psalms"}]
