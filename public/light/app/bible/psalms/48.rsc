2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":48,"verses":[{"id":"14636","book":"시편","book_name":"시편","chapter":48,"verse":1,"text":"(고라 자손의 시. 곧 노래) 여호와는 광대하시니 우리 하나님의 성, 거룩한 산에서 극진히 찬송하리로다","reference":"시편 48:1","category":"$undefined"},{"id":"14637","book":"시편","book_name":"시편","chapter":48,"verse":2,"text":"터가 높고 아름다워 온 세계가 즐거워함이여 큰 왕의 성 곧 북방에 있는 시온산이 그러하도다","reference":"시편 48:2","category":"$undefined"},{"id":"14638","book":"시편","book_name":"시편","chapter":48,"verse":3,"text":"하나님이 그 여러 궁중에서 자기를 피난처로 알리셨도다","reference":"시편 48:3","category":"$undefined"},{"id":"14639","book":"시편","book_name":"시편","chapter":48,"verse":4,"text":"열왕이 모여 함께 지났음이여","reference":"시편 48:4","category":"$undefined"},{"id":"14640","book":"시편","book_name":"시편","chapter":48,"verse":5,"text":"저희가 보고 놀라고 두려워 빨리 갔도다","reference":"시편 48:5","category":"$undefined"},{"id":"14641","book":"시편","book_name":"시편","chapter":48,"verse":6,"text":"거기서 떨림이 저희를 잡으니 고통이 해산하는 여인 같도다","reference":"시편 48:6","category":"$undefined"},{"id":"14642","book":"시편","book_name":"시편","chapter":48,"verse":7,"text":"주께서 동풍으로 다시스의 배를 깨뜨리시도다","reference":"시편 48:7","category":"$undefined"},{"id":"14643","book":"시편","book_name":"시편","chapter":48,"verse":8,"text":"우리가 들은 대로 만군의 여호와의 성, 우리 하나님의 성에서 보았나니 하나님이 이를 영영히 견고케 하시리로다 (셀라)","reference":"시편 48:8","category":"$undefined"},{"id":"14644","book":"시편","book_name":"시편","chapter":48,"verse":9,"text":"하나님이여, 우리가 주의 전가운데서 주의 인자하심을 생각하였나이다","reference":"시편 48:9","category":"$undefined"},{"id":"14645","book":"시편","book_name":"시편","chapter":48,"verse":10,"text":"하나님이여, 주의 이름과 같이 찬송도 땅끝까지 미쳤으며 주의 오른손에는 정의가 충만하나이다","reference":"시편 48:10","category":"$undefined"},{"id":"14646","book":"시편","book_name":"시편","chapter":48,"verse":11,"text":"주의 판단을 인하여 시온산은 기뻐하고 유다의 딸들은 즐거워 할지어다","reference":"시편 48:11","category":"$undefined"},{"id":"14647","book":"시편","book_name":"시편","chapter":48,"verse":12,"text":"너희는 시온을 편답하고 그것을 순행하며 그 망대들을 계수하라","reference":"시편 48:12","category":"$undefined"},{"id":"14648","book":"시편","book_name":"시편","chapter":48,"verse":13,"text":"그 성벽을 자세히 보고 그 궁전을 살펴서 후대에 전하라","reference":"시편 48:13","category":"$undefined"},{"id":"14649","book":"시편","book_name":"시편","chapter":48,"verse":14,"text":"이 하나님은 영영히 우리 하나님이시니 우리를 죽을 때까지 인도하시리로다","reference":"시편 48:14","category":"$undefined"}],"bookSlug":"psalms"}]
