2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":50,"verses":[{"id":"14670","book":"시편","book_name":"시편","chapter":50,"verse":1,"text":"(아삽의 시) 전능하신 자 하나님 여호와께서 말씀하사 해 돋는데서부터 지는 데까지 세상을 부르셨도다","reference":"시편 50:1","category":"$undefined"},{"id":"14671","book":"시편","book_name":"시편","chapter":50,"verse":2,"text":"온전히 아름다운 시온에서 하나님이 빛을 발하셨도다","reference":"시편 50:2","category":"$undefined"},{"id":"14672","book":"시편","book_name":"시편","chapter":50,"verse":3,"text":"우리 하나님이 임하사 잠잠치 아니하시니 그앞에는 불이 삼키고 그 사방에는 광풍이 불리로다","reference":"시편 50:3","category":"$undefined"},{"id":"14673","book":"시편","book_name":"시편","chapter":50,"verse":4,"text":"하나님이 그 백성을 판단하시려고 윗 하늘과 아래 땅에 반포하여","reference":"시편 50:4","category":"$undefined"},{"id":"14674","book":"시편","book_name":"시편","chapter":50,"verse":5,"text":"이르시되 나의 성도를 너의 앞에 모으라 곧 제사로 나와 언약한 자니라 하시도다","reference":"시편 50:5","category":"$undefined"},{"id":"14675","book":"시편","book_name":"시편","chapter":50,"verse":6,"text":"하늘이 그 공의를 선포하리니 하나님 그는 심판장이심이로다 (셀라)","reference":"시편 50:6","category":"$undefined"},{"id":"14676","book":"시편","book_name":"시편","chapter":50,"verse":7,"text":"내 백성아, 들을지어다 ! 내가 말하리라 이스라엘아, 내가 네게 증거하리라 나는 하나님 곧 네 하나님이로다","reference":"시편 50:7","category":"$undefined"},{"id":"14677","book":"시편","book_name":"시편","chapter":50,"verse":8,"text":"내가 너의 제물을 인하여는 너를 책망치 아니하리니 네 번제가 항상 내 앞에 있음이로다","reference":"시편 50:8","category":"$undefined"},{"id":"14678","book":"시편","book_name":"시편","chapter":50,"verse":9,"text":"내가 네 집에서 수소나 네 우리에서 수염소를 취치 아니하리니","reference":"시편 50:9","category":"$undefined"},{"id":"14679","book":"시편","book_name":"시편","chapter":50,"verse":10,"text":"이는 삼림의 짐승들과 천산의 생축이 다 내 것이며","reference":"시편 50:10","category":"$undefined"},{"id":"14680","book":"시편","book_name":"시편","chapter":50,"verse":11,"text":"산의 새들도 나의 아는 것이며 들의 짐승도 내 것임이로다","reference":"시편 50:11","category":"$undefined"},{"id":"14681","book":"시편","book_name":"시편","chapter":50,"verse":12,"text":"내가 가령 주려도 네게 이르지 않을 것은 세계와 거기 충만한 것이 내 것임이로다","reference":"시편 50:12","category":"$undefined"},{"id":"14682","book":"시편","book_name":"시편","chapter":50,"verse":13,"text":"내가 수소의 고기를 먹으며 염소의 피를 마시겠느냐 ?","reference":"시편 50:13","category":"$undefined"},{"id":"14683","book":"시편","book_name":"시편","chapter":50,"verse":14,"text":"감사로 하나님께 제사를 드리며 지극히 높으신 자에게 네 서원을 갚으며","reference":"시편 50:14","category":"$undefined"},{"id":"14684","book":"시편","book_name":"시편","chapter":50,"verse":15,"text":"환난 날에 나를 부르라 ! 내가 너를 건지리니 네가 나를 영화롭게 하리로다","reference":"시편 50:15","category":"$undefined"},{"id":"14685","book":"시편","book_name":"시편","chapter":50,"verse":16,"text":"악인에게는 하나님이 이르시되 네가 어찌 내 율례를 전하며 내 언약을 네 입에 두느냐","reference":"시편 50:16","category":"$undefined"},{"id":"14686","book":"시편","book_name":"시편","chapter":50,"verse":17,"text":"네가 교훈을 미워하고 내 말을 네 뒤로 던지며","reference":"시편 50:17","category":"$undefined"},{"id":"14687","book":"시편","book_name":"시편","chapter":50,"verse":18,"text":"도적을 본즉 연합하고 간음하는 자와 동류가 되며","reference":"시편 50:18","category":"$undefined"},{"id":"14688","book":"시편","book_name":"시편","chapter":50,"verse":19,"text":"네 입을 악에게 주고 네 혀로 궤사를 지으며","reference":"시편 50:19","category":"$undefined"},{"id":"14689","book":"시편","book_name":"시편","chapter":50,"verse":20,"text":"앉아서 네 형제를 공박하며 네 어미의 아들을 비방하는도다","reference":"시편 50:20","category":"$undefined"},{"id":"14690","book":"시편","book_name":"시편","chapter":50,"verse":21,"text":"네가 이 일을 행하여도 내가 잠잠하였더니 네가 나를 너와 같은 줄로 생각하였도다 그러나 내가 너를 책망하여 네 죄를 네 목전에 차례로 베풀리라 하시는도다","reference":"시편 50:21","category":"$undefined"},{"id":"14691","book":"시편","book_name":"시편","chapter":50,"verse":22,"text":"하나님을 잊어버린 너희여 이제 이를 생각하라 그렇지 않으면 내가 너희를 찢으리니 건질 자 없으리라","reference":"시편 50:22","category":"$undefined"},{"id":"14692","book":"시편","book_name":"시편","chapter":50,"verse":23,"text":"감사로 제사를 드리는 자가 나를 영화롭게 하나니 그 행위를 옳게 하는 자에게 내가 하나님의 구원을 보이리라","reference":"시편 50:23","category":"$undefined"}],"bookSlug":"psalms"}]
