2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":56,"verses":[{"id":"14757","book":"시편","book_name":"시편","chapter":56,"verse":1,"text":"(다윗의 믹담 시. 영장으로 요낫엘렘 르호김에 맞춘 노래. 다윗이 가드에서 블레셋인에게 잡힌 때에) 하나님이여, 나를 긍휼히 여기소서 사람이 나를 삼키려고 종일 치며 압제하나이다","reference":"시편 56:1","category":"$undefined"},{"id":"14758","book":"시편","book_name":"시편","chapter":56,"verse":2,"text":"나의 원수가 종일 나를 삼키려 하며 나를 교만히 치는 자 많사오니","reference":"시편 56:2","category":"$undefined"},{"id":"14759","book":"시편","book_name":"시편","chapter":56,"verse":3,"text":"내가 두려워하는 날에는 주를 의지하리이다","reference":"시편 56:3","category":"$undefined"},{"id":"14760","book":"시편","book_name":"시편","chapter":56,"verse":4,"text":"내가 하나님을 의지하고 그 말씀을 찬송하올지라 내가 하나님을 의지하였은즉 두려워 아니하리니 혈육있는 사람이 내게 어찌하리이까 ?","reference":"시편 56:4","category":"$undefined"},{"id":"14761","book":"시편","book_name":"시편","chapter":56,"verse":5,"text":"저희가 종일 내 말을 곡해하며 내게 대한 저희 모든 사상은 사악이라","reference":"시편 56:5","category":"$undefined"},{"id":"14762","book":"시편","book_name":"시편","chapter":56,"verse":6,"text":"저희가 내 생명을 엿보던 것과 같이 또 모여 숨어 내 종적을 살피나이다","reference":"시편 56:6","category":"$undefined"},{"id":"14763","book":"시편","book_name":"시편","chapter":56,"verse":7,"text":"저희가 죄악을 짓고야 피하오리이까 ? 하나님이여 분노하사 뭇 백성을 낮추소서","reference":"시편 56:7","category":"$undefined"},{"id":"14764","book":"시편","book_name":"시편","chapter":56,"verse":8,"text":"나의 유리함을 주께서 계수하셨으니 나의 눈물을 주의 병에 담으소서 ! 이것이 주의 책에 기록되지 아니하였나이까 ?","reference":"시편 56:8","category":"$undefined"},{"id":"14765","book":"시편","book_name":"시편","chapter":56,"verse":9,"text":"내가 아뢰는 날에 내 원수가 물러가리니 하나님이 나를 도우심인 줄 아나이다","reference":"시편 56:9","category":"$undefined"},{"id":"14766","book":"시편","book_name":"시편","chapter":56,"verse":10,"text":"내가 하나님을 의지하여 그 말씀을 찬송하며 여호와를 의지하여 그 말씀을 찬송하리이다","reference":"시편 56:10","category":"$undefined"},{"id":"14767","book":"시편","book_name":"시편","chapter":56,"verse":11,"text":"내가 하나님을 의지하였은즉 두려워 아니하리니 사람이 내게 어찌 하리이까 ?","reference":"시편 56:11","category":"$undefined"},{"id":"14768","book":"시편","book_name":"시편","chapter":56,"verse":12,"text":"하나님이여, 내가 주께 서원함이 있사온즉 내가 감사제를 주께 드리리니","reference":"시편 56:12","category":"$undefined"},{"id":"14769","book":"시편","book_name":"시편","chapter":56,"verse":13,"text":"주께서 내 생명을 사망에서 건지셨음이라 주께서 나로 하나님앞 생명의 빛에 다니게 하시려고 실족지 않게 하지 아니하셨나이까 ?","reference":"시편 56:13","category":"$undefined"}],"bookSlug":"psalms"}]
