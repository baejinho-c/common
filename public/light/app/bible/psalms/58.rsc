2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":58,"verses":[{"id":"14781","book":"시편","book_name":"시편","chapter":58,"verse":1,"text":"(다윗의 믹담 시. 영장으로 알다스헷에 맞춘 노래) 인자들아 ! 너희가 당연히 공의를 말하겠거늘 어찌 잠잠하느뇨 너희가 정직히 판단하느뇨","reference":"시편 58:1","category":"$undefined"},{"id":"14782","book":"시편","book_name":"시편","chapter":58,"verse":2,"text":"오히려 너희가 중심에 악을 행하며 땅에서 너희 손의 강포를 달아주는도다","reference":"시편 58:2","category":"$undefined"},{"id":"14783","book":"시편","book_name":"시편","chapter":58,"verse":3,"text":"악인은 모태에서부터 멀어졌음이여 나면서부터 곁길로 나아가 거짓을 말하는도다","reference":"시편 58:3","category":"$undefined"},{"id":"14784","book":"시편","book_name":"시편","chapter":58,"verse":4,"text":"저희의 독은 뱀의 독같으며 저희는 귀를 막은 귀머거리 독사같으니","reference":"시편 58:4","category":"$undefined"},{"id":"14785","book":"시편","book_name":"시편","chapter":58,"verse":5,"text":"곧 술사가 아무리 공교한 방술을 행할지라도 그 소리를 듣지 아니하는 독사로다","reference":"시편 58:5","category":"$undefined"},{"id":"14786","book":"시편","book_name":"시편","chapter":58,"verse":6,"text":"하나님이여, 저희 입에서 이를 꺾으소서 여호와여, 젊은 사자의 어금니를 꺾어내시며","reference":"시편 58:6","category":"$undefined"},{"id":"14787","book":"시편","book_name":"시편","chapter":58,"verse":7,"text":"저희로 급히 흐르는 물같이 사라지게 하시며 겨누는 살이 꺽임 같게 하시며","reference":"시편 58:7","category":"$undefined"},{"id":"14788","book":"시편","book_name":"시편","chapter":58,"verse":8,"text":"소멸하여 가는 달팽이 같게 하시며 만기되지 못하여 출생한 자가 일광을 보지 못함 같게 하소서","reference":"시편 58:8","category":"$undefined"},{"id":"14789","book":"시편","book_name":"시편","chapter":58,"verse":9,"text":"가시나무 불이 가마를 더웁게 하기 전에 저가 생 것과 불붙는 것을 회리바람으로 제하여 버리시리로다","reference":"시편 58:9","category":"$undefined"},{"id":"14790","book":"시편","book_name":"시편","chapter":58,"verse":10,"text":"의인은 악인의 보복 당함을 보고 기뻐함이여 그 발을 악인의 피에 씻으리로다","reference":"시편 58:10","category":"$undefined"},{"id":"14791","book":"시편","book_name":"시편","chapter":58,"verse":11,"text":"때에 사람의 말이 진실로 의인에게 갚음이 있고 진실로 땅에서 판단하시는 하나님이 계시다 하리로다","reference":"시편 58:11","category":"$undefined"}],"bookSlug":"psalms"}]
