2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":65,"verses":[{"id":"14862","book":"시편","book_name":"시편","chapter":65,"verse":1,"text":"(다윗의 시. 영장으로 한 노래) 하나님이여, 찬송이 시온에서 주를 기다리오며 사람이 서원을 주께 이행하리이다","reference":"시편 65:1","category":"$undefined"},{"id":"14863","book":"시편","book_name":"시편","chapter":65,"verse":2,"text":"기도를 들으시는 주여, 모든 육체가 주께 나아오리이다","reference":"시편 65:2","category":"$undefined"},{"id":"14864","book":"시편","book_name":"시편","chapter":65,"verse":3,"text":"죄악이 나를 이기었사오니 우리의 죄과를 주께서 사하시리이다","reference":"시편 65:3","category":"$undefined"},{"id":"14865","book":"시편","book_name":"시편","chapter":65,"verse":4,"text":"주께서 택하시고 가까이 오게 하사 주의 뜰에 거하게 하신 사람은 복이 있나이다 우리가 주의 집 곧 주의 성전의 아름다움으로 만족하리이다","reference":"시편 65:4","category":"$undefined"},{"id":"14866","book":"시편","book_name":"시편","chapter":65,"verse":5,"text":"우리 구원의 하나님이시여, 땅의 모든 끝과 먼 바다에 있는 자의 의지할 주께서 의를 좇아 엄위하신 일로 우리에게 응답하시리이 다","reference":"시편 65:5","category":"$undefined"},{"id":"14867","book":"시편","book_name":"시편","chapter":65,"verse":6,"text":"주는 주의 힘으로 산을 세우시며 권능으로 띠를 띠시며","reference":"시편 65:6","category":"$undefined"},{"id":"14868","book":"시편","book_name":"시편","chapter":65,"verse":7,"text":"바다의 흉용과 물결의 요동과 만민의 훤화까지 진정하시나이다","reference":"시편 65:7","category":"$undefined"},{"id":"14869","book":"시편","book_name":"시편","chapter":65,"verse":8,"text":"땅 끝에 거하는 자가 주의 징조를 두려워하나이다 주께서 아침 되는 것과 저녁되는 것을 즐거워하게 하시며","reference":"시편 65:8","category":"$undefined"},{"id":"14870","book":"시편","book_name":"시편","chapter":65,"verse":9,"text":"땅을 권고하사 물을 대어 심히 윤택케 하시며 하나님의 강에 물이 가득하게 하시고 이 같이 땅을 예비하신 후에 저희에게 곡식 을 주시나이다","reference":"시편 65:9","category":"$undefined"},{"id":"14871","book":"시편","book_name":"시편","chapter":65,"verse":10,"text":"주께서 밭고랑에 물을 넉넉히 대사 그 이랑을 평평하게 하시며 또 단비로 부드럽게 하시고 그 싹에 복주시나이다","reference":"시편 65:10","category":"$undefined"},{"id":"14872","book":"시편","book_name":"시편","chapter":65,"verse":11,"text":"주의 은택으로 년사에 관 씌우시니 주의 길에는 기름이 떨어지며","reference":"시편 65:11","category":"$undefined"},{"id":"14873","book":"시편","book_name":"시편","chapter":65,"verse":12,"text":"들의 초장에도 떨어지니 작은 산들이 기쁨으로 띠를 띠었나이다","reference":"시편 65:12","category":"$undefined"},{"id":"14874","book":"시편","book_name":"시편","chapter":65,"verse":13,"text":"초장에는 양떼가 입혔고 골짜기에는 곡식이 덮였으매 저희가 다 즐거이 외치고 또 노래하나이다","reference":"시편 65:13","category":"$undefined"}],"bookSlug":"psalms"}]
