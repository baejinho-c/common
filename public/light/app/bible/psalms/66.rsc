2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":66,"verses":[{"id":"14875","book":"시편","book_name":"시편","chapter":66,"verse":1,"text":"(시. 영장으로 한 노래) 온 땅이여, 하나님께 즐거운 소리를 발할지어다","reference":"시편 66:1","category":"$undefined"},{"id":"14876","book":"시편","book_name":"시편","chapter":66,"verse":2,"text":"그 이름의 영광을 찬양하고 영화롭게 찬송할지어다","reference":"시편 66:2","category":"$undefined"},{"id":"14877","book":"시편","book_name":"시편","chapter":66,"verse":3,"text":"하나님께 고하기를 주의 일이 어찌 그리 엄위하신지요 주의 큰 권능으로 인하여 주의 원수가 주께 복종할 것이며","reference":"시편 66:3","category":"$undefined"},{"id":"14878","book":"시편","book_name":"시편","chapter":66,"verse":4,"text":"온 땅이 주께 경배하고 주를 찬양하며 주의 이름을 찬양하리이다 할지어다 (셀라)","reference":"시편 66:4","category":"$undefined"},{"id":"14879","book":"시편","book_name":"시편","chapter":66,"verse":5,"text":"와서 하나님의 행하신 것을 보라 인생에게 행하심이 엄위하시도다","reference":"시편 66:5","category":"$undefined"},{"id":"14880","book":"시편","book_name":"시편","chapter":66,"verse":6,"text":"하나님이 바다를 변하여 육지되게 하셨으므로 무리가 도보로 강을 통과하고 우리가 거기서 주로 인하여 기뻐하였도다","reference":"시편 66:6","category":"$undefined"},{"id":"14881","book":"시편","book_name":"시편","chapter":66,"verse":7,"text":"저가 그 능으로 영원히 치리하시며 눈으로 열방을 감찰하시나니 거역하는 자는 자고하지 말지어다 (셀라)","reference":"시편 66:7","category":"$undefined"},{"id":"14882","book":"시편","book_name":"시편","chapter":66,"verse":8,"text":"만민들아 ! 우리 하나님을 송축하며 그 송축소리로 들리게 할찌어다","reference":"시편 66:8","category":"$undefined"},{"id":"14883","book":"시편","book_name":"시편","chapter":66,"verse":9,"text":"그는 우리 영혼을 살려 두시고 우리의 실족함을 허락지 아니하시는 주시로다","reference":"시편 66:9","category":"$undefined"},{"id":"14884","book":"시편","book_name":"시편","chapter":66,"verse":10,"text":"하나님이여, 주께서 우리를 시험하시되 우리를 단련하시기를 은을 단련함 같이 하셨으며","reference":"시편 66:10","category":"$undefined"},{"id":"14885","book":"시편","book_name":"시편","chapter":66,"verse":11,"text":"우리를 끌어 그물에 들게 하시며 어려운 짐을 우리 허리에 두셨으며","reference":"시편 66:11","category":"$undefined"},{"id":"14886","book":"시편","book_name":"시편","chapter":66,"verse":12,"text":"사람들로 우리 머리 위로 타고 가게 하셨나이다 우리가 불과 물을 통행하더니 주께서 우리를 끌어내사 풍부한 곳에 들이셨나이다","reference":"시편 66:12","category":"$undefined"},{"id":"14887","book":"시편","book_name":"시편","chapter":66,"verse":13,"text":"내가 번제를 가지고 주의 집에 들어가서 나의 서원을 갚으리니","reference":"시편 66:13","category":"$undefined"},{"id":"14888","book":"시편","book_name":"시편","chapter":66,"verse":14,"text":"이는 내 입술이 발한 것이요 내 환난 때에 내 입이 말한 것이니이다","reference":"시편 66:14","category":"$undefined"},{"id":"14889","book":"시편","book_name":"시편","chapter":66,"verse":15,"text":"내가 수양의 향기와 함께 살진 것으로 주께 번제를 드리며 수소와 염소를 드리리이다 (셀라)","reference":"시편 66:15","category":"$undefined"},{"id":"14890","book":"시편","book_name":"시편","chapter":66,"verse":16,"text":"하나님을 두려워하는 너희들아 다 와서 들으라 하나님이 내 영혼을 위하여 행하신 일을 내가 선포하리로다","reference":"시편 66:16","category":"$undefined"},{"id":"14891","book":"시편","book_name":"시편","chapter":66,"verse":17,"text":"내가 내 입으로 그에게 부르짖으며 내 혀로 높이 찬송하였도다","reference":"시편 66:17","category":"$undefined"},{"id":"14892","book":"시편","book_name":"시편","chapter":66,"verse":18,"text":"내가 내 마음에 죄악을 품으면 주께서 듣지 아니하시리라","reference":"시편 66:18","category":"$undefined"},{"id":"14893","book":"시편","book_name":"시편","chapter":66,"verse":19,"text":"그러나 하나님이 실로 들으셨으며 내 기도 소리에 주의하셨도다","reference":"시편 66:19","category":"$undefined"},{"id":"14894","book":"시편","book_name":"시편","chapter":66,"verse":20,"text":"하나님을 찬송하리로다 ! 저가 내 기도를 물리치지 아니하시고 그 인자하심을 내게서 거두지도 아니하셨도다","reference":"시편 66:20","category":"$undefined"}],"bookSlug":"psalms"}]
