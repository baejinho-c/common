11:I[1873,["9203","static/chunks/9203-ae381b7fbffaae75.js","2972","static/chunks/2972-cc56105e736753fc.js","5920","static/chunks/5920-0220998ad9e6d832.js","6678","static/chunks/6678-44347c63f7d678c3.js","1307","static/chunks/app/bible/%5Bbook%5D/%5Bchapter%5D/page-e6510753aaace286.js"],"ChapterPageClient"]
2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":69,"verses":[{"id":"14937","book":"시편","book_name":"시편","chapter":69,"verse":1,"text":"(다윗의 시. 영장으로 소산님에 맞춘 노래) 하나님이여, 나를 구원하소서 물들이 내 영혼까지 흘러들어 왔나이다","reference":"시편 69:1","category":"$undefined"},{"id":"14938","book":"시편","book_name":"시편","chapter":69,"verse":2,"text":"내가 설 곳이 없는 깊은 수렁에 빠지며 깊은 물에 들어가니 큰 물이 내게 넘치나이다","reference":"시편 69:2","category":"$undefined"},{"id":"14939","book":"시편","book_name":"시편","chapter":69,"verse":3,"text":"내가 부르짖음으로 피곤하여 내 목이 마르며 내 하나님을 바람으로 내 눈이 쇠하였나이다","reference":"시편 69:3","category":"$undefined"},{"id":"14940","book":"시편","book_name":"시편","chapter":69,"verse":4,"text":"무고히 나를 미워하는 자가 내 머리털보다 많고 무리히 내 원수가 되어 나를 끊으려 하는 자가 강하였으니 내가 취치 아니한 것도 물어 주게 되었나이다","reference":"시편 69:4","category":"$undefined"},{"id":"14941","book":"시편","book_name":"시편","chapter":69,"verse":5,"text":"하나님이여, 나의 우매함을 아시오니 내 죄가 주의 앞에서 숨김이 없나이다","reference":"시편 69:5","category":"$undefined"},{"id":"14942","book":"시편","book_name":"시편","chapter":69,"verse":6,"text":"만군의 주 여호와여, 주를 바라는 자로 나를 인하여 수치를 당케 마옵소서 이스라엘의 하나님이여 주를 찾는 자로 나를 인하여 욕을 당케 마옵소서","reference":"시편 69:6","category":"$undefined"},{"id":"14943","book":"시편","book_name":"시편","chapter":69,"verse":7,"text":"내가 주를 위하여 훼방을 받았사오니 수치가 내 얼굴에 덮였나이다","reference":"시편 69:7","category":"$undefined"},{"id":"14944","book":"시편","book_name":"시편","chapter":69,"verse":8,"text":"내가 내 형제에게는 객이 되고 내 모친의 자녀에게는 외인이 되었나이다","reference":"시편 69:8","category":"$undefined"},{"id":"14945","book":"시편","book_name":"시편","chapter":69,"verse":9,"text":"주의 집을 위하는 열성이 나를 삼키고 주를 훼방하는 훼방이 내게 미쳤나이다","reference":"시편 69:9","category":"$undefined"},{"id":"14946","book":"시편","book_name":"시편","chapter":69,"verse":10,"text":"내가 곡하고 금식함으로 내 영혼을 경계하였더니 그것이 도리어 나의 욕이 되었으며","reference":"시편 69:10","category":"$undefined"},{"id":"14947","book":"시편","book_name":"시편","chapter":69,"verse":11,"text":"내가 굵은 베로 내 옷을 삼았더니 내가 저희의 말거리가 되었나이다","reference":"시편 69:11","category":"$undefined"},{"id":"14948","book":"시편","book_name":"시편","chapter":69,"verse":12,"text":"성문에 앉은 자가 나를 말하며 취한 무리가 나를 가져 노래 하나이다","reference":"시편 69:12","category":"$undefined"},{"id":"14949","book":"시편","book_name":"시편","chapter":69,"verse":13,"text":"여호와여, 열납하시는 때에 나는 주께 기도하오니 하나님이여, 많은 인자와 구원의 진리로 내게 응답하소서","reference":"시편 69:13","category":"$undefined"},{"id":"14950","book":"시편","book_name":"시편","chapter":69,"verse":14,"text":"나를 수렁에서 건지사 빠지지 말게 하시고 나를 미워하는 자에게서와 깊은 물에서 건지소서","reference":"시편 69:14","category":"$undefined"},{"id":"14951","book":"시편","book_name":"시편","chapter":69,"verse":15,"text":"큰 물이 나를 엄몰하거나 깊음이 나를 삼키지 못하게 하시며 웅덩이로 내 위에 그 입을 닫지 못하게 하소서","reference":"시편 69:15","category":"$undefined"},{"id":"14952","book":"시편","book_name":"시편","chapter":69,"verse":16,"text":"여호와여, 주의 인자하심이 선하시오니 내게 응답하시며 주의 많은 긍휼을 따라 내게로 돌이키소서","reference":"시편 69:16","category":"$undefined"},{"id":"14953","book":"시편","book_name":"시편","chapter":69,"verse":17,"text":"주의 얼굴을 주의 종에게서 숨기지 마소서 내가 환난 중에 있사오니 속히 내게 응답하소서","reference":"시편 69:17","category":"$undefined"},{"id":"14954","book":"시편","book_name":"시편","chapter":69,"verse":18,"text":"내 영혼에게 가까이 하사 구속하시며 내 원수를 인하여 나를 속량 하소서","reference":"시편 69:18","category":"$undefined"},{"id":"14955","book":"시편","book_name":"시편","chapter":69,"verse":19,"text":"주께서 나의 훼방과 수치와 능욕을 아시나이다 내 대적이 다 주의 앞에 있나이다","reference":"시편 69:19","category":"$undefined"},{"id":"14956","book":"시편","book_name":"시편","chapter":69,"verse":20,"text":"훼방이 내 마음을 상하여 근심이 충만하니 긍휼히 여길 자를 바라나 없고 안위할 자를 바라나 찾지 못하였나이다","reference":"시편 69:20","category":"$undefined"},{"id":"14957","book":"시편","book_name":"시편","chapter":69,"verse":21,"text":"저희가 쓸개를 나의 식물로 주며 갈할 때에 초로 마시웠사오니","reference":"시편 69:21","category":"$undefined"},{"id":"14958","book":"시편","book_name":"시편","chapter":69,"verse":22,"text":"저희 앞에 밥상이 올무가 되게 하시며 저희 평안이 덫이 되게 하소서","reference":"시편 69:22","category":"$undefined"},{"id":"14959","book":"시편","book_name":"시편","chapter":69,"verse":23,"text":"저희 눈이 어두워 보지 못하게 하시며 그 허리가 항상 떨리게 하소서","reference":"시편 69:23","category":"$undefined"},{"id":"14960","book":"시편","book_name":"시편","chapter":69,"verse":24,"text":"주의 분노를 저희 위에 부으시며 주의 맹렬하신 노로 저희에게 미치게 하소서","reference":"시편 69:24","category":"$undefined"},{"id":"14961","book":"시편","book_name":"시편","chapter":69,"verse":25,"text":"저희 거처로 황폐하게 하시며 그 장막에 거하는 자가 없게 하소서","reference":"시편 69:25","category":"$undefined"},{"id":"14962","book":"시편","book_name":"시편","chapter":69,"verse":26,"text":"대저 저희가 주의 치신 자를 핍박하며 주께서 상케 하신 자의 슬픔을 말하였사오니","reference":"시편 69:26","category":"$undefined"},{"id":"14963","book":"시편","book_name":"시편","chapter":69,"verse":27,"text":"저희 죄악에 죄악을 더 정하사 주의 의에 들어오지 못하게 하소서","reference":"시편 69:27","category":"$undefined"},{"id":"14964","book":"시편","book_name":"시편","chapter":69,"verse":28,"text":"저희를 생명책에서 도말하사 의인과 함께 기록되게 마소서","reference":"시편 69:28","category":"$undefined"},{"id":"14965","book":"시편","book_name":"시편","chapter":69,"verse":29,"text":"오직 나는 가난하고 슬프오니 하나님이여, 주의 구원으로 나를 높이소서","reference":"시편 69:29","category":"$undefined"},{"id":"14966","book":"시편","book_name":"시편","chapter":69,"verse":30,"text":"내가 노래로 하나님의 이름을 찬송하며 감사함으로 하나님을 광대하시다 하리니","reference":"시편 69:30","category":"$undefined"},{"id":"14967","book":"시편","book_name":"시편","chapter":69,"verse":31,"text":"이것이 소 곧 뿔과 굽이 있는 황소를 드림보다 여호와를 더욱 기쁘시게 함이 될 것이라","reference":"시편 69:31","category":"$undefined"},{"id":"14968","book":"시편","book_name":"시편","chapter":69,"verse":32,"text":"온유한 자가 이를 보고 기뻐하나니 하나님을 찾는 너희들아 ! 너희 마음을 소생케 할지어다","reference":"시편 69:32","category":"$undefined"},{"id":"14969","book":"시편","book_name":"시편","chapter":69,"verse":33,"text":"여호와는 궁핍한 자를 들으시며 자기를 인하여 수금된 자를 멸시치 아니하시나니","reference":"시편 69:33","category":"$undefined"},{"id":"14970","book":"시편","book_name":"시편","chapter":69,"verse":34,"text":"천지가 그를 찬송할 것이요 바다와 그 중의 모든 동물도 그리할지로다","reference":"시편 69:34","category":"$undefined"},{"id":"14971","book":"시편","book_name":"시편","chapter":69,"verse":35,"text":"하나님이 시온을 구원하시고 유다 성읍들을 건설하시리니 무리가 거기 거하여 소유를 삼으리로다","reference":"시편 69:35","category":"$undefined"},{"id":"14972","book":"시편","book_name":"시편","chapter":69,"verse":36,"text":"그 종들의 후손이 또한 이를 상속하고 그 이름을 사랑하는 자가 그 중에 거하리로다","reference":"시편 69:36","category":"$undefined"}],"bookSlug":"psalms"}]
