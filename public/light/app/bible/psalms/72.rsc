2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":72,"verses":[{"id":"15002","book":"시편","book_name":"시편","chapter":72,"verse":1,"text":"(솔로몬의 시) 하나님이여, 주의 판단력을 왕에게 주시고 주의 의를 왕의 아들에게 주소서","reference":"시편 72:1","category":"$undefined"},{"id":"15003","book":"시편","book_name":"시편","chapter":72,"verse":2,"text":"저가 주의 백성을 의로 판단하며 주의 가난한 자를 공의로 판단하리니","reference":"시편 72:2","category":"$undefined"},{"id":"15004","book":"시편","book_name":"시편","chapter":72,"verse":3,"text":"의로 인하여 산들이 백성에게 평강을 주며 작은 산들도 그리하리로다","reference":"시편 72:3","category":"$undefined"},{"id":"15005","book":"시편","book_name":"시편","chapter":72,"verse":4,"text":"저가 백성의 가난한 자를 신원하며 궁핍한 자의 자손을 구원하며 압박하는 자를 꺾으리로다","reference":"시편 72:4","category":"$undefined"},{"id":"15006","book":"시편","book_name":"시편","chapter":72,"verse":5,"text":"저희가 해가 있을 동안에 주를 두려워하며 달이 있을 동안에 대대로 그리하리로다","reference":"시편 72:5","category":"$undefined"},{"id":"15007","book":"시편","book_name":"시편","chapter":72,"verse":6,"text":"저는 벤 풀에 내리는 비같이 땅을 적시는 소낙비 같이 임하리니","reference":"시편 72:6","category":"$undefined"},{"id":"15008","book":"시편","book_name":"시편","chapter":72,"verse":7,"text":"저의 날에 의인이 흥왕하여 평강의 풍성함이 달이 다할 때까지 이르리로다","reference":"시편 72:7","category":"$undefined"},{"id":"15009","book":"시편","book_name":"시편","chapter":72,"verse":8,"text":"저가 바다에서부터 바다까지와 강에서부터 땅 끝까지 다스리리니","reference":"시편 72:8","category":"$undefined"},{"id":"15010","book":"시편","book_name":"시편","chapter":72,"verse":9,"text":"광야에 거하는 자는 저의 앞에 굽히며 그 원수들은 티끌을 핥을것이며","reference":"시편 72:9","category":"$undefined"},{"id":"15011","book":"시편","book_name":"시편","chapter":72,"verse":10,"text":"다시스와 섬의 왕들이 공세를 바치며 스바와 시바 왕들이 예물을 드리리로다","reference":"시편 72:10","category":"$undefined"},{"id":"15012","book":"시편","book_name":"시편","chapter":72,"verse":11,"text":"만왕이 그 앞에 부복하며 열방이 다 그를 섬기리로다","reference":"시편 72:11","category":"$undefined"},{"id":"15013","book":"시편","book_name":"시편","chapter":72,"verse":12,"text":"저는 궁핍한 자의 부르짖을 때에 건지며 도움이 없는 가난한 자도 건지며","reference":"시편 72:12","category":"$undefined"},{"id":"15014","book":"시편","book_name":"시편","chapter":72,"verse":13,"text":"저는 가난한 자와 궁핍한 자를 긍휼히 여기며 궁핍한 자의 생명을 구원하며","reference":"시편 72:13","category":"$undefined"},{"id":"15015","book":"시편","book_name":"시편","chapter":72,"verse":14,"text":"저희 생명을 압박과 강포에서 구속하리니 저희 피가 그 목전에 귀하리로다","reference":"시편 72:14","category":"$undefined"},{"id":"15016","book":"시편","book_name":"시편","chapter":72,"verse":15,"text":"저희가 생존하여 스바의 금을 저에게 드리며 사람들이 저를 위하여 항상 기도하고 종일 찬송하리로다","reference":"시편 72:15","category":"$undefined"},{"id":"15017","book":"시편","book_name":"시편","chapter":72,"verse":16,"text":"산꼭대기의 땅에도 화곡이 풍성하고 그 열매가 레바논 같이 흔들리며 성에 있는 자가 땅의 풀같이 왕성하리로다","reference":"시편 72:16","category":"$undefined"},{"id":"15018","book":"시편","book_name":"시편","chapter":72,"verse":17,"text":"그 이름이 영구함이여, 그 이름이 해와 같이 장구하리로다 사람들이 그로 인하여 복을 받으리니 열방이 다 그를 복되다 하리로다","reference":"시편 72:17","category":"$undefined"},{"id":"15019","book":"시편","book_name":"시편","chapter":72,"verse":18,"text":"홀로 기사를 행하시는 여호와 하나님 곧 이스라엘의 하나님을 찬송하며","reference":"시편 72:18","category":"$undefined"},{"id":"15020","book":"시편","book_name":"시편","chapter":72,"verse":19,"text":"그 영화로운 이름을 영원히 찬송할지어다 ! 온 땅에 그 영광이 충만할지어다 ! 아멘, 아멘 이새의 아들 다윗의 기도가 필하다","reference":"시편 72:19","category":"$undefined"},{"id":"15021","book":"시편","book_name":"시편","chapter":72,"verse":20,"text":"","reference":"시편 72:20","category":"$undefined"}],"bookSlug":"psalms"}]
