2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":73,"verses":[{"id":"15022","book":"시편","book_name":"시편","chapter":73,"verse":1,"text":"(아삽의 시) 하나님이 참으로 이스라엘 중 마음이 정결한 자에게 선을 행하시나","reference":"시편 73:1","category":"$undefined"},{"id":"15023","book":"시편","book_name":"시편","chapter":73,"verse":2,"text":"나는 거의 실족할 뻔 하였고 내 걸음이 미끄러질 뻔 하였으니","reference":"시편 73:2","category":"$undefined"},{"id":"15024","book":"시편","book_name":"시편","chapter":73,"verse":3,"text":"이는 내가 악인의 형통함을 보고 오만한 자를 질시하였음이로다","reference":"시편 73:3","category":"$undefined"},{"id":"15025","book":"시편","book_name":"시편","chapter":73,"verse":4,"text":"저희는 죽는 때에도 고통이 없고 그 힘이 건강하며","reference":"시편 73:4","category":"$undefined"},{"id":"15026","book":"시편","book_name":"시편","chapter":73,"verse":5,"text":"타인과 같은 고난이 없고 타인과 같은 재앙도 없나니","reference":"시편 73:5","category":"$undefined"},{"id":"15027","book":"시편","book_name":"시편","chapter":73,"verse":6,"text":"그러므로 교만이 저희 목걸이요 강포가 저희의 입는 옷이며","reference":"시편 73:6","category":"$undefined"},{"id":"15028","book":"시편","book_name":"시편","chapter":73,"verse":7,"text":"살찜으로 저희 눈이 솟아나며 저희 소득은 마음의 소원보다 지나며","reference":"시편 73:7","category":"$undefined"},{"id":"15029","book":"시편","book_name":"시편","chapter":73,"verse":8,"text":"저희는 능욕하며 악하게 압제하여 말하며 거만히 말하며","reference":"시편 73:8","category":"$undefined"},{"id":"15030","book":"시편","book_name":"시편","chapter":73,"verse":9,"text":"저희 입은 하늘에 두고 저희 혀는 땅에 두루 다니도다","reference":"시편 73:9","category":"$undefined"},{"id":"15031","book":"시편","book_name":"시편","chapter":73,"verse":10,"text":"그러므로 그 백성이 이리로 돌아와서 잔에 가득한 물을 다 마시며","reference":"시편 73:10","category":"$undefined"},{"id":"15032","book":"시편","book_name":"시편","chapter":73,"verse":11,"text":"말하기를 하나님이 어찌 알랴 지극히 높은 자에게 지식이 있으랴 하도다","reference":"시편 73:11","category":"$undefined"},{"id":"15033","book":"시편","book_name":"시편","chapter":73,"verse":12,"text":"볼지어다 ! 이들은 악인이라 항상 평안하고 재물은 더 하도다","reference":"시편 73:12","category":"$undefined"},{"id":"15034","book":"시편","book_name":"시편","chapter":73,"verse":13,"text":"내가 내 마음을 정히 하며 내 손을 씻어 무죄하다 한 것이 실로 헛되도다","reference":"시편 73:13","category":"$undefined"},{"id":"15035","book":"시편","book_name":"시편","chapter":73,"verse":14,"text":"나는 종일 재앙을 당하며 아침마다 징책을 보았도다","reference":"시편 73:14","category":"$undefined"},{"id":"15036","book":"시편","book_name":"시편","chapter":73,"verse":15,"text":"내가 만일 스스로 이르기를 내가 이렇게 말하리라 하였더면 주의 아들들의 시대를 대하여 궤휼을 행하였으리이다","reference":"시편 73:15","category":"$undefined"},{"id":"15037","book":"시편","book_name":"시편","chapter":73,"verse":16,"text":"내가 어찌면 이를 알까 하여 생각한즉 내게 심히 곤란하더니","reference":"시편 73:16","category":"$undefined"},{"id":"15038","book":"시편","book_name":"시편","chapter":73,"verse":17,"text":"하나님의 성소에 들어갈 때에야 저희 결국을 내가 깨달았나이다","reference":"시편 73:17","category":"$undefined"},{"id":"15039","book":"시편","book_name":"시편","chapter":73,"verse":18,"text":"주께서 참으로 저희를 미끄러운 곳에 두시며 파멸에 던지시니","reference":"시편 73:18","category":"$undefined"},{"id":"15040","book":"시편","book_name":"시편","chapter":73,"verse":19,"text":"저희가 어찌 그리 졸지에 황폐되었는가 놀람으로 전멸하였나이다","reference":"시편 73:19","category":"$undefined"},{"id":"15041","book":"시편","book_name":"시편","chapter":73,"verse":20,"text":"주여, 사람이 깬 후에는 꿈을 무시함같이 주께서 깨신 후에 저희 형상을 멸시하시리이다","reference":"시편 73:20","category":"$undefined"},{"id":"15042","book":"시편","book_name":"시편","chapter":73,"verse":21,"text":"내 마음이 산란하며 내 심장이 찔렸나이다","reference":"시편 73:21","category":"$undefined"},{"id":"15043","book":"시편","book_name":"시편","chapter":73,"verse":22,"text":"내가 이같이 우매 무지하니 주의 앞에 짐승이오나","reference":"시편 73:22","category":"$undefined"},{"id":"15044","book":"시편","book_name":"시편","chapter":73,"verse":23,"text":"내가 항상 주와 함께하니 주께서 내 오른손을 붙드셨나이다","reference":"시편 73:23","category":"$undefined"},{"id":"15045","book":"시편","book_name":"시편","chapter":73,"verse":24,"text":"주의 교훈으로 나를 인도하시고 후에는 영광으로 나를 영접하시리니","reference":"시편 73:24","category":"$undefined"},{"id":"15046","book":"시편","book_name":"시편","chapter":73,"verse":25,"text":"하늘에서는 주 외에 누가 내게 있리요 땅에서는 주 밖에 나의 사모할 자 없나이다","reference":"시편 73:25","category":"$undefined"},{"id":"15047","book":"시편","book_name":"시편","chapter":73,"verse":26,"text":"내 육체와 마음은 쇠잔하나 하나님은 내 마음의 반석이시요 영원한 분깃이시라","reference":"시편 73:26","category":"$undefined"},{"id":"15048","book":"시편","book_name":"시편","chapter":73,"verse":27,"text":"대저 주를 멀리하는 자는 망하리니 음녀 같이 주를 떠난 자를 주께서 다 멸하셨나이다","reference":"시편 73:27","category":"$undefined"},{"id":"15049","book":"시편","book_name":"시편","chapter":73,"verse":28,"text":"하나님께 가까이 함이 내게 복이라 내가 주 여호와를 나의 피난처로 삼아 주의 모든 행사를 전파하리이다","reference":"시편 73:28","category":"$undefined"}],"bookSlug":"psalms"}]
