2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":81,"verses":[{"id":"15219","book":"시편","book_name":"시편","chapter":81,"verse":1,"text":"(아삽의 시. 영장으로 깃딧이 맞춘 노래) 우리 능력 되신 하나님께 높이 노래하며 야곱의 하나님께 즐거이 노래할지어다","reference":"시편 81:1","category":"$undefined"},{"id":"15220","book":"시편","book_name":"시편","chapter":81,"verse":2,"text":"시를 읊으며 소고를 치고 아름다운 수금에 비파를 아우를지어다","reference":"시편 81:2","category":"$undefined"},{"id":"15221","book":"시편","book_name":"시편","chapter":81,"verse":3,"text":"월삭과 월망과 우리의 절일에 나팔을 불지어다","reference":"시편 81:3","category":"$undefined"},{"id":"15222","book":"시편","book_name":"시편","chapter":81,"verse":4,"text":"이는 이스라엘의 율례요 야곱의 하나님의 규례로다","reference":"시편 81:4","category":"$undefined"},{"id":"15223","book":"시편","book_name":"시편","chapter":81,"verse":5,"text":"하나님이 애굽 땅을 치러 나가시던 때에 요셉의 족속 중에 이를 증거로 세우셨도다 거기서 내가 알지 못하던 말씀을 들었나니","reference":"시편 81:5","category":"$undefined"},{"id":"15224","book":"시편","book_name":"시편","chapter":81,"verse":6,"text":"이르시되 내가 그 어깨에서 짐을 벗기고 그 손에서 광주리를 놓게 하였도다","reference":"시편 81:6","category":"$undefined"},{"id":"15225","book":"시편","book_name":"시편","chapter":81,"verse":7,"text":"네가 고난 중에 부르짖으매 내가 너를 건졌고 뇌성의 은은한 곳에서 네게 응답하며 므리바 물가에서 너를 시험하였도다 (셀라)","reference":"시편 81:7","category":"$undefined"},{"id":"15226","book":"시편","book_name":"시편","chapter":81,"verse":8,"text":"내 백성이여 들으라 내가 네게 증거하리라 이스라엘이여, 내게 듣기를 원하노라","reference":"시편 81:8","category":"$undefined"},{"id":"15227","book":"시편","book_name":"시편","chapter":81,"verse":9,"text":"너희 중에 다른 신을 두지 말며 이방신에게 절하지 말지어다","reference":"시편 81:9","category":"$undefined"},{"id":"15228","book":"시편","book_name":"시편","chapter":81,"verse":10,"text":"나는 너를 애굽 땅에서 인도하여 낸 여호와 네 하나님이니 네 입을 넓게 열라 내가 채우리라 하였으나","reference":"시편 81:10","category":"$undefined"},{"id":"15229","book":"시편","book_name":"시편","chapter":81,"verse":11,"text":"내 백성이 내 소리를 듣지 아니하며 이스라엘이 나를 원치 아니하였도다","reference":"시편 81:11","category":"$undefined"},{"id":"15230","book":"시편","book_name":"시편","chapter":81,"verse":12,"text":"그러므로 내가 그 마음의 강퍅한대로 버려두어 그 임의대로 행케 하였도다","reference":"시편 81:12","category":"$undefined"},{"id":"15231","book":"시편","book_name":"시편","chapter":81,"verse":13,"text":"내 백성이 나를 청종하며 이스라엘이 내 도 행하기를 원하노라","reference":"시편 81:13","category":"$undefined"},{"id":"15232","book":"시편","book_name":"시편","chapter":81,"verse":14,"text":"그리하면 내가 속히 저희 원수를 제어하며 내 손을 돌려 저희 대적을 치리니","reference":"시편 81:14","category":"$undefined"},{"id":"15233","book":"시편","book_name":"시편","chapter":81,"verse":15,"text":"여호와를 한하는 자는 저에게 복종하는 체 할지라도 저희 시대는 영원히 계속하리라","reference":"시편 81:15","category":"$undefined"},{"id":"15234","book":"시편","book_name":"시편","chapter":81,"verse":16,"text":"내가 또 밀의 아름다운 것으로 저희에게 먹이며 반석에서 나오는 꿀로 너를 만족케 하리라 하셨도다","reference":"시편 81:16","category":"$undefined"}],"bookSlug":"psalms"}]
