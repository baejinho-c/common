2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":84,"verses":[{"id":"15261","book":"시편","book_name":"시편","chapter":84,"verse":1,"text":"(고라 자손의 시. 영장으로 깃딧에 맞춘 노래) 만군의 여호와여, 주의 장막이 어찌 그리 사랑스러운지요","reference":"시편 84:1","category":"$undefined"},{"id":"15262","book":"시편","book_name":"시편","chapter":84,"verse":2,"text":"내 영혼이 여호와의 궁정을 사모하여 쇠약함이여 내 마음과 육체가 생존하시는 하나님께 부르짖나이다","reference":"시편 84:2","category":"$undefined"},{"id":"15263","book":"시편","book_name":"시편","chapter":84,"verse":3,"text":"나의 왕, 나의 하나님, 만군의 여호와여, 주의 제단에서 참새도 제 집을 얻고 제비도 새끼 둘 보금자리를 얻었나이다","reference":"시편 84:3","category":"$undefined"},{"id":"15264","book":"시편","book_name":"시편","chapter":84,"verse":4,"text":"주의 집에 거하는 자가 복이 있나이다 저희가 항상 주를 찬송하리이다 셀라","reference":"시편 84:4","category":"$undefined"},{"id":"15265","book":"시편","book_name":"시편","chapter":84,"verse":5,"text":"주께 힘을 얻고 그 마음에 시온의 대로가 있는 자는 복이 있나이다","reference":"시편 84:5","category":"$undefined"},{"id":"15266","book":"시편","book_name":"시편","chapter":84,"verse":6,"text":"저희는 눈물 골짜기로 통행할 때에 그 곳으로 많은 샘의 곳이 되게 하며 이른 비도 은택을 입히나이다","reference":"시편 84:6","category":"$undefined"},{"id":"15267","book":"시편","book_name":"시편","chapter":84,"verse":7,"text":"저희는 힘을 얻고 더 얻어 나아가 시온에서 하나님 앞에 각기 나타나리이다","reference":"시편 84:7","category":"$undefined"},{"id":"15268","book":"시편","book_name":"시편","chapter":84,"verse":8,"text":"만군의 하나님 여호와여, 내 기도를 들으소서 야곱의 하나님이여, 귀를 기울이소서 (셀라)","reference":"시편 84:8","category":"$undefined"},{"id":"15269","book":"시편","book_name":"시편","chapter":84,"verse":9,"text":"우리 방패이신 하나님이여, 주의 기름 부으신 자의 얼굴을 살펴보옵소서","reference":"시편 84:9","category":"$undefined"},{"id":"15270","book":"시편","book_name":"시편","chapter":84,"verse":10,"text":"주의 궁정에서 한 날이 다른 곳에서 천 날보다 나은즉 악인의 장막에 거함보다 내 하나님 문지기로 있는 것이 좋사오니","reference":"시편 84:10","category":"$undefined"},{"id":"15271","book":"시편","book_name":"시편","chapter":84,"verse":11,"text":"여호와 하나님은 해요 방패시라 여호와께서 은혜와 영화를 주시며 정직히 행하는 자에게 좋은 것을 아끼지 아니하실 것임이니이다","reference":"시편 84:11","category":"$undefined"},{"id":"15272","book":"시편","book_name":"시편","chapter":84,"verse":12,"text":"만군의 여호와여, 주께 의지하는 자는 복이 있나이다","reference":"시편 84:12","category":"$undefined"}],"bookSlug":"psalms"}]
