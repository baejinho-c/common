2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":86,"verses":[{"id":"15286","book":"시편","book_name":"시편","chapter":86,"verse":1,"text":"(다윗의 기도) 여호와여, 나는 곤고하고 궁핍하오니 귀를 기울여 내게 응답하소서","reference":"시편 86:1","category":"$undefined"},{"id":"15287","book":"시편","book_name":"시편","chapter":86,"verse":2,"text":"나는 경건하오니 내 영혼을 보존하소서 내 주 하나님이여, 주를 의지하는 종을 구원하소서","reference":"시편 86:2","category":"$undefined"},{"id":"15288","book":"시편","book_name":"시편","chapter":86,"verse":3,"text":"주여, 나를 긍휼히 여기소서 내가 종일 주께 부르짖나이다","reference":"시편 86:3","category":"$undefined"},{"id":"15289","book":"시편","book_name":"시편","chapter":86,"verse":4,"text":"주여, 내 영혼이 주를 우러러 보오니 주여 내 영혼을 기쁘게 하소서","reference":"시편 86:4","category":"$undefined"},{"id":"15290","book":"시편","book_name":"시편","chapter":86,"verse":5,"text":"주는 선하사 사유하기를 즐기시며 주께 부르짖는 자에게 인자함이 후하심이니이다","reference":"시편 86:5","category":"$undefined"},{"id":"15291","book":"시편","book_name":"시편","chapter":86,"verse":6,"text":"여호와여, 나의 기도에 귀를 기울이시고 나의 간구하는 소리를 들으소서","reference":"시편 86:6","category":"$undefined"},{"id":"15292","book":"시편","book_name":"시편","chapter":86,"verse":7,"text":"나의 환난 날에 내가 주께 부르짖으리니 주께서 내게 응답하시리이다","reference":"시편 86:7","category":"$undefined"},{"id":"15293","book":"시편","book_name":"시편","chapter":86,"verse":8,"text":"주여, 신들 중에 주와 같은 자 없사오며 주의 행사와 같음도 없나이다","reference":"시편 86:8","category":"$undefined"},{"id":"15294","book":"시편","book_name":"시편","chapter":86,"verse":9,"text":"주여, 주의 지으신 모든 열방이 와서 주의 앞에 경배하며 주의 이름에 영화를 돌리리이다","reference":"시편 86:9","category":"$undefined"},{"id":"15295","book":"시편","book_name":"시편","chapter":86,"verse":10,"text":"대저 주는 광대하사 기사를 행하시오니 주만 하나님이시니이다","reference":"시편 86:10","category":"$undefined"},{"id":"15296","book":"시편","book_name":"시편","chapter":86,"verse":11,"text":"여호와여, 주의 도로 내게 가르치소서 내가 주의 진리에 행하오리니 일심으로 주의 이름을 경외하게 하소서","reference":"시편 86:11","category":"$undefined"},{"id":"15297","book":"시편","book_name":"시편","chapter":86,"verse":12,"text":"주 나의 하나님이여, 내가 전심으로 주를 찬송하고 영영토록 주의 이름에 영화를 돌리오리니","reference":"시편 86:12","category":"$undefined"},{"id":"15298","book":"시편","book_name":"시편","chapter":86,"verse":13,"text":"이는 내게 향하신 주의 인자가 크사 내 영혼을 깊은 음부에서 건지셨음이니이다","reference":"시편 86:13","category":"$undefined"},{"id":"15299","book":"시편","book_name":"시편","chapter":86,"verse":14,"text":"하나님이여, 교만한 자가 일어나 나를 치고 강포한 자의 무리가 내 혼을 찾았사오며 자기 앞에 주를 두지 아니하였나이다","reference":"시편 86:14","category":"$undefined"},{"id":"15300","book":"시편","book_name":"시편","chapter":86,"verse":15,"text":"그러나 주여, 주는 긍휼히 여기시며 은혜를 베푸시며 노하기를 더디 하시며 인자와 진실이 풍성하신 하나님이시오니","reference":"시편 86:15","category":"$undefined"},{"id":"15301","book":"시편","book_name":"시편","chapter":86,"verse":16,"text":"내게로 돌이키사 나를 긍휼히 여기소서 주의 종에게 힘을 주시고 주의 여종의 아들을 구원하소서","reference":"시편 86:16","category":"$undefined"},{"id":"15302","book":"시편","book_name":"시편","chapter":86,"verse":17,"text":"은총의 표징을 내게 보이소서 그러면 나를 미워하는 저희가 보고 부끄러워하오리니 여호와여, 주는 나를 돕고 위로하심이니이다","reference":"시편 86:17","category":"$undefined"}],"bookSlug":"psalms"}]
