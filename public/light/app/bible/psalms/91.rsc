2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":91,"verses":[{"id":"15397","book":"시편","book_name":"시편","chapter":91,"verse":1,"text":"지존자의 은밀한 곳에 거하는 자는 전능하신 자의 그늘 아래 거하리로다","reference":"시편 91:1","category":"$undefined"},{"id":"15398","book":"시편","book_name":"시편","chapter":91,"verse":2,"text":"내가 여호와를 가리켜 말하기를 저는 나의 피난처요, 나의 요새요, 나의 의뢰하는 하나님이라 하리니","reference":"시편 91:2","category":"$undefined"},{"id":"15399","book":"시편","book_name":"시편","chapter":91,"verse":3,"text":"이는 저가 너를 새 사냥군의 올무에서와 극한 염병에서 건지실 것임이로다","reference":"시편 91:3","category":"$undefined"},{"id":"15400","book":"시편","book_name":"시편","chapter":91,"verse":4,"text":"저가 너를 그 깃으로 덮으시리니 네가 그 날개 아래 피하리로다 그의 진실함은 방패와 손 방패가 되나니","reference":"시편 91:4","category":"$undefined"},{"id":"15401","book":"시편","book_name":"시편","chapter":91,"verse":5,"text":"너는 밤에 놀램과 낮에 흐르는 살과","reference":"시편 91:5","category":"$undefined"},{"id":"15402","book":"시편","book_name":"시편","chapter":91,"verse":6,"text":"흑암 중에 행하는 염병과 백주에 황폐케 하는 파멸을 두려워 아니하리로다","reference":"시편 91:6","category":"$undefined"},{"id":"15403","book":"시편","book_name":"시편","chapter":91,"verse":7,"text":"천인이 네 곁에서, 만인이 네 우편에서 엎드러지나 이 재앙이 네게 가까이 못하리로다","reference":"시편 91:7","category":"$undefined"},{"id":"15404","book":"시편","book_name":"시편","chapter":91,"verse":8,"text":"오직 너는 목도하리니 악인의 보응이 네게 보이리로다","reference":"시편 91:8","category":"$undefined"},{"id":"15405","book":"시편","book_name":"시편","chapter":91,"verse":9,"text":"네가 말하기를 여호와는 나의 피난처시라 하고 지존자로 거처를 삼았으므로","reference":"시편 91:9","category":"$undefined"},{"id":"15406","book":"시편","book_name":"시편","chapter":91,"verse":10,"text":"화가 네게 미치지 못하며 재앙이 네 장막에 가까이 오지 못하리니","reference":"시편 91:10","category":"$undefined"},{"id":"15407","book":"시편","book_name":"시편","chapter":91,"verse":11,"text":"저가 너를 위하여 그 사자들을 명하사 네 모든 길에 너를 지키게 하심이라","reference":"시편 91:11","category":"$undefined"},{"id":"15408","book":"시편","book_name":"시편","chapter":91,"verse":12,"text":"저희가 그 손으로 너를 붙들어 발이 돌에 부딪히지 않게 하리로다","reference":"시편 91:12","category":"$undefined"},{"id":"15409","book":"시편","book_name":"시편","chapter":91,"verse":13,"text":"네가 사자와 독사를 밟으며 젊은 사자와 뱀을 발로 누르리로다","reference":"시편 91:13","category":"$undefined"},{"id":"15410","book":"시편","book_name":"시편","chapter":91,"verse":14,"text":"하나님이 가라사대 저가 나를 사랑한즉 내가 저를 건지리라 저가 내 이름을 안즉 내가 저를 높이리라","reference":"시편 91:14","category":"$undefined"},{"id":"15411","book":"시편","book_name":"시편","chapter":91,"verse":15,"text":"저가 내게 간구하리니 내가 응답하리라 저희 환난 때에 내가 저와 함께하여 저를 건지고 영화롭게 하리라","reference":"시편 91:15","category":"$undefined"},{"id":"15412","book":"시편","book_name":"시편","chapter":91,"verse":16,"text":"내가 장수함으로 저를 만족케 하며 나의 구원으로 보이리라 하시도다","reference":"시편 91:16","category":"$undefined"}],"bookSlug":"psalms"}]
