2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":94,"verses":[{"id":"15433","book":"시편","book_name":"시편","chapter":94,"verse":1,"text":"여호와여, 보수하시는 하나님이여, 보수하시는 하나님이여, 빛을 비취소서","reference":"시편 94:1","category":"$undefined"},{"id":"15434","book":"시편","book_name":"시편","chapter":94,"verse":2,"text":"세계를 판단하시는 주여 일어나사 교만한 자에게 상당한 형벌을 주소서","reference":"시편 94:2","category":"$undefined"},{"id":"15435","book":"시편","book_name":"시편","chapter":94,"verse":3,"text":"여호와여, 악인이 언제까지, 악인이 언제까지 개가를 부르리이까","reference":"시편 94:3","category":"$undefined"},{"id":"15436","book":"시편","book_name":"시편","chapter":94,"verse":4,"text":"저희가 지껄이며 오만히 말을 하오며 죄악을 행하는 자가 다 자긍하나이다","reference":"시편 94:4","category":"$undefined"},{"id":"15437","book":"시편","book_name":"시편","chapter":94,"verse":5,"text":"여호와여, 저희가 주의 백성을 파쇄하며 주의 기업을 곤고케 하며","reference":"시편 94:5","category":"$undefined"},{"id":"15438","book":"시편","book_name":"시편","chapter":94,"verse":6,"text":"과부와 나그네를 죽이며 고아를 살해하며","reference":"시편 94:6","category":"$undefined"},{"id":"15439","book":"시편","book_name":"시편","chapter":94,"verse":7,"text":"말하기를 여호와가 보지 못하며 야곱의 하나님이 생각지 못하리라 하나이다","reference":"시편 94:7","category":"$undefined"},{"id":"15440","book":"시편","book_name":"시편","chapter":94,"verse":8,"text":"백성 중 우준한 자들아 너희는 생각하라 무지한 자들아 너희가 언제나 지혜로울꼬","reference":"시편 94:8","category":"$undefined"},{"id":"15441","book":"시편","book_name":"시편","chapter":94,"verse":9,"text":"귀를 지으신 자가 듣지 아니하시랴 눈을 만드신 자가 보지 아니하시랴","reference":"시편 94:9","category":"$undefined"},{"id":"15442","book":"시편","book_name":"시편","chapter":94,"verse":10,"text":"열방을 징벌하시는 자 곧 지식으로 사람을 교훈하시는 자가 징치하지 아니하시랴","reference":"시편 94:10","category":"$undefined"},{"id":"15443","book":"시편","book_name":"시편","chapter":94,"verse":11,"text":"여호와께서 사람의 생각이 허무함을 아시느니라","reference":"시편 94:11","category":"$undefined"},{"id":"15444","book":"시편","book_name":"시편","chapter":94,"verse":12,"text":"여호와여, 주의 징벌을 당하며 주의 법으로 교훈하심을 받는 자가 복이 있나니","reference":"시편 94:12","category":"$undefined"},{"id":"15445","book":"시편","book_name":"시편","chapter":94,"verse":13,"text":"이런 사람에게는 환난의 날에 벗어나게 하사 악인을 위하여 구덩이를 팔 때까지 평안을 주시리이다","reference":"시편 94:13","category":"$undefined"},{"id":"15446","book":"시편","book_name":"시편","chapter":94,"verse":14,"text":"여호와께서는 그 백성을 버리지 아니하시며 그 기업을 떠나지 아니하시리로다","reference":"시편 94:14","category":"$undefined"},{"id":"15447","book":"시편","book_name":"시편","chapter":94,"verse":15,"text":"판단이 의로 돌아가리니 마음이 정직한 자가 다 좇으리로다","reference":"시편 94:15","category":"$undefined"},{"id":"15448","book":"시편","book_name":"시편","chapter":94,"verse":16,"text":"누가 나를 위하여 일어나서 행악자를 치며 누가 나를 위하여 일어서서 죄악 행하는 자를 칠꼬","reference":"시편 94:16","category":"$undefined"},{"id":"15449","book":"시편","book_name":"시편","chapter":94,"verse":17,"text":"여호와께서 내게 도움이 되지 아니하셨더면 내 혼이 벌써 적막 중에 처하였으리로다","reference":"시편 94:17","category":"$undefined"},{"id":"15450","book":"시편","book_name":"시편","chapter":94,"verse":18,"text":"여호와여, 나의 발이 미끄러진다 말할 때에 주의 인자하심이 나를 붙드셨사오며","reference":"시편 94:18","category":"$undefined"},{"id":"15451","book":"시편","book_name":"시편","chapter":94,"verse":19,"text":"내 속에 생각이 많을 때에 주의 위안이 내 영혼을 즐겁게 하시나이다","reference":"시편 94:19","category":"$undefined"},{"id":"15452","book":"시편","book_name":"시편","chapter":94,"verse":20,"text":"율례를 빙자하고 잔해를 도모하는 악한 재판장이 어찌 주와 교제하리이까","reference":"시편 94:20","category":"$undefined"},{"id":"15453","book":"시편","book_name":"시편","chapter":94,"verse":21,"text":"저희가 모여 의인의 영혼을 치려 하며 무죄자를 정죄하여 피를 흘리려 하나","reference":"시편 94:21","category":"$undefined"},{"id":"15454","book":"시편","book_name":"시편","chapter":94,"verse":22,"text":"여호와는 나의 산성이시요 나의 하나님은 나의 피할 반석이시라","reference":"시편 94:22","category":"$undefined"},{"id":"15455","book":"시편","book_name":"시편","chapter":94,"verse":23,"text":"저희 죄악을 저희에게 돌리시며 저희의 악을 인하여 저희를 끊으시리니 여호와 우리 하나님이 저희를 끊으시리로다","reference":"시편 94:23","category":"$undefined"}],"bookSlug":"psalms"}]
