2:["$","$L11",null,{"book":{"id":"psalms","name":"시편","chapters":150,"testament":"old"},"chapter":96,"verses":[{"id":"15467","book":"시편","book_name":"시편","chapter":96,"verse":1,"text":"새 노래로 여호와께 노래하라 ! 온 땅이여 여호와께 노래할지어다 !","reference":"시편 96:1","category":"$undefined"},{"id":"15468","book":"시편","book_name":"시편","chapter":96,"verse":2,"text":"여호와께 노래하여 그 이름을 송축하며 그 구원을 날마다 선파 할지어다","reference":"시편 96:2","category":"$undefined"},{"id":"15469","book":"시편","book_name":"시편","chapter":96,"verse":3,"text":"그 영광을 열방 중에, 그 기이한 행적을 만민 중에 선포할지어다","reference":"시편 96:3","category":"$undefined"},{"id":"15470","book":"시편","book_name":"시편","chapter":96,"verse":4,"text":"여호와는 광대하시니 극진히 찬양할 것이요 모든 신보다 경외할 것임이여","reference":"시편 96:4","category":"$undefined"},{"id":"15471","book":"시편","book_name":"시편","chapter":96,"verse":5,"text":"만방의 모든 신은 헛 것이요 여호와께서는 하늘을 지으셨음이로다","reference":"시편 96:5","category":"$undefined"},{"id":"15472","book":"시편","book_name":"시편","chapter":96,"verse":6,"text":"존귀와 위엄이 그 앞에 있으며 능력과 아름다움이 그 성소에 있도다","reference":"시편 96:6","category":"$undefined"},{"id":"15473","book":"시편","book_name":"시편","chapter":96,"verse":7,"text":"만방의 족속들아 영광과 권능을 여호와께 돌릴지어다 ! 여호와께 돌릴지어다 !","reference":"시편 96:7","category":"$undefined"},{"id":"15474","book":"시편","book_name":"시편","chapter":96,"verse":8,"text":"여호와의 이름에 합당한 영광을 그에게 돌릴지어다 ! 예물을 가지고 그 궁정에 들어갈지어다","reference":"시편 96:8","category":"$undefined"},{"id":"15475","book":"시편","book_name":"시편","chapter":96,"verse":9,"text":"아름답고 거룩한 것으로 여호와께 경배할지어다 ! 온 땅이여, 그 앞에서 떨지어다","reference":"시편 96:9","category":"$undefined"},{"id":"15476","book":"시편","book_name":"시편","chapter":96,"verse":10,"text":"열방 중에서는 이르기를 여호와께서 통치하시니 세계가 굳게 서고 흔들리지 못할지라 저가 만민을 공평히 판단하시리라 할지로다","reference":"시편 96:10","category":"$undefined"},{"id":"15477","book":"시편","book_name":"시편","chapter":96,"verse":11,"text":"하늘은 기뻐하고 땅은 즐거워하며 바다와 거기 충만한 것은 외치며","reference":"시편 96:11","category":"$undefined"},{"id":"15478","book":"시편","book_name":"시편","chapter":96,"verse":12,"text":"밭과 그 가운데 모든 것은 즐거워할지로다 그리할 때에 삼림의 나무들이 여호와 앞에서 즐거이 노래하리니","reference":"시편 96:12","category":"$undefined"},{"id":"15479","book":"시편","book_name":"시편","chapter":96,"verse":13,"text":"저가 임하시되 땅을 판단하려 임하실 것임이라 저가 의로 세계를 판단하시며 그의 진실하심으로 백성을 판단하시리로다","reference":"시편 96:13","category":"$undefined"}],"bookSlug":"psalms"}]
