2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":1,"verses":[{"id":"27932","book":"로마서","book_name":"로마서","chapter":1,"verse":1,"text":"예수 그리스도의 종 바울은 사도로 부르심을 받아 하나님의 복음을 위하여 택정함을 입었으니","reference":"로마서 1:1","category":"$undefined"},{"id":"27933","book":"로마서","book_name":"로마서","chapter":1,"verse":2,"text":"이 복음은 하나님이 선지자들로 말미암아 그의 아들에 관하여 성경에 미리 약속하신 것이라","reference":"로마서 1:2","category":"$undefined"},{"id":"27934","book":"로마서","book_name":"로마서","chapter":1,"verse":3,"text":"이 아들로 말하면 육신으로는 다윗의 혈통에서 나셨고","reference":"로마서 1:3","category":"$undefined"},{"id":"27935","book":"로마서","book_name":"로마서","chapter":1,"verse":4,"text":"성결의 영으로는 죽은 가운데서 부활하여 능력으로 하나님의 아들로 인정되셨으니 곧 우리 주 예수 그리스도시니라","reference":"로마서 1:4","category":"$undefined"},{"id":"27936","book":"로마서","book_name":"로마서","chapter":1,"verse":5,"text":"그로 말미암아 우리가 은혜와 사도의 직분을 받아 그 이름을 위하여 모든 이방인 중에서 믿어 순종케 하나니","reference":"로마서 1:5","category":"$undefined"},{"id":"27937","book":"로마서","book_name":"로마서","chapter":1,"verse":6,"text":"너희도 그들 중에 있어 예수 그리스도의 것으로 부르심을 입은 자니라","reference":"로마서 1:6","category":"$undefined"},{"id":"27938","book":"로마서","book_name":"로마서","chapter":1,"verse":7,"text":"로마에 있어 하나님의 사랑하심을 입고 성도로 부르심을 입은 모든 자에게 하나님 우리 아버지와 주 예수 그리스도로 좇아 은혜와 평강이 있기를 원하노라","reference":"로마서 1:7","category":"$undefined"},{"id":"27939","book":"로마서","book_name":"로마서","chapter":1,"verse":8,"text":"첫째는 내가 예수 그리스도로 말미암아 너희 모든 사람을 인하여 내 하나님께 감사함은 너희 믿음이 온 세상에 전파됨이로다","reference":"로마서 1:8","category":"$undefined"},{"id":"27940","book":"로마서","book_name":"로마서","chapter":1,"verse":9,"text":"내가 그의 아들의 복음 안에서 내 심령으로 섬기는 하나님이 나의 증인이 되시거니와 항상 내 기도에 쉬지 않고 너희를 말하며","reference":"로마서 1:9","category":"$undefined"},{"id":"27941","book":"로마서","book_name":"로마서","chapter":1,"verse":10,"text":"어떠하든지 이제 하나님의 뜻 안에서 너희에게로 나아갈 좋은 길 얻기를 구하노라","reference":"로마서 1:10","category":"$undefined"},{"id":"27942","book":"로마서","book_name":"로마서","chapter":1,"verse":11,"text":"내가 너희 보기를 심히 원하는 것은 무슨 신령한 은사를 너희에게 나눠 주어 너희를 견고케 하려 함이니","reference":"로마서 1:11","category":"$undefined"},{"id":"27943","book":"로마서","book_name":"로마서","chapter":1,"verse":12,"text":"이는 곧 내가 너희 가운데서 너희와 나의 믿음을 인하여 피차 안위함을 얻으려 함이라","reference":"로마서 1:12","category":"$undefined"},{"id":"27944","book":"로마서","book_name":"로마서","chapter":1,"verse":13,"text":"형제들아 내가 여러 번 너희에게 가고자 한 것을 너희가 모르기를 원치 아니하노니 이는 너희 중에서도 다른 이방인 중에서와 같이 열매를 맺게 하려 함이로되 지금까지 길이 막혔도다","reference":"로마서 1:13","category":"$undefined"},{"id":"27945","book":"로마서","book_name":"로마서","chapter":1,"verse":14,"text":"헬라인이나 야만이나 지혜 있는 자나 어리석은 자에게 다 내가 빚진 자라","reference":"로마서 1:14","category":"$undefined"},{"id":"27946","book":"로마서","book_name":"로마서","chapter":1,"verse":15,"text":"그러므로 나는 할 수 있는대로 로마에 있는 너희에게도 복음 전하기를 원하노라","reference":"로마서 1:15","category":"$undefined"},{"id":"27947","book":"로마서","book_name":"로마서","chapter":1,"verse":16,"text":"내가 복음을 부끄러워하지 아니하노니 이 복음은 모든 믿는 자에게 구원을 주시는 하나님의 능력이 됨이라 첫째는 유대인에게요 또한 헬라인에게로다","reference":"로마서 1:16","category":"$undefined"},{"id":"27948","book":"로마서","book_name":"로마서","chapter":1,"verse":17,"text":"복음에는 하나님의 의가 나타나서 믿음으로 믿음에 이르게 하나니 기록된 바 오직 의인은 믿음으로 말미암아 살리라 함과 같으니라","reference":"로마서 1:17","category":"$undefined"},{"id":"27949","book":"로마서","book_name":"로마서","chapter":1,"verse":18,"text":"하나님의 진노가 불의로 진리를 막는 사람들의 모든 경건치 않음과 불의에 대하여 하늘로 좇아 나타나나니","reference":"로마서 1:18","category":"$undefined"},{"id":"27950","book":"로마서","book_name":"로마서","chapter":1,"verse":19,"text":"이는 하나님을 알만한 것이 저희 속에 보임이라 하나님께서 이를 저희에게 보이셨느니라","reference":"로마서 1:19","category":"$undefined"},{"id":"27951","book":"로마서","book_name":"로마서","chapter":1,"verse":20,"text":"창세로부터 그의 보이지 아니하는 것들 곧 그의 영원하신 능력과 신성이 그 만드신 만물에 분명히 보여 알게 되나니 그러므로 저희가 핑계치 못할지니라","reference":"로마서 1:20","category":"$undefined"},{"id":"27952","book":"로마서","book_name":"로마서","chapter":1,"verse":21,"text":"하나님을 알되 하나님으로 영화롭게도 아니하며 감사치도 아니하고 오히려 그 생각이 허망하여지며 미련한 마음이 어두워졌나니","reference":"로마서 1:21","category":"$undefined"},{"id":"27953","book":"로마서","book_name":"로마서","chapter":1,"verse":22,"text":"스스로 지혜 있다 하나 우둔하게 되어","reference":"로마서 1:22","category":"$undefined"},{"id":"27954","book":"로마서","book_name":"로마서","chapter":1,"verse":23,"text":"썩어지지 아니하는 하나님의 영광을 썩어질 사람과 금수와 버러지 형상의 우상으로 바꾸었느니라","reference":"로마서 1:23","category":"$undefined"},{"id":"27955","book":"로마서","book_name":"로마서","chapter":1,"verse":24,"text":"그러므로 하나님께서 저희를 마음의 정욕대로 더러움에 내어 버려두사 저희 몸을 서로 욕되게 하셨으니","reference":"로마서 1:24","category":"$undefined"},{"id":"27956","book":"로마서","book_name":"로마서","chapter":1,"verse":25,"text":"이는 저희가 하나님의 진리를 거짓 것으로 바꾸어 피조물을 조물주 보다 더 경배하고 섬김이라 주는 곧 영원히 찬송할 이시로다 아멘","reference":"로마서 1:25","category":"$undefined"},{"id":"27957","book":"로마서","book_name":"로마서","chapter":1,"verse":26,"text":"이를 인하여 하나님께서 저희를 부끄러운 욕심에 내어 버려 두셨으니 곧 저희 여인들도 순리대로 쓸 것을 바꾸어 역리로 쓰며","reference":"로마서 1:26","category":"$undefined"},{"id":"27958","book":"로마서","book_name":"로마서","chapter":1,"verse":27,"text":"이와 같이 남자들도 순리대로 여인 쓰기를 버리고 서로 향하여 음욕이 불 일듯하매 남자가 남자로 더불어 부끄러운 일을 행하여 저희의 그릇됨에 상당한 보응을 그 자신에 받았느니라","reference":"로마서 1:27","category":"$undefined"},{"id":"27959","book":"로마서","book_name":"로마서","chapter":1,"verse":28,"text":"또한 저희가 마음에 하나님 두기를 싫어하매 하나님께서 저희를 그 상실한 마음대로 내어 버려 두사 합당치 못한 일을 하게 하셨으니","reference":"로마서 1:28","category":"$undefined"},{"id":"27960","book":"로마서","book_name":"로마서","chapter":1,"verse":29,"text":"곧 모든 불의, 추악, 탐욕, 악의가 가득한 자요 시기, 살인, 분쟁, 사기, 악독이 가득한 자요, 수군수군 하는 자요","reference":"로마서 1:29","category":"$undefined"},{"id":"27961","book":"로마서","book_name":"로마서","chapter":1,"verse":30,"text":"비방하는 자요, 하나님의 미워하시는 자요, 능욕하는 자요, 교만한 자요, 자랑하는 자요, 악을 도모하는 자요, 부모를 거역하는 자요","reference":"로마서 1:30","category":"$undefined"},{"id":"27962","book":"로마서","book_name":"로마서","chapter":1,"verse":31,"text":"우매한 자요, 배약하는 자요, 무정한 자요, 무자비한 자라","reference":"로마서 1:31","category":"$undefined"},{"id":"27963","book":"로마서","book_name":"로마서","chapter":1,"verse":32,"text":"저희가 이같은 일을 행하는 자는 사형에 해당하다고 하나님의 정하심을 알고도 자기들만 행할 뿐 아니라 또한 그 일을 행하는 자를 옳다 하느니라","reference":"로마서 1:32","category":"$undefined"}],"bookSlug":"romans"}]
