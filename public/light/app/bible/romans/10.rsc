2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":10,"verses":[{"id":"28190","book":"로마서","book_name":"로마서","chapter":10,"verse":1,"text":"형제들아 내 마음에 원하는 바와 하나님께 구하는 바는 이스라엘을 위함이니 곧 저희로 구원을 얻게 함이라","reference":"로마서 10:1","category":"$undefined"},{"id":"28191","book":"로마서","book_name":"로마서","chapter":10,"verse":2,"text":"내가 증거하노니 저희가 하나님께 열심이 있으나 지식을 좇은 것이 아니라","reference":"로마서 10:2","category":"$undefined"},{"id":"28192","book":"로마서","book_name":"로마서","chapter":10,"verse":3,"text":"하나님의 의를 모르고 자기 의를 세우려고 힘써 하나님의 의를 복종치 아니하였느니라","reference":"로마서 10:3","category":"$undefined"},{"id":"28193","book":"로마서","book_name":"로마서","chapter":10,"verse":4,"text":"그리스도는 모든 믿는 자에게 의를 이루기 위하여 율법의 마침이 되시니라","reference":"로마서 10:4","category":"$undefined"},{"id":"28194","book":"로마서","book_name":"로마서","chapter":10,"verse":5,"text":"모세가 기록하되 율법으로 말미암는 의를 행하는 사람은 그 의로 살리라 하였거니와","reference":"로마서 10:5","category":"$undefined"},{"id":"28195","book":"로마서","book_name":"로마서","chapter":10,"verse":6,"text":"믿음으로 말미암는 의는 이같이 말하되 네 마음에 누가 하늘에 올라가겠느냐 하지 말라 하니 올라가겠느냐 함은 그리스도를 모셔 내리려는 것이요","reference":"로마서 10:6","category":"$undefined"},{"id":"28196","book":"로마서","book_name":"로마서","chapter":10,"verse":7,"text":"혹 누가 음부에 내려가겠느냐 하지 말라 하니 내려가겠느냐 함은 그리스도를 죽은 자 가운데서 모셔 올리려는 것이라","reference":"로마서 10:7","category":"$undefined"},{"id":"28197","book":"로마서","book_name":"로마서","chapter":10,"verse":8,"text":"그러면 무엇을 말하느뇨 말씀이 네게 가까와 네 입에 있으며 네 마음에 있다 하였으니 곧 우리가 전파하는 믿음의 말씀이라","reference":"로마서 10:8","category":"$undefined"},{"id":"28198","book":"로마서","book_name":"로마서","chapter":10,"verse":9,"text":"네가 만일 네 입으로 예수를 주로 시인하며 또 하나님께서 그를 죽은 자 가운데서 살리신 것을 네 마음에 믿으면 구원을 얻으리니","reference":"로마서 10:9","category":"$undefined"},{"id":"28199","book":"로마서","book_name":"로마서","chapter":10,"verse":10,"text":"사람이 마음으로 믿어 의에 이르고 입으로 시인하여 구원에 이르느니라","reference":"로마서 10:10","category":"$undefined"},{"id":"28200","book":"로마서","book_name":"로마서","chapter":10,"verse":11,"text":"성경에 이르되 누구든지 저를 믿는 자는 부끄러움을 당하지 아니하리라 하니","reference":"로마서 10:11","category":"$undefined"},{"id":"28201","book":"로마서","book_name":"로마서","chapter":10,"verse":12,"text":"유대인이나 헬라인이나 차별이 없음이라 한 주께서 모든 사람의 주가 되사 저를 부르는 모든 사람에게 부요하시도다","reference":"로마서 10:12","category":"$undefined"},{"id":"28202","book":"로마서","book_name":"로마서","chapter":10,"verse":13,"text":"누구든지 주의 이름을 부르는 자는 구원을 얻으리라","reference":"로마서 10:13","category":"$undefined"},{"id":"28203","book":"로마서","book_name":"로마서","chapter":10,"verse":14,"text":"그런즉 저희가 믿지 아니하는 이를 어찌 부르리요 듣지도 못한 이를 어찌 믿으리요 전파하는 자가 없이 어찌 들으리요","reference":"로마서 10:14","category":"$undefined"},{"id":"28204","book":"로마서","book_name":"로마서","chapter":10,"verse":15,"text":"보내심을 받지 아니하였으면 어찌 전파하리요 기록된 바 아름답도다 좋은 소식을 전하는 자들의 발이여 함과 같으니라","reference":"로마서 10:15","category":"$undefined"},{"id":"28205","book":"로마서","book_name":"로마서","chapter":10,"verse":16,"text":"그러나 저희가 다 복음을 순종치 아니하였도다 이사야가 가로되 주여 우리의 전하는 바를 누가 믿었나이까 하였으니","reference":"로마서 10:16","category":"$undefined"},{"id":"28206","book":"로마서","book_name":"로마서","chapter":10,"verse":17,"text":"그러므로 믿음은 들음에서 나며 들음은 그리스도의 말씀으로 말미암았느니라","reference":"로마서 10:17","category":"$undefined"},{"id":"28207","book":"로마서","book_name":"로마서","chapter":10,"verse":18,"text":"그러나 내가 말하노니 저희가 듣지 아니하였느뇨 그렇지 아니하다 그 소리가 온 땅에 퍼졌고 그 말씀이 땅 끝까지 이르렀도다 하였느니라","reference":"로마서 10:18","category":"$undefined"},{"id":"28208","book":"로마서","book_name":"로마서","chapter":10,"verse":19,"text":"그러나 내가 말하노니 이스라엘이 알지 못하였느뇨 먼저 모세가 이르되 내가 백성 아닌 자로써 너희를 시기나게 하며 미련한 백성으로써 너희를 노엽게 하리라 하였고","reference":"로마서 10:19","category":"$undefined"},{"id":"28209","book":"로마서","book_name":"로마서","chapter":10,"verse":20,"text":"또한 이사야가 매우 담대하여 이르되 내가 구하지 아니하는 자들에게 찾은 바 되고 내게 문의하지 아니하는 자들에게 나타났노라 하였고","reference":"로마서 10:20","category":"$undefined"},{"id":"28210","book":"로마서","book_name":"로마서","chapter":10,"verse":21,"text":"이스라엘을 대하여 가라사대 순종치 아니하고 거스려 말하는 백성에게 내가 종일 내 손을 벌렸노라 하셨느니라","reference":"로마서 10:21","category":"$undefined"}],"bookSlug":"romans"}]
