2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":11,"verses":[{"id":"28211","book":"로마서","book_name":"로마서","chapter":11,"verse":1,"text":"그러므로 내가 말하노니 하나님이 자기 백성을 버리셨느뇨 그럴수 없느니라 나도 이스라엘인이요 아브라함의 씨에서 난 자요 베냐민 지파라","reference":"로마서 11:1","category":"$undefined"},{"id":"28212","book":"로마서","book_name":"로마서","chapter":11,"verse":2,"text":"하나님이 그 미리 아신 자기 백성을 버리지 아니하셨나니 너희가 성경이 엘리야를 가리켜 말한 것을 알지 못하느냐 저가 이스라엘을 하나님께 송사하되","reference":"로마서 11:2","category":"$undefined"},{"id":"28213","book":"로마서","book_name":"로마서","chapter":11,"verse":3,"text":"주여 저희가 주의 선지자들을 죽였으며 주의 제단들을 헐어버렸고 나만 남았는데 내 목숨도 찾나이다 하니","reference":"로마서 11:3","category":"$undefined"},{"id":"28214","book":"로마서","book_name":"로마서","chapter":11,"verse":4,"text":"저에게 하신 대답이 무엇이뇨 내가 나를 위하여 바알에게 무릎을 꿇지 아니한 사람 칠천을 남겨 두었다 하셨으니","reference":"로마서 11:4","category":"$undefined"},{"id":"28215","book":"로마서","book_name":"로마서","chapter":11,"verse":5,"text":"그런즉 이와 같이 이제도 은혜로 택하심을 따라 남은 자가 있느니라","reference":"로마서 11:5","category":"$undefined"},{"id":"28216","book":"로마서","book_name":"로마서","chapter":11,"verse":6,"text":"만일 은혜로 된 것이면 행위로 말미암지 않음이니 그렇지 않으면 은혜가 은혜 되지 못하느니라","reference":"로마서 11:6","category":"$undefined"},{"id":"28217","book":"로마서","book_name":"로마서","chapter":11,"verse":7,"text":"그런즉 어떠하뇨 이스라엘이 구하는 그것을 얻지 못하고 오직 택하심을 입은 자가 얻었고 그 남은 자들은 완악하여졌느니라","reference":"로마서 11:7","category":"$undefined"},{"id":"28218","book":"로마서","book_name":"로마서","chapter":11,"verse":8,"text":"기록된 바 하나님이 오늘날까지 저희에게 혼미한 심령과 보지 못할 눈과 듣지 못할 귀를 주셨다 함과 같으니라","reference":"로마서 11:8","category":"$undefined"},{"id":"28219","book":"로마서","book_name":"로마서","chapter":11,"verse":9,"text":"또 다윗이 가로되 저희 밥상이 올무와 덫과 거치는 것과 보응이 되게 하옵시고","reference":"로마서 11:9","category":"$undefined"},{"id":"28220","book":"로마서","book_name":"로마서","chapter":11,"verse":10,"text":"저희 눈은 흐려 보지 못하고 저희 등은 항상 굽게 하옵소서 하였느니라","reference":"로마서 11:10","category":"$undefined"},{"id":"28221","book":"로마서","book_name":"로마서","chapter":11,"verse":11,"text":"그러므로 내가 말하노니 저희가 넘어지기까지 실족하였느뇨 그럴수 없느니라 저희의 넘어짐으로 구원이 이방인에게 이르러 이스라엘로 시기나게 함이니라","reference":"로마서 11:11","category":"$undefined"},{"id":"28222","book":"로마서","book_name":"로마서","chapter":11,"verse":12,"text":"저희의 넘어짐이 세상의 부요함이 되며 저희의 실패가 이방인의 부요함이 되거든 하물며 저희의 충만함이리요","reference":"로마서 11:12","category":"$undefined"},{"id":"28223","book":"로마서","book_name":"로마서","chapter":11,"verse":13,"text":"내가 이방인인 너희에게 말하노라 내가 이방인의 사도인만큼 내 직분을 영광스럽게 여기노니","reference":"로마서 11:13","category":"$undefined"},{"id":"28224","book":"로마서","book_name":"로마서","chapter":11,"verse":14,"text":"이는 곧 내 골육을 아무쪼록 시기케 하여 저희 중에서 얼마를 구원하려 함이라","reference":"로마서 11:14","category":"$undefined"},{"id":"28225","book":"로마서","book_name":"로마서","chapter":11,"verse":15,"text":"저희를 버리는 것이 세상의 화목이 되거든 그 받아들이는 것이 죽은 자 가운데서 사는 것이 아니면 무엇이리요","reference":"로마서 11:15","category":"$undefined"},{"id":"28226","book":"로마서","book_name":"로마서","chapter":11,"verse":16,"text":"제사하는 처음 익은 곡식 가루가 거룩한즉 떡 덩이도 그러하고 뿌리가 거룩한즉 가지도 그러하니라","reference":"로마서 11:16","category":"$undefined"},{"id":"28227","book":"로마서","book_name":"로마서","chapter":11,"verse":17,"text":"또한 가지 얼마가 꺾여졌는데 돌감람나무인 네가 그들 중에 접붙임이 되어 참감람나무 뿌리의 진액을 함께 받는 자 되었은즉","reference":"로마서 11:17","category":"$undefined"},{"id":"28228","book":"로마서","book_name":"로마서","chapter":11,"verse":18,"text":"그 가지들을 향하여 자긍하지말라 자긍할지라도 네가 뿌리를 보전하는 것이 아니요 뿌리가 너를 보전하는 것이니라","reference":"로마서 11:18","category":"$undefined"},{"id":"28229","book":"로마서","book_name":"로마서","chapter":11,"verse":19,"text":"그러면 네 말이 가지들이 꺾이운 것은 나로 접붙임을 받게 하려함이라 하리니","reference":"로마서 11:19","category":"$undefined"},{"id":"28230","book":"로마서","book_name":"로마서","chapter":11,"verse":20,"text":"옳도다 저희는 믿지 아니하므로 꺾이우고 너는 믿으므로 섰느니라 높은 마음을 품지 말고 도리어 두려워하라","reference":"로마서 11:20","category":"$undefined"},{"id":"28231","book":"로마서","book_name":"로마서","chapter":11,"verse":21,"text":"하나님이 원 가지들도 아끼지 아니하셨은즉 너도 아끼지 아니하시리라","reference":"로마서 11:21","category":"$undefined"},{"id":"28232","book":"로마서","book_name":"로마서","chapter":11,"verse":22,"text":"그러므로 하나님의 인자와 엄위를 보라 넘어지는 자들에게는 엄위가 있으니 너희가 만일 하나님의 인자에 거하면 그 인자가 너희에게 있으리라 그렇지 않으면 너도 찍히는 바 되리라","reference":"로마서 11:22","category":"$undefined"},{"id":"28233","book":"로마서","book_name":"로마서","chapter":11,"verse":23,"text":"저희도 믿지 아니하는데 거하지 아니하면 접붙임을 얻으리니 이는 저희를 접붙이실 능력이 하나님께 있음이라","reference":"로마서 11:23","category":"$undefined"},{"id":"28234","book":"로마서","book_name":"로마서","chapter":11,"verse":24,"text":"네가 원 돌감람나무에서 찍힘을 받고 본성을 거스려 좋은 감람나무에 접붙임을 얻었은즉 원 가지인 이 사람들이야 얼마나 더 자기 감람나무에 접붙이심을 얻으랴","reference":"로마서 11:24","category":"$undefined"},{"id":"28235","book":"로마서","book_name":"로마서","chapter":11,"verse":25,"text":"형제들아 너희가 스스로 지혜있다 함을 면키 위하여 이 비밀을 너희가 모르기를 내가 원치 아니하노니 이 비밀은 이방인의 충만한 수가 들어오기까지 이스라엘의 더러는 완악하게 된 것이라","reference":"로마서 11:25","category":"$undefined"},{"id":"28236","book":"로마서","book_name":"로마서","chapter":11,"verse":26,"text":"그리하여 온 이스라엘이 구원을 얻으리라 기록된 바 구원자가 시온에서 오사 야곱에게서 경건치 않은 것을 돌이키시겠고","reference":"로마서 11:26","category":"$undefined"},{"id":"28237","book":"로마서","book_name":"로마서","chapter":11,"verse":27,"text":"내가 저희 죄를 없이 할 때에 저희에게 이루어질 내 언약이 이것이라 함과 같으니라","reference":"로마서 11:27","category":"$undefined"},{"id":"28238","book":"로마서","book_name":"로마서","chapter":11,"verse":28,"text":"복음으로 하면 저희가 너희를 인하여 원수 된 자요 택하심으로 하면 조상들을 인하여 사랑을 입은 자라","reference":"로마서 11:28","category":"$undefined"},{"id":"28239","book":"로마서","book_name":"로마서","chapter":11,"verse":29,"text":"하나님의 은사와 부르심에는 후회하심이 없느니라","reference":"로마서 11:29","category":"$undefined"},{"id":"28240","book":"로마서","book_name":"로마서","chapter":11,"verse":30,"text":"너희가 전에 하나님께 순종치 아니하더니 이스라엘의 순종치 아니함으로 이제 긍휼을 입었는지라","reference":"로마서 11:30","category":"$undefined"},{"id":"28241","book":"로마서","book_name":"로마서","chapter":11,"verse":31,"text":"이와 같이 이 사람들이 순종치 아니하니 이는 너희에게 베푸시는 긍휼로 이제 저희도 긍휼을 얻게 하려 하심이니라","reference":"로마서 11:31","category":"$undefined"},{"id":"28242","book":"로마서","book_name":"로마서","chapter":11,"verse":32,"text":"하나님이 모든 사람을 순종치 아니하는 가운데 가두어 두심은 모든 사람에게 긍휼을 베풀려 하심이로다","reference":"로마서 11:32","category":"$undefined"},{"id":"28243","book":"로마서","book_name":"로마서","chapter":11,"verse":33,"text":"깊도다 하나님의 지혜와 지식의 부요함이여 그의 판단은 측량치 못할 것이며 그의 길은 찾지 못할 것이로다","reference":"로마서 11:33","category":"$undefined"},{"id":"28244","book":"로마서","book_name":"로마서","chapter":11,"verse":34,"text":"누가 주의 마음을 알았느뇨 누가 그의 모사가 되었느뇨","reference":"로마서 11:34","category":"$undefined"},{"id":"28245","book":"로마서","book_name":"로마서","chapter":11,"verse":35,"text":"누가 주께 먼저 드려서 갚으심을 받겠느뇨","reference":"로마서 11:35","category":"$undefined"},{"id":"28246","book":"로마서","book_name":"로마서","chapter":11,"verse":36,"text":"이는 만물이 주에게서 나오고 주로 말미암고 주에게로 돌아감이라 영광이 그에게 세세에 있으리로다 아멘","reference":"로마서 11:36","category":"$undefined"}],"bookSlug":"romans"}]
