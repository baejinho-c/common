2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":12,"verses":[{"id":"28247","book":"로마서","book_name":"로마서","chapter":12,"verse":1,"text":"그러므로 형제들아 내가 하나님의 모든 자비하심으로 너희를 권하노니 너희 몸을 하나님이 기뻐하시는 거룩한 산 제사로 드리라 이는 너희의 드릴 영적 예배니라","reference":"로마서 12:1","category":"$undefined"},{"id":"28248","book":"로마서","book_name":"로마서","chapter":12,"verse":2,"text":"너희는 이 세대를 본받지 말고 오직 마음을 새롭게 함으로 변화를 받아 하나님의 선하시고 기뻐하시고 온전하신 뜻이 무엇인지 분별하도록 하라","reference":"로마서 12:2","category":"$undefined"},{"id":"28249","book":"로마서","book_name":"로마서","chapter":12,"verse":3,"text":"내게 주신 은혜로 말미암아 너희 중 각 사람에게 말하노니 마땅히 생각할 그 이상의 생각을 품지 말고 오직 하나님께서 각 사람에게 나눠주신 믿음의 분량대로 지혜롭게 생각하라","reference":"로마서 12:3","category":"$undefined"},{"id":"28250","book":"로마서","book_name":"로마서","chapter":12,"verse":4,"text":"우리가 한 몸에 많은 지체를 가졌으나 모든 지체가 같은 직분을 가진 것이 아니니","reference":"로마서 12:4","category":"$undefined"},{"id":"28251","book":"로마서","book_name":"로마서","chapter":12,"verse":5,"text":"이와 같이 우리 많은 사람이 그리스도 안에서 한 몸이 되어 서로 지체가 되었느니라","reference":"로마서 12:5","category":"$undefined"},{"id":"28252","book":"로마서","book_name":"로마서","chapter":12,"verse":6,"text":"우리에게 주신 은혜대로 받은 은사가 각각 다르니 혹 예언이면 믿음의 분수대로","reference":"로마서 12:6","category":"$undefined"},{"id":"28253","book":"로마서","book_name":"로마서","chapter":12,"verse":7,"text":"혹 섬기는 일이면 섬기는 일로 혹 가르치는 자면 가르치는 일로","reference":"로마서 12:7","category":"$undefined"},{"id":"28254","book":"로마서","book_name":"로마서","chapter":12,"verse":8,"text":"혹 권위하는 자면 권위하는 일로 구제하는 자는 성실함으로 다스리는 자는 부지런함으로 긍휼을 베푸는 자는 즐거움으로 할 것이니라","reference":"로마서 12:8","category":"$undefined"},{"id":"28255","book":"로마서","book_name":"로마서","chapter":12,"verse":9,"text":"사랑엔 거짓이 없나니 악을 미워하고 선에 속하라","reference":"로마서 12:9","category":"$undefined"},{"id":"28256","book":"로마서","book_name":"로마서","chapter":12,"verse":10,"text":"형제를 사랑하여 서로 우애하고 존경하기를 서로 먼저 하며","reference":"로마서 12:10","category":"$undefined"},{"id":"28257","book":"로마서","book_name":"로마서","chapter":12,"verse":11,"text":"부지런하여 게으르지 말고 열심을 품고 주를 섬기라","reference":"로마서 12:11","category":"$undefined"},{"id":"28258","book":"로마서","book_name":"로마서","chapter":12,"verse":12,"text":"소망 중에 즐거워하며 환난 중에 참으며 기도에 항상 힘쓰며","reference":"로마서 12:12","category":"$undefined"},{"id":"28259","book":"로마서","book_name":"로마서","chapter":12,"verse":13,"text":"성도들의 쓸 것을 공급하며 손 대접하기를 힘쓰라","reference":"로마서 12:13","category":"$undefined"},{"id":"28260","book":"로마서","book_name":"로마서","chapter":12,"verse":14,"text":"너희를 핍박하는 자를 축복하라 축복하고 저주하지 말라","reference":"로마서 12:14","category":"$undefined"},{"id":"28261","book":"로마서","book_name":"로마서","chapter":12,"verse":15,"text":"즐거워하는 자들로 함께 즐거워하고 우는 자들로 함께 울라","reference":"로마서 12:15","category":"$undefined"},{"id":"28262","book":"로마서","book_name":"로마서","chapter":12,"verse":16,"text":"서로 마음을 같이 하며 높은 데 마음을 두지 말고 도리어 낮은 데 처하며 스스로 지혜 있는 체 말라","reference":"로마서 12:16","category":"$undefined"},{"id":"28263","book":"로마서","book_name":"로마서","chapter":12,"verse":17,"text":"아무에게도 악으로 악을 갚지말고 모든 사람 앞에서 선한 일을 도모하라","reference":"로마서 12:17","category":"$undefined"},{"id":"28264","book":"로마서","book_name":"로마서","chapter":12,"verse":18,"text":"할 수 있거든 너희로서는 모든 사람으로 더불어 평화하라","reference":"로마서 12:18","category":"$undefined"},{"id":"28265","book":"로마서","book_name":"로마서","chapter":12,"verse":19,"text":"내 사랑하는 자들아 너희가 친히 원수를 갚지말고 진노하심에 맡기라 기록되었으되 원수 갚는 것이 내게 있으니 내가 갚으리라고 주께서 말씀하시니라","reference":"로마서 12:19","category":"$undefined"},{"id":"28266","book":"로마서","book_name":"로마서","chapter":12,"verse":20,"text":"네 원수가 주리거든 먹이고 목마르거든 마시우라 그리함으로 네가 숯불을 그 머리에 쌓아 놓으리라","reference":"로마서 12:20","category":"$undefined"},{"id":"28267","book":"로마서","book_name":"로마서","chapter":12,"verse":21,"text":"악에게 지지 말고 선으로 악을 이기라","reference":"로마서 12:21","category":"$undefined"}],"bookSlug":"romans"}]
