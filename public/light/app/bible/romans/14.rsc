2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":14,"verses":[{"id":"28282","book":"로마서","book_name":"로마서","chapter":14,"verse":1,"text":"믿음이 연약한 자를 너희가 받되 그의 의심하는 바를 비판하지 말라","reference":"로마서 14:1","category":"$undefined"},{"id":"28283","book":"로마서","book_name":"로마서","chapter":14,"verse":2,"text":"어떤 사람은 모든 것을 먹을만한 믿음이 있고 연약한 자는 채소를 먹느니라","reference":"로마서 14:2","category":"$undefined"},{"id":"28284","book":"로마서","book_name":"로마서","chapter":14,"verse":3,"text":"먹는 자는 먹지 않는 자를 업신 여기지 말고 먹지 못하는 자는 먹는자를 판단하지 말라 이는 하나님이 저를 받으셨음이니라","reference":"로마서 14:3","category":"$undefined"},{"id":"28285","book":"로마서","book_name":"로마서","chapter":14,"verse":4,"text":"남의 하인을 판단하는 너는 누구뇨 그 섰는 것이나 넘어지는 것이 제 주인에게 있으매 저가 세움을 받으리니 이는 저를 세우시는 권능이 주께 있음이니라","reference":"로마서 14:4","category":"$undefined"},{"id":"28286","book":"로마서","book_name":"로마서","chapter":14,"verse":5,"text":"혹은 이날을 저날보다 낫게 여기고 혹은 모든 날을 같게 여기나니 각각 자기 마음에 확정할지니라","reference":"로마서 14:5","category":"$undefined"},{"id":"28287","book":"로마서","book_name":"로마서","chapter":14,"verse":6,"text":"날을 중히 여기는 자도 주를 위하여 중히 여기고 먹는 자도 주를 위하여 먹으니 이는 하나님께 감사함이요 먹지 않는 자도 주를 위하여 먹지 아니하며 하나님께 감사하느니라","reference":"로마서 14:6","category":"$undefined"},{"id":"28288","book":"로마서","book_name":"로마서","chapter":14,"verse":7,"text":"우리 중에 누구든지 자기를 위하여 사는 자가 없고 자기를 위하여 죽는 자도 없도다","reference":"로마서 14:7","category":"$undefined"},{"id":"28289","book":"로마서","book_name":"로마서","chapter":14,"verse":8,"text":"우리가 살아도 주를 위하여 살고 죽어도 주를 위하여 죽나니 그러므로 사나 죽으나 우리가 주의 것이로라","reference":"로마서 14:8","category":"$undefined"},{"id":"28290","book":"로마서","book_name":"로마서","chapter":14,"verse":9,"text":"이를 위하여 그리스도께서 죽었다가 다시 살으셨으니 곧 죽은 자와 산 자의 주가 되려 하심이니라","reference":"로마서 14:9","category":"$undefined"},{"id":"28291","book":"로마서","book_name":"로마서","chapter":14,"verse":10,"text":"네가 어찌하여 네 형제를 판단하느뇨 어찌하여 네 형제를 업신여기느뇨 우리가 다 하나님의 심판대 앞에 서리라","reference":"로마서 14:10","category":"$undefined"},{"id":"28292","book":"로마서","book_name":"로마서","chapter":14,"verse":11,"text":"기록되었으되 주께서 가라사대 내가 살았노니 모든 무릎이 내게 꿇을 것이요 모든 혀가 하나님께 자백 하리라 하였느니라","reference":"로마서 14:11","category":"$undefined"},{"id":"28293","book":"로마서","book_name":"로마서","chapter":14,"verse":12,"text":"이러므로 우리 각인이 자기 일을 하나님께 직고하리라","reference":"로마서 14:12","category":"$undefined"},{"id":"28294","book":"로마서","book_name":"로마서","chapter":14,"verse":13,"text":"그런즉 우리가 다시는 서로 판단하지 말고 도리어 부딪힐 것이나 거칠 것으로 형제 앞에 두지 아니할 것을 주의하라","reference":"로마서 14:13","category":"$undefined"},{"id":"28295","book":"로마서","book_name":"로마서","chapter":14,"verse":14,"text":"내가 주 예수 안에서 알고 확신하는 것은 무엇이든지 스스로 속된 것이 없으되 다만 속되게 여기는 그 사람에게는 속되니라","reference":"로마서 14:14","category":"$undefined"},{"id":"28296","book":"로마서","book_name":"로마서","chapter":14,"verse":15,"text":"만일 식물을 인하여 네 형제가 근심하게 되면 이는 네가 사랑으로 행치 아니함이라 그리스도께서 대신하여 죽으신 형제를 네 식물로 망케 하지 말라","reference":"로마서 14:15","category":"$undefined"},{"id":"28297","book":"로마서","book_name":"로마서","chapter":14,"verse":16,"text":"그러므로 너희의 선한 것이 비방을 받지 않게 하라","reference":"로마서 14:16","category":"$undefined"},{"id":"28298","book":"로마서","book_name":"로마서","chapter":14,"verse":17,"text":"하나님의 나라는 먹는 것과 마시는 것이 아니요 오직 성령 안에서 의와 평강과 희락이라","reference":"로마서 14:17","category":"$undefined"},{"id":"28299","book":"로마서","book_name":"로마서","chapter":14,"verse":18,"text":"이로써 그리스도를 섬기는 자는 하나님께 기뻐하심을 받으며 사람에게도 칭찬을 받느니라","reference":"로마서 14:18","category":"$undefined"},{"id":"28300","book":"로마서","book_name":"로마서","chapter":14,"verse":19,"text":"이러므로 우리가 화평의 일과 서로 덕을 세우는 일을 힘쓰나니","reference":"로마서 14:19","category":"$undefined"},{"id":"28301","book":"로마서","book_name":"로마서","chapter":14,"verse":20,"text":"식물을 인하여 하나님의 사업을 무너지게 말라 만물이 다 정하되 거리낌으로 먹는 사람에게는 악하니라","reference":"로마서 14:20","category":"$undefined"},{"id":"28302","book":"로마서","book_name":"로마서","chapter":14,"verse":21,"text":"고기도 먹지 아니하고 포도주도 마시지 아니하고 무엇이든지 네 형제로 거리끼게 하는 일을 아니함이 아름다우니라","reference":"로마서 14:21","category":"$undefined"},{"id":"28303","book":"로마서","book_name":"로마서","chapter":14,"verse":22,"text":"네게 있는 믿음을 하나님 앞에서 스스로 가지고 있으라 자기의 옳다 하는 바로 자기를 책하지 아니하는 자는 복이 있도다","reference":"로마서 14:22","category":"$undefined"},{"id":"28304","book":"로마서","book_name":"로마서","chapter":14,"verse":23,"text":"의심하고 먹는 자는 정죄되었나니 이는 믿음으로 좇아 하지 아니한 연고라 믿음으로 좇아 하지 아니하는 모든 것이 죄니라","reference":"로마서 14:23","category":"$undefined"}],"bookSlug":"romans"}]
