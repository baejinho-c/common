2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":15,"verses":[{"id":"28305","book":"로마서","book_name":"로마서","chapter":15,"verse":1,"text":"우리 강한 자가 마땅히 연약한 자의 약점을 담당하고 자기를 기쁘게 하지 아니할 것이라","reference":"로마서 15:1","category":"$undefined"},{"id":"28306","book":"로마서","book_name":"로마서","chapter":15,"verse":2,"text":"우리 각 사람이 이웃을 기쁘게 하되 선을 이루고 덕을 세우도록 할지니라","reference":"로마서 15:2","category":"$undefined"},{"id":"28307","book":"로마서","book_name":"로마서","chapter":15,"verse":3,"text":"그리스도께서 자기를 기쁘게 하지 아니하셨나니 기록된바 주를 비방하는 자들의 비방이 내게 미쳤나이다 함과 같으니라","reference":"로마서 15:3","category":"$undefined"},{"id":"28308","book":"로마서","book_name":"로마서","chapter":15,"verse":4,"text":"무엇이든지 전에 기록한 바는 우리의 교훈을 위하여 기록된 것이니 우리로 하여금 인내로 또는 성경의 안위로 소망을 가지게 함이니라","reference":"로마서 15:4","category":"$undefined"},{"id":"28309","book":"로마서","book_name":"로마서","chapter":15,"verse":5,"text":"이제 인내와 안위의 하나님이 너희로 그리스도 예수를 본받아 서로 뜻이 같게 하여 주사","reference":"로마서 15:5","category":"$undefined"},{"id":"28310","book":"로마서","book_name":"로마서","chapter":15,"verse":6,"text":"한 마음과 한 입으로 하나님 곧 우리 주 예수 그리스도의 아버지께 영광을 돌리게 하려 하노라","reference":"로마서 15:6","category":"$undefined"},{"id":"28311","book":"로마서","book_name":"로마서","chapter":15,"verse":7,"text":"이러므로 그리스도께서 우리를 받아 하나님께 영광을 돌리심과 같이 너희도 서로 받으라","reference":"로마서 15:7","category":"$undefined"},{"id":"28312","book":"로마서","book_name":"로마서","chapter":15,"verse":8,"text":"내가 말하노니 그리스도께서 하나님의 진실하심을 위하여 할례의 수종자가 되셨으니 이는 조상들에게 주신 약속들을 견고케 하시고","reference":"로마서 15:8","category":"$undefined"},{"id":"28313","book":"로마서","book_name":"로마서","chapter":15,"verse":9,"text":"이방인으로 그 긍휼하심을 인하여 하나님께 영광을 돌리게 하려 하심이라 기록된바 이러므로 내가 열방 중에서 주께 감사하고 주의 이름을 찬송하리로다 함과 같으니라","reference":"로마서 15:9","category":"$undefined"},{"id":"28314","book":"로마서","book_name":"로마서","chapter":15,"verse":10,"text":"또 가로되 열방들아 주의 백성과 함께 즐거워하라 하였으며","reference":"로마서 15:10","category":"$undefined"},{"id":"28315","book":"로마서","book_name":"로마서","chapter":15,"verse":11,"text":"또 모든 열방들아 주를 찬양하며 모든 백성들아 저를 찬송하라 하였으며","reference":"로마서 15:11","category":"$undefined"},{"id":"28316","book":"로마서","book_name":"로마서","chapter":15,"verse":12,"text":"또 이사야가 가로되 이새의 뿌리 곧 열방을 다스리기 위하여 일어나시는 이가 있으리니 열방이 그에게 소망을 두리라 하였느니라","reference":"로마서 15:12","category":"$undefined"},{"id":"28317","book":"로마서","book_name":"로마서","chapter":15,"verse":13,"text":"소망의 하나님이 모든 기쁨과 평강을 믿음 안에서 너희에게 충만케 하사 성령의 능력으로 소망이 넘치게 하시기를 원하노라","reference":"로마서 15:13","category":"$undefined"},{"id":"28318","book":"로마서","book_name":"로마서","chapter":15,"verse":14,"text":"내 형제들아 너희가 스스로 선함이 가득하고 모든 지식이 차서 능히 서로 권하는 자임을 나도 확신하노라","reference":"로마서 15:14","category":"$undefined"},{"id":"28319","book":"로마서","book_name":"로마서","chapter":15,"verse":15,"text":"그러나 내가 너희로 다시 생각나게 하려고 하나님께서 내게 주신 은혜로 인하여 더욱 담대히 대강 너희에게 썼노니","reference":"로마서 15:15","category":"$undefined"},{"id":"28320","book":"로마서","book_name":"로마서","chapter":15,"verse":16,"text":"이 은혜는 곧 나로 이방인을 위하여 그리스도 예수의 일군이 되어 하나님의 복음의 제사장 직무를 하게 하사 이방인을 제물로 드리는 그것이 성령 안에서 거룩하게 되어 받으심직하게 하려 하심이라","reference":"로마서 15:16","category":"$undefined"},{"id":"28321","book":"로마서","book_name":"로마서","chapter":15,"verse":17,"text":"그러므로 내가 그리스도 예수 안에서 하나님의 일에 대하여 자랑하는 것이 있거니와","reference":"로마서 15:17","category":"$undefined"},{"id":"28322","book":"로마서","book_name":"로마서","chapter":15,"verse":18,"text":"그리스도께서 이방인들을 순종케 하기 위하여 나로 말미암아 말과 일이며 표적과 기사의 능력이며 성령의 능력으로 역사하신 것외에는 내가 감히 말하지 아니하노라","reference":"로마서 15:18","category":"$undefined"},{"id":"28323","book":"로마서","book_name":"로마서","chapter":15,"verse":19,"text":"이 일로 인하여 내가 예루살렘으로부터 두루 행하여 일루리곤까지 그리스도의 복음을 편만하게 전하였노라","reference":"로마서 15:19","category":"$undefined"},{"id":"28324","book":"로마서","book_name":"로마서","chapter":15,"verse":20,"text":"또 내가 그리스도의 이름을 부르는 곳에는 복음을 전하지 않기로 힘썼노니 이는 남의 터 위에 건축하지 아니하려 함이라","reference":"로마서 15:20","category":"$undefined"},{"id":"28325","book":"로마서","book_name":"로마서","chapter":15,"verse":21,"text":"기록된바 주의 소식을 받지 못한 자들이 볼 것이요 듣지 못한 자들이 깨달으리라 함과 같으니라","reference":"로마서 15:21","category":"$undefined"},{"id":"28326","book":"로마서","book_name":"로마서","chapter":15,"verse":22,"text":"그러므로 또한 내가 너희에게 가려 하던 것이 여러번 막혔더니","reference":"로마서 15:22","category":"$undefined"},{"id":"28327","book":"로마서","book_name":"로마서","chapter":15,"verse":23,"text":"이제는 이 지방에 일할 곳이 없고 여러 해 전부터 언제든지 서바나로 갈 때에 너희에게 가려는 원이 있었으니","reference":"로마서 15:23","category":"$undefined"},{"id":"28328","book":"로마서","book_name":"로마서","chapter":15,"verse":24,"text":"이는 지나가는 길에 너희를 보고 먼저 너희와 교제하여 약간 만족을 받은 후에 너희의 그리로 보내줌을 바람이라","reference":"로마서 15:24","category":"$undefined"},{"id":"28329","book":"로마서","book_name":"로마서","chapter":15,"verse":25,"text":"그러나 이제는 내가 성도를 섬기는 일로 예루살렘에 가노니","reference":"로마서 15:25","category":"$undefined"},{"id":"28330","book":"로마서","book_name":"로마서","chapter":15,"verse":26,"text":"이는 마게도냐와 아가야 사람들이 예루살렘 성도 중 가난한 자들을 위하여 기쁘게 얼마를 동정하였음이라","reference":"로마서 15:26","category":"$undefined"},{"id":"28331","book":"로마서","book_name":"로마서","chapter":15,"verse":27,"text":"저희가 기뻐서 하였거니와 또한 저희는 그들에게 빚진 자니 만일 이방인들이 그들의 신령한 것을 나눠 가졌으면 육신의 것으로 그들을 섬기는 것이 마땅하니라","reference":"로마서 15:27","category":"$undefined"},{"id":"28332","book":"로마서","book_name":"로마서","chapter":15,"verse":28,"text":"그러므로 내가 이 일을 마치고 이 열매를 저희에게 확증한 후에 너희에게를 지나 서바나로 가리라","reference":"로마서 15:28","category":"$undefined"},{"id":"28333","book":"로마서","book_name":"로마서","chapter":15,"verse":29,"text":"내가 너희에게 나갈 때에 그리스도의 충만한 축복을 가지고 갈 줄을 아노라","reference":"로마서 15:29","category":"$undefined"},{"id":"28334","book":"로마서","book_name":"로마서","chapter":15,"verse":30,"text":"형제들아 내가 우리주 예수 그리스도로 말미암고 성령의 사랑으로 말미암아 너희를 권하노니 너희 기도에 나와 힘을 같이하여 나를 위하여 하나님께 빌어","reference":"로마서 15:30","category":"$undefined"},{"id":"28335","book":"로마서","book_name":"로마서","chapter":15,"verse":31,"text":"나로 유대에 순종치 아니하는 자들에게서 구원을 받게 하고 또 예루살렘에 대한 나의 섬기는 일을 성도들이 받음직하게 하고","reference":"로마서 15:31","category":"$undefined"},{"id":"28336","book":"로마서","book_name":"로마서","chapter":15,"verse":32,"text":"나로 하나님의 뜻을 좇아 기쁨으로 너희에게 나아가 너희와 함께 편히 쉬게 하라","reference":"로마서 15:32","category":"$undefined"},{"id":"28337","book":"로마서","book_name":"로마서","chapter":15,"verse":33,"text":"평강의 하나님께서 너희 모든 사람과 함께 계실지어다 ! 아멘","reference":"로마서 15:33","category":"$undefined"}],"bookSlug":"romans"}]
