2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":16,"verses":[{"id":"28338","book":"로마서","book_name":"로마서","chapter":16,"verse":1,"text":"내가 겐그레아 교회의 일군으로 있는 우리 자매 뵈뵈를 너희에게 천거하노니","reference":"로마서 16:1","category":"$undefined"},{"id":"28339","book":"로마서","book_name":"로마서","chapter":16,"verse":2,"text":"너희가 주 안에서 성도들의 합당한 예절로 그를 영접하고 무엇이든지 그에게 소용되는 바를 도와줄지니 이는 그가 여러 사람과 나의 보호자가 되었음이니라","reference":"로마서 16:2","category":"$undefined"},{"id":"28340","book":"로마서","book_name":"로마서","chapter":16,"verse":3,"text":"너희가 그리스도 예수 안에서 나의 동역자들인 브리스가와 아굴라에게 문안하라","reference":"로마서 16:3","category":"$undefined"},{"id":"28341","book":"로마서","book_name":"로마서","chapter":16,"verse":4,"text":"저희는 내 목숨을 위하여 자기의 목이라도 내어 놓았나니 나뿐 아니라 이방인의 모든 교회도 저희에게 감사하느니라","reference":"로마서 16:4","category":"$undefined"},{"id":"28342","book":"로마서","book_name":"로마서","chapter":16,"verse":5,"text":"또 저의 교회에게도 문안하러 너희 사랑하는 에배네도에게 문안하라 저는 아시아에서 그리스도께 처음 익은 열매니라","reference":"로마서 16:5","category":"$undefined"},{"id":"28343","book":"로마서","book_name":"로마서","chapter":16,"verse":6,"text":"너희를 위하여 많이 수고한 마리아에게 문안하라","reference":"로마서 16:6","category":"$undefined"},{"id":"28344","book":"로마서","book_name":"로마서","chapter":16,"verse":7,"text":"내 친척이요 나와 함께 갇혔던 안드로니고와 유니아에게 문안하라 저희는 사도에게 유명히 여김을 받고 또한 나보다 먼저 그리스도 안에 있는 자라","reference":"로마서 16:7","category":"$undefined"},{"id":"28345","book":"로마서","book_name":"로마서","chapter":16,"verse":8,"text":"또 주 안에서 내 사랑하는 암블리아에게 문안하라","reference":"로마서 16:8","category":"$undefined"},{"id":"28346","book":"로마서","book_name":"로마서","chapter":16,"verse":9,"text":"그리스도 안에서 우리의 동역자인 우르바노와 나의 사랑하는 스다구에게 문안하라","reference":"로마서 16:9","category":"$undefined"},{"id":"28347","book":"로마서","book_name":"로마서","chapter":16,"verse":10,"text":"그리스도 안에서 인정함을 받은 아벨레에게 문안하라 아리스도불로의 권속에게 문안하라","reference":"로마서 16:10","category":"$undefined"},{"id":"28348","book":"로마서","book_name":"로마서","chapter":16,"verse":11,"text":"내 친척 헤로디온에게 문안하라 나깃수의 권속 중 주 안에 있는 자들에게 문안하라","reference":"로마서 16:11","category":"$undefined"},{"id":"28349","book":"로마서","book_name":"로마서","chapter":16,"verse":12,"text":"주 안에서 수고한 드루배나와 드루보사에게 문안하라 주 안에서 많이 수고하고 사랑하는 버시에게 문안하라","reference":"로마서 16:12","category":"$undefined"},{"id":"28350","book":"로마서","book_name":"로마서","chapter":16,"verse":13,"text":"주 안에서 택하심을 입은 루포와 그 어머니에게 문안하라 그 어머니는 곧 내 어머니니라","reference":"로마서 16:13","category":"$undefined"},{"id":"28351","book":"로마서","book_name":"로마서","chapter":16,"verse":14,"text":"아순그리도와 블레곤과 허메와 바드로바와 허마와 저희와 함께 있는 형제들에게 문안하라","reference":"로마서 16:14","category":"$undefined"},{"id":"28352","book":"로마서","book_name":"로마서","chapter":16,"verse":15,"text":"빌롤로고와 율리아와 또 네레오와 그 자매와 올름바와 저희와 함께 있는 모든 성도에게 문안하라","reference":"로마서 16:15","category":"$undefined"},{"id":"28353","book":"로마서","book_name":"로마서","chapter":16,"verse":16,"text":"너희가 거룩하게 입맞춤으로 서로 문안하라 그리스도의 모든 교회가 다 너희에게 문안하느니라","reference":"로마서 16:16","category":"$undefined"},{"id":"28354","book":"로마서","book_name":"로마서","chapter":16,"verse":17,"text":"형제들아 내가 너희를 권하노니 너희 교훈을 거스려 분쟁을 일으키고 거치게 하는 자들을 살피고 저희에게서 떠나라","reference":"로마서 16:17","category":"$undefined"},{"id":"28355","book":"로마서","book_name":"로마서","chapter":16,"verse":18,"text":"이같은 자들은 우리 주 그리스도를 섬기지 아니하고 다만 자기의 배만 섬기나니 공교하고 아첨하는 말로 순진한 자들의 마음을 미혹하느니라","reference":"로마서 16:18","category":"$undefined"},{"id":"28356","book":"로마서","book_name":"로마서","chapter":16,"verse":19,"text":"너희 순종함이 모든 사람에게 들리는지라 그러므로 내가 너희를 인하여 기뻐하노니 너희가 선한데 지혜롭고 악한데 미련하기를 원하노라","reference":"로마서 16:19","category":"$undefined"},{"id":"28357","book":"로마서","book_name":"로마서","chapter":16,"verse":20,"text":"평강의 하나님께서 속히 사단을 너희 발 아래서 상하게 하시리라 우리 주 예수의 은혜가 너희에게 있을지어다","reference":"로마서 16:20","category":"$undefined"},{"id":"28358","book":"로마서","book_name":"로마서","chapter":16,"verse":21,"text":"나의 동역자 디모데와 나의 친척 누기오와 야손과 소시바더가 너희에게 문안하느니라","reference":"로마서 16:21","category":"$undefined"},{"id":"28359","book":"로마서","book_name":"로마서","chapter":16,"verse":22,"text":"이 편지를 대서하는 나 더디오도 주 안에서 너희에게 문안하노라","reference":"로마서 16:22","category":"$undefined"},{"id":"28360","book":"로마서","book_name":"로마서","chapter":16,"verse":23,"text":"나와 온 교회 식주인 가이오도 너희에게 문안하고 이 성의 재무 에라스도와 형제 구아도도 너희에게 문안하느니라","reference":"로마서 16:23","category":"$undefined"},{"id":"28361","book":"로마서","book_name":"로마서","chapter":16,"verse":24,"text":"(없 음)","reference":"로마서 16:24","category":"$undefined"},{"id":"28362","book":"로마서","book_name":"로마서","chapter":16,"verse":25,"text":"나의 복음과 예수 그리스도를 전파함은 영세 전부터 감취었다가","reference":"로마서 16:25","category":"$undefined"},{"id":"28363","book":"로마서","book_name":"로마서","chapter":16,"verse":26,"text":"이제는 나타내신 바 되었으며 영원하신 하나님의 명을 좇아 선지자들의 글로 말미암아 모든 민족으로 믿어 순종케 하시려고 알게하신 바 그 비밀의 계시를 좇아 된 것이니 이 복음으로 너희를 능히 견고케 하실","reference":"로마서 16:26","category":"$undefined"},{"id":"28364","book":"로마서","book_name":"로마서","chapter":16,"verse":27,"text":"지혜로우신 하나님께 예수 그리스도로 말미암아 영광이 세세무궁토록 있을지어다 아멘","reference":"로마서 16:27","category":"$undefined"}],"bookSlug":"romans"}]
