2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":2,"verses":[{"id":"27964","book":"로마서","book_name":"로마서","chapter":2,"verse":1,"text":"그러므로 남을 판단하는 사람아 ! 무론 누구든지 네가 핑계치 못할 것은 남을 판단하는 것으로 네가 너를 정죄함이니 판단하는 네가 같은 일을 행함이니라","reference":"로마서 2:1","category":"$undefined"},{"id":"27965","book":"로마서","book_name":"로마서","chapter":2,"verse":2,"text":"이런 일을 행하는 자에게 하나님의 판단이 진리대로 되는 줄 우리가 아노라","reference":"로마서 2:2","category":"$undefined"},{"id":"27966","book":"로마서","book_name":"로마서","chapter":2,"verse":3,"text":"이런 일을 행하는 자를 판단하고도 같은 일을 행하는 사람아 네가 하나님의 판단을 피할 줄로 생각하느냐","reference":"로마서 2:3","category":"$undefined"},{"id":"27967","book":"로마서","book_name":"로마서","chapter":2,"verse":4,"text":"혹 네가 하나님의 인자하심이 너를 인도하여 회개케 하심을 알지 못하여 그의 인자하심과 용납하심과 길이 참으심의 풍성함을 멸시하느뇨","reference":"로마서 2:4","category":"$undefined"},{"id":"27968","book":"로마서","book_name":"로마서","chapter":2,"verse":5,"text":"다만 네 고집과 회개치 아니한 마음을 따라 진노의 날 곧 하나님의 의로우신 판단이 나타나는 그 날에 임할 진노를 네게 쌓는도다","reference":"로마서 2:5","category":"$undefined"},{"id":"27969","book":"로마서","book_name":"로마서","chapter":2,"verse":6,"text":"하나님께서 각 사람에게 그 행한 대로 보응하시되","reference":"로마서 2:6","category":"$undefined"},{"id":"27970","book":"로마서","book_name":"로마서","chapter":2,"verse":7,"text":"참고 선을 행하여 영광과 존귀와 썩지 아니함을 구하는 자에게는 영생으로 하시고","reference":"로마서 2:7","category":"$undefined"},{"id":"27971","book":"로마서","book_name":"로마서","chapter":2,"verse":8,"text":"오직 당을 지어 진리를 좇지 아니하고 불의를 좇는 자에게는 노와 분으로 하시리라","reference":"로마서 2:8","category":"$undefined"},{"id":"27972","book":"로마서","book_name":"로마서","chapter":2,"verse":9,"text":"악을 행하는 각 사람의 영에게 환난과 곤고가 있으리니 첫째는 유대인에게요 또한 헬라인에게며","reference":"로마서 2:9","category":"$undefined"},{"id":"27973","book":"로마서","book_name":"로마서","chapter":2,"verse":10,"text":"선을 행하는 각 사람에게는 영광과 존귀와 평강이 있으리니 첫째는 유대인에게요 또한 헬라인에게라","reference":"로마서 2:10","category":"$undefined"},{"id":"27974","book":"로마서","book_name":"로마서","chapter":2,"verse":11,"text":"이는 하나님께서 외모로 사람을 취하지 아니하심이니라","reference":"로마서 2:11","category":"$undefined"},{"id":"27975","book":"로마서","book_name":"로마서","chapter":2,"verse":12,"text":"무릇 율법 없이 범죄한 자는 또한 율법 없이 망하고 무릇 율법이 있고 범죄한 자는 율법으로 말미암아 심판을 받으리라","reference":"로마서 2:12","category":"$undefined"},{"id":"27976","book":"로마서","book_name":"로마서","chapter":2,"verse":13,"text":"하나님 앞에서는 율법을 듣는 자가 의인이 아니요 오직 율법을 행하는 자라야 의롭다 하심을 얻으리니","reference":"로마서 2:13","category":"$undefined"},{"id":"27977","book":"로마서","book_name":"로마서","chapter":2,"verse":14,"text":"(율법 없는 이방인이 본성으로 율법의 일을 행할 때는 이 사람은 율법이 없어도 자기가 자기에게 율법이 되나니","reference":"로마서 2:14","category":"$undefined"},{"id":"27978","book":"로마서","book_name":"로마서","chapter":2,"verse":15,"text":"이런 이들은 그 양심이 증거가 되어 그 생각들이 서로 혹은 송사하며 혹은 변명하여 그 마음에 새긴 율법의 행위를 나타내느니라)","reference":"로마서 2:15","category":"$undefined"},{"id":"27979","book":"로마서","book_name":"로마서","chapter":2,"verse":16,"text":"곧 내 복음에 이른 바와 같이 하나님이 예수 그리스도로 말미암아 사람들의 은밀한 것을 심판하시는 그날이라","reference":"로마서 2:16","category":"$undefined"},{"id":"27980","book":"로마서","book_name":"로마서","chapter":2,"verse":17,"text":"유대인이라 칭하는 네가 율법을 의지하며 하나님을 자랑하며","reference":"로마서 2:17","category":"$undefined"},{"id":"27981","book":"로마서","book_name":"로마서","chapter":2,"verse":18,"text":"율법의 교훈을 받아 하나님의 뜻을 알고 지극히 선한 것을 좋게 여기며","reference":"로마서 2:18","category":"$undefined"},{"id":"27982","book":"로마서","book_name":"로마서","chapter":2,"verse":19,"text":"네가 율법에 있는 지식과 진리의 규모를 가진 자로서 소경의 길을 인도하는 자요 어두움에 있는 자의 빛이요","reference":"로마서 2:19","category":"$undefined"},{"id":"27983","book":"로마서","book_name":"로마서","chapter":2,"verse":20,"text":"어리석은 자의 훈도요 어린 아이의 선생이라고 스스로 믿으니","reference":"로마서 2:20","category":"$undefined"},{"id":"27984","book":"로마서","book_name":"로마서","chapter":2,"verse":21,"text":"그러면 다른 사람을 가르치는 네가 네 자신을 가르치지 아니하느냐 ? 도적질 말라 반포하는 네가 도적질하느냐 ?","reference":"로마서 2:21","category":"$undefined"},{"id":"27985","book":"로마서","book_name":"로마서","chapter":2,"verse":22,"text":"간음하지 말라 말하는 네가 간음하느냐 ? 우상을 가증히 여기는 네가 신사 물건을 도적질하느냐 ?","reference":"로마서 2:22","category":"$undefined"},{"id":"27986","book":"로마서","book_name":"로마서","chapter":2,"verse":23,"text":"율법을 자랑하는 네가 율법을 범함으로 하나님을 욕되게 하느냐 ?","reference":"로마서 2:23","category":"$undefined"},{"id":"27987","book":"로마서","book_name":"로마서","chapter":2,"verse":24,"text":"기록된 바와 같이 하나님의 이름이 너희로 인하여 이방인 중에서 모독을 받는도다","reference":"로마서 2:24","category":"$undefined"},{"id":"27988","book":"로마서","book_name":"로마서","chapter":2,"verse":25,"text":"네가 율법을 행한즉 할례가 유익하나 만일 율법을 범한즉 네 할례가 무할례가 되었느니라","reference":"로마서 2:25","category":"$undefined"},{"id":"27989","book":"로마서","book_name":"로마서","chapter":2,"verse":26,"text":"그런즉 무할례자가 율법의 제도를 지키면 그 무할례를 할례와 같이 여길 것이 아니냐","reference":"로마서 2:26","category":"$undefined"},{"id":"27990","book":"로마서","book_name":"로마서","chapter":2,"verse":27,"text":"또한 본래 무할례자가 율법을 온전히 지키면 의문과 할례를 가지고 율법을 범하는 너를 판단치 아니하겠느냐 ?","reference":"로마서 2:27","category":"$undefined"},{"id":"27991","book":"로마서","book_name":"로마서","chapter":2,"verse":28,"text":"대저 표면적 유대인이 유대인이 아니요 표면적 육신의 할례가 할례가 아니라","reference":"로마서 2:28","category":"$undefined"},{"id":"27992","book":"로마서","book_name":"로마서","chapter":2,"verse":29,"text":"오직 이면적 유대인이 유대인이며 할례는 마음에 할지니 신령에 있고 의문에 있지 아니한 것이라 그 칭찬이 사람에게서가 아니요 다만 하나님에게서니라","reference":"로마서 2:29","category":"$undefined"}],"bookSlug":"romans"}]
