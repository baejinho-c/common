2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":3,"verses":[{"id":"27993","book":"로마서","book_name":"로마서","chapter":3,"verse":1,"text":"그런즉 유대인의 나음이 무엇이며 할례의 유익이 무엇이뇨","reference":"로마서 3:1","category":"$undefined"},{"id":"27994","book":"로마서","book_name":"로마서","chapter":3,"verse":2,"text":"범사에 많으니 첫째는 저희가 하나님의 말씀을 맡았음이니라","reference":"로마서 3:2","category":"$undefined"},{"id":"27995","book":"로마서","book_name":"로마서","chapter":3,"verse":3,"text":"어떤 자들이 믿지 아니하였으면 어찌하리요 그 믿지 아니함이 하나님의 미쁘심을 폐하겠느뇨","reference":"로마서 3:3","category":"$undefined"},{"id":"27996","book":"로마서","book_name":"로마서","chapter":3,"verse":4,"text":"그럴 수 없느니라 사람은 다 거짓되되 오직 하나님은 참되시다 할지어다 기록된 바 주께서 주의 말씀에 의롭다 함을 얻으시고 판단 받으실 때에 이기려 하심이라 함과 같으니라","reference":"로마서 3:4","category":"$undefined"},{"id":"27997","book":"로마서","book_name":"로마서","chapter":3,"verse":5,"text":"그러나 우리 불의가 하나님의 의를 드러나게 하면 무슨 말 하리요 내가 사람의 말하는 대로 말하노니 진노를 내리시는 하나님이 불의하시냐","reference":"로마서 3:5","category":"$undefined"},{"id":"27998","book":"로마서","book_name":"로마서","chapter":3,"verse":6,"text":"결코 그렇지 아니하니라 만일 그러하면 하나님께서 어찌 세상을 심판하시리요","reference":"로마서 3:6","category":"$undefined"},{"id":"27999","book":"로마서","book_name":"로마서","chapter":3,"verse":7,"text":"그러나 나의 거짓말로 하나님의 참되심이 더 풍성하여 그의 영광이 되었으면 어찌 나도 죄인처럼 심판을 받으리요","reference":"로마서 3:7","category":"$undefined"},{"id":"28000","book":"로마서","book_name":"로마서","chapter":3,"verse":8,"text":"또는 그러면 선을 이루기 위하여 악을 행하자 하지 않겠느냐(어떤 이들이 이렇게 비방하여 우리가 이런 말을 한다고 하니) 저희가 정죄 받는 것이 옳으니라","reference":"로마서 3:8","category":"$undefined"},{"id":"28001","book":"로마서","book_name":"로마서","chapter":3,"verse":9,"text":"그러면 어떠하뇨 우리는 나으뇨 결코 아니라 유대인이나 헬라인이나 다 죄 아래 있다고 우리가 이미 선언하였느니라","reference":"로마서 3:9","category":"$undefined"},{"id":"28002","book":"로마서","book_name":"로마서","chapter":3,"verse":10,"text":"기록한 바 의인은 없나니 하나도 없으며","reference":"로마서 3:10","category":"$undefined"},{"id":"28003","book":"로마서","book_name":"로마서","chapter":3,"verse":11,"text":"깨닫는 자도 없고 하나님을 찾는 자도 없고","reference":"로마서 3:11","category":"$undefined"},{"id":"28004","book":"로마서","book_name":"로마서","chapter":3,"verse":12,"text":"다 치우쳐 한가지로 무익하게 되고 선을 행하는 자는 없나니 하나도 없도다","reference":"로마서 3:12","category":"$undefined"},{"id":"28005","book":"로마서","book_name":"로마서","chapter":3,"verse":13,"text":"저희 목구멍은 열린 무덤이요 그 혀로는 속임을 베풀며 그 입술에는 독사의 독이 있고","reference":"로마서 3:13","category":"$undefined"},{"id":"28006","book":"로마서","book_name":"로마서","chapter":3,"verse":14,"text":"그 입에는 저주와 악독이 가득하고","reference":"로마서 3:14","category":"$undefined"},{"id":"28007","book":"로마서","book_name":"로마서","chapter":3,"verse":15,"text":"그 발은 피 흘리는데 빠른지라","reference":"로마서 3:15","category":"$undefined"},{"id":"28008","book":"로마서","book_name":"로마서","chapter":3,"verse":16,"text":"파멸과 고생이 그 길에 있어","reference":"로마서 3:16","category":"$undefined"},{"id":"28009","book":"로마서","book_name":"로마서","chapter":3,"verse":17,"text":"평강의 길을 알지 못하였고","reference":"로마서 3:17","category":"$undefined"},{"id":"28010","book":"로마서","book_name":"로마서","chapter":3,"verse":18,"text":"저희 눈앞에 하나님을 두려워함이 없느니라 함과 같으니라","reference":"로마서 3:18","category":"$undefined"},{"id":"28011","book":"로마서","book_name":"로마서","chapter":3,"verse":19,"text":"우리가 알거니와 무릇 율법이 말하는 바는 율법 아래 있는 자들에게 말하는 것이니 이는 모든 입을 막고 온 세상으로 하나님의 심판 아래 있게 하려 함이니라","reference":"로마서 3:19","category":"$undefined"},{"id":"28012","book":"로마서","book_name":"로마서","chapter":3,"verse":20,"text":"그러므로 율법의 행위로 그의 앞에 의롭다 하심을 얻을 육체가 없나니 율법으로는 죄를 깨달음이니라","reference":"로마서 3:20","category":"$undefined"},{"id":"28013","book":"로마서","book_name":"로마서","chapter":3,"verse":21,"text":"이제는 율법 외에 하나님의 한 의가 나타났으니 율법과 선지자들에게 증거를 받은 것이라","reference":"로마서 3:21","category":"$undefined"},{"id":"28014","book":"로마서","book_name":"로마서","chapter":3,"verse":22,"text":"곧 예수 그리스도를 믿음으로 말미암아 모든 믿는 자에게 미치는 하나님의 의니 차별이 없느니라","reference":"로마서 3:22","category":"$undefined"},{"id":"28015","book":"로마서","book_name":"로마서","chapter":3,"verse":23,"text":"모든 사람이 죄를 범하였으매 하나님의 영광에 이르지 못하더니","reference":"로마서 3:23","category":"$undefined"},{"id":"28016","book":"로마서","book_name":"로마서","chapter":3,"verse":24,"text":"그리스도 예수 안에 있는 구속으로 말미암아 하나님의 은혜로 값없이 의롭다 하심을 얻은 자 되었느니라","reference":"로마서 3:24","category":"$undefined"},{"id":"28017","book":"로마서","book_name":"로마서","chapter":3,"verse":25,"text":"이 예수를 하나님이 그의 피로 인하여 믿음으로 말미암는 화목 제물로 세우셨으니 이는 하나님께서 길이 참으시는 중에 전에 지은 죄를 간과하심으로 자기의 의로우심을 나타내려 하심이니","reference":"로마서 3:25","category":"$undefined"},{"id":"28018","book":"로마서","book_name":"로마서","chapter":3,"verse":26,"text":"곧 이 때에 자기의 의로우심을 나타내사 자기도 의로우시며 또한 예수 믿는 자를 의롭다 하려 하심이니라","reference":"로마서 3:26","category":"$undefined"},{"id":"28019","book":"로마서","book_name":"로마서","chapter":3,"verse":27,"text":"그런즉 자랑할 데가 어디뇨 있을 수가 없느니라 무슨 법으로냐 행위로냐 아니라 오직 믿음의 법으로니라","reference":"로마서 3:27","category":"$undefined"},{"id":"28020","book":"로마서","book_name":"로마서","chapter":3,"verse":28,"text":"그러므로 사람이 의롭다 하심을 얻는 것은 율법의 행위에 있지 않고 믿음으로 되는 줄 우리가 인정하노라","reference":"로마서 3:28","category":"$undefined"},{"id":"28021","book":"로마서","book_name":"로마서","chapter":3,"verse":29,"text":"하나님은 홀로 유대인의 하나님뿐이시뇨 또 이방인의 하나님은 아니시뇨 진실로 이방인의 하나님도 되시느니라","reference":"로마서 3:29","category":"$undefined"},{"id":"28022","book":"로마서","book_name":"로마서","chapter":3,"verse":30,"text":"할례자도 믿음으로 말미암아 또는 무할례자도 믿음으로 말미암아 의롭다 하실 하나님은 한 분이시니라","reference":"로마서 3:30","category":"$undefined"},{"id":"28023","book":"로마서","book_name":"로마서","chapter":3,"verse":31,"text":"그런즉 우리가 믿음으로 말미암아 율법을 폐하느뇨 그럴 수 없느니라 도리어 율법을 굳게 세우느니라","reference":"로마서 3:31","category":"$undefined"}],"bookSlug":"romans"}]
