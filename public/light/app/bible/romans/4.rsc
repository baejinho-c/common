2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":4,"verses":[{"id":"28024","book":"로마서","book_name":"로마서","chapter":4,"verse":1,"text":"그런즉 육신으로 우리 조상된 아브라함이 무엇을 얻었다 하리요","reference":"로마서 4:1","category":"$undefined"},{"id":"28025","book":"로마서","book_name":"로마서","chapter":4,"verse":2,"text":"만일 아브라함이 행위로써 의롭다 하심을 얻었으면 자랑할 것이 있으려니와 하나님 앞에서는 없느니라","reference":"로마서 4:2","category":"$undefined"},{"id":"28026","book":"로마서","book_name":"로마서","chapter":4,"verse":3,"text":"성경이 무엇을 말하느뇨 아브라함이 하나님을 믿으매 이것이 저에게 의로 여기신바 되었느니라","reference":"로마서 4:3","category":"$undefined"},{"id":"28027","book":"로마서","book_name":"로마서","chapter":4,"verse":4,"text":"일하는 자에게는 그 삯을 은혜로 여기지 아니하고 빚으로 여기거니와","reference":"로마서 4:4","category":"$undefined"},{"id":"28028","book":"로마서","book_name":"로마서","chapter":4,"verse":5,"text":"일을 아니할지라도 경건치 아니한 자를 의롭다 하시는 이를 믿는 자에게는 그의 믿음을 의로 여기시나니","reference":"로마서 4:5","category":"$undefined"},{"id":"28029","book":"로마서","book_name":"로마서","chapter":4,"verse":6,"text":"일한 것이 없이 하나님께 의로 여기심을 받는 사람의 행복에 대하여 다윗의 말한 바","reference":"로마서 4:6","category":"$undefined"},{"id":"28030","book":"로마서","book_name":"로마서","chapter":4,"verse":7,"text":"그 불법을 사하심을 받고 그 죄를 가리우심을 받는 자는 복이 있고","reference":"로마서 4:7","category":"$undefined"},{"id":"28031","book":"로마서","book_name":"로마서","chapter":4,"verse":8,"text":"주께서 그 죄를 인정치 아니하실 사람은 복이 있도다 함과 같으니라","reference":"로마서 4:8","category":"$undefined"},{"id":"28032","book":"로마서","book_name":"로마서","chapter":4,"verse":9,"text":"그런즉 이 행복이 할례자에게뇨 혹 무할례자에게도뇨 대저 우리가 말하기를 아브라함에게는 그 믿음을 의로 여기셨다 하노라","reference":"로마서 4:9","category":"$undefined"},{"id":"28033","book":"로마서","book_name":"로마서","chapter":4,"verse":10,"text":"그런즉 이를 어떻게 여기셨느뇨 할례시냐 무할례시냐 할례시가 아니라 무할례시니라","reference":"로마서 4:10","category":"$undefined"},{"id":"28034","book":"로마서","book_name":"로마서","chapter":4,"verse":11,"text":"저가 할례의 표를 받은 것은 무할례시에 믿음으로 된 의를 인친 것이니 이는 무할례자로서 믿는 모든 자의 조상이 되어 저희로 의로 여기심을 얻게 하려 하심이라","reference":"로마서 4:11","category":"$undefined"},{"id":"28035","book":"로마서","book_name":"로마서","chapter":4,"verse":12,"text":"또한 할례자의 조상이 되었나니 곧 할례 받을 자에게뿐 아니라 우리 조상 아브라함의 무할례시에 가졌던 믿음의 자취를 좇는 자들에게도니라","reference":"로마서 4:12","category":"$undefined"},{"id":"28036","book":"로마서","book_name":"로마서","chapter":4,"verse":13,"text":"아브라함이나 그 후손에게 세상의 후사가 되리라고 하신 언약은 율법으로 말미암은 것이 아니요 오직 믿음의 의로 말미암은 것이니라","reference":"로마서 4:13","category":"$undefined"},{"id":"28037","book":"로마서","book_name":"로마서","chapter":4,"verse":14,"text":"만일 율법에 속한 자들이 후사이면 믿음은 헛것이 되고 약속은 폐하여졌느니라","reference":"로마서 4:14","category":"$undefined"},{"id":"28038","book":"로마서","book_name":"로마서","chapter":4,"verse":15,"text":"율법은 진노를 이루게 하나니 율법이 없는 곳에는 범함도 없느니라","reference":"로마서 4:15","category":"$undefined"},{"id":"28039","book":"로마서","book_name":"로마서","chapter":4,"verse":16,"text":"그러므로 후사가 되는 이것이 은혜에 속하기 위하여 믿음으로 되나니 이는 그 약속을 그 모든 후손에게 굳게 하려 하심이라 율법에 속한 자에게뿐 아니라 아브라함의 믿음에 속한 자에게도니 아브라함은 하나님 앞에서 우리 모든 사람의 조상이라","reference":"로마서 4:16","category":"$undefined"},{"id":"28040","book":"로마서","book_name":"로마서","chapter":4,"verse":17,"text":"기록된바 내가 너를 많은 민족의 조상으로 세웠다 하심과 같으니 그의 믿은바 하나님은 죽은 자를 살리시며 없는 것을 있는것 같이 부르시는 이시니라","reference":"로마서 4:17","category":"$undefined"},{"id":"28041","book":"로마서","book_name":"로마서","chapter":4,"verse":18,"text":"아브라함이 바랄 수 없는 중에 바라고 믿었으니 이는 네 후손이 이같으리라 하신 말씀대로 많은 민족의 조상이 되게 하려 하심을 인함이라","reference":"로마서 4:18","category":"$undefined"},{"id":"28042","book":"로마서","book_name":"로마서","chapter":4,"verse":19,"text":"그가 백세나 되어 자기 몸의 죽은 것 같음과 사라의 태의 죽은것 같음을 알고도 믿음이 약하여지지 아니하고","reference":"로마서 4:19","category":"$undefined"},{"id":"28043","book":"로마서","book_name":"로마서","chapter":4,"verse":20,"text":"믿음이 없어 하나님의 약속을 의심치 않고 믿음에 견고하여져서 하나님께 영광을 돌리며","reference":"로마서 4:20","category":"$undefined"},{"id":"28044","book":"로마서","book_name":"로마서","chapter":4,"verse":21,"text":"약속하신 그것을 또한 능히 이루실 줄을 확신하였으니","reference":"로마서 4:21","category":"$undefined"},{"id":"28045","book":"로마서","book_name":"로마서","chapter":4,"verse":22,"text":"그러므로 이것을 저에게 의로 여기셨느니라","reference":"로마서 4:22","category":"$undefined"},{"id":"28046","book":"로마서","book_name":"로마서","chapter":4,"verse":23,"text":"저에게 의로 여기셨다 기록된 것은 아브라함만 위한 것이 아니요","reference":"로마서 4:23","category":"$undefined"},{"id":"28047","book":"로마서","book_name":"로마서","chapter":4,"verse":24,"text":"의로 여기심을 받을 우리도 위함이니 곧 예수 우리 주를 죽은 자 가운데서 살리신 이를 믿는 자니라","reference":"로마서 4:24","category":"$undefined"},{"id":"28048","book":"로마서","book_name":"로마서","chapter":4,"verse":25,"text":"예수는 우리 범죄함을 위하여 내어줌이 되고 또한 우리를 의롭다 하심을 위하여 살아나셨느니라","reference":"로마서 4:25","category":"$undefined"}],"bookSlug":"romans"}]
