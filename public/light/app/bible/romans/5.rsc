2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":5,"verses":[{"id":"28049","book":"로마서","book_name":"로마서","chapter":5,"verse":1,"text":"그러므로 우리가 믿음으로 의롭다 하심을 얻었은즉 우리 주 예수 그리스도로 말미암아 하나님으로 더불어 화평을 누리자","reference":"로마서 5:1","category":"$undefined"},{"id":"28050","book":"로마서","book_name":"로마서","chapter":5,"verse":2,"text":"또한 그로 말미암아 우리가 믿음으로 서있는 이 은혜에 들어감을 얻었으며 하나님의 영광을 바라고 즐거워하느니라","reference":"로마서 5:2","category":"$undefined"},{"id":"28051","book":"로마서","book_name":"로마서","chapter":5,"verse":3,"text":"다만 이뿐 아니라 우리가 환난중에도 즐거워하나니 이는 환난은 인내를","reference":"로마서 5:3","category":"$undefined"},{"id":"28052","book":"로마서","book_name":"로마서","chapter":5,"verse":4,"text":"인내는 연단을 연단은 소망을 이루는 줄 앎이로다","reference":"로마서 5:4","category":"$undefined"},{"id":"28053","book":"로마서","book_name":"로마서","chapter":5,"verse":5,"text":"소망이 부끄럽게 아니함은 우리에게 주신 성령으로 말미암아 하나님의 사랑이 우리 마음에 부은바 됨이니","reference":"로마서 5:5","category":"$undefined"},{"id":"28054","book":"로마서","book_name":"로마서","chapter":5,"verse":6,"text":"우리가 아직 연약할 때에 기약대로 그리스도께서 경건치 않은 자를 위하여 죽으셨도다","reference":"로마서 5:6","category":"$undefined"},{"id":"28055","book":"로마서","book_name":"로마서","chapter":5,"verse":7,"text":"의인을 위하여 죽는 자가 쉽지않고 선인을 위하여 용감히 죽는 자가 혹 있거니와","reference":"로마서 5:7","category":"$undefined"},{"id":"28056","book":"로마서","book_name":"로마서","chapter":5,"verse":8,"text":"우리가 아직 죄인 되었을 때에 그리스도께서 우리를 위하여 죽으심으로 하나님께서 우리에게 대한 자기의 사랑을 확증하셨느니라","reference":"로마서 5:8","category":"$undefined"},{"id":"28057","book":"로마서","book_name":"로마서","chapter":5,"verse":9,"text":"그러면 이제 우리가 그 피를 인하여 의롭다 하심을 얻었은즉 더욱 그로 말미암아 진노하심에서 구원을 얻을 것이니","reference":"로마서 5:9","category":"$undefined"},{"id":"28058","book":"로마서","book_name":"로마서","chapter":5,"verse":10,"text":"곧 우리가 원수 되었을 때에 그 아들의 죽으심으로 말미암아 하나님으로 더불어 화목되었은즉 화목된 자로서는 더욱 그의 살으심을 인하여 구원을 얻을 것이니라","reference":"로마서 5:10","category":"$undefined"},{"id":"28059","book":"로마서","book_name":"로마서","chapter":5,"verse":11,"text":"이뿐 아니라 이제 우리로 화목을 얻게 하신 우리 주 예수 그리스도로 말미암아 하나님 안에서 또한 즐거워하느니라","reference":"로마서 5:11","category":"$undefined"},{"id":"28060","book":"로마서","book_name":"로마서","chapter":5,"verse":12,"text":"이러므로 한 사람으로 말미암아 죄가 세상에 들어오고 죄로 말미암아 사망이 왔나니 이와 같이 모든 사람이 죄를 지었으므로 사망이 모든 사람에게 이르렀느니라","reference":"로마서 5:12","category":"$undefined"},{"id":"28061","book":"로마서","book_name":"로마서","chapter":5,"verse":13,"text":"죄가 율법 있기 전에도 세상에 있었으나 율법이 없을 때에는 죄를 죄로 여기지 아니하느니라","reference":"로마서 5:13","category":"$undefined"},{"id":"28062","book":"로마서","book_name":"로마서","chapter":5,"verse":14,"text":"그러나 아담으로부터 모세까지 아담의 범죄와 같은 죄를 짓지 아니한 자들 위에도 사망이 왕노릇하였나니 아담은 오실 자의 표상이라","reference":"로마서 5:14","category":"$undefined"},{"id":"28063","book":"로마서","book_name":"로마서","chapter":5,"verse":15,"text":"그러나 이 은사는 그 범죄와 같지 아니하니 곧 한 사람의 범죄를 인하여 많은 사람이 죽었은즉 더욱 하나님의 은혜와 또는 한 사람 예수 그리스도의 은혜로 말미암은 선물이 많은 사람에게 넘쳤으리라","reference":"로마서 5:15","category":"$undefined"},{"id":"28064","book":"로마서","book_name":"로마서","chapter":5,"verse":16,"text":"또 이 선물은 범죄한 한 사람으로 말미암은 것과 같지 아니하니 심판은 한 사람을 인하여 정죄에 이르렀으나 은사는 많은 범죄를 인하여 의롭다 하심에 이름이니라","reference":"로마서 5:16","category":"$undefined"},{"id":"28065","book":"로마서","book_name":"로마서","chapter":5,"verse":17,"text":"한 사람의 범죄를 인하여 사망이 그 한 사람으로 말미암아 왕노릇 하였은즉 더욱 은혜와 의의 선물을 넘치게 받는 자들이 한 분 예수 그리스도로 말미암아 생명 안에서 왕노릇하리로다","reference":"로마서 5:17","category":"$undefined"},{"id":"28066","book":"로마서","book_name":"로마서","chapter":5,"verse":18,"text":"그런즉 한 범죄로 많은 사람이 정죄에 이른 것 같이 의의 한 행동으로 말미암아 많은 사람이 의롭다 하심을 받아 생명에 이르렀느니라","reference":"로마서 5:18","category":"$undefined"},{"id":"28067","book":"로마서","book_name":"로마서","chapter":5,"verse":19,"text":"한 사람의 순종치 아니함으로 많은 사람이 죄인 된 것같이 한 사람의 순종하심으로 많은 사람이 의인이 되리라","reference":"로마서 5:19","category":"$undefined"},{"id":"28068","book":"로마서","book_name":"로마서","chapter":5,"verse":20,"text":"율법이 가입한 것은 범죄를 더하게 하려 함이라 그러나 죄가 더한 곳에 은혜가 넘쳤나니","reference":"로마서 5:20","category":"$undefined"},{"id":"28069","book":"로마서","book_name":"로마서","chapter":5,"verse":21,"text":"이는 죄가 사망 안에서 왕노릇한 것 같이 은혜도 또한 의로 말미암아 왕노릇하여 우리 주 예수 그리스도로 말미암아 영생에 이르게 하려 함이니라","reference":"로마서 5:21","category":"$undefined"}],"bookSlug":"romans"}]
