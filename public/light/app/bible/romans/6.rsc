2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":6,"verses":[{"id":"28070","book":"로마서","book_name":"로마서","chapter":6,"verse":1,"text":"그런즉 우리가 무슨 말 하리요 은혜를 더하게 하려고 죄에 거하겠느뇨","reference":"로마서 6:1","category":"$undefined"},{"id":"28071","book":"로마서","book_name":"로마서","chapter":6,"verse":2,"text":"그럴 수 없느니라 죄에 대하여 죽은 우리가 어찌 그 가운데 더 살리요","reference":"로마서 6:2","category":"$undefined"},{"id":"28072","book":"로마서","book_name":"로마서","chapter":6,"verse":3,"text":"무릇 그리스도 예수와 합하여 세례를 받은 우리는 그의 죽으심과 합하여 세례 받은 줄을 알지 못하느뇨","reference":"로마서 6:3","category":"$undefined"},{"id":"28073","book":"로마서","book_name":"로마서","chapter":6,"verse":4,"text":"그러므로 우리가 그의 죽으심과 합하여 세례를 받음으로 그와 함께 장사되었나니 이는 아버지의 영광으로 말미암아 그리스도를 죽은 자 가운데서 살리심과 같이 우리로 또한 새 생명 가운데서 행하게 하려 함이니라","reference":"로마서 6:4","category":"$undefined"},{"id":"28074","book":"로마서","book_name":"로마서","chapter":6,"verse":5,"text":"만일 우리가 그의 죽으심을 본받아 연합한 자가 되었으면 또한 그의 부활을 본받아 연합한 자가 되리라","reference":"로마서 6:5","category":"$undefined"},{"id":"28075","book":"로마서","book_name":"로마서","chapter":6,"verse":6,"text":"우리가 알거니와 우리 옛 사람이 예수와 함께 십자가에 못 박힌 것은 죄의 몸이 멸하여 다시는 우리가 죄에게 종노릇하지 아니하려 함이니","reference":"로마서 6:6","category":"$undefined"},{"id":"28076","book":"로마서","book_name":"로마서","chapter":6,"verse":7,"text":"이는 죽은 자가 죄에서 벗어나 의롭다 하심을 얻었음이니라","reference":"로마서 6:7","category":"$undefined"},{"id":"28077","book":"로마서","book_name":"로마서","chapter":6,"verse":8,"text":"만일 우리가 그리스도와 함께 죽었으면 또한 그와 함께 살 줄을 믿노니","reference":"로마서 6:8","category":"$undefined"},{"id":"28078","book":"로마서","book_name":"로마서","chapter":6,"verse":9,"text":"이는 그리스도께서 죽은 자 가운데서 사셨으매 다시 죽지 아니하시고 사망이 다시 그를 주장하지 못할줄을 앎이로라","reference":"로마서 6:9","category":"$undefined"},{"id":"28079","book":"로마서","book_name":"로마서","chapter":6,"verse":10,"text":"그의 죽으심은 죄에 대하여 단번에 죽으심이요 그의 살으심은 하나님께 대하여 살으심이니","reference":"로마서 6:10","category":"$undefined"},{"id":"28080","book":"로마서","book_name":"로마서","chapter":6,"verse":11,"text":"이와 같이 너희도 너희 자신을 죄에 대하여는 죽은 자요 그리스도 예수 안에서 하나님을 대하여는 산 자로 여길지어다","reference":"로마서 6:11","category":"$undefined"},{"id":"28081","book":"로마서","book_name":"로마서","chapter":6,"verse":12,"text":"그러므로 너희는 죄로 너희죽을 몸에 왕노릇하지 못하게 하여 몸의 사욕을 순종치 말고","reference":"로마서 6:12","category":"$undefined"},{"id":"28082","book":"로마서","book_name":"로마서","chapter":6,"verse":13,"text":"또한 너희 지체를 불의의 병기로 죄에게 드리지 말고 오직 너희 자신을 죽은 자 가운데서 다시 산 자같이 하나님께 드리며 너의 지체를 의의 병기로 하나님께 드리라","reference":"로마서 6:13","category":"$undefined"},{"id":"28083","book":"로마서","book_name":"로마서","chapter":6,"verse":14,"text":"죄가 너희를 주관치 못하리니 이는 너희가 법 아래 있지 아니하고 은혜 아래 있음이니라","reference":"로마서 6:14","category":"$undefined"},{"id":"28084","book":"로마서","book_name":"로마서","chapter":6,"verse":15,"text":"그런즉 어찌하리요 우리가 법 아래 있지 아니하고 은혜 아래 있으니 죄를 지으리요 그럴 수 없느니라","reference":"로마서 6:15","category":"$undefined"},{"id":"28085","book":"로마서","book_name":"로마서","chapter":6,"verse":16,"text":"너희 자신을 종으로 드려 누구에게 순종하든지 그 순종함을 받는 자의 종이 되는 줄을 너희가 알지 못하느냐 혹은 죄의 종으로 사망에 이르고 순종의 종으로 의에 이르느니라","reference":"로마서 6:16","category":"$undefined"},{"id":"28086","book":"로마서","book_name":"로마서","chapter":6,"verse":17,"text":"하나님께 감사하리로다 너희가 본래 죄의 종이더니 너희에게 전하여 준바 교훈의 본을 마음으로 순종하여","reference":"로마서 6:17","category":"$undefined"},{"id":"28087","book":"로마서","book_name":"로마서","chapter":6,"verse":18,"text":"죄에게서 해방되어 의에게 종이 되었느니라","reference":"로마서 6:18","category":"$undefined"},{"id":"28088","book":"로마서","book_name":"로마서","chapter":6,"verse":19,"text":"너희 육신이 연약하므로 내가 사람의 예대로 말하노니 전에 너희가 너희 지체를 부정과 불법에 드려 불법에 이른 것같이 이제는 너희 지체를 의에게 종으로 드려 거룩함에 이르라","reference":"로마서 6:19","category":"$undefined"},{"id":"28089","book":"로마서","book_name":"로마서","chapter":6,"verse":20,"text":"너희가 죄의 종이 되었을 때에는 의에 대하여 자유하였느니라","reference":"로마서 6:20","category":"$undefined"},{"id":"28090","book":"로마서","book_name":"로마서","chapter":6,"verse":21,"text":"너희가 그 때에 무슨 열매를 얻었느뇨 이제는 너희가 그 일을 부끄러워하나니 이는 그 마지막이 사망임이니라","reference":"로마서 6:21","category":"$undefined"},{"id":"28091","book":"로마서","book_name":"로마서","chapter":6,"verse":22,"text":"그러나 이제는 너희가 죄에게서 해방되고 하나님께 종이 되어 거룩함에 이르는 열매를 얻었으니 이 마지막은 영생이라","reference":"로마서 6:22","category":"$undefined"},{"id":"28092","book":"로마서","book_name":"로마서","chapter":6,"verse":23,"text":"죄의 삯은 사망이요 하나님의 은사는 그리스도 예수 우리 주 안에 있는 영생이니라","reference":"로마서 6:23","category":"$undefined"}],"bookSlug":"romans"}]
