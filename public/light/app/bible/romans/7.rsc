2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":7,"verses":[{"id":"28093","book":"로마서","book_name":"로마서","chapter":7,"verse":1,"text":"형제들아 내가 법 아는 자들에게 말하노니 너희는 율법이 사람의 살 동안만 그를 주관하는 줄 알지 못하느냐","reference":"로마서 7:1","category":"$undefined"},{"id":"28094","book":"로마서","book_name":"로마서","chapter":7,"verse":2,"text":"남편 있는 여인이 그 남편 생전에는 법으로 그에게 매인바 되나 만일 그 남편이 죽으면 남편의 법에서 벗어났느니라","reference":"로마서 7:2","category":"$undefined"},{"id":"28095","book":"로마서","book_name":"로마서","chapter":7,"verse":3,"text":"그러므로 만일 그 남편 생전에 다른 남자에게 가면 음부라 이르되 남편이 죽으면 그 법에서 자유케 되나니 다른 남자에게 갈지라도 음부가 되지 아니하느니라","reference":"로마서 7:3","category":"$undefined"},{"id":"28096","book":"로마서","book_name":"로마서","chapter":7,"verse":4,"text":"그러므로 내 형제들아 너희도 그리스도의 몸으로 말미암아 율법에 대하여 죽임을 당하였으니 이는 다른이 곧 죽은 자 가운데서 살아나신 이에게 가서 우리로 하나님을 위하여 열매를 맺히게 하려 함이니라","reference":"로마서 7:4","category":"$undefined"},{"id":"28097","book":"로마서","book_name":"로마서","chapter":7,"verse":5,"text":"우리가 육신에 있을 때에는 율법으로 말미암는 죄의 정욕이 우리 지체 중에 역사하여 우리로 사망을 위하여 열매를 맺게 하였더니","reference":"로마서 7:5","category":"$undefined"},{"id":"28098","book":"로마서","book_name":"로마서","chapter":7,"verse":6,"text":"이제는 우리가 얽매였던 것에 대하여 죽었으므로 율법에서 벗어났으니 이러므로 우리가 영의 새로운 것으로 섬길 것이요 의문의 묵은 것으로 아니할지니라","reference":"로마서 7:6","category":"$undefined"},{"id":"28099","book":"로마서","book_name":"로마서","chapter":7,"verse":7,"text":"그런즉 우리가 무슨 말 하리요 율법이 죄냐 그럴 수 없느니라 율법으로 말미암지 않고는 내가 죄를 알지 못하였니 곧 율법이 탐내지 말라 하지 아니하였더면 내가 탐심을 알지 못하였으리라","reference":"로마서 7:7","category":"$undefined"},{"id":"28100","book":"로마서","book_name":"로마서","chapter":7,"verse":8,"text":"그러나 죄가 기회를 타서 계명으로 말미암아 내 속에서 각양 탐심을 이루었나니 이는 법이 없으면 죄가 죽은 것임이니라","reference":"로마서 7:8","category":"$undefined"},{"id":"28101","book":"로마서","book_name":"로마서","chapter":7,"verse":9,"text":"전에 법을 깨닫지 못할 때에는 내가 살았더니 계명이 이르매 죄는 살아나고 나는 죽었도다","reference":"로마서 7:9","category":"$undefined"},{"id":"28102","book":"로마서","book_name":"로마서","chapter":7,"verse":10,"text":"생명에 이르게 할 그 계명이 내게 대하여 도리어 사망에 이르게 하는 것이 되었도다","reference":"로마서 7:10","category":"$undefined"},{"id":"28103","book":"로마서","book_name":"로마서","chapter":7,"verse":11,"text":"죄가 기회를 타서 계명으로 말미암아 나를 속이고 그것으로 나를 죽였는지라","reference":"로마서 7:11","category":"$undefined"},{"id":"28104","book":"로마서","book_name":"로마서","chapter":7,"verse":12,"text":"이로 보건대 율법도 거룩하며 계명도 거룩하며 의로우며 선하도다","reference":"로마서 7:12","category":"$undefined"},{"id":"28105","book":"로마서","book_name":"로마서","chapter":7,"verse":13,"text":"그런즉 선한 것이 내게 사망이 되었느뇨 그럴 수 없느니라 오직 죄가 죄로 드러나기 위하여 선한 그것으로 말미암아 나를 죽게 만들었으니 이는 계명으로 말미암아 죄로 심히 죄되게 하려 함이니라","reference":"로마서 7:13","category":"$undefined"},{"id":"28106","book":"로마서","book_name":"로마서","chapter":7,"verse":14,"text":"우리가 율법은 신령한 줄 알거니와 나는 육신에 속하여 죄 아래 팔렸도다","reference":"로마서 7:14","category":"$undefined"},{"id":"28107","book":"로마서","book_name":"로마서","chapter":7,"verse":15,"text":"나의 행하는 것을 내가 알지 못하노니 곧 원하는 이것은 행하지 아니하고 도리어 미워하는 그것을 함이라","reference":"로마서 7:15","category":"$undefined"},{"id":"28108","book":"로마서","book_name":"로마서","chapter":7,"verse":16,"text":"만일 내가 원치 아니하는 그것을 하면 내가 이로 율법의 선한 것을 시인하노니","reference":"로마서 7:16","category":"$undefined"},{"id":"28109","book":"로마서","book_name":"로마서","chapter":7,"verse":17,"text":"이제는 이것을 행하는 자가 내가 아니요 내 속에 거하는 죄니라","reference":"로마서 7:17","category":"$undefined"},{"id":"28110","book":"로마서","book_name":"로마서","chapter":7,"verse":18,"text":"내 속 곧 내 육신에 선한 것이 거하지 아니하는 줄을 아노니 원함은 내게 있으나 선을 행하는 것은 없노라","reference":"로마서 7:18","category":"$undefined"},{"id":"28111","book":"로마서","book_name":"로마서","chapter":7,"verse":19,"text":"내가 원하는 바 선은 하지 아니하고 도리어 원치 아니하는 바 악은 행하는도다","reference":"로마서 7:19","category":"$undefined"},{"id":"28112","book":"로마서","book_name":"로마서","chapter":7,"verse":20,"text":"만일 내가 원치 아니하는 그것을 하면 이를 행하는 자가 내가 아니요 내 속에 거하는 죄니라","reference":"로마서 7:20","category":"$undefined"},{"id":"28113","book":"로마서","book_name":"로마서","chapter":7,"verse":21,"text":"그러므로 내가 한 법을 깨달았노니 곧 선을 행하기 원하는 나에게 악이 함께 있는 것이로다","reference":"로마서 7:21","category":"$undefined"},{"id":"28114","book":"로마서","book_name":"로마서","chapter":7,"verse":22,"text":"내 속 사람으로는 하나님의 법을 즐거워하되","reference":"로마서 7:22","category":"$undefined"},{"id":"28115","book":"로마서","book_name":"로마서","chapter":7,"verse":23,"text":"내 지체 속에서 한 다른 법이 내 마음의 법과 싸워 내 지체 속에 있는 죄의 법 아래로 나를 사로잡아 오는 것을 보는도다","reference":"로마서 7:23","category":"$undefined"},{"id":"28116","book":"로마서","book_name":"로마서","chapter":7,"verse":24,"text":"오호라 ! 나는 곤고한 사람이로다 이 사망의 몸에서 누가 나를 건져내랴","reference":"로마서 7:24","category":"$undefined"},{"id":"28117","book":"로마서","book_name":"로마서","chapter":7,"verse":25,"text":"우리 주 예수 그리스도로 말미암아 하나님께 감사하리로다 그런즉 내 자신이 마음으로는 하나님의 법을 육신으로는 죄의 법을 섬기노라","reference":"로마서 7:25","category":"$undefined"}],"bookSlug":"romans"}]
