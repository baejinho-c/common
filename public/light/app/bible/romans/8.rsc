2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":8,"verses":[{"id":"28118","book":"로마서","book_name":"로마서","chapter":8,"verse":1,"text":"그러므로 이제 그리스도 예수 안에 있는 자에게는 결코 정죄함이 없나니","reference":"로마서 8:1","category":"$undefined"},{"id":"28119","book":"로마서","book_name":"로마서","chapter":8,"verse":2,"text":"이는 그리스도 예수 안에 있는 생명의 성령의 법이 죄와 사망의 법에서 너를 해방하였음이라","reference":"로마서 8:2","category":"$undefined"},{"id":"28120","book":"로마서","book_name":"로마서","chapter":8,"verse":3,"text":"율법이 육신으로 말미암아 연약하여 할 수 없는 그것을 하나님은 하시나니 곧 죄를 인하여 자기 아들을 죄 있는 육신의 모양으로 보내어 육신에 죄를 정하사","reference":"로마서 8:3","category":"$undefined"},{"id":"28121","book":"로마서","book_name":"로마서","chapter":8,"verse":4,"text":"육신을 좇지 않고 그 영을 좇아 행하는 우리에게 율법의 요구를 이루어지게 하려 하심이니라","reference":"로마서 8:4","category":"$undefined"},{"id":"28122","book":"로마서","book_name":"로마서","chapter":8,"verse":5,"text":"육신을 좇는 자는 육신의 일을 영을 좇는 자는 영의 일을 생각하나니","reference":"로마서 8:5","category":"$undefined"},{"id":"28123","book":"로마서","book_name":"로마서","chapter":8,"verse":6,"text":"육신의 생각은 사망이요 영의 생각은 생명과 평안이니라","reference":"로마서 8:6","category":"$undefined"},{"id":"28124","book":"로마서","book_name":"로마서","chapter":8,"verse":7,"text":"육신의 생각은 하나님과 원수가 되나니 이는 하나님의 법에 굴복치 아니할 뿐 아니라 할수도 없음이라","reference":"로마서 8:7","category":"$undefined"},{"id":"28125","book":"로마서","book_name":"로마서","chapter":8,"verse":8,"text":"육신에 있는 자들은 하나님을 기쁘시게 할 수 없느니라","reference":"로마서 8:8","category":"$undefined"},{"id":"28126","book":"로마서","book_name":"로마서","chapter":8,"verse":9,"text":"만일 너희 속에 하나님의 영이 거하시면 너희가 육신에 있지 아니하고 영에 있나니 누구든지 그리스도의 영이 없으면 그리스도의 사람이 아니라","reference":"로마서 8:9","category":"$undefined"},{"id":"28127","book":"로마서","book_name":"로마서","chapter":8,"verse":10,"text":"또 그리스도께서 너희 안에 계시면 몸은 죄로 인하여 죽은 것이나 영은 의를 인하여 산 것이니라","reference":"로마서 8:10","category":"$undefined"},{"id":"28128","book":"로마서","book_name":"로마서","chapter":8,"verse":11,"text":"예수를 죽은 자 가운데서 살리신 이의 영이 너희 안에 거하시면 그리스도 예수를 죽은 자 가운데서 살리신 이가 너희 안에 거하시는 그의 영으로 말미암아 너희 죽을 몸도 살리시리라","reference":"로마서 8:11","category":"$undefined"},{"id":"28129","book":"로마서","book_name":"로마서","chapter":8,"verse":12,"text":"그러므로 형제들아 우리가 빚진 자로되 육신에게 져서 육신대로 살 것이 아니니라","reference":"로마서 8:12","category":"$undefined"},{"id":"28130","book":"로마서","book_name":"로마서","chapter":8,"verse":13,"text":"너희가 육신대로 살면 반드시 죽을 것이로되 영으로써 몸의 행실을 죽이면 살리니","reference":"로마서 8:13","category":"$undefined"},{"id":"28131","book":"로마서","book_name":"로마서","chapter":8,"verse":14,"text":"무릇 하나님의 영으로 인도함을 받는 그들은 곧 하나님의 아들이라","reference":"로마서 8:14","category":"$undefined"},{"id":"28132","book":"로마서","book_name":"로마서","chapter":8,"verse":15,"text":"너희는 다시 무서워하는 종의 영을 받지 아니하였고 양자의 영을 받았으므로 아바 아버지라 부르짖느니라","reference":"로마서 8:15","category":"$undefined"},{"id":"28133","book":"로마서","book_name":"로마서","chapter":8,"verse":16,"text":"성령이 친히 우리 영으로 더불어 우리가 하나님의 자녀인 것을 증거하시나니","reference":"로마서 8:16","category":"$undefined"},{"id":"28134","book":"로마서","book_name":"로마서","chapter":8,"verse":17,"text":"자녀이면 또한 후사 곧 하나님의 후사요 그리스도와 함께 한 후사니 우리가 그와 함께 영광을 받기 위하여 고난도 함께 받아야 될 것이니라","reference":"로마서 8:17","category":"$undefined"},{"id":"28135","book":"로마서","book_name":"로마서","chapter":8,"verse":18,"text":"생각건대 현재의 고난은 장차 우리에게 나타날 영광과 족히 비교할 수 없도다","reference":"로마서 8:18","category":"$undefined"},{"id":"28136","book":"로마서","book_name":"로마서","chapter":8,"verse":19,"text":"피조물의 고대하는 바는 하나님의 아들들의 나타나는 것이니","reference":"로마서 8:19","category":"$undefined"},{"id":"28137","book":"로마서","book_name":"로마서","chapter":8,"verse":20,"text":"피조물이 허무한데 굴복하는 것은 자기 뜻이 아니요 오직 굴복케 하시는 이로 말미암음이라","reference":"로마서 8:20","category":"$undefined"},{"id":"28138","book":"로마서","book_name":"로마서","chapter":8,"verse":21,"text":"그 바라는 것은 피조물도 썩어짐의 종노릇한 데서 해방되어 하나님의 자녀들의 영광의 자유에 이르는 것이니라","reference":"로마서 8:21","category":"$undefined"},{"id":"28139","book":"로마서","book_name":"로마서","chapter":8,"verse":22,"text":"피조물이 다 이제까지 함께 탄식하며 함께 고통하는 것을 우리가 아나니","reference":"로마서 8:22","category":"$undefined"},{"id":"28140","book":"로마서","book_name":"로마서","chapter":8,"verse":23,"text":"이뿐 아니라 또한 우리 곧 성령의 처음 익은 열매를 받은 우리까지도 속으로 탄식하여 양자 될 것 곧 우리 몸의 구속을 기다리느니라","reference":"로마서 8:23","category":"$undefined"},{"id":"28141","book":"로마서","book_name":"로마서","chapter":8,"verse":24,"text":"우리가 소망으로 구원을 얻었으매 보이는 소망이 소망이 아니니 보는 것을 누가 바라리요","reference":"로마서 8:24","category":"$undefined"},{"id":"28142","book":"로마서","book_name":"로마서","chapter":8,"verse":25,"text":"만일 우리가 보지 못하는 것을 바라면 참음으로 기다릴지니라","reference":"로마서 8:25","category":"$undefined"},{"id":"28143","book":"로마서","book_name":"로마서","chapter":8,"verse":26,"text":"이와 같이 성령도 우리 연약함을 도우시나니 우리가 마땅히 빌 바를 알지 못하나 오직 성령이 말할 수 없는 탄식으로 우리를 위하여 친히 간구하시느니라","reference":"로마서 8:26","category":"$undefined"},{"id":"28144","book":"로마서","book_name":"로마서","chapter":8,"verse":27,"text":"마음을 감찰하시는 이가 성령의 생각을 아시나니 이는 성령이 하나님의 뜻대로 성도를 위하여 간구하심이니라","reference":"로마서 8:27","category":"$undefined"},{"id":"28145","book":"로마서","book_name":"로마서","chapter":8,"verse":28,"text":"우리가 알거니와 하나님을 사랑하는 자 곧 그 뜻대로 부르심을 입은 자들에게는 모든 것이 합력하여 선을 이루느니라","reference":"로마서 8:28","category":"$undefined"},{"id":"28146","book":"로마서","book_name":"로마서","chapter":8,"verse":29,"text":"하나님이 미리 아신 자들로 또한 그 아들의 형상을 본받게 하기 위하여 미리 정하셨으니 이는 그로 많은 형제 중에서 맏아들이 되게 하려 하심이니라","reference":"로마서 8:29","category":"$undefined"},{"id":"28147","book":"로마서","book_name":"로마서","chapter":8,"verse":30,"text":"또 미리 정하신 그들을 또한 부르시고 부르신 그들을 또한 의롭 다 하시고 의롭다 하신 그들을 또한 영화롭게 하셨느니라","reference":"로마서 8:30","category":"$undefined"},{"id":"28148","book":"로마서","book_name":"로마서","chapter":8,"verse":31,"text":"그런즉 이 일에 대하여 우리가 무슨 말 하리요 만일 하나님이 우리를 위하시면 누가 우리를 대적하리요","reference":"로마서 8:31","category":"$undefined"},{"id":"28149","book":"로마서","book_name":"로마서","chapter":8,"verse":32,"text":"자기 아들을 아끼지 아니하시고 우리 모든 사람을 위하여 내어 주신 이가 어찌 그 아들과 함께 모든 것을 우리에게 은사로 주지 아니하시겠느뇨","reference":"로마서 8:32","category":"$undefined"},{"id":"28150","book":"로마서","book_name":"로마서","chapter":8,"verse":33,"text":"누가 능히 하나님의 택하신 자들을 송사하리요 의롭다 하신 이는 하나님이시니","reference":"로마서 8:33","category":"$undefined"},{"id":"28151","book":"로마서","book_name":"로마서","chapter":8,"verse":34,"text":"누가 정죄하리요 죽으실 뿐 아니라 다시 살아나신 이는 그리스도 예수시니 그는 하나님 우편에 계신 자요 우리를 위하여 간구하시는 자시니라","reference":"로마서 8:34","category":"$undefined"},{"id":"28152","book":"로마서","book_name":"로마서","chapter":8,"verse":35,"text":"누가 우리를 그리스도의 사랑에서 끊으리요 환난이나 곤고나 핍박이나 기근이나 적신이나 위협이나 칼이랴","reference":"로마서 8:35","category":"$undefined"},{"id":"28153","book":"로마서","book_name":"로마서","chapter":8,"verse":36,"text":"기록된바 우리가 종일 주를 위하여 죽임을 당케 되며 도살할 양같이 여김을 받았나이다 함과 같으니라","reference":"로마서 8:36","category":"$undefined"},{"id":"28154","book":"로마서","book_name":"로마서","chapter":8,"verse":37,"text":"그러나 이 모든 일에 우리를 사랑하시는 이로 말미암아 우리가 넉넉히 이기느니라","reference":"로마서 8:37","category":"$undefined"},{"id":"28155","book":"로마서","book_name":"로마서","chapter":8,"verse":38,"text":"내가 확신하노니 사망이나 생명이나 천사들이나 권세자들이나 현재 일이나 장래 일이나 능력이나","reference":"로마서 8:38","category":"$undefined"},{"id":"28156","book":"로마서","book_name":"로마서","chapter":8,"verse":39,"text":"높음이나 깊음이나 다른 아무 피조물이라도 우리를 우리 주 그리스도 예수 안에 있는 하나님의 사랑에서 끊을 수 없으리라","reference":"로마서 8:39","category":"$undefined"}],"bookSlug":"romans"}]
