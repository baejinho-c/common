2:["$","$L11",null,{"book":{"id":"romans","name":"로마서","chapters":16,"testament":"new"},"chapter":9,"verses":[{"id":"28157","book":"로마서","book_name":"로마서","chapter":9,"verse":1,"text":"내가 그리스도 안에서 참말을 하고 거짓말을 아니하노라 내게 큰 근심이 있는 것과 마음에 그치지 않는 고통이 있는 것을 내 양심이 성령 안에서 나로 더불어 증거하노니","reference":"로마서 9:1","category":"$undefined"},{"id":"28158","book":"로마서","book_name":"로마서","chapter":9,"verse":2,"text":"( 1절과 같음 )","reference":"로마서 9:2","category":"$undefined"},{"id":"28159","book":"로마서","book_name":"로마서","chapter":9,"verse":3,"text":"나의 형제 곧 골육의 친척을 위하여 내 자신이 저주를 받아 그리스도에게서 끊어질지라도 원하는 바로라","reference":"로마서 9:3","category":"$undefined"},{"id":"28160","book":"로마서","book_name":"로마서","chapter":9,"verse":4,"text":"저희는 이스라엘 사람이라 저희에게는 양자 됨과 영광과 언약들과 율법을 세우신 것과 예배와 약속들이 있고","reference":"로마서 9:4","category":"$undefined"},{"id":"28161","book":"로마서","book_name":"로마서","chapter":9,"verse":5,"text":"조상들도 저희 것이요 육신으로하면 그리스도가 저희에게서 나셨으니 저는 만물 위에 계셔 세세에 찬양을 받으실 하나님이시니라 아멘","reference":"로마서 9:5","category":"$undefined"},{"id":"28162","book":"로마서","book_name":"로마서","chapter":9,"verse":6,"text":"또한 하나님의 말씀이 폐하여진것 같지 않도다 이스라엘에게서 난 그들이 다 이스라엘이 아니요","reference":"로마서 9:6","category":"$undefined"},{"id":"28163","book":"로마서","book_name":"로마서","chapter":9,"verse":7,"text":"또한 아브라함의 씨가 다 그 자녀가 아니라 오직 이삭으로부터 난 자라야 네 씨라 칭하리라 하셨으니","reference":"로마서 9:7","category":"$undefined"},{"id":"28164","book":"로마서","book_name":"로마서","chapter":9,"verse":8,"text":"곧 육신의 자녀가 하나님의 자녀가 아니라 오직 약속의 자녀가 씨로 여기심을 받느니라","reference":"로마서 9:8","category":"$undefined"},{"id":"28165","book":"로마서","book_name":"로마서","chapter":9,"verse":9,"text":"약속의 말씀은 이것이라 명년 이때에 내가 이르리니 사라에게 아들이 있으리라 하시니라","reference":"로마서 9:9","category":"$undefined"},{"id":"28166","book":"로마서","book_name":"로마서","chapter":9,"verse":10,"text":"이뿐 아니라 또한 리브가가 우리 조상 이삭 한 사람으로 말미암아 잉태하였는데","reference":"로마서 9:10","category":"$undefined"},{"id":"28167","book":"로마서","book_name":"로마서","chapter":9,"verse":11,"text":"그 자식들이 아직 나지도 아니하고 무슨 선이나 악을 행하지 아니 한 때에 택하심을 따라 되는 하나님의 뜻이 행위로 말미암지 않고 오직 부르시는 이에게로 말미암아 서게 하려 하사","reference":"로마서 9:11","category":"$undefined"},{"id":"28168","book":"로마서","book_name":"로마서","chapter":9,"verse":12,"text":"리브가에게 이르시되 큰 자가 어린 자를 섬기리라 하셨나니","reference":"로마서 9:12","category":"$undefined"},{"id":"28169","book":"로마서","book_name":"로마서","chapter":9,"verse":13,"text":"기록된 바 내가 야곱은 사랑하고 에서는 미워하였다 하심과 같으니라","reference":"로마서 9:13","category":"$undefined"},{"id":"28170","book":"로마서","book_name":"로마서","chapter":9,"verse":14,"text":"그런즉 우리가 무슨 말 하리요 하나님께 불의가 있느뇨 그럴 수 없느니라","reference":"로마서 9:14","category":"$undefined"},{"id":"28171","book":"로마서","book_name":"로마서","chapter":9,"verse":15,"text":"모세에게 이르시되 내가 긍휼히 여길 자를 긍휼히 여기고 불쌍히 여길 자를 불쌍히 여기리라 하셨으니","reference":"로마서 9:15","category":"$undefined"},{"id":"28172","book":"로마서","book_name":"로마서","chapter":9,"verse":16,"text":"그런즉 원하는 자로 말미암음도 아니요 달음박질하는 자로 말미암음도 아니요 오직 긍휼히 여기시는 하나님으로 말미암음이니라","reference":"로마서 9:16","category":"$undefined"},{"id":"28173","book":"로마서","book_name":"로마서","chapter":9,"verse":17,"text":"성경이 바로에게 이르시되 내가 이 일을 위하여 너를 세웠으니 곧 너로 말미암아 내 능력을 보이고 내 이름이 온 땅에 전파되게 하려 함이로라 하셨으니","reference":"로마서 9:17","category":"$undefined"},{"id":"28174","book":"로마서","book_name":"로마서","chapter":9,"verse":18,"text":"그런즉 하나님께서 하고자 하시는 자를 긍휼히 여기시고 하고자 하시는 자를 강퍅케 하시느니라","reference":"로마서 9:18","category":"$undefined"},{"id":"28175","book":"로마서","book_name":"로마서","chapter":9,"verse":19,"text":"혹 네가 내게 말하기를 그러면 하나님이 어찌하여 허물하시느뇨 누가 그 뜻을 대적하느뇨 하리니","reference":"로마서 9:19","category":"$undefined"},{"id":"28176","book":"로마서","book_name":"로마서","chapter":9,"verse":20,"text":"이 사람아 ! 네가 뉘기에 감히 하나님을 힐문하느뇨 지음을 받은 물건이 지은 자에게 어찌 나를 이같이 만들었느냐 말하겠느뇨","reference":"로마서 9:20","category":"$undefined"},{"id":"28177","book":"로마서","book_name":"로마서","chapter":9,"verse":21,"text":"토기장이가 진흙 한 덩이로 하나는 귀히 쓸 그릇을 하나는 천히 쓸 그릇을 만드는 권이 없느냐","reference":"로마서 9:21","category":"$undefined"},{"id":"28178","book":"로마서","book_name":"로마서","chapter":9,"verse":22,"text":"만일 하나님이 그 진노를 보이시고 그 능력을 알게 하고자 하사 멸하기로 준비된 진노의 그릇을 오래 참으심으로 관용하시고","reference":"로마서 9:22","category":"$undefined"},{"id":"28179","book":"로마서","book_name":"로마서","chapter":9,"verse":23,"text":"또한 영광 받기로 예비하신 바 긍휼의 그릇에 대하여 그 영광의 부요함을 알게 하고자 하셨을지라도 무슨 말 하리요","reference":"로마서 9:23","category":"$undefined"},{"id":"28180","book":"로마서","book_name":"로마서","chapter":9,"verse":24,"text":"이 그릇은 우리니 곧 유대인 중에서뿐 아니라 이방인 중에서도 부르신 자니라","reference":"로마서 9:24","category":"$undefined"},{"id":"28181","book":"로마서","book_name":"로마서","chapter":9,"verse":25,"text":"호세아 글에도 이르기를 내가 내 백성 아닌 자를 내 백성이라 사랑치 아니한 자를 사랑한 자라 부르리라","reference":"로마서 9:25","category":"$undefined"},{"id":"28182","book":"로마서","book_name":"로마서","chapter":9,"verse":26,"text":"너희는 내 백성이 아니라 한 그곳에서 저희가 살아계신 하나님의 아들이라 부름을 얻으리라 함과 같으니라","reference":"로마서 9:26","category":"$undefined"},{"id":"28183","book":"로마서","book_name":"로마서","chapter":9,"verse":27,"text":"또 이사야가 이스라엘에 관하여 외치되 이스라엘 뭇 자손의 수가 비록 바다의 모래 같을지라도 남은 자만 구원을 얻으리니","reference":"로마서 9:27","category":"$undefined"},{"id":"28184","book":"로마서","book_name":"로마서","chapter":9,"verse":28,"text":"주께서 땅 위에서 그 말씀을 이루사 필하시고 끝내시리라 하셨느니라","reference":"로마서 9:28","category":"$undefined"},{"id":"28185","book":"로마서","book_name":"로마서","chapter":9,"verse":29,"text":"또한 이사야가 미리 말한 바 만일 만군의 주께서 우리에게 씨를 남겨 두시지 아니하셨더면 우리가 소돔과 같이 되고 고모라와 같았으리로다 함과 같으니라","reference":"로마서 9:29","category":"$undefined"},{"id":"28186","book":"로마서","book_name":"로마서","chapter":9,"verse":30,"text":"그런즉 우리가 무슨 말 하리요 의를 좇지 아니한 이방인들이 의를 얻었으니 곧 믿음에서 난 의요","reference":"로마서 9:30","category":"$undefined"},{"id":"28187","book":"로마서","book_name":"로마서","chapter":9,"verse":31,"text":"의의 법을 좇아간 이스라엘은 법에 이르지 못하였으니","reference":"로마서 9:31","category":"$undefined"},{"id":"28188","book":"로마서","book_name":"로마서","chapter":9,"verse":32,"text":"어찌 그러하뇨 이는 저희가 믿음에 의지하지 않고 행위에 의지함이라 부딪힐 돌에 부딪혔느니라","reference":"로마서 9:32","category":"$undefined"},{"id":"28189","book":"로마서","book_name":"로마서","chapter":9,"verse":33,"text":"기록된바 보라 내가 부딪히는 돌과 거치는 반석을 시온에 두노니 저를 믿는 자는 부끄러움을 당치 아니 하리라 함과 같으니라","reference":"로마서 9:33","category":"$undefined"}],"bookSlug":"romans"}]
