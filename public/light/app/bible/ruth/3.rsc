2:["$","$L11",null,{"book":{"id":"ruth","name":"룻기","chapters":4,"testament":"old"},"chapter":3,"verses":[{"id":"7174","book":"룻기","book_name":"룻기","chapter":3,"verse":1,"text":"룻의 시모 나오미가 그에게 이르되 `내 딸아 ! 내가 너를 위하여 안식할 곳을 구하여 너로 복되게 하여야 하지 않겠느냐 ?","reference":"룻기 3:1","category":"$undefined"},{"id":"7175","book":"룻기","book_name":"룻기","chapter":3,"verse":2,"text":"네가 함께 하던 시녀들을 둔 보아스는 우리의 친족이 아니냐 ? 그가 오늘 밤에 타작 마당에서 보리를 까불리라","reference":"룻기 3:2","category":"$undefined"},{"id":"7176","book":"룻기","book_name":"룻기","chapter":3,"verse":3,"text":"그런즉 너는 목욕하고 기름을 바르고 의복을 입고 타작 마당에 내려가서 그 사람이 먹고 마시기를 다하기까지는 그에게 보이지 말고","reference":"룻기 3:3","category":"$undefined"},{"id":"7177","book":"룻기","book_name":"룻기","chapter":3,"verse":4,"text":"그가 누울 때에 너는 그 눕는 곳을 알았다가 들어 가서 그 발치 이불을 들고 거기 누우라 그가 너의 할일을 네게 고하리라'","reference":"룻기 3:4","category":"$undefined"},{"id":"7178","book":"룻기","book_name":"룻기","chapter":3,"verse":5,"text":"룻이 시모에게 이르되 `어머니의 말씀대로 내가 다 행하리이다 !' 하니라","reference":"룻기 3:5","category":"$undefined"},{"id":"7179","book":"룻기","book_name":"룻기","chapter":3,"verse":6,"text":"그가 타작 마당으로 내려가서 시모의 명대로 다 하니라","reference":"룻기 3:6","category":"$undefined"},{"id":"7180","book":"룻기","book_name":"룻기","chapter":3,"verse":7,"text":"보아스가 먹고 마시고 마음이 즐거워서 가서 노적가리 곁에 눕는지라 룻이 가만히 가서 그 발치 이불을 들고 거기 누웠더라","reference":"룻기 3:7","category":"$undefined"},{"id":"7181","book":"룻기","book_name":"룻기","chapter":3,"verse":8,"text":"밤중에 그 사람이 놀라 몸을 돌이켜 본즉 한 여인이 자기 발치에 누웠는지라","reference":"룻기 3:8","category":"$undefined"},{"id":"7182","book":"룻기","book_name":"룻기","chapter":3,"verse":9,"text":"가로되 `네가 누구뇨 ?' 대답하되 `나는 당신의 시녀 룻이오니 당신의 옷자락으로 시녀를 덮으소서 당신은 우리 기업을 무를 자가 됨이니이다'","reference":"룻기 3:9","category":"$undefined"},{"id":"7183","book":"룻기","book_name":"룻기","chapter":3,"verse":10,"text":"가로되 `내 딸아 ! 여호와께서 네게 복주시기를 원하노라 ! 네가 빈부를 물론하고 연소한 자를 좇지 아니하였으니 너의 베푼 인애가 처음보다 나중이 더하도다","reference":"룻기 3:10","category":"$undefined"},{"id":"7184","book":"룻기","book_name":"룻기","chapter":3,"verse":11,"text":"내 딸아, 두려워말라 ! 내가 네 말대로 네게 다 행하리라 ! 네가 현숙한 여자인 줄 나의 성읍 백성이 다 아느니라","reference":"룻기 3:11","category":"$undefined"},{"id":"7185","book":"룻기","book_name":"룻기","chapter":3,"verse":12,"text":"참으로 나는 네 기업을 무를자나 무를 자가 나보다 더 가까운 친족이 있으니","reference":"룻기 3:12","category":"$undefined"},{"id":"7186","book":"룻기","book_name":"룻기","chapter":3,"verse":13,"text":"이 밤에 여기서 머무르라 아침에 그가 기업 무를 자의 책임을 네게 이행하려 하면 좋으니 그가 그 기업 무를 자의 책임을 행할 것이니라 만일 그가 기업 무를 자의 책임을 네게 이행코자 아니하면 여호와의 사심으로 맹세하노니 내가 기업 무를 자의 책임을 네게 행하리라 아침까지 누울지니라'","reference":"룻기 3:13","category":"$undefined"},{"id":"7187","book":"룻기","book_name":"룻기","chapter":3,"verse":14,"text":"룻이 새벽까지 그 발치에 누웠다가 사람이 피차 알아보기 어려울때에 일어났으니 보아스의 말에 여인이 타작 마당에 들어온 것을 사람이 알지 못하여야 할 것이라 하였음이라","reference":"룻기 3:14","category":"$undefined"},{"id":"7188","book":"룻기","book_name":"룻기","chapter":3,"verse":15,"text":"보아스가 가로되 `네 겉옷을 가져다가 펴서 잡으라` 펴서 잡으니 보리를 여섯번 되어 룻에게 이워주고 성으로 들어가니라","reference":"룻기 3:15","category":"$undefined"},{"id":"7189","book":"룻기","book_name":"룻기","chapter":3,"verse":16,"text":"룻이 시모에게 이르니 그가 가로되 `내 딸아 ! 어떻게 되었느냐 ?' 룻이 그 사람의 자기에게 행한 것을 다 고하고","reference":"룻기 3:16","category":"$undefined"},{"id":"7190","book":"룻기","book_name":"룻기","chapter":3,"verse":17,"text":"가로되 `그가 내게 이 보리를 여섯번 되어 주며 이르기를 빈손으로 네 시모에게 가지말라 하더이다`","reference":"룻기 3:17","category":"$undefined"},{"id":"7191","book":"룻기","book_name":"룻기","chapter":3,"verse":18,"text":"이에 시모가 가로되 `내 딸아 ! 이 사건이 어떻게 되는 것을 알기까지 가만히 앉아 있으라 그 사람이 오늘날 이 일을 성취하기 전에는 쉬지 아니하리라'","reference":"룻기 3:18","category":"$undefined"}],"bookSlug":"ruth"}]
