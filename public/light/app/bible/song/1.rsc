2:["$","$L11",null,{"book":{"id":"song","name":"아가","chapters":8,"testament":"old"},"chapter":1,"verses":[{"id":"17539","book":"아가","book_name":"아가","chapter":1,"verse":1,"text":"솔로몬의 아가라","reference":"아가 1:1","category":"$undefined"},{"id":"17540","book":"아가","book_name":"아가","chapter":1,"verse":2,"text":"내게 입맞추기를 원하니 네 사랑이 포도주보다 나음이로구나","reference":"아가 1:2","category":"$undefined"},{"id":"17541","book":"아가","book_name":"아가","chapter":1,"verse":3,"text":"네 기름이 향기로와 아름답고 네 이름이 쏟은 향기름 같으므로 처녀들이 너를 사랑하는구나","reference":"아가 1:3","category":"$undefined"},{"id":"17542","book":"아가","book_name":"아가","chapter":1,"verse":4,"text":"왕이 나를 침궁으로 이끌어 들이시니 너는 나를 인도하라 우리가 너를 따라 달려가리라 우리가 너를 인하여 기뻐하며 즐거워하니 네 사랑이 포도주에서 지남이라 처녀들이 너를 사랑함이 마땅하니라","reference":"아가 1:4","category":"$undefined"},{"id":"17543","book":"아가","book_name":"아가","chapter":1,"verse":5,"text":"예루살렘 여자들아 ! 내가 비록 검으나 아름다우니 게달의 장막 같을지라도 솔로몬의 휘장과도 같구나","reference":"아가 1:5","category":"$undefined"},{"id":"17544","book":"아가","book_name":"아가","chapter":1,"verse":6,"text":"내가 일광에 쬐어서 거무스름할지라도 흘겨보지 말 것은 내 어미의 아들들이 나를 노하여 포도원지기를 삼았음이라 나의 포도원은 내가 지키지 못하였구나","reference":"아가 1:6","category":"$undefined"},{"id":"17545","book":"아가","book_name":"아가","chapter":1,"verse":7,"text":"내 마음에 사랑하는 자야 ! 너의 양떼 먹이는 곳과 오정에 쉬게 하는 곳을 내게 고하라 내가 네 동무 양떼 곁에서 어찌 얼굴을 가리운 자 같이 되랴","reference":"아가 1:7","category":"$undefined"},{"id":"17546","book":"아가","book_name":"아가","chapter":1,"verse":8,"text":"여인 중에 어여쁜 자야 ! 네가 알지 못하겠거든 양떼의 발자취를 따라 목자들의 장막 곁에서 너의 염소 새끼를 먹일지니라","reference":"아가 1:8","category":"$undefined"},{"id":"17547","book":"아가","book_name":"아가","chapter":1,"verse":9,"text":"내 사랑아 내가 너를 바로의 병거의 준마에 비하였구나","reference":"아가 1:9","category":"$undefined"},{"id":"17548","book":"아가","book_name":"아가","chapter":1,"verse":10,"text":"네 두 뺨은 땋은 머리털로, 네 목은 구슬 꿰미로 아름답구나","reference":"아가 1:10","category":"$undefined"},{"id":"17549","book":"아가","book_name":"아가","chapter":1,"verse":11,"text":"우리가 너를 위하여 금사슬을 은을 박아 만들리라","reference":"아가 1:11","category":"$undefined"},{"id":"17550","book":"아가","book_name":"아가","chapter":1,"verse":12,"text":"왕이 상에 앉았을 때에 나의 나도 기름이 향기를 토하였구나","reference":"아가 1:12","category":"$undefined"},{"id":"17551","book":"아가","book_name":"아가","chapter":1,"verse":13,"text":"나의 사랑하는 자는 내 품 가운데 몰약 향낭이요","reference":"아가 1:13","category":"$undefined"},{"id":"17552","book":"아가","book_name":"아가","chapter":1,"verse":14,"text":"나의 사랑하는 자는 내게 엔게디 포도원의 고벨화 송이로구나","reference":"아가 1:14","category":"$undefined"},{"id":"17553","book":"아가","book_name":"아가","chapter":1,"verse":15,"text":"내 사랑아 ! 너는 어여쁘고, 어여쁘다 네 눈이 비둘기 같구나","reference":"아가 1:15","category":"$undefined"},{"id":"17554","book":"아가","book_name":"아가","chapter":1,"verse":16,"text":"나의 사랑하는 자야 ! 너는 어여쁘고 화창하다 우리의 침상은 푸르고","reference":"아가 1:16","category":"$undefined"},{"id":"17555","book":"아가","book_name":"아가","chapter":1,"verse":17,"text":"우리 집은 백향목 들보, 잣나무 석가래로구나","reference":"아가 1:17","category":"$undefined"}],"bookSlug":"song"}]
