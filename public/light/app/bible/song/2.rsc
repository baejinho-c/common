2:["$","$L11",null,{"book":{"id":"song","name":"아가","chapters":8,"testament":"old"},"chapter":2,"verses":[{"id":"17556","book":"아가","book_name":"아가","chapter":2,"verse":1,"text":"나는 사론의 수선화요 골짜기의 백합화로구나","reference":"아가 2:1","category":"$undefined"},{"id":"17557","book":"아가","book_name":"아가","chapter":2,"verse":2,"text":"여자들 중에 내 사랑은 가시나무 가운데 백합화 같구나","reference":"아가 2:2","category":"$undefined"},{"id":"17558","book":"아가","book_name":"아가","chapter":2,"verse":3,"text":"남자들 중에 나의 사랑하는 자는 수풀 가운데 사과나무 같구나 내가 그 그늘에 앉아서 심히 기뻐하였고 그 실과는 내 입에 달았구나","reference":"아가 2:3","category":"$undefined"},{"id":"17559","book":"아가","book_name":"아가","chapter":2,"verse":4,"text":"그가 나를 인도하여 잔치집에 들어갔으니 그 사랑이 내 위에 기로구나","reference":"아가 2:4","category":"$undefined"},{"id":"17560","book":"아가","book_name":"아가","chapter":2,"verse":5,"text":"너희는 건포도로 내 힘을 돕고 사과로 나를 시원케 하라 내가 사랑하므로 병이 났음이니라","reference":"아가 2:5","category":"$undefined"},{"id":"17561","book":"아가","book_name":"아가","chapter":2,"verse":6,"text":"그가 왼손으로 내 머리에 베게하고 오른손으로 나를 안는구나","reference":"아가 2:6","category":"$undefined"},{"id":"17562","book":"아가","book_name":"아가","chapter":2,"verse":7,"text":"예루살렘 여자들아 내가 노루와 들사슴으로 너희에게 부탁한다 내 사랑이 원하기 전에는 흔들지 말고 깨우지 말지니라","reference":"아가 2:7","category":"$undefined"},{"id":"17563","book":"아가","book_name":"아가","chapter":2,"verse":8,"text":"나의 사랑하는 자의 목소리로구나 보라, 그가 산에서 달리고 작은 산을 빨리 넘어 오는구나","reference":"아가 2:8","category":"$undefined"},{"id":"17564","book":"아가","book_name":"아가","chapter":2,"verse":9,"text":"나의 사랑하는 자는 노루와도 같고 어린 사슴과도 같아서 우리 벽 뒤에 서서 창으로 들여다 보며 창살 틈으로 엿보는구나","reference":"아가 2:9","category":"$undefined"},{"id":"17565","book":"아가","book_name":"아가","chapter":2,"verse":10,"text":"나의 사랑하는 자가 내게 말하여 이르기를 나의 사랑, 나의 어여쁜 자야 ! 일어나서 함께 가자","reference":"아가 2:10","category":"$undefined"},{"id":"17566","book":"아가","book_name":"아가","chapter":2,"verse":11,"text":"겨울도 지나고 비도 그쳤고","reference":"아가 2:11","category":"$undefined"},{"id":"17567","book":"아가","book_name":"아가","chapter":2,"verse":12,"text":"지면에는 꽃이 피고 새의 노래할 때가 이르렀는데 반구의 소리가 우리 땅에 들리는구나","reference":"아가 2:12","category":"$undefined"},{"id":"17568","book":"아가","book_name":"아가","chapter":2,"verse":13,"text":"무화과나무에는 푸른 열매가 익었고 포도나무는 꽃이 피어 향기를 토하는구나 나의 사랑 나의 어여쁜 자야 일어나서 함께 가자","reference":"아가 2:13","category":"$undefined"},{"id":"17569","book":"아가","book_name":"아가","chapter":2,"verse":14,"text":"바위 틈 낭떠러지 은밀한 속에 있는 나의 비둘기야, 나로 네 얼굴을 보게 하라 네 소리를 듣게 하라 네 소리는 부드럽고 네 얼굴은 아름답구나","reference":"아가 2:14","category":"$undefined"},{"id":"17570","book":"아가","book_name":"아가","chapter":2,"verse":15,"text":"우리를 위하여 여우 곧 포도원을 허는 작은 여우를 잡으라 ! 우리의 포도원에 꽃이 피었음이니라","reference":"아가 2:15","category":"$undefined"},{"id":"17571","book":"아가","book_name":"아가","chapter":2,"verse":16,"text":"나의 사랑하는 자는 내게 속하였고, 나는 그에게 속하였구나 그가 백합화 가운데서 양떼를 먹이는구나","reference":"아가 2:16","category":"$undefined"},{"id":"17572","book":"아가","book_name":"아가","chapter":2,"verse":17,"text":"나의 사랑하는 자야 ! 날이 기울고 그림자가 갈 때에 돌아와서 베데르 산에서의 노루와 어린 사슴 같아여라","reference":"아가 2:17","category":"$undefined"}],"bookSlug":"song"}]
