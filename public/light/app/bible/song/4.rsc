2:["$","$L11",null,{"book":{"id":"song","name":"아가","chapters":8,"testament":"old"},"chapter":4,"verses":[{"id":"17584","book":"아가","book_name":"아가","chapter":4,"verse":1,"text":"내 사랑, 너는 어여쁘고도 어여쁘다 너울 속에 있는 네 눈이 비둘기 같고 네 머리털은 길르앗 산 기슭에 누운 무리 염소 같구나","reference":"아가 4:1","category":"$undefined"},{"id":"17585","book":"아가","book_name":"아가","chapter":4,"verse":2,"text":"네 이는 목욕장에서 나온 털 깎인 암양 곧 새끼 없는 것은 하나도 없이 각각 쌍태를 낳은 양 같구나","reference":"아가 4:2","category":"$undefined"},{"id":"17586","book":"아가","book_name":"아가","chapter":4,"verse":3,"text":"네 입술은 홍색 실 같고 네 입은 어여쁘고 너울 속의 네 뺨은 석류 한 쪽 같구나","reference":"아가 4:3","category":"$undefined"},{"id":"17587","book":"아가","book_name":"아가","chapter":4,"verse":4,"text":"네 목은 군기를 두려고 건축한 다윗의 망대 곧, 일천 방패 용사의 모든 방패가 달린 망대같고","reference":"아가 4:4","category":"$undefined"},{"id":"17588","book":"아가","book_name":"아가","chapter":4,"verse":5,"text":"네 두 유방은 백합화 가운데서 꼴을 먹는 쌍태 노루 새끼 같구나","reference":"아가 4:5","category":"$undefined"},{"id":"17589","book":"아가","book_name":"아가","chapter":4,"verse":6,"text":"날이 기울고 그림자가 갈 때에 내가 몰약 산과 유향의 작은 산으로 가리라","reference":"아가 4:6","category":"$undefined"},{"id":"17590","book":"아가","book_name":"아가","chapter":4,"verse":7,"text":"나의 사랑, 너는 순전히 어여뻐서 아무 흠이 없구나","reference":"아가 4:7","category":"$undefined"},{"id":"17591","book":"아가","book_name":"아가","chapter":4,"verse":8,"text":"나의 신부야 ! 너는 레바논에서부터 나와 함께 하고 레바논에서부터 나와 함께 가자 아마나와 스닐과 헤르몬 꼭대기에서 사자 굴과 표범 산에서 내려다보아라","reference":"아가 4:8","category":"$undefined"},{"id":"17592","book":"아가","book_name":"아가","chapter":4,"verse":9,"text":"나의 누이, 나의 신부야 ! 네가 내 마음을 빼앗았구나 네 눈으로 한번 보는 것과 네 목의 구슬 한 꿰미로 내 마음을 빼앗았구나","reference":"아가 4:9","category":"$undefined"},{"id":"17593","book":"아가","book_name":"아가","chapter":4,"verse":10,"text":"나의 누이, 나의 신부야 ! 네 사랑이 어찌 그리 아름다운지 네 사랑은 포도주에 지나고 네 기름의 향기는 각양 향품보다 승하구나","reference":"아가 4:10","category":"$undefined"},{"id":"17594","book":"아가","book_name":"아가","chapter":4,"verse":11,"text":"내 신부야 ! 네 입술에서는 꿀 방울이 떨어지고 네 혀 밑에는 꿀과 젖이 있고 네 의복의 향기는 레바논의 향기 같구나","reference":"아가 4:11","category":"$undefined"},{"id":"17595","book":"아가","book_name":"아가","chapter":4,"verse":12,"text":"나의 누이, 나의 신부는 잠근 동산이요 덮은 우물이요 봉한 샘이로구나","reference":"아가 4:12","category":"$undefined"},{"id":"17596","book":"아가","book_name":"아가","chapter":4,"verse":13,"text":"네게서 나는 것은 석류나무와 각종 아름다운 과수와, 고벨화와, 나도초와,","reference":"아가 4:13","category":"$undefined"},{"id":"17597","book":"아가","book_name":"아가","chapter":4,"verse":14,"text":"나도와, 번홍화와, 창포와, 계수와, 각종 유향목과, 몰약과, 침향과, 모든 귀한 향품이요","reference":"아가 4:14","category":"$undefined"},{"id":"17598","book":"아가","book_name":"아가","chapter":4,"verse":15,"text":"너는 동산의 샘이요, 생수의 우물이요, 레바논에서부터 흐르는 시내로구나","reference":"아가 4:15","category":"$undefined"},{"id":"17599","book":"아가","book_name":"아가","chapter":4,"verse":16,"text":"북풍아, 일어나라 남풍아, 오라 나의 동산에 불어서 향기를 날리라 나의 사랑하는 자가 그 동산에 들어가서 그 아름다운 실과 먹기를 원하노라","reference":"아가 4:16","category":"$undefined"}],"bookSlug":"song"}]
