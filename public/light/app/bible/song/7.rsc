2:["$","$L11",null,{"book":{"id":"song","name":"아가","chapters":8,"testament":"old"},"chapter":7,"verses":[{"id":"17629","book":"아가","book_name":"아가","chapter":7,"verse":1,"text":"귀한 자의 딸아 ! 신을 신은 네 발이 어찌 그리 아름다운가 네 넓적다리는 둥글어서 공교한 장색의 만든 구슬 꿰미 같구나","reference":"아가 7:1","category":"$undefined"},{"id":"17630","book":"아가","book_name":"아가","chapter":7,"verse":2,"text":"배꼽은 섞은 포도주를 가득히 부은 둥근 잔 같고 허리는 백합화로 두른 밀단 같구나","reference":"아가 7:2","category":"$undefined"},{"id":"17631","book":"아가","book_name":"아가","chapter":7,"verse":3,"text":"두 유방은 암사슴의 쌍태 새끼 같고","reference":"아가 7:3","category":"$undefined"},{"id":"17632","book":"아가","book_name":"아가","chapter":7,"verse":4,"text":"목은 상아 망대 같구나 눈은 헤스본 바드랍빔 문 곁의 못 같고 코는 다메섹을 향한 레바논 망대 같구나","reference":"아가 7:4","category":"$undefined"},{"id":"17633","book":"아가","book_name":"아가","chapter":7,"verse":5,"text":"머리는 갈멜산 같고 드리운 머리털은 자주 빛이 있으니 왕이 그 머리카락에 매이었구나","reference":"아가 7:5","category":"$undefined"},{"id":"17634","book":"아가","book_name":"아가","chapter":7,"verse":6,"text":"사랑아, 네가 어찌 그리 아름다운지, 어찌 그리 화창한지 쾌락하게 하는구나","reference":"아가 7:6","category":"$undefined"},{"id":"17635","book":"아가","book_name":"아가","chapter":7,"verse":7,"text":"네 키는 종려나무 같고 네 유방은 그 열매 송이 같구나","reference":"아가 7:7","category":"$undefined"},{"id":"17636","book":"아가","book_name":"아가","chapter":7,"verse":8,"text":"내가 말하기를 종려나무에 올라가서 그 가지를 잡으리라 하였나니 네 유방은 포도송이 같고 네 콧김은 사과 냄새 같고","reference":"아가 7:8","category":"$undefined"},{"id":"17637","book":"아가","book_name":"아가","chapter":7,"verse":9,"text":"네 입은 좋은 포도주 같을 것이니라 이 포도주는 나의 사랑하는 자를 위하여 미끄럽게 흘러 내려서 자는 자의 입으로 움직이게 하느니라","reference":"아가 7:9","category":"$undefined"},{"id":"17638","book":"아가","book_name":"아가","chapter":7,"verse":10,"text":"나는 나의 사랑하는 자에게 속하였구나 그가 나를 사모하는구나","reference":"아가 7:10","category":"$undefined"},{"id":"17639","book":"아가","book_name":"아가","chapter":7,"verse":11,"text":"나의 사랑하는 자야 ! 우리가 함께 들로 가서 동네에서 유숙하자","reference":"아가 7:11","category":"$undefined"},{"id":"17640","book":"아가","book_name":"아가","chapter":7,"verse":12,"text":"우리가 일찌기 일어나서 포도원으로 가서 포도 움이 돋았는지 꽃술이 퍼졌는지 석류꽃이 피었는지 보자 거기서 내가 나의 사랑을 네게 주리라","reference":"아가 7:12","category":"$undefined"},{"id":"17641","book":"아가","book_name":"아가","chapter":7,"verse":13,"text":"합환채가 향기를 토하고 우리의 문 앞에는 각양 귀한 실과가 새것,묵은 것이 구비하였구나 내가 나의 사랑하는 자 너를 위하여 쌓아둔 것이로구나","reference":"아가 7:13","category":"$undefined"}],"bookSlug":"song"}]
