2:["$","$L11",null,{"book":{"id":"zechariah","name":"스가랴","chapters":14,"testament":"old"},"chapter":6,"verses":[{"id":"22949","book":"스가랴","book_name":"스가랴","chapter":6,"verse":1,"text":"내가 또 눈을 들어본즉 네 병거가 두산 사이에서 나왔는데 그 산은 놋산이더라","reference":"스가랴 6:1","category":"$undefined"},{"id":"22950","book":"스가랴","book_name":"스가랴","chapter":6,"verse":2,"text":"첫째 병거는 홍마들이, 둘째 병거는 흑마들이","reference":"스가랴 6:2","category":"$undefined"},{"id":"22951","book":"스가랴","book_name":"스가랴","chapter":6,"verse":3,"text":"세째 병거는 백마들이, 네째 병거는 어룽지고 건장한 말들이 메었는지라","reference":"스가랴 6:3","category":"$undefined"},{"id":"22952","book":"스가랴","book_name":"스가랴","chapter":6,"verse":4,"text":"내가 내게 말하는 천사에게 물어 가로되 내 주여 이것들이 무엇이니이까","reference":"스가랴 6:4","category":"$undefined"},{"id":"22953","book":"스가랴","book_name":"스가랴","chapter":6,"verse":5,"text":"천사가 대답하여 가로되 이는 하늘의 네 바람인데 온 세상의 주앞에 모셨다가 나가는 것이라 하더라","reference":"스가랴 6:5","category":"$undefined"},{"id":"22954","book":"스가랴","book_name":"스가랴","chapter":6,"verse":6,"text":"흑마는 북편 땅으로 나가매 백마의 그 뒤를 따르고 어룽진 말은 남편 땅으로 나가고","reference":"스가랴 6:6","category":"$undefined"},{"id":"22955","book":"스가랴","book_name":"스가랴","chapter":6,"verse":7,"text":"건장한 말은 나가서 땅에 두루 다니고자 하니 그가 이르되 너희는 여기서 나가서 땅에 두루 다니라 하매 곧 땅에 두루 다니더라","reference":"스가랴 6:7","category":"$undefined"},{"id":"22956","book":"스가랴","book_name":"스가랴","chapter":6,"verse":8,"text":"그가 외쳐 내게 일러 가로되 북방으로 나간 자들이 북방에서 내 마음을 시원케 하였느니라 하더라","reference":"스가랴 6:8","category":"$undefined"},{"id":"22957","book":"스가랴","book_name":"스가랴","chapter":6,"verse":9,"text":"여호와의 말씀이 내게 임하여 이르시되","reference":"스가랴 6:9","category":"$undefined"},{"id":"22958","book":"스가랴","book_name":"스가랴","chapter":6,"verse":10,"text":"사로잡힌 자 중 바벨론에서부터 돌아온 헬대와 도비야와 여다야가 스바냐의 아들 요시아의 집에 들었나니 너는 이 날에 그 집에 들어가서 그들에게서 취하되","reference":"스가랴 6:10","category":"$undefined"},{"id":"22959","book":"스가랴","book_name":"스가랴","chapter":6,"verse":11,"text":"은과 금을 취하여 면류관을 만들어 여호사닥의 아들 대제사장 여호수아의 머리에 씌우고","reference":"스가랴 6:11","category":"$undefined"},{"id":"22960","book":"스가랴","book_name":"스가랴","chapter":6,"verse":12,"text":"고하여 이르기를 만군의 여호와께서 말씀하시되 보라 순이라 이름하는 사람이 자기 곳에서 돌아나서 여호와의 전을 건축하리라","reference":"스가랴 6:12","category":"$undefined"},{"id":"22961","book":"스가랴","book_name":"스가랴","chapter":6,"verse":13,"text":"그가 여호와의 전을 건축하고 영광도 얻고 그 위에 앉아서 다스릴 것이요 또 제사장이 자기 위에 있으리니 이 두 사이에 평화와 의논이 있으리라 하셨다 하고","reference":"스가랴 6:13","category":"$undefined"},{"id":"22962","book":"스가랴","book_name":"스가랴","chapter":6,"verse":14,"text":"그 면류관은 헬렘과 도비야와 여다야와 스바냐의 아들 헨을 기념하기 위하여 여호와의 전 안에 두라 하시니라","reference":"스가랴 6:14","category":"$undefined"},{"id":"22963","book":"스가랴","book_name":"스가랴","chapter":6,"verse":15,"text":"먼데 사람이 와서 여호와의 전을 건축하리니 만국의 여호와께서 나를 너희에게 보내신 줄을 너희가 알리라 너희가 만일 너희 하나님 여호와의 말씀을 청종할진대 이같이 되리라","reference":"스가랴 6:15","category":"$undefined"}],"bookSlug":"zechariah"}]
