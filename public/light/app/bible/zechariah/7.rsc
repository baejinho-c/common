2:["$","$L11",null,{"book":{"id":"zechariah","name":"스가랴","chapters":14,"testament":"old"},"chapter":7,"verses":[{"id":"22964","book":"스가랴","book_name":"스가랴","chapter":7,"verse":1,"text":"다리오왕 사년 구월 곧 기슬래월 사일에 여호와의 말씀이 스가랴에게 임하니라","reference":"스가랴 7:1","category":"$undefined"},{"id":"22965","book":"스가랴","book_name":"스가랴","chapter":7,"verse":2,"text":"때에 벧엘 사람이 사레셀과 레겜멜렉과 그 종자를 보내어 여호와께 은혜를 구하고","reference":"스가랴 7:2","category":"$undefined"},{"id":"22966","book":"스가랴","book_name":"스가랴","chapter":7,"verse":3,"text":"만군의 여호와의 전에 있는 제사장들과 선지자들에게 물어 가로되 우리가 여러 해 동안에 행한대로 오월간에 울며 재계하리이까 하매","reference":"스가랴 7:3","category":"$undefined"},{"id":"22967","book":"스가랴","book_name":"스가랴","chapter":7,"verse":4,"text":"만군의 여호와의 말씀이 내게 임하여 이르시되","reference":"스가랴 7:4","category":"$undefined"},{"id":"22968","book":"스가랴","book_name":"스가랴","chapter":7,"verse":5,"text":"온 땅의 백성과 제사장들에게 이르라 너희가 칠십년 동안 오월과 칠월에 금식하고 애통하였거니와 그 금식이 나를 위하여 나를 위하여 한 것이냐 ?","reference":"스가랴 7:5","category":"$undefined"},{"id":"22969","book":"스가랴","book_name":"스가랴","chapter":7,"verse":6,"text":"너희의 먹으며 마심이 전혀 자기을 위하여 먹으며 자기를 위하여 마심이 아니냐","reference":"스가랴 7:6","category":"$undefined"},{"id":"22970","book":"스가랴","book_name":"스가랴","chapter":7,"verse":7,"text":"여호와가 이전 선지자로 외친 말을 너희가 청종할 것이 아니냐 ? 그 때에는 예루살렘과 사면읍에 백성이 거하여 형통하였고 남방과 평원에도 사람이 거하였었느니라","reference":"스가랴 7:7","category":"$undefined"},{"id":"22971","book":"스가랴","book_name":"스가랴","chapter":7,"verse":8,"text":"여호와의 말씀이 스가랴에게 임하여 이르시되","reference":"스가랴 7:8","category":"$undefined"},{"id":"22972","book":"스가랴","book_name":"스가랴","chapter":7,"verse":9,"text":"만군의 여호와가 이미 말하여 이르기를 너희는 진실한 재판을 행하며 피차에 인애와 긍휼을 베풀며","reference":"스가랴 7:9","category":"$undefined"},{"id":"22973","book":"스가랴","book_name":"스가랴","chapter":7,"verse":10,"text":"과부와 고아와 나그네와 궁핍한 자를 압제하지 말며 남을 해하려하여 심중에 도모하지 말라 하였으나","reference":"스가랴 7:10","category":"$undefined"},{"id":"22974","book":"스가랴","book_name":"스가랴","chapter":7,"verse":11,"text":"청종하기를 싫어하며 등으로 향하며 듣지 아니하려고 귀를 막으며","reference":"스가랴 7:11","category":"$undefined"},{"id":"22975","book":"스가랴","book_name":"스가랴","chapter":7,"verse":12,"text":"그 마음을 금강석 같게 하여 율법과 만군의 여호와가 신으로 이전 선지자를 빙자하여 전한 말을 듣지 아니하므로 큰 노가 나 만군의 여호와께로서 나왔도다","reference":"스가랴 7:12","category":"$undefined"},{"id":"22976","book":"스가랴","book_name":"스가랴","chapter":7,"verse":13,"text":"만군의 여호와가 말하였었노라 내가 불러도 그들이 듣지 아니하였은즉 그들이 불러도 내가 듣지 아니하고","reference":"스가랴 7:13","category":"$undefined"},{"id":"22977","book":"스가랴","book_name":"스가랴","chapter":7,"verse":14,"text":"회리바람으로 그들을 그 알지 못하던 모든 열국에 헤치리라한 후로 이 땅이 황무하여 왕래하는 사람이 없었나니 이는 그들이 아름다운 땅으로 황무하게 하였음이니라 하시니라","reference":"스가랴 7:14","category":"$undefined"}],"bookSlug":"zechariah"}]
