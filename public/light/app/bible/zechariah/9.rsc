2:["$","$L11",null,{"book":{"id":"zechariah","name":"스가랴","chapters":14,"testament":"old"},"chapter":9,"verses":[{"id":"23001","book":"스가랴","book_name":"스가랴","chapter":9,"verse":1,"text":"여호와의 말씀의 경고가 하드락 땅에 임하며 다메섹에 머물리니 세상 사람과 이스라엘 모든 지파의 눈이 여호와를 우러러 봄이니라","reference":"스가랴 9:1","category":"$undefined"},{"id":"23002","book":"스가랴","book_name":"스가랴","chapter":9,"verse":2,"text":"그 접경된 하맛에도 임하겠고 두로와 시돈은 넓은 지혜가 있으니 그들에게도 임하리라","reference":"스가랴 9:2","category":"$undefined"},{"id":"23003","book":"스가랴","book_name":"스가랴","chapter":9,"verse":3,"text":"두로는 자기를 위하여 보장을 건축하며 은을 티끌 같이 정금을 거리의 진흙 같이 쌓았은즉","reference":"스가랴 9:3","category":"$undefined"},{"id":"23004","book":"스가랴","book_name":"스가랴","chapter":9,"verse":4,"text":"주께서 그를 쫓아 내시며 그의 바다 권세를 치시리니 그가 불에 삼키울지라","reference":"스가랴 9:4","category":"$undefined"},{"id":"23005","book":"스가랴","book_name":"스가랴","chapter":9,"verse":5,"text":"아스글론이 보고 무서워하며 가사도 심히 아파할 것이며 에그론은 그 소망이 수치가 되므로 역시 그러하리라 가사에는 임금이 끊칠 것이며 아스글론에는 거민이 없을 것이며","reference":"스가랴 9:5","category":"$undefined"},{"id":"23006","book":"스가랴","book_name":"스가랴","chapter":9,"verse":6,"text":"아스돗에는 잡족이 거하리라 내가 블레셋 사람의 교만을 끊고","reference":"스가랴 9:6","category":"$undefined"},{"id":"23007","book":"스가랴","book_name":"스가랴","chapter":9,"verse":7,"text":"그 입에서 그 피를 그 잇사이에서 그 가증한 것을 제하리니 그도 남아서 우리 하나님께로 돌아와서 유다의 한 두목 같이 되겠고 에그론은 여부스 사람 같이 되리라","reference":"스가랴 9:7","category":"$undefined"},{"id":"23008","book":"스가랴","book_name":"스가랴","chapter":9,"verse":8,"text":"내가 내 집을 둘러 진을 쳐서 적군을 막아 거기 왕래하지 못하게 할 것이라 포학한 자가 다시는 그 지경으로 지나지 못하리니 이는 내가 눈으로 친히 봄이니라","reference":"스가랴 9:8","category":"$undefined"},{"id":"23009","book":"스가랴","book_name":"스가랴","chapter":9,"verse":9,"text":"시온의 딸아 크게 기뻐할지어다 ! 예루살렘의 딸아 즐거이 부를지어다 ! 보라 네 왕이 네게 임하나니 그는 공의로우며 구원을 베풀며 겸손하여서 나귀를 타나니 나귀의 작은 것 곧 나귀새끼니라","reference":"스가랴 9:9","category":"$undefined"},{"id":"23010","book":"스가랴","book_name":"스가랴","chapter":9,"verse":10,"text":"내가 에브라임의 병거와 예루살렘의 말을 끊겠고 전쟁하는 활도 끊으리니 그가 이방 사람에게 화평을 전할 것이요 그의 정권은 바다에서 바다까지 이르고 유브라데 강에서 땅 끝까지 이르리라","reference":"스가랴 9:10","category":"$undefined"},{"id":"23011","book":"스가랴","book_name":"스가랴","chapter":9,"verse":11,"text":"또 너로 말할진대 네 언약의 피를 인하여 내가 너의 갇힌 자들을 물 없는 구덩이에서 놓았나니","reference":"스가랴 9:11","category":"$undefined"},{"id":"23012","book":"스가랴","book_name":"스가랴","chapter":9,"verse":12,"text":"소망을 품은 갇혔던 자들아 너희는 보장으로 돌아올지니라 내가 오늘날도 이르노라 내가 배나 네게 갚을 것이라","reference":"스가랴 9:12","category":"$undefined"},{"id":"23013","book":"스가랴","book_name":"스가랴","chapter":9,"verse":13,"text":"내가 유다로 당긴 활을 삼고 에브라임으로 먹인 살을 삼았으니 시온아 내가 네 자식을 격동시켜 헬라 자식을 치게 하며 너로 용사의 칼과 같게 하리라","reference":"스가랴 9:13","category":"$undefined"},{"id":"23014","book":"스가랴","book_name":"스가랴","chapter":9,"verse":14,"text":"여호와께서 그 위에 나타나서 그 살을 번개 같이 쏘아내실 것이며 주 여호와께서 나팔을 불리시며 남방 회리바람을 타고 행하실 것이라","reference":"스가랴 9:14","category":"$undefined"},{"id":"23015","book":"스가랴","book_name":"스가랴","chapter":9,"verse":15,"text":"만군의 여호와께서 그들을 호위하시리니 그들이 원수를 삼키며 물매돌을 밟을 것이며 그들이 피를 마시고 즐거이 부르기를 술취한 것같이 할 것인즉 피가 가득한 동이와도 같고 피 묻은 제단 모퉁이와도 같을 것이라","reference":"스가랴 9:15","category":"$undefined"},{"id":"23016","book":"스가랴","book_name":"스가랴","chapter":9,"verse":16,"text":"이 날에 그들의 하나님 여호와께서 그들을 자기 백성의 양떼 같이 구원하시리니 그들이 면류관의 보석 같이 여호와의 땅에 빛나리로다","reference":"스가랴 9:16","category":"$undefined"},{"id":"23017","book":"스가랴","book_name":"스가랴","chapter":9,"verse":17,"text":"그의 형통함과 그의 아름다움이 어찌 그리 큰지 소년은 곡식으로 강건하며 처녀는 새 포도주로 그러하리로다","reference":"스가랴 9:17","category":"$undefined"}],"bookSlug":"zechariah"}]
