2:["$","$L11",null,{"book":{"id":"zephaniah","name":"스바냐","chapters":3,"testament":"old"},"chapter":1,"verses":[{"id":"22789","book":"스바냐","book_name":"스바냐","chapter":1,"verse":1,"text":"아몬의 아들 유다 왕 요시아의 시대에 스바냐에게 임한 여호와의 말씀이라 스바냐는 히스기야의 현손이요 아마랴의 증손이요 그다랴의 손자요 구시의 아들이었더라","reference":"스바냐 1:1","category":"$undefined"},{"id":"22790","book":"스바냐","book_name":"스바냐","chapter":1,"verse":2,"text":"여호와께서 가라사대 내가 지면에서 모든 것을 진멸하리라","reference":"스바냐 1:2","category":"$undefined"},{"id":"22791","book":"스바냐","book_name":"스바냐","chapter":1,"verse":3,"text":"내가 사람과 짐승을 진멸하고 공중의 새와 바다의 고기와 거치게 하는것과 악인들을 아울러 진멸할 것이라 내가 사람을 지면에서 멸절하리라 나 여호와의 말이니라","reference":"스바냐 1:3","category":"$undefined"},{"id":"22792","book":"스바냐","book_name":"스바냐","chapter":1,"verse":4,"text":"내가 유다와 예루살렘 모든 거민 위에 손을 펴서 바알의 남아 있는 것을 그곳에서 멸절하며 그마림이란 이름과 및 그 제사장들을 아울러 멸절하며","reference":"스바냐 1:4","category":"$undefined"},{"id":"22793","book":"스바냐","book_name":"스바냐","chapter":1,"verse":5,"text":"무릇 지붕에서 하늘의 일월성신에게 경배하며 여호와께 맹세하면서 말감을 가리켜 맹세하는 자와","reference":"스바냐 1:5","category":"$undefined"},{"id":"22794","book":"스바냐","book_name":"스바냐","chapter":1,"verse":6,"text":"여호와를 배반하고 좇지 아니한 자와 여호와를 찾지도 아니하며 구하지도 아니한 자를 멸절하리라","reference":"스바냐 1:6","category":"$undefined"},{"id":"22795","book":"스바냐","book_name":"스바냐","chapter":1,"verse":7,"text":"주 여호와 앞에서 잠잠할지어다 ! 이는 여호와의 날이 가까왔으므로 여호와가 희생을 준비하고 그 청할 자를 구별하였음이니라","reference":"스바냐 1:7","category":"$undefined"},{"id":"22796","book":"스바냐","book_name":"스바냐","chapter":1,"verse":8,"text":"여호와의 희생의 날에 내가 방백들과 왕자들과 이방의 의복을 입은 자들을 벌할 것이며","reference":"스바냐 1:8","category":"$undefined"},{"id":"22797","book":"스바냐","book_name":"스바냐","chapter":1,"verse":9,"text":"그 날에 문턱을 뛰어 넘어서 강포와 궤휼로 자기 주인의 집에 채운 자들을 내가 벌하리라","reference":"스바냐 1:9","category":"$undefined"},{"id":"22798","book":"스바냐","book_name":"스바냐","chapter":1,"verse":10,"text":"나 여호와가 말하노라 그 날에 어문에서는 곡성이,제 이 구역에서는 부르짖은 소리가 일어나리라","reference":"스바냐 1:10","category":"$undefined"},{"id":"22799","book":"스바냐","book_name":"스바냐","chapter":1,"verse":11,"text":"막데스 거민들아 너희는 애곡하라 가나안 백성이 다 패망하고 은을 수운하는 자가 끊어졌음이니라","reference":"스바냐 1:11","category":"$undefined"},{"id":"22800","book":"스바냐","book_name":"스바냐","chapter":1,"verse":12,"text":"그 때에 내가 등불로 예루살렘에 두루 찾아 무릇 찌끼 같이 가라 앉아서 심중에 스스로 이르기를 여호와께서는 복도 내리지 아니하시며 화도 내리지 아니하시리라 하는 자를 벌하리니","reference":"스바냐 1:12","category":"$undefined"},{"id":"22801","book":"스바냐","book_name":"스바냐","chapter":1,"verse":13,"text":"그들의 재물이 노략되며 그들의 집이 황무할 것이라 그들이 집을 건축하나 거기 거하지 못하며 포도원을 심으나 그 포도주를 마시지 못하리라","reference":"스바냐 1:13","category":"$undefined"},{"id":"22802","book":"스바냐","book_name":"스바냐","chapter":1,"verse":14,"text":"여호와의 큰 날이 가깝도다 가깝고도 심히 빠르도다 여호와의 날의 소리로다 용사가 거기서 심히 애곡하는도다","reference":"스바냐 1:14","category":"$undefined"},{"id":"22803","book":"스바냐","book_name":"스바냐","chapter":1,"verse":15,"text":"그 날은 분노의 날이요, 환난과 고통의 날이요, 황무와 패괴의 날이요, 캄캄하고 어두운 날이요, 구름과 흑암의 날이요,","reference":"스바냐 1:15","category":"$undefined"},{"id":"22804","book":"스바냐","book_name":"스바냐","chapter":1,"verse":16,"text":"나팔을 불어 경고하며 견고한 성읍을 치며 높은 망대를 치는 날이로다","reference":"스바냐 1:16","category":"$undefined"},{"id":"22805","book":"스바냐","book_name":"스바냐","chapter":1,"verse":17,"text":"내가 사람들에게 고난을 내려 소경 같이 행하게 하리니 이는 그들이 나 여호와께 범죄하였음이라 또 그들의 피는 흘리워서 티끌같이 되며 그들의 살은 분토 같이 될지라","reference":"스바냐 1:17","category":"$undefined"},{"id":"22806","book":"스바냐","book_name":"스바냐","chapter":1,"verse":18,"text":"그들의 은과 금이 여호와의 분노의 날에 능히 그들을 건지지 못할 것이며 이 온 땅이 여호와의 질투의 불에 삼키우리니 이는 여호와가 이 땅 모든 거민을 놀라게 멸절할 것임이니라","reference":"스바냐 1:18","category":"$undefined"}],"bookSlug":"zephaniah"}]
