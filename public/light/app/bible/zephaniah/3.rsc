2:["$","$L11",null,{"book":{"id":"zephaniah","name":"스바냐","chapters":3,"testament":"old"},"chapter":3,"verses":[{"id":"22822","book":"스바냐","book_name":"스바냐","chapter":3,"verse":1,"text":"패역하고 더러운 곳, 포학한 그 성읍이 화 있을진저 !","reference":"스바냐 3:1","category":"$undefined"},{"id":"22823","book":"스바냐","book_name":"스바냐","chapter":3,"verse":2,"text":"그가 명령을 듣지 아니하며 교훈을 받지 아니하며 여호와를 의뢰하지 아니하며 자기 하나님에게 가까이 나아가지 아니하였도다","reference":"스바냐 3:2","category":"$undefined"},{"id":"22824","book":"스바냐","book_name":"스바냐","chapter":3,"verse":3,"text":"그 가운데 방백들은 부르짖는 사자요 그 재판장들은 이튿날까지 남겨 두는 것이 없는 저녁 이리요","reference":"스바냐 3:3","category":"$undefined"},{"id":"22825","book":"스바냐","book_name":"스바냐","chapter":3,"verse":4,"text":"그 선지자들은 위인이 경솔하고 간사한 자요 그 제사장들은 성소를 더럽히고 율법을 범하였도다","reference":"스바냐 3:4","category":"$undefined"},{"id":"22826","book":"스바냐","book_name":"스바냐","chapter":3,"verse":5,"text":"그 중에 거하신 여호와는 의로우사 불의를 행치 아니하시고 아침마다 간단 없이 자기의 공의를 나타내시거늘 불의한 자는 수치를 알지 못하는도다","reference":"스바냐 3:5","category":"$undefined"},{"id":"22827","book":"스바냐","book_name":"스바냐","chapter":3,"verse":6,"text":"내가 열국을 끊어 버렸으므로 그 망대가 황무하였고 내가 그 거리를 비게 하여 지나는 자가 없게 하였으므로 그 모든 성읍이 황폐되며 사람이 없으며 거할 자가 없게 되었느니라","reference":"스바냐 3:6","category":"$undefined"},{"id":"22828","book":"스바냐","book_name":"스바냐","chapter":3,"verse":7,"text":"내가 이르기를 너는 오직 나를 경외하고 교훈을 받으라 ! 그리하면 내가 형벌을 내리기로 정하기는 하였거니와 너의 거처가 끊어지지 아니하리라 하였으나 그들이 부지런히 그 모든 행위를 더럽게 하였느니라","reference":"스바냐 3:7","category":"$undefined"},{"id":"22829","book":"스바냐","book_name":"스바냐","chapter":3,"verse":8,"text":"나 여호와가 말하노라 그러므로 내가 일어나 벌할 날까지 너희는 나를 기다리라 내가 뜻을 정하고 나의 분한과 모든 진노를 쏟으려고 나라들을 소집하며 열국을 모으리라 온 땅이 나의 질투의 불에 소멸되리라","reference":"스바냐 3:8","category":"$undefined"},{"id":"22830","book":"스바냐","book_name":"스바냐","chapter":3,"verse":9,"text":"그 때에 내가 열방의 입술을 깨끗케 하여 그들로 다 나 여호와의 이름을 부르며 일심으로 섬기게 하리니","reference":"스바냐 3:9","category":"$undefined"},{"id":"22831","book":"스바냐","book_name":"스바냐","chapter":3,"verse":10,"text":"내게 구하는 백성들 곧 내가 흩은 자의 딸이 구스 하수 건너편에서부터 예물을 가지고 와서 내게 드릴지라","reference":"스바냐 3:10","category":"$undefined"},{"id":"22832","book":"스바냐","book_name":"스바냐","chapter":3,"verse":11,"text":"그 날에 네가 내게 범죄한 모든 행위를 인하여 수치를 당하지 아니할 것은 그 때에 내가 너의 중에서 교만하여 자랑하는 자를 제하여 너로 나의 성산에서 다시는 교만하지 않게할 것임이니라","reference":"스바냐 3:11","category":"$undefined"},{"id":"22833","book":"스바냐","book_name":"스바냐","chapter":3,"verse":12,"text":"내가 곤고하고 가난한 백성을 너의 중에 남겨 두리니 그들이 여호와의 이름을 의탁하여 보호를 받을지라","reference":"스바냐 3:12","category":"$undefined"},{"id":"22834","book":"스바냐","book_name":"스바냐","chapter":3,"verse":13,"text":"이스라엘의 남은 자는 악을 행치 아니하며 거짓을 말하지 아니하며 입에 궤휼한 혀가 없으며 누우나 놀라게 할 자가 없으리라","reference":"스바냐 3:13","category":"$undefined"},{"id":"22835","book":"스바냐","book_name":"스바냐","chapter":3,"verse":14,"text":"시온의 딸아 노래할지어다 ! 이스라엘아 기쁘게 부를지어다 ! 예루살렘 딸아 전심으로 기뻐하며 즐거워할지어다 !","reference":"스바냐 3:14","category":"$undefined"},{"id":"22836","book":"스바냐","book_name":"스바냐","chapter":3,"verse":15,"text":"여호와가 너의 형벌을 제하였고 너의 원수를 쫓아 내었으며 이스라엘 왕 여호와가 너의 중에 있으니 네가 다시는 화를 당할까 두려워하지 아니할 것이라","reference":"스바냐 3:15","category":"$undefined"},{"id":"22837","book":"스바냐","book_name":"스바냐","chapter":3,"verse":16,"text":"그 날에 사람이 예루살렘에게 이르기를 두려워하지 말라 ! 시온아 네 손을 늘어뜨리지 말라 !","reference":"스바냐 3:16","category":"$undefined"},{"id":"22838","book":"스바냐","book_name":"스바냐","chapter":3,"verse":17,"text":"너의 하나님 여호와가 너의 가운데 계시니 그는 구원을 베푸실 전능자시라 그가 너로 인하여 기쁨을 이기지 못하여 하시며 너를 잠잠히 사랑하시며 너로 인하여 즐거이 부르며 기뻐하시리라 하리라","reference":"스바냐 3:17","category":"$undefined"},{"id":"22839","book":"스바냐","book_name":"스바냐","chapter":3,"verse":18,"text":"내가 대회로 인하여 근심하는 자를 모으리니 그들은 네게 속한 자라 너의 치욕이 그들에게 무거운 짐이 되었느니라","reference":"스바냐 3:18","category":"$undefined"},{"id":"22840","book":"스바냐","book_name":"스바냐","chapter":3,"verse":19,"text":"그 때에 내가 너를 괴롭게 하는 자를 다 벌하고 저는 자를 구원하며 쫓겨난 자를 모으며 온 세상에서 수욕 받는 자로 칭찬과 명성을 얻게 하리라","reference":"스바냐 3:19","category":"$undefined"},{"id":"22841","book":"스바냐","book_name":"스바냐","chapter":3,"verse":20,"text":"내가 그 때에 너희를 이끌고 그 때에 너희를 모을찌라 내가 너희 목전에서 너희 사로잡힘을 돌이킬 때에 너희로 천하 만민 중에서 명성과 칭찬을 얻게 하리라 나 여호와의 말이니라","reference":"스바냐 3:20","category":"$undefined"}],"bookSlug":"zephaniah"}]
