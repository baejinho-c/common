0:["co5kaRGqnQVOC0UYreFFc",[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],["",{"children":["__PAGE__",{},[["$L1",[["$","$L2",null,{}],[["$","section",null,{"id":"about","className":"border-t border-[#e5e7eb] bg-white px-4 py-16 md:py-20","children":["$","div",null,{"className":"container mx-auto max-w-3xl","children":[["$","h2",null,{"className":"font-display mb-6 text-2xl font-bold text-[#374151] md:text-3xl","children":"빛 QT 나눔 플랫폼 소개"}],["$","p",null,{"className":"mb-4 leading-relaxed text-[#4b5563]","children":[["$","strong",null,{"className":"text-[#374151]","children":"빛"}],"은 매일의 ",["$","strong",null,{"className":"text-[#374151]","children":"큐티"}],"와"," ",["$","strong",null,{"className":"text-[#374151]","children":"기도"}],"를 나누는"," ",["$","strong",null,{"className":"text-[#374151]","children":"기독교 커뮤니티"}],"입니다. 바쁜 일상 속에서도 말씀 묵상과 기도 제목을 기록하고, 성도들과 진솔한 간증을 나누며 신앙 안에서 함께 성장할 수 있는 온라인 공간을 제공합니다."]}],["$","p",null,{"className":"mb-4 leading-relaxed text-[#4b5563]","children":"66권 성경 전체를 온라인에서 읽고 검색할 수 있으며, 인기 구절과 최근 QT 나눔을 통해 다른 성도들의 묵상에서 영감을 받을 수 있습니다. 교회 찾기로 지역 공동체와 연결하고, AI 챗봇으로 성경 질문에 대한 참고 답변을 받아볼 수도 있습니다."}],["$","p",null,{"className":"leading-relaxed text-[#4b5563]","children":["성경 연구와 묵상에 도움이 되는 자료는"," ",["$","a",null,{"href":"https://www.bible.com/ko","className":"text-[#2563eb] hover:underline","rel":"noopener noreferrer","target":"_blank","children":"YouVersion 성경 앱"}],"과"," ",["$","a",null,{"href":"https://www.bskorea.or.kr/","className":"text-[#2563eb] hover:underline","rel":"noopener noreferrer","target":"_blank","children":"대한성서공회"}],"를 참고하세요. 빛은"," ",["$","a",null,{"href":"https://restyart.com/","className":"text-[#2563eb] hover:underline","rel":"noopener noreferrer","target":"_blank","children":"Restyart"}],"가 운영하는 신앙·커뮤니티 서비스입니다."]}]]}]}],["$","section",null,{"id":"faq","className":"bg-[#f9fafb] px-4 py-16 md:py-20","children":["$","div",null,{"className":"container mx-auto max-w-3xl","children":[["$","h2",null,{"className":"font-display mb-10 text-center text-2xl font-bold text-[#374151] md:text-3xl","children":"자주 묻는 질문"}],["$","dl",null,{"className":"space-y-6","children":[["$","div","빛은 어떤 플랫폼인가요?",{"className":"rounded-xl border border-[#e5e7eb] bg-white p-6 shadow-sm","children":[["$","dt",null,{"className":"font-display font-bold text-[#374151]","children":"빛은 어떤 플랫폼인가요?"}],["$","dd",null,{"className":"mt-2 text-sm leading-relaxed text-[#4b5563]","children":"빛은 매일 큐티(말씀 묵상), 기도 제목, 간증을 나누는 기독교 커뮤니티입니다. 성경 검색·교회 찾기·QT 작성으로 신앙 생활을 기록하고 공동체와 함께 성장할 수 있습니다."}]]}],["$","div","회원가입 없이 이용할 수 있나요?",{"className":"rounded-xl border border-[#e5e7eb] bg-white p-6 shadow-sm","children":[["$","dt",null,{"className":"font-display font-bold text-[#374151]","children":"회원가입 없이 이용할 수 있나요?"}],["$","dd",null,{"className":"mt-2 text-sm leading-relaxed text-[#4b5563]","children":"익명으로 QT와 기도를 작성할 수 있으며, 성경 검색·인기 구절·교회 찾기는 로그인 없이 이용 가능합니다. 즐겨찾기·프로필 관리는 계정이 필요합니다."}]]}],["$","div","어떤 성경 번역본을 사용하나요?",{"className":"rounded-xl border border-[#e5e7eb] bg-white p-6 shadow-sm","children":[["$","dt",null,{"className":"font-display font-bold text-[#374151]","children":"어떤 성경 번역본을 사용하나요?"}],["$","dd",null,{"className":"mt-2 text-sm leading-relaxed text-[#4b5563]","children":"개역개정 등 한국어 성경 본문을 제공하며, 구절·장·키워드 검색으로 원하는 말씀을 빠르게 찾을 수 있습니다."}]]}],["$","div","교회 찾기 기능은 무엇인가요?",{"className":"rounded-xl border border-[#e5e7eb] bg-white p-6 shadow-sm","children":[["$","dt",null,{"className":"font-display font-bold text-[#374151]","children":"교회 찾기 기능은 무엇인가요?"}],["$","dd",null,{"className":"mt-2 text-sm leading-relaxed text-[#4b5563]","children":"전국 교회 정보를 지역·이름으로 검색하고, 함께 예배할 공동체를 찾을 수 있습니다. 새 교회 등록도 지원합니다."}]]}]]}],["$","p",null,{"className":"mt-8 text-center text-sm text-[#6b7280]","children":[["$","$L3",null,{"href":"/bible/search","className":"text-[#2563eb] hover:underline","children":"성경 검색하기"}]," · ",["$","$L3",null,{"href":"/churches","className":"text-[#2563eb] hover:underline","children":"교회 찾기"}]," · ",["$","$L3