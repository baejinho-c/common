0:["co5kaRGqnQVOC0UYreFFc",[[["",{"children":["post",{"children":[["id","1","d"],{"children":["__PAGE__?{\"id\":\"1\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["post",{"children":[["id","1","d"],{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"container mx-auto px-4 py-8","children":["$","$L2",null,{"post":{"id":"1","title":"오늘의 QT 나눔 - 시편 23편","content":"오늘 시편 23편을 묵상하면서 하나님께서 나의 목자가 되어주신다는 말씀에 큰 위로를 받았습니다. 특히 '내게 부족함이 없으리로다'라는 구절이 마음에 깊이 와닿았어요.\n\n요즘 여러 어려움들로 인해 마음이 힘들었는데, 하나님께서 모든 것을 채워주시고 인도해주신다는 확신을 갖게 되었습니다. 여러분도 이 말씀으로 위로받으시길 바랍니다.","author":{"name":"김믿음"},"createdAt":"2026-07-06T00:31:50.116Z","updatedAt":"2026-07-06T00:31:50.116Z","tags":["QT","시편","위로","목자"],"likeCount":24,"commentCount":2,"isLiked":false,"category":"qt"},"comments":[{"id":"1","content":"정말 좋은 나눔이네요! 저도 시편 23편을 다시 읽어봐야겠어요.","author":{"name":"박소망","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-06T01:31:50.116Z","likeCount":0,"isLiked":false},{"id":"2","content":"하나님의 인도하심을 믿고 나아가겠습니다. 감사합니다!","author":{"name":"이평안","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-06T02:01:50.116Z","likeCount":0,"isLiked":false}]}]}],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","post","children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","post","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/light/_next/static/css/660510d62a9c633e.css","precedence":"next","crossOrigin":"$undefined"}],["$"