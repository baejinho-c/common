0:["co5kaRGqnQVOC0UYreFFc",[[["",{"children":["post",{"children":[["id","3","d"],{"children":["__PAGE__?{\"id\":\"3\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["post",{"children":[["id","3","d"],{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"container mx-auto px-4 py-8","children":["$","$L2",null,{"post":{"id":"3","title":"하나님의 놀라운 응답을 경험했습니다!","content":"지난달에 올린 기도제목에 대해 감사 간증을 나누고 싶습니다.\n\n취업 준비로 힘들어하며 기도 부탁을 드렸었는데, 정말 하나님께서 놀라운 방법으로 응답해 주셨습니다! 포기하려던 순간에 예상치 못한 곳에서 연락이 와서 면접을 보게 되었고, 결국 합격 통보를 받았습니다.\n\n정말 하나님의 때가 있다는 것을 깨달았고, 끝까지 포기하지 않고 기도해주신 모든 분들께 감사드립니다. 하나님께서 살아계시고 우리의 기도를 들으신다는 것을 다시 한번 확신하게 되었습니다.\n\n앞으로도 하나님께 영광 돌리는 삶을 살겠습니다!","author":{"name":"정감사"},"createdAt":"2026-07-05T20:31:50.138Z","updatedAt":"2026-07-05T20:31:50.138Z","tags":["간증","취업","응답","감사","하나님의때"],"likeCount":42,"commentCount":4,"isLiked":false,"category":"testimony"},"comments":[{"id":"1","content":"정말 감사한 간증이네요! 하나님께 영광 돌립니다!","author":{"name":"김할렐루야","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-05T21:31:50.138Z","likeCount":0,"isLiked":false},{"id":"2","content":"하나님의 선하신 계획을 보여주시는 간증입니다. 축하드려요!","author":{"name":"박아멘","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-05T22:31:50.138Z","likeCount":0,"isLiked":false},{"id":"3","content":"저도 취업 준비 중인데 큰 힘이 됩니다. 감사합니다!","author":{"name":"이축복","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-05T23:31:50.138Z","likeCount":0,"isLiked":false},{"id":"4","content":"하나님의 때를 기다리는 것의 중요성을 다시 깨닫게 됩니다.","author":{"name":"최은혜","avatar":"/placeholder-user.jpg"},"createdAt":"2026-07-06T00:31:50.138Z","likeCount":0,"isLiked":false}]}]}],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","post","children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[n