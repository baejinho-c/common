{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/competitors/layout,_N_T_/(app)/competitors/page,_N_T_/competitors"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/competitors/__PAGE__",
    "/!KGFwcCk/competitors",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}