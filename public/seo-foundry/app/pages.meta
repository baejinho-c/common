{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/pages/layout,_N_T_/(app)/pages/page,_N_T_/pages"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/pages/__PAGE__",
    "/!KGFwcCk/pages",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}