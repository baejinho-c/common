{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/destination/layout,_N_T_/destination/[id]/layout,_N_T_/destination/[id]/page,_N_T_/destination/jeju"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/destination/$d$id/__PAGE__",
    "/destination/$d$id",
    "/destination",
    "/_index",
    "/_head"
  ]
}