0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"clever-crow","sampleStory":{"id":"clever-crow","level":4,"cover":"/covers/clever-crow.png","author":"예준","authorEmoji":"🐦‍⬛","title":"The Clever Crow and the Jar","koreanTitle":"영리한 까마귀와 항아리","summary":"목마른 까마귀가 머리를 써서 깊은 항아리 속 물을 마시는 방법을 찾아내요.","tags":["지혜","문제해결","동물"],"likes":221,"reads":1870,"recordings":33,"publishedAt":"2026-06-12","community":true,"keyWords":[{"word":"clever","meaning":"영리한"},{"word":"jar","meaning":"항아리"},{"word":"pebble","meaning":"조약돌"},{"word":"rise","meaning":"올라오다"}],"scenes":[{"english":"A thirsty crow found a tall jar with a little water inside.","korean":"목마른 까마귀가 물이 조금 든 키 큰 항아리를 발견했어요.","imagePrompt":"a crow looking into a tall jar with a little water","image":"/scenes/clever-crow-1.png"},{"english":"The water was too low, and his beak could not reach it.","korean":"물이 너무 낮아서 부리가 닿지 않았어요.","imagePrompt":"a crow trying to reach water deep in a jar","image":"/scenes/clever-crow-2.png"},{"english":"Then the clever crow dropped pebbles into the jar, one by one.","korean":"그러자 영리한 까마귀가 조약돌을 하나씩 항아리에 넣었어요.","imagePrompt":"a crow dropping pebbles into a jar","image":"/scenes/clever-crow-3.png"},{"english":"Slowly the water rose, and the crow drank happily.","korean":"물이 천천히 올라왔고, 까마귀는 기쁘게 물을 마셨어요.","imagePrompt":"a happy crow drinking from a jar full of water and pebbles","image":"/scenes/clever-crow-4.png"}],"quiz":[{"type":"multiple_choice","question":"How does the crow get the water?","options":["He tips the jar","He drops pebbles in","He breaks the jar","He waits for rain"],"answerIndex":1,"explanation":"He drops pebbles in so the water rises."},{"type":"vocabulary","question":"What does 'clever' mean?","options":["영리한","게으른","슬픈","느린"],"answerIndex":0,"explanation":"'clever'는 '영리한'이에요."}]}}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0gri1gur.tmm7.js","async":true}]],["$","$L3",null