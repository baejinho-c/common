0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"clockwork-robot","sampleStory":{"id":"clockwork-robot","level":5,"cover":"/covers/clockwork-robot.png","author":"서윤","authorEmoji":"🤖","title":"Tik the Clockwork Friend","koreanTitle":"태엽 친구 틱","summary":"오래된 태엽 로봇 틱이 한 아이의 진심 어린 보살핌으로 다시 움직이며 우정을 키워요.","tags":["우정","상상력","마음"],"likes":243,"reads":1990,"recordings":41,"publishedAt":"2026-06-17","community":true,"keyWords":[{"word":"robot","meaning":"로봇"},{"word":"gear","meaning":"톱니바퀴"},{"word":"repair","meaning":"고치다"},{"word":"friendship","meaning":"우정"}],"scenes":[{"english":"In a dusty workshop, a child found an old clockwork robot.","korean":"먼지 쌓인 작업실에서, 한 아이가 오래된 태엽 로봇을 발견했어요.","imagePrompt":"a child finding an old copper clockwork robot in a workshop","image":"/scenes/clockwork-robot-1.png"},{"english":"Its gears were still, and it had not moved for many years.","korean":"톱니바퀴는 멈춰 있었고, 오랫동안 움직이지 않았어요.","imagePrompt":"a still copper robot covered in dust","image":"/scenes/clockwork-robot-2.png"},{"english":"Patiently, the child cleaned and repaired each tiny gear.","korean":"아이는 참을성 있게 작은 톱니바퀴를 하나하나 닦고 고쳤어요.","imagePrompt":"a child carefully repairing gears of a small robot","image":"/scenes/clockwork-robot-3.png"},{"english":"Tik blinked, smiled, and a new friendship began to tick.","korean":"틱이 눈을 깜빡이고 미소 지으며, 새로운 우정이 똑딱이기 시작했어요.","imagePrompt":"a happy copper robot smiling next to a child","image":"/scenes/clockwork-robot-4.png"}],"quiz":[{"type":"vocabulary","question":"What does 'repair' mean?","options":["고치다","버리다","숨기다","팔다"],"answerIndex":0,"explanation":"'repair'는 '고치다'예요."},{"type":"multiple_choice","question":"How does the child fix the robot?","options":["Quickly and roughly","Patiently, one gear at a time","By shaking it","It fixes itself"],"answerIndex":1,"explanation":"The child patiently repairs each tiny gear."}]}}]}],[["$","script","script-0",{"src":"/_