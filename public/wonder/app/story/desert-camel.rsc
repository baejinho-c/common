12:["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L1b",null,{"id":"desert-camel","sampleStory":{"id":"desert-camel","level":3,"cover":"/covers/desert-camel.png","author":"WonderTale","authorEmoji":"🐫","title":"Cami Crosses the Desert","koreanTitle":"사막을 건너는 카미","summary":"어린 낙타 카미가 포기하지 않고 끝까지 걸어 오아시스에 닿아요.","tags":["인내","모험","희망"],"likes":109,"reads":940,"recordings":16,"publishedAt":"2026-04-08","keyWords":[{"word":"desert","meaning":"사막"},{"word":"walk","meaning":"걷다"},{"word":"tired","meaning":"지친"},{"word":"oasis","meaning":"오아시스"}],"scenes":[{"english":"Cami the young camel walks across the hot golden desert.","korean":"어린 낙타 카미가 뜨거운 황��빛 사막을 걸어가요.","imagePrompt":"a young camel walking across golden desert dunes","image":"/scenes/desert-camel-1.png"},{"english":"The sun is high and Cami feels very tired.","korean":"해가 높이 떴고 카미는 무척 지쳤어요.","imagePrompt":"a tired camel in the desert under a bright sun","image":"/scenes/desert-camel-2.png"},{"english":"But Cami keeps walking, one slow step at a time.","korean":"하지만 카미는 한 걸음씩 천천히 계속 걸어요.","imagePrompt":"a determined camel walking over a sand dune","image":"/scenes/desert-camel-3.png"},{"english":"At last, Cami reaches a green oasis full of cool water.","korean":"마침내, 카미는 시원한 물이 가득한 푸른 오아시스에 닿아요.","imagePrompt":"a happy camel arriving at a green desert oasis with water","image":"/scenes/desert-camel-4.png"}],"quiz":[{"type":"vocabulary","question":"What does 'tired' mean?","options":["신난","지친","배부른","추운"],"answerIndex":1,"explanation":"'tired'는 '지친'이에요."},{"type":"multiple_choice","question":"What does Cami reach at last?","options":["A city","A green oasis","A mountain","A ship"],"answerIndex":1,"explanation":"Cami reaches a green oasis full of water."}]}}]}]
