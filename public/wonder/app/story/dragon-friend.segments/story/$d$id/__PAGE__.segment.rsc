0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"dragon-friend","sampleStory":{"id":"dragon-friend","level":4,"cover":"/covers/dragon-friend.png","author":"지우","authorEmoji":"🐲","title":"The Dragon Who Loved Books","koreanTitle":"책을 사랑한 용","summary":"사람들이 무서워하던 용이 사실은 책벌레였어요. 한 아이가 그 비밀을 발견해요.","tags":["우정","책","오해"],"likes":312,"reads":2890,"recordings":64,"publishedAt":"2026-06-15","community":true,"keyWords":[{"word":"dragon","meaning":"용"},{"word":"library","meaning":"도서관"},{"word":"gentle","meaning":"다정한"},{"word":"secret","meaning":"비밀"}],"scenes":[{"english":"Everyone in the village was afraid of the dragon on the hill.","korean":"마을 사람들은 모두 언덕 위의 용을 무서워했어요.","imagePrompt":"villagers looking nervously at a dragon on a hill","image":"/scenes/dragon-friend-1.png"},{"english":"But a curious girl named Mina climbed up to see for herself.","korean":"하지만 호기심 많은 미나라는 소녀가 직접 보려고 올라갔어요.","imagePrompt":"a brave girl climbing a hill toward a dragon's cave","image":"/scenes/dragon-friend-2.png"},{"english":"Inside the cave, the gentle dragon was reading a huge book.","korean":"동굴 안에서, 다정한 용이 커다란 책을 읽고 있었어요.","imagePrompt":"a friendly dragon reading a big book inside a cozy cave","image":"/scenes/dragon-friend-3.png"},{"english":"From that day on, Mina and the dragon read stories together.","korean":"그날부터 미나와 용은 함께 이야기를 읽었어요.","imagePrompt":"a girl and a dragon reading a book together under a tree","image":"/scenes/dragon-friend-4.png"}],"quiz":[{"type":"multiple_choice","question":"What was the dragon really doing?","options":["Sleeping","Reading a book","Cooking","Flying"],"answerIndex":1,"explanation":"The gentle dragon was reading a huge book."},{"type":"vocabulary","question":"What does 'gentle' mean?","options":["무서운","다정한","빠른","시끄러운"],"answerIndex":1,"explanation":"'gentle'은 '다정한'이에요."}]}}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0gri1gur.tmm7.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"_01l1e5fvyfvps4qzlUfT"}
