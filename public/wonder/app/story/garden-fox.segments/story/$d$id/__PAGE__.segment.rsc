0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"garden-fox","sampleStory":{"id":"garden-fox","level":3,"cover":"/covers/garden-fox.png","author":"WonderTale","authorEmoji":"🦊","title":"The Fox Who Grew a Garden","koreanTitle":"정원을 가꾼 여우","summary":"참을성 없는 여우가 정원을 가꾸며 인내를 배워요.","tags":["인내","자연","성장"],"likes":142,"reads":1190,"recordings":24,"publishedAt":"2026-06-10","keyWords":[{"word":"garden","meaning":"정원"},{"word":"seed","meaning":"씨앗"},{"word":"patient","meaning":"참을성 있는"},{"word":"bloom","meaning":"꽃이 피다"}],"scenes":[{"english":"One spring morning, Fox planted tiny seeds in the soft soil.","korean":"어느 봄날 아침, 여우는 부드러운 흙에 작은 씨앗을 심었어요.","imagePrompt":"a fox planting seeds in a garden in spring","image":"/scenes/garden-fox-1.png"},{"english":"Every day Fox waited, but nothing seemed to happen.","korean":"매일 여우는 기다렸지만 아무 일도 일어나지 않는 것 같았어요.","imagePrompt":"a fox looking at empty soil, waiting","image":"/scenes/garden-fox-2.png"},{"english":"'Maybe I am not patient enough,' Fox sighed.","korean":"'내가 참을성이 부족한 걸까,' 여우는 한숨을 쉬었어요.","imagePrompt":"a sad fox sitting by a garden","image":"/scenes/garden-fox-3.png"},{"english":"Then one bright day, the whole garden bloomed with color!","korean":"그러던 어느 화창한 날, 온 정원이 색색으로 활짝 피었어요!","imagePrompt":"a fox surprised by a garden full of blooming flowers","image":"/scenes/garden-fox-4.png"}],"quiz":[{"type":"multiple_choice","question":"What lesson does Fox learn?","options":["To be patient","To run fast","To be loud","To sleep more"],"answerIndex":0,"explanation":"Fox learns to be patient while the garden grows."},{"type":"vocabulary","question":"What does 'bloom' mean?","options":["시들다","꽃이 피다","자르다","심다"],"answerIndex":1,"explanation":"'bloom'은 '꽃이 피다'예요."}]}}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0dt62zmkg_c9v.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@