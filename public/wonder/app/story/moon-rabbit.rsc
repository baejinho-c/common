12:["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L1b",null,{"id":"moon-rabbit","sampleStory":{"id":"moon-rabbit","level":2,"cover":"/covers/moon-rabbit.png","author":"WonderTale","authorEmoji":"🐰","title":"Rabbit's Trip to the Moon","koreanTitle":"토끼의 달나라 여행","summary":"호기심 많은 토끼가 작은 로켓을 타고 달로 떠나요.","tags":["우주","호기심","모험"],"likes":204,"reads":2210,"recordings":51,"publishedAt":"2026-05-20","keyWords":[{"word":"moon","meaning":"달"},{"word":"rocket","meaning":"로켓"},{"word":"star","meaning":"별"},{"word":"dream","meaning":"꿈"}],"scenes":[{"english":"Rabbit looks up at the bright moon and makes a wish.","korean":"토끼가 밝은 달을 보며 소원을 빌어요.","imagePrompt":"a white rabbit looking up at a bright moon at night","image":"/scenes/moon-rabbit-1.png"},{"english":"She builds a tiny rocket from wood and old cans.","korean":"토끼는 나무와 깡통으로 작은 로켓을 만들어요.","imagePrompt":"a rabbit building a small wooden rocket","image":"/scenes/moon-rabbit-2.png"},{"english":"Up and up she flies, past the twinkling stars.","korean":"토끼는 반짝이는 별들을 지나 위로 위로 날아가요.","imagePrompt":"a rabbit in a small rocket flying past stars","image":"/scenes/moon-rabbit-3.png"},{"english":"On the moon, she dances and dreams of new adventures.","korean":"달 위에서 토끼는 춤추며 새로운 모험을 꿈꿔요.","imagePrompt":"a happy rabbit dancing on the moon","image":"/scenes/moon-rabbit-4.png"}],"quiz":[{"type":"multiple_choice","question":"What does Rabbit build?","options":["A house","A tiny rocket","A boat","A kite"],"answerIndex":1,"explanation":"She builds a tiny rocket to fly to the moon."},{"type":"vocabulary","question":"What does 'star' mean?","options":["별","달","해","구름"],"answerIndex":0,"explanation":"'star'는 '별'이에요."}]}}]}]
