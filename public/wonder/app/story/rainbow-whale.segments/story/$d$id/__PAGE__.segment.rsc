0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"rainbow-whale","sampleStory":{"id":"rainbow-whale","level":5,"cover":"/covers/rainbow-whale.png","author":"서연","authorEmoji":"🐳","title":"The Whale Who Painted the Sky","koreanTitle":"하늘을 그린 고래","summary":"구름 사이를 헤엄치는 고래가 비 온 뒤 무지개를 선물하는 비밀을 가진 이야기.","tags":["상상력","희망","자연"],"likes":267,"reads":2040,"recordings":38,"publishedAt":"2026-06-18","community":true,"keyWords":[{"word":"whale","meaning":"고래"},{"word":"rainbow","meaning":"무지개"},{"word":"gentle","meaning":"온화한"},{"word":"wonder","meaning":"경이로움"}],"scenes":[{"english":"High above the sea, a gentle whale swam through the clouds.","korean":"바다 위 높은 곳에서, 온화한 고래가 구름 사이를 헤엄쳤어요.","imagePrompt":"a blue whale swimming through fluffy clouds","image":"/scenes/rainbow-whale-1.png"},{"english":"Wherever it went, soft colors trailed behind its great tail.","korean":"고래가 가는 곳마다, 커다란 꼬리 뒤로 부드러운 색들이 따라왔어요.","imagePrompt":"a whale leaving a trail of soft rainbow colors in the sky","image":"/scenes/rainbow-whale-2.png"},{"english":"After every storm, the whale painted a rainbow for the children below.","korean":"폭풍이 지날 때마다, 고래는 아래의 아이들을 위해 무지개를 그렸어요.","imagePrompt":"a whale painting a rainbow over a small boat with a child","image":"/scenes/rainbow-whale-3.png"}],"quiz":[{"type":"multiple_choice","question":"What does the whale paint after a storm?","options":["A cloud","A rainbow","A star","A house"],"answerIndex":1,"explanation":"The whale paints a rainbow for the children."},{"type":"vocabulary","question":"What does 'wonder' mean?","options":["경이로움","두려움","지루함","분노"],"answerIndex":0,"explanation":"'wonder'는 '경이로움'이에요."}]}}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0dt62zmkg_c9v.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"v7dBDiTRhu1PNfu