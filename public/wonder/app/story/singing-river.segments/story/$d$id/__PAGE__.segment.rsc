0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"mx-auto max-w-5xl px-4 py-10 sm:py-14","children":["$","$L2",null,{"id":"singing-river","sampleStory":{"id":"singing-river","level":5,"cover":"/covers/singing-river.png","author":"WonderTale","authorEmoji":"🎵","title":"The River That Sang","koreanTitle":"노래하는 강","summary":"골짜기를 흐르는 강이 부르는 노래가 메마른 땅에 다시 생명을 불러와요.","tags":["자연","희망","음악"],"likes":176,"reads":1420,"recordings":24,"publishedAt":"2026-06-16","keyWords":[{"word":"river","meaning":"강"},{"word":"valley","meaning":"골짜기"},{"word":"melody","meaning":"선율"},{"word":"alive","meaning":"살아 있는"}],"scenes":[{"english":"Through the green valley flowed a river with a gentle song.","korean":"푸른 골짜기 사이로 부드러운 노래를 부르는 강이 흘렀어요.","imagePrompt":"a sparkling river flowing through a green valley","image":"/scenes/singing-river-1.png"},{"english":"Its melody floated over the hills like silver bells.","korean":"그 선율은 은빛 종소리처럼 언덕 위로 퍼졌어요.","imagePrompt":"musical notes floating above a river over hills","image":"/scenes/singing-river-2.png"},{"english":"Wherever the song reached, the dry land came alive again.","korean":"노래가 닿는 곳마다, 메마른 땅이 다시 살아났어요.","imagePrompt":"dry land turning green and blooming near a river","image":"/scenes/singing-river-3.png"},{"english":"Animals gathered by the bank to listen and to drink.","korean":"동물들이 강가에 모여 노래를 듣고 물을 마셨어요.","imagePrompt":"animals gathering by a river bank listening","image":"/scenes/singing-river-4.png"}],"quiz":[{"type":"vocabulary","question":"What does 'alive' mean?","options":["살아 있는","조용한","차가운","어두운"],"answerIndex":0,"explanation":"'alive'는 '살아 있는'이에요."},{"type":"multiple_choice","question":"What happens where the song reaches?","options":["It snows","The dry land comes alive","The river stops","Night falls"],"answerIndex":1,"explanation":"The dry land comes alive again wherever the song reaches."}]}}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0gri1gur.tmm7.js","async":true}]],["$","$L3",null,{"ch